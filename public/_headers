# Cloudflare Pages cache headers

# Content-hashed Astro assets — safe to cache for 1 year (immutable)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Favicons — 1 week
/favicon.ico
  Cache-Control: public, max-age=604800

/favicon.svg
  Cache-Control: public, max-age=604800

# robots.txt — 1 day
/robots.txt
  Cache-Control: public, max-age=86400

# Sitemaps — 1 day (re-generated on deploy)
/sitemap*.xml
  Cache-Control: public, max-age=86400

# Tool pages — cache 1 hour, serve stale up to 24h while revalidating in background
# Tools are static Astro HTML; content only changes on deploy
/tools/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# HTML pages — browser always revalidates; Cloudflare edge caches for 1h (stale-while-revalidate 24h)
/*
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400, must-revalidate

# Security headers (applied to all routes)
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=(), geolocation=(), camera=(), microphone=()
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Embedder-Policy: unsafe-none

# External scripts: help browser establish connections faster
# Cloudflare Insights beacon
https://static.cloudflareinsights.com/*
  Cross-Origin: anonymous

# Google AdSense
https://pagead2.googlesyndication.com/*
  Cross-Origin: anonymous

# Google Fonts (if added in future)
/https://fonts\.googleapis\.com/*
  Cross-Origin: anonymous

https://fonts\.gstatic\.com/*
  Cross-Origin: anonymous
