# Cloudflare Pages cache headers
# Last updated: 2026-03-25 — API no-cache rules + VIC-504 audit

# Content-hashed Astro assets — safe to cache for 1 year (immutable)
# Includes JS chunks, CSS bundles, web-vitals, preact vendor
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# OG images — 30 days (rarely change)
/og-*.png
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

/og-*.svg
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

/og-tools/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

# Favicons — 1 week
/favicon.ico
  Cache-Control: public, max-age=604800

/favicon.svg
  Cache-Control: public, max-age=604800

# robots.txt — 1 day
/robots.txt
  Cache-Control: public, max-age=86400

# Sitemaps — 1 day (re-generated on deploy)
/sitemap*.xml
  Cache-Control: public, max-age=86400

# API routes — never cache; dynamic responses must not be served stale
# Applies to all /api/* Cloudflare Pages Functions
/api/*
  Cache-Control: no-store

# Tool pages — cache 4h at edge, serve stale up to 24h while revalidating
# Tools are static Astro HTML; content only changes on deploy
/tools/*
  Cache-Control: public, max-age=0, s-maxage=14400, stale-while-revalidate=86400

# Blog articles — cache 2h at edge, serve stale up to 48h
/blog/*
  Cache-Control: public, max-age=0, s-maxage=7200, stale-while-revalidate=172800

# HTML pages — browser always revalidates; Cloudflare edge caches for 1h (stale-while-revalidate 24h)
/*
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400, must-revalidate

# Security headers (applied to all routes)
# Last security audit: 2026-04-04 — added HSTS + CSP-Report-Only (VIC-1276)
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=(), geolocation=(), camera=(), microphone=()
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Embedder-Policy: unsafe-none
  # Allow web-vitals RUM beacons to read timing data for accurate LCP/CLS measurement
  Timing-Allow-Origin: *
  # HSTS: enforce HTTPS for 2 years, include subdomains, eligible for preload list
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  # CSP in report-only mode — validates all sources without breaking the site.
  # Covers: Cloudflare Analytics, Google AdSense, GA4, inline JSON-LD, Astro inline styles.
  # TODO: Switch to Content-Security-Policy once report-only confirms no violations.
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com https://pagead2.googlesyndication.com https://www.googletagmanager.com https://tpc.googlesyndication.com https://googleads.g.doubleclick.net https://adservice.google.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; connect-src 'self' https://static.cloudflareinsights.com https://pagead2.googlesyndication.com https://*.google-analytics.com https://*.analytics.google.com https://*.googletagmanager.com https://www.googleadservices.com; frame-src 'self' https://googleads.g.doubleclick.net https://tpc.googlesyndication.com; font-src 'self' data:; media-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self' https://vicnail.gumroad.com

# External scripts: help browser establish connections faster
# Cloudflare Insights beacon
https://static.cloudflareinsights.com/*
  Cross-Origin: anonymous

# Google AdSense
https://pagead2.googlesyndication.com/*
  Cross-Origin: anonymous

# Google Fonts (if added in future)
/https://fonts\.googleapis\.com/*
  Cross-Origin: anonymous

https://fonts\.gstatic\.com/*
  Cross-Origin: anonymous
