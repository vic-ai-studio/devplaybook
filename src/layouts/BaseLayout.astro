---
import NewsletterForm from '../components/NewsletterForm.astro';

interface Props {
  title: string;
  description: string;
  tool?: string;
  noDefaultJsonLd?: boolean;
  noindex?: boolean;
  ogImage?: string;
}

const { title, description, tool, noDefaultJsonLd, noindex, ogImage } = Astro.props;
const siteUrl = 'https://devplaybook.cc';
const fullTitle = `${title} | DevPlaybook`;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = ogImage ? new URL(ogImage, siteUrl).href : `${siteUrl}/og-default.svg`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Preconnect to external origins for faster resource loading (Core Web Vitals) -->
    <link rel="preconnect" href="https://static.cloudflareinsights.com" />
    <link rel="dns-prefetch" href="https://static.cloudflareinsights.com" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="DevPlaybook" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={fullTitle} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={fullTitle} />

    <!-- JSON-LD (skipped when page provides its own) -->
    {!noDefaultJsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebApplication",
        "name": fullTitle,
        "description": description,
        "url": canonicalUrl,
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "Any",
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
        ...(tool ? { "featureList": tool } : {})
      })} />
    )}

    <style is:global>
      @import "../styles/global.css";
    </style>

    <!-- Cloudflare Web Analytics (token set via PUBLIC_CF_ANALYTICS_TOKEN env var) -->
    {import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN && (
      <script defer src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token":"${import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN}"}`}></script>
    )}

    <!-- Google AdSense Auto-ads (entry point 1/3: global head)
         Activate by setting PUBLIC_ADSENSE_PUBLISHER_ID in Cloudflare Pages env vars
         Value: ca-pub-XXXXXXXXXXXXXXXXX (from AdSense account) -->
    {import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID && (
      <script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID}`} crossorigin="anonymous"></script>
    )}
  </head>
  <body class="bg-bg text-text min-h-screen">
  <!-- Exit-intent scroll banner (shown at 80% scroll depth on tool pages) -->
  <div id="exit-banner" class="fixed bottom-0 left-0 right-0 z-50 hidden">
    <div class="bg-bg-card border-t border-primary/40 shadow-2xl px-6 py-4">
      <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>
          <p class="font-semibold text-sm">Before you go — grab the full guide 🚀</p>
          <p class="text-text-muted text-xs">13 premium products (boilerplates, scripts, AI toolkits) in one bundle</p>
        </div>
        <div class="flex items-center gap-3 shrink-0">
          <span class="text-text-muted line-through text-sm">$241</span>
          <a
            href="https://vicnail.gumroad.com/l/devplaybook-pro-bundle"
            target="_blank"
            rel="noopener noreferrer"
            data-track="exit_banner_cta"
            data-product-name="DevPlaybook Pro Bundle"
            data-product-price="79"
            class="bg-primary hover:bg-primary-dark text-white font-semibold px-5 py-2.5 rounded-lg text-sm transition-colors whitespace-nowrap"
          >
            Get DevPlaybook Pro — $79 →
          </a>
          <button id="exit-banner-close" aria-label="Dismiss" class="text-text-muted hover:text-text text-xl leading-none">×</button>
        </div>
      </div>
    </div>
  </div>
    <nav class="border-b border-border px-6 py-4">
      <div class="max-w-6xl mx-auto flex items-center justify-between">
        <a href="/" class="text-xl font-bold text-primary">DevPlaybook</a>
        <div class="flex gap-4 text-sm text-text-muted">
          <a href="/products" class="hover:text-text font-medium text-primary">Products</a>
          <a href="/bundles" class="hover:text-text font-semibold text-primary border border-primary/40 px-2.5 py-0.5 rounded-lg">Pro Bundle</a>
          <a href="/blog" class="hover:text-text font-medium text-primary">Blog</a>
          <a href="/tools" class="hover:text-text font-medium text-primary">Tools</a>
          <a href="/my-dev-setup" class="hover:text-text font-medium text-primary">Setups</a>
          <a href="/tools/json-diff-viewer" class="hover:text-text">JSON Diff</a>
          <a href="/tools/regex-tester" class="hover:text-text">Regex</a>
          <a href="/tools/uuid-generator" class="hover:text-text">UUID</a>
          <a href="/tools/api-request-builder" class="hover:text-text">API Builder</a>
          <a href="/tools/cron-generator" class="hover:text-text">Cron</a>
          <a href="/tools/git-command-builder" class="hover:text-text">Git</a>
          <a href="/ai-tools" class="hover:text-text font-medium text-yellow-400">AI Tools</a>
        </div>
      </div>
    </nav>
    <main class="max-w-6xl mx-auto px-6 py-8">
      <slot />
    </main>
    <footer class="border-t border-border px-6 py-8 mt-12 text-text-muted text-sm">
      <div class="max-w-6xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between gap-6 mb-6">
          <div>
            <p class="font-semibold text-text mb-2">DevPlaybook</p>
            <p>Free, fast, privacy-first developer tools.</p>
          </div>
          <div class="flex gap-8">
            <div>
              <p class="font-semibold text-text mb-2">Tools</p>
              <ul class="space-y-1">
                <li><a href="/tools/jwt-decoder" class="hover:text-primary">JWT Decoder</a></li>
                <li><a href="/tools/http-status-codes" class="hover:text-primary">HTTP Status Codes</a></li>
                <li><a href="/tools/cors-tester" class="hover:text-primary">CORS Tester</a></li>
                <li><a href="/tools/uuid-generator" class="hover:text-primary">UUID Generator</a></li>
                <li><a href="/tools/json-diff-viewer" class="hover:text-primary">JSON Diff</a></li>
                <li><a href="/tools/regex-tester" class="hover:text-primary">Regex Tester</a></li>
                <li><a href="/tools/api-request-builder" class="hover:text-primary">API Builder</a></li>
                <li><a href="/tools/cron-generator" class="hover:text-primary">Cron</a></li>
                <li><a href="/tools/git-command-builder" class="hover:text-primary">Git</a></li>
                <li><a href="/tools/docker-compose-generator" class="hover:text-primary">Docker</a></li>
                <li><a href="/tools/pomodoro-timer" class="hover:text-primary">Pomodoro Timer</a></li>
                <li><a href="/ai-tools" class="hover:text-primary">AI Tools Comparison</a></li>
              </ul>
            </div>
            <div>
              <p class="font-semibold text-text mb-2">Products</p>
              <ul class="space-y-1">
                <li><a href="/products" class="hover:text-primary">All Products</a></li>
                <li><a href="/bundles" class="hover:text-primary font-semibold text-primary">Pro Bundle — $79</a></li>
              </ul>
            </div>
            <div>
              <p class="font-semibold text-text mb-2">Blog</p>
              <ul class="space-y-1">
                <li><a href="/blog" class="hover:text-primary">All Articles</a></li>
              </ul>
            </div>
            <div>
              <p class="font-semibold text-text mb-2">Community</p>
              <ul class="space-y-1">
                <li><a href="/my-dev-setup" class="hover:text-primary">Dev Setups</a></li>
              </ul>
            </div>
          </div>
        </div>
        <NewsletterForm source="footer" />
        <p class="text-center pt-4">&copy; {new Date().getFullYear()} DevPlaybook. Free developer tools.</p>
      </div>
    </footer>

    <!-- Exit-intent scroll banner logic -->
    <script is:inline>
      (function() {
        var banner = document.getElementById('exit-banner');
        var closeBtn = document.getElementById('exit-banner-close');
        if (!banner || !closeBtn) return;
        var shown = false;
        var dismissed = false;
        // Only show on /tools/* pages
        if (!/^\/tools\//.test(location.pathname)) return;
        // Don't show if dismissed this session
        try { if (sessionStorage.getItem('exit_banner_dismissed')) return; } catch(e) {}
        function onScroll() {
          if (shown || dismissed) return;
          var scrolled = window.scrollY + window.innerHeight;
          var total = document.documentElement.scrollHeight;
          if (total > 0 && scrolled / total >= 0.8) {
            banner.classList.remove('hidden');
            shown = true;
          }
        }
        window.addEventListener('scroll', onScroll, { passive: true });
        closeBtn.addEventListener('click', function() {
          banner.classList.add('hidden');
          dismissed = true;
          try { sessionStorage.setItem('exit_banner_dismissed', '1'); } catch(e) {}
        });
      })();
    </script>

    <!-- Pageview tracking (custom KV analytics) -->
    <script is:inline>
      (function() {
        try {
          navigator.sendBeacon('/api/track', JSON.stringify({ path: location.pathname }));
        } catch (e) {}
      })();
    </script>

    <!-- Privacy-first localStorage analytics (no external API, VIC-165) -->
    <script is:inline>
      (function() {
        // Helper: append event to pc_events (keeps last 500)
        window.pcTrack = function(event, props) {
          try {
            var evts = JSON.parse(localStorage.getItem('pc_events') || '[]');
            evts.push({ event: event, props: props || {}, ts: Date.now() });
            if (evts.length > 500) evts = evts.slice(-500);
            localStorage.setItem('pc_events', JSON.stringify(evts));
            console.log('[pc]', event, props);
          } catch(e) {}
        };

        // Task 3: page view tracking — store pathname + timestamp
        (function() {
          try {
            var views = JSON.parse(localStorage.getItem('pc_pages_visited') || '[]');
            views.push({ path: location.pathname, ts: Date.now(), mobile: /Mobi|Android/i.test(navigator.userAgent) });
            if (views.length > 1000) views = views.slice(-1000);
            localStorage.setItem('pc_pages_visited', JSON.stringify(views));
          } catch(e) {}
        })();

        // Task 1: click event tracking
        document.addEventListener('click', function(e) {
          var el = e.target.closest('[data-track]');
          if (!el) return;
          var t = el.dataset.track;
          var props = {};
          if (el.dataset.productName) props.product_name = el.dataset.productName;
          if (el.dataset.productPrice) props.product_price = el.dataset.productPrice;

          if (t === 'gumroad_click') {
            window.pcTrack('gumroad_click', props);
          } else if (t === 'pro_checkout_click' || t === 'pro_cta_click') {
            window.pcTrack('pro_cta_click', { source: t });
          } else if (t === 'bundle_hero_cta' || t === 'bundle_bottom_cta' || t === 'bundle_cta_click' || t === 'exit_banner_cta') {
            window.pcTrack('pro_cta_click', { source: t });
          }
        });

        // Task 1: newsletter submit tracking
        document.addEventListener('submit', function(e) {
          var form = e.target.closest('form[data-track-submit]');
          if (!form) return;
          var s = form.dataset.trackSubmit || '';
          if (s.includes('newsletter')) {
            window.pcTrack('newsletter_submit', { source: s });
          }
        });
      })();
    </script>

    <!-- Core Web Vitals tracking (LCP, CLS, INP, FCP, TTFB via web-vitals v5) -->
    <script>
      import { onLCP, onCLS, onINP, onFCP, onTTFB } from 'web-vitals';
      function sendVital({ name, value, rating }) {
        try {
          navigator.sendBeacon('/api/vitals', JSON.stringify({
            name, value, rating, path: location.pathname
          }));
        } catch (e) {}
      }
      onLCP(sendVital);
      onCLS(sendVital);
      onINP(sendVital);
      onFCP(sendVital);
      onTTFB(sendVital);
    </script>

    <!-- Conversion event tracking -->
    <script is:inline>
      window.dpTrack = function(event, props) {
        if (window.zaraz && window.zaraz.track) {
          window.zaraz.track(event, props || {});
        }
      };

      document.addEventListener('click', function(e) {
        var el = e.target.closest('[data-track]');
        if (!el) return;
        var props = {};
        if (el.dataset.productName) props.product = el.dataset.productName;
        if (el.dataset.productPrice) props.price = el.dataset.productPrice;
        if (el.dataset.formName) props.form = el.dataset.formName;
        window.dpTrack(el.dataset.track, props);
      });

      document.addEventListener('submit', function(e) {
        var form = e.target.closest('form[data-track-submit]');
        if (!form) return;
        window.dpTrack(form.dataset.trackSubmit, { form: form.id || '' });
      });
    </script>
  </body>
</html>
