---
import NewsletterForm from '../components/NewsletterForm.astro';

interface Props {
  title: string;
  description: string;
  tool?: string;
  noDefaultJsonLd?: boolean;
  noindex?: boolean;
  ogImage?: string;
  faq?: Array<{ question: string; answer: string }>;
}

const { title, description, tool, noDefaultJsonLd, noindex, ogImage, faq } = Astro.props;
const siteUrl = 'https://devplaybook.cc';
const fullTitle = `${title} | DevPlaybook`;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;

// Auto-select category OG image if no custom one provided
function getDefaultOgImage(pathname: string): string {
  if (pathname.startsWith('/tools')) return '/og-tools.svg';
  if (pathname.startsWith('/blog')) return '/og-blog.svg';
  return '/og-default.svg';
}
const ogImageUrl = ogImage
  ? new URL(ogImage, siteUrl).href
  : `${siteUrl}${getDefaultOgImage(Astro.url.pathname)}`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- theme-color: speeds up mobile Chrome initial paint (avoids white flash) -->
    <meta name="theme-color" content="#0f172a" />

    <!-- Preconnect to external origins for faster resource loading (Core Web Vitals) -->
    <link rel="preconnect" href="https://static.cloudflareinsights.com" />
    <link rel="dns-prefetch" href="https://static.cloudflareinsights.com" />
    {import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID && (
      <>
        <link rel="preconnect" href="https://pagead2.googlesyndication.com" />
        <link rel="dns-prefetch" href="https://pagead2.googlesyndication.com" />
      </>
    )}
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {import.meta.env.PUBLIC_GSC_SITE_VERIFICATION && (
      <meta name="google-site-verification" content={import.meta.env.PUBLIC_GSC_SITE_VERIFICATION} />
    )}

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="DevPlaybook" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={fullTitle} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={fullTitle} />

    <!-- JSON-LD (skipped when page provides its own) -->
    {!noDefaultJsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": title,
        "description": description,
        "url": canonicalUrl,
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "Any",
        "image": ogImageUrl,
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
        ...(tool ? { "featureList": tool } : {})
      })} />
    )}

    <!-- BreadcrumbList JSON-LD for all non-home pages -->
    {Astro.url.pathname !== '/' && (
      <script type="application/ld+json" set:html={JSON.stringify((() => {
        const parts = Astro.url.pathname.replace(/\/$/, '').split('/').filter(Boolean);
        const items = [{ name: 'DevPlaybook', url: siteUrl }];
        let path = '';
        for (const part of parts) {
          path += '/' + part;
          const name = part.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
          items.push({ name, url: siteUrl + path });
        }
        return {
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          "itemListElement": items.map((item, i) => ({
            "@type": "ListItem",
            "position": i + 1,
            "name": i === items.length - 1 ? title : item.name,
            "item": item.url
          }))
        };
      })())} />
    )}

    {faq && faq.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faq.map((item) => ({
          "@type": "Question",
          "name": item.question,
          "acceptedAnswer": { "@type": "Answer", "text": item.answer }
        }))
      })} />
    )}

    <style is:global>
      @import "../styles/global.css";
    </style>

    <!-- Cloudflare Web Analytics (token set via PUBLIC_CF_ANALYTICS_TOKEN env var) -->
    {import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN && (
      <script defer src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token":"${import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN}"}`}></script>
    )}

    <!-- Google AdSense Auto-ads (entry point 1/3: global head)
         Activate by setting PUBLIC_ADSENSE_PUBLISHER_ID in Cloudflare Pages env vars
         Value: ca-pub-XXXXXXXXXXXXXXXXX (from AdSense account) -->
    {import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID && (
      <script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID}`} crossorigin="anonymous"></script>
    )}

    <!-- Google Analytics 4 (set PUBLIC_GA4_MEASUREMENT_ID in Cloudflare Pages env vars) -->
    {import.meta.env.PUBLIC_GA4_MEASUREMENT_ID && (
      <>
        <link rel="preconnect" href="https://www.googletagmanager.com" />
        <link rel="dns-prefetch" href="https://www.google-analytics.com" />
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA4_MEASUREMENT_ID}`}></script>
        <script is:inline define:vars={{ ga4Id: import.meta.env.PUBLIC_GA4_MEASUREMENT_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', ga4Id, {
            send_page_view: true,
            cookie_flags: 'SameSite=None;Secure'
          });
          window._ga4Id = ga4Id;
        </script>
      </>
    )}
  </head>
  <body class="bg-bg text-text min-h-screen">
