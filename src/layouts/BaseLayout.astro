    <!-- Exit-intent newsletter popup logic (blog pages only) -->
    <script is:inline>
      (function() {
        var popup = document.getElementById('newsletter-exit-popup');
        var closeBtn = document.getElementById('newsletter-popup-close');
        var backdrop = document.getElementById('newsletter-popup-backdrop');
        var form = document.getElementById('newsletter-popup-form');
        var msg = document.getElementById('newsletter-popup-msg');
        if (!popup || !form) return;
        // Only on blog pages
        if (!/^\/blog\//.test(location.pathname)) return;
        // Don't show if already dismissed or subscribed this session
        try { if (sessionStorage.getItem('newsletter_popup_dismissed')) return; } catch(e) {}

        var shown = false;
        function showPopup() {
          if (shown) return;
          shown = true;
          popup.classList.remove('hidden');
        }
        function hidePopup() {
          popup.classList.add('hidden');
          try { sessionStorage.setItem('newsletter_popup_dismissed', '1'); } catch(e) {}
        }

        // Show on mouse moving toward top (exit-intent)
        document.addEventListener('mouseleave', function(e) {
          if (e.clientY <= 20) showPopup();
        });
        // Also show at 75% scroll depth as fallback
        window.addEventListener('scroll', function() {
          if (shown) return;
          var pct = (window.scrollY + window.innerHeight) / document.documentElement.scrollHeight;
          if (pct >= 0.75) showPopup();
        }, { passive: true });

        if (closeBtn) closeBtn.addEventListener('click', hidePopup);
        if (backdrop) backdrop.addEventListener('click', hidePopup);

        form.addEventListener('submit', async function(e) {
          e.preventDefault();
          var emailInput = form.querySelector('input[type="email"]');
          var submitBtn = form.querySelector('button[type="submit"]');
          var email = emailInput.value.trim();
          submitBtn.disabled = true;
          submitBtn.textContent = 'Subscribing...';
          try {
            var res = await fetch('/api/newsletter/subscribe', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email: email, source: 'exit_popup' }),
            });
            var data = await res.json();
            if (data.success) {
              form.innerHTML = '<p class="text-green-400 font-medium text-center">You\'re in! 🎉 Check your inbox soon.</p>';
              try { window.pcTrack && window.pcTrack('newsletter_signup', { source: 'exit_popup' }); } catch(te) {}
              try { window.dpTrack && window.dpTrack('newsletter_signup', { source: 'exit_popup' }); } catch(te) {}
              setTimeout(hidePopup, 2000);
            } else {
              submitBtn.disabled = false;
              submitBtn.textContent = 'Subscribe Free';
              msg.textContent = data.error || 'Something went wrong.';
              msg.style.color = '#f87171';
              msg.classList.remove('hidden');
            }
          } catch(err) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Subscribe Free';
            msg.textContent = 'Network error. Please try again.';
            msg.style.color = '#f87171';
            msg.classList.remove('hidden');
          }
        });
      })();
    </script>

    <!-- Exit-intent scroll banner logic -->
    <script is:inline>
      (function() {
        var banner = document.getElementById('exit-banner');
        var closeBtn = document.getElementById('exit-banner-close');
        if (!banner || !closeBtn) return;
        var shown = false;
        var dismissed = false;
        // Only show on /tools/* pages
        if (!/^\/tools\//.test(location.pathname)) return;
        // Don't show if dismissed this session
        try { if (sessionStorage.getItem('exit_banner_dismissed')) return; } catch(e) {}
        function onScroll() {
          if (shown || dismissed) return;
          var scrolled = window.scrollY + window.innerHeight;
          var total = document.documentElement.scrollHeight;
          if (total > 0 && scrolled / total >= 0.8) {
            banner.classList.remove('hidden');
            shown = true;
          }
        }
        window.addEventListener('scroll', onScroll, { passive: true });
        closeBtn.addEventListener('click', function() {
          banner.classList.add('hidden');
          dismissed = true;
          try { sessionStorage.setItem('exit_banner_dismissed', '1'); } catch(e) {}
        });
      })();
    </script>

    <!-- Pageview tracking (custom KV analytics) -->
    <script is:inline>
      (function() {
        try {
          navigator.sendBeacon('/api/track', JSON.stringify({ path: location.pathname }));
        } catch (e) {}
      })();
    </script>

    <!-- Privacy-first localStorage analytics (no external API, VIC-165) -->
    <script is:inline>
      (function() {
        // Helper: append event to pc_events (keeps last 500)
        window.pcTrack = function(event, props) {
          try {
            var evts = JSON.parse(localStorage.getItem('pc_events') || '[]');
            evts.push({ event: event, props: props || {}, ts: Date.now() });
            if (evts.length > 500) evts = evts.slice(-500);
            localStorage.setItem('pc_events', JSON.stringify(evts));
            console.log('[pc]', event, props);
          } catch(e) {}
        };

        // Task 3: page view tracking — store pathname + timestamp
        (function() {
          try {
            var views = JSON.parse(localStorage.getItem('pc_pages_visited') || '[]');
            views.push({ path: location.pathname, ts: Date.now(), mobile: /Mobi|Android/i.test(navigator.userAgent) });
            if (views.length > 1000) views = views.slice(-1000);
            localStorage.setItem('pc_pages_visited', JSON.stringify(views));
          } catch(e) {}
        })();

        // Task 1: click event tracking
        document.addEventListener('click', function(e) {
          var el = e.target.closest('[data-track]');
          if (!el) return;
          var t = el.dataset.track;
          var props = {};
          if (el.dataset.productName) props.product_name = el.dataset.productName;
          if (el.dataset.productPrice) props.product_price = el.dataset.productPrice;

          if (t === 'gumroad_click') {
            window.pcTrack('gumroad_click', props);
          } else if (t === 'pro_checkout_click' || t === 'pro_cta_click') {
            window.pcTrack('pro_cta_click', { source: t });
          } else if (t === 'bundle_hero_cta' || t === 'bundle_bottom_cta' || t === 'bundle_cta_click' || t === 'exit_banner_cta') {
            window.pcTrack('pro_cta_click', { source: t });
          }
        });

        // Task 1: newsletter submit tracking
        document.addEventListener('submit', function(e) {
          var form = e.target.closest('form[data-track-submit]');
          if (!form) return;
          var s = form.dataset.trackSubmit || '';
          if (s.includes('newsletter')) {
            window.pcTrack('newsletter_submit', { source: s });
          }
        });
      })();
    </script>

    <!-- Core Web Vitals tracking (LCP, CLS, INP, FCP, TTFB via web-vitals v5) -->
    <script>
      import { onLCP, onCLS, onINP, onFCP, onTTFB } from 'web-vitals';
      function sendVital({ name, value, rating }) {
        try {
          navigator.sendBeacon('/api/vitals', JSON.stringify({
            name, value, rating, path: location.pathname
          }));
        } catch (e) {}
      }
      onLCP(sendVital);
      onCLS(sendVital);
      onINP(sendVital);
      onFCP(sendVital);
      onTTFB(sendVital);
    </script>

    <!-- BuyMeACoffee floating widget (set PUBLIC_BMC_USERNAME env var to activate) -->
    {import.meta.env.PUBLIC_BMC_USERNAME && (
      <script is:inline
        data-name="BMC-Widget"
        data-cfasync="false"
        src="https://cdnjs.buymeacoffee.com/1.0.0/widget.prod.min.js"
        data-id={import.meta.env.PUBLIC_BMC_USERNAME}
        data-description="Support DevPlaybook"
        data-message="If these free tools saved you time, buy me a coffee!"
        data-color="#FFDD00"
        data-position="Right"
        data-x_margin="18"
        data-y_margin="18">
      </script>
    )}

    <!-- Conversion event tracking (Zaraz + GA4) -->
    <script is:inline>
      window.dpTrack = function(event, props) {
        if (window.zaraz && window.zaraz.track) {
          window.zaraz.track(event, props || {});
        }
      };

      // GA4 helper — fires event if gtag is available
      window.ga4Track = function(eventName, params) {
        try {
          if (typeof gtag === 'function') {
            gtag('event', eventName, params || {});
          }
        } catch(e) {}
      };

      document.addEventListener('click', function(e) {
        var el = e.target.closest('[data-track]');
        if (!el) return;
        var props = {};
        if (el.dataset.productName) props.product = el.dataset.productName;
        if (el.dataset.productPrice) props.price = Number(el.dataset.productPrice) || el.dataset.productPrice;
        if (el.dataset.formName) props.form = el.dataset.formName;
        var t = el.dataset.track;
        window.dpTrack(t, props);
        // GA4 conversion events
        if (t === 'pro_checkout_click' || t === 'pro_cta_click' || t === 'bundle_hero_cta' || t === 'bundle_bottom_cta' || t === 'bundle_cta_click' || t === 'exit_banner_cta') {
          window.ga4Track('pro_cta_click', { source: t, currency: 'USD', value: props.price || 0, item_name: props.product || 'Pro' });
        } else if (t === 'gumroad_click') {
          window.ga4Track('begin_checkout', { currency: 'USD', value: props.price || 0, item_name: props.product || '' });
        } else if (t === 'bmc_click') {
          window.ga4Track('bmc_click', {});
        }
      });

      document.addEventListener('submit', function(e) {
        var form = e.target.closest('form[data-track-submit]');
        if (!form) return;
        var s = form.dataset.trackSubmit || '';
        window.dpTrack(s, { form: form.id || '' });
        if (s.includes('newsletter')) {
          window.ga4Track('newsletter_signup', { source: s });
        }
      });
    </script>

    <!-- GA4 article read-time tracking (blog pages only) -->
    <script is:inline>
      (function() {
        if (!/^\/blog\//.test(location.pathname)) return;
        var start = Date.now();
        var milestones = [30, 60, 120, 180];
        var fired = {};
        var iv = setInterval(function() {
          var elapsed = Math.round((Date.now() - start) / 1000);
          for (var i = 0; i < milestones.length; i++) {
            var m = milestones[i];
            if (!fired[m] && elapsed >= m) {
              fired[m] = true;
              try {
                if (typeof gtag === 'function') {
                  gtag('event', 'article_read_time', { seconds: m, path: location.pathname });
                }
              } catch(e) {}
            }
          }
          if (fired[180]) clearInterval(iv);
        }, 10000);
        // Also fire total read time on page unload
        window.addEventListener('pagehide', function() {
          var total = Math.round((Date.now() - start) / 1000);
          try {
            if (typeof gtag === 'function') {
              gtag('event', 'article_exit', { read_seconds: total, path: location.pathname });
            }
          } catch(e) {}
        });
      })();
    </script>
  </body>
</html>
