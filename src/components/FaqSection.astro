---
interface Props {
  faq: Array<{ question: string; answer: string }>;
  title?: string;
}

const { faq, title = "Frequently Asked Questions" } = Astro.props;
---

{faq && faq.length > 0 && (
  <section class="mt-12 pt-8 border-t border-gray-700">
    <h2 class="text-2xl font-bold mb-6 text-white">{title}</h2>
    <div class="space-y-3">
      {faq.map((item) => (
        <details class="bg-gray-800/50 border border-gray-700 rounded-lg p-4 group cursor-pointer hover:border-blue-500/50 transition-colors">
          <summary class="font-semibold text-white flex items-center justify-between cursor-pointer select-none list-none">
            <span>{item.question}</span>
            <span class="text-blue-400 group-open:rotate-180 transition-transform text-sm ml-2 shrink-0">&#9660;</span>
          </summary>
          <p class="text-gray-300 mt-3 text-sm leading-relaxed">{item.answer}</p>
        </details>
      ))}
    </div>
  </section>
)}
