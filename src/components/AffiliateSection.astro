---
/**
 * AffiliateSection.astro
 * Tasteful affiliate/sponsor section for tool pages.
 *
 * NOTE FOR VIC: Replace affiliate URLs below with your actual referral links
 * once you have joined each program:
 *   - DigitalOcean: digitalocean.com/referral-program
 *   - Railway: railway.app (Dashboard → Settings → Referral)
 *   - Supabase: supabase.com/docs/guides/resources/supabase-partners
 *   - Vercel: vercel.com/referral-program
 *   - Hostinger: hostinger.com/affiliate-program
 */

export type AffiliateCategory = 'deployment' | 'database' | 'hosting' | 'cicd';

interface Props {
  /** Which set of affiliates to show based on the tool's category */
  category: AffiliateCategory | AffiliateCategory[];
}

const { category } = Astro.props;
const categories = Array.isArray(category) ? category : [category];

interface Affiliate {
  name: string;
  tagline: string;
  badge: string;
  href: string;
  cta: string;
  categories: AffiliateCategory[];
  highlight: string;
}

const affiliates: Affiliate[] = [
  {
    name: 'Vercel',
    tagline: 'Deploy frontend apps in seconds. Zero config, global CDN.',
    badge: '▲',
    href: 'https://vercel.com/?utm_source=devplaybook&utm_medium=affiliate&utm_campaign=tools',
    cta: 'Deploy free →',
    categories: ['deployment', 'cicd'],
    highlight: 'Free tier available',
  },
  {
    name: 'Railway',
    tagline: 'Deploy any app or database with one click. No DevOps required.',
    badge: '🚂',
    href: 'https://railway.app?utm_source=devplaybook&utm_medium=affiliate',
    cta: 'Start free →',
    categories: ['deployment', 'database'],
    highlight: '$5 free credit',
  },
  {
    name: 'Supabase',
    tagline: 'Open-source Firebase alternative. Postgres + Auth + Storage.',
    badge: '⚡',
    href: 'https://supabase.com/?utm_source=devplaybook&utm_medium=affiliate',
    cta: 'Start for free →',
    categories: ['database'],
    highlight: 'Free tier forever',
  },
  {
    name: 'DigitalOcean',
    tagline: 'Simple cloud hosting for developers. VPS, managed databases, and more.',
    badge: '🌊',
    href: 'https://www.digitalocean.com/?refcode=REPLACE_WITH_YOUR_REFCODE&utm_campaign=Referral_Invite&utm_medium=Referral_Program&utm_source=devplaybook',
    cta: 'Get $200 free →',
    categories: ['deployment', 'hosting'],
    highlight: '$200 credit for new users',
  },
  {
    name: 'Hostinger',
    tagline: 'Fast, affordable web hosting. WordPress, VPS, and domain names.',
    badge: '🏠',
    href: 'https://www.hostinger.com/?utm_source=devplaybook&utm_medium=affiliate',
    cta: 'View plans →',
    categories: ['hosting'],
    highlight: 'From $2.99/mo',
  },
];

const visibleAffiliates = affiliates.filter(a =>
  a.categories.some(c => categories.includes(c))
);
---

{visibleAffiliates.length > 0 && (
  <section class="mt-8 mb-4">
    <div class="flex items-center gap-3 mb-3">
      <h2 class="text-sm font-semibold text-text-muted uppercase tracking-widest">Sponsored</h2>
      <span class="flex-1 h-px bg-border" />
      <a href="/affiliate" class="text-xs text-text-muted hover:text-primary transition-colors">Disclosure</a>
    </div>
    <p class="text-xs text-text-muted mb-4 italic">
      Affiliate disclosure: some links below may earn us a small commission at no cost to you.
      <a href="/affiliate" class="underline hover:text-primary transition-colors">Learn more</a>
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {visibleAffiliates.map(a => (
        <a
          href={a.href}
          target="_blank"
          rel="noopener sponsored"
          class="flex items-start gap-3 bg-bg-card border border-border hover:border-primary/50 rounded-xl p-4 transition-colors group"
        >
          <span class="text-2xl shrink-0 mt-0.5">{a.badge}</span>
          <div class="min-w-0">
            <div class="flex items-center gap-2 mb-0.5">
              <span class="font-semibold text-sm text-text group-hover:text-primary transition-colors">{a.name}</span>
              <span class="text-xs bg-green-500/10 text-green-500 border border-green-500/20 rounded-full px-2 py-px font-medium shrink-0">
                {a.highlight}
              </span>
            </div>
            <p class="text-xs text-text-muted mb-1.5 line-clamp-2">{a.tagline}</p>
            <span class="text-xs text-primary font-medium">{a.cta}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
)}
