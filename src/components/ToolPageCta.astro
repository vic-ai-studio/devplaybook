---
import { products } from '../data/products';
import ShareButtons from './ShareButtons.astro';
import { getCollection } from 'astro:content';
import ExitIntentCta from './ExitIntentCta';
import NewsletterForm from './NewsletterForm.astro';

interface Props {
  /** Tags to match related products, e.g. ['api-testing', 'cli'] */
  relatedTags?: string[];
  /** Current tool name for the "other tools" section */
  currentTool: string;
}

const { relatedTags = [], currentTool } = Astro.props;

// Find related blog articles by tag overlap
const allPosts = await getCollection('blog');
const relatedPosts = relatedTags.length > 0
  ? allPosts
    .map(p => ({ ...p, score: p.data.tags.filter((t: string) => relatedTags.includes(t)).length }))
    .filter(p => p.score > 0)
    .sort((a, b) => b.score - a.score || new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
    .slice(0, 3)
  : allPosts
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
    .slice(0, 3);

const tools = [
  { name: 'JSON Formatter', href: '/tools/json-formatter' },
  { name: 'JSON Formatter Pro', href: '/tools/json-formatter-pro' },
  { name: 'JSON Diff Viewer', href: '/tools/json-diff-viewer' },
  { name: 'CSS Grid Generator', href: '/tools/css-grid-generator' },
  { name: 'Regex Tester', href: '/tools/regex-tester' },
  { name: 'Regex Tester Pro', href: '/tools/regex-tester-pro' },
  { name: 'SQL Formatter', href: '/tools/sql-formatter' },
  { name: 'API Response Formatter', href: '/tools/api-response-formatter' },
  { name: 'Color Palette Generator', href: '/tools/color-palette-generator' },
  { name: 'Cron Expression Generator', href: '/tools/cron-generator' },
  { name: 'TypeScript Playground', href: '/tools/typescript-playground' },
  { name: 'Git Command Builder', href: '/tools/git-command-builder' },
  { name: 'HTTP Status Codes', href: '/tools/http-status-codes' },
  { name: 'Base64 Encode / Decode', href: '/tools/base64' },
  { name: 'Base64 Encoder & Decoder', href: '/tools/base64-encoder' },
  { name: 'Password Generator', href: '/tools/password-generator' },
  { name: 'Markdown Preview', href: '/tools/markdown-preview' },
  { name: 'API Request Builder', href: '/tools/api-request-builder' },
  { name: 'Regex Playground', href: '/tools/regex-playground' },
  { name: 'Docker Compose Generator', href: '/tools/docker-compose-generator' },
  { name: 'UUID Generator', href: '/tools/uuid-generator' },
  { name: 'Hash Generator', href: '/tools/hash-generator' },
];

const otherTools = tools.filter(t => t.name !== currentTool);

// Pick up to 3 related products by tag overlap
const scored = products.map(p => ({
  product: p,
  score: p.tags.filter(t => relatedTags.includes(t)).length,
}));
scored.sort((a, b) => b.score - a.score);
const related = scored.slice(0, 3).map(s => s.product);

const BUNDLE_URL = 'https://vicnail.gumroad.com/l/devplaybook-pro-bundle?utm_source=devplaybook&utm_medium=tool_cta&utm_campaign=pro-bundle';
const BUNDLE_PRICE = 79;
const BUNDLE_ORIGINAL = 241;
---

<ShareButtons toolName={currentTool} />

<!-- Social Proof Strip -->
<div class="mt-8 py-4 border-y border-border">
  <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-2 text-sm text-text-muted">
    <span class="flex items-center gap-1.5">
      <span class="text-green-500 font-bold">✓</span>
      <strong class="text-text">60,000+</strong>&nbsp;developers use DevPlaybook
    </span>
    <span class="flex items-center gap-1.5">
      <span class="text-yellow-400 tracking-tight">★★★★★</span>
      <span>4.8 / 5 on Gumroad</span>
    </span>
    <span class="flex items-center gap-1.5">
      <span class="text-green-500 font-bold">✓</span>
      MIT licensed · Instant download
    </span>
    <span class="flex items-center gap-1.5">
      <span class="text-green-500 font-bold">✓</span>
      No login required
    </span>
  </div>
</div>

<section class="mt-8 pt-8 border-t border-border">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-2xl font-bold">Related <span class="text-primary">Products</span></h2>
    <span class="text-xs bg-yellow-500/10 text-yellow-600 dark:text-yellow-400 border border-yellow-500/30 rounded-full px-3 py-1 font-medium">on Gumroad</span>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    {related.map(product => (
      <a href={`/products/${product.slug}`} class="block bg-bg-card rounded-xl p-5 border border-border hover:border-primary transition-colors group relative overflow-hidden">
        <div class="flex items-start justify-between mb-2">
          <span class="text-2xl">{product.icon}</span>
          <span class="text-primary font-bold">${product.price}</span>
        </div>
        <h3 class="font-semibold mb-1 group-hover:text-primary transition-colors text-sm">{product.name}</h3>
        <p class="text-text-muted text-xs line-clamp-2 mb-3">{product.description}</p>
        <span class="inline-flex items-center gap-1 text-xs text-yellow-600 dark:text-yellow-400 font-medium">
          Buy on Gumroad →
        </span>
      </a>
    ))}
  </div>

  <!-- You might also need: 3 featured tool cards -->
  <h2 class="text-xl font-bold mb-4">You Might Also <span class="text-primary">Need</span></h2>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
    {otherTools.slice(0, 3).map(tool => (
      <a href={tool.href} class="block bg-bg-card rounded-xl p-4 border border-border hover:border-primary transition-colors group text-center">
        <div class="text-2xl mb-2">🛠️</div>
        <h3 class="font-semibold text-sm group-hover:text-primary transition-colors">{tool.name}</h3>
        <p class="text-primary text-xs mt-1 font-medium">Open free tool →</p>
      </a>
    ))}
  </div>

  <h2 class="text-xl font-bold mb-4">More Free <span class="text-primary">Tools</span></h2>
  <div class="flex flex-wrap gap-3 mb-12">
    {otherTools.map(tool => (
      <a href={tool.href} class="text-sm bg-bg-card border border-border rounded-lg px-4 py-2 hover:border-primary hover:text-primary transition-colors">
        {tool.name}
      </a>
    ))}
  </div>

  {relatedPosts.length > 0 && (
    <div class="mb-10">
      <h2 class="text-xl font-bold mb-4">Related <span class="text-primary">Articles</span></h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {relatedPosts.map(post => (
          <a href={`/blog/${post.id}`} class="block bg-bg-card rounded-xl p-5 border border-border hover:border-primary transition-colors group">
            <div class="text-xs text-text-muted mb-2">{new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })} · {post.data.readingTime}</div>
            <h3 class="font-semibold text-sm mb-1 group-hover:text-primary transition-colors line-clamp-2">{post.data.title}</h3>
            <p class="text-text-muted text-xs line-clamp-2">{post.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  )}
</section>

<!-- Newsletter CTA with inline email capture -->
<section class="mt-8 mb-4 bg-bg-card border border-border rounded-xl p-6">
  <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
    <div class="flex-1 min-w-0">
      <h3 class="font-semibold text-base mb-1">Enjoying this tool? Get more like it.</h3>
      <p class="text-text-muted text-sm">Weekly developer tool guides, productivity playbooks &amp; AI tricks. Free. No spam.</p>
    </div>
    <div class="shrink-0">
      <NewsletterForm source="tool" compact={true} />
    </div>
  </div>
</section>

<!-- Pro Subscription CTA -->
<section class="mt-4 mb-4 rounded-2xl border border-primary/40 bg-gradient-to-r from-primary/5 to-bg-card p-6">
  <div class="flex flex-col sm:flex-row items-start sm:items-center gap-5">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1">
        <span class="text-xs font-bold uppercase tracking-widest text-primary">DevPlaybook Pro</span>
        <span class="text-xs bg-green-500/10 text-green-500 border border-green-500/30 rounded-full px-2 py-0.5 font-medium">7 days free</span>
      </div>
      <h3 class="font-bold text-lg mb-1">Unlock AI-Powered Dev Tools</h3>
      <ul class="text-text-muted text-sm space-y-0.5">
        <li>⚡ AI Code Review, Doc Generator &amp; SQL Builder</li>
        <li>⚡ All premium templates &amp; early access</li>
        <li>⚡ Member discounts on Gumroad products</li>
      </ul>
    </div>
    <div class="shrink-0 text-center">
      <a
        href="/pricing"
        data-track="pro_cta_click"
        data-cta-location="tool_page"
        class="inline-block bg-primary hover:bg-primary-dark text-white font-bold px-6 py-3 rounded-xl transition-colors text-sm whitespace-nowrap"
      >
        Start Free Trial →
      </a>
      <p class="text-xs text-text-muted mt-2">$9/mo after trial · Cancel anytime</p>
    </div>
  </div>
</section>

<!-- DevPlaybook Pro Bundle CTA -->
<section class="rounded-2xl border border-primary/30 bg-gradient-to-br from-bg-card to-bg p-8 text-center mt-4">
  <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-3">Want the full toolkit?</p>
  <h2 class="text-3xl font-bold mb-2">Get DevPlaybook Pro</h2>
  <p class="text-text-muted mb-4 max-w-xl mx-auto">
    Every template, guide, boilerplate, and automation script in one bundle.
    13 premium products — grab them all at once and save big.
  </p>
  <div class="flex items-center justify-center gap-3 mb-6">
    <span class="text-4xl font-bold text-primary">${BUNDLE_PRICE}</span>
    <div class="text-left">
      <span class="block text-text-muted line-through text-sm">${BUNDLE_ORIGINAL} separately</span>
      <span class="block text-green-400 text-sm font-semibold">Save ${BUNDLE_ORIGINAL - BUNDLE_PRICE} (67% off)</span>
    </div>
  </div>
  <a
    href={BUNDLE_URL}
    target="_blank"
    rel="noopener noreferrer"
    data-track="bundle_cta_click"
    data-product-name="DevPlaybook Pro Bundle"
    data-product-price={String(BUNDLE_PRICE)}
    class="inline-block bg-primary hover:bg-primary-dark text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors"
  >
    Get DevPlaybook Pro — ${BUNDLE_PRICE} →
  </a>
  <p class="text-text-muted text-xs mt-3">MIT licensed · Instant download · No subscription</p>
  <a href="/bundles" class="block text-primary text-sm mt-2 hover:underline">See what's included →</a>
  <a href="/deals" class="block text-primary text-sm mt-1 hover:underline">Browse all deals →</a>
</section>

<!-- Exit-intent popup (fires when cursor leaves the viewport) -->
<ExitIntentCta client:only="preact" />
