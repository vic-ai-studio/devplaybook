---
import { products } from '../data/products';
import ProWaitlist from './ProWaitlist.tsx';
import ShareButtons from './ShareButtons.astro';

interface Props {
  /** Tags to match related products, e.g. ['api-testing', 'cli'] */
  relatedTags?: string[];
  /** Current tool name for the "other tools" section */
  currentTool: string;
}

const { relatedTags = [], currentTool } = Astro.props;

const tools = [
  { name: 'API Request Builder', href: '/tools/api-request-builder' },
  { name: 'Regex Playground', href: '/tools/regex-playground' },
  { name: 'Cron Expression Generator', href: '/tools/cron-generator' },
  { name: 'Git Command Builder', href: '/tools/git-command-builder' },
  { name: 'Docker Compose Generator', href: '/tools/docker-compose-generator' },
  { name: 'UUID Generator', href: '/tools/uuid-generator' },
  { name: 'Base64 Encode / Decode', href: '/tools/base64' },
  { name: 'Hash Generator', href: '/tools/hash-generator' },
  { name: 'Markdown Preview', href: '/tools/markdown-preview' },
];

const otherTools = tools.filter(t => t.name !== currentTool);

// Pick up to 3 related products by tag overlap
const scored = products.map(p => ({
  product: p,
  score: p.tags.filter(t => relatedTags.includes(t)).length,
}));
scored.sort((a, b) => b.score - a.score);
const related = scored.slice(0, 3).map(s => s.product);

const BUNDLE_URL = 'https://vicnail.gumroad.com/l/devplaybook-pro-bundle';
const BUNDLE_PRICE = 79;
const BUNDLE_ORIGINAL = 241;
---

<ShareButtons toolName={currentTool} />

<section class="mt-8 pt-8 border-t border-border">
  <h2 class="text-2xl font-bold mb-6">Related <span class="text-primary">Products</span></h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    {related.map(product => (
      <a href={`/products/${product.slug}`} class="block bg-bg-card rounded-xl p-5 border border-border hover:border-primary transition-colors group">
        <div class="flex items-start justify-between mb-2">
          <span class="text-2xl">{product.icon}</span>
          <span class="text-primary font-bold">${product.price}</span>
        </div>
        <h3 class="font-semibold mb-1 group-hover:text-primary transition-colors text-sm">{product.name}</h3>
        <p class="text-text-muted text-xs line-clamp-2">{product.description}</p>
      </a>
    ))}
  </div>

  <h2 class="text-xl font-bold mb-4">More Free <span class="text-primary">Tools</span></h2>
  <div class="flex flex-wrap gap-3 mb-12">
    {otherTools.map(tool => (
      <a href={tool.href} class="text-sm bg-bg-card border border-border rounded-lg px-4 py-2 hover:border-primary hover:text-primary transition-colors">
        {tool.name}
      </a>
    ))}
  </div>
</section>

<!-- Pro Waitlist CTA -->
<section class="mt-8 mb-4">
  <ProWaitlist variant="banner" client:load />
</section>

<!-- DevPlaybook Pro Bundle CTA -->
<section class="rounded-2xl border border-primary/30 bg-gradient-to-br from-bg-card to-bg p-8 text-center mt-4">
  <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-3">Want the full toolkit?</p>
  <h2 class="text-3xl font-bold mb-2">Get DevPlaybook Pro</h2>
  <p class="text-text-muted mb-4 max-w-xl mx-auto">
    Every template, guide, boilerplate, and automation script in one bundle.
    13 premium products — grab them all at once and save big.
  </p>
  <div class="flex items-center justify-center gap-3 mb-6">
    <span class="text-4xl font-bold text-primary">${BUNDLE_PRICE}</span>
    <div class="text-left">
      <span class="block text-text-muted line-through text-sm">${BUNDLE_ORIGINAL} separately</span>
      <span class="block text-green-400 text-sm font-semibold">Save ${BUNDLE_ORIGINAL - BUNDLE_PRICE} (67% off)</span>
    </div>
  </div>
  <a
    href={BUNDLE_URL}
    target="_blank"
    rel="noopener noreferrer"
    data-track="bundle_cta_click"
    data-product-name="DevPlaybook Pro Bundle"
    data-product-price={String(BUNDLE_PRICE)}
    class="inline-block bg-primary hover:bg-primary-dark text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors"
  >
    Get DevPlaybook Pro — ${BUNDLE_PRICE} →
  </a>
  <p class="text-text-muted text-xs mt-3">MIT licensed · Instant download · No subscription</p>
  <a href="/bundles" class="block text-primary text-sm mt-2 hover:underline">See what's included →</a>
</section>
