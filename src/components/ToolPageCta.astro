---
import { products } from '../data/products';

interface Props {
  /** Tags to match related products, e.g. ['api-testing', 'cli'] */
  relatedTags?: string[];
  /** Current tool name for the "other tools" section */
  currentTool: string;
}

const { relatedTags = [], currentTool } = Astro.props;

const tools = [
  { name: 'API Request Builder', href: '/tools/api-request-builder' },
  { name: 'Regex Playground', href: '/tools/regex-playground' },
  { name: 'Cron Expression Generator', href: '/tools/cron-generator' },
  { name: 'Git Command Builder', href: '/tools/git-command-builder' },
  { name: 'Docker Compose Generator', href: '/tools/docker-compose-generator' },
];

const otherTools = tools.filter(t => t.name !== currentTool);

// Pick up to 3 related products by tag overlap
const scored = products.map(p => ({
  product: p,
  score: p.tags.filter(t => relatedTags.includes(t)).length,
}));
scored.sort((a, b) => b.score - a.score);
const related = scored.slice(0, 3).map(s => s.product);
---

<section class="mt-12 pt-8 border-t border-border">
  <h2 class="text-2xl font-bold mb-6">Related <span class="text-primary">Products</span></h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    {related.map(product => (
      <a href={`/products/${product.slug}`} class="block bg-bg-card rounded-xl p-5 border border-border hover:border-primary transition-colors group">
        <div class="flex items-start justify-between mb-2">
          <span class="text-2xl">{product.icon}</span>
          <span class="text-primary font-bold">${product.price}</span>
        </div>
        <h3 class="font-semibold mb-1 group-hover:text-primary transition-colors text-sm">{product.name}</h3>
        <p class="text-text-muted text-xs line-clamp-2">{product.description}</p>
      </a>
    ))}
  </div>

  <h2 class="text-xl font-bold mb-4">More Free <span class="text-primary">Tools</span></h2>
  <div class="flex flex-wrap gap-3">
    {otherTools.map(tool => (
      <a href={tool.href} class="text-sm bg-bg-card border border-border rounded-lg px-4 py-2 hover:border-primary hover:text-primary transition-colors">
        {tool.name}
      </a>
    ))}
  </div>
</section>
