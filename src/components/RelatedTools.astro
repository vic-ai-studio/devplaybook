---
/**
 * RelatedTools — shows up to 3 DevPlaybook tools relevant to a blog post.
 * Matches post tags against tool keywords in tool-keyword-map.json.
 */
import toolKeywordMap from '../data/tool-keyword-map.json';

interface Props {
  postTags: string[];
  postTitle?: string;
}

const { postTags, postTitle = '' } = Astro.props;

const normalizedTags = postTags.map((t: string) => t.toLowerCase());

// Score each tool by keyword overlap with post tags
const scored = Object.entries(toolKeywordMap).map(([slug, tool]) => {
  const toolData = tool as { title: string; description: string; path: string; keywords: string[] };
  const score = toolData.keywords.filter((kw: string) =>
    normalizedTags.some(tag => tag.includes(kw) || kw.includes(tag))
  ).length;
  return { slug, ...toolData, score };
});

const relatedTools = scored
  .filter(t => t.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 3);
---

{relatedTools.length > 0 && (
  <aside class="mt-10 pt-8 border-t border-border">
    <h2 class="text-xl font-bold mb-4">Free Tools for This Topic</h2>
    <div class="grid sm:grid-cols-3 gap-4">
      {relatedTools.map(tool => (
        <a
          href={tool.path}
          class="bg-card border border-border rounded-xl p-4 hover:border-primary transition-colors block group"
        >
          <p class="font-semibold text-sm text-text group-hover:text-primary transition-colors line-clamp-2 mb-1">
            {tool.title}
          </p>
          <p class="text-xs text-text-muted line-clamp-3">{tool.description}</p>
          <span class="mt-3 inline-flex items-center text-xs text-primary font-medium">
            Try it free →
          </span>
        </a>
      ))}
    </div>
  </aside>
)}
