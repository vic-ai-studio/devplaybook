---
/**
 * LeadMagnetBox.astro
 * Email lead magnet offering the free "50 CLI Commands" PDF.
 * Uses the same /api/newsletter/subscribe endpoint as NewsletterForm.
 */
interface Props {
  source?: string;
  variant?: 'inline' | 'banner';
}
const { source = 'lead-magnet', variant = 'inline' } = Astro.props;
const formId = `lm-form-${source}`;
---

{variant === 'banner' ? (
  <div class="lead-magnet-banner bg-gradient-to-r from-primary/10 via-primary/5 to-transparent border border-primary/20 rounded-xl p-6 my-8">
    <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center">
      <div class="text-4xl shrink-0" aria-hidden="true">📄</div>
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 mb-1">
          <span class="text-xs font-bold text-primary uppercase tracking-wider bg-primary/10 px-2 py-0.5 rounded">FREE PDF</span>
        </div>
        <h3 class="text-base font-bold text-text mb-0.5">50 CLI Commands That Save Hours</h3>
        <p class="text-sm text-text-muted">Git shortcuts, Docker tricks, productivity boosters — the commands senior devs actually use daily.</p>
      </div>
      <form id={formId} class="flex gap-2 shrink-0 w-full sm:w-auto">
        <input
          type="email"
          placeholder="your@email.com"
          required
          autocomplete="email"
          aria-label="Email address"
          class="flex-1 sm:w-48 px-3 py-2 text-sm rounded border border-border bg-bg-alt text-text placeholder-text-muted focus:outline-none focus:border-primary"
        />
        <button type="submit" class="px-4 py-2 bg-primary text-white text-sm font-semibold rounded hover:bg-primary-hover transition-colors whitespace-nowrap">
          Get PDF →
        </button>
      </form>
    </div>
    <p class="lm-msg text-xs text-text-muted mt-2 hidden"></p>
  </div>
) : (
  <div class="lead-magnet-box bg-bg-card border border-border rounded-xl overflow-hidden my-10">
    <div class="bg-gradient-to-r from-primary/15 to-primary/5 px-6 py-4 border-b border-border">
      <div class="flex items-center gap-2">
        <span class="text-2xl" aria-hidden="true">🎁</span>
        <span class="text-xs font-bold text-primary uppercase tracking-wider">Free Download</span>
      </div>
    </div>
    <div class="px-6 py-6">
      <h3 class="text-xl font-bold text-text mb-2">50 CLI Commands That Save Hours Every Week</h3>
      <p class="text-text-muted text-sm mb-4 leading-relaxed">
        The exact Git shortcuts, file search tricks, Docker commands, and productivity hacks that senior developers use daily.
        Compiled from 5+ years of shipping production code.
      </p>
      <ul class="grid grid-cols-2 gap-1 mb-6 text-sm text-text-muted">
        <li class="flex items-center gap-1.5"><span class="text-primary" aria-hidden="true">✓</span> Git mastery (10 cmds)</li>
        <li class="flex items-center gap-1.5"><span class="text-primary" aria-hidden="true">✓</span> File &amp; search wizardry</li>
        <li class="flex items-center gap-1.5"><span class="text-primary" aria-hidden="true">✓</span> Docker &amp; DevOps tricks</li>
        <li class="flex items-center gap-1.5"><span class="text-primary" aria-hidden="true">✓</span> Process &amp; network tools</li>
        <li class="flex items-center gap-1.5"><span class="text-primary" aria-hidden="true">✓</span> Productivity boosters</li>
        <li class="flex items-center gap-1.5"><span class="text-primary" aria-hidden="true">✓</span> macOS &amp; Linux install guide</li>
      </ul>
      <form id={formId} class="flex flex-col sm:flex-row gap-3">
        <input
          type="email"
          placeholder="your@email.com"
          required
          autocomplete="email"
          aria-label="Email address"
          class="flex-1 px-4 py-2.5 rounded-lg border border-border bg-bg-alt text-text placeholder-text-muted focus:outline-none focus:border-primary text-sm"
        />
        <button type="submit" class="sm:w-auto px-6 py-2.5 bg-primary text-white font-semibold rounded-lg hover:bg-primary-hover transition-colors text-sm whitespace-nowrap">
          Send Me the PDF →
        </button>
      </form>
      <p class="lm-msg text-xs mt-2 hidden"></p>
      <p class="text-xs text-text-muted mt-3">No spam. 1 email/week max. Unsubscribe anytime.</p>
    </div>
  </div>
)}

<script define:vars={{ formId, source }}>
  (function () {
    var form = document.getElementById(formId);
    if (!form) return;
    var msg = form.closest('.lead-magnet-box, .lead-magnet-banner')?.querySelector('.lm-msg');

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      var email = form.querySelector('input[type="email"]').value.trim();
      var btn = form.querySelector('button[type="submit"]');
      var origText = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Sending...';

      try {
        var res = await fetch('/api/newsletter/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source }),
        });
        var data = await res.json();
        if (data.success) {
          form.innerHTML =
            '<p class="text-green-400 font-semibold text-sm py-1">🎉 Check your inbox! PDF on its way.</p>';
          try { window.dpTrack && window.dpTrack('lead_magnet_signup', { source }); } catch (_) {}
        } else {
          btn.disabled = false;
          btn.textContent = origText;
          if (msg) {
            msg.textContent = data.error || 'Something went wrong. Please try again.';
            msg.classList.remove('hidden');
            msg.style.color = '#f87171';
          }
        }
      } catch (_) {
        btn.disabled = false;
        btn.textContent = origText;
        if (msg) {
          msg.textContent = 'Network error. Please try again.';
          msg.classList.remove('hidden');
          msg.style.color = '#f87171';
        }
      }
    });
  })();
</script>
