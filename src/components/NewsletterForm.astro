---
interface Props {
  source?: string;
  compact?: boolean;
  showName?: boolean;
  redirectOnSuccess?: boolean;
}
const { source = 'footer', compact = false, showName = false, redirectOnSuccess = false } = Astro.props;
const formId = `newsletter-form-${source}`;
---

{compact ? (
  <div class="newsletter-compact">
    <form id={formId} class="flex gap-2 flex-wrap">
      <input
        type="email"
        placeholder="your@email.com"
        required
        class="flex-1 min-w-0 px-3 py-2 text-sm rounded border border-border bg-bg-alt text-text placeholder-text-muted focus:outline-none focus:border-primary"
      />
      <button type="submit" class="px-4 py-2 bg-primary text-white text-sm font-medium rounded hover:bg-primary-hover transition-colors whitespace-nowrap">
        Subscribe
      </button>
    </form>
    <p class="newsletter-msg text-xs mt-1 hidden"></p>
  </div>
) : (
  <div class="newsletter-section py-8 border-t border-border">
    <div class="max-w-xl mx-auto text-center">
      <h3 class="text-lg font-semibold text-text mb-1">Stay sharp. Ship faster.</h3>
      <p class="text-sm text-text-muted mb-4">
        Weekly developer tips, tool guides &amp; productivity playbooks. No spam. Unsubscribe anytime.
      </p>
      <form id={formId} class="flex gap-2 flex-wrap justify-center">
        <input
          type="email"
          placeholder="your@email.com"
          required
          class="flex-1 min-w-[220px] max-w-xs px-4 py-2 rounded border border-border bg-bg-alt text-text placeholder-text-muted focus:outline-none focus:border-primary"
        />
        <button type="submit" class="px-6 py-2 bg-primary text-white font-semibold rounded hover:bg-primary-hover transition-colors">
          Subscribe Free
        </button>
      </form>
      <p class="newsletter-msg text-sm mt-3 hidden"></p>
    </div>
  </div>
)}

<script define:vars={{ formId, source, redirectOnSuccess }}>
  (function() {
    var form = document.getElementById(formId);
    if (!form) return;
    var msg = form.parentElement.querySelector('.newsletter-msg');

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      var email = form.querySelector('input[type="email"]').value.trim();
      var nameInput = form.querySelector('input[name="name"]');
      var name = nameInput ? nameInput.value.trim() : '';
      var btn = form.querySelector('button[type="submit"]');
      btn.disabled = true;
      btn.textContent = 'Subscribing...';

      try {
        var res = await fetch('/api/newsletter/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, name, source }),
        });
        var data = await res.json();
        if (data.success) {
          if (redirectOnSuccess) {
            window.location.href = '/subscribe/thanks';
            return;
          }
          form.innerHTML = '<p class="text-green-400 font-medium">You\'re in! Check your inbox soon.</p>';
          if (msg) { msg.classList.add('hidden'); }
          try { window.pcTrack && window.pcTrack('newsletter_signup', { source: source }); } catch(te) {}
          try { window.dpTrack && window.dpTrack('newsletter_signup', { source: source }); } catch(te) {}
        } else {
          btn.disabled = false;
          btn.textContent = source === 'footer' ? 'Subscribe Free' : 'Subscribe';
          if (msg) { msg.textContent = data.error || 'Something went wrong.'; msg.classList.remove('hidden'); msg.style.color = '#f87171'; }
        }
      } catch (err) {
        btn.disabled = false;
        btn.textContent = source === 'footer' ? 'Subscribe Free' : 'Subscribe';
        if (msg) { msg.textContent = 'Network error. Please try again.'; msg.classList.remove('hidden'); msg.style.color = '#f87171'; }
      }
    });
  })();
</script>
