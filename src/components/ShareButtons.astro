---
interface Props {
  toolName: string;
  toolUrl?: string;
}
const { toolName, toolUrl } = Astro.props;
const siteUrl = 'https://devplaybook.cc';
const pageUrl = toolUrl ? `${siteUrl}${toolUrl}` : `${siteUrl}${Astro.url.pathname}`;
const tweetText = encodeURIComponent(`Just found this free dev tool: ${toolName} on @DevPlaybook — no signup needed! `);
const twitterUrl = `https://twitter.com/intent/tweet?text=${tweetText}&url=${encodeURIComponent(pageUrl)}`;
const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`;
---

<div class="flex items-center gap-3 mt-8 pt-6 border-t border-border">
  <span class="text-sm text-text-muted">Share this tool:</span>
  <a
    href={twitterUrl}
    target="_blank"
    rel="noopener noreferrer"
    data-track="tool_share"
    data-platform="twitter"
    data-tool={toolName}
    class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-bg-card border border-border hover:border-primary text-sm text-text-muted hover:text-text transition-colors"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
    </svg>
    X / Twitter
  </a>
  <a
    href={linkedinUrl}
    target="_blank"
    rel="noopener noreferrer"
    data-track="tool_share"
    data-platform="linkedin"
    data-tool={toolName}
    class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-bg-card border border-border hover:border-primary text-sm text-text-muted hover:text-text transition-colors"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
    </svg>
    LinkedIn
  </a>
</div>

<script is:inline>
  document.querySelectorAll('[data-track="tool_share"]').forEach(function(el) {
    el.addEventListener('click', function() {
      var platform = el.dataset.platform;
      var tool = el.dataset.tool;
      try { window.pcTrack?.('tool_share', { platform: platform, tool: tool }); } catch {}
      try { window.dpTrack?.('tool_share', { platform: platform, tool: tool }); } catch {}
    });
  });
</script>
