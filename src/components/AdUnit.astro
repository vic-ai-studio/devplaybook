---
/**
 * AdUnit.astro — Conditional AdSense display ad
 * Only renders when PUBLIC_ADSENSE_PUBLISHER_ID env var is set.
 *
 * Usage:
 *   <AdUnit slot="1234567890" format="auto" />
 *   <AdUnit slot="1234567890" format="rectangle" label="Sponsored" />
 *
 * Placement guide:
 *   - "auto"        → Responsive leaderboard, best for wide page areas
 *   - "rectangle"   → 300×250 medium rectangle, best below tools / in sidebars
 *   - "in-article"  → Fluid in-article, best between blog paragraphs
 */

interface Props {
  /** AdSense ad-slot ID from your AdSense account (required — do not use "auto") */
  slot: string;
  /** Ad format */
  format?: 'auto' | 'rectangle' | 'in-article';
  /** Optional label text (e.g. "Advertisement") */
  label?: string;
  /** Extra wrapper classes */
  class?: string;
}

const {
  slot,
  format = 'auto',
  label,
  class: extraClass = '',
} = Astro.props;

// Guard: skip rendering if slot ID is missing or placeholder
if (!slot || slot === 'auto') return;

const publisherId = import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID;
if (!publisherId) return;

const isInArticle = format === 'in-article';
const isRectangle = format === 'rectangle';
---

{publisherId && (
  <div class:list={['ad-unit my-6', extraClass]} aria-label="Advertisement">
    {label && (
      <p class="text-[10px] text-text-muted text-center mb-1 uppercase tracking-widest">{label}</p>
    )}
    {isInArticle ? (
      <div class="flex justify-center">
        <ins
          class="adsbygoogle"
          style="display:block;text-align:center;"
          data-ad-layout="in-article"
          data-ad-format="fluid"
          data-ad-client={publisherId}
          data-ad-slot={slot}
        ></ins>
        <script>try{(adsbygoogle = window.adsbygoogle || []).push({});}catch(e){}</script>
      </div>
    ) : isRectangle ? (
      <div class="flex justify-center">
        <ins
          class="adsbygoogle"
          style="display:inline-block;width:300px;height:250px"
          data-ad-client={publisherId}
          data-ad-slot={slot}
        ></ins>
        <script>try{(adsbygoogle = window.adsbygoogle || []).push({});}catch(e){}</script>
      </div>
    ) : (
      /* min-height: 90px reserves space before ad loads — prevents CLS (Core Web Vitals) */
      <ins
        class="adsbygoogle"
        style="display:block;min-height:90px"
        data-ad-client={publisherId}
        data-ad-slot={slot}
        data-ad-format="auto"
        data-full-width-responsive="true"
      ></ins>
      <script>try{(adsbygoogle = window.adsbygoogle || []).push({});}catch(e){}</script>
    )}
  </div>
)}
