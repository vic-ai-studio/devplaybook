---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';
import { getCollection, render } from 'astro:content';
import { products } from '../../data/products';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const siteUrl = 'https://devplaybook.cc';
const canonicalUrl = `${siteUrl}/blog/${post.id}`;

// Pick 3 related products based on tag overlap
const postTags = post.data.tags.map((t: string) => t.toLowerCase());
const relatedProducts = products
  .map(p => ({ ...p, score: p.tags.filter(t => postTags.includes(t.toLowerCase())).length }))
  .filter(p => p.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 3);
---

<BaseLayout title={post.data.title} description={post.data.description} noDefaultJsonLd>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.data.title,
    "description": post.data.description,
    "datePublished": post.data.date,
    "dateModified": post.data.updatedDate || post.data.date,
    "author": { "@type": "Organization", "name": "DevPlaybook", "url": siteUrl },
    "publisher": {
      "@type": "Organization",
      "name": "DevPlaybook",
      "url": siteUrl,
      "logo": { "@type": "ImageObject", "url": `${siteUrl}/favicon.svg` }
    },
    "url": canonicalUrl,
    "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalUrl },
    "keywords": post.data.tags.join(', '),
    "inLanguage": "en-US"
  })} />

  <article class="max-w-4xl mx-auto">
    <header class="mb-10">
      <div class="flex items-center gap-3 text-sm text-text-muted mb-4">
        <a href="/blog" class="hover:text-primary">&larr; All Articles</a>
        <span>·</span>
        <time datetime={post.data.date}>{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        <span>·</span>
        <span>{post.data.readingTime}</span>
      </div>
      <h1 class="text-4xl font-bold mb-4">{post.data.title}</h1>
      <p class="text-xl text-text-muted">{post.data.description}</p>
      <div class="flex flex-wrap gap-2 mt-4">
        {post.data.tags.map((tag: string) => (
          <span class="text-xs px-2 py-1 bg-card rounded border border-border text-text-muted">{tag}</span>
        ))}
      </div>
    </header>

    <div class="prose prose-invert prose-lg max-w-none
      [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:mt-10 [&_h2]:mb-4 [&_h2]:text-text
      [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:mt-8 [&_h3]:mb-3 [&_h3]:text-text
      [&_p]:text-text-muted [&_p]:leading-relaxed [&_p]:mb-4
      [&_ul]:text-text-muted [&_ul]:mb-4 [&_ul]:ml-6 [&_ul]:list-disc
      [&_ol]:text-text-muted [&_ol]:mb-4 [&_ol]:ml-6 [&_ol]:list-decimal
      [&_li]:mb-2
      [&_a]:text-primary [&_a]:underline [&_a:hover]:text-secondary
      [&_code]:bg-card [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:text-sm [&_code]:text-secondary
      [&_pre]:bg-card [&_pre]:p-4 [&_pre]:rounded-lg [&_pre]:overflow-x-auto [&_pre]:mb-4 [&_pre]:border [&_pre]:border-border
      [&_pre_code]:bg-transparent [&_pre_code]:p-0
      [&_blockquote]:border-l-4 [&_blockquote]:border-primary [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-text-muted
      [&_table]:w-full [&_table]:mb-4
      [&_th]:text-left [&_th]:p-2 [&_th]:border-b [&_th]:border-border [&_th]:text-text
      [&_td]:p-2 [&_td]:border-b [&_td]:border-border [&_td]:text-text-muted
      [&_hr]:border-border [&_hr]:my-8
      [&_strong]:text-text [&_strong]:font-semibold
    ">
      <Content />
    </div>

    {relatedProducts.length > 0 && (
      <aside class="mt-12 pt-8 border-t border-border">
        <h2 class="text-xl font-bold mb-4">Related Products</h2>
        <div class="grid md:grid-cols-3 gap-4">
          {relatedProducts.map(product => (
            <a href={`/products/${product.slug}`} class="bg-card border border-border rounded-lg p-4 hover:border-primary transition-colors block">
              <span class="text-2xl">{product.icon}</span>
              <h3 class="font-semibold mt-2 text-text">{product.name}</h3>
              <p class="text-sm text-text-muted mt-1">${product.price}</p>
            </a>
          ))}
        </div>
      </aside>
    )}

    <!-- AdSense in-article ad (entry point 2/3: after blog content)
         Activates automatically when PUBLIC_ADSENSE_PUBLISHER_ID is set -->
    {import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID && (
      <div class="mt-10 flex justify-center" aria-label="Advertisement">
        <ins class="adsbygoogle"
          style="display:block;text-align:center;"
          data-ad-layout="in-article"
          data-ad-format="fluid"
          data-ad-client={import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID}
          data-ad-slot="auto">
        </ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>
    )}

    <!-- Newsletter CTA -->
    <div class="mt-12 pt-8 border-t border-border bg-card rounded-xl p-8 text-center">
      <p class="text-xs font-semibold text-primary uppercase tracking-wider mb-2">Free Newsletter</p>
      <h2 class="text-2xl font-bold mb-2">Level Up Your Dev Workflow</h2>
      <p class="text-text-muted mb-2">Get new tools, guides, and productivity tips delivered to your inbox.</p>
      <p class="text-text-muted text-sm mb-6">
        Plus: grab the free <a href="/free-checklist" class="text-primary underline hover:text-primary-dark">Developer Productivity Checklist</a> when you subscribe.
      </p>
      <NewsletterForm source="blog" />
    </div>

    <div class="mt-8 text-center">
      <p class="text-text-muted mb-4 text-sm">Found this guide useful? Check out our free developer tools.</p>
      <div class="flex justify-center gap-4">
        <a href="/tools" class="px-6 py-2 bg-primary text-white rounded-lg hover:opacity-90 transition-opacity font-medium">Free Tools</a>
        <a href="/products" class="px-6 py-2 bg-card border border-border text-text rounded-lg hover:border-primary transition-colors font-medium">All Products</a>
      </div>
    </div>
  </article>
</BaseLayout>
