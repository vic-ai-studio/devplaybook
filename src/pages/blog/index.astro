---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const POSTS_PER_PAGE = 48;
const posts = allPosts.slice(0, POSTS_PER_PAGE);
const totalPosts = allPosts.length;
---

<BaseLayout title="Blog" description="In-depth guides, tutorials, and comparisons for developers. Learn about productivity tools, AI agents, Docker, Kubernetes, API design, and more." noDefaultJsonLd>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "DevPlaybook Blog",
    "url": "https://devplaybook.cc/blog",
    "description": "In-depth guides, tutorials, and comparisons for developers.",
    "publisher": { "@type": "Organization", "name": "DevPlaybook", "url": "https://devplaybook.cc" },
    "blogPost": allPosts.slice(0, 10).map(post => ({
      "@type": "BlogPosting",
      "headline": post.data.title,
      "description": post.data.description,
      "url": `https://devplaybook.cc/blog/${post.id}`,
      "datePublished": post.data.date,
      "keywords": post.data.tags.join(', ')
    }))
  })} />
  <div class="max-w-4xl mx-auto">
    <h1 class="text-4xl font-bold mb-2">Developer Guides & Tutorials</h1>
    <p class="text-text-muted text-lg mb-2">In-depth articles to level up your development workflow.</p>
    <p class="text-text-muted text-sm mb-10">{totalPosts} articles — showing the {POSTS_PER_PAGE} most recent.</p>

    <div class="space-y-8">
      {posts.map((post) => (
        <article class="bg-card border border-border rounded-lg p-6 hover:border-primary transition-colors">
          <a href={`/blog/${post.id}`} class="block">
            <div class="flex items-center gap-3 text-sm text-text-muted mb-3">
              <time datetime={post.data.date}>{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
              <span>·</span>
              <span>{post.data.readingTime}</span>
            </div>
            <h2 class="text-2xl font-bold mb-2 text-text hover:text-primary transition-colors">{post.data.title}</h2>
            <p class="text-text-muted mb-4">{post.data.description}</p>
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag: string) => (
                <span class="text-xs px-2 py-1 bg-bg rounded border border-border text-text-muted">{tag}</span>
              ))}
            </div>
          </a>
        </article>
      ))}
    </div>
    {totalPosts > POSTS_PER_PAGE && (
      <div class="text-center mt-10 py-6 border-t border-border">
        <p class="text-text-muted text-sm mb-4">
          Showing {POSTS_PER_PAGE} of {totalPosts} articles. Use the search below to find specific topics.
        </p>
        <form action="/tools" method="get" role="search" class="flex gap-2 max-w-sm mx-auto">
          <input
            type="search"
            name="q"
            placeholder="Search developer tools & guides…"
            aria-label="Search tools and articles"
            class="flex-1 px-4 py-2 rounded-lg border border-border bg-bg-card text-text placeholder-text-muted focus:outline-none focus:border-primary text-sm"
          />
          <button type="submit" class="px-4 py-2 bg-primary hover:bg-primary-dark text-white font-semibold rounded-lg transition-colors text-sm whitespace-nowrap">
            Search
          </button>
        </form>
      </div>
    )}
  </div>
</BaseLayout>
