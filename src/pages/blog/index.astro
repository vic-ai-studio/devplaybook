---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Blog" description="In-depth guides, tutorials, and comparisons for developers. Learn about productivity tools, AI agents, Docker, Kubernetes, API design, and more.">
  <div class="max-w-4xl mx-auto">
    <h1 class="text-4xl font-bold mb-2">Developer Guides & Tutorials</h1>
    <p class="text-text-muted text-lg mb-10">In-depth articles to level up your development workflow.</p>

    <div class="space-y-8">
      {posts.map((post) => (
        <article class="bg-card border border-border rounded-lg p-6 hover:border-primary transition-colors">
          <a href={`/blog/${post.id}`} class="block">
            <div class="flex items-center gap-3 text-sm text-text-muted mb-3">
              <time datetime={post.data.date}>{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
              <span>·</span>
              <span>{post.data.readingTime}</span>
            </div>
            <h2 class="text-2xl font-bold mb-2 text-text hover:text-primary transition-colors">{post.data.title}</h2>
            <p class="text-text-muted mb-4">{post.data.description}</p>
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag: string) => (
                <span class="text-xs px-2 py-1 bg-bg rounded border border-border text-text-muted">{tag}</span>
              ))}
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
