---
import BaseLayout from '../layouts/BaseLayout.astro';

const earlyBirdLimit = 100;
const earlyBirdBase = 47; // baseline shown before live count loads
---

<BaseLayout
  title="Join DevPlaybook Pro Early Access — 50% Off for First 100 Members"
  description="Get early access to DevPlaybook Pro. AI-powered dev tools, premium templates, and exclusive discounts. First 100 members get 50% off forever. Join the waitlist."
>
  <!-- Hero -->
  <div class="max-w-2xl mx-auto text-center py-12">
    <div class="inline-flex items-center gap-2 bg-primary/10 text-primary text-sm font-semibold px-4 py-2 rounded-full mb-6">
      <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
      Only <span id="spots-left">{earlyBirdLimit - earlyBirdBase}</span> early bird spots remaining
    </div>

    <h1 class="text-4xl md:text-5xl font-bold mb-4">
      Get <span class="text-primary">50% Off</span> DevPlaybook Pro<br />
      <span class="text-2xl md:text-3xl text-text-muted font-normal">Forever. First 100 members only.</span>
    </h1>

    <p class="text-text-muted text-lg mb-8 max-w-xl mx-auto">
      DevPlaybook Pro is launching soon with AI-powered developer tools, premium templates, and unlimited API access.
      Join the waitlist now to lock in the early bird price — <strong class="text-text">$4.50/month</strong> instead of $9.
    </p>

    <!-- Email Form -->
    <div id="waitlist-form-container" class="max-w-md mx-auto">
      <form
        id="waitlist-form"
        class="flex flex-col sm:flex-row gap-3"
        novalidate
      >
        <input
          type="email"
          id="waitlist-email"
          name="email"
          placeholder="you@example.com"
          required
          class="flex-1 bg-bg-input border border-border rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors"
        />
        <button
          type="submit"
          id="waitlist-submit"
          class="bg-primary hover:bg-primary-dark text-white font-semibold px-6 py-3 rounded-xl transition-colors text-sm shrink-0 shadow-lg"
        >
          Join Waitlist
        </button>
      </form>
      <p id="waitlist-error" class="text-red-400 text-sm mt-2 hidden"></p>
      <p class="text-text-muted text-xs mt-3">No spam. Unsubscribe anytime. We'll email you when your spot opens.</p>
    </div>

    <!-- Success State -->
    <div id="waitlist-success" class="hidden max-w-md mx-auto bg-primary/10 border border-primary/30 rounded-xl p-6">
      <div class="text-4xl mb-3">🎉</div>
      <h3 class="text-lg font-semibold mb-2">You're on the list!</h3>
      <p class="text-text-muted text-sm">
        We'll email you when your early bird spot opens. Your 50% discount is reserved.
      </p>
    </div>
  </div>

  <!-- Social Proof -->
  <div class="flex flex-wrap justify-center gap-6 text-center mb-12 text-sm text-text-muted">
    <div>
      <div class="text-2xl font-bold text-text" id="joined-count">{earlyBirdBase}</div>
      <div>developers joined</div>
    </div>
    <div>
      <div class="text-2xl font-bold text-text" id="spots-left-2">{earlyBirdLimit - earlyBirdBase}</div>
      <div>spots left at 50% off</div>
    </div>
    <div>
      <div class="text-2xl font-bold text-primary">$4.50</div>
      <div>early bird price / month</div>
    </div>
  </div>

  <!-- What's included -->
  <div class="max-w-3xl mx-auto mb-12">
    <h2 class="text-2xl font-bold text-center mb-8">Everything in DevPlaybook Pro</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {[
        { icon: '🤖', title: 'AI Code Review', desc: 'Instant feedback on your code — bugs, performance, security, and style suggestions.' },
        { icon: '📝', title: 'AI Doc Generator', desc: 'Generate JSDoc, README files, and OpenAPI specs from your code automatically.' },
        { icon: '🗄️', title: 'AI SQL Builder', desc: 'Natural language to SQL. Describe what you want, get the query.' },
        { icon: '🚀', title: 'Unlimited API Access', desc: 'No daily limits on AI-powered tools. Use them as much as you need.' },
        { icon: '📦', title: 'Premium Templates', desc: 'Full-stack boilerplates, GitHub Actions workflows, and developer productivity bundles.' },
        { icon: '⚡', title: 'Early Access', desc: 'First to try new tools before they launch. Shape the roadmap.' },
        { icon: '🏷️', title: 'Member Discounts', desc: 'Exclusive discounts on all DevPlaybook products — up to 40% off.' },
        { icon: '💬', title: 'Priority Support', desc: 'Fast responses when you have questions or run into issues.' },
      ].map(feature => (
        <div class="bg-bg-card border border-border rounded-xl p-5 flex gap-4">
          <div class="text-2xl shrink-0">{feature.icon}</div>
          <div>
            <h3 class="font-semibold mb-1">{feature.title}</h3>
            <p class="text-text-muted text-sm">{feature.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Pricing comparison -->
  <div class="max-w-md mx-auto mb-12">
    <h2 class="text-xl font-bold text-center mb-6">Early Bird vs Regular Pricing</h2>
    <div class="grid grid-cols-2 gap-4">
      <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
        <div class="text-text-muted text-sm mb-2">Regular price</div>
        <div class="text-3xl font-bold line-through text-text-muted">$9</div>
        <div class="text-text-muted text-sm">/month</div>
      </div>
      <div class="bg-primary/10 border border-primary/30 rounded-xl p-5 text-center relative overflow-hidden">
        <div class="absolute top-2 right-2 text-xs bg-primary text-white px-2 py-0.5 rounded-full font-semibold">50% off</div>
        <div class="text-text-muted text-sm mb-2">Early bird</div>
        <div class="text-3xl font-bold text-primary">$4.50</div>
        <div class="text-text-muted text-sm">/month forever</div>
      </div>
    </div>
    <p class="text-text-muted text-xs text-center mt-3">
      Early bird price is locked in permanently — your price never goes up.
    </p>
  </div>

  <!-- FAQ -->
  <div class="max-w-2xl mx-auto mb-12">
    <h2 class="text-xl font-bold text-center mb-6">Questions</h2>
    <div class="space-y-4">
      {[
        {
          q: 'When does Pro launch?',
          a: 'We\'re finishing the last Pro features now. Expected launch within the next few weeks. Waitlist members get access first.'
        },
        {
          q: 'How does the 50% off work?',
          a: 'The first 100 members to join the waitlist get access at $4.50/month (50% off the $9 regular price). That price is locked in permanently — it never increases for you.'
        },
        {
          q: 'What if I miss the early bird?',
          a: 'Regular Pro pricing is $9/month or $49/year. Still a fair price, but early bird is much better. Don\'t wait.'
        },
        {
          q: 'Is there a free trial?',
          a: 'Yes — Pro will include a 7-day free trial. No charge until the trial ends. Cancel anytime.'
        },
      ].map(faq => (
        <details class="bg-bg-card border border-border rounded-xl group">
          <summary class="flex items-center justify-between p-5 cursor-pointer font-medium">
            {faq.q}
            <span class="text-text-muted group-open:rotate-180 transition-transform">▾</span>
          </summary>
          <p class="px-5 pb-5 text-text-muted text-sm">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>

  <!-- Bottom CTA -->
  <div class="text-center mb-8">
    <p class="text-text-muted text-sm mb-4">
      <span id="spots-left-3">{earlyBirdLimit - earlyBirdBase}</span> of {earlyBirdLimit} early bird spots remaining
    </p>
    <button
      onclick="document.getElementById('waitlist-email').focus(); window.scrollTo({top: 0, behavior: 'smooth'});"
      class="bg-primary hover:bg-primary-dark text-white font-semibold px-8 py-3 rounded-xl transition-colors shadow-lg"
    >
      Reserve My Spot — 50% Off Forever
    </button>
  </div>
</BaseLayout>

<script>
  const EARLY_BIRD_LIMIT = 100;

  // Fetch live count from Cloudflare Worker
  async function loadCount() {
    try {
      const res = await fetch('/api/pro-waitlist/count');
      if (!res.ok) return;
      const data = await res.json() as { count: number };
      const joined = data.count;
      const spotsLeft = Math.max(0, EARLY_BIRD_LIMIT - joined);
      (document.getElementById('joined-count') as HTMLElement).textContent = String(joined);
      for (const id of ['spots-left', 'spots-left-2', 'spots-left-3']) {
        const el = document.getElementById(id);
        if (el) el.textContent = String(spotsLeft);
      }
    } catch {}
  }
  loadCount();

  const form = document.getElementById('waitlist-form') as HTMLFormElement;
  const emailInput = document.getElementById('waitlist-email') as HTMLInputElement;
  const submitBtn = document.getElementById('waitlist-submit') as HTMLButtonElement;
  const errorEl = document.getElementById('waitlist-error') as HTMLElement;
  const formContainer = document.getElementById('waitlist-form-container');
  const successEl = document.getElementById('waitlist-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const email = emailInput.value.trim();
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      errorEl.textContent = 'Please enter a valid email address.';
      errorEl.classList.remove('hidden');
      return;
    }

    errorEl.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Joining...';

    try {
      const res = await fetch('/api/pro-waitlist/join', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      if (res.ok) {
        formContainer?.classList.add('hidden');
        successEl?.classList.remove('hidden');
        if (typeof window !== 'undefined' && (window as any).gtag) {
          (window as any).gtag('event', 'waitlist_signup', { event_category: 'pro', event_label: 'early_bird' });
        }
        // Refresh count
        loadCount();
      } else {
        const data = await res.json() as { error?: string };
        throw new Error(data.error || 'Submission failed');
      }
    } catch (err: any) {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Join Waitlist';
      errorEl.textContent = err.message === 'Submission failed' ? 'Something went wrong. Please try again.' : err.message;
      errorEl.classList.remove('hidden');
    }
  });
</script>
