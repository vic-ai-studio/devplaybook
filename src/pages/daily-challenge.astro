---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
---

<BaseLayout
  title="Daily Coding Challenge"
  description="A new coding challenge every day — algorithms, data structures, JavaScript, SQL, system design, and more. Practice consistently and level up your skills."
  noDefaultJsonLd
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Daily Coding Challenge | DevPlaybook",
    "description": "A new coding challenge every day — algorithms, data structures, JavaScript, SQL, and more.",
    "url": "https://devplaybook.cc/daily-challenge"
  })} />

  <!-- Header -->
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-2">
      <span class="text-3xl">🧩</span>
      <h1 class="text-3xl font-bold">Daily Coding Challenge</h1>
    </div>
    <p class="text-text-muted max-w-2xl">
      A fresh challenge every day. Algorithms, data structures, JavaScript, SQL, system design, and more.
      Sharpen your skills consistently — one problem at a time.
    </p>
  </div>

  <!-- Challenge Card (populated by JS) -->
  <div id="challenge-card" class="bg-bg-card border border-border rounded-xl p-6 mb-8 hidden">

    <!-- Meta bar -->
    <div class="flex flex-wrap items-center gap-3 mb-5">
      <span id="challenge-date" class="text-xs text-text-muted font-mono bg-bg-alt px-2 py-1 rounded"></span>
      <span id="challenge-category" class="text-xs font-semibold px-2.5 py-1 rounded-full bg-primary/15 text-primary"></span>
      <span id="challenge-difficulty" class="text-xs font-semibold px-2.5 py-1 rounded-full"></span>
      <span class="ml-auto text-xs text-text-muted" id="challenge-counter"></span>
    </div>

    <!-- Title -->
    <h2 id="challenge-title" class="text-xl font-bold mb-4"></h2>

    <!-- Description -->
    <div id="challenge-description" class="text-text-muted leading-relaxed mb-4 whitespace-pre-wrap"></div>

    <!-- Example -->
    <div id="challenge-example-block" class="mb-6">
      <p class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-2">Example</p>
      <pre id="challenge-example" class="bg-bg-alt border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto whitespace-pre-wrap"></pre>
    </div>

    <!-- Hint toggle -->
    <div class="mb-4">
      <button id="hint-toggle" class="flex items-center gap-2 text-sm font-medium text-primary hover:text-primary-hover transition-colors">
        <svg id="hint-chevron" class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        Show Hint
      </button>
      <div id="hint-content" class="hidden mt-3 bg-yellow-500/10 border border-yellow-500/30 rounded-lg p-4 text-sm text-text-muted leading-relaxed"></div>
    </div>

    <!-- Solution toggle -->
    <div class="mb-6">
      <button id="solution-toggle" class="flex items-center gap-2 text-sm font-medium text-primary hover:text-primary-hover transition-colors">
        <svg id="solution-chevron" class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        Show Solution
      </button>
      <div id="solution-content" class="hidden mt-3">
        <pre id="solution-code" class="bg-bg-alt border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto whitespace-pre-wrap text-green-400"></pre>
      </div>
    </div>

    <!-- Actions -->
    <div class="flex flex-wrap gap-3 pt-4 border-t border-border">
      <a
        id="twitter-share"
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium bg-[#1d9bf0]/15 text-[#1d9bf0] border border-[#1d9bf0]/30 rounded-lg hover:bg-[#1d9bf0]/25 transition-colors"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.743l7.73-8.835L1.254 2.25H8.08l4.259 5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
        Share on X
      </a>
      <button
        id="copy-challenge"
        class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium bg-bg-alt border border-border rounded-lg hover:border-primary/50 transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
        </svg>
        Copy Challenge
      </button>
    </div>
  </div>

  <!-- Loading state -->
  <div id="challenge-loading" class="bg-bg-card border border-border rounded-xl p-6 mb-8 animate-pulse">
    <div class="flex gap-3 mb-5">
      <div class="h-5 w-24 bg-bg-alt rounded"></div>
      <div class="h-5 w-20 bg-bg-alt rounded"></div>
    </div>
    <div class="h-7 w-2/3 bg-bg-alt rounded mb-4"></div>
    <div class="space-y-2 mb-6">
      <div class="h-4 bg-bg-alt rounded"></div>
      <div class="h-4 bg-bg-alt rounded w-5/6"></div>
      <div class="h-4 bg-bg-alt rounded w-4/6"></div>
    </div>
  </div>

  <!-- Next challenge countdown -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-8 flex flex-col sm:flex-row items-start sm:items-center gap-4">
    <div class="flex-1">
      <p class="text-sm font-semibold mb-0.5">Next challenge in</p>
      <p id="countdown" class="text-2xl font-mono font-bold text-primary">--:--:--</p>
    </div>
    <div class="text-sm text-text-muted">
      Challenges rotate daily at <strong class="text-text">midnight UTC</strong>. Bookmark this page and come back tomorrow.
    </div>
  </div>

  <!-- Archive teaser -->
  <div id="archive-section" class="mb-10 hidden">
    <h3 class="text-lg font-semibold mb-3">Browse All Challenges</h3>
    <div id="archive-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3"></div>
  </div>

  <!-- Newsletter CTA -->
  <div class="bg-bg-card border border-primary/20 rounded-xl p-6 mb-10">
    <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center">
      <div class="flex-1">
        <h3 class="font-semibold mb-1">Get tomorrow's challenge in your inbox 📬</h3>
        <p class="text-sm text-text-muted">Weekly coding challenges + dev productivity tips. No spam. Unsubscribe anytime.</p>
      </div>
    </div>
    <div class="mt-4">
      <NewsletterForm source="daily-challenge" compact={true} />
    </div>
  </div>

</BaseLayout>

<script is:inline>
(function() {
  // ---------- helpers ----------
  function dayOfYear(d) {
    const start = new Date(d.getFullYear(), 0, 0);
    const diff = d - start + (start.getTimezoneOffset() - d.getTimezoneOffset()) * 60 * 1000;
    return Math.floor(diff / 86400000);
  }

  function difficultyClass(d) {
    return d === 'easy' ? 'bg-green-500/15 text-green-400 border border-green-500/30'
         : d === 'medium' ? 'bg-yellow-500/15 text-yellow-400 border border-yellow-500/30'
         : 'bg-red-500/15 text-red-400 border border-red-500/30';
  }

  function formatDate(d) {
    return d.toLocaleDateString('en-US', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
  }

  // ---------- countdown ----------
  function updateCountdown() {
    const now = new Date();
    const tomorrow = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate() + 1));
    const diff = tomorrow - now;
    const h = Math.floor(diff / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    const s = Math.floor((diff % 60000) / 1000);
    const el = document.getElementById('countdown');
    if (el) el.textContent = String(h).padStart(2,'0') + ':' + String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0');
  }
  setInterval(updateCountdown, 1000);
  updateCountdown();

  // ---------- load challenges ----------
  fetch('/challenges.json')
    .then(function(r) { return r.json(); })
    .then(function(challenges) {
      const today = new Date();
      const idx = dayOfYear(today) % challenges.length;
      const challenge = challenges[idx];

      // hide loading, show card
      document.getElementById('challenge-loading').style.display = 'none';
      var card = document.getElementById('challenge-card');
      card.classList.remove('hidden');

      // populate fields
      document.getElementById('challenge-date').textContent = formatDate(today);
      document.getElementById('challenge-category').textContent = challenge.category;
      var diffEl = document.getElementById('challenge-difficulty');
      diffEl.textContent = challenge.difficulty.charAt(0).toUpperCase() + challenge.difficulty.slice(1);
      diffEl.className = 'text-xs font-semibold px-2.5 py-1 rounded-full ' + difficultyClass(challenge.difficulty);
      document.getElementById('challenge-counter').textContent = 'Challenge #' + challenge.id + ' of ' + challenges.length;
      document.getElementById('challenge-title').textContent = challenge.title;
      document.getElementById('challenge-description').textContent = challenge.description;
      document.getElementById('challenge-example').textContent = challenge.example;
      document.getElementById('hint-content').textContent = challenge.hint;
      document.getElementById('solution-code').textContent = challenge.solution;

      // Twitter share
      var shareText = encodeURIComponent('🧩 Today\'s coding challenge: "' + challenge.title + '" (' + challenge.difficulty + ' · ' + challenge.category + ')\n\nSolve it at devplaybook.cc/daily-challenge');
      document.getElementById('twitter-share').href = 'https://twitter.com/intent/tweet?text=' + shareText;

      // Copy button
      document.getElementById('copy-challenge').addEventListener('click', function() {
        var text = challenge.title + '\n\n' + challenge.description + '\n\nExample:\n' + challenge.example + '\n\nHint: ' + challenge.hint + '\n\nSource: https://devplaybook.cc/daily-challenge';
        navigator.clipboard.writeText(text).then(function() {
          var btn = document.getElementById('copy-challenge');
          btn.textContent = '✓ Copied!';
          setTimeout(function() { btn.innerHTML = '<svg class="w-4 h-4 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/> </svg> Copy Challenge'; }, 2000);
        });
      });

      // Hint toggle
      document.getElementById('hint-toggle').addEventListener('click', function() {
        var content = document.getElementById('hint-content');
        var chevron = document.getElementById('hint-chevron');
        var btn = document.getElementById('hint-toggle');
        var isHidden = content.classList.toggle('hidden');
        chevron.style.transform = isHidden ? '' : 'rotate(90deg)';
        btn.querySelector('svg + span') && (btn.querySelector('svg + span').textContent = isHidden ? 'Show Hint' : 'Hide Hint');
        // update text node
        btn.childNodes.forEach(function(n) { if (n.nodeType === 3) n.textContent = isHidden ? ' Show Hint' : ' Hide Hint'; });
      });

      // Solution toggle
      document.getElementById('solution-toggle').addEventListener('click', function() {
        var content = document.getElementById('solution-content');
        var chevron = document.getElementById('solution-chevron');
        var btn = document.getElementById('solution-toggle');
        var isHidden = content.classList.toggle('hidden');
        chevron.style.transform = isHidden ? '' : 'rotate(90deg)';
        btn.childNodes.forEach(function(n) { if (n.nodeType === 3) n.textContent = isHidden ? ' Show Solution' : ' Hide Solution'; });
      });

      // Archive grid (show all challenges as mini cards)
      var archiveSection = document.getElementById('archive-section');
      var archiveGrid = document.getElementById('archive-grid');
      archiveSection.classList.remove('hidden');
      challenges.forEach(function(c, i) {
        var isToday = i === idx;
        var el = document.createElement('div');
        el.className = 'bg-bg-card border ' + (isToday ? 'border-primary' : 'border-border') + ' rounded-lg p-3 cursor-pointer hover:border-primary/50 transition-colors' + (isToday ? ' ring-1 ring-primary/30' : '');
        el.innerHTML = '<div class="flex items-center justify-between gap-2 mb-1">'
          + '<span class="text-xs font-mono text-text-muted">#' + c.id + '</span>'
          + '<span class="text-xs px-1.5 py-0.5 rounded ' + difficultyClass(c.difficulty) + '">' + c.difficulty + '</span>'
          + (isToday ? '<span class="text-xs text-primary font-semibold">Today</span>' : '')
          + '</div>'
          + '<p class="text-sm font-medium truncate">' + c.title + '</p>'
          + '<p class="text-xs text-text-muted mt-0.5">' + c.category + '</p>';

        // clicking a non-today card shows it inline
        el.addEventListener('click', function() {
          if (!isToday) {
            document.getElementById('challenge-title').textContent = c.title;
            document.getElementById('challenge-description').textContent = c.description;
            document.getElementById('challenge-example').textContent = c.example;
            document.getElementById('hint-content').textContent = c.hint;
            document.getElementById('solution-code').textContent = c.solution;
            document.getElementById('challenge-category').textContent = c.category;
            var dEl = document.getElementById('challenge-difficulty');
            dEl.textContent = c.difficulty.charAt(0).toUpperCase() + c.difficulty.slice(1);
            dEl.className = 'text-xs font-semibold px-2.5 py-1 rounded-full ' + difficultyClass(c.difficulty);
            document.getElementById('challenge-counter').textContent = 'Challenge #' + c.id + ' of ' + challenges.length;
            // reset toggles
            document.getElementById('hint-content').classList.add('hidden');
            document.getElementById('solution-content').classList.add('hidden');
            document.getElementById('hint-chevron').style.transform = '';
            document.getElementById('solution-chevron').style.transform = '';
            // scroll to card
            document.getElementById('challenge-card').scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
        archiveGrid.appendChild(el);
      });
    })
    .catch(function(err) {
      document.getElementById('challenge-loading').innerHTML = '<p class="text-red-400">Failed to load challenge. Please refresh the page.</p>';
      console.error('challenges.json load failed:', err);
    });
})();
</script>
