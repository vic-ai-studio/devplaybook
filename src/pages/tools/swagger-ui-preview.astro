---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SwaggerUiPreview from '../../components/SwaggerUiPreview.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What OpenAPI versions does this preview support?",
    answer: "It supports OpenAPI 3.0.x, OpenAPI 3.1.x, and Swagger 2.0, in both YAML and JSON format. The spec version is auto-detected from the 'openapi' or 'swagger' field at the root of your spec."
  },
  {
    question: "What does the preview show?",
    answer: "The preview renders: API title, version, description, and contact info; server URLs; all endpoints grouped by tag with color-coded HTTP method badges (GET=blue, POST=green, PUT=orange, PATCH=yellow, DELETE=red); path, query, and header parameters with types and required markers; request body content types; and all response codes with descriptions. Click any endpoint to expand its details."
  },
  {
    question: "Is this the same as Swagger Editor or Swagger UI?",
    answer: "This is a lightweight browser-based preview, not a full Swagger Editor replacement. It's designed for quick visual inspection — seeing how your API is structured, verifying tags, checking parameter lists, and reviewing response codes — without needing to run a local server or upload your spec anywhere. For full JSON Schema validation, use the OpenAPI Spec Validator tool."
  },
  {
    question: "Does this tool send my spec to a server?",
    answer: "No. All parsing and rendering runs 100% in your browser using JavaScript. Your OpenAPI spec — which may contain internal endpoint names and data models — never leaves your machine."
  },
  {
    question: "Why would I use this instead of Swagger Editor?",
    answer: "This tool is faster for a quick read-through of an API — no setup, no local server, works offline. It's useful for reviewing a spec in a PR, sharing a quick preview with a non-technical stakeholder, or checking if a spec looks structurally correct before feeding it to a code generator."
  },
  {
    question: "Can I use this with a Swagger 2.0 spec?",
    answer: "Yes. Swagger 2.0 specs (with 'swagger: \"2.0\"') are parsed and rendered. The server URL is reconstructed from the 'host', 'basePath', and 'schemes' fields. Paths and operations render the same way as OpenAPI 3.x."
  },
];
---

<BaseLayout
  title="Swagger UI Preview — Preview OpenAPI & Swagger Docs Instantly in Browser"
  description="Paste your OpenAPI 3.x or Swagger 2.0 spec (YAML or JSON) and instantly preview a Swagger UI-style view of your API. See endpoints grouped by tag, HTTP methods, parameters, request bodies, and response codes. Free, runs 100% in your browser."
  tool="Swagger UI preview, OpenAPI preview, API documentation preview, OpenAPI 3 viewer, Swagger 2.0 viewer, REST API docs preview"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Swagger UI Preview",
    "url": "https://devplaybook.cc/tools/swagger-ui-preview",
    "description": "Paste an OpenAPI 3.x or Swagger 2.0 spec (YAML or JSON) to instantly preview a Swagger UI-style view. Shows endpoints, tags, parameters, request bodies, and responses. Runs 100% in browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Swagger UI Preview</h1>
  <p class="text-text-muted mb-4">
    Paste your OpenAPI 3.x or Swagger 2.0 spec in YAML or JSON to instantly preview a Swagger UI-style view of your API.
    See endpoints grouped by tag, expandable operation details, parameters, request bodies, and response codes —
    all running 100% in your browser with no upload required.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> OpenAPI 3.x + Swagger 2.0</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> YAML & JSON input</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Grouped by tag</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Expandable endpoint details</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <SwaggerUiPreview client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Swagger UI Preview" relatedTags={['api', 'openapi', 'swagger', 'rest-api', 'documentation', 'developer-tools']} />
</BaseLayout>
