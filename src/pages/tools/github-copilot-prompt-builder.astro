---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What makes a GitHub Copilot prompt effective?",
    answer: "Effective Copilot prompts have four elements: (1) Role — tell Copilot what expert it should act as ('You are a senior Go engineer'). (2) Context — describe the file, function, or system this code fits into. (3) Constraints — specify requirements like error handling, performance bounds, or coding standards. (4) Output format — describe what you want returned (function signature, full file, inline comment). The more precise the context, the more accurate the suggestion."
  },
  {
    question: "What is the difference between Copilot ghost text and Copilot Chat?",
    answer: "Ghost text (inline suggestions) activates automatically as you type and completes code based on the surrounding file context. It's best for short completions: next line, function body, boilerplate. Copilot Chat (/fix, /explain, /tests, /doc) is a conversational interface for longer tasks requiring explanation or multi-step reasoning. Use ghost text for speed; use Chat for complex refactors, test generation, and debugging sessions."
  },
  {
    question: "How do slash commands work in Copilot Chat?",
    answer: "/fix: sends selected code + error context and asks Copilot to repair it. /explain: asks Copilot to walk through what selected code does, line by line. /tests: generates unit test suite for selected code using your project's test framework. /doc: generates JSDoc/docstring for selected code. /optimize: suggests performance improvements. These commands work best when you first select the relevant code, then invoke the slash command so Copilot has the full context."
  },
  {
    question: "Does providing more context always improve Copilot suggestions?",
    answer: "More context generally helps, but there's a sweet spot. Too little context produces generic suggestions that don't fit your codebase. Too much irrelevant context can confuse the model. The ideal approach: open only the files Copilot needs (it uses open tabs as context), write a precise comment above the code you want generated, include type signatures, and reference the function or class this code is part of. Avoid pasting entire codebases into prompts."
  },
  {
    question: "Can I use Copilot to generate prompts for other AI tools?",
    answer: "Yes — this is a meta-prompting technique. You can use Copilot Chat to refine prompts for ChatGPT, Claude, or other LLMs. Write a comment describing what you want (e.g., '// Prompt for Claude to analyze this SQL query') and let Copilot draft it. You can also use /explain on a poor AI response to understand why it failed, then /fix to improve the original prompt. Copilot is useful as a prompt engineering assistant, not just a code generator."
  }
];
---

<BaseLayout
  title="GitHub Copilot Prompt Builder — Optimize Copilot Suggestions"
  description="Build optimized GitHub Copilot prompts for any task. Select task type, language, and context level to generate precision prompts with role definitions, constraints, and output format. Includes slash command reference and before/after comparison."
  tool="GitHub Copilot Prompt Builder, Copilot Prompt Optimizer, Copilot Chat Prompt, GitHub Copilot Tips, AI Code Prompt Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">GitHub Copilot Prompt Builder</h1>
  <p class="text-text-muted mb-4">Craft precision prompts that get better suggestions from GitHub Copilot. See before/after comparisons, task-specific tips, and slash command patterns.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Before/after comparison</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Task-specific tips</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Slash command reference</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Role + context + constraints</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 10+ languages</span>
  </div>

  <!-- Configuration -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Prompt Configuration</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Task Type</label>
        <select id="task-type" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="generate">Generate Function</option>
          <option value="test">Write Tests</option>
          <option value="refactor">Refactor Code</option>
          <option value="explain">Explain Code</option>
          <option value="fix">Fix Bug</option>
          <option value="document">Add Documentation</option>
          <option value="review">Code Review</option>
          <option value="convert">Convert / Migrate</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Language</label>
        <select id="language" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="Python">Python</option>
          <option value="TypeScript" selected>TypeScript</option>
          <option value="JavaScript">JavaScript</option>
          <option value="Go">Go</option>
          <option value="Java">Java</option>
          <option value="Rust">Rust</option>
          <option value="C#">C#</option>
          <option value="C++">C++</option>
          <option value="Ruby">Ruby</option>
          <option value="Swift">Swift</option>
          <option value="Kotlin">Kotlin</option>
          <option value="PHP">PHP</option>
          <option value="SQL">SQL</option>
          <option value="Bash">Bash</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Context Level</label>
        <select id="context-level" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="minimal">Minimal (quick snippet)</option>
          <option value="moderate" selected>Moderate (feature-level)</option>
          <option value="detailed">Detailed (production-grade)</option>
        </select>
      </div>
    </div>
    <div class="mb-4">
      <label class="block text-sm font-medium mb-1.5">What do you want to do? <span class="text-text-muted font-normal">(describe your task)</span></label>
      <textarea id="task-input" rows="3" placeholder="e.g. Create a function that fetches user data from an API with retry logic and timeout handling"
        class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary resize-none">Create a function that fetches user data from a REST API with retry logic, exponential backoff, and timeout handling</textarea>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Framework / Library <span class="text-text-muted font-normal">(optional)</span></label>
        <input id="framework" type="text" placeholder="e.g. React, Express, FastAPI, Spring"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" value="Node.js / axios" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Code Style / Standards <span class="text-text-muted font-normal">(optional)</span></label>
        <input id="code-style" type="text" placeholder="e.g. functional, no classes, strict typing, async/await"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" value="async/await, strict TypeScript types" />
      </div>
    </div>
    <div class="flex gap-3 flex-wrap">
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <input type="checkbox" id="include-role" checked class="rounded" /> Include role definition
      </label>
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <input type="checkbox" id="include-constraints" checked class="rounded" /> Include constraints
      </label>
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <input type="checkbox" id="include-output-format" checked class="rounded" /> Specify output format
      </label>
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <input type="checkbox" id="include-example" class="rounded" /> Include usage example
      </label>
    </div>
  </div>

  <!-- Before / After Output -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-base font-semibold">Prompt Comparison</h2>
      <button id="build-btn" class="bg-primary text-white px-4 py-1.5 rounded-lg hover:opacity-90 text-sm font-medium">Build Prompt</button>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <div class="flex items-center gap-2 mb-2">
          <span class="bg-red-500/20 text-red-400 text-xs font-medium px-2 py-0.5 rounded">Before — Vague</span>
        </div>
        <pre id="prompt-before" class="bg-black/30 rounded-lg p-4 text-xs font-mono overflow-x-auto whitespace-pre-wrap text-text-muted min-h-28 border border-border"></pre>
      </div>
      <div>
        <div class="flex items-center gap-2 mb-2">
          <span class="bg-green-500/20 text-green-400 text-xs font-medium px-2 py-0.5 rounded">After — Optimized</span>
          <button id="copy-prompt" class="ml-auto bg-primary text-white px-2 py-0.5 rounded text-xs hover:opacity-90">Copy</button>
        </div>
        <pre id="prompt-after" class="bg-black/30 rounded-lg p-4 text-xs font-mono overflow-x-auto whitespace-pre-wrap text-green-300 min-h-28 border border-border"></pre>
      </div>
    </div>
  </div>

  <!-- Tips Panel -->
  <div id="tips-panel" class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-3">Tips for <span id="tips-task-label">this task type</span></h2>
    <div id="tips-content" class="space-y-2 text-sm"></div>
  </div>

  <!-- Slash Commands Reference -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Copilot Slash Commands Quick Reference</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      <div class="bg-black/20 rounded-lg p-3">
        <div class="font-mono text-primary text-sm mb-1">/fix</div>
        <div class="text-xs text-text-muted">Repair selected code. Paste error message after the command for best results: <span class="font-mono text-xs">/fix TypeError: cannot read property</span></div>
      </div>
      <div class="bg-black/20 rounded-lg p-3">
        <div class="font-mono text-primary text-sm mb-1">/explain</div>
        <div class="text-xs text-text-muted">Walk through what selected code does. Works best on unfamiliar algorithms, regex, or complex logic.</div>
      </div>
      <div class="bg-black/20 rounded-lg p-3">
        <div class="font-mono text-primary text-sm mb-1">/tests</div>
        <div class="text-xs text-text-muted">Generate unit tests for selected function. Copilot auto-detects Jest, Pytest, JUnit, etc. based on project files.</div>
      </div>
      <div class="bg-black/20 rounded-lg p-3">
        <div class="font-mono text-primary text-sm mb-1">/doc</div>
        <div class="text-xs text-text-muted">Generate JSDoc, docstring, or XML doc comments for selected code. Includes param and return documentation.</div>
      </div>
      <div class="bg-black/20 rounded-lg p-3">
        <div class="font-mono text-primary text-sm mb-1">/optimize</div>
        <div class="text-xs text-text-muted">Suggest performance improvements for selected code. Useful for hot paths, database queries, and loops.</div>
      </div>
      <div class="bg-black/20 rounded-lg p-3">
        <div class="font-mono text-primary text-sm mb-1">@workspace</div>
        <div class="text-xs text-text-muted">Use <span class="font-mono text-xs">@workspace</span> prefix to ask questions about your entire codebase: <span class="font-mono text-xs">@workspace Where is auth handled?</span></div>
      </div>
    </div>
  </div>

  <!-- Ghost Text Patterns -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Ghost Text Trigger Patterns</h2>
    <div class="space-y-3 text-sm">
      <div class="flex gap-3 items-start">
        <span class="bg-primary/20 text-primary rounded px-2 py-0.5 text-xs font-mono shrink-0">Function header</span>
        <div>Write the full function signature with typed parameters. Copilot predicts the body. Example: <span class="font-mono text-xs bg-black/30 px-1 rounded">async function fetchUser(id: string): Promise&lt;User&gt;</span></div>
      </div>
      <div class="flex gap-3 items-start">
        <span class="bg-primary/20 text-primary rounded px-2 py-0.5 text-xs font-mono shrink-0">Comment intent</span>
        <div>Write a descriptive comment on the line above: <span class="font-mono text-xs bg-black/30 px-1 rounded">// Validate email format using RFC 5322 pattern</span> then press Enter and wait.</div>
      </div>
      <div class="flex gap-3 items-start">
        <span class="bg-primary/20 text-primary rounded px-2 py-0.5 text-xs font-mono shrink-0">Open tabs</span>
        <div>Keep related files open in your editor. Copilot uses open tabs as context — models, types, and utility files influence suggestions.</div>
      </div>
      <div class="flex gap-3 items-start">
        <span class="bg-primary/20 text-primary rounded px-2 py-0.5 text-xs font-mono shrink-0">Example pattern</span>
        <div>Write one example of what you want, then start the second. Copilot completes the pattern: write one test case, start the second assertion, and Copilot fills the rest.</div>
      </div>
    </div>
  </div>

  <ToolPageCta />
</BaseLayout>

<script>
  const taskTips: Record<string, string[]> = {
    generate: [
      "Start with the function signature including full type annotations — Copilot uses types as strong hints.",
      "Open files that contain related types, interfaces, or utilities so Copilot can reference them.",
      "Write a detailed comment block (JSDoc/docstring style) above the function before asking Copilot to generate it.",
      "Specify edge cases explicitly: 'Handle null input', 'Should throw on invalid format', 'Return empty array not null'.",
      "Use the name of the function to encode intent: fetchUserById is better than getData."
    ],
    test: [
      "Select the function under test first, then use /tests or write the test file name to signal your intent.",
      "Specify your test framework in the chat: 'Write Jest tests with describe/it blocks and explicit mock setup'.",
      "Ask for both happy path and error path tests in one prompt to avoid back-and-forth.",
      "Include a test for each branch: null input, empty array, max value, concurrent calls.",
      "Reference existing test files in open tabs so Copilot mirrors your project's test style."
    ],
    refactor: [
      "Describe the specific code smell: 'Extract this 80-line function into smaller single-responsibility functions'.",
      "Specify what must NOT change: 'Keep the public API identical, only refactor internals'.",
      "Name the pattern you want applied: 'Apply the strategy pattern', 'Convert to functional style', 'Remove all mutation'.",
      "Ask for one refactor type at a time — mixing rename + extract + change logic leads to errors.",
      "After refactoring, use /tests to verify behavior hasn't changed."
    ],
    explain: [
      "Use /explain with specific questions: 'What does the bitwise operation on line 12 do?' is better than 'Explain this'.",
      "Ask Copilot to explain time and space complexity after explaining logic.",
      "Request explanation at different levels: 'Explain as if I'm new to async programming' vs 'Explain for a systems engineer'.",
      "Follow up: 'What could go wrong?' or 'What edge cases does this miss?' after the initial explanation.",
      "For regex or complex expressions, ask Copilot to break them into named capture groups with comments."
    ],
    fix: [
      "Always include the exact error message with /fix — it's the most important context.",
      "Paste the stack trace, not just the top line. Copilot uses the full trace to pinpoint the root cause.",
      "Describe expected vs actual behavior: 'Should return array, returns undefined when input is empty'.",
      "If the fix introduces new code, follow up with /tests to ensure the fix is tested.",
      "For async bugs (race conditions, unhandled rejections), explicitly state the async context in your prompt."
    ],
    document: [
      "Use /doc with the function selected to generate JSDoc with @param, @returns, and @throws tags.",
      "Ask for examples in the docstring: 'Include a @example showing typical usage with edge cases'.",
      "For RESTful routes, ask for OpenAPI YAML inline comments that tools like swagger-jsdoc can parse.",
      "Request docs at the module level too: 'Document this entire file with module-level JSDoc explaining its purpose'.",
      "Specify the audience: 'Write for public API consumers, not internal maintainers' changes the tone significantly."
    ],
    review: [
      "Frame the review scope: 'Review for security vulnerabilities only' vs 'Full review: style, logic, performance'.",
      "Ask Copilot to assign a severity to each issue: critical, warning, suggestion.",
      "Request concrete improvement suggestions, not just identification: 'Show me the fixed version of each issue'.",
      "Use @workspace to ask 'Is this pattern consistent with the rest of the codebase?'",
      "Ask for best practice comparison: 'How does this compare to the recommended Node.js security checklist?'"
    ],
    convert: [
      "Specify source and target explicitly: 'Convert this CommonJS module to ESM with named exports'.",
      "List breaking changes you want to preserve or remove: 'Keep the same function names, update all error types'.",
      "Convert in small chunks to avoid token limits and verify each section before continuing.",
      "Ask Copilot to add TODO comments where manual intervention is needed during migration.",
      "Include version numbers: 'Migrate from React 17 class components to React 18 hooks' is much clearer."
    ]
  };

  const roleMap: Record<string, string> = {
    generate: 'You are a senior {lang} engineer who writes clean, production-ready, well-typed code.',
    test: 'You are a senior {lang} engineer specializing in test-driven development and comprehensive test coverage.',
    refactor: 'You are an expert {lang} architect focused on clean code principles, SOLID patterns, and maintainability.',
    explain: 'You are an expert {lang} engineer and technical educator who explains complex code clearly and concisely.',
    fix: 'You are a {lang} debugging expert who systematically identifies root causes and implements minimal correct fixes.',
    document: 'You are a technical writer and {lang} engineer who writes clear, accurate, developer-facing documentation.',
    review: 'You are a staff {lang} engineer performing a thorough security and quality code review.',
    convert: 'You are a {lang} migration expert who understands both legacy and modern patterns in depth.'
  };

  const constraintMap: Record<string, string[]> = {
    generate: ['Handle all error cases explicitly', 'Include TypeScript types for all parameters and return values', 'No any types', 'Handle async operations with proper error propagation', 'Follow {style} patterns'],
    test: ['Test both success and failure cases', 'Mock all external dependencies', 'Use descriptive test names that explain the expected behavior', 'Cover boundary conditions and edge cases', 'Tests must be independent and idempotent'],
    refactor: ['Do not change the public API or function signatures', 'Preserve all existing behavior', 'Keep changes minimal — do not refactor unrelated code', 'Add types where missing', 'Remove dead code and unused variables'],
    explain: ['Explain line by line for complex sections', 'Note potential bugs or gotchas', 'Describe time and space complexity', 'Highlight any non-obvious assumptions'],
    fix: ['Fix only the reported bug — do not change unrelated code', 'Explain the root cause before showing the fix', 'Add a comment explaining why the fix works', 'Ensure the fix handles the same edge case in similar code'],
    document: ['Include @param and @returns with types', 'Add @throws for all thrown errors', 'Include a @example with typical and edge case usage', 'Keep descriptions concise but complete'],
    review: ['Categorize each issue as: critical / warning / suggestion', 'Focus on security, correctness, and performance in that order', 'Show the fixed version for each critical issue', 'Ignore pure style preferences unless they affect readability'],
    convert: ['Preserve all business logic exactly', 'Migrate imports and dependencies', 'Add TODO comments where manual review is required', 'Test each converted section before moving on']
  };

  const outputFormatMap: Record<string, string> = {
    generate: 'Output: Complete, runnable {lang} function with imports. No prose, only code with inline comments.',
    test: 'Output: Full test file with all imports, describe blocks, and beforeEach/afterEach setup. No prose.',
    refactor: 'Output: The refactored code only. Show before and after as a diff if helpful.',
    explain: 'Output: Structured explanation with section headers. Include a TL;DR at the top, then detailed walkthrough.',
    fix: 'Output: Brief root cause explanation (2-3 sentences), then the corrected code block.',
    document: 'Output: The original function with complete documentation comments added. No other changes.',
    review: 'Output: Numbered list of issues with severity, line reference, explanation, and suggested fix.',
    convert: 'Output: The fully converted code file. Mark lines that need manual review with // TODO: REVIEW comments.'
  };

  function buildPrompt(): { before: string; after: string } {
    const task = (document.getElementById('task-type') as HTMLSelectElement).value;
    const lang = (document.getElementById('language') as HTMLSelectElement).value;
    const context = (document.getElementById('context-level') as HTMLSelectElement).value;
    const taskInput = (document.getElementById('task-input') as HTMLTextAreaElement).value.trim();
    const framework = (document.getElementById('framework') as HTMLInputElement).value.trim();
    const codeStyle = (document.getElementById('code-style') as HTMLInputElement).value.trim();
    const includeRole = (document.getElementById('include-role') as HTMLInputElement).checked;
    const includeConstraints = (document.getElementById('include-constraints') as HTMLInputElement).checked;
    const includeOutputFormat = (document.getElementById('include-output-format') as HTMLInputElement).checked;
    const includeExample = (document.getElementById('include-example') as HTMLInputElement).checked;

    // Vague "before" prompt
    const before = taskInput || `Write ${lang} code to do this task`;

    // Build optimized "after" prompt
    const parts: string[] = [];

    if (includeRole) {
      const role = (roleMap[task] || 'You are an expert {lang} engineer.')
        .replace('{lang}', lang);
      parts.push(`# Role\n${role}`);
    }

    const contextLines: string[] = [];
    contextLines.push(`Task: ${taskInput}`);
    if (framework) contextLines.push(`Framework/Library: ${framework}`);
    if (codeStyle) contextLines.push(`Style requirements: ${codeStyle}`);
    if (context === 'moderate' || context === 'detailed') {
      contextLines.push(`Language: ${lang}`);
    }
    if (context === 'detailed') {
      contextLines.push(`Assume this code runs in production with real users.`);
      contextLines.push(`Consider thread safety, resource cleanup, and observability.`);
    }
    parts.push(`# Context\n${contextLines.join('\n')}`);

    if (includeConstraints) {
      const constraints = (constraintMap[task] || [])
        .map(c => c.replace('{lang}', lang).replace('{style}', codeStyle || 'idiomatic'))
        .slice(0, context === 'minimal' ? 2 : context === 'moderate' ? 3 : 5);
      if (constraints.length > 0) {
        parts.push(`# Constraints\n${constraints.map(c => `- ${c}`).join('\n')}`);
      }
    }

    if (includeExample && context !== 'minimal') {
      const exampleMap: Record<string, string> = {
        generate: `// Expected usage:\nconst result = await myFunction(input);\nconsole.log(result); // { data: ..., error: null }`,
        test: `// Expected test structure:\ndescribe('myFunction', () => {\n  it('should return X when Y', async () => {\n    expect(await myFunction(input)).toEqual(expected);\n  });\n});`,
        fix: `// Current error:\n// TypeError: Cannot read properties of undefined (reading 'map')\n// on line 42 when input array is empty`,
        document: `// Expected output format:\n/**\n * @description Brief description\n * @param {string} id - The user ID\n * @returns {Promise<User>} The user object\n * @throws {NotFoundError} If user does not exist\n */`
      };
      if (exampleMap[task]) {
        parts.push(`# Example\n${exampleMap[task]}`);
      }
    }

    if (includeOutputFormat) {
      const fmt = (outputFormatMap[task] || 'Output: Complete {lang} code.')
        .replace('{lang}', lang);
      parts.push(`# Output Format\n${fmt}`);
    }

    const after = parts.join('\n\n');
    return { before, after };
  }

  function renderTips() {
    const task = (document.getElementById('task-type') as HTMLSelectElement).value;
    const tips = taskTips[task] || [];
    const taskLabel = (document.getElementById('task-type') as HTMLSelectElement)
      .options[(document.getElementById('task-type') as HTMLSelectElement).selectedIndex].text;
    (document.getElementById('tips-task-label') as HTMLElement).textContent = taskLabel;
    const content = document.getElementById('tips-content')!;
    content.innerHTML = tips.map((tip, i) =>
      `<div class="flex gap-2 items-start"><span class="text-primary font-bold shrink-0">${i + 1}.</span><span class="text-text-muted">${tip}</span></div>`
    ).join('');
  }

  function update() {
    const { before, after } = buildPrompt();
    (document.getElementById('prompt-before') as HTMLElement).textContent = before;
    (document.getElementById('prompt-after') as HTMLElement).textContent = after;
    renderTips();
  }

  document.getElementById('build-btn')!.addEventListener('click', update);

  document.getElementById('copy-prompt')!.addEventListener('click', () => {
    const text = (document.getElementById('prompt-after') as HTMLElement).textContent || '';
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById('copy-prompt')!;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
    });
  });

  // Re-render tips on task type change
  document.getElementById('task-type')!.addEventListener('change', renderTips);

  // Initial render
  update();
</script>
