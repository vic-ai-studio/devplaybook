};

// ─── HCL block types ──────────────────────────────────────────────────────────
const BLOCK_KEYWORDS = new Set([
  'terraform', 'provider', 'resource', 'data', 'variable', 'output',
  'locals', 'module', 'moved', 'required_providers', 'required_version',
  'backend', 'ingress', 'egress', 'root_block_device', 'environment',
  'versioning_configuration', 'rule', 'apply_server_side_encryption_by_default',
]);

// ─── Syntax highlighting ──────────────────────────────────────────────────────
function highlightHcl(code: string): string {
  // Simple token-by-token highlighting for display
  const lines = code.split('\n');
  return lines.map(line => {
    // Comment
    if (/^\s*#/.test(line)) {
      return `<span class="text-text-muted italic">${escapeHtml(line)}</span>`;
    }

    // Block declarations: keyword "label" "label" {
    const blockMatch = line.match(/^(\s*)(terraform|provider|resource|data|variable|output|locals|module|moved|backend)\s*(.*)?(\{)\s*$/);
    if (blockMatch) {
      const indent = escapeHtml(blockMatch[1]);
      const kw = `<span class="text-purple-400 font-semibold">${escapeHtml(blockMatch[2])}</span>`;
      const rest = escapeHtml(blockMatch[3] || '');
      const brace = `<span class="text-text-muted">{</span>`;
      return `${indent}${kw} ${rest}${brace}`;
    }

    // Closing brace
    if (/^\s*\}\s*$/.test(line)) {
      return `<span class="text-text-muted">${escapeHtml(line)}</span>`;
    }

    // key = value lines
    const kvMatch = line.match(/^(\s*)([\w-]+)(\s*=\s*)(.*)$/);
    if (kvMatch) {
      const indent = escapeHtml(kvMatch[1]);
      const key = `<span class="text-blue-300">${escapeHtml(kvMatch[2])}</span>`;
      const eq = `<span class="text-text-muted">${escapeHtml(kvMatch[3])}</span>`;
      const val = highlightValue(kvMatch[4]);
      return `${indent}${key}${eq}${val}`;
    }

    // Nested block open line (word {)
    const nestedBlock = line.match(/^(\s*)([\w-]+)(\s*\{)\s*$/);
    if (nestedBlock) {
      const indent = escapeHtml(nestedBlock[1]);
      const label = `<span class="text-cyan-400">${escapeHtml(nestedBlock[2])}</span>`;
      const brace = `<span class="text-text-muted">{</span>`;
      return `${indent}${label}${brace}`;
    }

    return escapeHtml(line);
  }).join('\n');
}

function highlightValue(val: string): string {
  val = val.trim();
  // Boolean
  if (val === 'true' || val === 'false') {
    return `<span class="text-orange-400">${escapeHtml(val)}</span>`;
  }
  // Number
  if (/^-?\d+(\.\d+)?$/.test(val)) {
    return `<span class="text-yellow-400">${escapeHtml(val)}</span>`;
  }
  // String (quoted)
  if (/^"/.test(val)) {
    return `<span class="text-green-400">${escapeHtml(val)}</span>`;
  }
  // Reference (var., local., data., resource.)
  if (/^(var|local|data|module|aws_|google_|azurerm_)/.test(val)) {
    return `<span class="text-amber-300">${escapeHtml(val)}</span>`;
  }
  // Function call
  if (/^\w+\(/.test(val)) {
    return `<span class="text-pink-400">${escapeHtml(val)}</span>`;
  }
  return escapeHtml(val);
}

function escapeHtml(str: string): string {
  return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

// ─── HCL Formatter ────────────────────────────────────────────────────────────
interface FormatOptions {
  sortAttributes: boolean;
}

function formatHcl(input: string, opts: FormatOptions): string {
  const lines = input.split('\n');
  const result: string[] = [];
  let depth = 0;
  let blockLines: string[] = []; // current block's attribute lines (for alignment)
  let blockStart = 0;

  // First pass: normalize indentation and collect blocks for alignment
  const normalized = firstPassNormalize(lines);
  // Second pass: align = signs within each block scope
  const aligned = secondPassAlign(normalized, opts.sortAttributes);
  // Third pass: normalize blank lines
  return thirdPassBlankLines(aligned);
}

function firstPassNormalize(lines: string[]): string[] {
  const out: string[] = [];
  let depth = 0;

  for (let i = 0; i < lines.length; i++) {
    const raw = lines[i];
    const trimmed = raw.trim();

    if (trimmed === '') {
      out.push('');
      continue;
    }

    if (trimmed === '}') {
      depth = Math.max(0, depth - 1);
      out.push('  '.repeat(depth) + '}');
      continue;
    }

    // Lines ending with { open a new block
    if (trimmed.endsWith('{')) {
      out.push('  '.repeat(depth) + trimmed);
      depth++;
      continue;
    }

    // Comment line
    if (trimmed.startsWith('#')) {
      out.push('  '.repeat(depth) + trimmed);
      continue;
    }

    // Normal line
    out.push('  '.repeat(depth) + trimmed);
  }

  return out;
}

function secondPassAlign(lines: string[], sortAttributes: boolean): string[] {
  // Find blocks (between matching { }) and align = signs within each block
  const out: string[] = [...lines];

  // Collect ranges of consecutive key=value lines at the same depth
  let i = 0;
  while (i < out.length) {
    // Find a run of attribute lines (contain = but not block opens)
    const runStart = i;
    const baseIndent = getIndent(out[i]);
    const attrPattern = /^(\s+)([\w-]+)\s*=\s*(.*)$/;
    const runLines: number[] = [];

    let j = i;
    while (j < out.length) {
      const line = out[j];
      if (line.trim() === '' || line.trim() === '{' || line.trim() === '}') {
        if (runLines.length > 0) break;
        j++;
        continue;
      }
      // Must be at same indent
      if (getIndent(line) !== baseIndent) break;
      // Must match attr pattern and not be a block open
      if (attrPattern.test(line) && !line.trimEnd().endsWith('{')) {
        runLines.push(j);
        j++;
      } else {
        if (runLines.length > 0) break;
        j++;
      }
    }

    if (runLines.length > 1) {
      // Find max key length in this run
      let maxKeyLen = 0;
      const parsed: Array<{ indent: string; key: string; value: string }> = [];
      for (const idx of runLines) {
        const m = out[idx].match(/^(\s*)([\w-]+)\s*=\s*(.*)$/);
        if (m) {
          maxKeyLen = Math.max(maxKeyLen, m[2].length);
          parsed.push({ indent: m[1], key: m[2], value: m[3] });
        }
      }

      // Sort if requested
      if (sortAttributes) {
        parsed.sort((a, b) => a.key.localeCompare(b.key));
      }

      for (let k = 0; k < runLines.length; k++) {
        const { indent, key, value } = parsed[k];
        const padded = key + ' '.repeat(maxKeyLen - key.length);
        out[runLines[k]] = `${indent}${padded} = ${value}`;
      }
    }

    i = j === i ? i + 1 : j;
  }

  return out;
}

function thirdPassBlankLines(lines: string[]): string[] {
  const out: string[] = [];
  let blankCount = 0;

  for (const line of lines) {
    if (line.trim() === '') {
      blankCount++;
      if (blankCount <= 1) out.push('');
    } else {
      blankCount = 0;
      out.push(line);
    }
  }

  // Remove leading/trailing blank lines
  while (out.length > 0 && out[0].trim() === '') out.shift();
  while (out.length > 0 && out[out.length - 1].trim() === '') out.pop();

  return out;
}

function getIndent(line: string): number {
  return line.length - line.trimStart().length;
}

// ─── HCL Validator ────────────────────────────────────────────────────────────
interface ValidationIssue {
  level: 'error' | 'warning' | 'info';
  message: string;
  line?: number;
}

function validateHcl(input: string): ValidationIssue[] {
  const issues: ValidationIssue[] = [];
  const lines = input.split('\n');

  // 1. Brace balance
  let depth = 0;
  const openStack: number[] = [];
  for (let i = 0; i < lines.length; i++) {
    const line = lines[i];
    // Skip comments and strings (simplified)
    if (line.trim().startsWith('#')) continue;
    for (const ch of line) {
      if (ch === '{') { depth++; openStack.push(i + 1); }
      if (ch === '}') {
        depth--;
        if (openStack.length) openStack.pop();
        if (depth < 0) {
          issues.push({ level: 'error', message: `Unexpected closing brace }`, line: i + 1 });
          depth = 0;
        }
      }
    }
  }
  if (depth > 0) {
    issues.push({ level: 'error', message: `${depth} unclosed block(s) — missing closing brace(s)`, line: openStack[openStack.length - 1] });
  }

  // 2. Deprecated 0.11 string interpolation (wrapping bare references)
  const deprecatedInterp = /"\$\{(var\.|local\.|data\.|module\.|[a-z_]+\.[a-z_]+\.)[^}]+\}"/;
  for (let i = 0; i < lines.length; i++) {
    const line = lines[i];
    if (line.trim().startsWith('#')) continue;
    // Check for "${var.x}" without any other string content (pure reference)
    const m = line.match(/=\s*"\$\{([^}]+)\}"\s*$/);
    if (m && !m[1].includes(' ') && !m[1].includes('+') && !m[1].includes('(')) {
      issues.push({
        level: 'warning',
        message: `Deprecated 0.11 pattern: "\${${m[1]}}" should be just ${m[1]}`,
        line: i + 1
      });
    }
  }

  // 3. Double quotes around references (e.g. = "var.foo" literally)
  for (let i = 0; i < lines.length; i++) {
    const line = lines[i];
    if (line.trim().startsWith('#')) continue;
    const m = line.match(/=\s*"(var\.[a-z_]+|local\.[a-z_]+|data\.[a-z_]+\.[a-z_]+)"\s*$/);
    if (m) {
      issues.push({
        level: 'warning',
        message: `Possible mistake: "${m[1]}" is a string literal, not a reference. Remove quotes.`,
        line: i + 1
      });
    }
  }

  // 4. list() and map() deprecated constructors
  for (let i = 0; i < lines.length; i++) {
    const line = lines[i];
    if (/\b(list|map)\(/.test(line) && !line.trim().startsWith('#')) {
      issues.push({
        level: 'warning',
        message: `Deprecated 0.11 function: list() or map() — use [] or {} literal syntax`,
        line: i + 1
      });
    }
  }

  // 5. Missing required_version in terraform block
  const hasTerraformBlock = /\bterraform\s*\{/.test(input);
  const hasRequiredVersion = /required_version/.test(input);
  if (hasTerraformBlock && !hasRequiredVersion) {
    issues.push({ level: 'warning', message: 'terraform block is missing required_version — pin your Terraform version for reproducibility' });
  }

  // 6. count.index with static resources (hint about for_each)
  if (/count\.index/.test(input)) {
    issues.push({ level: 'info', message: 'count.index detected — consider for_each with a map for more readable state keys (e.g. resource["name"] instead of resource[0])' });
  }

  return issues;
}

// ─── Extract variables ────────────────────────────────────────────────────────
function extractVariables(input: string): string {
  const varRefs = new Set<string>();
  const regex = /\bvar\.([a-zA-Z_][a-zA-Z0-9_]*)/g;
  let m: RegExpExecArray | null;
  while ((m = regex.exec(input)) !== null) {
    varRefs.add(m[1]);
  }

  if (varRefs.size === 0) return '# No var.xxx references found in the input.';

  const sorted = [...varRefs].sort();
  return sorted.map(v => `variable "${v}" {\n  description = ""\n  type        = string\n  # default   = ""\n}\n`).join('\n');
}

// ─── UI ───────────────────────────────────────────────────────────────────────
const inputEl = document.getElementById('hcl-input') as HTMLTextAreaElement;
const outputEl = document.getElementById('hcl-output') as HTMLPreElement;
const formatBtn = document.getElementById('format-btn') as HTMLButtonElement;
const validateBtn = document.getElementById('validate-btn') as HTMLButtonElement;
const extractBtn = document.getElementById('extract-btn') as HTMLButtonElement;
const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;
const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
const copyExtractBtn = document.getElementById('copy-extract-btn') as HTMLButtonElement;
const exampleSelect = document.getElementById('example-select') as HTMLSelectElement;
const sortAttrsEl = document.getElementById('sort-attrs') as HTMLInputElement;
const outputStatus = document.getElementById('output-status') as HTMLSpanElement;
const validationPanel = document.getElementById('validation-panel') as HTMLDivElement;
const validationList = document.getElementById('validation-list') as HTMLDivElement;
const validationSummary = document.getElementById('validation-summary') as HTMLSpanElement;
const extractPanel = document.getElementById('extract-panel') as HTMLDivElement;
const extractOutput = document.getElementById('extract-output') as HTMLPreElement;
const inputLineCount = document.getElementById('input-line-count') as HTMLSpanElement;

// Track last formatted code (plain) for copy
let lastFormattedPlain = '';
let lastExtractedPlain = '';

exampleSelect.addEventListener('change', () => {
  const val = exampleSelect.value;
  if (val && EXAMPLES[val]) {
    inputEl.value = EXAMPLES[val];
    exampleSelect.value = '';
    updateInputStats();
    outputEl.innerHTML = '<span class="text-text-muted italic">Click "Format HCL" to format…</span>';
    outputStatus.textContent = '';
    validationPanel.classList.add('hidden');
    extractPanel.classList.add('hidden');
  }
});

clearBtn.addEventListener('click', () => {
  inputEl.value = '';
  outputEl.innerHTML = '<span class="text-text-muted italic">Formatted HCL will appear here…</span>';
  outputStatus.textContent = '';
  validationPanel.classList.add('hidden');
  extractPanel.classList.add('hidden');
  inputLineCount.textContent = '';
  lastFormattedPlain = '';
});

inputEl.addEventListener('input', updateInputStats);

function updateInputStats() {
  const lines = inputEl.value.split('\n').length;
  inputLineCount.textContent = inputEl.value ? `${lines} lines` : '';
}

formatBtn.addEventListener('click', () => {
  const input = inputEl.value.trim();
  if (!input) { inputEl.focus(); return; }

  const formatted = formatHcl(input, { sortAttributes: sortAttrsEl.checked });
  lastFormattedPlain = formatted;

  outputEl.innerHTML = highlightHcl(formatted);
  outputStatus.textContent = `${formatted.split('\n').length} lines`;
  outputStatus.className = 'text-xs text-green-400';
});

validateBtn.addEventListener('click', () => {
  const input = inputEl.value.trim();
  if (!input) { inputEl.focus(); return; }

  const issues = validateHcl(input);
  const errors = issues.filter(i => i.level === 'error').length;
  const warnings = issues.filter(i => i.level === 'warning').length;
  const infos = issues.filter(i => i.level === 'info').length;

  if (issues.length === 0) {
    validationSummary.textContent = 'All checks passed';
    validationSummary.className = 'text-xs text-green-400';
    validationList.innerHTML = '<div class="text-sm text-green-400 flex items-center gap-2"><span>✓</span> No issues found — HCL looks valid!</div>';
  } else {
    validationSummary.textContent = `${errors} error${errors !== 1 ? 's' : ''}, ${warnings} warning${warnings !== 1 ? 's' : ''}, ${infos} info`;
    validationSummary.className = errors > 0 ? 'text-xs text-red-400' : 'text-xs text-yellow-400';

    const iconMap = { error: '✗', warning: '⚠', info: 'ℹ' };
    const colorMap = { error: 'text-red-400', warning: 'text-yellow-400', info: 'text-blue-400' };

    validationList.innerHTML = issues.map(issue => `
      <div class="flex gap-2 text-sm items-start">
        <span class="flex-shrink-0 font-mono font-bold ${colorMap[issue.level]}">${iconMap[issue.level]}</span>
        <div>
          ${issue.line ? `<span class="text-xs font-mono text-text-muted mr-2">line ${issue.line}</span>` : ''}
          <span>${escapeHtml(issue.message)}</span>
        </div>
      </div>
    `).join('');
  }

  validationPanel.classList.remove('hidden');
});

extractBtn.addEventListener('click', () => {
  const input = inputEl.value.trim();
  if (!input) { inputEl.focus(); return; }

  const skeleton = extractVariables(input);
  lastExtractedPlain = skeleton;
  extractOutput.textContent = skeleton;
  extractPanel.classList.remove('hidden');
  extractPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
});

copyBtn.addEventListener('click', async () => {
  const text = lastFormattedPlain || inputEl.value;
  if (!text) return;
  try {
    await navigator.clipboard.writeText(text);
    copyBtn.textContent = 'Copied!';
    setTimeout(() => { copyBtn.textContent = 'Copy'; }, 1500);
  } catch {
    copyBtn.textContent = 'Copy failed';
    setTimeout(() => { copyBtn.textContent = 'Copy'; }, 1500);
  }
});

copyExtractBtn.addEventListener('click', async () => {
  if (!lastExtractedPlain) return;
  try {
    await navigator.clipboard.writeText(lastExtractedPlain);
    copyExtractBtn.textContent = 'Copied!';
    setTimeout(() => { copyExtractBtn.textContent = 'Copy'; }, 1500);
  } catch {
    copyExtractBtn.textContent = 'Copy failed';
    setTimeout(() => { copyExtractBtn.textContent = 'Copy'; }, 1500);
  }
});


</script>
