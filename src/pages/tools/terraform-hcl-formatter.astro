---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is HCL and why does formatting matter?",
    answer: "HCL (HashiCorp Configuration Language) is the declarative language used by Terraform to define infrastructure. Consistent formatting makes diffs smaller in code review, reduces merge conflicts, and makes large configs easier to navigate. The official terraform fmt command enforces a canonical style, and this tool applies the same rules in your browser."
  },
  {
    question: "What does terraform fmt actually do?",
    answer: "terraform fmt reformats HCL files to canonical style: 2-space indentation, aligned = signs within blocks, normalized blank lines, and consistent brace placement. It does not change logic — only whitespace and alignment. You should run it as a pre-commit hook or in CI to keep your codebase consistent."
  },
  {
    question: "Should I sort attributes alphabetically?",
    answer: "Alphabetical sorting is optional and depends on team preference. It makes it easier to find attributes in large blocks and reduces the chance of duplicate keys, but it can make logically-related attributes (like ingress/egress rules) feel disconnected. This formatter lets you toggle it on or off."
  },
  {
    question: "What Terraform block types are supported?",
    answer: "This formatter recognises terraform, provider, resource, data, variable, output, locals, module, and moved blocks. Each block is parsed individually so indentation and alignment are correctly scoped to their own block level."
  },
  {
    question: "What does the 'Extract Variables' button do?",
    answer: "It scans your HCL for every var.xxx reference and generates a variables.tf skeleton with an empty variable block for each unique variable name. This is handy when you've written a module and need to declare all its input variables quickly."
  },
  {
    question: "What are the deprecated 0.11-style patterns this tool detects?",
    answer: "Terraform 0.12 introduced first-class expressions. Common 0.11 patterns that still work but are discouraged include: string-wrapping references like \"${var.name}\" (should be just var.name), and list() / map() constructor functions that were replaced by literal syntax. This tool flags them so you can modernise your configs."
  }
];
---

<BaseLayout
  title="Terraform HCL Formatter — Format & Validate HCL Online"
  description="Format and validate Terraform HCL code in your browser. Aligns = signs, normalizes indentation, detects mismatched braces and deprecated syntax, and extracts variable skeletons. Free, no signup."
  tool="terraform hcl formatter, terraform fmt online, hcl formatter, terraform validator, hcl validator, terraform format, extract terraform variables"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Terraform HCL Formatter",
    "url": "https://devplaybook.cc/tools/terraform-hcl-formatter",
    "description": "Format, validate, and extract variables from Terraform HCL code. Runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Terraform HCL Formatter</h1>
  <p class="text-text-muted mb-4">Format and validate Terraform HCL like <code class="font-mono text-xs bg-bg-card border border-border px-1 rounded">terraform fmt</code> — right in your browser. Aligns <code class="font-mono text-xs bg-bg-card border border-border px-1 rounded">=</code> signs, normalizes indentation, validates syntax, detects deprecated patterns, and extracts variable skeletons.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Aligns = signs per block</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Validates HCL syntax</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Detects deprecated 0.11 patterns</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Extracts variables.tf skeleton</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100% runs in your browser</span>
  </div>

  <!-- Toolbar -->
  <div class="flex flex-wrap items-center gap-2 mb-3">
    <select id="example-select" class="px-3 py-2 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors focus:outline-none focus:border-primary cursor-pointer">
      <option value="">Load example HCL…</option>
      <option value="ec2">EC2 + Security Group</option>
      <option value="rds">RDS Database</option>
      <option value="lambda">Lambda Function</option>
      <option value="s3">S3 Bucket</option>
    </select>

    <label class="flex items-center gap-2 px-3 py-2 bg-bg-card border border-border rounded-lg text-sm cursor-pointer hover:border-primary transition-colors select-none">
      <input type="checkbox" id="sort-attrs" class="w-3 h-3 accent-primary" />
      Sort attributes A–Z
    </label>

    <div class="flex-1"></div>

    <button id="format-btn" class="px-4 py-2 bg-primary text-white rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors">Format HCL</button>
    <button id="validate-btn" class="px-3 py-2 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Validate</button>
    <button id="extract-btn" class="px-3 py-2 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Extract Variables</button>
    <button id="clear-btn" class="px-3 py-2 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Clear</button>
  </div>

  <!-- Two-panel layout -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
    <!-- Input -->
    <div class="bg-bg-card border border-border rounded-lg overflow-hidden flex flex-col">
      <div class="flex items-center justify-between px-4 py-2 border-b border-border flex-shrink-0">
        <span class="text-sm font-medium">Input HCL</span>
        <span id="input-line-count" class="text-xs text-text-muted"></span>
      </div>
      <textarea
        id="hcl-input"
        class="w-full flex-1 bg-transparent p-4 text-sm font-mono focus:outline-none resize-none"
        rows="22"
        placeholder="Paste your Terraform HCL here…"
        spellcheck="false"
      ></textarea>
    </div>

    <!-- Output -->
    <div class="bg-bg-card border border-border rounded-lg overflow-hidden flex flex-col">
      <div class="flex items-center justify-between px-4 py-2 border-b border-border flex-shrink-0">
        <span class="text-sm font-medium">Output</span>
        <div class="flex items-center gap-2">
          <span id="output-status" class="text-xs"></span>
          <button id="copy-btn" class="px-2 py-1 text-xs bg-bg-card border border-border rounded hover:border-primary transition-colors">Copy</button>
        </div>
      </div>
      <pre
        id="hcl-output"
        class="flex-1 p-4 text-sm font-mono overflow-auto whitespace-pre-wrap leading-relaxed"
        style="min-height: 22rem;"
      ><span class="text-text-muted italic">Formatted HCL will appear here…</span></pre>
    </div>
  </div>

  <!-- Validation results -->
  <div id="validation-panel" class="hidden bg-bg-card border border-border rounded-lg mb-4 overflow-hidden">
    <div class="flex items-center justify-between px-4 py-2 border-b border-border">
      <span class="text-sm font-medium">Validation Results</span>
      <span id="validation-summary" class="text-xs text-text-muted"></span>
    </div>
    <div id="validation-list" class="p-4 space-y-2"></div>
  </div>

  <!-- Extract variables panel -->
  <div id="extract-panel" class="hidden bg-bg-card border border-border rounded-lg mb-4 overflow-hidden">
    <div class="flex items-center justify-between px-4 py-2 border-b border-border">
      <span class="text-sm font-medium">Extracted variables.tf Skeleton</span>
      <button id="copy-extract-btn" class="px-2 py-1 text-xs bg-bg-card border border-border rounded hover:border-primary transition-colors">Copy</button>
    </div>
    <pre id="extract-output" class="p-4 text-sm font-mono whitespace-pre-wrap overflow-auto"></pre>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Terraform HCL Formatter" relatedTags={['terraform', 'hcl', 'infrastructure', 'devops', 'iac', 'aws']} />
</BaseLayout>

<script>
// ─── Example HCL snippets ─────────────────────────────────────────────────────
const EXAMPLES: Record<string, string> = {
  ec2: `terraform {
required_version = ">= 1.5.0"
