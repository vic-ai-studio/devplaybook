---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CorsHeadersChecker from '../../components/CorsHeadersChecker.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is CORS and why does it matter?",
    answer: "CORS (Cross-Origin Resource Sharing) is a browser security mechanism that controls how web pages can make requests to a different domain, protocol, or port than the one that served the page. Without CORS headers, browsers block cross-origin requests by default. If your API needs to accept requests from a frontend at a different domain, the API server must include the correct Access-Control-Allow-Origin header.",
  },
  {
    question: "What is the Access-Control-Allow-Origin header?",
    answer: "Access-Control-Allow-Origin tells the browser which origins are allowed to read the response. Setting it to * allows all origins but disables credentials. Setting it to a specific origin (e.g., https://yourapp.com) allows only that origin. If this header is missing or doesn't match the requesting origin, the browser blocks the response — even if the request succeeded on the server.",
  },
  {
    question: "What is an OPTIONS preflight request?",
    answer: "For 'non-simple' requests (non-GET/POST, custom headers, or content-type: application/json), browsers first send an OPTIONS preflight to check if the server permits the actual request. The server must respond with Access-Control-Allow-Methods and Access-Control-Allow-Headers. If the preflight fails, the actual request is never sent. Caching preflight responses with Access-Control-Max-Age reduces latency.",
  },
  {
    question: "Why does Access-Control-Allow-Origin: * break with credentials?",
    answer: "The CORS spec explicitly forbids using wildcard (*) with Access-Control-Allow-Credentials: true. When credentials (cookies, auth headers) are included in a cross-origin request, the browser requires the server to echo back the exact requesting origin — not *. Use a dynamic origin allowlist on the server instead: check the incoming Origin header and echo it back if it's on your whitelist.",
  },
  {
    question: "What does Access-Control-Expose-Headers do?",
    answer: "By default, the browser only exposes a small set of response headers (like Content-Type) to JavaScript. Access-Control-Expose-Headers lists additional headers that should be accessible via response.headers.get() — for example, custom headers like X-Request-Id, X-Rate-Limit-Remaining, or Link for pagination. Headers not in this list are invisible to client-side code even if present in the response.",
  },
  {
    question: "How do I fix CORS errors in nginx, Express, or FastAPI?",
    answer: "Nginx: add add_header Access-Control-Allow-Origin \"https://yourapp.com\"; to your server block. Express: use the cors() middleware (npm install cors) with the origin option. FastAPI: add CORSMiddleware with allow_origins. For dynamic origins, check the incoming Origin header against a whitelist and echo it back. Never use * in production APIs that handle authenticated requests.",
  },
];
---

<BaseLayout
  title="CORS Headers Checker — Test Cross-Origin Policy for Any URL"
  description="Check CORS headers for any API URL. Send a real cross-origin request, analyze Access-Control-Allow-Origin, methods, headers, and credentials. Get instant verdict and fix suggestions. Free developer tool."
  tool="CORS headers checker, CORS tester, Access-Control-Allow-Origin checker, cross-origin request debugger, CORS policy analyzer, CORS configuration tester"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "CORS Headers Checker",
    "url": "https://devplaybook.cc/tools/cors-headers-checker",
    "description": "Test CORS configuration for any API endpoint. Analyze Access-Control-Allow-Origin, methods, headers, credentials, and preflight caching. Get instant verdict with fix suggestions.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">CORS Headers Checker</h1>
  <p class="text-text-muted mb-4">
    Test CORS policy for any API endpoint. Inspect <code class="font-mono bg-surface px-1 rounded text-sm">Access-Control-Allow-Origin</code>, methods, headers, and credentials. Get an instant verdict and server config snippets.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Analyzes all CORS headers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> OPTIONS preflight support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Nginx / Express fix snippets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Credentials & wildcard validation</span>
  </div>
  <CorsHeadersChecker client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CORS Headers Checker" relatedTags={['cors', 'api', 'http', 'security', 'web', 'developer-tools']} />
</BaseLayout>
