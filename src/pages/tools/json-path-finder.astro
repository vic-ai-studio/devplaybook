---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonPathFinder from '../../components/JsonPathFinder.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout title="JSON Path Finder" description="Paste JSON and click any value to instantly get its JSONPath and jq path. Visual tree explorer with copy-to-clipboard. No server, no signup." tool="JSON Path Finder, JSONPath Explorer, jq Path Generator, JSON Tree Viewer, JSON Click Path">
  <h1 class="text-3xl font-bold mb-2">JSON Path Finder</h1>
  <p class="text-text-muted mb-8">Paste JSON and click any value to get its JSONPath and jq expression. Copy paths instantly for use in queries, scripts, or APIs.</p>
  <JsonPathFinder client:load />
  <AffiliateSection category={['json', 'data']} />
  <ToolPageCta currentTool="JSON Path Finder" relatedTags={['json', 'data', 'api', 'debugging']} />
</BaseLayout>
