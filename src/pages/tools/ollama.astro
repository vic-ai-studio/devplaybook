---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Ollama and how does it work?", answer: "Ollama is an open-source tool that lets you download and run large language models entirely on your own hardware. It bundles model weights, configuration, and a lightweight inference server into a single CLI. When you run 'ollama serve', it starts a local REST API on port 11434 that any application can call — exactly like calling OpenAI's API but with no network requests leaving your machine." },
  { question: "Which models can I run with Ollama?", answer: "Ollama supports hundreds of models from its official registry including Llama 3.2 (1B–90B), Mistral 7B, Gemma 3 (1B–27B), Phi-4, Qwen2.5, DeepSeek-R1, CodeLlama, and many more. You can pull any model with 'ollama pull <name>'. Ollama uses GGUF quantized models, so a 7B model typically needs 4–6 GB of RAM." },
  { question: "What GPU and hardware do I need for Ollama?", answer: "Ollama runs on CPU-only hardware, but GPU acceleration dramatically improves speed. On macOS, it uses Apple Metal (M1/M2/M3/M4 chips are ideal). On Windows/Linux, it supports NVIDIA CUDA and AMD ROCm. A 7B model runs at roughly 5–10 tokens/sec on CPU, 50–100+ tokens/sec on a modern GPU. Minimum 8 GB RAM for 7B models; 16 GB+ recommended for 13B models." },
  { question: "Is Ollama compatible with OpenAI client libraries?", answer: "Yes. Ollama exposes an OpenAI-compatible REST API. You can point any OpenAI SDK at http://localhost:11434/v1 by setting the base URL. This means tools like LangChain, LlamaIndex, Open WebUI, AnythingLLM, and custom Python/Node apps work with Ollama without code changes — just swap the API base URL." },
  { question: "How do I create a custom model with Ollama?", answer: "Use a Modelfile — a simple text file similar to a Dockerfile. You specify FROM (base model), SYSTEM (system prompt), PARAMETER (temperature, context length, stop tokens), and TEMPLATE (prompt format). Run 'ollama create mymodel -f Modelfile' to build it. This lets you bake in personas, task-specific instructions, or custom context windows." },
  { question: "How does Ollama compare to LM Studio?", answer: "Ollama is CLI/API-first and ideal for developers who want to integrate local LLMs into apps or scripts. LM Studio provides a desktop GUI with a built-in chat interface and model browser — better for non-technical users or quick experimentation. Both support GGUF models and expose OpenAI-compatible APIs. Ollama is more scriptable; LM Studio is more visual." },
];
---

<BaseLayout
  title="Ollama: Run LLMs Locally on Mac, Windows & Linux (2026)"
  description="Learn how to install Ollama, pull models like Llama 3.2 and Mistral, run a local REST API server, and customize models with Modelfiles. The complete guide to private local AI in 2026."
  tool="Ollama, run LLM locally, local AI tools, private LLM, Llama local, offline AI, self-hosted LLM"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"Ollama: Run LLMs Locally on Mac, Windows & Linux","url":"https://devplaybook.cc/tools/ollama","description":"Complete guide to installing Ollama, running local LLMs, and building private AI apps in 2026."})} />

  <h1 class="text-3xl font-bold mb-2">Ollama: Run LLMs Locally on Mac, Windows &amp; Linux</h1>
  <p class="text-text-muted mb-6">Ollama is the fastest way to run open-source large language models entirely on your own hardware — no API keys, no cloud costs, no data leaving your machine. Install it in under a minute and have Llama, Mistral, or Gemma running locally in 2026.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Completely private — no data sent to cloud</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> OpenAI-compatible REST API</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> macOS, Windows, Linux support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GPU acceleration (CUDA, Metal, ROCm)</span>
  </div>

  <ToolPageCta />

  <!-- Installation -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Installation</h2>
    <p class="text-text-muted text-sm mb-4">Ollama installs as a single binary with no dependencies. Choose your platform:</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-3"><code># macOS (Homebrew)
brew install ollama

# Linux (one-liner)
curl -fsSL https://ollama.com/install.sh | sh

# Windows
# Download the installer from https://ollama.com/download
# Or via winget:
winget install Ollama.Ollama</code></pre>
    <p class="text-text-muted text-sm">After installation, Ollama runs as a background service. Verify with <code class="bg-bg-card border border-border rounded px-1.5 py-0.5 text-xs font-mono">ollama --version</code>.</p>
  </div>

  <!-- Pulling and running models -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Pulling and Running Models</h2>
    <p class="text-text-muted text-sm mb-4">Use <code class="bg-bg-card border border-border rounded px-1.5 py-0.5 text-xs font-mono">ollama pull</code> to download a model and <code class="bg-bg-card border border-border rounded px-1.5 py-0.5 text-xs font-mono">ollama run</code> to start an interactive chat. Popular models and their approximate RAM requirements:</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># Pull models (downloads to ~/.ollama/models)
ollama pull llama3.2          # Llama 3.2 3B — ~2 GB, fast on CPU
ollama pull llama3.2:7b       # Llama 3.2 7B — ~4.7 GB
ollama pull mistral           # Mistral 7B — ~4.1 GB
ollama pull gemma3            # Gemma 3 4B — ~3 GB
ollama pull phi4              # Phi-4 14B — ~8.9 GB
ollama pull deepseek-r1:7b    # DeepSeek-R1 7B — ~4.7 GB

# Start interactive chat
ollama run llama3.2

# Run with a one-shot prompt
ollama run mistral "Explain Docker in one paragraph"

# List downloaded models
ollama list

# Remove a model
ollama rm phi4</code></pre>
    <p class="text-text-muted text-sm">Models are stored in <code class="bg-bg-card border border-border rounded px-1.5 py-0.5 text-xs font-mono">~/.ollama/models</code> on macOS/Linux and <code class="bg-bg-card border border-border rounded px-1.5 py-0.5 text-xs font-mono">C:\Users\&lt;user&gt;\.ollama\models</code> on Windows.</p>
  </div>

  <!-- REST API -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Using the Ollama REST API</h2>
    <p class="text-text-muted text-sm mb-4">Ollama starts an HTTP server on <code class="bg-bg-card border border-border rounded px-1.5 py-0.5 text-xs font-mono">http://localhost:11434</code> automatically. It exposes two API styles: the native Ollama API and an OpenAI-compatible endpoint at <code class="bg-bg-card border border-border rounded px-1.5 py-0.5 text-xs font-mono">/v1/chat/completions</code>.</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># Native Ollama API — streaming chat
curl http://localhost:11434/api/chat -d '&#123;
  "model": "llama3.2",
  "messages": [&#123;"role": "user", "content": "Why is the sky blue?"&#125;],
  "stream": false
&#125;'

# OpenAI-compatible endpoint (drop-in replacement)
curl http://localhost:11434/v1/chat/completions \
  -H "Content-Type: application/json" \
  -d '&#123;
    "model": "llama3.2",
    "messages": [&#123;"role": "user", "content": "Write a Python hello world"&#125;]
  &#125;'

# Python with openai SDK pointing at Ollama
# pip install openai
from openai import OpenAI
client = OpenAI(base_url="http://localhost:11434/v1", api_key="ollama")
response = client.chat.completions.create(
  model="llama3.2",
  messages=[&#123;"role": "user", "content": "Hello!"&#125;]
)
print(response.choices[0].message.content)</code></pre>
  </div>

  <!-- Modelfile customization -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Modelfile: Custom Model Configuration</h2>
    <p class="text-text-muted text-sm mb-4">A Modelfile lets you create a named model variant with a custom system prompt, parameters, and prompt template — similar to a Dockerfile for LLMs.</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># Create a file named "Modelfile"
FROM llama3.2

# Set a persistent system prompt
SYSTEM """
You are a senior software engineer who gives concise, production-ready
code examples with minimal explanation. Always use modern best practices.
"""

# Tune generation parameters
PARAMETER temperature 0.3
PARAMETER num_ctx 8192
PARAMETER top_p 0.9

# Build and run
# ollama create dev-assistant -f Modelfile
# ollama run dev-assistant "Write a FastAPI endpoint for user auth"</code></pre>
    <p class="text-text-muted text-sm">Custom models appear in <code class="bg-bg-card border border-border rounded px-1.5 py-0.5 text-xs font-mono">ollama list</code> alongside downloaded models and can be shared with <code class="bg-bg-card border border-border rounded px-1.5 py-0.5 text-xs font-mono">ollama push</code>.</p>
  </div>

  <!-- Comparison table -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-4">Ollama vs LM Studio vs llama.cpp</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-text-muted text-xs uppercase border-b border-border">
            <th class="text-left pb-2 pr-4">Feature</th>
            <th class="text-left pb-2 pr-4">Ollama</th>
            <th class="text-left pb-2 pr-4">LM Studio</th>
            <th class="text-left pb-2">llama.cpp</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border text-xs">
          <tr><td class="py-2 pr-4 font-medium">Interface</td><td class="py-2 pr-4">CLI + REST API</td><td class="py-2 pr-4">Desktop GUI</td><td class="py-2">CLI + server</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Ease of use</td><td class="py-2 pr-4">Very easy</td><td class="py-2 pr-4">Very easy</td><td class="py-2">Technical</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Model format</td><td class="py-2 pr-4">GGUF (auto)</td><td class="py-2 pr-4">GGUF (manual)</td><td class="py-2">GGUF (manual)</td></tr>
          <tr><td class="py-2 pr-4 font-medium">OpenAI API compat</td><td class="py-2 pr-4 text-green-500">Yes</td><td class="py-2 pr-4 text-green-500">Yes</td><td class="py-2 text-green-500">Yes (server)</td></tr>
          <tr><td class="py-2 pr-4 font-medium">GPU support</td><td class="py-2 pr-4">CUDA, Metal, ROCm</td><td class="py-2 pr-4">CUDA, Metal</td><td class="py-2">CUDA, Metal, Vulkan</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Ideal for</td><td class="py-2 pr-4">Developers, API apps</td><td class="py-2 pr-4">Non-technical users</td><td class="py-2">Advanced customization</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Model library</td><td class="py-2 pr-4">ollama.com registry</td><td class="py-2 pr-4">HuggingFace browse</td><td class="py-2">Manual download</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Ollama Local LLM" relatedTags={['ai', 'llm', 'local-ai', 'ollama', 'private-ai', 'inference']} />
</BaseLayout>
