---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What are coverage badges and why use them?", answer: "Coverage badges are small SVG images you embed in your README to show the percentage of code covered by tests. They give contributors and users an at-a-glance quality signal. A badge showing 95% coverage signals a well-tested project; one showing 20% may deter contributors." },
  { question: "How do I get my coverage percentage?", answer: "Run your test suite with coverage enabled: Jest uses --coverage flag, Vitest uses --coverage, Go uses go test -cover, and Python uses pytest-cov. After running, you'll see a summary with the overall percentage. Use that number in this generator." },
  { question: "What do the badge colors mean?", answer: "Green (≥90%) indicates excellent coverage. Yellow-green (75-89%) indicates good coverage. Yellow (60-74%) indicates moderate coverage. Orange (40-59%) indicates low coverage. Red (<40%) indicates very low coverage. These thresholds follow common open-source conventions but can be customized to your project standards." },
  { question: "How do I add the badge to my README?", answer: "Copy the Markdown snippet from this generator and paste it at the top of your README.md, typically next to other badges like build status. The badge links to your coverage report or test workflow, so viewers can click for details." },
  { question: "Should I use shields.io or a CI-generated badge?", answer: "Static badges (generated here) are simple and always visible but need manual updates. Dynamic badges from shields.io or Codecov update automatically from your CI pipeline. For active projects, integrate Codecov or Coveralls with GitHub Actions to auto-update badges on every push." },
];
---

<BaseLayout
  title="Test Coverage Badge Generator — Create README Coverage Badges Online"
  description="Free online test coverage badge generator. Enter your coverage percentage and get SVG badges in multiple styles for your README. Supports shields.io format, custom colors, and Markdown/HTML output."
  tool="coverage badge generator, test coverage badge, README badge, shields.io badge, code coverage badge, jest coverage badge"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Test Coverage Badge Generator",
    "url": "https://devplaybook.cc/tools/test-coverage-badge-generator",
    "description": "Generate README coverage badges from a coverage percentage. Preview the badge and copy Markdown or HTML embed code.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Test Coverage Badge Generator</h1>
  <p class="text-text-muted mb-4">Generate coverage badges for your README from your test coverage percentage. Preview instantly and copy the Markdown or HTML embed code.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auto color by percentage</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multiple badge styles</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Markdown & HTML output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Custom label & link</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Config -->
    <div class="bg-bg-card border border-border rounded-xl p-5 flex flex-col gap-4">
      <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Badge Settings</h2>

      <div>
        <label class="block text-sm font-medium mb-1" for="coverage-pct">Coverage Percentage</label>
        <div class="flex items-center gap-3">
          <input id="coverage-pct" type="range" min="0" max="100" value="87" class="flex-1 accent-accent" />
          <span id="pct-display" class="text-2xl font-bold w-16 text-right">87%</span>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" for="badge-label">Badge Label</label>
        <input id="badge-label" type="text" value="coverage" placeholder="coverage" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" for="badge-style">Badge Style</label>
        <select id="badge-style" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors">
          <option value="flat">Flat</option>
          <option value="flat-square">Flat Square</option>
          <option value="for-the-badge">For the Badge</option>
          <option value="plastic">Plastic</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" for="badge-logo">Logo (optional)</label>
        <select id="badge-logo" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors">
          <option value="">None</option>
          <option value="jest">Jest</option>
          <option value="vitest">Vitest</option>
          <option value="pytest">pytest</option>
          <option value="go">Go</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" for="badge-link">Link URL (optional)</label>
        <input id="badge-link" type="text" placeholder="https://github.com/user/repo/actions" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
      </div>

      <div>
        <label class="block text-sm font-medium mb-1">Color Thresholds</label>
        <div class="grid grid-cols-3 gap-2 text-xs">
          <div class="bg-bg border border-border rounded-lg p-2 text-center">
            <span class="inline-block w-3 h-3 rounded-full bg-green-500 mb-1"></span>
            <div class="text-text-muted">≥90% Green</div>
          </div>
          <div class="bg-bg border border-border rounded-lg p-2 text-center">
            <span class="inline-block w-3 h-3 rounded-full bg-yellow-400 mb-1"></span>
            <div class="text-text-muted">75-89% Yellow</div>
          </div>
          <div class="bg-bg border border-border rounded-lg p-2 text-center">
            <span class="inline-block w-3 h-3 rounded-full bg-red-500 mb-1"></span>
            <div class="text-text-muted">&lt;75% Red</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Preview + Output -->
    <div class="flex flex-col gap-4">
      <div class="bg-bg-card border border-border rounded-xl p-5 flex flex-col gap-4">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Preview</h2>
        <div class="bg-bg border border-border rounded-lg p-6 flex items-center justify-center min-h-20">
          <img id="badge-preview" src="" alt="Coverage badge preview" class="max-h-12" />
        </div>

        <div>
          <div class="flex items-center justify-between mb-1">
            <label class="text-sm font-medium">Markdown</label>
            <button id="copy-md" class="text-xs text-text-muted hover:text-accent px-2 py-1 border border-border hover:border-accent rounded transition-colors">Copy</button>
          </div>
          <pre id="output-md" class="bg-bg border border-border rounded-lg p-3 text-xs font-mono overflow-x-auto whitespace-pre-wrap text-text"></pre>
        </div>

        <div>
          <div class="flex items-center justify-between mb-1">
            <label class="text-sm font-medium">HTML</label>
            <button id="copy-html" class="text-xs text-text-muted hover:text-accent px-2 py-1 border border-border hover:border-accent rounded transition-colors">Copy</button>
          </div>
          <pre id="output-html" class="bg-bg border border-border rounded-lg p-3 text-xs font-mono overflow-x-auto whitespace-pre-wrap text-text"></pre>
        </div>

        <div>
          <div class="flex items-center justify-between mb-1">
            <label class="text-sm font-medium">Badge URL</label>
            <button id="copy-url" class="text-xs text-text-muted hover:text-accent px-2 py-1 border border-border hover:border-accent rounded transition-colors">Copy</button>
          </div>
          <pre id="output-url" class="bg-bg border border-border rounded-lg p-3 text-xs font-mono overflow-x-auto whitespace-pre-wrap text-text break-all"></pre>
        </div>
      </div>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Test Coverage Badge Generator" relatedTags={['testing', 'readme', 'badges', 'developer-tools', 'ci-cd']} />
</BaseLayout>

<script>
function getColor(pct: number): string {
  if (pct >= 90) return 'brightgreen';
  if (pct >= 75) return 'yellowgreen';
  if (pct >= 60) return 'yellow';
  if (pct >= 40) return 'orange';
  return 'red';
}

function buildUrl(): string {
  const pct = parseInt((document.getElementById('coverage-pct') as HTMLInputElement).value);
  const label = encodeURIComponent((document.getElementById('badge-label') as HTMLInputElement).value.trim() || 'coverage');
  const style = (document.getElementById('badge-style') as HTMLSelectElement).value;
  const logo = (document.getElementById('badge-logo') as HTMLSelectElement).value;
  const color = getColor(pct);
  const message = encodeURIComponent(`${pct}%25`);

  let url = `https://img.shields.io/badge/${label}-${message}-${color}?style=${style}`;
  if (logo) url += `&logo=${logo}`;
  return url;
}

function update() {
  const pct = parseInt((document.getElementById('coverage-pct') as HTMLInputElement).value);
  (document.getElementById('pct-display') as HTMLElement).textContent = `${pct}%`;

  const url = buildUrl();
  const link = (document.getElementById('badge-link') as HTMLInputElement).value.trim();
  const label = (document.getElementById('badge-label') as HTMLInputElement).value.trim() || 'coverage';
  const altText = `${label}: ${pct}%`;

  (document.getElementById('badge-preview') as HTMLImageElement).src = url;

  const md = link
    ? `[![${altText}](${url})](${link})`
    : `![${altText}](${url})`;

  const html = link
    ? `<a href="${link}"><img src="${url}" alt="${altText}" /></a>`
    : `<img src="${url}" alt="${altText}" />`;

  (document.getElementById('output-md') as HTMLElement).textContent = md;
  (document.getElementById('output-html') as HTMLElement).textContent = html;
  (document.getElementById('output-url') as HTMLElement).textContent = url;
}

function copyText(id: string, btnId: string) {
  const text = (document.getElementById(id) as HTMLElement).textContent || '';
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.getElementById(btnId) as HTMLElement;
    const orig = btn.textContent;
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = orig; }, 2000);
  });
}

['coverage-pct', 'badge-label', 'badge-style', 'badge-logo', 'badge-link'].forEach(id => {
  document.getElementById(id)!.addEventListener('input', update);
  document.getElementById(id)!.addEventListener('change', update);
});

document.getElementById('copy-md')!.addEventListener('click', () => copyText('output-md', 'copy-md'));
document.getElementById('copy-html')!.addEventListener('click', () => copyText('output-html', 'copy-html'));
document.getElementById('copy-url')!.addEventListener('click', () => copyText('output-url', 'copy-url'));

update();
</script>
