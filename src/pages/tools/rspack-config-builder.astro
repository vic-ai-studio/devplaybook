---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Rspack?", answer: "Rspack is a high-performance JavaScript bundler written in Rust, developed by ByteDance. It is designed to be a drop-in replacement for webpack, offering the same configuration API and plugin ecosystem while delivering dramatically faster build times — often 5-10x faster than webpack for large projects." },
  { question: "How does Rspack compare to webpack?", answer: "Rspack is API-compatible with webpack, meaning most webpack configs and plugins work with minimal changes. The main difference is speed: Rspack parallelises work using Rust threads and avoids JavaScript's single-threaded bottleneck. For most projects, switching from webpack to Rspack is a config-level change with no code changes required." },
  { question: "Rspack vs Vite — which should I choose?", answer: "Vite uses native ESM in development (very fast cold start) and Rollup for production builds. Rspack uses a bundling approach in both dev and prod, similar to webpack. Choose Vite for new greenfield projects — especially React/Vue SPAs. Choose Rspack when migrating a large existing webpack project, or when you need webpack's advanced code-splitting and module federation features." },
  { question: "How do I migrate from webpack to Rspack?", answer: "1. Install @rspack/cli and @rspack/core. 2. Rename webpack.config.js to rspack.config.js (or keep both). 3. Replace webpack imports with @rspack/core equivalents. 4. Run rspack build and address any plugin incompatibilities. Most built-in loaders (babel-loader, css-loader, sass-loader) work unchanged. Some webpack plugins have Rspack-native equivalents." },
  { question: "Does Rspack support TypeScript and React?", answer: "Yes. Rspack has built-in TypeScript and JSX/TSX support via its own SWC-based transformer — no extra loaders required. You can enable it via module.rules with type: 'typescript' or use the built-in experiments.rspackFuture settings. For React, set jsx: 'react' or 'react-jsx' in your tsconfig or rspack config." },
  { question: "Does Rspack support CSS Modules?", answer: "Yes. CSS Modules are supported natively. Set modules: true in your css-loader options (or use Rspack's built-in CSS handling). Class names are scoped locally by default, just like in webpack." },
];
---

<BaseLayout
  title="Rspack Config Builder — Generate rspack.config.js Visually"
  description="Free Rspack config generator. Choose entry, output, mode, TypeScript, React/JSX, CSS Modules, source maps and target — get a ready-to-use rspack.config.js. No sign-up needed."
  tool="Rspack config generator, rspack.config.js builder, Rspack webpack alternative, Rust bundler config, Rspack TypeScript, Rspack React"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Rspack Config Builder",
    "url": "https://devplaybook.cc/tools/rspack-config-builder",
    "description": "Generate rspack.config.js visually with support for TypeScript, React/JSX, CSS Modules, source maps, and multiple targets.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Rspack Config Builder</h1>
  <p class="text-text-muted mb-4">Generate a <code class="bg-surface px-1 rounded text-sm">rspack.config.js</code> for the Rust-powered webpack-compatible bundler by ByteDance. Configure entry, output, mode, TypeScript, React, CSS Modules and more — then copy the ready-to-use config.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> webpack-compatible API</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5-10x faster than webpack</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <div class="space-y-6">
    <div class="bg-surface border border-border rounded-xl p-5 space-y-5">
      <h2 class="text-sm font-semibold mb-1 text-text-muted uppercase tracking-wide">Configuration</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="rs-entry" class="block text-sm font-medium mb-1.5">Entry Point</label>
          <input id="rs-entry" type="text" placeholder="./src/index.js"
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-accent" />
        </div>
        <div>
          <label for="rs-output" class="block text-sm font-medium mb-1.5">Output Path</label>
          <input id="rs-output" type="text" placeholder="./dist"
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-accent" />
        </div>
      </div>

      <div>
        <label for="rs-mode" class="block text-sm font-medium mb-1.5">Mode</label>
        <select id="rs-mode" class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent">
          <option value="development">development</option>
          <option value="production">production</option>
          <option value="none">none</option>
        </select>
      </div>

      <div>
        <label for="rs-target" class="block text-sm font-medium mb-1.5">Target</label>
        <select id="rs-target" class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent">
          <option value="web">web</option>
          <option value="node">node</option>
          <option value="webworker">webworker</option>
          <option value="electron-main">electron-main</option>
          <option value="electron-renderer">electron-renderer</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium mb-2">Options</label>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="rs-sourcemap" class="accent-accent" /> Source Maps
          </label>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="rs-typescript" class="accent-accent" /> TypeScript
          </label>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="rs-react" class="accent-accent" /> React / JSX
          </label>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="rs-cssmod" class="accent-accent" /> CSS Modules
          </label>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="rs-split" class="accent-accent" /> Code Splitting
          </label>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="rs-assets" class="accent-accent" /> Asset Handling
          </label>
        </div>
      </div>

      <button id="rs-generate" class="bg-accent hover:bg-accent/80 text-white font-medium px-5 py-2 rounded-lg text-sm transition-colors">
        Generate Config
      </button>
    </div>

    <div class="bg-surface border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <label class="text-sm font-medium">rspack.config.js</label>
        <button id="rs-copy" class="text-xs bg-background border border-border hover:bg-accent/20 px-3 py-1 rounded-lg transition-colors">Copy</button>
      </div>
      <pre id="rs-output-code" class="bg-background border border-border rounded-lg px-4 py-3 text-xs font-mono overflow-x-auto whitespace-pre leading-relaxed min-h-[200px]"></pre>
      <p class="text-xs text-text-muted mt-2">Save as <code class="bg-background px-1 rounded">rspack.config.js</code> in your project root. Install with <code class="bg-background px-1 rounded">npm install -D @rspack/cli @rspack/core</code>.</p>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Rspack Config Builder" relatedTags={['build-tools', 'bundler', 'webpack', 'typescript', 'javascript']} />
</BaseLayout>

<script>
(function() {
  function el(id) { return document.getElementById(id); }

  function generate() {
    var entry = (el('rs-entry') as HTMLInputElement).value.trim() || './src/index.js';
    var outputPath = (el('rs-output') as HTMLInputElement).value.trim() || './dist';
    var mode = (el('rs-mode') as HTMLSelectElement).value;
    var target = (el('rs-target') as HTMLSelectElement).value;
    var sourceMap = (el('rs-sourcemap') as HTMLInputElement).checked;
    var useTS = (el('rs-typescript') as HTMLInputElement).checked;
    var useReact = (el('rs-react') as HTMLInputElement).checked;
    var cssModules = (el('rs-cssmod') as HTMLInputElement).checked;
    var codeSplit = (el('rs-split') as HTMLInputElement).checked;
    var assets = (el('rs-assets') as HTMLInputElement).checked;

    var lines = [];
    lines.push("const path = require('path');");
    lines.push("const { DefinePlugin } = require('@rspack/core');");
    lines.push("");
    lines.push("/** @type {import('@rspack/core').Configuration} */");
    lines.push("module.exports = {");
    lines.push("  entry: '" + entry + "',");
    lines.push("  output: {");
    lines.push("    path: path.resolve(__dirname, '" + outputPath.replace(/^\.\//, '') + "'),");
    lines.push("    filename: '[name].[contenthash].js',");
    lines.push("    clean: true,");
    lines.push("  },");
    lines.push("  mode: '" + mode + "',");
    lines.push("  target: '" + target + "',");
    if (sourceMap) {
      var smType = mode === 'development' ? 'cheap-module-source-map' : 'source-map';
      lines.push("  devtool: '" + smType + "',");
    }
    lines.push("  module: {");
    lines.push("    rules: [");

    if (useTS && useReact) {
      lines.push("      {");
      lines.push("        test: /\\.tsx?$/,");
      lines.push("        use: { loader: 'builtin:swc-loader', options: { jsc: { parser: { syntax: 'typescript', tsx: true }, transform: { react: { runtime: 'automatic' } } } } },");
      lines.push("        exclude: /node_modules/,");
      lines.push("      },");
    } else if (useTS) {
      lines.push("      {");
      lines.push("        test: /\\.tsx?$/,");
      lines.push("        use: { loader: 'builtin:swc-loader', options: { jsc: { parser: { syntax: 'typescript' } } } },");
      lines.push("        exclude: /node_modules/,");
      lines.push("      },");
    } else if (useReact) {
      lines.push("      {");
      lines.push("        test: /\\.jsx?$/,");
      lines.push("        use: { loader: 'builtin:swc-loader', options: { jsc: { parser: { syntax: 'ecmascript', jsx: true }, transform: { react: { runtime: 'automatic' } } } } },");
      lines.push("        exclude: /node_modules/,");
      lines.push("      },");
    }

    if (cssModules) {
      lines.push("      {");
      lines.push("        test: /\\.module\\.css$/,");
      lines.push("        type: 'css/module',");
      lines.push("      },");
      lines.push("      {");
      lines.push("        test: /(?<!module)\\.css$/,");
      lines.push("        type: 'css',");
      lines.push("      },");
    } else {
      lines.push("      {");
      lines.push("        test: /\\.css$/,");
      lines.push("        type: 'css',");
      lines.push("      },");
    }

    if (assets) {
      lines.push("      {");
      lines.push("        test: /\\.(png|jpg|jpeg|gif|svg|webp)$/i,");
      lines.push("        type: 'asset/resource',");
      lines.push("      },");
      lines.push("      {");
      lines.push("        test: /\\.(woff|woff2|eot|ttf|otf)$/i,");
      lines.push("        type: 'asset/resource',");
      lines.push("      },");
    }

    lines.push("    ],");
    lines.push("  },");
    lines.push("  resolve: {");
    if (useTS || useReact) {
      lines.push("    extensions: ['.ts', '.tsx', '.js', '.jsx'],");
    } else {
      lines.push("    extensions: ['.js', '.json'],");
    }
    lines.push("  },");

    if (codeSplit) {
      lines.push("  optimization: {");
      lines.push("    splitChunks: {");
      lines.push("      chunks: 'all',");
      lines.push("      cacheGroups: {");
      lines.push("        vendor: {");
      lines.push("          test: /[\\\\/]node_modules[\\\\/]/,");
      lines.push("          name: 'vendors',");
      lines.push("          chunks: 'all',");
      lines.push("        },");
      lines.push("      },");
      lines.push("    },");
      lines.push("  },");
    }

    lines.push("  plugins: [");
    lines.push("    new DefinePlugin({");
    lines.push("      'process.env.NODE_ENV': JSON.stringify('" + mode + "'),");
    lines.push("    }),");
    lines.push("  ],");
    lines.push("};");

    el('rs-output-code').textContent = lines.join('\n');
  }

  el('rs-generate').addEventListener('click', generate);
  ['rs-entry','rs-output'].forEach(function(id) {
    el(id).addEventListener('input', generate);
  });
  ['rs-mode','rs-target'].forEach(function(id) {
    el(id).addEventListener('change', generate);
  });
  ['rs-sourcemap','rs-typescript','rs-react','rs-cssmod','rs-split','rs-assets'].forEach(function(id) {
    el(id).addEventListener('change', generate);
  });

  el('rs-copy').addEventListener('click', function() {
    var text = el('rs-output-code').textContent;
    navigator.clipboard.writeText(text).then(function() {
      var btn = el('rs-copy');
      btn.textContent = 'Copied!';
      setTimeout(function() { btn.textContent = 'Copy'; }, 1500);
    });
  });

  // Set defaults via JS to avoid Astro parse issues
  (el('rs-entry') as HTMLInputElement).value = './src/index.js';
  (el('rs-output') as HTMLInputElement).value = './dist';
  generate();
})();
</script>
