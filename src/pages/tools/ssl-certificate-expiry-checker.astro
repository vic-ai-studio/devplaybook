NThk4HXNBrHMpKGE9X3Y0E/PSMFMDO2v4PQXGqB9dFjMbhVqGXeV3RbXxWdluoX
y0m/JD+0D5XyZ3+vk0wjHR7nJoK+Q3zrp97gHBKb0y5j2bnpO9BPKDc6h6OlV2f
y13bLKx7Y4u1LiTN8ot3VDLSZhDv1a0gXt7LOJGf7BFMM+2PBg3+RdqFYUQDKGT
cxoZlRiZDIPiB2qbMBOuioYfqxGNbbgG6rJHW+y9AgMBAAGjUzBRMB0GA1UdDgQW
BBRDVx5H6q5CPi0kSMhTAVrGLdqkUzAfBgNVHSMEGDAWgBRDVx5H6q5CPi0kSMhT
AVrGLdqkUzAPBgNVHRMBAf8EBTADAQH/MA0GCSqGSIb3DQEBCwUAA4IBAQBc5yXe
dxTFwCsTY+5tME2JHxL0MZ1eEMz5EGqOLGlKRCfCj9w6hb9oV3lcfXaSs5tC7X+r
3v8M9U0hK4aF8aVtHAQ8DW7BRdZFuuXHPL7r6XOv6D7GkLhE+Qy3wfCJY7UgqDKO
Ux/wGFf8kHmRYUTfOvP2J3aVCmBFVLEo
-----END CERTIFICATE-----`;

  document.getElementById('load-example')?.addEventListener('click', () => {
    (document.getElementById('cert-input') as HTMLTextAreaElement).value = EXAMPLE;
  });

  document.getElementById('check-btn')?.addEventListener('click', () => {
    const pem = (document.getElementById('cert-input') as HTMLTextAreaElement).value.trim();
    const cert = parseCert(pem);
    const statusBanner = document.getElementById('status-banner') as HTMLElement;
    const certDetails = document.getElementById('cert-details') as HTMLElement;
    const sansPanel = document.getElementById('sans-panel') as HTMLElement;
    const alertsPanel = document.getElementById('alerts-panel') as HTMLElement;

    if (!cert) {
      statusBanner.classList.remove('hidden');
      certDetails.classList.add('hidden');
      sansPanel.classList.add('hidden');
      alertsPanel.classList.add('hidden');
      (document.getElementById('status-icon') as HTMLElement).textContent = '❌';
      (document.getElementById('status-text') as HTMLElement).textContent = 'Invalid certificate';
      (document.getElementById('days-remaining') as HTMLElement).textContent = 'Could not parse the PEM. Ensure it includes the -----BEGIN/END CERTIFICATE----- headers.';
      statusBanner.className = 'bg-red-500/10 border border-red-500/30 rounded-xl p-5';
      return;
    }

    const now = new Date();
    const daysLeft = Math.ceil((cert.notAfter.getTime() - now.getTime()) / 86400000);
    const expired = daysLeft <= 0;

    statusBanner.classList.remove('hidden');
    certDetails.classList.remove('hidden');
    alertsPanel.classList.remove('hidden');

    if (expired) {
      statusBanner.className = 'bg-red-500/10 border border-red-500/30 rounded-xl p-5';
      (document.getElementById('status-icon') as HTMLElement).textContent = '🚨';
      (document.getElementById('status-text') as HTMLElement).textContent = `EXPIRED ${Math.abs(daysLeft)} days ago`;
      (document.getElementById('days-remaining') as HTMLElement).textContent = `Expired on ${cert.notAfter.toDateString()}`;
    } else if (daysLeft <= 30) {
      statusBanner.className = 'bg-red-500/10 border border-red-500/30 rounded-xl p-5';
      (document.getElementById('status-icon') as HTMLElement).textContent = '⚠️';
      (document.getElementById('status-text') as HTMLElement).textContent = `Expiring in ${daysLeft} days — RENEW NOW`;
      (document.getElementById('days-remaining') as HTMLElement).textContent = `Expires ${cert.notAfter.toDateString()}`;
    } else if (daysLeft <= 60) {
      statusBanner.className = 'bg-yellow-500/10 border border-yellow-500/30 rounded-xl p-5';
      (document.getElementById('status-icon') as HTMLElement).textContent = '⏰';
      (document.getElementById('status-text') as HTMLElement).textContent = `Expiring in ${daysLeft} days — Plan renewal`;
      (document.getElementById('days-remaining') as HTMLElement).textContent = `Expires ${cert.notAfter.toDateString()}`;
    } else {
      statusBanner.className = 'bg-green-500/10 border border-green-500/30 rounded-xl p-5';
      (document.getElementById('status-icon') as HTMLElement).textContent = '✅';
      (document.getElementById('status-text') as HTMLElement).textContent = `Valid — ${daysLeft} days remaining`;
      (document.getElementById('days-remaining') as HTMLElement).textContent = `Expires ${cert.notAfter.toDateString()}`;
    }

    (document.getElementById('detail-cn') as HTMLElement).textContent = cert.cn;
    (document.getElementById('detail-issuer') as HTMLElement).textContent = cert.issuer || 'N/A';
    (document.getElementById('detail-from') as HTMLElement).textContent = cert.notBefore.toUTCString();
    (document.getElementById('detail-to') as HTMLElement).textContent = cert.notAfter.toUTCString();
    (document.getElementById('detail-serial') as HTMLElement).textContent = cert.serial;
    (document.getElementById('detail-algo') as HTMLElement).textContent = cert.algo;

    if (cert.sans.length > 0) {
      sansPanel.classList.remove('hidden');
      (document.getElementById('sans-list') as HTMLElement).innerHTML = cert.sans
        .map(s => `<span class="text-xs font-mono bg-bg border border-border rounded px-2 py-1">${s}</span>`)
        .join('');
    } else {
      sansPanel.classList.add('hidden');
    }

    const alerts = [
      { days: 90, label: '90-day alert', color: 'text-text-muted' },
      { days: 60, label: '60-day alert', color: 'text-yellow-400' },
      { days: 30, label: '30-day alert (renew now)', color: 'text-red-400' },
    ];
    (document.getElementById('alerts-list') as HTMLElement).innerHTML = alerts.map(a => {
      const alertDate = new Date(cert.notAfter.getTime() - a.days * 86400000);
      const passed = alertDate < now;
      return `<div class="flex justify-between items-center text-sm py-1.5 border-b border-border/50 last:border-0">
        <span class="${a.color} font-medium">${a.label}</span>
        <span class="font-mono text-xs ${passed ? 'line-through text-text-muted/50' : ''}">${alertDate.toDateString()}</span>
      </div>`;
    }).join('');
  });
</script>
