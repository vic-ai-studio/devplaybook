---

<BaseLayout
  title="SSL Certificate Expiry Checker — Certificate Info & Renewal Alerts"
  description="Paste a PEM certificate to check expiry date, days remaining, issuer, Subject Alternative Names, and get renewal reminders at 30/60/90 day thresholds."
  tool="SSL certificate expiry checker, certificate renewal reminder, PEM certificate decoder, SSL expiry date, certificate info checker"
  keywords={["ssl certificate expiry", "certificate checker", "pem decoder", "ssl renewal", "certificate expiry date", "san checker"]}
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">SSL Certificate Expiry Checker</h1>
  <p class="text-text-muted mb-4">Paste a PEM certificate to instantly check expiry, issuer, SANs, days remaining, and renewal alert dates — no server needed.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Expiry date + days remaining</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Issuer + SANs</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 30/60/90-day renewal alerts</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <!-- Input -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-2">
        <label class="text-sm font-semibold">PEM Certificate</label>
        <button id="load-example" class="text-xs text-primary hover:underline">Load example</button>
      </div>
      <textarea id="cert-input" rows="14" spellcheck="false"
        placeholder="-----BEGIN CERTIFICATE-----&#10;...&#10;-----END CERTIFICATE-----"
        class="w-full bg-bg border border-border rounded-lg p-3 text-xs font-mono focus:outline-none focus:border-primary resize-y"
      ></textarea>
      <button id="check-btn"
        class="mt-3 w-full bg-primary text-white rounded-lg py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity">
        Check Certificate
      </button>
      <p class="mt-2 text-xs text-text-muted">Your certificate is parsed entirely in your browser. Nothing is sent to any server.</p>
    </div>

    <!-- Results -->
    <div id="results-panel" class="space-y-4">
      <div id="status-banner" class="hidden bg-bg-card border border-border rounded-xl p-5">
        <div id="status-icon" class="text-4xl mb-2 text-center"></div>
        <div id="status-text" class="text-center font-semibold text-lg mb-1"></div>
        <div id="days-remaining" class="text-center text-text-muted text-sm"></div>
      </div>

      <div id="cert-details" class="hidden bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">Certificate Details</h2>
        <div class="space-y-2">
          <div class="flex gap-2">
            <span class="text-xs text-text-muted w-28 shrink-0">Common Name</span>
            <span id="detail-cn" class="text-xs font-mono font-semibold break-all"></span>
          </div>
          <div class="flex gap-2">
            <span class="text-xs text-text-muted w-28 shrink-0">Issuer</span>
            <span id="detail-issuer" class="text-xs font-mono break-all"></span>
          </div>
          <div class="flex gap-2">
            <span class="text-xs text-text-muted w-28 shrink-0">Valid From</span>
            <span id="detail-from" class="text-xs font-mono"></span>
          </div>
          <div class="flex gap-2">
            <span class="text-xs text-text-muted w-28 shrink-0">Valid To</span>
            <span id="detail-to" class="text-xs font-mono font-semibold"></span>
          </div>
          <div class="flex gap-2">
            <span class="text-xs text-text-muted w-28 shrink-0">Serial</span>
            <span id="detail-serial" class="text-xs font-mono break-all"></span>
          </div>
          <div class="flex gap-2">
            <span class="text-xs text-text-muted w-28 shrink-0">Algorithm</span>
            <span id="detail-algo" class="text-xs font-mono"></span>
          </div>
        </div>
      </div>

      <div id="sans-panel" class="hidden bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">Subject Alternative Names (SANs)</h2>
        <div id="sans-list" class="flex flex-wrap gap-1.5"></div>
      </div>

      <div id="alerts-panel" class="hidden bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">Renewal Reminder Dates</h2>
        <div id="alerts-list" class="space-y-2"></div>
      </div>
    </div>
  </div>

  <ToolPageCta />
  <FaqSection faq={faq} />
</BaseLayout>

<script>
  // Minimal ASN.1/DER parser for X.509 certificates
  function base64ToBytes(b64: string): Uint8Array {
    const bin = atob(b64);
    const bytes = new Uint8Array(bin.length);
    for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
    return bytes;
  }

  function readLength(data: Uint8Array, pos: number): { len: number; nextPos: number } {
    if (data[pos] < 0x80) return { len: data[pos], nextPos: pos + 1 };
    const numBytes = data[pos] & 0x7f;
    let len = 0;
    for (let i = 0; i < numBytes; i++) len = (len << 8) | data[pos + 1 + i];
    return { len, nextPos: pos + 1 + numBytes };
  }

  interface AsnNode {
    tag: number;
    value: Uint8Array;
    children?: AsnNode[];
    pos: number;
  }

  function parseAsn1(data: Uint8Array, pos: number = 0): AsnNode {
    const tag = data[pos];
    const { len, nextPos } = readLength(data, pos + 1);
    const value = data.slice(nextPos, nextPos + len);
    const node: AsnNode = { tag, value, pos };

    // Parse constructed types (SEQUENCE=0x30, SET=0x31, context=0xa*)
    if ((tag & 0x20) || (tag & 0xc0) === 0xa0) {
      node.children = [];
      let childPos = 0;
      while (childPos < value.length) {
        const child = parseAsn1(value, childPos);
        const { len: cl, nextPos: cn } = readLength(value, childPos + 1);
        node.children.push(child);
        childPos = cn + cl;
      }
    }
    return node;
  }

  function bytesToHex(b: Uint8Array): string {
    return Array.from(b).map(x => x.toString(16).padStart(2,'0')).join(':');
  }

  function parseUtcTime(b: Uint8Array): Date {
    const s = String.fromCharCode(...b);
    // YYMMDDHHMMSSZ or YYYYMMDDHHMMSSZ
    const year = s.length <= 13 ? (parseInt(s.slice(0,2)) >= 50 ? '19' : '20') + s.slice(0,2) : s.slice(0,4);
    const off = s.length <= 13 ? 2 : 4;
    return new Date(`${year}-${s.slice(off,off+2)}-${s.slice(off+2,off+4)}T${s.slice(off+4,off+6)}:${s.slice(off+6,off+8)}:${s.slice(off+8,off+10)}Z`);
  }

  function parseOid(b: Uint8Array): string {
    const oids: Record<string, string> = {
      '2.5.4.3': 'CN', '2.5.4.6': 'C', '2.5.4.7': 'L', '2.5.4.8': 'ST',
      '2.5.4.10': 'O', '2.5.4.11': 'OU',
      '1.2.840.113549.1.1.11': 'sha256WithRSAEncryption',
      '1.2.840.113549.1.1.5': 'sha1WithRSAEncryption',
      '1.2.840.10045.4.3.2': 'ecdsa-with-SHA256',
      '2.5.29.17': 'subjectAltName',
    };
    let val = '';
    let first = true;
    let prev = 0;
    for (let i = 0; i < b.length; i++) {
      let byte = b[i];
      prev = (prev << 7) | (byte & 0x7f);
      if (!(byte & 0x80)) {
        if (first) { val += Math.floor(prev / 40) + '.' + (prev % 40); first = false; }
        else val += '.' + prev;
        prev = 0;
      }
    }
    return oids[val] || val;
  }

  function parseRdn(node: AsnNode): string {
    if (!node.children) return '';
    const parts: string[] = [];
    for (const set of node.children) {
      if (!set.children) continue;
      for (const seq of set.children) {
        if (!seq.children || seq.children.length < 2) continue;
        const oid = parseOid(seq.children[0].value);
        const val = String.fromCharCode(...seq.children[1].value);
        if (oid === 'CN' || oid === 'O') parts.push(`${oid}=${val}`);
      }
    }
    return parts.join(', ');
  }

  function parseSANs(extNode: AsnNode): string[] {
    const sans: string[] = [];
    // extNode is the SEQUENCE of SANs
    if (!extNode.children) return sans;
    for (const child of extNode.children) {
      const tag = child.tag & 0x1f;
      const val = String.fromCharCode(...child.value);
      if (tag === 2) sans.push(val); // dNSName
      else if (tag === 7) sans.push(Array.from(child.value).map(b => b).join('.')); // iPAddress
    }
    return sans;
  }

  function parseCert(pem: string): { cn: string; issuer: string; notBefore: Date; notAfter: Date; serial: string; algo: string; sans: string[] } | null {
    try {
      const b64 = pem.replace(/-----[^-]+-----/g, '').replace(/\s+/g, '');
      const der = base64ToBytes(b64);
      const root = parseAsn1(der);
      const tbsCert = root.children?.[0];
      if (!tbsCert?.children) return null;

      const children = tbsCert.children;
      // tbsCert structure: version?, serialNumber, signature, issuer, validity, subject, ...
      let idx = 0;
      if (children[0]?.tag === 0xa0) idx = 1; // skip version if present

      const serial = bytesToHex(children[idx].value).slice(0, 29) + '…';
      idx++;
      const algoOid = children[idx]?.children?.[0];
      const algo = algoOid ? parseOid(algoOid.value) : 'unknown';
      idx++;
      const issuer = parseRdn(children[idx]);
      idx++;
      const validity = children[idx];
      const notBefore = parseUtcTime(validity?.children?.[0]?.value || new Uint8Array());
      const notAfter = parseUtcTime(validity?.children?.[1]?.value || new Uint8Array());
      idx++;
      const subject = parseRdn(children[idx]);
      const cn = subject.replace(/.*CN=([^,]+).*/, '$1') || subject;

      // Try to extract SANs from extensions
      const sans: string[] = [];
      const extsNode = tbsCert.children.find(c => c.tag === 0xa3);
      if (extsNode?.children?.[0]?.children) {
        for (const ext of extsNode.children[0].children) {
          if (!ext.children) continue;
          const oid = ext.children[0] ? parseOid(ext.children[0].value) : '';
          if (oid === 'subjectAltName') {
            const sanData = ext.children[ext.children.length - 1];
            const inner = parseAsn1(sanData.value, 0);
            sans.push(...parseSANs(inner));
          }
        }
      }

      return { cn, issuer, notBefore, notAfter, serial, algo, sans };
    } catch {
      return null;
    }
  }

  const EXAMPLE = `-----BEGIN CERTIFICATE-----
MIIDazCCAlOgAwIBAgIUYLKIJX6B1QX/vvjFVD5yVT2pjLswDQYJKoZIhvcNAQEL
BQAwRTELMAkGA1UEBhMCVVMxEzARBgNVBAgMClNvbWUtU3RhdGUxITAfBgNVBAoM
GEludGVybmV0IFdpZGdpdHMgUHR5IEx0ZDAeFw0yNTAxMDEwMDAwMDBaFw0yNjAx
