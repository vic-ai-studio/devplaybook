---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WasmModuleExplorer from '../../components/WasmModuleExplorer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is WebAssembly (WASM)?",
    answer: "WebAssembly (WASM) is a binary instruction format for a stack-based virtual machine. It is designed as a portable compilation target for programming languages such as C, C++, Rust, and Go, enabling high-performance code to run in web browsers and server runtimes at near-native speed. WASM modules are compact, fast to decode, and sandboxed for security.",
  },
  {
    question: "What is WAT (WebAssembly Text Format)?",
    answer: "WAT is the human-readable text representation of a WebAssembly module. While .wasm files are compact binary files, WAT uses S-expression syntax — parentheses-nested declarations like (module (func ...)) — to express the same structure. WAT is primarily used for debugging, learning, and hand-authoring small WebAssembly modules. You can convert between .wasm and .wat using the wasm2wat and wat2wasm tools from the WebAssembly Binary Toolkit (WABT).",
  },
  {
    question: "What are WASM exports and imports?",
    answer: "Exports are items (functions, memories, globals, tables) that a WASM module exposes to the host environment — a JavaScript runtime, another module, or a WASI host. Imports are items that the module requires from the host before it can run. For example, a module might import a 'log' function from 'env' and export an 'add' function that JavaScript can call. The host must supply all declared imports or instantiation will fail.",
  },
  {
    question: "What WASM sections does this tool detect?",
    answer: "A WebAssembly binary is composed of numbered sections: type (function signatures), import, function (index → type mapping), table, memory, global, export, start (entry-point), element (table initializers), code (function bodies), and data (memory initializers). For .wasm binary files this tool scans the actual section IDs in the binary. For WAT text input it infers sections from the declarations present in the source.",
  },
  {
    question: "Does this tool send my .wasm file to a server?",
    answer: "No. All analysis runs entirely in your browser using the native WebAssembly JavaScript API — specifically WebAssembly.compile(), WebAssembly.Module.exports(), and WebAssembly.Module.imports(). Your file never leaves your machine. This also means the tool requires a modern browser with WebAssembly support (Chrome 57+, Firefox 52+, Safari 11+, Edge 16+).",
  },
];
---

<BaseLayout
  title="WASM Module Explorer — Inspect WebAssembly Exports, Imports & Sections"
  description="Free browser-based WebAssembly module explorer. Paste WAT source or upload a .wasm file to inspect exports, imports, functions, memory, globals, and tables. Runs entirely in your browser."
  tool="WASM Module Explorer, WebAssembly Inspector, WAT Parser, WASM Exports Viewer, WebAssembly Analyzer"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">WASM Module Explorer</h1>
  <p class="text-text-muted mb-4">
    Inspect a WebAssembly module's exports, imports, sections, functions, memory, globals, and tables.
    Paste WAT (WebAssembly Text Format) source or upload a compiled <code class="font-mono text-accent">.wasm</code> binary file.
    Everything runs client-side — no data leaves your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> WAT text format parsing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> .wasm binary analysis via browser WebAssembly API</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Exports, imports, sections, memory &amp; globals</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100% client-side, no upload</span>
  </div>
  <WasmModuleExplorer client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="WASM Module Explorer" relatedTags={['webassembly', 'wasm', 'wat', 'browser', 'performance']} />
</BaseLayout>
