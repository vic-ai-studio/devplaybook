---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CookieConsentGenerator from '../../components/CookieConsentGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "Do I legally need a cookie consent banner?", answer: "If you have visitors from the EU/EEA, you likely need one under GDPR. For California visitors, CCPA requires disclosure and opt-out for 'sale' of personal data. The UK has its own PECR rules similar to GDPR. Most countries with privacy laws require at minimum that you disclose cookie use. When in doubt, consult a privacy lawyer for your specific situation." },
  { question: "What is the difference between GDPR and CCPA cookie requirements?", answer: "GDPR (EU) requires explicit opt-in consent before setting non-essential cookies. You cannot pre-check boxes or use dark patterns. CCPA (California) does not require opt-in consent for cookies, but requires a 'Do Not Sell My Personal Information' link if you share data with third parties for value. GDPR is generally stricter." },
  { question: "What are essential vs. non-essential cookies?", answer: "Essential (strictly necessary) cookies are required for the website to function — session tokens, shopping cart contents, security cookies. These do not require consent. Non-essential cookies include analytics (Google Analytics), advertising/tracking, personalization, and social media pixels. These require consent under GDPR." },
  { question: "Does Google Analytics require cookie consent?", answer: "Yes. Google Analytics sets cookies that track users across sessions. Under GDPR, you need explicit opt-in consent before activating GA. Alternatively, use cookieless analytics like Plausible or Fathom, or configure GA4 in consent mode so it fires without cookies until consent is given." },
  { question: "What makes a cookie consent implementation compliant?", answer: "Key requirements: (1) Equal prominence for Accept and Reject buttons — no dark patterns. (2) Granular choices by category, not just accept/reject all. (3) Easy withdrawal of consent at any time. (4) Consent must be freely given, specific, informed, and unambiguous. (5) Keep a consent log. (6) Do not set non-essential cookies before consent." },
  { question: "Can I use this generated code in production?", answer: "The generated code is a starting point and educational template. For production use, you should test it thoroughly, ensure it blocks non-essential scripts before consent is given (using tag manager or script loading logic), maintain a consent log with timestamps, and have a privacy/legal professional review your full privacy implementation." },
];
---

<BaseLayout
  title="Cookie Consent Banner Generator — GDPR & CCPA Ready HTML/JS Code"
  description="Generate a customizable GDPR and CCPA cookie consent banner. Choose position, theme, and cookie categories. Get ready-to-paste HTML/CSS/JS code with accept, reject, and granular preference options."
  tool="Cookie Consent Generator, GDPR Cookie Banner, CCPA Cookie Consent, Cookie Consent Code Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Cookie Consent Banner Generator</h1>
  <p class="text-text-muted mb-4">Customize your cookie consent banner — choose position, theme, and cookie categories. Get ready-to-paste HTML/CSS/JavaScript code for GDPR and CCPA compliance. Runs entirely in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GDPR & CCPA compliant structure</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Customizable position & theme</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Ready-to-paste HTML/JS snippet</span>
  </div>
  <CookieConsentGenerator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Cookie Consent Banner Generator" relatedTags={['gdpr', 'privacy', 'cookies', 'compliance', 'html', 'javascript']} />
</BaseLayout>
