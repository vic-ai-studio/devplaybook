---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SslCertificateDecoder from '../../components/SslCertificateDecoder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is an X.509 certificate and what information does it contain?", answer: "An X.509 certificate is the standard format for TLS/SSL certificates defined in RFC 5280. It contains: Subject (who owns the cert — domain, organization, country), Issuer (who signed it — the Certificate Authority), Validity period (notBefore and notAfter dates), Subject Alternative Names (SANs — the exact hostnames the cert is valid for), Public key (RSA, ECDSA, etc.), Serial number (unique per CA), Extensions (key usage, extended key usage, basicConstraints, OCSP URLs), and a SHA-256 fingerprint for identification. The PEM format wraps this binary DER structure in base64 with BEGIN/END CERTIFICATE markers." },
  { question: "How do I get a certificate in PEM format?", answer: "Several ways: (1) From your server config: nginx uses ssl_certificate /path/to/cert.pem, Apache uses SSLCertificateFile /path/to/cert.crt. (2) Via OpenSSL: 'openssl s_client -connect example.com:443 -showcerts </dev/null 2>/dev/null | openssl x509 -outform PEM'. (3) From your CA dashboard (Let's Encrypt, DigiCert, etc.). (4) Files with extensions .pem, .crt, or .cer are usually PEM-formatted. (5) If you have a .pfx or .p12 (PKCS#12) file, convert with: 'openssl pkcs12 -in cert.pfx -clcerts -nokeys -out cert.pem'" },
  { question: "What are Subject Alternative Names (SANs)?", answer: "SANs (Subject Alternative Names) define the exact hostnames, IP addresses, or email addresses the certificate is valid for. Modern browsers exclusively use SANs for host validation — the Common Name (CN) in the Subject is ignored. A cert with SANs [example.com, www.example.com, api.example.com] is valid for all three. Wildcard SANs like *.example.com cover one subdomain level (www, api, mail) but not nested subdomains (a.b.example.com). If your domain is not in the SANs list, browsers will display a security warning." },
  { question: "How does this tool decode certificates without sending them to a server?", answer: "The tool implements a pure JavaScript DER/ASN.1 parser. X.509 certificates use DER (Distinguished Encoding Rules) binary encoding internally. After stripping PEM headers and base64-decoding, it parses the ASN.1 structure to extract each field. The SHA-256 fingerprint is computed using the browser's built-in Web Crypto API (crypto.subtle.digest). No data is ever transmitted — everything runs locally in your browser." },
  { question: "What does 'Is CA: Yes' mean in the certificate details?", answer: "A CA certificate is used to sign other certificates (it's a Certificate Authority), not to identify a website. CA certs have the basicConstraints extension with cA=TRUE and typically the keyCertSign key usage bit. Root CA certificates are self-signed (subject equals issuer) and stored in browser/OS trust stores. Intermediate CAs chain from Root CAs and sign end-entity (leaf) certificates. If your web server certificate shows 'Is CA: Yes', your configuration is incorrect — the server should present the leaf certificate, not an intermediate or root." },
  { question: "Why does my certificate show an expiry warning in red?", answer: "This tool color-codes expiry dates: green = valid for 30+ days, yellow = expires within 30 days, red = already expired. Expired certificates cause browser security errors (ERR_CERT_DATE_INVALID) and should be renewed immediately. If using Let's Encrypt, certificates expire every 90 days — set up auto-renewal with certbot renew via cron or systemd timer. For paid certificates, renew through your CA dashboard at least 30 days before expiry to avoid downtime." },
];
---

<BaseLayout
  title="Certificate Decoder — Decode X.509 / SSL / TLS Certificates from PEM"
  description="Decode X.509 certificates from PEM format. View subject, issuer, Subject Alternative Names, expiry dates, key usage, and SHA-256 fingerprint. Runs entirely in your browser — no uploads."
  tool="certificate decoder, X.509 certificate parser, PEM certificate viewer, SSL certificate decoder, TLS certificate inspector, certificate fingerprint"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Certificate Decoder",
    "url": "https://devplaybook.cc/tools/certificate-decoder",
    "description": "Decode and inspect X.509 / SSL / TLS certificates from PEM format. View subject, issuer, SANs, expiry, key usage, and SHA-256 fingerprint. Runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Certificate Decoder</h1>
  <p class="text-text-muted mb-4">
    Paste a <strong>PEM-format X.509 certificate</strong> to decode and inspect all fields — subject DN, issuer, Subject Alternative Names (SANs), validity dates, key usage extensions, and SHA-256 fingerprint. Expiry is color-coded (green / yellow / red). Runs entirely in your browser — no data is uploaded or sent to any server.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Subject, Issuer, SANs, Key Usage</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Expiry with color-coded status</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> SHA-256 fingerprint</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100% client-side, no uploads</span>
  </div>
  <SslCertificateDecoder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Certificate Decoder" relatedTags={['ssl', 'tls', 'security', 'certificates', 'x509', 'developer-tools']} />
</BaseLayout>
