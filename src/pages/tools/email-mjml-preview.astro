---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmailMjmlPreview from '../../components/EmailMjmlPreview.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is MJML?",
    answer: "MJML (Mailjet Markup Language) is an open-source HTML email framework designed to make responsive email coding easy. Instead of writing complex HTML tables and inline styles from scratch, you write semantic MJML components like <mj-section>, <mj-column>, and <mj-text> — and MJML compiles them to battle-tested, cross-client HTML. It's the most popular email templating framework with 50,000+ GitHub stars."
  },
  {
    question: "Why do emails need special HTML like MJML?",
    answer: "Email clients (Outlook, Gmail, Apple Mail, Yahoo) have notoriously inconsistent CSS and HTML support. Outlook uses the Word rendering engine, which doesn't support flexbox, grid, or many modern CSS properties. Gmail strips <head> styles. Mobile clients need different layouts than desktop. MJML abstracts all of this — it generates responsive, table-based HTML that renders correctly across 90+ email clients automatically."
  },
  {
    question: "What is the difference between minAvailable and mobile/desktop preview?",
    answer: "The desktop preview shows the email at full container width (typically 600px, which is the standard for email width). The mobile preview shows it at 375px, simulating an iPhone SE/14 viewport. MJML's generated HTML includes media queries and fluid layouts that automatically restack columns to single-column on mobile."
  },
  {
    question: "What are the core MJML components?",
    answer: "<mj-section> is the row wrapper, always inside <mj-body>. <mj-column> is the column inside a section — multiple columns create a multi-column layout. <mj-text> renders text with font and color attributes. <mj-button> creates a CTA button. <mj-image> for images. <mj-divider> for horizontal rules. <mj-table> for HTML tables. All live inside <mjml><mj-head> (metadata) and <mj-body> (content)."
  },
  {
    question: "How do I use MJML in production?",
    answer: "In Node.js projects: npm install mjml, then const { html } = mjml2html(mjmlString). For build pipelines, use the mjml CLI: mjml input.mjml -o output.html. For transactional emails, services like Mailjet, SendGrid, and Postmark have native MJML support. The generated HTML should be inlined (use a CSS inliner) before sending — tools like juice or premailer handle this automatically."
  },
  {
    question: "What is the recommended email width?",
    answer: "600px is the universal standard for email content width. This ensures readability in a two-pane email client (like Outlook with a sidebar) and on most desktop monitors. The actual email container is often wider, but the content table is constrained to 600px with margin: auto. On mobile, MJML automatically adjusts to 100% viewport width."
  },
];
---

<BaseLayout
  title="Email MJML Preview — Live MJML Editor & HTML Export"
  description="Preview and edit MJML email templates in real time. Switch between mobile and desktop viewports, insert component snippets, and export the compiled HTML. Includes newsletter, transactional, and promotional templates."
  tool="MJML editor, email template preview, MJML to HTML, responsive email builder, email HTML generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Email MJML Preview",
    "url": "https://devplaybook.cc/tools/email-mjml-preview",
    "description": "Live MJML email template editor with mobile/desktop viewport preview. Edit MJML, see the rendered result instantly, and export the compiled HTML.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Email MJML Preview</h1>
  <p class="text-text-muted mb-4">
    Write and preview <strong>MJML email templates</strong> in real time. Switch between mobile (375px) and desktop viewports,
    insert common MJML snippets, and export the compiled HTML ready to send.
    Includes newsletter, transactional, and promotional starter templates.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Mobile + Desktop viewports</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 3 starter templates</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Export to HTML</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <EmailMjmlPreview client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Email MJML Preview" relatedTags={['email', 'html', 'template', 'frontend', 'developer-tools']} />
</BaseLayout>
