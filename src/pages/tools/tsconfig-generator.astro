---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TsconfigGenerator from '../../components/TsconfigGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is tsconfig.json and do I need one?",
    answer: "tsconfig.json tells the TypeScript compiler how to compile your project — what files to include, which ES version to target, and what strictness to apply. You need one for any TypeScript project. Without it, tsc falls back to defaults that are often too permissive and don't match your runtime environment."
  },
  {
    question: "Which preset should I choose?",
    answer: "Use Strict for new projects — it enables all type safety features and sets you up for maintainable code. Use Next.js or React for frontend apps (these set jsx and DOM lib). Use Node for backend services (Node16/NodeNext modules). Use Base for a minimal config you'll customize yourself."
  },
  {
    question: "What does 'strict' mode actually enable?",
    answer: "strict: true enables: strictNullChecks (no implicit null), noImplicitAny (all values must have types), strictFunctionTypes (function parameter contravariance), strictBindCallApply (correct bind/call/apply types), strictPropertyInitialization (class properties must be initialized), and noImplicitThis. Enabling strict is the single best thing you can do for type safety."
  },
  {
    question: "What is the difference between 'module: ESNext' and 'module: Node16'?",
    answer: "module: ESNext outputs ES modules (import/export syntax) and is correct for bundlers like Vite, esbuild, and webpack. module: Node16 or NodeNext is for Node.js projects running without a bundler — it enforces .js extensions on imports and respects package.json 'exports'. Use Node16/NodeNext for Node CLIs and libraries; use ESNext for bundled apps."
  },
  {
    question: "What does moduleResolution: bundler mean?",
    answer: "moduleResolution: bundler (added in TypeScript 5.0) matches how modern bundlers (Vite, esbuild, Rollup) resolve modules — it allows extensionless imports, respects 'exports' in package.json, and doesn't require .js extensions on relative imports. It's the correct choice for Vite + React, Next.js 13+, and most frontend toolchains."
  },
  {
    question: "When should I use isolatedModules: true?",
    answer: "Use isolatedModules when your build pipeline uses a transpile-only tool (Babel, esbuild, SWC, Vite) instead of tsc to compile TypeScript. These tools process files one at a time and can't use type information from other files. isolatedModules: true tells TypeScript to error when you write code that can't be safely transpiled in isolation (like const enum, namespace imports, etc.)."
  },
];
---

<BaseLayout
  title="TypeScript tsconfig.json Generator — Visual Config Builder"
  description="Build a complete tsconfig.json visually. Choose a preset (Strict, Next.js, Node, React, Deno), toggle compiler options, enable path aliases, and get ready-to-use TypeScript config. Free, runs in your browser."
  tool="tsconfig Generator, TypeScript Config Builder, tsconfig.json, TypeScript Compiler Options, TS Config Presets"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "TypeScript tsconfig.json Generator",
    "url": "https://devplaybook.cc/tools/tsconfig-generator",
    "description": "Generate a complete tsconfig.json with visual controls. Choose presets for Strict, Next.js, React, Node, and Deno. Toggle compiler options with inline explanations.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">TypeScript tsconfig.json Generator</h1>
  <p class="text-text-muted mb-4">
    Build a complete <code class="text-accent font-mono">tsconfig.json</code> visually. Select a preset for your project type,
    toggle compiler options with inline explanations, and copy the ready-to-use config.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 6 presets (Strict, Next.js, React, Node, Deno)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Inline option explanations</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Path aliases support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <TsconfigGenerator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="tsconfig Generator" relatedTags={['typescript', 'javascript', 'build', 'development', 'configuration']} />
</BaseLayout>
