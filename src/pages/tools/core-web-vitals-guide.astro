---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What are Core Web Vitals and why do they matter for SEO?", answer: "Core Web Vitals are three user-experience metrics Google uses in its Page Experience ranking signal: LCP (Largest Contentful Paint) measures loading speed, INP (Interaction to Next Paint) measures responsiveness, and CLS (Cumulative Layout Shift) measures visual stability. Pages that pass all three thresholds get a small ranking boost. More importantly, improving these metrics improves real user experience, which correlates with lower bounce rates and higher conversions." },
  { question: "How do I measure Core Web Vitals in production (real users)?", answer: "Use the Chrome User Experience Report (CrUX) for real-field data: search your domain on PageSpeed Insights (pagespeed.web.dev) or use the CrUX API. Install the `web-vitals` npm package to capture metrics in your analytics. Google Search Console's Core Web Vitals report shows URL-level field data. Field data reflects real users on real devices — it often differs significantly from lab (Lighthouse) data due to user device variance, cold starts, and network conditions." },
  { question: "What is the difference between LCP lab data and field data?", answer: "Lab data (Lighthouse, PageSpeed Insights) measures LCP in a controlled simulated environment with a specific device profile and 4G throttling. Field data (CrUX) aggregates real user measurements from Chrome browsers. They often differ because: real users have faster or slower connections, some users have the page cached, mobile device CPU varies widely, and different users navigate to different entry points. Optimize for field data thresholds — lab data is for debugging, not for CrUX status." },
  { question: "How do I fix Cumulative Layout Shift (CLS)?", answer: "The most common CLS causes are: images/videos without explicit width/height attributes (browser doesn't reserve space), dynamically injected content above existing content (ads, banners, cookie notices), web fonts causing FOIT/FOUT (text reflow), and iframes without aspect ratio containers. Fix by always setting width/height on media elements, reserving space for dynamic content with min-height, using `font-display: optional` or `size-adjust` for fonts, and using CSS aspect-ratio for embeds." },
  { question: "What replaced FID (First Input Delay) in Core Web Vitals?", answer: "Google replaced First Input Delay (FID) with INP (Interaction to Next Paint) in March 2024. FID measured only the delay before the browser could start processing the first interaction. INP measures the full duration of the slowest interaction (input delay + processing time + presentation delay) across the entire page session. INP is a stricter, more comprehensive measure of responsiveness. The good threshold for INP is ≤ 200ms, needs improvement 200–500ms, poor > 500ms." },
];
---

<BaseLayout
  title="Core Web Vitals Guide 2026 — LCP, INP, CLS Optimization"
  description="Complete Core Web Vitals guide: understand LCP, INP, and CLS metrics, measure field vs lab data, and implement fixes to pass Google's Page Experience thresholds."
  tool="Core Web Vitals, LCP, INP, CLS, Largest Contentful Paint, Interaction to Next Paint, Cumulative Layout Shift"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Core Web Vitals Optimization Guide 2026",
    "url": "https://devplaybook.cc/tools/core-web-vitals-guide",
    "description": "Understand and optimize LCP, INP, and CLS to pass Google's Core Web Vitals thresholds.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Core Web Vitals Guide 2026</h1>
  <p class="text-text-muted mb-6">
    <strong>Core Web Vitals</strong> are Google's three essential user-experience metrics: LCP, INP, and CLS. Passing all three is required for the Page Experience ranking signal and correlates directly with user retention and conversion rates.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> LCP / INP / CLS explained</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Field vs lab data</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Fix guides per metric</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Measurement tools</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">The Three Core Web Vitals</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Metric</th>
          <th class="border border-border px-3 py-2 text-left">Measures</th>
          <th class="border border-border px-3 py-2 text-left">Good</th>
          <th class="border border-border px-3 py-2 text-left">Poor</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2 font-semibold">LCP</td><td class="border border-border px-3 py-2">Loading performance — time until largest visible content renders</td><td class="border border-border px-3 py-2 text-green-400">≤ 2.5s</td><td class="border border-border px-3 py-2 text-red-400">&gt; 4s</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2 font-semibold">INP</td><td class="border border-border px-3 py-2">Responsiveness — slowest interaction response across page session</td><td class="border border-border px-3 py-2 text-green-400">≤ 200ms</td><td class="border border-border px-3 py-2 text-red-400">&gt; 500ms</td></tr>
        <tr><td class="border border-border px-3 py-2 font-semibold">CLS</td><td class="border border-border px-3 py-2">Visual stability — unexpected layout shifts during page lifetime</td><td class="border border-border px-3 py-2 text-green-400">≤ 0.1</td><td class="border border-border px-3 py-2 text-red-400">&gt; 0.25</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Measuring Core Web Vitals</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Install web-vitals library
npm install web-vitals

# Measure and send to analytics
import &#123; onLCP, onINP, onCLS, onFCP, onTTFB &#125; from 'web-vitals';

function sendToAnalytics(&#123; name, value, rating, id &#125;) &#123;
  // Send to your analytics endpoint
  navigator.sendBeacon('/analytics', JSON.stringify(&#123;
    metric: name,
    value: Math.round(name === 'CLS' ? value * 1000 : value),
    rating,   // 'good' | 'needs-improvement' | 'poor'
    id,
  &#125;));
&#125;

onLCP(sendToAnalytics);
onINP(sendToAnalytics);
onCLS(sendToAnalytics);
onFCP(sendToAnalytics);
onTTFB(sendToAnalytics);</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Fixing LCP (Largest Contentful Paint)</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Preload the LCP image</strong> — <code class="bg-bg-card px-1 rounded font-mono text-xs">&lt;link rel="preload" as="image" href="/hero.webp" fetchpriority="high"&gt;</code></li>
    <li><strong>Reduce TTFB</strong> — Use a CDN, enable caching headers, move server closer to users</li>
    <li><strong>Avoid lazy-loading the LCP element</strong> — Set <code class="bg-bg-card px-1 rounded font-mono text-xs">loading="eager"</code> and <code class="bg-bg-card px-1 rounded font-mono text-xs">fetchpriority="high"</code> on the hero image</li>
    <li><strong>Use modern image formats</strong> — Convert hero images to WebP/AVIF (40–80% smaller)</li>
    <li><strong>Inline critical CSS</strong> — Unblock render by inlining above-the-fold styles</li>
    <li><strong>Use HTTP/2 or HTTP/3</strong> — Allows parallel asset loading</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Fixing INP (Interaction to Next Paint)</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// Break up long tasks with scheduler
async function processLargeList(items) &#123;
  const CHUNK_SIZE = 100;
  for (let i = 0; i &lt; items.length; i += CHUNK_SIZE) &#123;
    const chunk = items.slice(i, i + CHUNK_SIZE);
    processChunk(chunk);
    // Yield to browser between chunks
    await scheduler.yield();
  &#125;
&#125;

// Use isInputPending to avoid blocking interactions
function runWithYielding(tasks) &#123;
  return new Promise(resolve =&gt; &#123;
    function runTask() &#123;
      while (tasks.length &gt; 0) &#123;
        if (navigator.scheduling?.isInputPending()) &#123;
          // Yield to user input
          setTimeout(runTask, 0);
          return;
        &#125;
        tasks.shift()();
      &#125;
      resolve();
    &#125;
    runTask();
  &#125;);
&#125;</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Fixing CLS (Cumulative Layout Shift)</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">&lt;!-- Always include width + height on images --&gt;
&lt;img src="hero.webp" width="1200" height="600" alt="Hero" loading="eager"&gt;

&lt;!-- CSS aspect-ratio for responsive media --&gt;
&lt;style&gt;
.video-container &#123;
  aspect-ratio: 16 / 9;
  width: 100%;
&#125;
.ad-slot &#123;
  min-height: 250px; /* Reserve space for late-loading ads */
&#125;
&lt;/style&gt;

&lt;!-- Font-display to prevent FOUT layout shift --&gt;
&lt;style&gt;
@font-face &#123;
  font-family: 'MyFont';
  src: url('font.woff2') format('woff2');
  font-display: optional; /* Skip FOUT entirely */
  /* Or use 'swap' with size-adjust to reduce shift: */
  /* font-display: swap; size-adjust: 98%; */
&#125;
&lt;/style&gt;</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Tools for Measuring Core Web Vitals</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>PageSpeed Insights</strong> — pagespeed.web.dev — field + lab data per URL</li>
    <li><strong>Google Search Console</strong> — Core Web Vitals report, URL groups, historical trends</li>
    <li><strong>Chrome DevTools Performance panel</strong> — Record interactions, identify long tasks</li>
    <li><strong>Lighthouse</strong> — Lab data audit with fix suggestions (see <a href="/tools/lighthouse-performance-audit" class="text-blue-400 hover:underline">Lighthouse audit guide</a>)</li>
    <li><strong>web-vitals npm package</strong> — In-page measurement, send to your analytics</li>
    <li><strong>CrUX API</strong> — Programmatic access to field data for any public URL</li>
  </ul>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Core Web Vitals Guide" relatedTags={['performance', 'core-web-vitals', 'lighthouse', 'seo', 'web-performance']} />
</BaseLayout>
