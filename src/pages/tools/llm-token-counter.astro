---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How does this token counter work?", answer: "It uses a tiktoken-style approximation: roughly 1 token per 4 characters for English text, with adjustments for whitespace, punctuation, and code. For production use cases, run tiktoken or the official tokenizer for your model." },
  { question: "Why do token counts differ between models?", answer: "GPT-4/GPT-4o uses cl100k_base, Claude uses its own tokenizer, and Gemini uses SentencePiece. All are roughly 1 token per 3-4 characters, but punctuation and special characters tokenize differently." },
  { question: "How is API cost estimated?", answer: "Input tokens use the published input price per 1M tokens; output tokens use the output price. The estimate assumes your pasted text is all input tokens. Actual costs depend on your output length." },
  { question: "What is a token in the context of LLMs?", answer: "A token is the basic unit an LLM processes — typically a word fragment, punctuation mark, or whitespace. 'tokenization' splits into 4 tokens: 'token', 'ization'. Most English words are 1-2 tokens." },
  { question: "Are my texts sent to any server?", answer: "No. All tokenization and cost calculations happen in your browser using JavaScript. Nothing is sent to any server." },
];
---

<BaseLayout
  title="LLM Token Counter — GPT-4, Claude, Gemini Token Estimator"
  description="Count tokens for GPT-4o, Claude 3.5 Sonnet, and Gemini 1.5 Pro. Paste any text and instantly see token counts per model with estimated API costs. Runs 100% in your browser."
  tool="LLM Token Counter, GPT Token Counter, Claude Token Estimator, Gemini Token Counter, AI Token Estimator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">LLM Token Counter</h1>
  <p class="text-text-muted mb-6">Paste any text to count tokens and estimate API costs across GPT-4o, Claude 3.5 Sonnet, and Gemini 1.5 Pro. Uses tiktoken-style approximation — runs entirely in your browser.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No data sent to any server</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>

  <div id="llm-token-counter" class="space-y-5">
    <!-- Input -->
    <div>
      <label for="input-text" class="block text-sm font-medium mb-2">Paste your text</label>
      <textarea
        id="input-text"
        rows="8"
        placeholder="Paste any text here — prompts, documents, code, conversations..."
        class="w-full font-mono text-sm bg-bg-card border border-border rounded-lg px-4 py-3 resize-y focus:outline-none focus:ring-2 focus:ring-primary"
      ></textarea>
      <div class="flex items-center justify-between mt-1 text-xs text-text-muted">
        <span id="char-count">0 characters</span>
        <button id="clear-btn" class="hover:text-text transition-colors">Clear</button>
      </div>
    </div>

    <!-- Results grid -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4" id="results-grid">
      <!-- GPT-4o card -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-xl">🤖</span>
          <div>
            <p class="font-semibold text-sm">GPT-4o</p>
            <p class="text-xs text-text-muted">cl100k_base</p>
          </div>
        </div>
        <p class="text-3xl font-bold tabular-nums" id="gpt4o-tokens">0</p>
        <p class="text-xs text-text-muted mt-1">tokens</p>
        <hr class="border-border my-3" />
        <p class="text-xs text-text-muted">Input cost</p>
        <p class="text-sm font-medium tabular-nums" id="gpt4o-cost">$0.000000</p>
        <p class="text-xs text-text-muted mt-2">$5.00 / 1M input tokens</p>
      </div>

      <!-- Claude 3.5 card -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-xl">✦</span>
          <div>
            <p class="font-semibold text-sm">Claude 3.5 Sonnet</p>
            <p class="text-xs text-text-muted">Anthropic tokenizer</p>
          </div>
        </div>
        <p class="text-3xl font-bold tabular-nums" id="claude-tokens">0</p>
        <p class="text-xs text-text-muted mt-1">tokens</p>
        <hr class="border-border my-3" />
        <p class="text-xs text-text-muted">Input cost</p>
        <p class="text-sm font-medium tabular-nums" id="claude-cost">$0.000000</p>
        <p class="text-xs text-text-muted mt-2">$3.00 / 1M input tokens</p>
      </div>

      <!-- Gemini card -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-xl">💎</span>
          <div>
            <p class="font-semibold text-sm">Gemini 1.5 Pro</p>
            <p class="text-xs text-text-muted">SentencePiece</p>
          </div>
        </div>
        <p class="text-3xl font-bold tabular-nums" id="gemini-tokens">0</p>
        <p class="text-xs text-text-muted mt-1">tokens</p>
        <hr class="border-border my-3" />
        <p class="text-xs text-text-muted">Input cost</p>
        <p class="text-sm font-medium tabular-nums" id="gemini-cost">$0.000000</p>
        <p class="text-xs text-text-muted mt-2">$3.50 / 1M input tokens</p>
      </div>
    </div>

    <!-- Summary bar -->
    <div class="bg-bg-card border border-border rounded-xl p-4 flex flex-wrap gap-6 text-sm">
      <div>
        <span class="text-text-muted">Words: </span>
        <span class="font-semibold tabular-nums" id="word-count">0</span>
      </div>
      <div>
        <span class="text-text-muted">Characters: </span>
        <span class="font-semibold tabular-nums" id="char-count-2">0</span>
      </div>
      <div>
        <span class="text-text-muted">Lines: </span>
        <span class="font-semibold tabular-nums" id="line-count">0</span>
      </div>
      <div>
        <span class="text-text-muted">~Reading time: </span>
        <span class="font-semibold tabular-nums" id="reading-time">0s</span>
      </div>
    </div>

    <p class="text-xs text-text-muted">
      ⚠️ Token counts are approximations. For production billing, use the official tokenizer for each model.
      Prices as of Q1 2025 — check provider websites for latest rates.
    </p>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="LLM Token Counter" relatedTags={['ai', 'llm', 'openai', 'claude', 'gemini', 'tokens', 'cost']} />
</BaseLayout>

<script>
  // Tiktoken approximation — ~1 token per 4 chars for English, adjusted for whitespace/code
  function estimateTokens(text: string, multiplier = 1.0): number {
    if (!text) return 0;
    // Split on whitespace boundaries and common punctuation
    const rough = text.split(/(\s+|[.,;:!?()\[\]{}<>"'`])/g).filter(t => t.trim().length > 0);
    let count = 0;
    for (const chunk of rough) {
      // Long words / code identifiers get split more
      count += Math.ceil(chunk.length / 4);
    }
    return Math.max(1, Math.round(count * multiplier));
  }

  // Pricing per 1M input tokens (USD)
  const PRICES: Record<string, number> = {
    gpt4o: 5.00,
    claude: 3.00,
    gemini: 3.50,
  };

  function formatCost(tokens: number, pricePerMillion: number): string {
    const cost = (tokens / 1_000_000) * pricePerMillion;
    if (cost < 0.000001) return '$0.000000';
    return `$${cost.toFixed(6)}`;
  }

  function formatReadingTime(words: number): string {
    const seconds = Math.round((words / 200) * 60);
    if (seconds < 60) return `${seconds}s`;
    return `${Math.floor(seconds / 60)}m ${seconds % 60}s`;
  }

  const textarea = document.getElementById('input-text') as HTMLTextAreaElement;
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;

  function update() {
    const text = textarea.value;
    const words = text.trim() ? text.trim().split(/\s+/).length : 0;
    const chars = text.length;
    const lines = text ? text.split('\n').length : 0;

    // Model-specific multipliers (Claude tokenizes slightly more efficiently for English prose)
    const gpt4oTok = estimateTokens(text, 1.0);
    const claudeTok = estimateTokens(text, 0.95);
    const geminiTok = estimateTokens(text, 0.98);

    (document.getElementById('gpt4o-tokens') as HTMLElement).textContent = gpt4oTok.toLocaleString();
    (document.getElementById('claude-tokens') as HTMLElement).textContent = claudeTok.toLocaleString();
    (document.getElementById('gemini-tokens') as HTMLElement).textContent = geminiTok.toLocaleString();

    (document.getElementById('gpt4o-cost') as HTMLElement).textContent = formatCost(gpt4oTok, PRICES.gpt4o);
    (document.getElementById('claude-cost') as HTMLElement).textContent = formatCost(claudeTok, PRICES.claude);
    (document.getElementById('gemini-cost') as HTMLElement).textContent = formatCost(geminiTok, PRICES.gemini);

    (document.getElementById('char-count') as HTMLElement).textContent = `${chars.toLocaleString()} characters`;
    (document.getElementById('char-count-2') as HTMLElement).textContent = chars.toLocaleString();
    (document.getElementById('word-count') as HTMLElement).textContent = words.toLocaleString();
    (document.getElementById('line-count') as HTMLElement).textContent = lines.toLocaleString();
    (document.getElementById('reading-time') as HTMLElement).textContent = formatReadingTime(words);
  }

  textarea.addEventListener('input', update);
  clearBtn.addEventListener('click', () => {
    textarea.value = '';
    update();
  });
</script>
