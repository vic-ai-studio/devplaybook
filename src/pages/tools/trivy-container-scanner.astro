---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What does Trivy scan — OS packages, language dependencies, IaC, and secrets?",
    answer: "Trivy scans OS packages (Alpine apk, Debian dpkg, RHEL rpm), language dependencies (npm, pip, gem, cargo, go.sum, composer), IaC files (Terraform, CloudFormation, Kubernetes YAML, Dockerfile, Helm charts), and secrets (API keys, passwords, tokens in source code and config files). It's an all-in-one scanner for the full software supply chain."
  },
  {
    question: "How do I scan a Docker image in CI with Trivy?",
    answer: "In GitHub Actions, use the aquasecurity/trivy-action with image-ref set to your image tag. Trivy pulls the image, extracts layers, and scans them. Set exit-code to 1 and severity to CRITICAL,HIGH to fail the pipeline only on serious findings. Cache the Trivy DB between runs with actions/cache to avoid repeated downloads."
  },
  {
    question: "How do I output SARIF format for the GitHub Security tab?",
    answer: "Run 'trivy image --format sarif --output trivy-results.sarif your-image:tag'. In GitHub Actions, upload the SARIF file using the github/codeql-action/upload-sarif action. The findings then appear in the repo's Security → Code scanning alerts tab, making vulnerability tracking part of your normal code review workflow."
  },
  {
    question: "How do I update Trivy's vulnerability database?",
    answer: "Trivy automatically downloads the latest DB on first run. Force a manual update with 'trivy image --download-db-only'. In CI, cache the ~/.cache/trivy directory between runs to avoid downloading the DB every build. The DB is updated daily by Aqua Security and mirrors the NVD, GitHub Advisory Database, and OS-specific advisories."
  },
  {
    question: "What is the difference between Trivy and Docker Scout?",
    answer: "Trivy is open-source, runs entirely locally, and scans OS packages, language deps, IaC, and secrets. Docker Scout is Docker Inc's commercial offering (free for personal use) with tighter Docker Hub integration and remediation advice. Trivy has broader ecosystem support and is the standard in Kubernetes/GitOps pipelines. Docker Scout is better for teams already deep in the Docker ecosystem."
  },
  {
    question: "How do I ignore specific CVEs in Trivy?",
    answer: "Create a .trivyignore file at the repo root and list CVE IDs one per line. Trivy reads this file automatically. For more control, use the --ignorefile flag to point to a custom path. You can also use --ignore-unfixed to skip CVEs with no available fix, significantly reducing noise in reports."
  },
];
---

<BaseLayout
  title="Trivy Container Scanner: Docker Image & IaC Security Scanning"
  description="Trivy container and IaC security scanner guide. Scan Docker images, filesystems, git repos, Kubernetes configs, and Terraform for vulnerabilities and misconfigurations."
  tool="Trivy, container scanner, Docker security, IaC scanning, Kubernetes security, vulnerability scanner"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Trivy Container Scanner: Docker Image & IaC Security Scanning",
    "url": "https://devplaybook.cc/tools/trivy-container-scanner",
    "description": "Trivy container and IaC security scanner guide. Scan Docker images, filesystems, git repos, Kubernetes configs, and Terraform for vulnerabilities and misconfigurations.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Trivy Container Scanner: Docker Image & IaC Security Scanning</h1>
  <p class="text-text-muted mb-6">Trivy is an open-source, all-in-one vulnerability and misconfiguration scanner from Aqua Security. It scans container images, filesystems, Git repositories, Kubernetes manifests, and Terraform — making it the go-to tool for cloud-native security pipelines.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Docker & OCI image scanning</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Terraform & Kubernetes IaC</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Secret detection</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> SARIF output for GitHub Security tab</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100% open-source</span>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-3">What is Trivy?</h2>
  <p class="text-text-muted mb-4">Trivy (Trivial Vulnerability scanner) detects CVEs in OS packages and language-specific dependencies, misconfigurations in IaC files, and exposed secrets in source code — all with a single binary and no daemon required. It's widely adopted in Kubernetes environments and integrates natively with GitHub Actions, GitLab CI, and ArgoCD.</p>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Installation</h2>
  <pre class="bg-surface rounded-lg p-4 text-sm overflow-x-auto mb-4"><code># Homebrew (macOS/Linux)
brew install aquasecurity/trivy/trivy

# Debian/Ubuntu
sudo apt-get install wget apt-transport-https gnupg
wget -qO - https://aquasecurity.github.io/trivy-repo/deb/public.key | gpg --dearmor | sudo tee /usr/share/keyrings/trivy.gpg > /dev/null
echo "deb [signed-by=/usr/share/keyrings/trivy.gpg] https://aquasecurity.github.io/trivy-repo/deb generic main" | sudo tee /etc/apt/sources.list.d/trivy.list
sudo apt-get update && sudo apt-get install trivy

# Docker
docker run --rm aquasec/trivy image nginx:latest</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Scan Docker Images</h2>
  <pre class="bg-surface rounded-lg p-4 text-sm overflow-x-auto mb-4"><code># Scan a public image
trivy image nginx:latest

# Scan your own image
trivy image myapp:1.0.0

# Only show CRITICAL and HIGH
trivy image --severity CRITICAL,HIGH myapp:1.0.0

# Skip unfixed vulnerabilities (less noise)
trivy image --ignore-unfixed myapp:1.0.0

# Output as JSON
trivy image --format json --output report.json myapp:1.0.0</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Scan Filesystem & Git Repos</h2>
  <pre class="bg-surface rounded-lg p-4 text-sm overflow-x-auto mb-4"><code># Scan local filesystem (app dependencies + secrets)
trivy fs .

# Scan a git repository remotely
trivy repo https://github.com/myorg/myrepo

# Scan with secret detection enabled
trivy fs --scanners secret .

# Scan specific directory
trivy fs --scanners vuln,secret ./src/</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Scan IaC — Terraform & Kubernetes</h2>
  <pre class="bg-surface rounded-lg p-4 text-sm overflow-x-auto mb-4"><code># Scan Terraform files
trivy config ./terraform/

# Scan Kubernetes YAML manifests
trivy config ./k8s/

# Scan Helm chart
trivy config ./charts/myapp/

# Scan a single file
trivy config deployment.yaml</code></pre>
  <p class="text-text-muted mb-4">IaC scanning catches issues like containers running as root, missing read-only root filesystems, privilege escalation enabled, hostPath volumes, and open ingress ports — all before <code>kubectl apply</code>.</p>

  <h2 class="text-2xl font-semibold mt-8 mb-3">GitHub Actions Integration</h2>
  <pre class="bg-surface rounded-lg p-4 text-sm overflow-x-auto mb-4"><code>name: Trivy Security Scan

on: [push, pull_request]

jobs:
  trivy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Build Docker image
        run: docker build -t myapp:&#123;&#123; github.sha &#125;&#125; .

      - name: Run Trivy vulnerability scanner
        uses: aquasecurity/trivy-action@master
        with:
          image-ref: 'myapp:&#123;&#123; github.sha &#125;&#125;'
          format: 'sarif'
          output: 'trivy-results.sarif'
          severity: 'CRITICAL,HIGH'
          exit-code: '1'

      - name: Upload SARIF to GitHub Security tab
        uses: github/codeql-action/upload-sarif@v3
        if: always()
        with:
          sarif_file: 'trivy-results.sarif'</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Output Formats</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 font-semibold">Format</th>
          <th class="text-left py-2 pr-4 font-semibold">Flag</th>
          <th class="text-left py-2 pr-4 font-semibold">Best For</th>
        </tr>
      </thead>
      <tbody class="text-text-muted">
        <tr class="border-b border-border/50"><td class="py-2 pr-4">Table</td><td class="py-2 pr-4"><code>--format table</code></td><td class="py-2 pr-4">Human review in terminal</td></tr>
        <tr class="border-b border-border/50"><td class="py-2 pr-4">JSON</td><td class="py-2 pr-4"><code>--format json</code></td><td class="py-2 pr-4">Programmatic processing, dashboards</td></tr>
        <tr class="border-b border-border/50"><td class="py-2 pr-4">SARIF</td><td class="py-2 pr-4"><code>--format sarif</code></td><td class="py-2 pr-4">GitHub Security tab integration</td></tr>
        <tr><td class="py-2 pr-4">CycloneDX</td><td class="py-2 pr-4"><code>--format cyclonedx</code></td><td class="py-2 pr-4">SBOM generation, compliance</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Trivy vs Alternatives</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 font-semibold">Tool</th>
          <th class="text-left py-2 pr-4 font-semibold">IaC</th>
          <th class="text-left py-2 pr-4 font-semibold">Secrets</th>
          <th class="text-left py-2 pr-4 font-semibold">SBOM</th>
          <th class="text-left py-2 pr-4 font-semibold">License</th>
        </tr>
      </thead>
      <tbody class="text-text-muted">
        <tr class="border-b border-border/50"><td class="py-2 pr-4 font-medium text-text">Trivy</td><td class="py-2 pr-4">✓</td><td class="py-2 pr-4">✓</td><td class="py-2 pr-4">✓</td><td class="py-2 pr-4">Apache 2.0</td></tr>
        <tr class="border-b border-border/50"><td class="py-2 pr-4 font-medium text-text">Snyk</td><td class="py-2 pr-4">✓</td><td class="py-2 pr-4">✓</td><td class="py-2 pr-4">✓</td><td class="py-2 pr-4">Commercial</td></tr>
        <tr class="border-b border-border/50"><td class="py-2 pr-4 font-medium text-text">Grype</td><td class="py-2 pr-4">✗</td><td class="py-2 pr-4">✗</td><td class="py-2 pr-4">✓ (Syft)</td><td class="py-2 pr-4">Apache 2.0</td></tr>
        <tr><td class="py-2 pr-4 font-medium text-text">Docker Scout</td><td class="py-2 pr-4">✗</td><td class="py-2 pr-4">✗</td><td class="py-2 pr-4">✓</td><td class="py-2 pr-4">Commercial</td></tr>
      </tbody>
    </table>
  </div>

  <ToolPageCta />
  <FaqSection faqs={faq} />
</BaseLayout>
