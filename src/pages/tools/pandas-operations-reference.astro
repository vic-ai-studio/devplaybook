---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is pandas?",
    answer: "pandas is an open-source Python library for data manipulation and analysis. It provides two primary data structures: DataFrame (2D labeled table, like a spreadsheet or SQL table) and Series (1D labeled array). pandas makes it easy to load, clean, transform, aggregate, and analyze structured data. It's the foundation of Python data science and works seamlessly with NumPy, Matplotlib, and scikit-learn."
  },
  {
    question: "What is the difference between loc and iloc?",
    answer: "loc selects data by label (row index names and column names): df.loc['row_name', 'col_name']. iloc selects by integer position (zero-based): df.iloc[0, 1] selects row 0, column 1. When your index is integers, loc and iloc may look similar but behave differently — loc includes the end of a slice, iloc does not. Use loc for label-based selection and iloc for positional selection."
  },
  {
    question: "How do I handle missing values in pandas?",
    answer: "pandas uses NaN (Not a Number) to represent missing values. Key operations: df.isna() or df.isnull() detects NaN values; df.dropna() removes rows (or columns) with NaN; df.fillna(value) replaces NaN with a specified value; df.fillna(method='ffill') forward-fills from the previous valid value. For numeric data, df.fillna(df.mean()) fills with column mean."
  },
  {
    question: "What is groupby() and how does it work?",
    answer: "groupby() splits data into groups based on one or more column values, applies a function to each group, and combines the results. It follows the split-apply-combine pattern. Example: df.groupby('category')['sales'].sum() groups by 'category' and sums 'sales' per group. You can chain multiple aggregations with .agg({'col1': 'sum', 'col2': 'mean'})."
  },
  {
    question: "What is the difference between merge() and concat()?",
    answer: "merge() is a SQL-style join that combines DataFrames on a common key column (like JOIN in SQL). It supports inner, left, right, and outer joins. concat() stacks DataFrames along an axis — axis=0 stacks rows (like UNION ALL in SQL), axis=1 stacks columns side by side. Use merge() when combining tables with a shared key; use concat() when adding more rows or columns."
  },
  {
    question: "How do I apply a custom function to a DataFrame column?",
    answer: "Use .apply() for element-wise or row/column operations. For a single column: df['col'].apply(my_func) applies my_func to each element. For rows: df.apply(my_func, axis=1) applies to each row. For multiple columns at once, use .applymap() (element-wise across DataFrame). For vectorized operations on numeric columns, prefer NumPy functions directly (faster than apply): df['col'] * 2, np.sqrt(df['col'])."
  },
];
---

<BaseLayout
  title="Pandas Operations Reference — Interactive Python Pandas Cheatsheet"
  description="Interactive pandas cheatsheet with searchable code snippets. Covers DataFrame creation, selection, filtering, groupby, merge/join, pivot tables, missing data, and apply/transform. Copy button on each snippet."
  tool="Pandas Cheatsheet, Pandas Operations Reference, Python pandas Tutorial, pandas groupby, pandas merge, pandas DataFrame, pandas loc iloc"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Pandas Operations Reference",
    "url": "https://devplaybook.cc/tools/pandas-operations-reference",
    "description": "Interactive pandas cheatsheet with searchable code snippets for DataFrame operations, groupby, merge, pivot tables, and more.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Pandas Operations Reference</h1>
  <p class="text-text-muted mb-4">
    Searchable pandas cheatsheet. Find operations by category or keyword — each snippet shows the code with a copy button and a brief description of what it does.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60+ operations</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Searchable by keyword</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy button on each snippet</span>
  </div>

  <div id="pandas-app" class="space-y-4">
    <div class="flex flex-col sm:flex-row gap-3">
      <input id="search-input" type="text" placeholder="Search operations... (e.g. groupby, merge, fillna)" class="flex-1 bg-surface border border-border rounded-lg px-4 py-2 text-sm text-text focus:outline-none focus:border-accent" />
      <select id="category-filter" class="bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent">
        <option value="">All Categories</option>
        <option value="creation">DataFrame Creation</option>
        <option value="selection">Selection & Filtering</option>
        <option value="groupby">GroupBy & Aggregation</option>
        <option value="merge">Merge & Join</option>
        <option value="pivot">Pivot & Reshape</option>
        <option value="missing">Missing Data</option>
        <option value="apply">Apply & Transform</option>
        <option value="io">I/O (Read/Write)</option>
      </select>
    </div>

    <div id="ops-count" class="text-xs text-text-muted"></div>
    <div id="ops-container" class="space-y-3"></div>
    <div id="no-results" class="hidden text-center py-8 text-text-muted text-sm">No operations match your search.</div>
  </div>

  <script>
    (function () {
      const ops = [
        // Creation
        { cat: 'creation', title: 'Create DataFrame from dict', desc: 'Create a DataFrame from a dictionary of lists. Keys become column names.', code: `import pandas as pd\n\ndf = pd.DataFrame({\n    'name': ['Alice', 'Bob', 'Carol'],\n    'age': [25, 30, 27],\n    'city': ['NY', 'LA', 'SF']\n})` },
        { cat: 'creation', title: 'Create DataFrame from CSV', desc: 'Read a CSV file into a DataFrame. Use sep="\\t" for TSV files.', code: `df = pd.read_csv('data.csv')\n# With options:\ndf = pd.read_csv('data.csv', index_col='id', parse_dates=['date'], dtype={'col': str})` },
        { cat: 'creation', title: 'Create DataFrame from list of dicts', desc: 'Each dict becomes a row. Missing keys become NaN.', code: `rows = [\n    {'name': 'Alice', 'score': 90},\n    {'name': 'Bob', 'score': 85, 'bonus': 5},\n]\ndf = pd.DataFrame(rows)` },
        { cat: 'creation', title: 'Create empty DataFrame with columns', desc: 'Create an empty DataFrame with predefined columns.', code: `df = pd.DataFrame(columns=['id', 'name', 'value'])\n# Or with dtype:\ndf = pd.DataFrame({'id': pd.Series(dtype=int), 'name': pd.Series(dtype=str)})` },
        { cat: 'creation', title: 'Read JSON / Excel / SQL', desc: 'Load data from different sources.', code: `df = pd.read_json('data.json')\ndf = pd.read_excel('data.xlsx', sheet_name='Sheet1')\n# SQL:\nimport sqlalchemy\nengine = sqlalchemy.create_engine('sqlite:///db.sqlite3')\ndf = pd.read_sql('SELECT * FROM table', engine)` },

        // Selection
        { cat: 'selection', title: 'Select column(s)', desc: 'Single column returns Series. List of columns returns DataFrame.', code: `s = df['name']          # Series\ndf2 = df[['name', 'age']]  # DataFrame (double brackets)` },
        { cat: 'selection', title: 'Select rows by label (loc)', desc: 'loc selects by index label. Slice includes both endpoints.', code: `df.loc[0]               # Row with label 0\ndf.loc[0:2]             # Rows 0, 1, 2 (inclusive)\ndf.loc[0, 'name']       # Scalar value\ndf.loc[:, 'age':'city'] # All rows, columns age through city` },
        { cat: 'selection', title: 'Select rows by position (iloc)', desc: 'iloc uses integer positions. Slice excludes the end (Python-style).', code: `df.iloc[0]              # First row\ndf.iloc[0:3]            # Rows 0, 1, 2 (not 3)\ndf.iloc[-1]             # Last row\ndf.iloc[0, 1]           # Row 0, column 1` },
        { cat: 'selection', title: 'Boolean filtering', desc: 'Filter rows using conditions. Use & (and), | (or), ~ (not).', code: `df[df['age'] > 25]\ndf[(df['age'] > 25) & (df['city'] == 'NY')]\ndf[df['name'].isin(['Alice', 'Bob'])]\ndf[~df['city'].isin(['LA'])]    # NOT in LA` },
        { cat: 'selection', title: 'Filter with query()', desc: 'query() accepts a string expression — cleaner for complex conditions.', code: `df.query('age > 25')\ndf.query('age > 25 and city == "NY"')\n# Use @ for Python variables:\nmin_age = 25\ndf.query('age > @min_age')` },
        { cat: 'selection', title: 'Sort values', desc: 'Sort by one or more columns. ascending=False for descending.', code: `df.sort_values('age')\ndf.sort_values(['city', 'age'], ascending=[True, False])\ndf.sort_values('score', na_position='last')  # NaN at end` },

        // GroupBy
        { cat: 'groupby', title: 'Basic groupby + aggregate', desc: 'Group by a column and apply aggregation functions.', code: `df.groupby('city')['age'].mean()\ndf.groupby('city')['age'].agg(['mean', 'min', 'max', 'count'])` },
        { cat: 'groupby', title: 'Multi-column groupby', desc: 'Group by multiple columns for hierarchical aggregation.', code: `df.groupby(['city', 'department']).agg({\n    'salary': 'mean',\n    'headcount': 'sum'\n}).reset_index()` },
        { cat: 'groupby', title: 'groupby with transform()', desc: 'transform() returns a Series aligned with original index — useful for adding group statistics back to the original DataFrame.', code: `# Add group mean as a new column:\ndf['city_avg_age'] = df.groupby('city')['age'].transform('mean')\n# Normalize within group:\ndf['score_z'] = df.groupby('group')['score'].transform(\n    lambda x: (x - x.mean()) / x.std()\n)` },
        { cat: 'groupby', title: 'groupby filter()', desc: 'Filter groups by a condition applied to the whole group.', code: `# Keep groups where group size >= 3:\ndf.groupby('city').filter(lambda x: len(x) >= 3)\n# Keep groups where mean salary > 50000:\ndf.groupby('dept').filter(lambda x: x['salary'].mean() > 50000)` },
        { cat: 'groupby', title: 'value_counts()', desc: 'Count occurrences of each unique value in a column.', code: `df['city'].value_counts()\ndf['city'].value_counts(normalize=True)  # As proportions\ndf['city'].value_counts(dropna=False)    # Include NaN` },

        // Merge
        { cat: 'merge', title: 'Inner join (merge)', desc: 'Keeps only rows where the key exists in both DataFrames.', code: `result = pd.merge(df1, df2, on='id')\n# Different key names:\nresult = pd.merge(df1, df2, left_on='user_id', right_on='id')` },
        { cat: 'merge', title: 'Left / right / outer join', desc: 'Left keeps all rows from left df. Outer keeps all rows from both.', code: `pd.merge(df1, df2, on='id', how='left')    # All df1 rows\npd.merge(df1, df2, on='id', how='right')   # All df2 rows\npd.merge(df1, df2, on='id', how='outer')   # All rows` },
        { cat: 'merge', title: 'Stack DataFrames (concat)', desc: 'Concatenate along rows (axis=0) or columns (axis=1).', code: `# Stack rows (UNION ALL):\nresult = pd.concat([df1, df2], ignore_index=True)\n# Stack columns:\nresult = pd.concat([df1, df2], axis=1)` },
        { cat: 'merge', title: 'Join on index', desc: 'Use join() to merge on index rather than a column.', code: `# Set index before joining:\nresult = df1.set_index('id').join(df2.set_index('id'), how='inner')` },

        // Pivot
        { cat: 'pivot', title: 'pivot_table()', desc: 'Create a pivot table — similar to Excel pivot tables. aggfunc defaults to mean.', code: `pd.pivot_table(\n    df,\n    values='sales',\n    index='region',\n    columns='product',\n    aggfunc='sum',\n    fill_value=0\n)` },
        { cat: 'pivot', title: 'melt() — wide to long', desc: 'Unpivot wide-format data to long format (opposite of pivot).', code: `pd.melt(\n    df,\n    id_vars=['id', 'name'],      # Columns to keep\n    value_vars=['q1', 'q2', 'q3'],  # Columns to unpivot\n    var_name='quarter',\n    value_name='revenue'\n)` },
        { cat: 'pivot', title: 'stack() and unstack()', desc: 'stack() pivots columns to row index. unstack() does the reverse.', code: `# Multi-index DataFrame:\ndf_stacked = df.stack()     # Columns become rows\ndf_wide = df_stacked.unstack()  # Rows become columns` },
        { cat: 'pivot', title: 'crosstab()', desc: 'Compute a cross-tabulation of two (or more) factors.', code: `pd.crosstab(df['gender'], df['department'])\n# With normalize:\npd.crosstab(df['gender'], df['department'], normalize='index')` },

        // Missing data
        { cat: 'missing', title: 'Detect missing values', desc: 'Check for NaN values across the DataFrame or a specific column.', code: `df.isna()                  # Boolean mask\ndf.isna().sum()            # Count NaN per column\ndf.isna().sum().sum()      # Total NaN count\ndf['col'].notna()          # True where NOT NaN` },
        { cat: 'missing', title: 'Drop rows/columns with NaN', desc: 'dropna() removes rows (default) or columns that contain NaN.', code: `df.dropna()                        # Drop any row with NaN\ndf.dropna(how='all')               # Drop only rows that are all NaN\ndf.dropna(subset=['age', 'city'])  # Drop only if these cols are NaN\ndf.dropna(axis=1)                  # Drop columns with any NaN` },
        { cat: 'missing', title: 'Fill missing values', desc: 'fillna() replaces NaN with a specified value, method, or dict.', code: `df.fillna(0)                   # Fill all NaN with 0\ndf['age'].fillna(df['age'].mean())  # Fill with column mean\ndf.fillna({'age': 0, 'city': 'Unknown'})  # Per-column values\ndf.fillna(method='ffill')     # Forward fill\ndf.fillna(method='bfill')     # Backward fill` },
        { cat: 'missing', title: 'Interpolate missing values', desc: 'interpolate() fills NaN using linear (or other) interpolation — useful for time series.', code: `df['price'].interpolate()                   # Linear\ndf['price'].interpolate(method='time')       # Time-based\ndf['price'].interpolate(limit=2)             # Max 2 consecutive fills` },

        // Apply
        { cat: 'apply', title: 'apply() on a column', desc: 'Apply a function element-wise to a Series.', code: `df['name'].apply(str.upper)\ndf['age'].apply(lambda x: x * 2)\ndf['text'].apply(lambda x: len(x.split()))` },
        { cat: 'apply', title: 'apply() on rows (axis=1)', desc: 'Apply a function to each row. row is a Series with column names as index.', code: `df.apply(lambda row: row['first'] + ' ' + row['last'], axis=1)\n# Create new column:\ndf['full_name'] = df.apply(\n    lambda row: f"{row['first']} {row['last']}", axis=1\n)` },
        { cat: 'apply', title: 'map() for column replacement', desc: 'map() replaces values using a dict or function. Values not in dict become NaN.', code: `df['status'].map({'active': 1, 'inactive': 0})\ndf['city'].map(str.lower)\n# Replace with fillna to keep unmapped values:\ndf['status'].map({'A': 'Active'}).fillna(df['status'])` },
        { cat: 'apply', title: 'Vectorized string operations', desc: 'str accessor provides vectorized string methods on Series.', code: `df['name'].str.lower()\ndf['name'].str.upper()\ndf['name'].str.strip()\ndf['email'].str.contains('@gmail')\ndf['name'].str.split(' ', expand=True)  # Split into columns\ndf['code'].str.startswith('A')` },

        // I/O
        { cat: 'io', title: 'Write to CSV / Excel', desc: 'Save DataFrame to file. Use index=False to skip writing the index.', code: `df.to_csv('output.csv', index=False)\ndf.to_csv('output.csv', index=False, encoding='utf-8')\ndf.to_excel('output.xlsx', sheet_name='Data', index=False)` },
        { cat: 'io', title: 'Write to JSON / Parquet', desc: 'JSON and Parquet are common data exchange formats.', code: `df.to_json('output.json', orient='records', indent=2)\ndf.to_parquet('output.parquet', index=False)  # Requires pyarrow\n# Read back:\ndf = pd.read_parquet('output.parquet')` },
        { cat: 'io', title: 'DataFrame info and describe', desc: 'Quick summary of DataFrame structure and statistics.', code: `df.info()           # Column names, dtypes, non-null counts\ndf.describe()       # Stats: count, mean, std, min, 25%, 50%, 75%, max\ndf.describe(include='all')  # Include categorical columns\ndf.dtypes           # Column data types\ndf.shape            # (rows, columns)` },
      ];

      function escape(s) {
        return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      }

      function renderOps(list) {
        const container = document.getElementById('ops-container');
        const noResults = document.getElementById('no-results');
        const count = document.getElementById('ops-count');

        count.textContent = `${list.length} operation${list.length !== 1 ? 's' : ''}`;

        if (list.length === 0) {
          container.innerHTML = '';
          noResults.classList.remove('hidden');
          return;
        }
        noResults.classList.add('hidden');

        const catLabels = {
          creation: 'DataFrame Creation', selection: 'Selection & Filtering',
          groupby: 'GroupBy & Aggregation', merge: 'Merge & Join',
          pivot: 'Pivot & Reshape', missing: 'Missing Data',
          apply: 'Apply & Transform', io: 'I/O'
        };

        // Group by category
        const byCat = {};
        list.forEach(op => {
          if (!byCat[op.cat]) byCat[op.cat] = [];
          byCat[op.cat].push(op);
        });

        container.innerHTML = Object.entries(byCat).map(([cat, catOps]) => {
          const cards = catOps.map((op, i) => {
            const id = `op-${cat}-${i}`;
            return `<div class="bg-surface border border-border rounded-lg overflow-hidden">
              <div class="px-4 py-3 border-b border-border flex items-start justify-between gap-3">
                <div>
                  <p class="text-sm font-semibold text-text">${escape(op.title)}</p>
                  <p class="text-xs text-text-muted mt-0.5">${escape(op.desc)}</p>
                </div>
                <button class="copy-btn flex-shrink-0 text-xs text-accent hover:underline font-medium" data-id="${id}">Copy</button>
              </div>
              <pre id="${id}" class="px-4 py-3 text-xs font-mono text-text overflow-auto leading-relaxed bg-surface/50">&#36;&#123;escape(op.code)&#125;</pre>
            </div>`;
          }).join('');
          return `<div>
            <p class="text-xs font-semibold text-text-muted uppercase tracking-wide mb-2 mt-4">${catLabels[cat] || cat}</p>
            <div class="space-y-2">${cards}</div>
          </div>`;
        }).join('');

        // Bind copy buttons
        container.querySelectorAll('.copy-btn').forEach(btn => {
          btn.addEventListener('click', function () {
            const pre = document.getElementById(this.dataset.id);
            if (!pre) return;
            navigator.clipboard.writeText(pre.textContent).then(() => {
              this.textContent = 'Copied!';
              setTimeout(() => { this.textContent = 'Copy'; }, 2000);
            });
          });
        });
      }

      function filterOps() {
        const q = document.getElementById('search-input').value.toLowerCase().trim();
        const cat = document.getElementById('category-filter').value;
        const filtered = ops.filter(op => {
          const matchCat = !cat || op.cat === cat;
          const matchQ = !q || op.title.toLowerCase().includes(q) || op.desc.toLowerCase().includes(q) || op.code.toLowerCase().includes(q);
          return matchCat && matchQ;
        });
        renderOps(filtered);
      }

      document.getElementById('search-input').addEventListener('input', filterOps);
      document.getElementById('category-filter').addEventListener('change', filterOps);

      renderOps(ops);
    })();
  </script>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Pandas Operations Reference" relatedTags={['python', 'pandas', 'data-science', 'data-analysis', 'machine-learning']} />
</BaseLayout>
