---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SqlQueryFormatter from '../../components/SqlQueryFormatter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What SQL statements does this formatter support?",
    answer: "The formatter handles all common SQL statements including SELECT, INSERT INTO, UPDATE, DELETE FROM, CREATE TABLE, ALTER TABLE, and WITH (CTEs). It correctly formats JOIN variants (LEFT JOIN, RIGHT JOIN, INNER JOIN), GROUP BY, ORDER BY, HAVING, LIMIT, OFFSET, and UNION clauses."
  },
  {
    question: "Is my SQL sent to any server?",
    answer: "No. All formatting happens entirely in your browser using JavaScript. Your SQL queries never leave your machine and are never stored anywhere."
  },
  {
    question: "What does the keyword case option do?",
    answer: "The keyword case option lets you choose between UPPERCASE keywords (e.g. SELECT, FROM, WHERE) or lowercase keywords (e.g. select, from, where). UPPERCASE is the conventional SQL style and improves readability by visually separating keywords from identifiers."
  },
  {
    question: "Why use 2 vs 4 space indentation?",
    answer: "Two-space indentation produces more compact output that is easier to read for shorter queries, while four-space indentation adds more visual separation and is preferred in teams that follow standard code style guides. Both are widely accepted in SQL formatting conventions."
  },
  {
    question: "Does the formatter handle comments and quoted strings?",
    answer: "Yes. The formatter preserves single-line comments (-- comment), block comments (/* comment */), single-quoted string literals, double-quoted identifiers, and backtick-quoted identifiers without modifying their contents."
  },
];
---

<BaseLayout
  title="SQL Query Formatter — Format & Prettify SQL Online Free"
  description="Format and prettify SQL queries instantly in your browser. Supports SELECT, INSERT, UPDATE, DELETE, CREATE TABLE, CTEs, and all JOIN types. Configure indent size, keyword case, and line wrap. Free, no signup, runs offline."
  tool="SQL Query Formatter, SQL Beautifier, Format SQL, SQL Pretty Print, SQL indenter"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "SQL Query Formatter",
    "url": "https://devplaybook.cc/tools/sql-query-formatter",
    "description": "Format and prettify SQL queries instantly in your browser. Supports SELECT, INSERT, UPDATE, DELETE, CREATE TABLE, CTEs, and JOIN types. Configure indent size and keyword case.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">SQL Query Formatter</h1>
  <p class="text-text-muted mb-4">
    Paste any SQL query and get clean, readable output in one click. Formats SELECT, INSERT, UPDATE, DELETE, CREATE TABLE, CTEs, and all JOIN variants. Configure indent size, keyword case, and line wrapping. Runs entirely in your browser — nothing is sent to any server.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Uppercase or lowercase keywords</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 2 or 4 space indent</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <SqlQueryFormatter client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SQL Query Formatter" relatedTags={['sql', 'database', 'formatting', 'postgresql', 'mysql']} />
</BaseLayout>
