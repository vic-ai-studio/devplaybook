---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CypressTestGenerator from '../../components/CypressTestGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is Cypress and when should I use it?",
    answer: "Cypress is an end-to-end (E2E) testing framework that runs tests directly in the browser, giving you real interaction with your UI just like a real user. Use it when you need to test complete user flows — login, form submission, navigation, API interactions — from the browser's perspective. Unlike unit tests, Cypress catches integration bugs that only appear when components interact with real DOM and network requests."
  },
  {
    question: "What is the difference between cy.get() and cy.contains()?",
    answer: "cy.get() selects elements by CSS selector (e.g. '[data-testid=\"btn\"]', '.submit', '#email'). cy.contains() finds elements by their text content, making it useful for asserting that specific text appears on the page. Use cy.get() for targeting specific interactive elements, and cy.contains() for verifying text outcomes like success messages or navigation labels."
  },
  {
    question: "What are data-testid attributes and why use them?",
    answer: "data-testid attributes (e.g. data-testid=\"submit-btn\") are custom HTML attributes added specifically to target elements in tests. They're preferred over CSS classes or IDs because they decouple your tests from styling decisions — renaming a class won't break your tests. Add them to your React/Vue/HTML elements: <button data-testid=\"submit-btn\">. Then select with cy.get('[data-testid=\"submit-btn\"]')."
  },
  {
    question: "How does cy.intercept() work for API testing?",
    answer: "cy.intercept() intercepts network requests made by your app. You can observe them (cy.wait('@alias') to confirm they fired and check request/response details) or mock them (by providing a fixture or inline response body). This lets you test how your UI reacts to specific API responses — including errors — without hitting a real backend. Always call cy.intercept() before the action that triggers the request."
  },
  {
    question: "How do I run Cypress in CI/CD?",
    answer: "Use npx cypress run (headless mode) in your CI pipeline. Add it to your GitHub Actions, GitLab CI, or CircleCI config. The Cypress Dashboard service records test results, screenshots, and videos. For parallel runs: npx cypress run --record --parallel. Set your CYPRESS_baseUrl environment variable to your staging URL so cy.visit('/path') resolves correctly."
  },
  {
    question: "How do I handle flaky tests in Cypress?",
    answer: "Flaky tests usually stem from timing issues. Avoid cy.wait(1000) (arbitrary waits). Instead: wait for elements to appear (cy.get('.el').should('be.visible')), wait for network requests (cy.wait('@alias')), or use cy.intercept() to stub slow APIs. Cypress automatically retries queries until they pass or time out. For persistent flakiness, check if your app has race conditions or inconsistent async behavior."
  },
];
---

<BaseLayout
  title="Cypress E2E Test Generator — Generate Cypress Tests Instantly"
  description="Generate Cypress end-to-end test boilerplate instantly. Configure test type (navigation, form, button, API), add selectors, and copy ready-to-run TypeScript Cypress tests. Free, runs in your browser."
  tool="Cypress Test Generator, E2E Test Generator, Cypress E2E, Cypress TypeScript, JavaScript Testing"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Cypress E2E Test Generator",
    "url": "https://devplaybook.cc/tools/cypress-test-generator",
    "description": "Generate Cypress end-to-end test boilerplate instantly. Configure test type, add selectors, and copy ready-to-run TypeScript Cypress tests.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Cypress E2E Test Generator</h1>
  <p class="text-text-muted mb-4">
    Generate <code class="text-primary font-mono">cypress/e2e/*.cy.ts</code> boilerplate instantly.
    Pick your test type, enter your selectors, and get complete TypeScript test code with
    <code class="text-primary font-mono">cy.visit</code>, <code class="text-primary font-mono">cy.get</code>,
    <code class="text-primary font-mono">cy.intercept</code>, and proper assertions — ready to copy and run.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Navigation, Form, Button & API tests</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> cy.intercept() with alias + error handling</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> viewport + screenshot options</span>
  </div>
  <CypressTestGenerator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Cypress E2E Test Generator" relatedTags={['testing', 'cypress', 'e2e', 'javascript', 'developer-tools']} />
</BaseLayout>
