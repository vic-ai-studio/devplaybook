---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is FaaS (Function-as-a-Service)?", answer: "Function-as-a-Service (FaaS) is a serverless compute model where you deploy individual functions that execute on demand. The cloud provider manages the underlying infrastructure, scaling, and execution environments. You pay only for execution time and invocations rather than reserved capacity. Major FaaS platforms include AWS Lambda, Google Cloud Functions, Azure Functions, and Cloudflare Workers (edge FaaS)." },
  { question: "Which FaaS platform is cheapest for high-volume workloads?", answer: "AWS Lambda has a generous free tier (1M requests + 400,000 GB-seconds/month free forever) and competitive pricing beyond that. For very high-volume short-duration functions, Cloudflare Workers at $0.30/million requests (paid plan) is often cheaper than Lambda. GCP Cloud Functions and Azure Functions have similar pricing to Lambda. The key variable is duration — Lambda charges per GB-second, so memory allocation and duration both affect cost." },
  { question: "Which FaaS platform has the best local development experience?", answer: "AWS Lambda with SAM CLI or Serverless Framework + serverless-offline provides solid local emulation. GCP Cloud Functions has a local emulator. Azure Functions Core Tools provides excellent local development with Docker-based function host. Cloudflare Workers has Wrangler with miniflare for local testing. For pure developer experience, Azure Functions Core Tools and Cloudflare Wrangler are often praised for their fidelity to the production environment." },
  { question: "What is the maximum function execution timeout across platforms?", answer: "AWS Lambda: 15 minutes (standard), 1 year (Step Functions orchestrated). GCP Cloud Functions: 60 minutes (Gen 2, HTTP). Azure Functions: 5-10 minutes (Consumption), unlimited (Premium/Dedicated). Cloudflare Workers: No duration limit but 10-50ms CPU time limit per request. For long-running processes, AWS Step Functions or Azure Durable Functions are the recommended patterns." },
  { question: "Can FaaS functions access VPC resources like RDS databases?", answer: "AWS Lambda has native VPC integration — functions can be placed in a VPC subnet to access RDS, ElastiCache, and private EC2 instances. GCP Cloud Functions supports VPC connector for accessing VPC resources. Azure Functions supports VNet integration on Premium and Dedicated plans. Cloudflare Workers does not support TCP VPC connections — use Cloudflare Tunnel + Hyperdrive for database proxy access." },
  { question: "How difficult is it to migrate between FaaS platforms?", answer: "Migrating between FaaS platforms requires effort proportional to how platform-specific your functions are. Generic HTTP handlers (JSON in/out) are the easiest to migrate. Functions using platform-specific services (Lambda → DynamoDB, GCP → Firestore, Azure → CosmosDB) require refactoring. Cloudflare Workers has unique APIs (V8 isolates model) that differ significantly. Using an abstraction layer like the Serverless Framework reduces migration effort." },
];
---

<BaseLayout
  title="FaaS Platform Selector: AWS Lambda vs GCP vs Azure vs Cloudflare"
  description="Full feature comparison of AWS Lambda, Google Cloud Functions, Azure Functions, and Cloudflare Workers. Pricing, limits, runtimes, VPC support, cold starts, and ecosystem considerations."
  tool="FaaS, AWS Lambda, Google Cloud Functions, Azure Functions, Cloudflare Workers, Serverless Platform"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"FaaS Platform Selector: AWS Lambda vs GCP vs Azure vs Cloudflare","url":"https://devplaybook.cc/tools/faas-platform-selector","description":"Full comparison of FaaS platforms: AWS Lambda vs GCP Cloud Functions vs Azure Functions vs Cloudflare Workers. Pricing, limits, runtimes, and ecosystem guide."})} />

  <h1 class="text-3xl font-bold mb-2">FaaS Platform Selector: AWS Lambda vs GCP vs Azure vs Cloudflare</h1>
  <p class="text-text-muted mb-6">Choosing a FaaS platform involves evaluating pricing, ecosystem, runtime support, cold starts, limits, and how well the platform integrates with your existing infrastructure. This guide provides a comprehensive side-by-side comparison to support your decision.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Comprehensive feature comparison table</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Pricing breakdown per platform</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Use case decision guide</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Ecosystem & integration considerations</span>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-4">Full Platform Comparison</h2>
  <div class="overflow-x-auto mb-8">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4">Feature</th>
          <th class="text-left py-2 pr-4">AWS Lambda</th>
          <th class="text-left py-2 pr-4">GCP Cloud Functions</th>
          <th class="text-left py-2 pr-4">Azure Functions</th>
          <th class="text-left py-2">Cloudflare Workers</th>
        </tr>
      </thead>
      <tbody class="text-text-muted">
        <tr class="border-b border-border"><td class="py-2 pr-4">Cold start (Node.js)</td><td class="py-2 pr-4">~200ms</td><td class="py-2 pr-4">~200ms</td><td class="py-2 pr-4">~250ms</td><td class="py-2">&lt;5ms</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Max timeout</td><td class="py-2 pr-4">15 min</td><td class="py-2 pr-4">60 min (Gen 2)</td><td class="py-2 pr-4">10 min (Consumption)</td><td class="py-2">No limit (50ms CPU)</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Max memory</td><td class="py-2 pr-4">10GB</td><td class="py-2 pr-4">32GB (Gen 2)</td><td class="py-2 pr-4">14GB (Premium)</td><td class="py-2">128MB</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Free tier (req/month)</td><td class="py-2 pr-4">1M</td><td class="py-2 pr-4">2M</td><td class="py-2 pr-4">1M</td><td class="py-2">100K/day (Free)</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Per 1M req (beyond free)</td><td class="py-2 pr-4">$0.20</td><td class="py-2 pr-4">$0.40</td><td class="py-2 pr-4">$0.20</td><td class="py-2">$0.30 (Paid plan)</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">VPC support</td><td class="py-2 pr-4">Yes (native)</td><td class="py-2 pr-4">Yes (VPC connector)</td><td class="py-2 pr-4">Yes (Premium)</td><td class="py-2">Limited (Tunnel)</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Container images</td><td class="py-2 pr-4">Yes (10GB)</td><td class="py-2 pr-4">Yes (Cloud Run)</td><td class="py-2 pr-4">Yes</td><td class="py-2">No (WASM only)</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Edge locations</td><td class="py-2 pr-4">~20 (Lambda@Edge)</td><td class="py-2 pr-4">35+ regions</td><td class="py-2 pr-4">60+ regions</td><td class="py-2">300+ PoPs</td></tr>
        <tr><td class="py-2 pr-4">Best ecosystem fit</td><td class="py-2 pr-4">AWS services</td><td class="py-2 pr-4">GCP / Firebase</td><td class="py-2 pr-4">Azure / Microsoft 365</td><td class="py-2">Cloudflare stack</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-4">Pricing Calculator: 10M Requests/Month</h2>
  <div class="overflow-x-auto mb-8">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4">Platform</th>
          <th class="text-left py-2 pr-4">Requests Cost</th>
          <th class="text-left py-2 pr-4">Duration (128MB, 100ms)</th>
          <th class="text-left py-2">Approx Total/Month</th>
        </tr>
      </thead>
      <tbody class="text-text-muted">
        <tr class="border-b border-border"><td class="py-2 pr-4">AWS Lambda</td><td class="py-2 pr-4">$1.80 (after free tier)</td><td class="py-2 pr-4">~$1.67</td><td class="py-2">~$3.47</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">GCP Cloud Functions</td><td class="py-2 pr-4">$3.20</td><td class="py-2 pr-4">~$1.80</td><td class="py-2">~$5.00</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Azure Functions</td><td class="py-2 pr-4">$1.80</td><td class="py-2 pr-4">~$1.60</td><td class="py-2">~$3.40</td></tr>
        <tr><td class="py-2 pr-4">Cloudflare Workers</td><td class="py-2 pr-4">$3.00 (Paid plan req)</td><td class="py-2 pr-4">~$0 (short CPU time)</td><td class="py-2">~$8.00 ($5 plan + req)</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-4">Use Case Decision Guide</h2>
  <pre class="bg-surface border border-border rounded-lg p-4 mb-6 overflow-x-auto text-sm"><code># Decision flowchart (simplified)

if existing_aws_infrastructure:
    → AWS Lambda (deepest ecosystem integration)

elif existing_gcp_or_firebase:
    → GCP Cloud Functions (native Firestore/BigQuery)

elif existing_azure_or_microsoft365:
    → Azure Functions (Logic Apps, Service Bus, Durable Functions)

elif edge_latency_critical and cpu_time_under_50ms:
    → Cloudflare Workers (300+ PoPs, near-zero cold start)

elif need_long_running or gpu_or_large_memory:
    → AWS Lambda (10GB RAM, 15min timeout, container support)

else:
    → AWS Lambda (largest ecosystem, most IaC tooling, best docs)</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-4">Migration Considerations</h2>
  <pre class="bg-surface border border-border rounded-lg p-4 mb-6 overflow-x-auto text-sm"><code>// Platform-agnostic handler pattern (easier migration)
// Wrap platform-specific event adapters around a core handler

// core/handler.ts (no platform dependencies)
export async function processRequest(req: &#123;
  method: string;
  path: string;
  body: unknown;
  headers: Record&#60;string, string&#62;;
&#125;): Promise&#60;&#123; status: number; body: unknown &#125;&#62; &#123;
  // Pure business logic — no AWS/GCP/Azure SDK imports
  return &#123; status: 200, body: &#123; ok: true &#125; &#125;;
&#125;

// adapters/aws.ts
export const handler = async (event: APIGatewayEvent) =&#62;
  processRequest(&#123;
    method: event.httpMethod,
    path: event.path,
    body: JSON.parse(event.body ?? '&#123;&#125;'),
    headers: event.headers ?? &#123;&#125;,
  &#125;);

// adapters/cloudflare.ts
export default &#123;
  async fetch(req: Request) &#123;
    const result = await processRequest(&#123;
      method: req.method,
      path: new URL(req.url).pathname,
      body: await req.json(),
      headers: Object.fromEntries(req.headers),
    &#125;);
    return Response.json(result.body, &#123; status: result.status &#125;);
  &#125;
&#125;;</code></pre>

  <ToolPageCta currentTool="FaaS Platform Selector" relatedTags={['aws', 'gcp', 'azure', 'cloudflare', 'serverless', 'faas']} />
  <FaqSection faq={faq} />
</BaseLayout>
