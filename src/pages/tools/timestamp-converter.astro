---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TimestampConverter from '../../components/TimestampConverter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the difference between Unix seconds and Unix milliseconds?", answer: "Unix timestamps in seconds (epoch seconds) count how many seconds have passed since January 1, 1970 UTC — they're typically 10 digits (e.g. 1711238400). JavaScript and many modern APIs use milliseconds instead, which gives a 13-digit number (e.g. 1711238400000). This converter auto-detects which you mean based on your selection, so you can convert either format." },
  { question: "What is ISO 8601 format?", answer: "ISO 8601 is the international standard for representing dates and times, for example 2024-03-24T00:00:00.000Z. The T separates the date from the time, and the Z at the end means UTC (Zulu time). Many APIs, databases, and programming languages use ISO 8601 as their default date format because it's unambiguous and sortable as a string." },
  { question: "How do I convert a date string to a Unix timestamp?", answer: "Select the format that matches your input (e.g. ISO 8601 or Local DateTime), type or paste the date string, and the converter immediately shows the equivalent Unix timestamp in seconds and milliseconds along with all other formats." },
  { question: "What is RFC 2822 / email date format?", answer: "RFC 2822 is the date format used in email headers, for example: Sun, 24 Mar 2024 00:00:00 +0000. It's also used in HTTP headers and RSS feeds. The format includes a day abbreviation, numeric date, 3-letter month, 4-digit year, time, and timezone offset." },
  { question: "Why do timestamps look different in different timezones?", answer: "A Unix timestamp always refers to the same absolute moment in time regardless of timezone — it's the number of seconds since the UTC epoch. When you display it as a human-readable date, you convert it to a specific timezone which shifts the hours (and sometimes the date). ISO 8601 with a Z suffix is always UTC, while 'Local DateTime' shows the time in your browser's timezone." },
];
---

<BaseLayout
  title="Timestamp Converter — Unix, ISO 8601, UTC, RFC 2822"
  description="Free timestamp converter. Convert between Unix timestamps (seconds & milliseconds), ISO 8601, UTC string, RFC 2822 / email format, and local datetime. Live current timestamp. Runs in your browser."
  tool="Timestamp Converter, Unix Timestamp Converter, ISO 8601 Converter, Epoch Converter, RFC 2822 Date, UTC Converter, Milliseconds to Date"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Timestamp Converter</h1>
  <p class="text-text-muted mb-4">Convert timestamps between all common formats: Unix seconds, Unix milliseconds, ISO 8601, UTC string, RFC 2822, and local datetime. See the live current timestamp and instantly convert any value to all formats at once. Runs in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 6 formats including ISO 8601 & RFC 2822</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live clock + instant conversion</span>
  </div>
  <TimestampConverter client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Timestamp Converter" relatedTags={['datetime', 'timestamp', 'epoch', 'api', 'utilities']} />
</BaseLayout>
