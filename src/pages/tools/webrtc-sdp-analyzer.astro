---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WebRTCSdpAnalyzer from '../../components/WebRTCSdpAnalyzer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is an SDP in WebRTC?",
    answer: "SDP (Session Description Protocol) is a text-based format used to negotiate media capabilities between WebRTC peers. An offer SDP describes what the caller supports (codecs, ICE candidates, DTLS fingerprint), and an answer SDP is the callee's response. Together they form the basis of the WebRTC handshake."
  },
  {
    question: "What are ICE candidates and why do they matter?",
    answer: "ICE (Interactive Connectivity Establishment) candidates are potential network paths between peers. 'host' candidates are local network addresses, 'srflx' (server-reflexive) candidates come from a STUN server and reflect your public IP, and 'relay' candidates come from a TURN server and handle cases where direct or STUN-based connections fail. More candidate types = better chances of a successful connection."
  },
  {
    question: "What does the DTLS fingerprint tell me?",
    answer: "The DTLS fingerprint (usually SHA-256) is a hash of the peer's TLS certificate. It's included in the SDP so both peers can verify each other's identity during the DTLS handshake, preventing man-in-the-middle attacks. It changes with each session as WebRTC generates self-signed certificates."
  },
  {
    question: "What is SSRC in WebRTC?",
    answer: "SSRC (Synchronization Source identifier) is a 32-bit number that uniquely identifies each media stream within an RTP session. In WebRTC, each audio or video track gets its own SSRC. When simulcast is used (multiple resolutions), you'll see multiple SSRCs per track — often grouped with SSRC-GROUP:FID for RTX (retransmission) pairing."
  },
  {
    question: "What does 'sendrecv / sendonly / recvonly' mean?",
    answer: "'sendrecv' means the peer can both send and receive media on this track. 'sendonly' means it will only send. 'recvonly' means it will only receive. 'inactive' means the track exists but no media flows. These directions are negotiated between the offer and answer."
  },
  {
    question: "What is Trickle ICE?",
    answer: "Trickle ICE is a WebRTC optimization where ICE candidates are sent incrementally as they're discovered, rather than waiting for all candidates before sending the SDP. If you see 'a=ice-options:trickle' in the SDP and few or no candidates, the candidates arrive separately via signaling. This reduces connection setup time significantly."
  },
];
---

<BaseLayout
  title="WebRTC SDP Analyzer — Parse & Visualize SDP Offer/Answer"
  description="Paste your WebRTC SDP offer or answer and instantly visualize media sections, codecs, ICE candidates, DTLS fingerprint, SSRC identifiers, and header extensions. Runs 100% in your browser."
  tool="WebRTC SDP analyzer, SDP parser, WebRTC debugger, ICE candidate viewer, SDP offer answer"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "WebRTC SDP Analyzer",
    "url": "https://devplaybook.cc/tools/webrtc-sdp-analyzer",
    "description": "Parse and visualize WebRTC SDP offer/answer. Extracts media sections, codecs, ICE candidates, DTLS fingerprint, SSRC identifiers, and RTP header extensions.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">WebRTC SDP Analyzer</h1>
  <p class="text-text-muted mb-4">
    Paste your WebRTC SDP offer or answer and instantly visualize media sections, codecs, ICE candidates,
    DTLS fingerprint, SSRC identifiers, and RTP header extensions. Useful for debugging WebRTC signaling,
    codec negotiation, and connectivity issues. Runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> ICE candidate breakdown</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Codec & SSRC visualization</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <WebRTCSdpAnalyzer client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="WebRTC SDP Analyzer" relatedTags={['webrtc', 'networking', 'debugging', 'media', 'developer-tools', 'video']} />
</BaseLayout>
