---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MarkdownToHtml from '../../components/MarkdownToHtml.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What Markdown elements are supported?", answer: "The converter handles headings (h1–h6), paragraphs, bold (**), italic (*), strikethrough (~~), inline code (`), fenced code blocks (```), links, images, unordered lists (- or *), ordered lists (1.), blockquotes (>), and horizontal rules (---)." },
  { question: "Is my Markdown content sent to any server?", answer: "No. Conversion happens entirely in your browser using JavaScript. Your content never leaves your machine — it's fully private." },
  { question: "What does the Preview tab show?", answer: "The Preview tab renders the converted HTML visually, so you can verify headings, links, and formatting look correct before copying the HTML output." },
  { question: "What is Pretty-print HTML?", answer: "When enabled, block-level tags are placed on separate lines for readability. Disable it to get compact single-line output, which is slightly smaller and preferable for inline embedding." },
  { question: "Can I convert GitHub-Flavored Markdown (GFM)?", answer: "Yes. The tool supports GFM extensions including strikethrough (~~text~~) and fenced code blocks with language labels (```js). Tables are not yet supported." },
  { question: "Why convert Markdown to HTML?", answer: "Common use cases: embedding content in CMS systems that accept HTML, copying content for email templates, generating static pages, or previewing how a README will render in a browser." },
];
---

<BaseLayout
  title="Markdown to HTML — Free Online Converter with Live Preview"
  description="Convert Markdown to clean HTML instantly. Supports headings, bold, italic, links, lists, code blocks, blockquotes, and more. Live preview included. Runs entirely in your browser."
  tool="Markdown to HTML, MD to HTML converter, convert Markdown online, markdown renderer, markdown parser"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Markdown to HTML",
    "url": "https://devplaybook.cc/tools/markdown-to-html",
    "description": "Convert Markdown to clean HTML instantly in your browser. Supports headings, code blocks, lists, links, and more. Live preview included.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Markdown to HTML</h1>
  <p class="text-text-muted mb-4">
    Paste Markdown and get clean HTML output with a live preview. Supports headings, bold, italic, links, images, lists, code blocks, blockquotes, and strikethrough. Runs entirely in your browser — nothing is sent to any server.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live HTML + preview tabs</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Pretty-print or compact output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <MarkdownToHtml client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Markdown to HTML" relatedTags={['markdown', 'html', 'converter', 'text', 'developer-tools']} />
</BaseLayout>
