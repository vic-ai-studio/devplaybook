---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RegexTesterPro from '../../components/RegexTesterPro.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const cheatsheet = [
  { cat: 'Character Classes', items: [
    { pattern: '.', desc: 'Any character except newline' },
    { pattern: '\\w', desc: 'Word character [a-zA-Z0-9_]' },
    { pattern: '\\d', desc: 'Digit [0-9]' },
    { pattern: '\\s', desc: 'Whitespace (space, tab, newline)' },
    { pattern: '\\W \\D \\S', desc: 'Negated versions of \\w \\d \\s' },
    { pattern: '[abc]', desc: 'Any of a, b, or c' },
    { pattern: '[^abc]', desc: 'Not a, b, or c' },
    { pattern: '[a-z]', desc: 'Character range a through z' },
  ]},
  { cat: 'Anchors', items: [
    { pattern: '^', desc: 'Start of string (or line in multiline mode)' },
    { pattern: '$', desc: 'End of string (or line in multiline mode)' },
    { pattern: '\\b', desc: 'Word boundary' },
    { pattern: '\\B', desc: 'Not a word boundary' },
  ]},
  { cat: 'Quantifiers', items: [
    { pattern: '*', desc: '0 or more (greedy)' },
    { pattern: '+', desc: '1 or more (greedy)' },
    { pattern: '?', desc: '0 or 1 (optional)' },
    { pattern: '{n}', desc: 'Exactly n times' },
    { pattern: '{n,}', desc: 'n or more times' },
    { pattern: '{n,m}', desc: 'Between n and m times' },
    { pattern: '*? +? ??', desc: 'Lazy/non-greedy versions' },
  ]},
  { cat: 'Groups & Lookarounds', items: [
    { pattern: '(abc)', desc: 'Capture group — accessible as $1, $2…' },
    { pattern: '(?:abc)', desc: 'Non-capturing group — groups without capturing' },
    { pattern: '(?<name>abc)', desc: 'Named capture group' },
    { pattern: '(?=abc)', desc: 'Positive lookahead — followed by abc' },
    { pattern: '(?!abc)', desc: 'Negative lookahead — not followed by abc' },
    { pattern: '(?<=abc)', desc: 'Positive lookbehind — preceded by abc' },
    { pattern: '(?<!abc)', desc: 'Negative lookbehind — not preceded by abc' },
  ]},
  { cat: 'Flags', items: [
    { pattern: 'g', desc: 'Global — find all matches, not just the first' },
    { pattern: 'i', desc: 'Case-insensitive matching' },
    { pattern: 'm', desc: 'Multiline — ^ and $ match each line' },
    { pattern: 's', desc: 'Dotall — . matches newlines too' },
    { pattern: 'u', desc: 'Unicode — enables full Unicode matching' },
    { pattern: 'd', desc: 'Indices — include match start/end index in results' },
  ]},
];

const faq = [
  { question: "What is a capture group in regex?", answer: "A capture group (abc) captures the matched substring so you can reference it later — in replace operations as $1 or backreferences as \\1. Named groups (?<name>abc) let you reference by name with $<name> or \\k<name>. Non-capturing groups (?:abc) group without capturing, useful for alternation or quantifier scope." },
  { question: "What is the difference between greedy and lazy quantifiers?", answer: "Greedy quantifiers (* + ?) match as much as possible. Lazy quantifiers (*? +? ??) match as little as possible. Example: <.+> on '<div><p></p></div>' — greedy matches the whole string, lazy matches just '<div>'. Use lazy when you want the shortest possible match." },
  { question: "When should I use a lookahead?", answer: "Use a lookahead (?=...) when you want to match only if followed by a pattern, without including that pattern in the match. Example: \\d+(?= dollars) matches the number in '100 dollars' but not in '100 euros'. Negative lookahead (?!...) does the opposite." },
  { question: "What does the 'm' flag do?", answer: "The multiline flag makes ^ and $ match the start and end of each line (separated by \\n), instead of only the start and end of the entire string. Without 'm', ^ only matches at position 0. With 'm', it matches after every newline too." },
  { question: "How do I match a literal dot or special character?", answer: "Escape special characters with a backslash: \\. for a literal dot, \\* for a literal asterisk, \\( and \\) for literal parentheses. Special regex characters that need escaping: . * + ? ^ $ { } [ ] | ( ) \\" },
];
---

<BaseLayout
  title="Advanced Regex Tester — Full Flags, Capture Groups & Cheat Sheet"
  description="Free advanced regex tester with full flag support (g, i, m, s, u, d), named capture groups, real-time match highlighting, and a complete regex cheat sheet. Runs in your browser."
  tool="advanced regex tester, regex with capture groups, regex flags tester, regex cheat sheet, named groups regex, regex lookahead tester"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Advanced Regex Tester</h1>
  <p class="text-text-muted mb-4">Test regular expressions with full flag support (g, i, m, s, u, d), capture group inspection, real-time match highlighting, and preset patterns. Scroll down for a complete regex cheat sheet.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Named capture groups</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All regex flags supported</span>
  </div>

  <RegexTesterPro client:only="preact" />

  {/* Cheat Sheet */}
  <div class="mt-10 space-y-6">
    <h2 class="text-2xl font-bold">Regex Cheat Sheet</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {cheatsheet.map((section) => (
        <div class="border border-border rounded-xl overflow-hidden">
          <div class="px-4 py-2.5 bg-bg-card border-b border-border">
            <h3 class="text-sm font-semibold text-text">{section.cat}</h3>
          </div>
          <div class="divide-y divide-border">
            {section.items.map((item) => (
              <div class="flex items-start gap-3 px-4 py-2.5">
                <code class="shrink-0 text-xs font-mono text-primary bg-primary/10 px-2 py-0.5 rounded w-32 text-center">{item.pattern}</code>
                <span class="text-xs text-text-muted">{item.desc}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Advanced Regex Tester" relatedTags={['regex', 'string', 'devtools', 'javascript', 'testing']} />
</BaseLayout>
