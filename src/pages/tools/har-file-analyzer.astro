---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HarFileAnalyzer from '../../components/HarFileAnalyzer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is a HAR file?", answer: "HAR (HTTP Archive) is a JSON-format file that records all HTTP requests and responses captured by a browser's DevTools network tab. It includes request/response headers, timings, body content, and status codes — making it ideal for performance debugging and API analysis." },
  { question: "How do I export a HAR file from Chrome or Firefox?", answer: "Open DevTools (F12), go to the Network tab, reproduce the issue, then right-click any request and choose 'Save all as HAR with content'. In Firefox, click the gear icon in the Network tab and select 'Save All as HAR'." },
  { question: "What does the timing waterfall show?", answer: "The waterfall chart shows each request's total load time as a horizontal bar relative to the slowest request in the file. Longer bars indicate slower requests. This helps you identify bottlenecks in your page load sequence." },
  { question: "Is my HAR data sent to any server?", answer: "No — all analysis runs entirely in your browser using JavaScript. Your HAR file never leaves your machine, which is important since HAR files often contain sensitive data like authentication tokens and cookies." },
  { question: "How do I filter requests by status code or content type?", answer: "Switch to the 'All' tab and use the Status and Type dropdown filters. You can filter to show only errors (4xx/5xx), only JSON responses, only images, and more." },
  { question: "What should I look for when debugging performance?", answer: "Check the 'Slowest' tab for requests taking the most time, and 'Largest' for the biggest responses. Also look at the 'Errors' tab for any failed requests. High wait times often indicate slow backend processing, while large responses suggest data over-fetching." },
];
---

<BaseLayout
  title="HAR File Analyzer — Inspect HTTP Requests, Timings & Errors"
  description="Analyze HAR files for HTTP performance. See slowest requests, largest responses, error counts, and timing waterfall. Filter by status code or type. Browser-side."
  tool="HAR Analyzer, HAR File Viewer, HTTP Archive Analysis, Network Performance Tool, HAR Inspector"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">HAR File Analyzer</h1>
  <p class="text-text-muted mb-4">Upload or paste a HAR (HTTP Archive) file to analyze all captured HTTP requests. Instantly see the <strong>slowest requests</strong>, <strong>largest responses</strong>, <strong>error count</strong>, and a <strong>timing waterfall</strong>. Filter by status code and content type. Everything runs in your browser — no data sent to any server.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Drag & drop .har files</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Timing waterfall chart</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Filter by status & content type</span>
  </div>
  <HarFileAnalyzer client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="HAR File Analyzer" relatedTags={['api', 'http', 'networking', 'performance', 'debugging']} />
</BaseLayout>
