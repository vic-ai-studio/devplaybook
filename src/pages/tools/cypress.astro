---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const installExample = `# Install Cypress as a dev dependency
npm install --save-dev cypress

# Open the Cypress interactive test runner
npx cypress open

# Run tests headlessly (for CI)
npx cypress run

# Run a specific spec file
npx cypress run --spec "cypress/e2e/login.cy.ts"

# Run against a specific browser
npx cypress run --browser firefox`;

const testExample = `// cypress/e2e/login.cy.ts
describe("Login flow", () => {
  beforeEach(() => {
    cy.visit("/login");
  });

  it("logs in with valid credentials", () => {
    cy.get('[data-testid="email"]').type("user@example.com");
    cy.get('[data-testid="password"]').type("s3cret");
    cy.get('[data-testid="submit"]').click();

    // Cypress auto-retries until the assertion passes or times out
    cy.url().should("include", "/dashboard");
    cy.contains("h1", "Dashboard").should("be.visible");
  });

  it("shows an error for wrong password", () => {
    cy.get('[data-testid="email"]').type("user@example.com");
    cy.get('[data-testid="password"]').type("wrong");
    cy.get('[data-testid="submit"]').click();

    cy.contains("Invalid credentials").should("be.visible");
  });
});`;

const networkExample = `// Intercept and stub network requests
describe("Posts page", () => {
  it("displays stubbed posts", () => {
    // Intercept GET /api/posts and return fixture data
    cy.intercept("GET", "/api/posts", { fixture: "posts.json" }).as("getPosts");

    cy.visit("/posts");
    cy.wait("@getPosts");

    cy.get('[data-testid="post-list"]').children().should("have.length", 3);
  });

  it("shows error state when API fails", () => {
    cy.intercept("GET", "/api/posts", { statusCode: 500 }).as("postsFail");

    cy.visit("/posts");
    cy.wait("@postsFail");

    cy.contains("Failed to load posts").should("be.visible");
  });
});`;

const commandExample = `// cypress/support/commands.ts — custom command for login
Cypress.Commands.add("login", (email: string, password: string) => {
  cy.session(
    [email, password],
    () => {
      cy.visit("/login");
      cy.get('[data-testid="email"]').type(email);
      cy.get('[data-testid="password"]').type(password);
      cy.get('[data-testid="submit"]').click();
      cy.url().should("include", "/dashboard");
    },
    {
      cacheAcrossSpecs: true, // reuse session across spec files
    }
  );
});

// In any test file:
beforeEach(() => {
  cy.login("admin@example.com", "adminpass");
});`;

const componentExample = `// cypress/component/Button.cy.tsx — component test
import Button from "../../src/components/Button";

describe("Button", () => {
  it("renders the label", () => {
    cy.mount(<Button label="Save" onClick={cy.stub()} />);
    cy.contains("Save").should("be.visible");
  });

  it("calls onClick when clicked", () => {
    const onClick = cy.stub().as("clickHandler");
    cy.mount(<Button label="Save" onClick={onClick} />);
    cy.get("button").click();
    cy.get("@clickHandler").should("have.been.calledOnce");
  });
});`;

const faq = [
  {
    question: "What is Cypress?",
    answer: "Cypress is a JavaScript end-to-end testing framework that runs tests inside a real browser. Unlike Selenium-based tools that run tests in a separate process, Cypress operates in the same event loop as your application, giving it direct access to DOM, network requests, and application state. It is designed for modern web applications and supports both E2E and component testing."
  },
  {
    question: "How does Cypress automatic retry work?",
    answer: "Cypress automatically retries most commands and assertions until they pass or the timeout is reached (default 4 seconds for most assertions). When you write cy.contains('Dashboard').should('be.visible'), Cypress keeps re-querying the DOM and checking the assertion on each retry cycle. This built-in retry eliminates most explicit wait calls and makes tests resilient to minor timing variations."
  },
  {
    question: "What is time-travel debugging in Cypress?",
    answer: "In the Cypress Test Runner, the command log on the left side shows every command that ran. Hovering over a command pins the DOM snapshot at that exact moment — you see exactly what the page looked like before and after each action. This time-travel capability makes it trivial to identify why a test failed without adding logging or taking screenshots manually."
  },
  {
    question: "How does cy.intercept() work for network stubbing?",
    answer: "cy.intercept() registers a network route handler that intercepts matching requests and can stub the response, modify it, or just alias it for waiting. You pass a URL pattern and optional response fixture or object. After calling cy.intercept(), alias it with .as('name') and use cy.wait('@name') to pause the test until that request completes. This is essential for testing loading states, error handling, and data-driven scenarios."
  },
  {
    question: "What is cy.session() and why should I use it?",
    answer: "cy.session() caches and restores browser session state (cookies, localStorage, sessionStorage) between tests. Instead of going through the full login UI before each test, cy.session() runs the setup once, caches the resulting session, and restores it on subsequent calls. With cacheAcrossSpecs: true, the session persists across spec files, dramatically speeding up test suites that need authentication."
  },
  {
    question: "What is Cypress Cloud (formerly Cypress Dashboard)?",
    answer: "Cypress Cloud is an optional paid service that records test runs, provides parallel test execution across multiple CI machines, stores video and screenshot artifacts, and gives a test analytics dashboard. It integrates with GitHub, GitLab, and Slack to report test status on pull requests. The free tier allows limited monthly test recordings; paid plans include more recordings, parallelization, and access controls."
  },
];
---

<BaseLayout
  title="Cypress — JavaScript End-to-End Testing Framework"
  description="Cypress is a JavaScript E2E testing framework that runs in a real browser. Features time-travel debugging, network stubbing with cy.intercept(), component testing, session caching, and Cypress Cloud."
  tool="cypress, end-to-end testing, e2e testing, javascript testing, component testing, browser testing, cy.intercept, cypress cloud"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Cypress — JavaScript End-to-End Testing Framework",
    "url": "https://devplaybook.cc/tools/cypress",
    "description": "Cypress is a JavaScript E2E testing framework running inside a real browser, featuring time-travel debugging, network stubbing, component testing, and Cypress Cloud.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Cypress</h1>
  <p class="text-text-muted mb-6">
    A JavaScript end-to-end and component testing framework that runs inside a real browser.
    Time-travel debugging, automatic retries, network stubbing with <code class="bg-bg-card px-1 rounded text-sm">cy.intercept()</code>,
    session caching, and an interactive test runner — all built in.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs in real browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Time-travel debugging</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Network stubbing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Component testing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Session caching</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript support</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Cypress?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Cypress is an open-source end-to-end testing framework for JavaScript applications. Unlike Selenium-based tools that control the browser remotely via WebDriver, Cypress runs directly inside the browser alongside your application. This architecture gives Cypress access to real DOM events, network requests, cookies, and application state — and enables the time-travel debugging experience in its interactive test runner.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    Cypress supports two modes: E2E testing (loading your full app in the browser) and component testing (mounting individual React, Vue, Angular, or Svelte components in isolation). Both use the same assertion and command API. Tests are written in JavaScript or TypeScript, and the interactive runner shows you a live DOM preview at every command step.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Time-travel debugging</strong> — hover over any command in the log to see a DOM snapshot of that exact moment</li>
    <li><strong>Automatic retry</strong> — commands and assertions auto-retry until they pass or time out, reducing flaky tests</li>
    <li><strong>cy.intercept()</strong> — intercept, stub, or spy on any network request with fixture data or dynamic responses</li>
    <li><strong>Component testing</strong> — mount and test individual components in real browser conditions (React, Vue, Angular, Svelte)</li>
    <li><strong>cy.session()</strong> — cache and restore authentication state across tests and spec files for fast, DRY test suites</li>
    <li><strong>Custom commands</strong> — extend cy with reusable commands (login, drag-and-drop, accessibility checks)</li>
    <li><strong>Cypress Cloud</strong> — optional SaaS for parallel execution, test recording, video artifacts, and PR reporting</li>
    <li><strong>Plugins ecosystem</strong> — first-class support for accessibility testing, visual regression, coverage, and more</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Installation</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={installExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Writing E2E Tests</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Tests are written with <code class="bg-bg-card px-1 rounded text-xs">describe</code> / <code class="bg-bg-card px-1 rounded text-xs">it</code> blocks using the <code class="bg-bg-card px-1 rounded text-xs">cy</code> command object. Commands chain together and execute sequentially; assertions auto-retry until they pass or time out.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={testExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Network Stubbing with cy.intercept()</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    <code class="bg-bg-card px-1 rounded text-xs">cy.intercept()</code> lets you stub API responses with fixture files or inline objects, simulate error states, and alias requests to wait for them explicitly. This makes testing loading states and error handling deterministic.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={networkExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Custom Commands and Session Caching</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Define custom commands in <code class="bg-bg-card px-1 rounded text-xs">cypress/support/commands.ts</code>. Combine them with <code class="bg-bg-card px-1 rounded text-xs">cy.session()</code> to cache authentication state across the entire test suite — login once, reuse everywhere.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={commandExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Component Testing</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Cypress component testing mounts a component in a real browser environment. Use <code class="bg-bg-card px-1 rounded text-xs">cy.mount()</code> to render the component and the same cy assertions to verify behavior — no jsdom limitations.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={componentExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Cypress vs Playwright</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">Cypress</th>
          <th class="border border-border px-3 py-2 text-left">Playwright</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2">Architecture</td><td class="border border-border px-3 py-2 text-green-400">In-browser</td><td class="border border-border px-3 py-2">Out-of-process</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Interactive runner</td><td class="border border-border px-3 py-2 text-green-400">Polished GUI</td><td class="border border-border px-3 py-2">UI mode (newer)</td></tr>
        <tr><td class="border border-border px-3 py-2">Component testing</td><td class="border border-border px-3 py-2 text-green-400">Stable</td><td class="border border-border px-3 py-2">Experimental</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">WebKit (Safari)</td><td class="border border-border px-3 py-2">Experimental</td><td class="border border-border px-3 py-2 text-green-400">Stable</td></tr>
        <tr><td class="border border-border px-3 py-2">Multi-tab support</td><td class="border border-border px-3 py-2">Limited</td><td class="border border-border px-3 py-2 text-green-400">Full</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Free parallelism</td><td class="border border-border px-3 py-2">Requires Cloud</td><td class="border border-border px-3 py-2 text-green-400">Built-in</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pros and Cons</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-green-400 mb-2">Pros</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✓ Polished interactive test runner with time-travel debugging</li>
        <li>✓ Excellent documentation and large community</li>
        <li>✓ Stable component testing for React, Vue, Angular, Svelte</li>
        <li>✓ cy.intercept() makes network stubbing intuitive</li>
        <li>✓ cy.session() dramatically speeds up authenticated test suites</li>
      </ul>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-red-400 mb-2">Cons</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✗ Parallelism requires Cypress Cloud (paid)</li>
        <li>✗ Multi-tab and multi-origin scenarios are restricted</li>
        <li>✗ Only supports JavaScript / TypeScript</li>
        <li>✗ WebKit (Safari) support is still experimental</li>
        <li>✗ Tests run in a single browser tab by design — some architectures complicate this</li>
      </ul>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="cypress" relatedTags={['testing', 'e2e', 'browser', 'javascript', 'component-testing', 'ci-cd']} />
</BaseLayout>
