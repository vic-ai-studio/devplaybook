---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is Zustand?", answer: "Zustand is a small, fast, and scalable state management library for React. Unlike Redux, it doesn't require action types, reducers, or a Provider wrapper. You define a store as a function, and components subscribe to slices of state with minimal re-renders. It works with TypeScript out of the box." },
  { question: "When should I use Zustand over useState or useReducer?", answer: "Use Zustand when state needs to be shared across multiple components that aren't in the same component tree, or when you want to avoid prop drilling. For truly local state, useState or useReducer is simpler. Zustand is ideal for global UI state (modals, themes, user sessions) or feature-level shared state." },
  { question: "What is the difference between set and get in Zustand?", answer: "set merges the new state with existing state (shallow merge by default). get lets you read the current state inside actions — useful when an action needs to derive new state from the current state. For deep updates, use immer middleware or spread manually: set(state => ({ nested: { ...state.nested, key: value } }))." },
  { question: "How does Zustand handle TypeScript?", answer: "Define your store interface separately and pass it as a generic to create: const useStore = create<StoreType>()(set => (...)). All state and actions will be fully typed. Use the StateCreator utility type when splitting stores into slices." },
  { question: "What are Zustand slices?", answer: "Slices are a pattern for splitting a large Zustand store into smaller, focused pieces. Each slice is a StateCreator function that manages a domain (e.g., auth slice, cart slice). They're combined in a single create() call. This improves organization without giving up the simplicity of a single store." },
  { question: "How do I persist Zustand state to localStorage?", answer: "Use the persist middleware: import { persist } from 'zustand/middleware'. Wrap your store function with persist(fn, { name: 'storage-key' }). By default it uses localStorage. For sessionStorage, pass { storage: createJSONStorage(() => sessionStorage) }. You can also whitelist specific keys with partialize." },
];
---

<BaseLayout
  title="Zustand Store Builder — TypeScript Zustand Store Code Generator"
  description="Visual Zustand store designer. Add state fields and actions, configure middleware (persist, immer, devtools), and generate production-ready TypeScript Zustand store code instantly."
  tool="Zustand Store Builder, Zustand Code Generator, TypeScript Zustand Store, Zustand Slice Generator, React State Management Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Zustand Store Builder</h1>
  <p class="text-text-muted mb-4">Design your Zustand store visually. Add state fields and actions, pick middleware, and generate clean TypeScript code ready to paste into your project.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript-first output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> persist / immer / devtools middleware</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Slice pattern support</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-5">
    <!-- Config Panel -->
    <div class="space-y-4">
      <!-- Store Settings -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Store Settings</h2>
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium mb-1">Store Name</label>
            <input id="store-name" type="text" value="useAppStore" placeholder="useAppStore"
              class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Interface Name</label>
            <input id="interface-name" type="text" value="AppStore" placeholder="AppStore"
              class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5">Middleware</label>
            <div class="space-y-2">
              <label class="flex items-center gap-2 text-sm cursor-pointer">
                <input type="checkbox" id="mw-devtools" class="rounded" />
                <span>devtools (Redux DevTools support)</span>
              </label>
              <label class="flex items-center gap-2 text-sm cursor-pointer">
                <input type="checkbox" id="mw-persist" class="rounded" />
                <span>persist (localStorage sync)</span>
              </label>
              <label class="flex items-center gap-2 text-sm cursor-pointer">
                <input type="checkbox" id="mw-immer" class="rounded" />
                <span>immer (mutable update syntax)</span>
              </label>
            </div>
          </div>
        </div>
      </div>

      <!-- State Fields -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-base font-semibold">State Fields</h2>
          <button id="add-field" class="text-xs bg-primary/10 text-primary border border-primary/30 rounded-lg px-3 py-1.5 hover:bg-primary/20 transition-colors">+ Add Field</button>
        </div>
        <div id="fields-list" class="space-y-2"></div>
      </div>

      <!-- Actions -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-base font-semibold">Actions</h2>
          <button id="add-action" class="text-xs bg-primary/10 text-primary border border-primary/30 rounded-lg px-3 py-1.5 hover:bg-primary/20 transition-colors">+ Add Action</button>
        </div>
        <div id="actions-list" class="space-y-2"></div>
      </div>
    </div>

    <!-- Code Output -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-base font-semibold">Generated Code</h2>
        <button id="copy-btn" class="text-xs bg-primary/10 text-primary border border-primary/30 rounded-lg px-3 py-1.5 hover:bg-primary/20 transition-colors">Copy</button>
      </div>
      <pre id="code-output" class="text-xs font-mono bg-bg-card border border-border rounded-lg p-4 overflow-auto max-h-[600px] whitespace-pre-wrap text-text-muted"></pre>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Zustand Store Builder" relatedTags={['react', 'state-management', 'typescript', 'zustand', 'frontend']} />
</BaseLayout>

<script>
  type FieldType = 'string' | 'number' | 'boolean' | 'string[]' | 'number[]' | 'object' | 'null';
  interface Field { name: string; type: FieldType; defaultVal: string; }
  interface Action { name: string; params: string; body: string; }

  const fields: Field[] = [
    { name: 'count', type: 'number', defaultVal: '0' },
    { name: 'user', type: 'string', defaultVal: "''" },
    { name: 'isLoading', type: 'boolean', defaultVal: 'false' },
  ];

  const actions: Action[] = [
    { name: 'increment', params: '', body: 'count: state.count + 1' },
    { name: 'setUser', params: 'name: string', body: 'user: name' },
    { name: 'reset', params: '', body: `count: 0, user: '', isLoading: false` },
  ];

  const typeMap: Record<string, string> = {
    string: "string", number: "number", boolean: "boolean",
    "string[]": "string[]", "number[]": "number[]", object: "Record<string, unknown>", null: "null | undefined",
  };

  const defaultMap: Record<string, string> = {
    string: "''", number: "0", boolean: "false",
    "string[]": "[]", "number[]": "[]", object: "{}", null: "null",
  };

  function renderFields() {
    const el = document.getElementById('fields-list')!;
    el.innerHTML = fields.map((f, i) => `
      <div class="flex gap-2 items-center">
        <input type="text" value="${f.name}" placeholder="fieldName"
          data-idx="${i}" data-key="name"
          class="field-input flex-1 bg-bg-card border border-border rounded-lg px-2 py-1.5 text-sm font-mono focus:outline-none focus:border-primary" />
        <select data-idx="${i}" data-key="type" class="field-input bg-bg-card border border-border rounded-lg px-2 py-1.5 text-sm focus:outline-none focus:border-primary">
          ${['string','number','boolean','string[]','number[]','object','null'].map(t =>
            `<option value="${t}" ${f.type === t ? 'selected' : ''}>${t}</option>`
          ).join('')}
        </select>
        <input type="text" value="${f.defaultVal}" placeholder="default"
          data-idx="${i}" data-key="defaultVal"
          class="field-input w-20 bg-bg-card border border-border rounded-lg px-2 py-1.5 text-sm font-mono focus:outline-none focus:border-primary" />
        <button data-del-field="${i}" class="text-red-500 hover:text-red-400 text-sm px-1">✕</button>
      </div>
    `).join('');
  }

  function renderActions() {
    const el = document.getElementById('actions-list')!;
    el.innerHTML = actions.map((a, i) => `
      <div class="border border-border rounded-lg p-3 space-y-2">
        <div class="flex gap-2 items-center">
          <input type="text" value="${a.name}" placeholder="actionName"
            data-idx="${i}" data-key="name"
            class="action-input flex-1 bg-bg-card border border-border rounded-lg px-2 py-1.5 text-sm font-mono focus:outline-none focus:border-primary" />
          <button data-del-action="${i}" class="text-red-500 hover:text-red-400 text-sm px-1">✕</button>
        </div>
        <input type="text" value="${a.params}" placeholder="param: type (optional)"
          data-idx="${i}" data-key="params"
          class="action-input w-full bg-bg-card border border-border rounded-lg px-2 py-1.5 text-sm font-mono focus:outline-none focus:border-primary" />
        <input type="text" value="${a.body}" placeholder="state update: key: value, ..."
          data-idx="${i}" data-key="body"
          class="action-input w-full bg-bg-card border border-border rounded-lg px-2 py-1.5 text-sm font-mono focus:outline-none focus:border-primary" />
      </div>
    `).join('');
  }

  function generateCode(): string {
    const storeName = (document.getElementById('store-name') as HTMLInputElement).value.trim() || 'useAppStore';
    const interfaceName = (document.getElementById('interface-name') as HTMLInputElement).value.trim() || 'AppStore';
    const usePersist = (document.getElementById('mw-persist') as HTMLInputElement).checked;
    const useImmer = (document.getElementById('mw-immer') as HTMLInputElement).checked;
    const useDevtools = (document.getElementById('mw-devtools') as HTMLInputElement).checked;

    const imports = ["import { create } from 'zustand';"];
    const mwImports: string[] = [];
    if (useDevtools) mwImports.push('devtools');
    if (usePersist) mwImports.push('persist');
    if (useImmer) mwImports.push('immer');
    if (mwImports.length) imports.push(`import { ${mwImports.join(', ')} } from 'zustand/middleware';`);

    const stateFields = fields.map(f => `  ${f.name}: ${typeMap[f.type] || f.type};`).join('\n');
    const actionDefs = actions.map(a => {
      const params = a.params ? `(${a.params})` : '()';
      return `  ${a.name}${params}: void;`;
    }).join('\n');

    const interface_ = `interface ${interfaceName} {\n${stateFields}\n${actionDefs}\n}`;

    const initialState = fields.map(f => `    ${f.name}: ${f.defaultVal || defaultMap[f.type] || 'undefined'},`).join('\n');

    const actionImpls = actions.map(a => {
      const params = a.params ? `(${a.params})` : '()';
      if (useImmer) {
        return `    ${a.name}${params} => {\n      set(state => { Object.assign(state, { ${a.body} }); });\n    },`;
      }
      return `    ${a.name}${params} => set(state => ({ ${a.body} })),`;
    }).join('\n');

    const storeBody = `(set, get) => ({\n${initialState}\n\n${actionImpls}\n  })`;

    let storeExpr = storeBody;
    if (useImmer) storeExpr = `immer(${storeExpr})`;
    if (useDevtools) storeExpr = `devtools(${storeExpr}, { name: '${storeName}' })`;
    if (usePersist) storeExpr = `persist(${storeExpr}, { name: '${storeName.toLowerCase()}-storage' })`;

    const storeDecl = `export const ${storeName} = create<${interfaceName}>()(${storeExpr});`;

    const usageFields = fields.slice(0, 2).map(f => f.name).join(', ');
    const usageAction = actions.length ? actions[0].name : 'action';
    const usage = `\n// Usage in component\nconst { ${usageFields}${usageAction ? `, ${usageAction}` : ''} } = ${storeName}();\n\n// Subscribe to a single value (prevents unnecessary re-renders)\nconst ${fields[0]?.name || 'count'} = ${storeName}(state => state.${fields[0]?.name || 'count'});`;

    return [imports.join('\n'), '', interface_, '', storeDecl, usage].join('\n');
  }

  function update() {
    const code = document.getElementById('code-output')!;
    code.textContent = generateCode();
  }

  document.getElementById('add-field')!.addEventListener('click', () => {
    fields.push({ name: `field${fields.length + 1}`, type: 'string', defaultVal: "''" });
    renderFields();
    update();
  });

  document.getElementById('add-action')!.addEventListener('click', () => {
    actions.push({ name: `action${actions.length + 1}`, params: '', body: '' });
    renderActions();
    update();
  });

  document.getElementById('fields-list')!.addEventListener('input', (e) => {
    const t = e.target as HTMLElement;
    const idx = parseInt(t.getAttribute('data-idx') || '0');
    const key = t.getAttribute('data-key') as keyof Field;
    if (key && idx >= 0 && fields[idx]) {
      (fields[idx] as any)[key] = (t as HTMLInputElement).value;
      if (key === 'type') {
        const f = fields[idx];
        if (!f.defaultVal || Object.values(defaultMap).includes(f.defaultVal)) {
          f.defaultVal = defaultMap[f.type] || "''";
          renderFields();
        }
      }
      update();
    }
  });

  document.getElementById('fields-list')!.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    const idx = t.getAttribute('data-del-field');
    if (idx !== null) { fields.splice(parseInt(idx), 1); renderFields(); update(); }
  });

  document.getElementById('actions-list')!.addEventListener('input', (e) => {
    const t = e.target as HTMLElement;
    const idx = parseInt(t.getAttribute('data-idx') || '0');
    const key = t.getAttribute('data-key') as keyof Action;
    if (key && idx >= 0 && actions[idx]) { (actions[idx] as any)[key] = (t as HTMLInputElement).value; update(); }
  });

  document.getElementById('actions-list')!.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    const idx = t.getAttribute('data-del-action');
    if (idx !== null) { actions.splice(parseInt(idx), 1); renderActions(); update(); }
  });

  document.querySelectorAll('#store-name, #interface-name, #mw-devtools, #mw-persist, #mw-immer').forEach(el => {
    el.addEventListener('input', update);
    el.addEventListener('change', update);
  });

  document.getElementById('copy-btn')!.addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('code-output')!.textContent || '');
    const btn = document.getElementById('copy-btn')!;
    btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = 'Copy', 1500);
  });

  renderFields();
  renderActions();
  update();
</script>
