---
import BaseLayout from '../../layouts/BaseLayout.astro';
import KubernetesResourceEstimator from '../../components/KubernetesResourceEstimator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the difference between CPU requests and limits?",
    answer: "Requests are what Kubernetes uses for scheduling — it guarantees that much CPU will be available. Limits are the maximum a container can use before being throttled (CPU) or killed (memory). Setting requests = limits gives you Guaranteed QoS. A common pattern is requests at 25–50% of limits for burstable workloads."
  },
  {
    question: "What units are used for CPU and memory?",
    answer: "CPU is measured in millicores (m). 1000m = 1 vCPU core. A typical Node.js app might request 100–250m. Memory is in MiB (mebibytes). 1 GiB = 1024 MiB. Set memory limits based on your app's actual heap usage plus a safety buffer."
  },
  {
    question: "How do I find out actual resource usage?",
    answer: "Use kubectl top pods --all-namespaces to see live CPU and memory usage. For historical data, check Prometheus + Grafana or your cloud provider's container insights. Always base your requests on measured p95 usage, not guesses."
  },
  {
    question: "What is a ResourceQuota and should I use one?",
    answer: "A ResourceQuota limits total resource consumption within a namespace. It prevents runaway pods from consuming all cluster resources and enforces fair usage between teams. It's strongly recommended for multi-tenant clusters or any production namespace. The quota this tool generates includes a 20% buffer above your workload totals."
  },
  {
    question: "What is QoS class in Kubernetes?",
    answer: "Kubernetes assigns each pod a Quality of Service class: Guaranteed (requests = limits), Burstable (requests < limits), or BestEffort (no requests/limits). Guaranteed pods are the last to be evicted under memory pressure. Use Guaranteed for critical services like databases."
  },
  {
    question: "How much extra capacity should I provision on nodes?",
    answer: "Reserve 10–20% for system components (kube-system, monitoring DaemonSets). Add another buffer for peak traffic bursts. A common rule: size nodes so that workloads use 60–70% of total node capacity at steady state, leaving room for rolling updates and traffic spikes."
  },
];
---

<BaseLayout
  title="Kubernetes Resource Estimator — Calculate Pod CPU & Memory Requirements"
  description="Estimate total Kubernetes cluster resource requirements for your workloads. Input pods, replicas, CPU and memory requests/limits to get total cluster needs, requests vs limits analysis, and a ready-to-use ResourceQuota YAML. Free browser-based K8s tool."
  tool="Kubernetes resource estimator, K8s resource calculator, pod resource calculator, Kubernetes CPU memory estimator, namespace quota generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Kubernetes Resource Estimator",
    "url": "https://devplaybook.cc/tools/kubernetes-resource-estimator",
    "description": "Calculate total Kubernetes cluster CPU and memory requirements from your workload list. Generates ResourceQuota and Deployment YAML snippets. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Kubernetes Resource Estimator</h1>
  <p class="text-text-muted mb-4">
    Add your workloads with replicas, CPU, and memory requests/limits to estimate total cluster resource requirements.
    Get a requests-vs-limits analysis, namespace <code class="font-mono bg-surface px-1 rounded text-sm">ResourceQuota</code>,
    and per-workload Deployment YAML — ready to copy.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multi-workload calculator</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> ResourceQuota YAML output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Deployment YAML per workload</span>
  </div>
  <KubernetesResourceEstimator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Kubernetes Resource Estimator" relatedTags={['kubernetes', 'k8s', 'devops', 'cloud', 'infrastructure', 'containers', 'docker']} />
</BaseLayout>
