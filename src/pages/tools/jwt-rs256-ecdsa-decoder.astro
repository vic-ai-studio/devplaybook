---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JwtRs256EcdsaDecoder from '../../components/JwtRs256EcdsaDecoder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the difference between RS256 and HS256?",
    answer: "HS256 (HMAC-SHA256) uses a single shared secret key for both signing and verifying tokens — anyone who can verify a token can also create one. RS256 (RSA-SHA256) uses a public/private key pair: the server signs with its private key, and any consumer can verify with the public key without being able to forge tokens. RS256 is preferred for distributed systems, third-party integrations, and zero-trust architectures where you cannot share a secret."
  },
  {
    question: "What is ECDSA and why use ES256 instead of RS256?",
    answer: "ECDSA (Elliptic Curve Digital Signature Algorithm) uses elliptic curve cryptography instead of RSA. ES256 (ECDSA with P-256 and SHA-256) produces signatures roughly 7x smaller than RS256 (64 bytes vs ~256 bytes) while offering equivalent security with much shorter keys (256-bit vs 2048-bit). ES256 is faster to sign and verify, making it ideal for mobile apps, IoT devices, and high-throughput APIs. The tradeoff is slightly more complex key management."
  },
  {
    question: "How do I get my public key in the right PEM format for verification?",
    answer: "You need the key in SPKI (SubjectPublicKeyInfo) PEM format. For RSA: export from your key pair with 'openssl rsa -in private.pem -pubout -out public.pem'. For EC keys: 'openssl ec -in private.pem -pubout -out public.pem'. If you have a JWK (JSON Web Key) from a JWKS endpoint, convert it using a library like 'jose' (Node.js): 'import { exportSPKI } from \"jose\"; const spki = await exportSPKI(key)'. The PEM should start with '-----BEGIN PUBLIC KEY-----'."
  },
  {
    question: "What do JWT standard claims mean (iss, sub, aud, exp, iat, nbf, jti)?",
    answer: "These are defined in RFC 7519: 'iss' (issuer) identifies who created the token; 'sub' (subject) identifies who the token is about; 'aud' (audience) specifies the intended recipient; 'exp' (expiration) is a Unix timestamp after which the token must be rejected; 'iat' (issued at) is when the token was created; 'nbf' (not before) means the token cannot be used before this time; 'jti' (JWT ID) is a unique identifier to prevent replay attacks. All timestamps are in Unix epoch seconds, not milliseconds."
  },
  {
    question: "What is the difference between JWK and PEM, and how do I convert between them?",
    answer: "PEM (Privacy Enhanced Mail) is a base64-encoded DER format — the format you see with '-----BEGIN PUBLIC KEY-----' headers. JWK (JSON Web Key) is a JSON representation of the same key material, used in JWKS endpoints for automatic key discovery. To convert JWK to PEM in Node.js: 'const { createPublicKey } = require(\"crypto\"); const key = createPublicKey({ key: jwk, format: \"jwk\" }); const pem = key.export({ format: \"pem\", type: \"spki\" });'. The jose library also provides 'importJWK' and 'exportSPKI' helpers."
  },
  {
    question: "When should I use PS256 instead of RS256?",
    answer: "PS256 (RSA-PSS with SHA-256) uses probabilistic padding (PSS) instead of the deterministic PKCS#1 v1.5 padding used by RS256. PSS is cryptographically stronger and resistant to certain padding oracle attacks. The OpenID Connect specification recommends PS256 over RS256 for new implementations. If you have a choice and your platform supports it (all modern browsers and Node.js 12+ do via SubtleCrypto), prefer PS256 or ES256 over RS256. The key format is identical — the same RSA key pair works for both RS256 and PS256."
  }
];
---

<BaseLayout
  title="JWT RS256/ECDSA Decoder — Verify Asymmetric JWT Signatures"
  description="Decode and verify JWT tokens signed with RS256, RS384, RS512, ES256, ES384, ES512, and PS algorithms. Paste your public key to verify the signature using Web Crypto API. Free, runs in browser."
  tool="JWT RS256 decoder, JWT ECDSA decoder, asymmetric JWT, verify JWT signature, RS256 public key, ES256 verify, PS256 JWT, JSON Web Token, SPKI PEM"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "JWT RS256 / ECDSA Decoder",
    "url": "https://devplaybook.cc/tools/jwt-rs256-ecdsa-decoder",
    "description": "Decode and verify JWT tokens using asymmetric algorithms: RS256, RS384, RS512, ES256, ES384, ES512, PS256, PS384, PS512. Paste a PEM public key to verify signatures using SubtleCrypto in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">JWT RS256 / ECDSA Decoder</h1>
  <p class="text-text-muted mb-4">Decode and verify JWT tokens signed with asymmetric algorithms — RS256, RS384, RS512, ES256, ES384, ES512, PS256, PS384, PS512. Inspect all claims with human-readable timestamps. Paste your PEM public key to cryptographically verify the signature using the Web Crypto API. All processing runs locally in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> RS256, ES256, PS256 + all variants</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Verify signature with PEM public key</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Standard claims with readable timestamps</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100% in-browser, no data sent anywhere</span>
  </div>

  <JwtRs256EcdsaDecoder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="JWT RS256 / ECDSA Decoder" relatedTags={['jwt', 'security', 'authentication', 'rsa', 'ecdsa', 'cryptography']} />
</BaseLayout>
