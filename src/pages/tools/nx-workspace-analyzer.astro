---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NxWorkspaceAnalyzer from '../../components/NxWorkspaceAnalyzer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Nx and what problem does it solve?",
    answer: "Nx is a build system and monorepo toolkit that makes large-scale JavaScript/TypeScript projects manageable. It provides task scheduling with caching, affected command detection (only test/build what changed), project graph visualization, code generators, and plugins for React, Next.js, Angular, NestJS, and more. Unlike Turborepo which is purely a task runner, Nx is a full-featured development platform with generators, executors, and a rich plugin ecosystem."
  },
  {
    question: "What is cacheableOperations in Nx?",
    answer: "cacheableOperations lists the task targets that Nx should cache. When you run `nx run my-app:build`, Nx hashes the inputs (source files, dependencies, config) and checks the local or Nx Cloud cache. On a hit, it replays the cached output in milliseconds. Set cacheableOperations to tasks that are deterministic: build, test, lint, typecheck, storybook:build. Do NOT cache dev servers or tasks with side effects like database migrations."
  },
  {
    question: "How does nx affected work?",
    answer: "`nx affected --target=test` runs the test target only for projects that have changed compared to the base branch. Nx traces the project dependency graph to also include any project that depends on a changed project. The base branch is configured via `affected.defaultBase` in nx.json (usually 'main'). In CI, you can override with `--base=origin/main --head=HEAD`. This is the primary way Nx speeds up CI — skipping unchanged projects entirely."
  },
  {
    question: "What is the difference between targetDefaults and project-level targets?",
    answer: "targetDefaults in nx.json applies to all projects in the workspace as a default configuration for each target. For example, setting `targetDefaults.build.dependsOn = [\"^build\"]` means every project's build waits for its dependencies to build first. Individual projects can override these defaults in their own project.json. targetDefaults is useful for workspace-wide conventions like caching strategy and dependency ordering without repeating config in every project."
  },
  {
    question: "What are namedInputs in Nx?",
    answer: "namedInputs are reusable sets of file patterns used to define what files affect a task's cache. The 'default' input typically includes all project files plus shared globals. The 'production' input excludes test files and test setup, so changing test files doesn't invalidate production build cache. Reference them in targetDefaults: `inputs: ['production', '^production']` means use 'production' files from this project and all upstream projects. This fine-grained control prevents unnecessary cache misses."
  },
  {
    question: "Should I use Nx or Turborepo for my monorepo?",
    answer: "Choose Turborepo if: you want a lightweight task runner that's easy to adopt incrementally, you're mainly focused on build speed, and you don't need code generators. Choose Nx if: you want a full development platform with generators, executors, project graph visualization, and a plugin ecosystem. Nx scales better for large teams and complex projects. Turborepo has a simpler mental model. Both support any framework and can be adopted incrementally. For a new greenfield monorepo with a large team, Nx is generally the stronger choice."
  },
];
---

<BaseLayout
  title="Nx Workspace Analyzer — nx.json Config Generator & Validator"
  description="Analyze and generate nx.json configs for your Nx monorepo. Validate existing configs, detect missing caching settings, and generate preset configurations for React, Node, and full-stack workspaces."
  tool="nx workspace analyzer, nx.json generator, nx monorepo config, nx caching, nx affected, nx workspace setup"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Nx Workspace Analyzer",
    "url": "https://devplaybook.cc/tools/nx-workspace-analyzer",
    "description": "Generate and validate nx.json configs. Choose presets for React+Node, full-stack, or minimal setups. Analyze existing nx.json for missing cache settings and configuration issues.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Nx Workspace Analyzer</h1>
  <p class="text-text-muted mb-4">
    Generate and validate <strong>nx.json configurations</strong> for your Nx monorepo. Choose from preset templates (React+Node, full-stack, minimal), or paste your existing <code class="font-mono text-sm">nx.json</code> to detect missing caching settings, affected config, and target defaults.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 3 preset templates</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Config validation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Affected & cache analysis</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-ready nx.json</span>
  </div>
  <NxWorkspaceAnalyzer client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Nx Workspace Analyzer" relatedTags={['monorepo', 'nx', 'build', 'devops', 'cicd', 'javascript']} />
</BaseLayout>
