---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What are Core Web Vitals?", answer: "Core Web Vitals are three user-centric performance metrics used by Google as ranking signals: LCP (Largest Contentful Paint) measures how fast the main content loads, INP (Interaction to Next Paint) measures responsiveness to user interactions, and CLS (Cumulative Layout Shift) measures visual stability. Google updated CWV in March 2024, replacing FID with INP." },
  { question: "What are the Good, Needs Improvement, and Poor thresholds?", answer: "LCP: Good ≤ 2.5s, Needs Improvement 2.5–4.0s, Poor > 4.0s. INP: Good ≤ 200ms, Needs Improvement 200–500ms, Poor > 500ms. CLS: Good ≤ 0.1, Needs Improvement 0.1–0.25, Poor > 0.25. FCP: Good ≤ 1.8s, Needs Improvement 1.8–3s, Poor > 3s. TTFB: Good ≤ 0.8s, Needs Improvement 0.8–1.8s, Poor > 1.8s." },
  { question: "What replaced FID in Core Web Vitals?", answer: "INP (Interaction to Next Paint) replaced FID (First Input Delay) as an official Core Web Vital in March 2024. FID only measured the delay before the browser started processing the first interaction. INP measures the full input latency — from user interaction through rendering — for all interactions on the page, giving a more accurate picture of responsiveness." },
  { question: "How do I measure my site's Core Web Vitals?", answer: "Field data (real users): Google Search Console Core Web Vitals report, Chrome User Experience Report (CrUX), and the web-vitals.js library. Lab data (simulated): Chrome DevTools Lighthouse, PageSpeed Insights, WebPageTest. Important: Google uses field data (CrUX) for search ranking, not lab data. Lab data is for debugging — field data shows what real users experience." },
  { question: "How do I fix a poor LCP score?", answer: "LCP is usually the hero image or largest text block. Fixes: (1) Preload the LCP element with <link rel='preload'>. (2) Use a CDN to serve images close to users. (3) Optimize image formats — use WebP/AVIF with proper sizing. (4) Eliminate render-blocking resources (defer non-critical JS/CSS). (5) Use HTTP/2 or HTTP/3. (6) Enable compression (gzip/brotli). Target: LCP should load within the first 2.5 seconds of page start." },
  { question: "How do I reduce CLS?", answer: "CLS (layout shift) is caused by elements that move after initial render. Common fixes: (1) Always specify width and height attributes on images and videos. (2) Reserve space for ads and embeds with CSS aspect-ratio. (3) Avoid inserting content above existing content. (4) Use font-display: optional or preload fonts to avoid FOIT/FOUT. (5) Animate with transform and opacity instead of properties that trigger layout (margin, height, top)." },
];
---

<BaseLayout
  title="Core Web Vitals Calculator — LCP, INP, CLS Score & Grade"
  description="Enter your LCP, INP, and CLS scores to get an instant pass/fail grade with color-coded results and improvement recommendations. Includes FCP and TTFB. Free browser tool."
  tool="Core Web Vitals calculator, LCP INP CLS grade, web performance score, Google ranking signals, page speed checker"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Core Web Vitals Calculator",
    "url": "https://devplaybook.cc/tools/cwv-calculator",
    "description": "Enter LCP, INP, CLS, FCP, and TTFB scores to get instant pass/fail grades with color-coded results and optimization tips.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Core Web Vitals Calculator</h1>
  <p class="text-text-muted mb-4">
    Enter your <strong>LCP</strong>, <strong>INP</strong>, and <strong>CLS</strong> values to get an instant pass/fail grade. Color-coded results show exactly where you stand against Google's thresholds. Also supports FCP and TTFB. All calculations run in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> LCP, INP, CLS (+ FCP, TTFB)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Good / Needs Improvement / Poor thresholds</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Overall grade + optimization tips</span>
  </div>

  <!-- Calculator -->
  <div class="bg-bg-card border border-border rounded-xl p-6 mb-6">
    <h2 class="font-semibold text-base mb-4">Enter Your Metrics</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">

      <!-- LCP -->
      <div>
        <label class="block text-sm font-medium mb-1" for="lcp-input">
          LCP — Largest Contentful Paint
          <span class="text-text-muted font-normal">(seconds)</span>
        </label>
        <input id="lcp-input" type="number" step="0.01" min="0" placeholder="e.g. 2.1"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/50" />
        <div id="lcp-badge" class="mt-1 text-xs font-medium hidden"></div>
      </div>

      <!-- INP -->
      <div>
        <label class="block text-sm font-medium mb-1" for="inp-input">
          INP — Interaction to Next Paint
          <span class="text-text-muted font-normal">(milliseconds)</span>
        </label>
        <input id="inp-input" type="number" step="1" min="0" placeholder="e.g. 150"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/50" />
        <div id="inp-badge" class="mt-1 text-xs font-medium hidden"></div>
      </div>

      <!-- CLS -->
      <div>
        <label class="block text-sm font-medium mb-1" for="cls-input">
          CLS — Cumulative Layout Shift
          <span class="text-text-muted font-normal">(score, no unit)</span>
        </label>
        <input id="cls-input" type="number" step="0.001" min="0" placeholder="e.g. 0.05"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/50" />
        <div id="cls-badge" class="mt-1 text-xs font-medium hidden"></div>
      </div>

      <!-- FCP -->
      <div>
        <label class="block text-sm font-medium mb-1" for="fcp-input">
          FCP — First Contentful Paint
          <span class="text-text-muted font-normal">(seconds, optional)</span>
        </label>
        <input id="fcp-input" type="number" step="0.01" min="0" placeholder="e.g. 1.2"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/50" />
        <div id="fcp-badge" class="mt-1 text-xs font-medium hidden"></div>
      </div>

      <!-- TTFB -->
      <div>
        <label class="block text-sm font-medium mb-1" for="ttfb-input">
          TTFB — Time to First Byte
          <span class="text-text-muted font-normal">(seconds, optional)</span>
        </label>
        <input id="ttfb-input" type="number" step="0.001" min="0" placeholder="e.g. 0.4"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/50" />
        <div id="ttfb-badge" class="mt-1 text-xs font-medium hidden"></div>
      </div>

    </div>

    <div class="flex gap-3">
      <button id="calculate-btn"
        class="bg-primary text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors">
        Calculate Score
      </button>
      <button id="load-example-btn"
        class="text-sm text-primary hover:underline">
        Load example values
      </button>
    </div>
  </div>

  <!-- Results -->
  <div id="results" class="hidden">
    <!-- Overall Grade -->
    <div id="overall-grade" class="rounded-xl border p-6 mb-6 text-center">
      <div class="text-5xl font-bold mb-2" id="grade-letter">A</div>
      <div class="text-lg font-semibold mb-1" id="grade-label">Excellent</div>
      <div class="text-sm text-text-muted" id="grade-desc"></div>
    </div>

    <!-- Metric Breakdown -->
    <div class="bg-bg-card border border-border rounded-xl p-6 mb-6">
      <h2 class="font-semibold text-base mb-4">Metric Breakdown</h2>
      <div class="space-y-4" id="metric-breakdown"></div>
    </div>

    <!-- Tips -->
    <div id="tips-section" class="bg-bg-card border border-border rounded-xl p-6 mb-6 hidden">
      <h2 class="font-semibold text-base mb-3">Optimization Tips</h2>
      <ul class="space-y-2 text-sm" id="tips-list"></ul>
    </div>

    <!-- Thresholds Reference -->
    <div class="bg-bg-card border border-border rounded-xl p-6 mb-6">
      <h2 class="font-semibold text-base mb-3">Google Thresholds Reference</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border">
              <th class="text-left py-2 pr-4 font-medium text-text-muted">Metric</th>
              <th class="text-left py-2 pr-4 font-medium text-green-500">✓ Good</th>
              <th class="text-left py-2 pr-4 font-medium text-yellow-500">⚠ Needs Work</th>
              <th class="text-left py-2 font-medium text-red-500">✗ Poor</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <tr><td class="py-2 pr-4 font-mono">LCP</td><td class="py-2 pr-4 text-green-500">≤ 2.5s</td><td class="py-2 pr-4 text-yellow-500">2.5–4.0s</td><td class="py-2 text-red-500">&gt; 4.0s</td></tr>
            <tr><td class="py-2 pr-4 font-mono">INP</td><td class="py-2 pr-4 text-green-500">≤ 200ms</td><td class="py-2 pr-4 text-yellow-500">200–500ms</td><td class="py-2 text-red-500">&gt; 500ms</td></tr>
            <tr><td class="py-2 pr-4 font-mono">CLS</td><td class="py-2 pr-4 text-green-500">≤ 0.1</td><td class="py-2 pr-4 text-yellow-500">0.1–0.25</td><td class="py-2 text-red-500">&gt; 0.25</td></tr>
            <tr><td class="py-2 pr-4 font-mono">FCP</td><td class="py-2 pr-4 text-green-500">≤ 1.8s</td><td class="py-2 pr-4 text-yellow-500">1.8–3.0s</td><td class="py-2 text-red-500">&gt; 3.0s</td></tr>
            <tr><td class="py-2 pr-4 font-mono">TTFB</td><td class="py-2 pr-4 text-green-500">≤ 0.8s</td><td class="py-2 pr-4 text-yellow-500">0.8–1.8s</td><td class="py-2 text-red-500">&gt; 1.8s</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  const METRICS = {
    lcp:  { label: 'LCP', unit: 's', good: 2.5, poor: 4.0,
            tips: {
              poor: 'LCP > 4s: Preload the hero image with <link rel="preload">, use a CDN, convert to WebP/AVIF, and eliminate render-blocking resources.',
              needs: 'LCP 2.5–4s: Optimize server response time (TTFB), preload critical resources, and ensure the LCP image is not lazy-loaded.'
            }},
    inp:  { label: 'INP', unit: 'ms', good: 200, poor: 500,
            tips: {
              poor: 'INP > 500ms: Break up long JavaScript tasks (> 50ms) with scheduler.yield() or setTimeout. Reduce third-party scripts.',
              needs: 'INP 200–500ms: Profile interactions in DevTools Performance panel. Defer non-critical JS and reduce event handler complexity.'
            }},
    cls:  { label: 'CLS', unit: '', good: 0.1, poor: 0.25,
            tips: {
              poor: 'CLS > 0.25: Always set width/height on images and videos. Reserve space for ads. Avoid inserting content above existing content.',
              needs: 'CLS 0.1–0.25: Use aspect-ratio CSS for media, preload fonts with font-display: optional, and avoid animations that cause layout shifts.'
            }},
    fcp:  { label: 'FCP', unit: 's', good: 1.8, poor: 3.0,
            tips: {
              poor: 'FCP > 3s: Eliminate render-blocking scripts/styles, inline critical CSS, and reduce server response time.',
              needs: 'FCP 1.8–3s: Preconnect to critical origins, defer non-critical CSS, and minimize main-thread blocking.'
            }},
    ttfb: { label: 'TTFB', unit: 's', good: 0.8, poor: 1.8,
            tips: {
              poor: 'TTFB > 1.8s: Use a CDN, enable server-side caching, optimize database queries, and consider edge computing.',
              needs: 'TTFB 0.8–1.8s: Enable HTTP caching, use compression (gzip/brotli), and reduce server processing time.'
            }},
  };

  function getStatus(metric, value) {
    if (value <= metric.good) return 'good';
    if (value <= metric.poor) return 'needs';
    return 'poor';
  }

  function statusLabel(s) {
    return s === 'good' ? '✓ Good' : s === 'needs' ? '⚠ Needs Improvement' : '✗ Poor';
  }

  function statusColor(s) {
    return s === 'good' ? 'text-green-500' : s === 'needs' ? 'text-yellow-500' : 'text-red-500';
  }

  function statusBg(s) {
    return s === 'good' ? 'bg-green-500/10 border-green-500/30' : s === 'needs' ? 'bg-yellow-500/10 border-yellow-500/30' : 'bg-red-500/10 border-red-500/30';
  }

  function calculate() {
    const vals = {};
    let coreCount = 0, corePass = 0, hasCoreData = false;
    const tips = [];

    ['lcp', 'inp', 'cls', 'fcp', 'ttfb'].forEach(key => {
      const raw = document.getElementById(key + '-input').value;
      if (raw === '') { vals[key] = null; return; }
      vals[key] = parseFloat(raw);
    });

    // Show per-metric badges on inputs
    ['lcp', 'inp', 'cls', 'fcp', 'ttfb'].forEach(key => {
      const badge = document.getElementById(key + '-badge');
      if (vals[key] === null) { badge.className = 'mt-1 text-xs font-medium hidden'; return; }
      const s = getStatus(METRICS[key], vals[key]);
      badge.textContent = statusLabel(s);
      badge.className = `mt-1 text-xs font-medium ${statusColor(s)}`;
      badge.classList.remove('hidden');
    });

    // Check core 3
    ['lcp', 'inp', 'cls'].forEach(key => {
      if (vals[key] !== null) {
        hasCoreData = true;
        coreCount++;
        if (getStatus(METRICS[key], vals[key]) === 'good') corePass++;
      }
    });

    if (!hasCoreData) {
      alert('Please enter at least one Core Web Vital (LCP, INP, or CLS).');
      return;
    }

    // Overall grade
    const passRate = coreCount > 0 ? corePass / coreCount : 0;
    let grade, gradeLabel, gradeDesc, gradeBg;
    if (passRate === 1) {
      grade = 'A'; gradeLabel = 'All Core Web Vitals Pass';
      gradeDesc = 'Your page meets Google\'s "Good" thresholds for all measured Core Web Vitals.';
      gradeBg = 'bg-green-500/10 border-green-500/30';
    } else if (passRate >= 0.67) {
      grade = 'B'; gradeLabel = 'Mostly Good';
      gradeDesc = 'Most Core Web Vitals pass. Fix the flagged metric(s) to achieve full compliance.';
      gradeBg = 'bg-yellow-500/10 border-yellow-500/30';
    } else if (passRate >= 0.33) {
      grade = 'C'; gradeLabel = 'Needs Improvement';
      gradeDesc = 'Several Core Web Vitals are below Google\'s "Good" threshold. Optimization needed.';
      gradeBg = 'bg-orange-500/10 border-orange-500/30';
    } else {
      grade = 'D'; gradeLabel = 'Poor Performance';
      gradeDesc = 'Core Web Vitals are in the "Poor" range. This may negatively impact search rankings.';
      gradeBg = 'bg-red-500/10 border-red-500/30';
    }

    const gradeEl = document.getElementById('overall-grade');
    gradeEl.className = `rounded-xl border p-6 mb-6 text-center ${gradeBg}`;
    document.getElementById('grade-letter').textContent = grade;
    document.getElementById('grade-label').textContent = gradeLabel;
    document.getElementById('grade-desc').textContent = gradeDesc;

    // Metric breakdown
    const breakdown = document.getElementById('metric-breakdown');
    breakdown.innerHTML = '';
    ['lcp', 'inp', 'cls', 'fcp', 'ttfb'].forEach(key => {
      if (vals[key] === null) return;
      const m = METRICS[key];
      const s = getStatus(m, vals[key]);
      const label = statusLabel(s);
      const barW = Math.min(100, (vals[key] / (m.poor * 1.5)) * 100);

      breakdown.innerHTML += `
        <div>
          <div class="flex items-center justify-between mb-1">
            <span class="text-sm font-medium">${m.label}</span>
            <span class="text-sm font-mono ${statusColor(s)}">${vals[key]}${m.unit} — <span class="font-medium">${label}</span></span>
          </div>
          <div class="h-2 bg-border rounded-full overflow-hidden">
            <div class="h-full rounded-full transition-all ${s === 'good' ? 'bg-green-500' : s === 'needs' ? 'bg-yellow-500' : 'bg-red-500'}"
              style="width: ${barW}%"></div>
          </div>
        </div>`;

      if (s !== 'good' && m.tips[s]) tips.push(m.tips[s]);
    });

    // Tips
    const tipsSection = document.getElementById('tips-section');
    const tipsList = document.getElementById('tips-list');
    if (tips.length > 0) {
      tipsList.innerHTML = tips.map(t => `<li class="flex gap-2"><span class="text-yellow-500 mt-0.5 shrink-0">→</span><span>${t}</span></li>`).join('');
      tipsSection.classList.remove('hidden');
    } else {
      tipsSection.classList.add('hidden');
    }

    document.getElementById('results').classList.remove('hidden');
  }

  document.getElementById('calculate-btn').addEventListener('click', calculate);

  document.getElementById('load-example-btn').addEventListener('click', () => {
    document.getElementById('lcp-input').value = '2.8';
    document.getElementById('inp-input').value = '180';
    document.getElementById('cls-input').value = '0.15';
    document.getElementById('fcp-input').value = '1.6';
    document.getElementById('ttfb-input').value = '0.6';
  });

  ['lcp', 'inp', 'cls', 'fcp', 'ttfb'].forEach(key => {
    document.getElementById(key + '-input').addEventListener('keydown', e => {
      if (e.key === 'Enter') calculate();
    });
  });
</script>

<FaqSection faq={faq} />
<ToolPageCta currentTool="Core Web Vitals Calculator" relatedTags={['performance', 'web-vitals', 'seo', 'optimization', 'developer-tools']} />
