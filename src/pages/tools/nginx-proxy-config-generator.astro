---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NginxProxyConfigGenerator from '../../components/NginxProxyConfigGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is an Nginx reverse proxy and when do I need one?",
    answer: "A reverse proxy sits in front of your backend server (Node.js, Python, Go, etc.) and forwards client requests to it. You need one when: running multiple apps on one server (route by domain/path), adding SSL/TLS termination without modifying your app, hiding the backend port and implementation, adding rate limiting/security headers at the edge, or enabling WebSocket connections with proper upgrade headers."
  },
  {
    question: "How do I proxy a Node.js app on port 3000?",
    answer: "Set Upstream URL to http://127.0.0.1:3000 and Server Name to your domain. Nginx listens on port 80 (or 443 with SSL) and forwards all requests to your Node app. Add proxy_set_header X-Forwarded-For to make the real client IP available via req.headers['x-forwarded-for'] in your Node app. Also set proxy_buffering off for streaming/SSE responses."
  },
  {
    question: "How do I enable WebSocket support with Nginx?",
    answer: "WebSocket connections require the Upgrade header to be passed through. Check 'WebSocket Support' in this tool — it adds: proxy_http_version 1.1; proxy_set_header Upgrade $http_upgrade; proxy_set_header Connection 'upgrade'; Without these, the WebSocket handshake fails with a 400 or 502 error. This works for socket.io, ws, and any WS-based protocol."
  },
  {
    question: "What is the proxy_read_timeout and when should I increase it?",
    answer: "proxy_read_timeout defines how long Nginx waits for a response from the upstream server before returning 504 Gateway Timeout. Default is 60s. Increase it for: long-running API endpoints, file uploads, AI inference, report generation, or any operation that takes more than a minute. Set it to the maximum expected response time plus a buffer. Never set it below your upstream's processing time."
  },
  {
    question: "How does CORS work at the Nginx level?",
    answer: "CORS (Cross-Origin Resource Sharing) headers tell browsers whether a cross-origin request is allowed. Nginx can add these headers before the response reaches the client. This is useful when your backend doesn't handle CORS itself or when you want to centralize CORS policy. The Access-Control-Allow-Origin header specifies which origins are allowed — use * for any origin or a specific domain for tighter security."
  },
  {
    question: "How do I add SSL/TLS to my Nginx proxy?",
    answer: "The easiest way is Let's Encrypt: install certbot, run 'sudo certbot --nginx -d yourdomain.com'. Certbot auto-configures SSL in your nginx.conf. Alternatively, enable SSL in this generator and provide your certificate paths. The config will add an HTTP→HTTPS redirect block, TLSv1.2/1.3, and modern cipher suites. After applying, run 'sudo nginx -t' then 'sudo systemctl reload nginx'."
  },
];
---

<BaseLayout
  title="Nginx Reverse Proxy Config Generator — WebSocket, SSL, CORS, Rate Limiting"
  description="Generate production-ready Nginx reverse proxy configurations. Options for WebSocket support, SSL/TLS, CORS headers, gzip compression, security headers, caching, rate limiting, and HSTS. Copy-ready nginx.conf output."
  tool="nginx reverse proxy config generator, nginx proxy config, nginx WebSocket proxy, nginx SSL proxy, nginx CORS config, nginx rate limiting"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Nginx Reverse Proxy Config Generator",
    "url": "https://devplaybook.cc/tools/nginx-proxy-config-generator",
    "description": "Generate production-ready Nginx reverse proxy server blocks. Supports WebSocket, SSL/TLS, CORS, gzip, security headers, cache, and rate limiting.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Nginx Reverse Proxy Config Generator</h1>
  <p class="text-text-muted mb-4">
    Generate a production-ready Nginx reverse proxy configuration for your backend app. Configure WebSocket support, SSL/TLS, CORS, rate limiting, cache headers, and security headers — then copy the result directly into your server.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> WebSocket + SSL/TLS</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CORS + Security headers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Rate limiting + Gzip</span>
  </div>
  <NginxProxyConfigGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Nginx Reverse Proxy Config Generator" relatedTags={['nginx', 'devops', 'server', 'ssl', 'proxy', 'web-server']} />
</BaseLayout>
