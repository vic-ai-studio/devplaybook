---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CssBoxShadowGenerator from '../../components/CssBoxShadowGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is CSS box-shadow?", answer: "The CSS box-shadow property adds shadow effects around an element's frame. It accepts one or more shadow layers, each defined by: horizontal offset (X), vertical offset (Y), blur radius, spread radius, color, and an optional 'inset' keyword. Multiple shadows create layered effects and can be combined for depth and glow effects." },
  { question: "What does the blur radius do?", answer: "The blur radius determines how blurry the shadow edge is. A value of 0 creates a sharp, hard shadow with crisp edges. Higher values create softer, more diffuse shadows that fade out gradually. Unlike other CSS blur functions, the shadow blur cannot be negative." },
  { question: "What is the spread radius?", answer: "The spread radius expands or contracts the shadow before blurring. A positive value makes the shadow larger than the element; a negative value makes it smaller. For example, a shadow with blur: 0 and spread: 4px creates a solid outline effect around the element." },
  { question: "What is an inset shadow?", answer: "Adding the 'inset' keyword flips the shadow inside the element instead of outside. Inset shadows appear as if light is hitting from the opposite side, creating a sunken, pressed, or inner-glow effect. Inset shadows are commonly used for inputs, wells, and neumorphic UI designs." },
  { question: "How do I create a layered shadow effect?", answer: "Add multiple shadow layers using the 'Add layer' button. Each layer is rendered in order, allowing you to combine a close tight shadow for definition with a far soft shadow for depth. The classic technique uses 3 layers: a small tight shadow, a medium soft shadow, and a large diffuse shadow." },
  { question: "Why use rgba for shadow colors?", answer: "rgba() with an alpha value creates semi-transparent shadows that blend naturally with any background color. A pure black shadow (#000000) at 15% opacity looks neutral on any background, while a fully opaque black shadow looks harsh and artificial. Always use rgba for realistic-looking shadows." },
];
---

<BaseLayout
  title="CSS Box Shadow Generator — Free Visual Editor"
  description="Free CSS box-shadow generator with live preview. Adjust offset, blur, spread, color, and opacity with sliders. Add multiple shadow layers, use neumorphism presets, and copy clean CSS output. Runs 100% in your browser."
  tool="CSS Box Shadow Generator, Box Shadow Editor, CSS Shadow Maker, Neumorphism Generator, CSS Shadow Builder, Layered Box Shadow, CSS Drop Shadow Tool"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">CSS Box Shadow Generator</h1>
  <p class="text-text-muted mb-4">Build CSS box shadows visually. Adjust offset, blur, spread, color, and opacity with sliders. Layer multiple shadows for depth effects. Copy clean CSS output instantly — all in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multi-layer shadow support</span>
  </div>
  <CssBoxShadowGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CSS Box Shadow Generator" relatedTags={['css', 'design', 'ui', 'animation', 'tailwind']} />
</BaseLayout>
