---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "How do I record a Performance profile in Chrome DevTools?", answer: "Open DevTools (F12), go to the Performance tab, click the Record button (circle), interact with your page or wait for the page to load, then click Stop. For load profiling, use the reload button (circle with arrow) to capture the full page load from navigation. Use Incognito mode and disable extensions to reduce noise. Set CPU throttling to 4x or 6x to simulate mobile devices." },
  { question: "What is a long task and how do I find it in the Performance panel?", answer: "A long task is any JavaScript execution that blocks the main thread for more than 50ms. They appear as red-corner triangles on Tasks in the Main thread lane. Click on a long task to see its call stack in the Bottom-Up and Call Tree tabs. Common causes: heavy event handlers, synchronous layout/style recalculation (forced reflow), unoptimized loops processing large data sets, and third-party scripts." },
  { question: "What is forced reflow and how do I avoid it?", answer: "Forced reflow (layout thrashing) occurs when JavaScript reads layout properties (offsetWidth, getBoundingClientRect, scrollTop) after making DOM changes, forcing the browser to synchronously recalculate layout. It appears as a red 'Layout' warning in the Performance panel. Fix by batching DOM reads before writes, using `requestAnimationFrame` for visual updates, or using CSS transforms/opacity instead of layout-triggering properties." },
  { question: "How do I use the Performance Insights panel vs the Performance panel?", answer: "The Performance Insights panel (newer) provides actionable insights with specific fix suggestions, automatically highlighting Core Web Vitals (LCP, CLS, INP), long tasks, and render-blocking resources with direct explanations. The Performance panel provides the raw flame chart for deep call-stack analysis. For initial diagnosis, use Performance Insights. For pinpointing the exact function causing a bottleneck, switch to the full Performance panel." },
];
---

<BaseLayout
  title="Chrome DevTools Performance Panel Guide — Profile & Fix JavaScript Bottlenecks"
  description="Master Chrome DevTools Performance panel: record load profiles, find long tasks, diagnose forced reflow, analyze Web Vitals, and fix JavaScript performance bottlenecks."
  tool="Chrome DevTools, Performance panel, JavaScript profiling, flame chart, long tasks, Web Vitals, performance debugging"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Chrome DevTools Performance Panel Guide",
    "url": "https://devplaybook.cc/tools/chrome-devtools-performance",
    "description": "Master Chrome DevTools Performance panel to profile JavaScript, find long tasks, and fix Web Vitals issues.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Chrome DevTools Performance Panel Guide</h1>
  <p class="text-text-muted mb-6">
    The <strong>Chrome DevTools Performance panel</strong> is the most powerful tool for diagnosing JavaScript performance issues, layout thrashing, long tasks, and Core Web Vitals regressions directly in your browser.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Recording profiles</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Flame chart reading</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Long task detection</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Forced reflow diagnosis</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Recording a Performance Profile</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li>Open Chrome DevTools → <strong>Performance</strong> tab (<kbd class="bg-bg-card px-1 rounded text-xs font-mono">F12</kbd> → Performance)</li>
    <li>Use <strong>Incognito mode</strong> to disable extensions and reduce noise</li>
    <li>Set <strong>CPU throttling</strong>: 4x slowdown for mid-range mobile, 6x for low-end</li>
    <li>Set <strong>Network throttling</strong>: Fast 3G for realistic conditions</li>
    <li><strong>Load profile</strong>: Click the reload+record button (↺) to capture full navigation</li>
    <li><strong>Interaction profile</strong>: Press Record → interact → Stop (3–5 seconds is enough)</li>
    <li>Check <strong>Screenshots</strong> to correlate visual changes with timeline events</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Reading the Flame Chart</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Lane</th>
          <th class="border border-border px-3 py-2 text-left">What It Shows</th>
          <th class="border border-border px-3 py-2 text-left">Look For</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2">CPU</td><td class="border border-border px-3 py-2">Total CPU usage by type</td><td class="border border-border px-3 py-2">Yellow (scripting) spikes</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Network</td><td class="border border-border px-3 py-2">Resource requests timeline</td><td class="border border-border px-3 py-2">Long chains, render-blockers</td></tr>
        <tr><td class="border border-border px-3 py-2">Main Thread</td><td class="border border-border px-3 py-2">JS execution call stack</td><td class="border border-border px-3 py-2">Red triangles = long tasks</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Timings</td><td class="border border-border px-3 py-2">FCP, LCP, CLS, INP markers</td><td class="border border-border px-3 py-2">LCP timing and its cause</td></tr>
        <tr><td class="border border-border px-3 py-2">Compositor</td><td class="border border-border px-3 py-2">GPU compositing work</td><td class="border border-border px-3 py-2">Paint storms</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Diagnosing Long Tasks</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// Mark custom tasks for DevTools visibility
performance.mark('process-start');
processLargeDataSet(data);
performance.mark('process-end');
performance.measure('Process Data', 'process-start', 'process-end');

// Break up long tasks with scheduler.yield()
async function processInChunks(items) &#123;
  for (let i = 0; i &lt; items.length; i++) &#123;
    process(items[i]);
    // Yield every 50 items to avoid blocking
    if (i % 50 === 0) &#123;
      await scheduler.yield();
      // Falls back to: await new Promise(r => setTimeout(r, 0))
    &#125;
  &#125;
&#125;</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Detecting Forced Reflow (Layout Thrashing)</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// ❌ BAD: Read-write interleaving causes forced reflow
function badLoop(elements) &#123;
  elements.forEach(el => &#123;
    const width = el.offsetWidth;     // READ: forces layout
    el.style.width = width * 2 + 'px'; // WRITE: invalidates layout
    // Next read will force layout again!
  &#125;);
&#125;

// ✅ GOOD: Batch reads, then writes
function goodLoop(elements) &#123;
  // Phase 1: read all layout values
  const widths = elements.map(el => el.offsetWidth);
  // Phase 2: write all styles
  elements.forEach((el, i) => &#123;
    el.style.width = widths[i] * 2 + 'px';
  &#125;);
&#125;

// Layout-triggering properties to avoid in loops:
// offsetWidth, offsetHeight, offsetTop, offsetLeft
// scrollWidth, scrollHeight, scrollTop
// clientWidth, clientHeight, clientTop
// getBoundingClientRect(), getComputedStyle()</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Bottom-Up & Call Tree Analysis</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Bottom-Up tab</strong>: Shows which functions took the most self-time (execution within the function itself). Best for finding the specific hot function.</li>
    <li><strong>Call Tree tab</strong>: Shows the full call hierarchy from root to leaf. Best for understanding what triggered the expensive function.</li>
    <li><strong>Event Log tab</strong>: Flat list of all events sorted by time. Filter by type (Script, Render, Paint).</li>
    <li>Click <strong>Group by URL</strong> in Bottom-Up to identify third-party scripts by domain.</li>
  </ul>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Chrome DevTools Performance Panel" relatedTags={['performance', 'chrome-devtools', 'javascript', 'core-web-vitals', 'debugging']} />
</BaseLayout>
