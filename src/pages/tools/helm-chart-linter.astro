---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HelmChartLinter from '../../components/HelmChartLinter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a Helm chart?",
    answer: "A Helm chart is a package of pre-configured Kubernetes resources. It consists of templates (YAML files with Go template directives), a values.yaml file with default configuration, and a Chart.yaml metadata file. Helm renders templates with the provided values and applies the resulting manifests to your Kubernetes cluster. Charts enable repeatable, parameterized deployments and are the standard packaging format for Kubernetes applications."
  },
  {
    question: "What is the difference between Helm v2 and Helm v3?",
    answer: "Helm v3 removed Tiller (the in-cluster component) for improved security, and uses apiVersion: v2 in Chart.yaml. Key differences: v3 uses Kubernetes RBAC directly instead of Tiller's service account; chart dependencies moved from requirements.yaml into Chart.yaml; the 'type' field (application or library) was introduced in v2. If your Chart.yaml has apiVersion: v1, you're using a Helm 2 chart format. Upgrade to v2 for all new charts."
  },
  {
    question: "What is semantic versioning in Helm charts?",
    answer: "Helm requires semantic versioning (semver) for the 'version' field in Chart.yaml. The format is MAJOR.MINOR.PATCH (e.g. 1.2.3). MAJOR: breaking changes, MINOR: new features (backward-compatible), PATCH: bug fixes. The 'version' field tracks the chart version, while 'appVersion' tracks the version of the application the chart deploys. Always increment 'version' when you change the chart, even if the application version stays the same."
  },
  {
    question: "Why should I avoid 'pullPolicy: Always'?",
    answer: "pullPolicy: Always forces Kubernetes to contact the registry and check for image updates on every Pod start. This adds latency to Pod startup, increases registry load, and can cause deployments to fail if the registry is temporarily unavailable. When using pinned image tags (like nginx:1.25.3), use pullPolicy: IfNotPresent — Kubernetes only pulls the image if it's not cached on the node. Use Always only with mutable tags like :latest where you explicitly want the newest version."
  },
  {
    question: "How do I reference Kubernetes Secrets in Helm values?",
    answer: "Never put actual secret values in values.yaml — these files are committed to version control. Instead, use placeholder values and override them at deploy time: helm upgrade --set db.password=$DB_PASSWORD my-release ./chart. For production, use external secret management: Helm Secrets plugin (with SOPS encryption), External Secrets Operator, or Vault Agent Injector. Reference secrets in templates using {{ .Values.db.password | b64enc | quote }} or mount Kubernetes Secrets created outside the chart."
  },
  {
    question: "What is the difference between application and library chart types?",
    answer: "Application charts (type: application) contain a complete, deployable set of Kubernetes resources. Library charts (type: library) contain reusable template helpers and partials that other charts can depend on — they don't deploy any resources directly. Library charts are useful for sharing common template logic (like labels, annotations, or naming conventions) across multiple application charts in a monorepo or organization."
  },
];
---

<BaseLayout
  title="Helm Chart Linter — Validate Chart.yaml and values.yaml Online"
  description="Free online Helm chart linter. Validates Chart.yaml structure, semver versioning, values.yaml best practices, image tag pinning, and hardcoded secrets. No Helm CLI required."
  tool="Helm chart linter, Chart.yaml validator, values.yaml checker, Helm best practices, Helm v3 validator, Kubernetes Helm linter"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Helm Chart Linter</h1>
  <p class="text-text-muted mb-4">Validate your Helm chart files without running <code class="font-mono text-sm bg-surface px-1 rounded">helm lint</code>. Switch between Chart.yaml and values.yaml tabs to catch required field errors, semver violations, insecure configurations, and production best-practice issues instantly.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Chart.yaml + values.yaml checks</span>
  </div>
  <HelmChartLinter client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Helm Chart Linter" relatedTags={['devops', 'kubernetes', 'cloud', 'infrastructure', 'helm']} />
</BaseLayout>
