---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is critical CSS and why does it improve performance?", answer: "Critical CSS is the minimum set of CSS rules required to render the above-the-fold content of a page. By inlining this CSS in a <style> tag in the <head>, the browser can render visible content without waiting to download external stylesheets. This reduces render-blocking time and improves FCP (First Contentful Paint) and LCP. The non-critical CSS is then loaded asynchronously after the page is visible." },
  { question: "How do I extract critical CSS automatically?", answer: "Use tools like `critters` (Google, Astro/Next.js integration), `critical` (Node.js CLI), or `penthouse` (Puppeteer-based). These tools load your page in a headless browser, determine what CSS is needed above the fold, inline it in the HTML, and defer the rest. For static sites, run them at build time. For server-rendered apps, integrate into your build pipeline or use edge-side rendering." },
  { question: "Should I manually write critical CSS or generate it automatically?", answer: "For most projects, auto-generation is preferred since manual maintenance is error-prone. Use `critters` for Next.js/webpack projects or the built-in critical CSS features in Astro and Nuxt. However, auto-generation tools can include too much or too little CSS. Review the output and verify FCP improvement with Lighthouse. For small sites with hand-crafted CSS, manual critical CSS can be more precise and lighter." },
  { question: "How do I load non-critical CSS without render blocking?", answer: "Use the media type trick: `<link rel='stylesheet' href='styles.css' media='print' onload=\"this.media='all'\">`. This loads the stylesheet without blocking rendering (print styles don't block render) and switches it to apply to all media once loaded. Add a `<noscript>` fallback for no-JavaScript environments. Alternatively, use `rel='preload'` with `as='style'` and `onload=\"this.rel='stylesheet'\"` for the same effect." },
];
---

<BaseLayout
  title="Critical CSS Guide — Extract, Inline & Defer CSS for Faster FCP"
  description="Improve First Contentful Paint by extracting and inlining critical CSS. Learn to use critters, critical, and Penthouse, defer non-critical styles, and verify results."
  tool="critical CSS, inline CSS, render blocking, FCP, First Contentful Paint, critters, CSS optimization, performance"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Critical CSS Guide",
    "url": "https://devplaybook.cc/tools/critical-css-guide",
    "description": "Extract and inline critical CSS to eliminate render-blocking stylesheets and improve FCP.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Critical CSS Guide</h1>
  <p class="text-text-muted mb-6">
    <strong>Critical CSS</strong> inlines above-the-fold styles in the HTML <code class="font-mono text-sm bg-bg-card px-1 rounded">&lt;head&gt;</code> so the browser can render visible content immediately, without waiting for external CSS files. It's one of the highest-impact FCP optimizations.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Extraction tools</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Inline vs defer pattern</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Astro / Next.js integration</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Verification with Lighthouse</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">How Critical CSS Works</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">&lt;!-- ❌ Standard approach: render-blocking --&gt;
&lt;head&gt;
  &lt;link rel="stylesheet" href="/styles.css"&gt;  &lt;!-- Blocks render until downloaded --&gt;
&lt;/head&gt;

&lt;!-- ✅ Critical CSS approach --&gt;
&lt;head&gt;
  &lt;!-- 1. Inline critical (above-fold) CSS --&gt;
  &lt;style&gt;
    /* Only styles needed for above-fold content */
    body &#123; font-family: sans-serif; margin: 0; &#125;
    .hero &#123; height: 100vh; background: #111; &#125;
    .nav &#123; display: flex; padding: 1rem; &#125;
  &lt;/style&gt;

  &lt;!-- 2. Async-load full CSS (non-render-blocking) --&gt;
  &lt;link
    rel="stylesheet"
    href="/styles.css"
    media="print"
    onload="this.media='all'"
  &gt;
  &lt;noscript&gt;&lt;link rel="stylesheet" href="/styles.css"&gt;&lt;/noscript&gt;
&lt;/head&gt;</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Using critters (Recommended for Webpack/Next.js)</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">npm install --save-dev critters</pre>

  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// webpack.config.js
const Critters = require('critters/webpack');

module.exports = &#123;
  plugins: [
    new Critters(&#123;
      // Inline critical CSS, preload the rest
      preload: 'swap',         // 'swap' | 'js' | 'js-lazy' | 'media' | 'body'
      pruneSource: true,       // remove inlined styles from the external file
      mergeStylesheets: true,  // merge multiple &lt;style&gt; tags into one
      inlineFonts: false,      // don't inline @font-face (too large)
      preloadFonts: true,      // preload font files instead
    &#125;),
  ],
&#125;;

// Next.js — critters is built in:
// next.config.js
module.exports = &#123;
  experimental: &#123;
    optimizeCss: true,  // enable critters integration
  &#125;,
&#125;;</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Using critical (CLI Tool)</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">npm install -g critical

# Extract critical CSS from a URL
critical https://example.com \
  --base dist/ \
  --inline \
  --width 1300 \
  --height 900 \
  --css dist/styles.css

# From a local HTML file
critical dist/index.html \
  --base dist/ \
  --inline \
  --dest dist/index.html</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Astro Built-in Critical CSS</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// Astro automatically scopes and inlines component CSS.
// For page-level critical CSS, use &lt;style&gt; in your layout:

// src/layouts/BaseLayout.astro
---
const &#123; title &#125; = Astro.props;
---
&lt;html&gt;
  &lt;head&gt;
    &lt;title&gt;&#123;title&#125;&lt;/title&gt;
    &lt;!-- Astro scopes this CSS and includes it inline --&gt;
    &lt;style&gt;
      :global(body) &#123; margin: 0; font-family: system-ui; &#125;
      header &#123; position: sticky; top: 0; &#125;
    &lt;/style&gt;
    &lt;!-- Non-critical: loaded async --&gt;
    &lt;link rel="preload" href="/fonts/inter.woff2" as="font" crossorigin&gt;
  &lt;/head&gt;
  &lt;body&gt;
    &lt;slot /&gt;
  &lt;/body&gt;
&lt;/html&gt;</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Common Mistakes</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Inlining too much CSS</strong> — Every byte inlined is not cached. Keep critical CSS under 14KB (one TCP window)</li>
    <li><strong>Not using a noscript fallback</strong> — The media print trick breaks in environments without JS</li>
    <li><strong>Extracting based on 1440px viewport only</strong> — Run extraction at multiple viewport sizes for responsive sites</li>
    <li><strong>Not verifying reduction</strong> — Measure FCP before/after with Lighthouse to confirm improvement</li>
    <li><strong>Forgetting fonts</strong> — @font-face blocks rendering; use <code class="font-mono text-xs bg-bg-card px-1 rounded">font-display: swap</code> and preload</li>
  </ul>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Critical CSS Guide" relatedTags={['performance', 'css', 'fcp', 'render-blocking', 'core-web-vitals']} />
</BaseLayout>
