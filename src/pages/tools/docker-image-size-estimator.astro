---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DockerImageSizeEstimator from '../../components/DockerImageSizeEstimator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "Why does image size matter in Docker?", answer: "Smaller images pull faster in CI/CD pipelines, start containers faster (especially in serverless/ephemeral environments), consume less storage in registries (reducing costs), and have a smaller attack surface with fewer packages to patch." },
  { question: "What is a multi-stage Docker build?", answer: "Multi-stage builds use multiple FROM statements. The first stage installs build tools and compiles your app. The second (final) stage copies only the compiled output into a minimal base image. This keeps build dependencies (gcc, node_modules/devDependencies) out of the final image. Example: Go apps can build in golang:alpine and run in scratch." },
  { question: "What is the difference between alpine, slim, and the default image?", answer: "Default (e.g., node:20) is based on Debian Bookworm with all common tools — largest but most compatible. slim variants remove documentation, man pages, and some utilities, cutting size significantly. alpine variants use Alpine Linux with musl libc — smallest, but may have compatibility issues with packages expecting glibc." },
  { question: "How do I reduce the size of apt-get layers?", answer: "Always combine apt-get update, apt-get install, and apt-get clean in a single RUN command: RUN apt-get update && apt-get install -y pkg && rm -rf /var/lib/apt/lists/*. If you split these into separate RUN commands, Docker caches each layer separately, and the cache files remain in the image." },
  { question: "What is .dockerignore?", answer: "Similar to .gitignore, .dockerignore lists files that should not be sent to the Docker build context. Always include node_modules, .git, .env, dist, and build artifacts. A missing .dockerignore can cause your COPY . . instruction to include gigabytes of irrelevant files in the build context." },
];
---

<BaseLayout
  title="Docker Image Size Estimator — Dockerfile Builder & Layer Calculator"
  description="Estimate Docker image size before building. Choose base image, add layers with size estimates, and get optimization tips. Build and copy your Dockerfile."
  tool="Docker image size estimator, Dockerfile size calculator, Docker layer estimator, optimize Docker image, Docker base image comparison"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Docker Image Size Estimator</h1>
  <p class="text-text-muted mb-4">Plan your Dockerfile and estimate the final image size before building. Choose a base image, add layers with size estimates, get optimization tips, and copy the generated Dockerfile. Aim for under 100 MB in production.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 15+ base images with real sizes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Optimization tips per layer</span>
  </div>
  <DockerImageSizeEstimator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Docker Image Size Estimator" relatedTags={['docker', 'devops', 'containers', 'infrastructure', 'kubernetes']} />
</BaseLayout>
