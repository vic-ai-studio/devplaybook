---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HtmlTableGenerator from '../../components/HtmlTableGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How do I create an HTML table?", answer: "An HTML table uses the <table> element with nested <thead> (for header rows), <tbody> (for data rows), <tr> (for each row), <th> (for header cells), and <td> (for data cells). This generator creates valid, semantic HTML tables with proper structure and optional Tailwind CSS or inline styling." },
  { question: "What is the difference between Tailwind CSS and inline styles?", answer: "Tailwind CSS classes (like 'px-4 py-2 border') are utility classes that require Tailwind to be installed in your project. Inline styles use the HTML style attribute and work anywhere without any CSS framework. Choose Tailwind for projects that already use it, and inline styles for standalone HTML pages or email templates." },
  { question: "Can I add more rows or columns after generating?", answer: "Yes — use the Rows and Columns number inputs to change the table dimensions. The generator preserves your existing cell content when you resize. You can also directly edit the header names and cell values in the interactive table editor before copying the HTML." },
  { question: "How do I use the generated HTML in my project?", answer: "Copy the generated HTML and paste it directly into your HTML file. If using Tailwind CSS output, ensure Tailwind is configured in your project. If using inline styles, the table works without any external CSS. For CMS platforms, paste in an HTML block or code embed widget." },
  { question: "What is a striped table?", answer: "A striped (or zebra-stripe) table alternates row background colors between white and light gray to improve readability, especially in wide tables with many rows. This is a common UI pattern implemented with the :nth-child(even) CSS selector or (as in this generator) with a conditional class on every other row." },
];
---

<BaseLayout
  title="HTML Table Generator — Free Online Tool"
  description="Free HTML table generator. Set rows and columns, fill in data, choose Tailwind CSS or inline styles, add borders and striped rows, then copy clean HTML table code instantly. Runs 100% in your browser."
  tool="HTML Table Generator, HTML Table Maker, Table Code Generator, HTML Table Builder, Tailwind Table Generator, HTML Table Code, Bootstrap Table Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">HTML Table Generator</h1>
  <p class="text-text-muted mb-4">Set rows and columns, fill in your data, choose Tailwind CSS or inline styles, toggle borders and striped rows — then copy clean, valid HTML table code ready for any project.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Tailwind CSS + inline styles</span>
  </div>
  <HtmlTableGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="HTML Table Generator" relatedTags={['html', 'css', 'tailwind', 'ui', 'frontend']} />
</BaseLayout>
