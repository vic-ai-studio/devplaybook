---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How are input and output tokens different?", answer: "Input tokens are the text you send to the model (prompt + context). Output tokens are the text the model generates in response. Output tokens are typically 2-4x more expensive than input tokens." },
  { question: "What is the difference between daily and monthly cost?", answer: "Daily cost is requests/day × cost per request. Monthly cost multiplies by 30. This assumes consistent daily usage — factor in weekends or peak/off-peak patterns for a more accurate forecast." },
  { question: "Which model is the cheapest for my use case?", answer: "For most text tasks, Claude Haiku and Gemini Flash are cheapest. For code/reasoning, GPT-4o Mini and Claude Haiku offer the best cost-to-quality ratio. Frontier models (GPT-4o, Claude Opus) cost significantly more but excel at complex tasks." },
  { question: "How do I reduce my LLM API costs?", answer: "1) Shorten system prompts. 2) Use prompt caching (Anthropic/OpenAI both support it). 3) Route simple requests to cheaper models. 4) Limit max_tokens in your API calls. 5) Batch requests where latency allows." },
  { question: "Are these the real prices?", answer: "Prices are approximate as of Q1 2025. LLM providers change pricing frequently — always verify on the provider's official pricing page before budgeting." },
];
---

<BaseLayout
  title="AI Prompt Cost Calculator — LLM API Cost Estimator"
  description="Calculate daily and monthly API costs for GPT-4o, Claude 3.5, Gemini 1.5, and more. Enter token counts, model, and request volume to get instant cost projections. Free, browser-based."
  tool="AI Cost Calculator, LLM API Cost Estimator, GPT-4o Cost, Claude API Pricing, Gemini Cost Estimator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">AI Prompt Cost Calculator</h1>
  <p class="text-text-muted mb-6">Estimate daily and monthly API costs for any LLM. Select a model, enter your average token counts and request volume, and get instant cost projections.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 10+ models supported</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Daily & monthly projections</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs in your browser</span>
  </div>

  <div id="cost-calculator" class="space-y-6">
    <!-- Model selector -->
    <div>
      <label for="model-select" class="block text-sm font-medium mb-2">Model</label>
      <select id="model-select" class="w-full bg-bg-card border border-border rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary">
        <optgroup label="OpenAI">
          <option value="gpt4o">GPT-4o ($5.00 / $15.00 per 1M)</option>
          <option value="gpt4o-mini">GPT-4o Mini ($0.15 / $0.60 per 1M)</option>
          <option value="o1">o1 ($15.00 / $60.00 per 1M)</option>
          <option value="o1-mini">o1-mini ($3.00 / $12.00 per 1M)</option>
        </optgroup>
        <optgroup label="Anthropic">
          <option value="claude-sonnet">Claude 3.5 Sonnet ($3.00 / $15.00 per 1M)</option>
          <option value="claude-haiku">Claude 3.5 Haiku ($0.80 / $4.00 per 1M)</option>
          <option value="claude-opus">Claude 3 Opus ($15.00 / $75.00 per 1M)</option>
        </optgroup>
        <optgroup label="Google">
          <option value="gemini-pro">Gemini 1.5 Pro ($3.50 / $10.50 per 1M)</option>
          <option value="gemini-flash">Gemini 1.5 Flash ($0.075 / $0.30 per 1M)</option>
          <option value="gemini-flash-8b">Gemini 1.5 Flash-8B ($0.0375 / $0.15 per 1M)</option>
        </optgroup>
        <optgroup label="Meta / Open Source">
          <option value="llama3-70b">Llama 3.3 70B* ($0.59 / $0.79 per 1M)</option>
          <option value="llama3-8b">Llama 3.1 8B* ($0.10 / $0.10 per 1M)</option>
        </optgroup>
      </select>
    </div>

    <!-- Token inputs -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label for="input-tokens" class="block text-sm font-medium mb-2">Avg. Input Tokens per Request</label>
        <input type="number" id="input-tokens" value="500" min="1" max="1000000"
          class="w-full bg-bg-card border border-border rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
        <p class="text-xs text-text-muted mt-1">System prompt + user message</p>
      </div>
      <div>
        <label for="output-tokens" class="block text-sm font-medium mb-2">Avg. Output Tokens per Request</label>
        <input type="number" id="output-tokens" value="200" min="1" max="100000"
          class="w-full bg-bg-card border border-border rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
        <p class="text-xs text-text-muted mt-1">Model response length</p>
      </div>
    </div>

    <!-- Request volume -->
    <div>
      <label for="requests-per-day" class="block text-sm font-medium mb-2">Requests per Day</label>
      <input type="number" id="requests-per-day" value="1000" min="1" max="10000000"
        class="w-full bg-bg-card border border-border rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
    </div>

    <!-- Results -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
        <p class="text-xs text-text-muted uppercase tracking-wide mb-2">Cost per Request</p>
        <p class="text-2xl font-bold tabular-nums text-primary" id="cost-per-request">$0.00</p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
        <p class="text-xs text-text-muted uppercase tracking-wide mb-2">Daily Cost</p>
        <p class="text-2xl font-bold tabular-nums" id="daily-cost">$0.00</p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
        <p class="text-xs text-text-muted uppercase tracking-wide mb-2">Monthly Cost (30d)</p>
        <p class="text-2xl font-bold tabular-nums" id="monthly-cost">$0.00</p>
      </div>
    </div>

    <!-- Breakdown -->
    <div class="bg-bg-card border border-border rounded-xl p-5 text-sm space-y-2" id="breakdown">
      <p class="font-semibold mb-3">Cost Breakdown</p>
      <div class="flex justify-between text-text-muted">
        <span>Input tokens (per request)</span>
        <span class="tabular-nums" id="bd-input-tok">500</span>
      </div>
      <div class="flex justify-between text-text-muted">
        <span>Input cost (per request)</span>
        <span class="tabular-nums" id="bd-input-cost">—</span>
      </div>
      <div class="flex justify-between text-text-muted">
        <span>Output tokens (per request)</span>
        <span class="tabular-nums" id="bd-output-tok">200</span>
      </div>
      <div class="flex justify-between text-text-muted">
        <span>Output cost (per request)</span>
        <span class="tabular-nums" id="bd-output-cost">—</span>
      </div>
      <hr class="border-border" />
      <div class="flex justify-between font-medium">
        <span>Total tokens / 1000 requests</span>
        <span class="tabular-nums" id="bd-total-tok">—</span>
      </div>
    </div>

    <!-- Model comparison -->
    <div>
      <p class="text-sm font-semibold mb-3">Compare All Models (same usage)</p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-text-muted text-xs uppercase border-b border-border">
              <th class="text-left pb-2 pr-4">Model</th>
              <th class="text-right pb-2 pr-4">Per Request</th>
              <th class="text-right pb-2 pr-4">Daily</th>
              <th class="text-right pb-2">Monthly</th>
            </tr>
          </thead>
          <tbody id="comparison-table" class="divide-y divide-border">
          </tbody>
        </table>
      </div>
    </div>

    <p class="text-xs text-text-muted">
      * Llama prices are indicative of cloud inference APIs (Together AI, Groq). Prices as of Q1 2025.
    </p>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="AI Prompt Cost Calculator" relatedTags={['ai', 'llm', 'openai', 'claude', 'gemini', 'cost', 'api']} />
</BaseLayout>

<script>
  type ModelDef = { name: string; input: number; output: number };
  const MODELS: Record<string, ModelDef> = {
    'gpt4o':          { name: 'GPT-4o',               input: 5.00,   output: 15.00  },
    'gpt4o-mini':     { name: 'GPT-4o Mini',           input: 0.15,   output: 0.60   },
    'o1':             { name: 'o1',                    input: 15.00,  output: 60.00  },
    'o1-mini':        { name: 'o1-mini',               input: 3.00,   output: 12.00  },
    'claude-sonnet':  { name: 'Claude 3.5 Sonnet',     input: 3.00,   output: 15.00  },
    'claude-haiku':   { name: 'Claude 3.5 Haiku',      input: 0.80,   output: 4.00   },
    'claude-opus':    { name: 'Claude 3 Opus',         input: 15.00,  output: 75.00  },
    'gemini-pro':     { name: 'Gemini 1.5 Pro',        input: 3.50,   output: 10.50  },
    'gemini-flash':   { name: 'Gemini 1.5 Flash',      input: 0.075,  output: 0.30   },
    'gemini-flash-8b':{ name: 'Gemini Flash-8B',       input: 0.0375, output: 0.15   },
    'llama3-70b':     { name: 'Llama 3.3 70B*',        input: 0.59,   output: 0.79   },
    'llama3-8b':      { name: 'Llama 3.1 8B*',         input: 0.10,   output: 0.10   },
  };

  function calcCost(model: ModelDef, inputTok: number, outputTok: number): number {
    return (inputTok / 1_000_000) * model.input + (outputTok / 1_000_000) * model.output;
  }

  function fmt(n: number): string {
    if (n < 0.001) return `$${n.toFixed(6)}`;
    if (n < 1) return `$${n.toFixed(4)}`;
    return `$${n.toFixed(2)}`;
  }

  function fmtLarge(n: number): string {
    if (n >= 1000) return `$${n.toLocaleString('en-US', { maximumFractionDigits: 2 })}`;
    return fmt(n);
  }

  function update() {
    const modelKey = (document.getElementById('model-select') as HTMLSelectElement).value;
    const inputTok = parseInt((document.getElementById('input-tokens') as HTMLInputElement).value) || 0;
    const outputTok = parseInt((document.getElementById('output-tokens') as HTMLInputElement).value) || 0;
    const reqPerDay = parseInt((document.getElementById('requests-per-day') as HTMLInputElement).value) || 0;

    const model = MODELS[modelKey];
    const perReq = calcCost(model, inputTok, outputTok);
    const daily = perReq * reqPerDay;
    const monthly = daily * 30;

    (document.getElementById('cost-per-request') as HTMLElement).textContent = fmt(perReq);
    (document.getElementById('daily-cost') as HTMLElement).textContent = fmtLarge(daily);
    (document.getElementById('monthly-cost') as HTMLElement).textContent = fmtLarge(monthly);

    (document.getElementById('bd-input-tok') as HTMLElement).textContent = inputTok.toLocaleString();
    (document.getElementById('bd-output-tok') as HTMLElement).textContent = outputTok.toLocaleString();
    (document.getElementById('bd-input-cost') as HTMLElement).textContent = `$${((inputTok / 1_000_000) * model.input).toFixed(8)}`;
    (document.getElementById('bd-output-cost') as HTMLElement).textContent = `$${((outputTok / 1_000_000) * model.output).toFixed(8)}`;
    (document.getElementById('bd-total-tok') as HTMLElement).textContent = ((inputTok + outputTok) * 1000).toLocaleString() + ' tokens';

    // Comparison table
    const tbody = document.getElementById('comparison-table') as HTMLElement;
    const rows = Object.entries(MODELS).map(([key, m]) => {
      const pr = calcCost(m, inputTok, outputTok);
      const d = pr * reqPerDay;
      const mo = d * 30;
      const isActive = key === modelKey;
      return `<tr class="${isActive ? 'bg-primary/10 font-semibold' : ''}">
        <td class="py-2 pr-4 ${isActive ? 'text-primary' : ''}">${m.name}${isActive ? ' ✓' : ''}</td>
        <td class="py-2 pr-4 text-right tabular-nums">${fmt(pr)}</td>
        <td class="py-2 pr-4 text-right tabular-nums">${fmtLarge(d)}</td>
        <td class="py-2 text-right tabular-nums">${fmtLarge(mo)}</td>
      </tr>`;
    }).join('');
    tbody.innerHTML = rows;
  }

  ['model-select', 'input-tokens', 'output-tokens', 'requests-per-day'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', update);
  });

  update();
</script>
