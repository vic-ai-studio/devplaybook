---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is the difference between k6 and Artillery?",
    answer: "k6 is a modern load testing tool written in Go with a JavaScript scripting API. It's performant, runs locally or in the cloud, and has excellent Grafana integration. Artillery is a Node.js-based load tester with a YAML-first config approach and a plugin ecosystem. k6 is better for high-throughput testing and CI integration; Artillery is easier for non-developers to configure and has better built-in reporting for multi-step scenarios.",
  },
  {
    question: "What is the difference between VUs (virtual users) and requests per second (RPS)?",
    answer: "VUs (virtual users) simulate concurrent users. Each VU runs your test script sequentially — making requests, waiting for responses, then making more. RPS (requests per second) is the throughput. The relationship is: RPS = VUs / response_time_seconds. With 100 VUs and 200ms average response time, you get ~500 RPS. Most load tests are configured by VU count; RPS is the result you measure.",
  },
  {
    question: "What is a ramp-up period and why does it matter?",
    answer: "A ramp-up period gradually increases load from 0 to the target VU count over a set time. This mimics real traffic patterns and gives your application time to warm up (JVM JIT compilation, connection pool initialization, cache warming). Without ramp-up, a sudden spike of 1000 VUs can cause artificial errors from cold-start conditions that wouldn't occur in production.",
  },
  {
    question: "What performance thresholds should I set?",
    answer: "Common industry thresholds: p95 response time < 500ms for APIs, p99 < 1000ms; error rate < 1% under normal load, < 5% under stress load. For web pages: Time to First Byte (TTFB) < 200ms. The exact values depend on your SLA and user expectations. Define thresholds before testing — deciding after seeing results introduces confirmation bias.",
  },
  {
    question: "What is a spike test vs a stress test vs a soak test?",
    answer: "Stress test: gradually increase load until the system fails — finds the breaking point. Spike test: instantly jump to 10x normal load — tests elasticity and auto-scaling behavior. Soak test: run at normal load for 24+ hours — finds memory leaks, connection pool exhaustion, and drift in performance over time. Load test: run at expected production load — validates performance SLAs. Use all four for comprehensive coverage.",
  },
];
---

<BaseLayout
  title="Load Test Configurator — Generate k6 & Artillery Load Test Scripts"
  description="Configure and generate load test scripts for k6 and Artillery. Set virtual users, ramp-up profiles, test duration, and thresholds. Export ready-to-run scripts for API performance testing."
  tool="Load Test Configurator, k6 Script Generator, Artillery Config Generator, Load Testing Tool, API Performance Testing"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Load Test Configurator",
    "url": "https://devplaybook.cc/tools/load-test-configurator",
    "description": "Generate k6 and Artillery load testing scripts with configurable VUs, ramp-up profiles, durations, and thresholds. Ready to run against any HTTP endpoint.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Load Test Configurator</h1>
  <p class="text-text-muted mb-4">
    Configure load test parameters and generate ready-to-run
    <strong class="text-text">k6</strong> or <strong class="text-text">Artillery</strong> scripts.
    Set virtual users, ramp-up profiles, duration, and performance thresholds.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> k6 & Artillery output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Ramp-up profiles</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Threshold configuration</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multiple test scenarios</span>
  </div>

  <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
    <!-- Config panel -->
    <div class="flex flex-col gap-4">
      <!-- Target -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted mb-4">Target</h2>
        <div class="flex flex-col gap-3">
          <div>
            <label class="block text-sm font-medium mb-1">Base URL</label>
            <input id="base-url" type="url" value="https://api.example.com" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm font-mono focus:outline-none focus:border-accent transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Endpoint Path</label>
            <input id="endpoint" type="text" value="/api/v1/users" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm font-mono focus:outline-none focus:border-accent transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">HTTP Method</label>
            <select id="http-method" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors">
              <option>GET</option>
              <option>POST</option>
              <option>PUT</option>
              <option>DELETE</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Load profile -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Load Profile</h2>
          <div class="flex gap-2">
            <button id="btn-k6" class="px-3 py-1 rounded text-xs bg-accent text-white transition-colors">k6</button>
            <button id="btn-artillery" class="px-3 py-1 rounded text-xs bg-bg border border-border text-text-muted transition-colors">Artillery</button>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium mb-1">Max VUs</label>
            <input id="max-vus" type="number" value="100" min="1" max="10000" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Ramp-up (s)</label>
            <input id="ramp-up" type="number" value="30" min="0" max="600" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Steady Duration (s)</label>
            <input id="steady-duration" type="number" value="120" min="10" max="3600" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Ramp-down (s)</label>
            <input id="ramp-down" type="number" value="10" min="0" max="300" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
          </div>
        </div>

        <div class="mt-3">
          <label class="block text-sm font-medium mb-1">Test Type</label>
          <select id="test-type" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors">
            <option value="load">Load Test (normal capacity)</option>
            <option value="stress">Stress Test (find breaking point)</option>
            <option value="spike">Spike Test (sudden surge)</option>
            <option value="soak">Soak Test (endurance)</option>
          </select>
        </div>
      </div>

      <!-- Thresholds -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted mb-4">Thresholds</h2>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium mb-1">p95 latency (ms)</label>
            <input id="p95-threshold" type="number" value="500" min="1" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">p99 latency (ms)</label>
            <input id="p99-threshold" type="number" value="1000" min="1" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Max error rate (%)</label>
            <input id="error-threshold" type="number" value="1" min="0" max="100" step="0.1" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Min RPS</label>
            <input id="rps-threshold" type="number" value="50" min="0" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
          </div>
        </div>
      </div>
    </div>

    <!-- Output -->
    <div class="flex flex-col gap-4">
      <!-- Estimated metrics -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted mb-3">Estimated Metrics</h2>
        <div id="metrics-grid" class="grid grid-cols-2 gap-3"></div>
      </div>

      <!-- Script output -->
      <div class="bg-bg-card border border-border rounded-xl p-5 flex flex-col flex-1">
        <div class="flex items-center justify-between mb-3">
          <h2 id="script-title" class="font-semibold text-sm uppercase tracking-wide text-text-muted">k6 Script</h2>
          <button id="copy-script-btn" class="px-3 py-1 rounded text-xs bg-bg border border-border text-text-muted hover:text-text transition-colors">Copy</button>
        </div>
        <pre id="script-output" class="text-xs font-mono bg-bg rounded-lg p-3 overflow-auto max-h-96 text-text whitespace-pre flex-1"></pre>
      </div>
    </div>
  </div>

  <script>
    type Tool = 'k6' | 'artillery';
    let tool: Tool = 'k6';

    function getVal(id: string): string {
      return (document.getElementById(id) as HTMLInputElement).value;
    }
    function getNum(id: string): number {
      return parseFloat(getVal(id)) || 0;
    }

    function generateK6(): string {
      const baseUrl = getVal('base-url');
      const endpoint = getVal('endpoint');
      const method = getVal('http-method');
      const maxVus = getNum('max-vus');
      const rampUp = getNum('ramp-up');
      const steady = getNum('steady-duration');
      const rampDown = getNum('ramp-down');
      const p95 = getNum('p95-threshold');
      const p99 = getNum('p99-threshold');
      const errRate = getNum('error-threshold') / 100;
      const minRps = getNum('rps-threshold');
      const testType = getVal('test-type');

      let stages = '';
      if (testType === 'spike') {
        stages = `
    { duration: '10s', target: ${Math.floor(maxVus * 0.1)} },  // baseline
    { duration: '10s', target: ${maxVus} },                    // spike
    { duration: '${steady}s', target: ${maxVus} },             // spike duration
    { duration: '10s', target: ${Math.floor(maxVus * 0.1)} },  // recovery
    { duration: '10s', target: 0 },                            // ramp-down`;
      } else if (testType === 'stress') {
        stages = `
    { duration: '${Math.floor(rampUp / 3)}s', target: ${Math.floor(maxVus * 0.3)} },
    { duration: '${Math.floor(rampUp / 3)}s', target: ${Math.floor(maxVus * 0.6)} },
    { duration: '${Math.floor(rampUp / 3)}s', target: ${maxVus} },
    { duration: '${steady}s', target: ${maxVus} },
    { duration: '${Math.floor(rampUp / 2)}s', target: ${Math.floor(maxVus * 1.5)} },  // beyond capacity
    { duration: '${rampDown}s', target: 0 },`;
      } else {
        stages = `
    { duration: '${rampUp}s', target: ${maxVus} },   // ramp up
    { duration: '${steady}s', target: ${maxVus} },   // steady load
    { duration: '${rampDown}s', target: 0 },          // ramp down`;
      }

      const body = method === 'POST' ? `, JSON.stringify({ key: 'value' }), params` : ', null, params';

      return `import http from 'k6/http';
import { check, sleep } from 'k6';
import { Rate, Trend } from 'k6/metrics';

const errorRate = new Rate('errors');
const latencyTrend = new Trend('latency');

export const options = {
  stages: [${stages}
  ],
  thresholds: {
    http_req_duration: [
      'p(95)<${p95}',
      'p(99)<${p99}',
    ],
    errors: ['rate<${errRate}'],
    http_reqs: ['rate>${minRps}'],
  },
};

const BASE_URL = '${baseUrl}';

export default function () {
  const params = {
    headers: {
      'Content-Type': 'application/json',
      // 'Authorization': 'Bearer YOUR_TOKEN',
    },
  };

  const res = http.${method.toLowerCase()}(\`\${BASE_URL}${endpoint}\`${body});

  const ok = check(res, {
    'status is 2xx': (r) => r.status >= 200 && r.status < 300,
    'response time < ${p95}ms': (r) => r.timings.duration < ${p95},
  });

  errorRate.add(!ok);
  latencyTrend.add(res.timings.duration);

  sleep(1); // Think time between requests
}`;
    }

    function generateArtillery(): string {
      const baseUrl = getVal('base-url');
      const endpoint = getVal('endpoint');
      const method = getVal('http-method');
      const maxVus = getNum('max-vus');
      const rampUp = getNum('ramp-up');
      const steady = getNum('steady-duration');
      const p95 = getNum('p95-threshold');
      const errRate = getNum('error-threshold');
      const rpsApprox = Math.floor(maxVus / 2);

      return `config:
  target: '${baseUrl}'
  http:
    timeout: 30
  phases:
    - duration: ${rampUp}
      arrivalRate: ${Math.floor(rpsApprox * 0.1)}
      rampTo: ${rpsApprox}
      name: Ramp up
    - duration: ${steady}
      arrivalRate: ${rpsApprox}
      name: Sustained load
  ensure:
    p95: ${p95}
    maxErrorRate: ${errRate}

scenarios:
  - name: "${method} ${endpoint}"
    weight: 100
    flow:
      - ${method.toLowerCase()}:
          url: "${endpoint}"
          headers:
            Content-Type: "application/json"
            # Authorization: "Bearer YOUR_TOKEN"${method === 'POST' ? `
          json:
            key: "value"` : ''}
          capture:
            - json: "$.id"
              as: "entityId"
          expect:
            - statusCode:
              - 200
              - 201
            - contentType: json
`;
    }

    function renderMetrics() {
      const maxVus = getNum('max-vus');
      const rampUp = getNum('ramp-up');
      const steady = getNum('steady-duration');
      const rampDown = getNum('ramp-down');
      const estimatedRps = Math.round(maxVus / 0.5); // assume 500ms avg
      const totalSeconds = rampUp + steady + rampDown;
      const totalRequests = Math.round(estimatedRps * steady * 0.7);

      const metrics = [
        { label: 'Max VUs', value: maxVus.toLocaleString() },
        { label: 'Est. peak RPS', value: `~${estimatedRps.toLocaleString()}` },
        { label: 'Total duration', value: `${totalSeconds}s` },
        { label: 'Est. total reqs', value: `~${totalRequests.toLocaleString()}` },
      ];

      document.getElementById('metrics-grid')!.innerHTML = metrics.map(m => `
        <div class="bg-bg rounded-lg p-3 text-center">
          <div class="text-xs text-text-muted mb-1">${m.label}</div>
          <div class="text-lg font-bold font-mono">${m.value}</div>
        </div>
      `).join('');
    }

    function render() {
      const script = tool === 'k6' ? generateK6() : generateArtillery();
      (document.getElementById('script-output') as HTMLPreElement).textContent = script;
      (document.getElementById('script-title') as HTMLElement).textContent = tool === 'k6' ? 'k6 Script' : 'Artillery Config';
      renderMetrics();
    }

    document.getElementById('btn-k6')!.addEventListener('click', () => {
      tool = 'k6';
      document.getElementById('btn-k6')!.className = 'px-3 py-1 rounded text-xs bg-accent text-white transition-colors';
      document.getElementById('btn-artillery')!.className = 'px-3 py-1 rounded text-xs bg-bg border border-border text-text-muted transition-colors';
      render();
    });

    document.getElementById('btn-artillery')!.addEventListener('click', () => {
      tool = 'artillery';
      document.getElementById('btn-artillery')!.className = 'px-3 py-1 rounded text-xs bg-accent text-white transition-colors';
      document.getElementById('btn-k6')!.className = 'px-3 py-1 rounded text-xs bg-bg border border-border text-text-muted transition-colors';
      render();
    });

    document.getElementById('copy-script-btn')!.addEventListener('click', () => {
      const text = (document.getElementById('script-output') as HTMLPreElement).textContent || '';
      navigator.clipboard.writeText(text).then(() => {
        const btn = document.getElementById('copy-script-btn') as HTMLButtonElement;
        btn.textContent = 'Copied!';
        setTimeout(() => btn.textContent = 'Copy', 2000);
      });
    });

    ['base-url', 'endpoint', 'http-method', 'max-vus', 'ramp-up', 'steady-duration', 'ramp-down',
      'test-type', 'p95-threshold', 'p99-threshold', 'error-threshold', 'rps-threshold'].forEach(id => {
      document.getElementById(id)!.addEventListener('input', render);
      document.getElementById(id)!.addEventListener('change', render);
    });

    render();
  </script>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Load Test Configurator" relatedTags={['testing', 'performance', 'k6', 'artillery', 'load-testing', 'developer-tools']} />
</BaseLayout>
