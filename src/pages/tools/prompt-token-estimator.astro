---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PromptTokenEstimator from '../../components/PromptTokenEstimator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "How accurate are the token estimates?",
    answer: "This tool uses a character-ratio approximation (~4 chars per token for GPT-style models, slightly different for Claude and Gemini). For exact counts, use the model's official tokenizer: tiktoken for OpenAI, Anthropic's tokenizer API, or Vertex AI for Gemini. Estimates are typically within 5–10% of actual counts."
  },
  {
    question: "Why do different models have different token counts for the same text?",
    answer: "Each model uses a different tokenizer with a different vocabulary. GPT-4/GPT-4o uses cl100k_base (100k vocabulary), Claude uses its own tokenizer with a 100k+ vocabulary, Gemini uses SentencePiece. Models with larger vocabularies tend to produce fewer tokens for the same text, especially for code and non-English text."
  },
  {
    question: "What is the difference between input and output pricing?",
    answer: "LLM APIs charge separately for prompt tokens (what you send) and completion tokens (what the model generates). Output tokens cost 3–5x more than input tokens because they require running the model autoregressively — each token requires a full forward pass with all KV cache from previous tokens."
  },
  {
    question: "How do I reduce my API costs?",
    answer: "1) Shorten system prompts — compress instructions without losing meaning. 2) Use cheaper models (GPT-4o mini, Gemini Flash, Claude Haiku) for simple tasks. 3) Reduce output tokens with explicit length instructions ('Answer in 3 bullets'). 4) Cache repeated prompts using prompt caching (Anthropic, OpenAI). 5) Batch similar requests. 6) Use local models (Llama, Mistral) for high-volume tasks."
  },
  {
    question: "What does 'context used' percentage mean?",
    answer: "This is the ratio of your total tokens (input + expected output) to the model's maximum context window. Staying under 50% is safe. Above 80%, models may degrade in quality on long-range reasoning tasks. Above 100%, the API will reject the request. If you're consistently at 80%+, consider chunking inputs or using a model with a larger context window."
  },
  {
    question: "Which model is cheapest for my use case?",
    answer: "For simple Q&A and classification: Gemini 1.5 Flash ($0.075/1M input) or GPT-4o mini ($0.15/1M input). For complex reasoning: compare monthly estimates here — Claude 3.5 Sonnet and GPT-4o are similarly priced at $3–$5/1M input. For bulk processing with 1M+ daily tokens: always run a cost comparison here before committing to a model."
  },
];
---

<BaseLayout
  title="Prompt Token Estimator — GPT-4, Claude, Gemini Token Count & Cost"
  description="Estimate token counts and API costs for GPT-4o, Claude 3.5, Gemini 1.5, and 9 more LLMs. Enter your prompt, set expected output length, and get per-call and monthly cost projections instantly."
  tool="Prompt Token Estimator, LLM Cost Calculator, GPT-4 Token Counter, Claude Token Estimator, Gemini Cost Calculator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Prompt Token Estimator",
    "url": "https://devplaybook.cc/tools/prompt-token-estimator",
    "description": "Estimate token counts and API costs for GPT-4o, Claude 3.5, Gemini 1.5, and more. Enter your prompt to get per-call and monthly cost projections.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Prompt Token Estimator</h1>
  <p class="text-text-muted mb-4">
    Paste your prompt or system message to estimate token counts and API costs across GPT-4o, Claude 3.5 Sonnet, Gemini 1.5, and more. Set expected output length and daily call volume to get accurate monthly cost projections.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 9 models compared</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Monthly cost projections</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Context window usage</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <PromptTokenEstimator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Prompt Token Estimator" relatedTags={['ai', 'llm', 'openai', 'claude', 'gemini', 'cost', 'tokens']} />
</BaseLayout>
