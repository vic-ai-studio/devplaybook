---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MimeTypeLookup from '../../components/MimeTypeLookup.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is a MIME type?", answer: "MIME (Multipurpose Internet Mail Extensions) type is a standard that indicates the nature and format of a document or file. Browsers and servers use MIME types to handle files correctly — for example, 'text/html' tells the browser to render HTML, while 'application/octet-stream' triggers a file download." },
  { question: "How do I look up the MIME type for a file extension?", answer: "Type the file extension (e.g., 'jpg', 'pdf', 'mp4') in the search box. The tool filters all MIME types that include that extension. You can also search by MIME type string (e.g., 'image/') or by keyword (e.g., 'video')." },
  { question: "What MIME type should I use for JSON APIs?", answer: "Use 'application/json' for JSON response bodies. For JSON-LD (linked data), use 'application/ld+json'. For form submissions, use 'application/x-www-form-urlencoded' for simple forms or 'multipart/form-data' when uploading files." },
  { question: "Why does my file upload fail even with the correct extension?", answer: "Servers validate MIME types sent in the 'Content-Type' header, not the file extension. If your client sends the wrong MIME type, the server rejects the upload. Use this tool to find the correct MIME type string and set it explicitly in your HTTP request headers." },
  { question: "What is the MIME type for Excel and Word files?", answer: "Modern Excel files (.xlsx) use 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'. Legacy .xls uses 'application/vnd.ms-excel'. For Word: .docx is 'application/vnd.openxmlformats-officedocument.wordprocessingml.document', .doc is 'application/msword'." },
  { question: "What should I use for binary file downloads?", answer: "'application/octet-stream' is the generic binary MIME type. When a server sends this type, the browser will prompt the user to download the file rather than trying to render it. Use it as a safe fallback when the specific MIME type is unknown." },
];
---

<BaseLayout
  title="MIME Type Lookup — Search by Extension or Type"
  description="Free MIME type lookup tool. Search by file extension (.jpg, .pdf, .mp4) or MIME type string (image/jpeg). Filter by category: image, video, audio, text, application, office, font. Includes quick reference for common HTTP Content-Type headers."
  tool="MIME Type Lookup, Content-Type Header, File Extension MIME, MIME Type List, HTTP Content Type, MIME Types Database, File Format MIME"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">MIME Type Lookup</h1>
  <p class="text-text-muted mb-4">Search MIME types by file extension, type string, or keyword. Find the correct <code class="text-primary font-mono text-sm">Content-Type</code> header value for any file format — images, video, audio, documents, fonts, and more. Includes a quick reference for common HTTP API content types.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Search by extension or MIME string</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 80+ MIME types indexed</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> One-click copy</span>
  </div>
  <MimeTypeLookup client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="MIME Type Lookup" relatedTags={['http', 'files', 'api', 'content-type', 'backend', 'web']} />
</BaseLayout>
