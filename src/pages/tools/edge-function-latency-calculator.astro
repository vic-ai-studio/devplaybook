---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EdgeLatencyCalculator from '../../components/EdgeLatencyCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is an edge function?",
    answer: "Edge functions are serverless functions executed at CDN edge nodes (Points of Presence) geographically close to users rather than in a single central data center. Providers include Cloudflare Workers, Vercel Edge Functions, Deno Deploy, and Fastly Compute. They reduce latency by eliminating the round-trip to a central origin and are ideal for personalization, A/B testing, authentication, request routing, and geo-specific responses."
  },
  {
    question: "Why does Cloudflare Workers have near-zero cold start?",
    answer: "Cloudflare Workers use V8 isolates rather than full container or VM instances. Isolates share a single V8 process, so spawning a new isolate takes microseconds rather than the 50-500ms typical of container cold starts. Cloudflare pre-warms isolates globally, meaning in practice Workers have ~0ms cold start. The tradeoff is a restricted runtime — no filesystem, limited memory, and a subset of Node.js APIs."
  },
  {
    question: "What is P50, P95, P99 latency?",
    answer: "Percentile latency describes the distribution of response times. P50 (median) is the time within which 50% of requests complete — your typical user experience. P95 means 95% of requests complete within that time — covering most users. P99 (tail latency) means 99% of requests finish by then — the worst 1% experience, often 3-10x the median. Optimizing P99 matters most for interactive applications where tail latency affects perceived performance."
  },
  {
    question: "How does function complexity affect edge latency?",
    answer: "Simple functions (header reads, cached KV gets, routing decisions) take 1-5ms of execution. Medium complexity (JSON parsing, a single upstream fetch, lightweight transformation) typically runs 5-20ms. Complex functions (multiple fetches, database queries, crypto operations, large payload processing) can take 20-100ms+. The dominant cost for edge functions is often the upstream fetch latency rather than CPU time, since edge runtimes are single-threaded and non-blocking."
  },
  {
    question: "What are the tradeoffs between edge providers?",
    answer: "Cloudflare Workers: largest PoP network (300+), near-zero cold starts, but limited runtime (no Node.js compat without polyfills). Vercel Edge: tight Next.js integration, good DX, fewer PoPs (~90). Deno Deploy: native TypeScript/Deno APIs, fewer PoPs (~35), higher cold starts. Fastly Compute: WASM-based (Rust/Go/JS), extremely fast warm execution, higher cold starts, requires Fastly's SDK. Choose based on your existing stack, required APIs, and target geographic regions."
  },
];
---

<BaseLayout
  title="Edge Function Latency Calculator — Compare Cloudflare, Vercel, Deno, Fastly"
  description="Estimate edge function latency across providers. Compare Cloudflare Workers, Vercel Edge, Deno Deploy, and Fastly Compute. See P50/P95/P99 estimates by region, complexity, and cold start settings."
  tool="edge function latency, Cloudflare Workers latency, Vercel Edge Functions, edge computing calculator, serverless latency comparison"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Edge Function Latency Calculator</h1>
  <p class="text-text-muted mb-4">Estimate and compare latency for Cloudflare Workers, Vercel Edge, Deno Deploy, and Fastly Compute. Select region, complexity, and cold start settings to see P50/P95/P99 estimates.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 4 edge providers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> P50 / P95 / P99 estimates</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Cold start toggle</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Provider comparison table</span>
  </div>

  <EdgeLatencyCalculator client:only="preact" />

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Edge Function Latency Calculator" relatedTags={['cloudflare', 'vercel', 'edge', 'serverless', 'performance', 'latency', 'deno']} />
</BaseLayout>
