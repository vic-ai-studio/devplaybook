---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShadcnRegistryBuilder from '../../components/ShadcnRegistryBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a shadcn/ui custom registry?",
    answer: "A custom registry lets you host your own shadcn/ui-compatible components that can be installed with the same `npx shadcn@latest add` CLI command. Instead of publishing to npm, you host a JSON file describing your component — its files, dependencies, and configuration. Teams use custom registries to share design system components across multiple projects."
  },
  {
    question: "What's the difference between registry:ui, registry:component, and registry:block?",
    answer: "registry:ui is for primitive UI components (buttons, inputs, cards) that are installed into your components/ui/ folder. registry:component is for more complex, opinionated components that use registry:ui primitives. registry:block is for full page sections or layouts. registry:lib is for utility functions. registry:hook is for React hooks."
  },
  {
    question: "Where should I host my registry?",
    answer: "Host it as static JSON files on any CDN or web server. Common options: (1) Vercel — deploy a Next.js app that serves the JSON, (2) GitHub Pages — push JSON files to a gh-pages branch, (3) Cloudflare Pages — cheap and fast global CDN, (4) Your own domain with a /r/ path (e.g. yoursite.com/r/component-name.json). The URL just needs to return valid JSON."
  },
  {
    question: "How do registryDependencies work?",
    answer: "registryDependencies lists other shadcn/ui components your component depends on. When a user installs your component, the CLI automatically installs these dependencies too. For example, if your data-table uses a Button component, list 'button' in registryDependencies. Use the official shadcn/ui component names (lowercase slugs)."
  },
  {
    question: "Can I use a custom registry in a monorepo?",
    answer: "Yes. Set up one registry package in your monorepo (e.g. packages/ui/registry/) and have all apps reference it. You can serve it locally during development with `npx serve ./registry` and use a deployed URL in production. The CLI also supports local file:// URLs for development."
  },
];
---

<BaseLayout
  title="shadcn/ui Registry Builder — Build Custom Component Registry JSON"
  description="Build a shadcn/ui custom registry entry JSON. Configure component name, files, dependencies, and registry type. Generate the registry.json and install command for your custom component registry."
  tool="shadcn registry builder, shadcn ui custom registry, registry.json generator, shadcn component registry, shadcn add custom component"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "shadcn/ui Registry Builder",
    "url": "https://devplaybook.cc/tools/shadcn-registry-builder",
    "description": "Build custom shadcn/ui component registry JSON entries. Generate registry.json and CLI install commands for sharing components across projects.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">shadcn/ui Registry Builder</h1>
  <p class="text-text-muted mb-4">
    Build a custom <code class="font-mono text-sm bg-bg-card px-1 rounded">shadcn/ui</code> registry entry. Define your component's files, dependencies, and registry type — then get the JSON and install command to share components across your projects.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 registry types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> npm & dev dependencies</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Ready-to-use install command</span>
  </div>
  <ShadcnRegistryBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="shadcn/ui Registry Builder" relatedTags={['react', 'ui', 'developer-tools', 'components', 'shadcn']} />
</BaseLayout>
