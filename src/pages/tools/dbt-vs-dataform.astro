---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is dbt and when should I use it?",
    answer: "dbt (data build tool) is a SQL-first transformation framework that lets analytics engineers transform data in their warehouse by simply writing SELECT statements. dbt handles dependency management, testing, documentation, and incremental materialization. Use dbt Core (open source) when you want full control over your infrastructure and have a team comfortable with Git and CLI workflows. Use dbt Cloud when you need a managed scheduler, a browser-based IDE, and collaboration features without self-hosting overhead. dbt is the de facto standard for ELT transformations in warehouses like BigQuery, Snowflake, Redshift, and DuckDB."
  },
  {
    question: "How does Dataform differ from dbt?",
    answer: "Dataform is Google Cloud's native SQL transformation tool, now fully integrated into BigQuery. It uses SQLX (SQL + JavaScript templating) rather than Jinja, and workflow definitions are declared in JSON config files. The key advantage: Dataform is free for BigQuery users and has zero infrastructure to manage. The tradeoff is BigQuery lock-in — Dataform does not support other warehouses. If your entire data stack runs on GCP and you want tight IAM integration, Dataform is a compelling zero-cost alternative to dbt Cloud."
  },
  {
    question: "What is SQLMesh and how does it compare?",
    answer: "SQLMesh is a next-generation open-source data transformation framework that goes beyond dbt's capabilities. Key differentiators: (1) Virtual environments — preview changes before deploying to production without duplicating all tables. (2) Automatic change categorization — SQLMesh detects whether a model change is breaking (needs full refresh) or non-breaking (can backfill only affected rows). (3) First-class Python models alongside SQL. (4) Built-in column-level lineage. SQLMesh is best for teams managing very large datasets where dbt's full refresh model becomes prohibitively expensive."
  },
  {
    question: "Can I migrate from dbt to SQLMesh or Dataform?",
    answer: "Yes, with varying effort. SQLMesh has a built-in dbt project importer — run `sqlmesh init --dbt` to convert your dbt project. Most models, tests, and seeds are compatible with minimal changes, though Jinja macros may need refactoring. Migrating from dbt to Dataform requires more manual work: rewriting Jinja to SQLX, converting schema.yml tests to Dataform assertion syntax, and accepting BigQuery-only deployment. If you have fewer than 100 models, migration is manageable in a sprint; at 500+ models, budget several weeks for a careful incremental migration."
  },
];
---

<BaseLayout
  title="dbt vs Dataform vs SQLMesh: Data Transformation Tools 2026"
  description="Compare dbt Core, dbt Cloud, Dataform, and SQLMesh for data transformation. Interactive warehouse selector, pricing breakdown, and feature matrix to pick the right tool."
  tool="dbt vs Dataform, SQLMesh comparison, data transformation tools, ELT comparison, dbt Cloud vs Dataform, analytics engineering tools"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">dbt vs Dataform vs SQLMesh</h1>
  <p class="text-text-muted mb-4">The three major SQL transformation frameworks compared. Find the right tool for your warehouse, team size, and budget in 2026.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Warehouse compatibility matrix</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Interactive tool selector</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Pricing breakdown</span>
  </div>

  <!-- Interactive Selector -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-4">Find Your Tool — Answer 4 Questions</h2>
    <div class="space-y-4" id="selector-questions">

      <div>
        <p class="text-sm font-medium mb-2">1. What is your primary data warehouse?</p>
        <div class="flex flex-wrap gap-2" id="q-warehouse">
          <button class="sel-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="warehouse" data-v="bigquery">BigQuery</button>
          <button class="sel-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="warehouse" data-v="snowflake">Snowflake</button>
          <button class="sel-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="warehouse" data-v="redshift">Redshift</button>
          <button class="sel-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="warehouse" data-v="databricks">Databricks</button>
          <button class="sel-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="warehouse" data-v="duckdb">DuckDB / local</button>
        </div>
      </div>

      <div>
        <p class="text-sm font-medium mb-2">2. Team size?</p>
        <div class="flex flex-wrap gap-2" id="q-team">
          <button class="sel-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="team" data-v="solo">Solo / 1–2 people</button>
          <button class="sel-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="team" data-v="small">Small team (3–10)</button>
          <button class="sel-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="team" data-v="large">Large team (10+)</button>
        </div>
      </div>

      <div>
        <p class="text-sm font-medium mb-2">3. Managed cloud UI or self-hosted CLI?</p>
        <div class="flex flex-wrap gap-2" id="q-deploy">
          <button class="sel-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="deploy" data-v="managed">Managed / cloud UI preferred</button>
          <button class="sel-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="deploy" data-v="selfhosted">Self-hosted / CLI preferred</button>
        </div>
      </div>

      <div>
        <p class="text-sm font-medium mb-2">4. Dataset scale?</p>
        <div class="flex flex-wrap gap-2" id="q-scale">
          <button class="sel-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="scale" data-v="small">Under 100 GB</button>
          <button class="sel-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="scale" data-v="medium">100 GB – 10 TB</button>
          <button class="sel-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="scale" data-v="large">10 TB+</button>
        </div>
      </div>
    </div>

    <div id="selector-result" class="hidden mt-5 bg-primary/10 border border-primary/30 rounded-xl p-4">
      <p class="text-sm font-semibold text-primary mb-1" id="result-tool"></p>
      <p class="text-sm text-text-muted" id="result-reason"></p>
    </div>
  </div>

  <!-- Feature Comparison Table -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6 overflow-x-auto">
    <h2 class="text-base font-semibold mb-4">Feature Comparison Matrix</h2>
    <table class="w-full text-sm min-w-[640px]">
      <thead>
        <tr class="text-text-muted text-xs border-b border-border">
          <th class="text-left pb-3 font-medium w-48">Feature</th>
          <th class="text-center pb-3 font-medium">dbt Core</th>
          <th class="text-center pb-3 font-medium">dbt Cloud</th>
          <th class="text-center pb-3 font-medium">Dataform</th>
          <th class="text-center pb-3 font-medium">SQLMesh</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border text-xs">
        <tr>
          <td class="py-3 text-text-muted font-medium">Open Source</td>
          <td class="py-3 text-center text-green-500">✓</td>
          <td class="py-3 text-center text-red-400">✗</td>
          <td class="py-3 text-center text-red-400">✗</td>
          <td class="py-3 text-center text-green-500">✓</td>
        </tr>
        <tr>
          <td class="py-3 text-text-muted font-medium">Managed Scheduler</td>
          <td class="py-3 text-center text-red-400">✗</td>
          <td class="py-3 text-center text-green-500">✓</td>
          <td class="py-3 text-center text-green-500">✓</td>
          <td class="py-3 text-center text-yellow-500">Paid</td>
        </tr>
        <tr>
          <td class="py-3 text-text-muted font-medium">BigQuery native</td>
          <td class="py-3 text-center text-green-500">✓</td>
          <td class="py-3 text-center text-green-500">✓</td>
          <td class="py-3 text-center text-green-500">Native</td>
          <td class="py-3 text-center text-green-500">✓</td>
        </tr>
        <tr>
          <td class="py-3 text-text-muted font-medium">Snowflake / Redshift</td>
          <td class="py-3 text-center text-green-500">✓</td>
          <td class="py-3 text-center text-green-500">✓</td>
          <td class="py-3 text-center text-red-400">✗</td>
          <td class="py-3 text-center text-green-500">✓</td>
        </tr>
        <tr>
          <td class="py-3 text-text-muted font-medium">Python models</td>
          <td class="py-3 text-center text-green-500">✓</td>
          <td class="py-3 text-center text-green-500">✓</td>
          <td class="py-3 text-center text-red-400">✗</td>
          <td class="py-3 text-center text-green-500">✓</td>
        </tr>
        <tr>
          <td class="py-3 text-text-muted font-medium">Virtual environments</td>
          <td class="py-3 text-center text-red-400">✗</td>
          <td class="py-3 text-center text-red-400">✗</td>
          <td class="py-3 text-center text-red-400">✗</td>
          <td class="py-3 text-center text-green-500">✓</td>
        </tr>
        <tr>
          <td class="py-3 text-text-muted font-medium">Column-level lineage</td>
          <td class="py-3 text-center text-yellow-500">Partial</td>
          <td class="py-3 text-center text-green-500">✓</td>
          <td class="py-3 text-center text-yellow-500">Partial</td>
          <td class="py-3 text-center text-green-500">✓</td>
        </tr>
        <tr>
          <td class="py-3 text-text-muted font-medium">Auto incremental detection</td>
          <td class="py-3 text-center text-red-400">✗</td>
          <td class="py-3 text-center text-red-400">✗</td>
          <td class="py-3 text-center text-red-400">✗</td>
          <td class="py-3 text-center text-green-500">✓</td>
        </tr>
        <tr>
          <td class="py-3 text-text-muted font-medium">Templating language</td>
          <td class="py-3 text-center">Jinja2</td>
          <td class="py-3 text-center">Jinja2</td>
          <td class="py-3 text-center">SQLX / JS</td>
          <td class="py-3 text-center">Jinja2 + Python</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Pricing Breakdown -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-4">Pricing Breakdown (2026)</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="border border-border rounded-lg p-4">
        <p class="text-sm font-semibold mb-1">dbt Core</p>
        <p class="text-2xl font-bold text-green-500 mb-1">Free</p>
        <p class="text-xs text-text-muted">Open source. Self-host your scheduler (Airflow, Prefect, GitHub Actions). No seat limits. Community support only.</p>
      </div>
      <div class="border border-primary/30 rounded-lg p-4 bg-primary/5">
        <p class="text-sm font-semibold mb-1">dbt Cloud</p>
        <p class="text-2xl font-bold text-primary mb-1">$100<span class="text-sm font-normal text-text-muted">/seat/mo</span></p>
        <p class="text-xs text-text-muted">Developer tier starts at $50/seat. Team plan $100/seat includes CI/CD, semantic layer, and job scheduling. Enterprise custom pricing.</p>
      </div>
      <div class="border border-border rounded-lg p-4">
        <p class="text-sm font-semibold mb-1">Dataform</p>
        <p class="text-2xl font-bold text-green-500 mb-1">Free</p>
        <p class="text-xs text-text-muted">Included with Google Cloud / BigQuery. No extra cost. Pay only for BigQuery compute used by your transformations.</p>
      </div>
      <div class="border border-border rounded-lg p-4">
        <p class="text-sm font-semibold mb-1">SQLMesh</p>
        <p class="text-2xl font-bold text-yellow-500 mb-1">OSS / Cloud</p>
        <p class="text-xs text-text-muted">Core is open source (free). SQLMesh Cloud (managed scheduler, UI, support) is ~$500/mo for teams. Tobiko Data enterprise pricing available.</p>
      </div>
    </div>
  </div>

  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-sm font-semibold mb-3">Key Decision Factors</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-xs text-text-muted">
      <div class="flex items-start gap-2"><span class="text-primary mt-0.5">→</span><span><strong class="text-foreground">Choose dbt Core</strong> — Git-native teams, multi-warehouse, cost-conscious. Pair with Airflow or GitHub Actions for scheduling.</span></div>
      <div class="flex items-start gap-2"><span class="text-primary mt-0.5">→</span><span><strong class="text-foreground">Choose dbt Cloud</strong> — Teams needing browser IDE, SOC 2 compliance, managed CI/CD, and Slack/PagerDuty integrations out of the box.</span></div>
      <div class="flex items-start gap-2"><span class="text-primary mt-0.5">→</span><span><strong class="text-foreground">Choose Dataform</strong> — All-in on GCP, want zero infrastructure overhead, prefer JS/SQLX over Jinja, and have BigQuery as sole warehouse.</span></div>
      <div class="flex items-start gap-2"><span class="text-primary mt-0.5">→</span><span><strong class="text-foreground">Choose SQLMesh</strong> — 10TB+ datasets, need virtual dev environments, incremental change detection, or column-level lineage without add-ons.</span></div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="dbt vs Dataform vs SQLMesh" relatedTags={['dbt', 'dataform', 'sqlmesh', 'data-engineering', 'bigquery', 'analytics', 'sql', 'elt']} />
</BaseLayout>

<script>
  const answers: Record<string, string> = {};

  function getRecommendation() {
    const { warehouse, team, deploy, scale } = answers;
    if (!warehouse || !team || !deploy || !scale) return null;

    if (warehouse === 'bigquery' && deploy === 'managed') {
      return { tool: 'Dataform', reason: 'You are on BigQuery and want a managed UI — Dataform is free, native to GCP, and requires zero infrastructure. It integrates with Cloud Composer (Airflow) natively.' };
    }
    if (warehouse === 'bigquery' && deploy === 'selfhosted') {
      return { tool: 'dbt Core', reason: 'BigQuery with CLI workflow — dbt Core has the most mature BigQuery adapter with macro ecosystem, incremental strategies, and a huge community of patterns.' };
    }
    if (scale === 'large') {
      return { tool: 'SQLMesh', reason: 'At 10 TB+ scale, SQLMesh\'s automatic change categorization and virtual environments prevent expensive full-refresh runs. The ROI on compute savings typically offsets the Cloud plan cost.' };
    }
    if (deploy === 'managed' && (team === 'small' || team === 'large')) {
      return { tool: 'dbt Cloud', reason: 'Managed scheduler, browser IDE, SOC 2, semantic layer, and CI/CD — dbt Cloud reduces ops overhead and lets your team focus on model quality rather than infrastructure.' };
    }
    if (deploy === 'selfhosted' && team === 'solo') {
      return { tool: 'dbt Core', reason: 'Free, runs locally or in CI, and has the largest ecosystem of adapters and community packages. Perfect for a solo analyst or small project with no budget for paid tooling.' };
    }
    return { tool: 'dbt Core', reason: 'dbt Core is the safest default — largest ecosystem, most adapters, huge community, and free. You can always migrate to dbt Cloud or SQLMesh later.' };
  }

  document.querySelectorAll('.sel-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const q = (btn as HTMLElement).dataset.q!;
      const v = (btn as HTMLElement).dataset.v!;
      answers[q] = v;

      // Highlight selected
      document.querySelectorAll(`.sel-btn[data-q="${q}"]`).forEach(b => {
        b.classList.remove('border-primary', 'bg-primary/10', 'text-primary');
        b.classList.add('border-border');
      });
      btn.classList.remove('border-border');
      btn.classList.add('border-primary', 'bg-primary/10', 'text-primary');

      const rec = getRecommendation();
      const resultEl = document.getElementById('selector-result')!;
      if (rec) {
        resultEl.classList.remove('hidden');
        document.getElementById('result-tool')!.textContent = `Recommended: ${rec.tool}`;
        document.getElementById('result-reason')!.textContent = rec.reason;
      }
    });
  });
</script>
