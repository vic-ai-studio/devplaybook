---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="HTTPie Command Builder — Build http Commands Visually"
  description="Build HTTPie (http) commands visually. Set method, URL, headers, auth, query params, and JSON body. Copy the ready-to-run http command instantly. Free online HTTPie CLI generator."
  tool="HTTPie Command Builder, http CLI Generator, HTTPie GUI, REST API CLI Tool, HTTPie Syntax Generator"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "HTTPie Command Builder",
    "url": "https://devplaybook.cc/tools/httpie-command-builder",
    "description": "Build HTTPie (http) commands visually with method, URL, headers, auth, and body options.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">HTTPie Command Builder</h1>
  <p class="text-text-muted mb-8">
    Build <code class="font-mono bg-surface px-1 rounded">http</code> commands visually — no memorizing HTTPie syntax.
    Set your method, URL, query params, headers, authentication, and JSON body, then copy the ready-to-run command.
    Supports Bearer tokens, Basic Auth, API key headers, and JSON item syntax.
  </p>

  <div class="space-y-5" id="httpie-tool">
    <!-- Method + URL -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="font-semibold mb-3 text-sm uppercase tracking-wide text-text-muted">Request</h2>
      <div class="flex gap-3 flex-wrap">
        <select id="method" class="bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40">
          <option>GET</option>
          <option>POST</option>
          <option>PUT</option>
          <option>PATCH</option>
          <option>DELETE</option>
          <option>HEAD</option>
          <option>OPTIONS</option>
        </select>
        <input id="url" type="text" placeholder="https://api.example.com/users" value="https://api.example.com/users"
          class="flex-1 min-w-[200px] bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
      </div>
    </div>

    <!-- Query Params -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Query Params</h2>
        <button id="add-param" class="text-xs text-primary hover:underline">+ Add Param</button>
      </div>
      <div id="params-list" class="space-y-2"></div>
    </div>

    <!-- Headers -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Headers</h2>
        <button id="add-header" class="text-xs text-primary hover:underline">+ Add Header</button>
      </div>
      <div id="headers-list" class="space-y-2"></div>
    </div>

    <!-- Auth -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="font-semibold mb-3 text-sm uppercase tracking-wide text-text-muted">Authentication</h2>
      <div class="flex gap-3 flex-wrap items-start">
        <select id="auth-type" class="bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40">
          <option value="none">None</option>
          <option value="bearer">Bearer Token</option>
          <option value="basic">Basic Auth</option>
          <option value="apikey">API Key Header</option>
        </select>
        <div id="auth-fields" class="flex gap-2 flex-wrap flex-1"></div>
      </div>
    </div>

    <!-- Body -->
    <div class="bg-bg-card border border-border rounded-xl p-5" id="body-section">
      <div class="flex items-center justify-between mb-3">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">JSON Body Items</h2>
        <button id="add-item" class="text-xs text-primary hover:underline">+ Add Item</button>
      </div>
      <p class="text-xs text-text-muted mb-3">HTTPie uses <code class="font-mono bg-bg px-1 rounded">key=value</code> for strings and <code class="font-mono bg-bg px-1 rounded">key:=value</code> for JSON types (numbers, booleans, arrays).</p>
      <div id="items-list" class="space-y-2"></div>
    </div>

    <!-- Options -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="font-semibold mb-3 text-sm uppercase tracking-wide text-text-muted">Options</h2>
      <div class="flex gap-4 flex-wrap text-sm">
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" id="opt-verbose" class="accent-primary" />
          <span><code class="font-mono">--verbose</code> <span class="text-text-muted">(-v)</span></span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" id="opt-follow" class="accent-primary" />
          <span><code class="font-mono">--follow</code> <span class="text-text-muted">(follow redirects)</span></span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" id="opt-verify" class="accent-primary" />
          <span><code class="font-mono">--verify=no</code> <span class="text-text-muted">(skip SSL)</span></span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" id="opt-stream" class="accent-primary" />
          <span><code class="font-mono">--stream</code> <span class="text-text-muted">(streaming)</span></span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" id="opt-download" class="accent-primary" />
          <span><code class="font-mono">--download</code> <span class="text-text-muted">(-d)</span></span>
        </label>
        <div class="flex items-center gap-2">
          <label class="text-sm text-text-muted" for="opt-timeout">--timeout</label>
          <input id="opt-timeout" type="number" placeholder="30" min="1" max="3600"
            class="w-20 bg-bg border border-border rounded px-2 py-1 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          <span class="text-text-muted text-xs">seconds</span>
        </div>
      </div>
    </div>

    <!-- Output -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Generated Command</h2>
        <button id="copy-btn" class="text-xs bg-primary text-white px-3 py-1.5 rounded-lg hover:bg-primary/80 transition-colors">Copy</button>
      </div>
      <pre id="output" class="bg-bg border border-border rounded-lg p-4 text-sm font-mono whitespace-pre-wrap break-all text-green-400 min-h-[60px]"></pre>
    </div>

    <div class="p-4 bg-bg-card border border-border rounded-xl text-xs text-text-muted">
      <strong>Install HTTPie:</strong>
      <code class="font-mono bg-bg px-1 rounded">pip install httpie</code> or
      <code class="font-mono bg-bg px-1 rounded">brew install httpie</code> —
      <a href="https://httpie.io/docs/cli/installation" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">full install docs →</a>
    </div>
  </div>

  <ToolPageCta currentTool="HTTPie Command Builder" relatedTags={['http', 'api', 'curl', 'cli', 'devops']} />
</BaseLayout>

<script is:inline>
(function () {
  let params = [];
  let headers = [];
  let items = [];

  function el(id) { return document.getElementById(id); }

  function mkRow(placeholder1, placeholder2, arr, listId, removeLabel) {
    const idx = arr.length;
    arr.push({ k: '', v: '', type: 'string' });

    const row = document.createElement('div');
    row.className = 'flex gap-2 items-center';
    row.innerHTML = `
      <input type="text" placeholder="${placeholder1}" class="flex-1 bg-bg border border-border rounded-lg px-3 py-1.5 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40 kp" />
      <input type="text" placeholder="${placeholder2}" class="flex-1 bg-bg border border-border rounded-lg px-3 py-1.5 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40 vp" />
      ${listId === 'items-list' ? `<select class="bg-bg border border-border rounded px-2 py-1.5 text-xs tp focus:outline-none"><option value="string">string (=)</option><option value="json">JSON (:=)</option></select>` : ''}
      <button class="text-text-muted hover:text-red-400 text-lg leading-none rm" title="${removeLabel}">×</button>`;

    row.querySelector('.kp').addEventListener('input', e => { arr[idx].k = e.target.value; build(); });
    row.querySelector('.vp').addEventListener('input', e => { arr[idx].v = e.target.value; build(); });
    if (listId === 'items-list') {
      row.querySelector('.tp').addEventListener('change', e => { arr[idx].type = e.target.value; build(); });
    }
    row.querySelector('.rm').addEventListener('click', () => {
      arr.splice(idx, 1);
      el(listId).removeChild(row);
      build();
    });

    el(listId).appendChild(row);
    build();
  }

  function renderAuthFields() {
    const type = el('auth-type').value;
    const f = el('auth-fields');
    f.innerHTML = '';

    if (type === 'bearer') {
      f.innerHTML = `<input id="auth-token" type="text" placeholder="your-token-here" class="flex-1 bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />`;
      el('auth-token').addEventListener('input', build);
    } else if (type === 'basic') {
      f.innerHTML = `
        <input id="auth-user" type="text" placeholder="username" class="bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40 w-36" />
        <input id="auth-pass" type="text" placeholder="password" class="bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40 w-36" />`;
      el('auth-user').addEventListener('input', build);
      el('auth-pass').addEventListener('input', build);
    } else if (type === 'apikey') {
      f.innerHTML = `
        <input id="auth-key-name" type="text" placeholder="X-API-Key" class="bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40 w-40" />
        <input id="auth-key-val" type="text" placeholder="your-api-key" class="flex-1 bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />`;
      el('auth-key-name').addEventListener('input', build);
      el('auth-key-val').addEventListener('input', build);
    }
    build();
  }

  function build() {
    const method = el('method').value;
    const rawUrl = el('url').value.trim() || 'https://api.example.com';
    const authType = el('auth-type').value;
    const verbose = el('opt-verbose').checked;
    const follow = el('opt-follow').checked;
    const verify = el('opt-verify').checked;
    const stream = el('opt-stream').checked;
    const download = el('opt-download').checked;
    const timeout = el('opt-timeout').value.trim();

    const parts = ['http'];

    // options
    if (verbose) parts.push('--verbose');
    if (follow) parts.push('--follow');
    if (verify) parts.push('--verify=no');
    if (stream) parts.push('--stream');
    if (download) parts.push('--download');
    if (timeout) parts.push(`--timeout=${timeout}`);

    // auth
    if (authType === 'bearer') {
      const tok = (el('auth-token') || {}).value || '';
      if (tok) parts.push(`-A bearer -a "${tok}"`);
    } else if (authType === 'basic') {
      const u = (el('auth-user') || {}).value || '';
      const p = (el('auth-pass') || {}).value || '';
      if (u || p) parts.push(`-a "${u}:${p}"`);
    } else if (authType === 'apikey') {
      const kn = (el('auth-key-name') || {}).value || 'X-API-Key';
      const kv = (el('auth-key-val') || {}).value || '';
      if (kv) headers = headers; // handled below
      // API key is added as a header item
    }

    // method
    parts.push(method);

    // build URL with query params
    let url = rawUrl;
    const validParams = params.filter(p => p.k.trim());
    if (validParams.length) {
      const qs = validParams.map(p => `${encodeURIComponent(p.k)}==${encodeURIComponent(p.v)}`).join(' ');
      parts.push(url);
      // params added as httpie items
    } else {
      parts.push(url);
    }

    // query params as httpie items (==)
    validParams.forEach(p => parts.push(`'${p.k}==${p.v}'`));

    // headers
    const validHeaders = headers.filter(h => h.k.trim());
    validHeaders.forEach(h => parts.push(`'${h.k}:${h.v}'`));

    // api key header
    if (authType === 'apikey') {
      const kn = (el('auth-key-name') || {}).value || 'X-API-Key';
      const kv = (el('auth-key-val') || {}).value || '';
      if (kv) parts.push(`'${kn}:${kv}'`);
    }

    // body items
    const validItems = items.filter(i => i.k.trim());
    validItems.forEach(i => {
      const sep = i.type === 'json' ? ':=' : '=';
      parts.push(`${i.k}${sep}'${i.v}'`);
    });

    el('output').textContent = parts.join(' \\\n  ');
  }

  // Wire up events
  el('method').addEventListener('change', build);
  el('url').addEventListener('input', build);
  el('auth-type').addEventListener('change', renderAuthFields);
  el('opt-verbose').addEventListener('change', build);
  el('opt-follow').addEventListener('change', build);
  el('opt-verify').addEventListener('change', build);
  el('opt-stream').addEventListener('change', build);
  el('opt-download').addEventListener('change', build);
  el('opt-timeout').addEventListener('input', build);

  el('add-param').addEventListener('click', () => mkRow('key', 'value', params, 'params-list', 'Remove param'));
  el('add-header').addEventListener('click', () => mkRow('Header-Name', 'value', headers, 'headers-list', 'Remove header'));
  el('add-item').addEventListener('click', () => mkRow('key', 'value', items, 'items-list', 'Remove item'));

  el('copy-btn').addEventListener('click', () => {
    const text = el('output').textContent;
    navigator.clipboard.writeText(text).then(() => {
      const btn = el('copy-btn');
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
    });
  });

  renderAuthFields();
  build();
})();
</script>
