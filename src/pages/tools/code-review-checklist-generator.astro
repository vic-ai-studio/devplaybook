---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What should every code review check?", answer: "Every review should check: correctness (does the logic match the spec?), edge cases (null, empty, overflow, off-by-one), security (injection, auth, data exposure), performance (unnecessary queries, missing indexes, O(n²) where O(n) is needed), readability (names, comments, complexity), and test coverage (is new logic tested?). Use a checklist to ensure nothing is skipped under time pressure." },
  { question: "What is the ideal PR size for review?", answer: "Research by SmartBear found reviewers find 70–90% of defects in PRs under 400 lines. Above 400 lines, defect detection drops and review takes disproportionately longer. Aim for PRs under 300 lines changed. If a feature requires more, split into a stack of dependent PRs: infrastructure → logic → UI → tests." },
  { question: "How should I give code review feedback?", answer: "Use the Conventional Comment format: prefix comments with labels like 'nit: (optional style suggestion)', 'question: (asking for clarification)', 'suggestion: (not blocking)', 'issue: (must fix)', 'blocking: (cannot merge)'. This makes intent clear and reduces misunderstandings. Praise good patterns explicitly — 'nice use of the strategy pattern here'." },
  { question: "What should reviewers NOT do?", answer: "Don't: review for style (use linters/formatters instead), bikeshed on personal preferences, rewrite code in a different style just because you'd write it differently, review the same issue in multiple comments, or delay reviews causing merge conflicts. Do: ask questions not accusations, acknowledge tradeoffs, approve with nits if overall direction is correct." },
  { question: "How do automated tools help code review?", answer: "Automated tools handle objective checks so humans can focus on logic and design: ESLint/TSLint (style, bugs), TypeScript (type safety), Snyk/Dependabot (security), SonarQube (code smells, complexity), Codecov (test coverage), and GitHub Actions (CI tests). A good policy: PRs can only be reviewed by humans after all automated checks pass." },
];
---

<BaseLayout
  title="Code Review Checklist Generator — React, Node.js, Python & More"
  description="Select your tech stack to generate a tailored PR code review checklist. Covers correctness, security, performance, tests, and style. Copy as Markdown for your PR template. Runs in your browser."
  tool="Code Review Checklist Generator, PR review checklist, pull request review, React code review, Node.js review, Python review, security review, code quality"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Code Review Checklist Generator",
    "url": "https://devplaybook.cc/tools/code-review-checklist-generator",
    "description": "Generate a tailored PR code review checklist for React, Node.js, Python, and more. Copy as Markdown. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Code Review Checklist Generator</h1>
  <p class="text-text-muted mb-4">Select your <strong>tech stack and review areas</strong> to generate a tailored code review checklist. Copy as Markdown to paste into your PR template, team wiki, or GitHub PR description.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Stack-specific checks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Universal best practices</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy as Markdown</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Progress tracking</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 mb-6">
    <!-- Config panel -->
    <div class="bg-bg-card border border-border rounded-lg p-4 space-y-4">
      <h2 class="text-sm font-semibold">Configuration</h2>

      <div>
        <label class="block text-xs font-medium text-text-muted mb-2">Tech Stack</label>
        <div id="stack-pills" class="flex flex-wrap gap-2">
          <!-- generated by JS -->
        </div>
      </div>

      <div>
        <label class="block text-xs font-medium text-text-muted mb-2">Review Categories</label>
        <div class="space-y-2" id="category-checks">
          <!-- generated by JS -->
        </div>
      </div>

      <button id="btn-generate" class="w-full px-4 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Generate Checklist</button>
    </div>

    <!-- Checklist -->
    <div class="lg:col-span-2 space-y-4">
      <!-- Progress -->
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm font-semibold">Review Progress</span>
          <span id="review-pct" class="text-sm font-bold text-primary">0%</span>
        </div>
        <div class="w-full bg-bg-page border border-border rounded-full h-2.5 overflow-hidden mb-1">
          <div id="review-bar" class="h-2.5 rounded-full bg-primary transition-all duration-300" style="width:0%"></div>
        </div>
        <p id="review-count" class="text-xs text-text-muted">0 of 0 items checked</p>
      </div>

      <!-- Generated checklist -->
      <div id="checklist-output" class="bg-bg-card border border-border rounded-lg p-4">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold">Checklist</h2>
          <div class="flex gap-2">
            <button id="btn-copy-md" class="hidden px-3 py-1.5 bg-bg-page border border-border rounded text-xs hover:border-primary transition-colors">Copy Markdown</button>
            <button id="btn-reset" class="hidden px-3 py-1.5 bg-bg-page border border-border rounded text-xs hover:border-primary transition-colors">Reset</button>
          </div>
        </div>
        <p class="text-xs text-text-muted italic">Select a stack and click Generate.</p>
      </div>
    </div>
  </div>

  <ToolPageCta currentTool="Code Review Checklist Generator" relatedTags={['code-review', 'github', 'pull-request', 'best-practices', 'team']} />
  <FaqSection faq={faq} />
</BaseLayout>

<script>
const STACKS = ['React', 'Node.js', 'Python', 'TypeScript', 'Go', 'SQL', 'Docker', 'API'];
const CATEGORIES = ['Correctness', 'Security', 'Performance', 'Tests', 'Readability', 'Documentation'];

const UNIVERSAL_ITEMS: Record<string, string[]> = {
  Correctness: [
    'Logic matches the ticket/spec requirements',
    'Edge cases handled: null, undefined, empty, zero, negative',
    'Error cases handled with appropriate messages',
    'No off-by-one errors in loops or array access',
    'Return types are consistent and well-defined',
    'Race conditions / concurrency issues considered',
  ],
  Security: [
    'No secrets, tokens, or credentials hardcoded',
    'User input is validated and sanitized',
    'Authentication and authorization checks in place',
    'No SQL injection vulnerabilities (use parameterized queries)',
    'No path traversal or file inclusion vulnerabilities',
    'Dependencies have no known CVEs (check npm audit / pip-audit)',
  ],
  Performance: [
    'No unnecessary database queries in loops (N+1 problem)',
    'Expensive operations are memoized or cached where appropriate',
    'Large data sets are paginated, not loaded all at once',
    'No blocking synchronous I/O in async context',
    'New indexes added for new query patterns',
  ],
  Tests: [
    'New code has corresponding unit tests',
    'Happy path tested',
    'Edge cases and error cases tested',
    'Tests are deterministic (no random or time-dependent behavior)',
    'Test names clearly describe what they test',
    'No test-only code left in production files',
  ],
  Readability: [
    'Variable and function names are descriptive and accurate',
    'Functions do one thing (single responsibility)',
    'No deep nesting (arrow antipattern)',
    'Magic numbers extracted to named constants',
    'Complex logic has inline comments explaining WHY',
    'Dead code removed (no commented-out code)',
  ],
  Documentation: [
    'Public API / function signatures are documented',
    'README updated if setup steps changed',
    'CHANGELOG entry added if user-facing behavior changed',
    'Breaking changes are documented and migration path provided',
  ],
};

const STACK_ITEMS: Record<string, Record<string, string[]>> = {
  React: {
    Correctness: ['useEffect dependencies array is complete and correct', 'State mutations done via setters only', 'Conditional rendering handles loading/error/empty states'],
    Performance: ['Component memoization (memo, useMemo, useCallback) used appropriately', 'Keys in list renders are stable and unique (not array index)', 'Large components are lazy-loaded with React.lazy/Suspense'],
    Security: ['dangerouslySetInnerHTML only used with sanitized content', 'User-supplied URLs validated before href/src use'],
    Tests: ['Components tested with React Testing Library', 'User interactions tested (fireEvent/userEvent)', 'Async state changes awaited correctly in tests'],
    Readability: ['Custom hooks extracted for reusable stateful logic', 'Props interfaces/types defined (TypeScript)', 'Component files under 200 lines'],
    Documentation: [],
  },
  'Node.js': {
    Correctness: ['All async functions awaited or properly chained', 'Express error handler registered', 'Environment variables validated at startup'],
    Performance: ['Database connections pooled (not per-request)', 'Streams used for large file/data processing', 'CPU-intensive work offloaded to worker threads or queues'],
    Security: ['Helmet.js or equivalent security headers set', 'Rate limiting applied to public endpoints', 'Express body size limited', 'CORS configured correctly'],
    Tests: ['Integration tests use real DB / test DB, not mocks', 'HTTP endpoints tested with supertest', 'Error paths tested'],
    Readability: [],
    Documentation: ['API endpoints documented (OpenAPI/Swagger)'],
  },
  Python: {
    Correctness: ['Type hints used and consistent', 'Exceptions caught specifically (not bare except)', 'Context managers used for file/resource handling'],
    Performance: ['List comprehensions preferred over loops for transformations', 'Generator expressions used for large iterations', 'Database ORM N+1 avoided (select_related/prefetch_related)'],
    Security: ['SQL queries use parameterized placeholders, not f-strings', 'pickle not used with untrusted data', 'subprocess called with shell=False'],
    Tests: ['pytest fixtures used for setup/teardown', 'Mocks scoped correctly with monkeypatch', 'Coverage ≥ 80% for new modules'],
    Readability: ['PEP 8 followed', 'Docstrings on public functions/classes', 'Functions under 30 lines'],
    Documentation: ['Module-level docstring present', 'Arguments and return types documented'],
  },
  TypeScript: {
    Correctness: ['No `as any` casts without justification', 'No `@ts-ignore` or `@ts-expect-error` without comment', 'Discriminated unions used for complex state'],
    Performance: [],
    Security: ['External API responses validated with Zod or similar at runtime boundary'],
    Tests: [],
    Readability: ['Utility types used (Partial, Required, Pick, Omit, Record)', 'No `object` or `{}` as catch-all types', 'Enums vs string unions: consistent choice per domain'],
    Documentation: ['JSDoc types on exported functions'],
  },
  Go: {
    Correctness: ['All errors returned, not ignored with _', 'Context cancellation propagated correctly', 'Goroutine leaks checked (deferred cancel calls)'],
    Performance: ['Slice pre-allocated with make([]T, 0, cap) when size known', 'String concatenation uses strings.Builder for loops'],
    Security: ['SQL uses database/sql placeholders ($1, ?)', 'http.Client has timeouts set', 'User input sanitized for paths and commands'],
    Tests: ['Table-driven tests used', 'Subtests named descriptively with t.Run', 'Race detector: go test -race'],
    Readability: ['golangci-lint passes with no new warnings', 'Exported functions have godoc comments'],
    Documentation: [],
  },
  SQL: {
    Correctness: ['Joins use appropriate type (INNER, LEFT, etc.)', 'NULL handling explicit (IS NULL, COALESCE)', 'Transactions used for multi-step mutations', 'Foreign key constraints in place'],
    Performance: ['New columns used in WHERE/JOIN have indexes', 'SELECT * avoided — explicit column list', 'EXPLAIN/ANALYZE checked for slow queries', 'Pagination uses keyset pagination for large tables'],
    Security: ['Dynamic SQL uses parameterized queries', 'Row-level security applied where needed', 'Sensitive columns encrypted or hashed'],
    Tests: ['Migrations run in both directions (up/down)', 'Schema changes tested in staging before prod'],
    Readability: ['SQL keywords uppercase, table/column names snake_case', 'Complex queries have inline comments'],
    Documentation: ['Schema changes documented in migration file comment'],
  },
  Docker: {
    Correctness: ['Multi-stage build used to minimize final image', 'Non-root user set in Dockerfile', 'ENTRYPOINT vs CMD distinction clear'],
    Performance: ['Layer order optimized (rarely changed layers first)', 'Build cache busting minimized', '.dockerignore file present and comprehensive'],
    Security: ['Base image is pinned to a specific digest or tag', 'No secrets in ENV or COPY layers', 'Trivy or Snyk scan passes', 'Image size under acceptable limit'],
    Tests: ['Container starts and passes health check'],
    Readability: ['Dockerfile has comments for non-obvious commands'],
    Documentation: ['Docker Compose or K8s manifests updated if needed'],
  },
  API: {
    Correctness: ['HTTP status codes semantically correct (201 for create, 204 for delete, etc.)', 'Pagination implemented for list endpoints', 'Response schema consistent with existing API patterns'],
    Performance: ['Response time under 200ms for P95', 'Caching headers set appropriately (Cache-Control, ETag)', 'Unnecessary data not included in responses'],
    Security: ['Auth required on all private endpoints', 'Rate limiting applied', 'CORS headers correct', 'Input validation returns 400 not 500'],
    Tests: ['All new endpoints have integration tests', 'Auth failure path tested (403)', 'Input validation tested with bad data'],
    Readability: ['Endpoint naming follows REST conventions', 'Error responses have consistent structure'],
    Documentation: ['OpenAPI spec updated', 'Postman/Bruno collection updated'],
  },
};

// State
const selectedStacks = new Set<string>(['React', 'TypeScript']);
const selectedCategories = new Set<string>(CATEGORIES);
let generatedSections: { title: string; items: string[] }[] = [];
const checked = new Map<string, boolean>();

function renderConfig() {
  const pillsEl = document.getElementById('stack-pills')!;
  pillsEl.innerHTML = STACKS.map(s => `
    <button class="stack-pill px-3 py-1.5 rounded-full text-xs font-semibold border transition-colors ${selectedStacks.has(s) ? 'bg-primary text-white border-primary' : 'bg-bg-page border-border text-text-muted hover:border-primary'}" data-stack="${s}">${s}</button>
  `).join('');

  const catEl = document.getElementById('category-checks')!;
  catEl.innerHTML = CATEGORIES.map(c => `
    <label class="flex items-center gap-2 cursor-pointer">
      <input type="checkbox" class="cat-cb w-4 h-4 rounded accent-primary" data-cat="${c}" ${selectedCategories.has(c) ? 'checked' : ''} />
      <span class="text-sm">${c}</span>
    </label>
  `).join('');

  document.querySelectorAll('.stack-pill').forEach(btn => {
    btn.addEventListener('click', () => {
      const s = (btn as HTMLElement).dataset.stack!;
      if (selectedStacks.has(s)) selectedStacks.delete(s);
      else selectedStacks.add(s);
      renderConfig();
    });
  });

  document.querySelectorAll('.cat-cb').forEach(cb => {
    cb.addEventListener('change', () => {
      const c = (cb as HTMLElement).dataset.cat!;
      if ((cb as HTMLInputElement).checked) selectedCategories.add(c);
      else selectedCategories.delete(c);
    });
  });
}

function generate() {
  generatedSections = [];
  checked.clear();

  for (const cat of CATEGORIES) {
    if (!selectedCategories.has(cat)) continue;
    const items: string[] = [...UNIVERSAL_ITEMS[cat]];
    for (const stack of selectedStacks) {
      const stackItems = STACK_ITEMS[stack]?.[cat] || [];
      for (const item of stackItems) {
        if (!items.includes(item)) items.push(item);
      }
    }
    if (items.length) generatedSections.push({ title: cat, items });
  }

  renderChecklist();
  document.getElementById('btn-copy-md')?.classList.remove('hidden');
  document.getElementById('btn-reset')?.classList.remove('hidden');
}

function updateProgress() {
  const total = [...checked.keys()].length;
  const done = [...checked.values()].filter(Boolean).length;
  const pct = total > 0 ? Math.round(done / total * 100) : 0;
  document.getElementById('review-pct')!.textContent = `${pct}%`;
  document.getElementById('review-bar')!.style.width = `${pct}%`;
  document.getElementById('review-count')!.textContent = `${done} of ${total} items checked`;
}

function renderChecklist() {
  const container = document.getElementById('checklist-output')!;

  const ICONS: Record<string, string> = { Correctness: '✓', Security: '🔒', Performance: '⚡', Tests: '🧪', Readability: '📖', Documentation: '📝' };

  const html = generatedSections.map(sec => `
    <div class="mb-5">
      <h3 class="text-sm font-semibold mb-2.5 flex items-center gap-2">
        <span>${ICONS[sec.title] || '•'}</span> ${sec.title}
      </h3>
      <div class="space-y-1.5">
        ${sec.items.map((item, i) => {
          const key = `${sec.title}-${i}`;
          if (!checked.has(key)) checked.set(key, false);
          return `<label class="flex items-start gap-2.5 cursor-pointer group">
            <input type="checkbox" class="review-cb mt-0.5 w-4 h-4 rounded accent-green-500 cursor-pointer flex-shrink-0" data-key="${key}" />
            <span class="text-sm group-hover:text-foreground transition-colors">${item}</span>
          </label>`;
        }).join('')}
      </div>
    </div>
  `).join('');

  const inner = container.querySelector('.checklist-inner') || (() => {
    const d = document.createElement('div');
    d.className = 'checklist-inner';
    return d;
  })();

  const headerEl = container.querySelector('div.flex.items-center.justify-between')!;
  container.innerHTML = '';
  container.appendChild(headerEl.cloneNode(true) as HTMLElement);
  inner.innerHTML = html;
  container.appendChild(inner);

  // Re-attach header buttons
  container.querySelector('#btn-copy-md')?.remove();
  container.querySelector('#btn-reset')?.remove();
  const hdr = container.querySelector('.flex.items-center.justify-between') as HTMLElement;
  hdr.innerHTML = `
    <h2 class="text-sm font-semibold">Checklist <span class="text-text-muted text-xs">(${generatedSections.reduce((a, s) => a + s.items.length, 0)} items)</span></h2>
    <div class="flex gap-2">
      <button id="btn-copy-md" class="px-3 py-1.5 bg-bg-page border border-border rounded text-xs hover:border-primary transition-colors">Copy Markdown</button>
      <button id="btn-reset" class="px-3 py-1.5 bg-bg-page border border-border rounded text-xs hover:border-primary transition-colors">Reset</button>
    </div>`;

  document.querySelectorAll('.review-cb').forEach(cb => {
    cb.addEventListener('change', () => {
      checked.set((cb as HTMLElement).dataset.key!, (cb as HTMLInputElement).checked);
      // Strike-through
      const label = (cb as HTMLElement).closest('label')!;
      const span = label.querySelector('span')!;
      span.classList.toggle('line-through', (cb as HTMLInputElement).checked);
      span.classList.toggle('text-text-muted', (cb as HTMLInputElement).checked);
      updateProgress();
    });
  });

  document.getElementById('btn-copy-md')?.addEventListener('click', copyMarkdown);
  document.getElementById('btn-reset')?.addEventListener('click', () => {
    document.querySelectorAll('.review-cb').forEach(cb => {
      (cb as HTMLInputElement).checked = false;
    });
    checked.forEach((_, k) => checked.set(k, false));
    document.querySelectorAll('.review-cb').forEach(cb => {
      const label = (cb as HTMLElement).closest('label')!;
      label.querySelector('span')!.classList.remove('line-through', 'text-text-muted');
    });
    updateProgress();
  });

  updateProgress();
}

function copyMarkdown() {
  const stackList = [...selectedStacks].join(', ') || 'General';
  const lines = [`# Code Review Checklist — ${stackList}\n`];
  for (const sec of generatedSections) {
    lines.push(`## ${sec.title}\n`);
    for (const item of sec.items) lines.push(`- [ ] ${item}`);
    lines.push('');
  }
  navigator.clipboard.writeText(lines.join('\n')).then(() => {
    const btn = document.getElementById('btn-copy-md')!;
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = 'Copy Markdown'; }, 2000);
  });
}

renderConfig();
document.getElementById('btn-generate')?.addEventListener('click', generate);
generate(); // auto-generate with defaults
</script>
