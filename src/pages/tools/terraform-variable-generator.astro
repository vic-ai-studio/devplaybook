---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TerraformVariableGenerator from '../../components/TerraformVariableGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What does this tool generate?",
    answer: "This tool generates two files: variables.tf (the variable declarations with type, description, default, sensitive flag, and optional validation blocks) and terraform.tfvars (the variable value assignments). These are the standard Terraform files for defining and setting input variables."
  },
  {
    question: "What Terraform variable types are supported?",
    answer: "All primitive types: string, number, bool. Collection types: list(string), list(number), map(string), set(string). And 'any' for untyped variables. For complex nested types like object({}) or tuple([]), you can type them manually in the HCL default value field."
  },
  {
    question: "What is the difference between variables.tf and terraform.tfvars?",
    answer: "variables.tf declares the variables — their name, type, description, default, and validation rules. It's part of your module's interface and should be committed to source control. terraform.tfvars provides actual values for those variables. For sensitive or environment-specific values, use a .tfvars file that is gitignored, or pass values via environment variables (TF_VAR_name) or -var flags."
  },
  {
    question: "What does 'sensitive = true' do?",
    answer: "Marking a variable as sensitive tells Terraform to redact its value in plan output, apply output, and state file display. The value is still stored in state, but Terraform won't print it in logs. This is recommended for passwords, API keys, and private keys. You should still encrypt your state backend (S3 + KMS, Terraform Cloud) for full protection."
  },
  {
    question: "How do validation blocks work?",
    answer: "Validation blocks (introduced in Terraform 0.13) let you add custom constraints to variables. The 'condition' is a Terraform expression that must evaluate to true for the value to be accepted — you can use var.<name> to reference the variable being validated. The 'error_message' is shown when validation fails. Example: condition = var.instance_count >= 1 && var.instance_count <= 100."
  },
  {
    question: "What is the correct HCL format for default values?",
    answer: "String defaults must be quoted: \"us-east-1\". Number defaults are plain: 42. Boolean defaults: true or false. List defaults: [\"a\", \"b\", \"c\"]. Map defaults: { key = \"value\" }. Set defaults use the same syntax as list. Leave the default field empty for required variables (no default means Terraform will prompt for the value or error if not provided)."
  },
];
---

<BaseLayout
  title="Terraform Variable Generator — Build variables.tf & terraform.tfvars"
  description="Generate Terraform variable declarations and value files from a form. Add variables with type, description, default values, sensitive flag, and validation blocks. Instantly get ready-to-use variables.tf and terraform.tfvars output. Free, runs in your browser."
  tool="Terraform Variable Generator, variables.tf Generator, terraform.tfvars Builder, Terraform HCL Variables, Terraform Input Variables, IaC Variable Builder"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Terraform Variable Generator",
    "url": "https://devplaybook.cc/tools/terraform-variable-generator",
    "description": "Generate Terraform variables.tf declarations and terraform.tfvars value files from a form. Supports all types, sensitive flag, defaults, and validation blocks.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Terraform Variable Generator</h1>
  <p class="text-text-muted mb-4">
    Define your Terraform input variables using the form and instantly get the corresponding
    <code class="font-mono bg-surface px-1 rounded text-sm">variables.tf</code> and
    <code class="font-mono bg-surface px-1 rounded text-sm">terraform.tfvars</code> output.
    Supports all primitive and collection types, sensitive values, default values, and validation blocks.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All Terraform variable types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Validation block support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> variables.tf + terraform.tfvars</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <TerraformVariableGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Terraform Variable Generator" relatedTags={['terraform', 'devops', 'infrastructure', 'iac', 'cloud', 'developer-tools']} />
</BaseLayout>
