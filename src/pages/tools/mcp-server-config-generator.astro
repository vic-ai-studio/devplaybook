---
import BaseLayout from '../../layouts/BaseLayout.astro';
import McpServerConfigGenerator from '../../components/McpServerConfigGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is MCP (Model Context Protocol)?",
    answer: "MCP (Model Context Protocol) is an open standard developed by Anthropic that lets AI assistants like Claude connect to external tools, data sources, and services. Think of it as a universal plugin system for AI — instead of hardcoding integrations, MCP lets AI clients discover and call server-defined tools at runtime. This tool generates the JSON configuration that tells your AI client which MCP servers to load on startup."
  },
  {
    question: "Where is the claude_desktop_config.json file located?",
    answer: "On macOS, the file lives at ~/Library/Application Support/Claude/claude_desktop_config.json. On Windows, it's at %APPDATA%\\Claude\\claude_desktop_config.json (typically C:\\Users\\YourName\\AppData\\Roaming\\Claude\\). On Linux, check ~/.config/Claude/claude_desktop_config.json. You can also find it via Claude Desktop → Settings → Developer → Edit Config, which opens the file directly in your editor."
  },
  {
    question: "What is the difference between stdio and SSE transport?",
    answer: "stdio (standard input/output) is the most common transport: the AI client launches the MCP server as a subprocess and communicates via stdin/stdout pipes. This works great for local servers installed via npm, Python, or other runtimes. SSE (Server-Sent Events) connects to a remote HTTP server instead — useful for shared servers, cloud-hosted MCP services, or servers that need to stay running independently. For local development, stdio is usually simpler; for production services, SSE is preferred."
  },
  {
    question: "How do I add environment variables to an MCP server config?",
    answer: "In the stdio transport section, click '+ env var' to add key-value pairs. These become the env object in the JSON config, which the AI client passes to the server process as environment variables. This is the recommended way to provide API keys and secrets to MCP servers — never hardcode secrets in the args array. Example: set GITHUB_TOKEN as a key with your personal access token as the value for the GitHub MCP server."
  },
  {
    question: "What are some commonly used MCP servers?",
    answer: "The official Anthropic MCP repository includes servers for: filesystem (read/write local files), GitHub (repos, issues, PRs), PostgreSQL and SQLite (database queries), Brave Search and Fetch (web search), Memory (persistent key-value store), Puppeteer (browser automation), Slack (messaging), and Google Drive. The community has built hundreds more. Install most via npx -y @modelcontextprotocol/server-name. Browse the full list at github.com/modelcontextprotocol/servers."
  },
  {
    question: "Does this tool work for Cursor, Continue, and Windsurf too?",
    answer: "Yes — switch the Target Client selector to generate config for Cursor (~/.cursor/mcp.json), Continue (~/.continue/config.json), or Windsurf (~/.codeium/windsurf/mcp_config.json). The mcpServers JSON structure is identical across all clients since they all follow the MCP specification. Only the file location differs. The 'File Path' tab shows where to save the config for each client and includes setup instructions."
  },
];
---

<BaseLayout
  title="MCP Server Config Generator — Claude Desktop & AI Client Config Builder"
  description="Generate MCP (Model Context Protocol) server configuration for Claude Desktop, Cursor, and other AI clients. Add stdio and SSE servers, configure args and env vars. Free, runs in browser."
  tool="MCP Server Config Generator, Claude Desktop Config, Model Context Protocol, MCP Config Builder, claude_desktop_config.json"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">MCP Server Config Generator</h1>
  <p class="text-text-muted mb-4">
    Build your <code class="font-mono text-sm bg-surface px-1 rounded">mcpServers</code> configuration for Claude Desktop, Cursor, Continue, or Windsurf. Add stdio and SSE servers, configure arguments and environment variables, then copy the JSON directly into your config file. Runs entirely in your browser — no data sent anywhere.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Claude Desktop, Cursor, Continue, Windsurf</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> stdio &amp; SSE transports</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Args + env var builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> File path guide included</span>
  </div>

  <McpServerConfigGenerator client:only="preact" />

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="MCP Server Config Generator" relatedTags={['mcp', 'claude', 'ai', 'developer-tools', 'configuration', 'model-context-protocol']} />
</BaseLayout>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "MCP Server Config Generator",
  "description": "Generate MCP (Model Context Protocol) server configuration for Claude Desktop, Cursor, and other AI clients. Add stdio and SSE servers, configure args and env vars.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "url": "https://devplaybook.cc/tools/mcp-server-config-generator"
}
</script>
