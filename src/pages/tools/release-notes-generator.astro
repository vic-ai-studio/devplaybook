---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What makes good release notes?",
    answer: "Good release notes answer three questions a user cares about: What is new (new features)? What is fixed (bugs resolved)? Does anything break (breaking changes)? Structure matters: group changes by type (Features, Bug Fixes, Breaking Changes), include a short summary at the top, link to relevant issues or PRs for context, and provide a migration path for breaking changes. Avoid developer jargon — write for the person upgrading, not the person who wrote the code."
  },
  {
    question: "What is Conventional Commits and why does it enable automation?",
    answer: "Conventional Commits is a specification for structuring commit messages: type(scope): description. The type encodes intent — feat for new features, fix for bug fixes, docs for documentation. Release tools parse these types to determine version bumps and categorize changes automatically. Without a consistent commit format, every release requires manual curation. With Conventional Commits, releasing becomes a single command that reads git log, determines the version, and generates formatted notes."
  },
  {
    question: "How do I set up semantic-release in a GitHub Actions workflow?",
    answer: "Install semantic-release: npm install --save-dev semantic-release @semantic-release/git @semantic-release/changelog. Create a release.config.js or add a 'release' key in package.json. In your GitHub Actions workflow, add a release job that runs on main with: npx semantic-release. semantic-release needs a GITHUB_TOKEN with write access to create releases. It automatically reads commits since the last tag, determines the version bump, publishes to npm (if configured), creates a GitHub Release, and updates CHANGELOG.md."
  },
  {
    question: "What is the difference between semantic-release and release-please?",
    answer: "Both automate releases from Conventional Commits, but with different philosophies. semantic-release runs on every merge to main and releases immediately if there are releasable commits. release-please creates a Release PR that accumulates all pending changes — you control when the release actually happens by merging the PR. Use semantic-release for fully automated, continuous release pipelines (npm libraries). Use release-please when you want a human to approve the release timing (apps, teams with release windows, Google-style projects)."
  },
  {
    question: "How do I maintain a CHANGELOG.md manually?",
    answer: "Follow the Keep a Changelog format: each release gets a section with version and date header. Organize entries under Added, Changed, Deprecated, Removed, Fixed, Security subsections. Keep an [Unreleased] section at the top that accumulates changes since the last release. When you cut a release, rename [Unreleased] to the version and date, and create a new empty [Unreleased] section. Link version headers to git comparison URLs (e.g., github.com/owner/repo/compare/v1.0.0...v1.1.0) for diff visibility."
  },
  {
    question: "Can I use these tools in a monorepo with multiple packages?",
    answer: "Yes. release-please has first-class monorepo support — configure it to release each package independently with separate changelogs and version numbers using release-type per directory in release-please-config.json. semantic-release supports monorepos via the @semantic-release/exec plugin or multi-semantic-release. Nx and Turborepo both have release tooling built in. For simple monorepos, Changesets (by the Remix/Preconstruct team) is purpose-built for independently versioning multiple packages with human-authored change descriptions."
  }
];
---

<BaseLayout
  title="Release Notes Generator: Conventional Commits & CHANGELOG Guide"
  description="Automate release notes with Conventional Commits, semantic-release, and release-please. Covers CHANGELOG.md maintenance, GitHub Releases automation, and semantic-release vs release-please comparison."
  tool="release notes generator, CHANGELOG, semantic-release, release-please, conventional commits, standard-version"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"Release Notes Generator: Conventional Commits & CHANGELOG Guide","url":"https://devplaybook.cc/tools/release-notes-generator","description":"Complete guide to automating release notes using Conventional Commits, semantic-release, release-please, and CHANGELOG.md maintenance."})} />

  <h1 class="text-3xl font-bold mb-2">Release Notes Generator: Conventional Commits & CHANGELOG Guide</h1>
  <p class="text-text-muted mb-6">Writing release notes manually is time-consuming and inconsistently done under release pressure. Conventional Commits combined with automation tools like semantic-release and release-please turn your git history into structured release notes automatically — so your changelogs are always accurate, up to date, and require no extra effort on release day.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Conventional Commits → release notes mapping</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> semantic-release setup guide</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> release-please configuration</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CHANGELOG.md maintenance</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> semantic-release vs release-please comparison</span>
  </div>

  <ToolPageCta />

  <div class="mt-8 space-y-8">

    <section>
      <h2 class="text-2xl font-bold mb-3">Conventional Commits → Release Notes Mapping</h2>
      <p class="text-text-muted mb-4">Conventional Commits encode intent in the commit message. Release tools read these types and map them to version bumps and changelog sections automatically.</p>
      <pre class="bg-bg-card border border-gray-700 rounded-lg p-4 overflow-x-auto text-sm font-mono text-gray-300"><code># Commit format: type(scope): short description
#
# BREAKING CHANGE → MAJOR bump → "Breaking Changes" section
feat!: migrate authentication to OAuth 2.0
# or with footer:
feat(auth): add OAuth 2.0 support

BREAKING CHANGE: Basic auth is no longer supported. Migrate to OAuth tokens.

# feat → MINOR bump → "Features" section
feat(api): add bulk user import endpoint
feat: support dark mode in dashboard

# fix → PATCH bump → "Bug Fixes" section
fix(auth): prevent session timeout on active use
fix: correct timezone handling in date picker

# perf → PATCH bump → "Performance Improvements" section
perf(db): add index on users.email column

# These types produce PATCH but often appear in notes:
refactor: extract validation logic to separate module
docs: add API authentication examples

# These types are typically excluded from release notes:
test: add edge case coverage for date parsing
chore: upgrade dev dependencies
ci: cache npm dependencies in GitHub Actions</code></pre>
    </section>

    <section>
      <h2 class="text-2xl font-bold mb-3">semantic-release GitHub Actions Setup</h2>
      <p class="text-text-muted mb-4">semantic-release is fully automated — it runs on every merge to main, determines if a release is needed, bumps the version, updates CHANGELOG.md, creates a GitHub Release, and optionally publishes to npm. Zero manual steps after setup.</p>
      <pre class="bg-bg-card border border-gray-700 rounded-lg p-4 overflow-x-auto text-sm font-mono text-gray-300"><code># .github/workflows/release.yml
name: Release
on:
  push:
    branches: [main]

jobs:
  release:
    runs-on: ubuntu-latest
    permissions:
      contents: write
      issues: write
      pull-requests: write
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0    # full history required for semantic-release
          persist-credentials: false
      - uses: actions/setup-node@v4
        with: &#123; node-version: '20' &#125;
      - run: npm ci
      - run: npx semantic-release
        env:
          GITHUB_TOKEN: $&#123;&#123; secrets.GITHUB_TOKEN &#125;&#125;
          NPM_TOKEN: $&#123;&#123; secrets.NPM_TOKEN &#125;&#125;   # omit if not publishing to npm

# release.config.js
module.exports = &#123;
  branches: ['main'],
  plugins: [
    '@semantic-release/commit-analyzer',
    '@semantic-release/release-notes-generator',
    ['@semantic-release/changelog', &#123; changelogFile: 'CHANGELOG.md' &#125;],
    '@semantic-release/npm',
    ['@semantic-release/git', &#123;
      assets: ['CHANGELOG.md', 'package.json'],
      message: 'chore(release): $&#123;nextRelease.version&#125; [skip ci]'
    &#125;],
    '@semantic-release/github',
  ],
&#125;;</code></pre>
    </section>

    <section>
      <h2 class="text-2xl font-bold mb-3">release-please: PR-Based Release Workflow</h2>
      <p class="text-text-muted mb-4">release-please creates a Release PR that accumulates all pending changes. You decide when to release by merging the PR — giving you control over timing while keeping the preparation work automated.</p>
      <pre class="bg-bg-card border border-gray-700 rounded-lg p-4 overflow-x-auto text-sm font-mono text-gray-300"><code># .github/workflows/release-please.yml
name: Release Please
on:
  push:
    branches: [main]

jobs:
  release-please:
    runs-on: ubuntu-latest
    steps:
      - uses: googleapis/release-please-action@v4
        id: release
        with:
          release-type: node
          token: $&#123;&#123; secrets.GITHUB_TOKEN &#125;&#125;

      # Steps below only run when the Release PR is merged (a release happens)
      - uses: actions/checkout@v4
        if: $&#123;&#123; steps.release.outputs.release_created &#125;&#125;
      - uses: actions/setup-node@v4
        if: $&#123;&#123; steps.release.outputs.release_created &#125;&#125;
        with:
          node-version: '20'
          registry-url: 'https://registry.npmjs.org'
      - run: npm ci && npm publish
        if: $&#123;&#123; steps.release.outputs.release_created &#125;&#125;
        env:
          NODE_AUTH_TOKEN: $&#123;&#123; secrets.NPM_TOKEN &#125;&#125;</code></pre>
    </section>

    <section>
      <h2 class="text-2xl font-bold mb-4">semantic-release vs release-please Comparison</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="border-b border-gray-700">
              <th class="text-left py-3 px-4 text-gray-300 font-semibold">Dimension</th>
              <th class="text-left py-3 px-4 text-gray-300 font-semibold">semantic-release</th>
              <th class="text-left py-3 px-4 text-gray-300 font-semibold">release-please</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-700/50 hover:bg-gray-800/30">
              <td class="py-3 px-4 text-gray-300">Release trigger</td>
              <td class="py-3 px-4 text-gray-400">Fully automatic on merge to main</td>
              <td class="py-3 px-4 text-gray-400">Manual: merge the Release PR</td>
            </tr>
            <tr class="border-b border-gray-700/50 hover:bg-gray-800/30">
              <td class="py-3 px-4 text-gray-300">Release PR</td>
              <td class="py-3 px-4 text-gray-400">No — releases immediately</td>
              <td class="py-3 px-4 text-gray-400">Yes — accumulates in a PR</td>
            </tr>
            <tr class="border-b border-gray-700/50 hover:bg-gray-800/30">
              <td class="py-3 px-4 text-gray-300">Monorepo support</td>
              <td class="py-3 px-4 text-gray-400">Via plugins (multi-semantic-release)</td>
              <td class="py-3 px-4 text-gray-400">Native (release-please-config.json)</td>
            </tr>
            <tr class="border-b border-gray-700/50 hover:bg-gray-800/30">
              <td class="py-3 px-4 text-gray-300">Plugin ecosystem</td>
              <td class="py-3 px-4 text-gray-400">Rich (npm, GitHub, GitLab, Slack...)</td>
              <td class="py-3 px-4 text-gray-400">Focused (GitHub Releases)</td>
            </tr>
            <tr class="border-b border-gray-700/50 hover:bg-gray-800/30">
              <td class="py-3 px-4 text-gray-300">Setup complexity</td>
              <td class="py-3 px-4 text-gray-400">Medium (release.config.js)</td>
              <td class="py-3 px-4 text-gray-400">Low (one action, minimal config)</td>
            </tr>
            <tr class="hover:bg-gray-800/30">
              <td class="py-3 px-4 text-gray-300">Best for</td>
              <td class="py-3 px-4 text-gray-400">npm libraries, continuous delivery</td>
              <td class="py-3 px-4 text-gray-400">Apps, monorepos, controlled cadence</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

  </div>

  <FaqSection faq={faq} />
</BaseLayout>
