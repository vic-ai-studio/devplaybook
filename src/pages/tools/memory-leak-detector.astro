---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MemoryLeakDetector from '../../components/MemoryLeakDetector.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What causes JavaScript memory leaks in React apps?",
    answer: "The most common sources: (1) event listeners added in useEffect without cleanup (removeEventListener in return function), (2) setInterval/setTimeout not cleared, (3) subscriptions to observables, WebSockets, or EventEmitters without unsubscribing, (4) setState/dispatch called after component unmount in async callbacks, (5) closures that reference large objects preventing garbage collection, (6) global caches (window.myCache) growing without bounds."
  },
  {
    question: "How do I detect memory leaks with Chrome DevTools?",
    answer: "Open DevTools → Memory tab. Method 1 - Heap Snapshot: take a snapshot, perform actions, take another snapshot, compare 'Objects allocated between snapshots' to find growing objects. Method 2 - Allocation Timeline: record while performing repeated actions, look for object counts that grow each iteration but never shrink. Method 3 - Performance Monitor: watch JS heap size in real time — it should fluctuate but trend flat, not steadily upward."
  },
  {
    question: "Why does setState after unmount cause memory leaks?",
    answer: "When a component unmounts, React expects it to clean up. If an async operation (fetch, setTimeout) completes after unmount and calls setState, React can't update a non-existent component. Before React 18, this caused the warning 'Can't perform a React state update on an unmounted component'. While React 18 removed the warning, the underlying issue remains: the component isn't garbage collected until all async references to it are resolved, causing a temporary memory leak."
  },
  {
    question: "How does AbortController prevent memory leaks in fetch?",
    answer: "AbortController creates a signal that can cancel a fetch request. When passed to fetch({ signal: controller.signal }), aborting the controller cancels the HTTP request and causes the Promise to reject with AbortError. In useEffect cleanup (return function), call controller.abort() — this cancels any in-flight request when the component unmounts, preventing the then() callbacks from running and setState from being called on an unmounted component."
  },
  {
    question: "What are WeakMap and WeakSet and how do they prevent memory leaks?",
    answer: "WeakMap and WeakSet hold 'weak references' to their keys — if no other code holds a reference to the key object, it can be garbage collected even if it's still a key in the WeakMap. This prevents the common pattern of module-level caches holding DOM nodes or component instances indefinitely. Use WeakMap for object-keyed caches: const cache = new WeakMap(); cache.set(element, computedData). When element is removed from DOM and dereferenced, its cache entry is automatically eligible for GC."
  },
  {
    question: "How do I find memory leaks in a production Next.js app?",
    answer: "Monitor heap usage with Node.js: process.memoryUsage().heapUsed in a /api/health endpoint or PM2 monitoring. Use node --inspect and Chrome DevTools remote debugging for production-like profiling. Install clinic.js (npm install -g clinic) for automated leak detection: clinic heapdump -- node server.js then load with heapdump.clinic.sh. For React: React DevTools Profiler shows component memory usage. Enable Chrome's 'Record allocation profiles' in Memory tab on production-like data."
  },
];
---

<BaseLayout
  title="JavaScript Memory Leak Detector — Find Leaks in Your Code"
  description="Detect common JavaScript and React memory leak patterns. Paste your code to find unremoved event listeners, uncleaned intervals, unsubscribed observables, and unguarded async updates. Free, runs in your browser."
  tool="javascript memory leak detector, react memory leak checker, event listener leak, setinterval not cleared, memory leak patterns, js memory leak analyzer"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "JavaScript Memory Leak Detector",
    "url": "https://devplaybook.cc/tools/memory-leak-detector",
    "description": "Detect common JavaScript and React memory leak patterns. Analyzes code for unremoved event listeners, uncleaned intervals, unsubscribed observables, and unguarded async state updates.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">JavaScript Memory Leak Detector</h1>
  <p class="text-text-muted mb-4">
    Detect common <strong>JavaScript and React memory leak patterns</strong> in your code. Paste your code to analyze for unremoved event listeners, uncleaned intervals, unsubscribed observables, unguarded async updates, and DOM reference leaks — with before/after fix examples for each issue.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 8 leak patterns</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Severity levels</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Before/after examples</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Line numbers</span>
  </div>
  <MemoryLeakDetector client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Memory Leak Detector" relatedTags={['javascript', 'react', 'performance', 'debugging', 'memory', 'developer-tools']} />
</BaseLayout>
