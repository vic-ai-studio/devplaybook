---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is React Hook Form?", answer: "React Hook Form is a performant, flexible library for building forms in React. It uses uncontrolled components and native HTML inputs, minimizing re-renders and improving performance compared to controlled-component approaches like Formik. It integrates seamlessly with TypeScript and validation libraries like Zod, Yup, and Joi." },
  { question: "Why use Zod with React Hook Form?", answer: "Zod is a TypeScript-first schema validation library. When paired with React Hook Form via @hookform/resolvers, it provides type-safe validation with auto-inferred TypeScript types from schemas. This means one schema definition covers both runtime validation and compile-time type safety — no duplication." },
  { question: "What is the register function in React Hook Form?", answer: "The register function connects HTML inputs to React Hook Form's state. It returns props (name, ref, onChange, onBlur) that you spread onto an input element. The ref allows React Hook Form to track the value without controlled state, which is why it's so performant — fields don't trigger full re-renders on every keystroke." },
  { question: "When should I use Controller vs register?", answer: "Use register for native HTML inputs (input, select, textarea). Use Controller for third-party controlled components like React Select, MUI TextField, or any component that doesn't expose a DOM ref. Controller wraps the component and provides value/onChange/onBlur through render props." },
  { question: "How does validation mode work in React Hook Form?", answer: "React Hook Form supports 5 validation modes: onChange (validates on every keystroke), onBlur (validates when field loses focus), onSubmit (validates on submit only — default), onTouched (validates on first blur, then on change), and all (validates on all events). onSubmit is fastest; onChange is most responsive but can feel aggressive." },
];
---

<BaseLayout
  title="React Hook Form Builder — Generate useForm, JSX, Zod Schema & TypeScript Interface"
  description="Generate React Hook Form code instantly. Build useForm hook, JSX form markup, Zod resolver schema, and TypeScript interfaces from a visual form builder. Zero dependencies."
  tool="React Hook Form Builder, useForm Generator, Zod Schema Generator, Form TypeScript Interface"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">React Hook Form Builder</h1>
  <p class="text-text-muted mb-4">Design your form fields visually and get production-ready React Hook Form code — including useForm hook, JSX markup, Zod validation schema, and TypeScript interface.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Zero dependencies</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Zod + TypeScript output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 4 output tabs</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy per section</span>
  </div>

  <!-- Form Config -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Form Configuration</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Form Name</label>
        <input id="form-name" type="text" value="MyForm" placeholder="MyForm"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Validation Mode</label>
        <select id="validation-mode" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="onSubmit">onSubmit (default)</option>
          <option value="onChange">onChange (eager)</option>
          <option value="onBlur">onBlur (lazy)</option>
          <option value="onTouched">onTouched</option>
          <option value="all">all</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Submit Button Label</label>
        <input id="submit-label" type="text" value="Submit" placeholder="Submit"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
    </div>
  </div>

  <!-- Fields Builder -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-base font-semibold">Form Fields</h2>
      <button id="add-field-btn" class="flex items-center gap-1.5 bg-primary text-white text-sm px-3 py-1.5 rounded-lg hover:opacity-90 transition-opacity">
        <span>+</span> Add Field
      </button>
    </div>

    <!-- Header row -->
    <div class="hidden md:grid grid-cols-[1fr_120px_80px_80px_120px_100px_36px] gap-2 text-xs text-text-muted font-medium mb-2 px-1">
      <span>Field Name</span>
      <span>Type</span>
      <span>Required</span>
      <span>Min</span>
      <span>Max</span>
      <span>Pattern</span>
      <span></span>
    </div>

    <div id="fields-container" class="space-y-2"></div>
  </div>

  <!-- Output Tabs -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-4">Generated Code</h2>
    <div class="flex gap-1 mb-4 flex-wrap" id="tab-bar">
      <button data-tab="hook" class="tab-btn px-3 py-1.5 text-sm rounded-lg border border-primary bg-primary text-white">useForm Hook</button>
      <button data-tab="jsx" class="tab-btn px-3 py-1.5 text-sm rounded-lg border border-border text-text-muted hover:border-primary hover:text-primary transition-colors">JSX Markup</button>
      <button data-tab="zod" class="tab-btn px-3 py-1.5 text-sm rounded-lg border border-border text-text-muted hover:border-primary hover:text-primary transition-colors">Zod Schema</button>
      <button data-tab="ts" class="tab-btn px-3 py-1.5 text-sm rounded-lg border border-border text-text-muted hover:border-primary hover:text-primary transition-colors">TS Interface</button>
    </div>

    <div class="relative">
      <pre id="code-output" class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto whitespace-pre text-green-400 min-h-[200px]"></pre>
      <button id="copy-btn" class="absolute top-2 right-2 bg-bg-card border border-border text-text-muted hover:text-primary hover:border-primary text-xs px-2.5 py-1 rounded-md transition-colors">Copy</button>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="React Hook Form Builder" relatedTags={['react', 'forms', 'typescript', 'zod', 'validation', 'hooks']} />
</BaseLayout>

<script>
  interface Field {
    id: string;
    name: string;
    type: string;
    required: boolean;
    min: string;
    max: string;
    pattern: string;
  }

  let fields: Field[] = [
    { id: 'f1', name: 'email', type: 'email', required: true, min: '', max: '', pattern: '' },
    { id: 'f2', name: 'username', type: 'text', required: true, min: '3', max: '20', pattern: '' },
    { id: 'f3', name: 'age', type: 'number', required: false, min: '18', max: '99', pattern: '' },
  ];

  let activeTab = 'hook';

  function uid(): string {
    return 'f' + Math.random().toString(36).slice(2, 8);
  }

  function renderFields(): void {
    const container = document.getElementById('fields-container')!;
    if (fields.length === 0) {
      container.innerHTML = `<div class="text-center text-text-muted text-sm py-6 border border-dashed border-border rounded-lg">No fields yet. Click "Add Field" to start.</div>`;
      return;
    }
    container.innerHTML = fields.map((f, i) => `
      <div class="grid grid-cols-1 md:grid-cols-[1fr_120px_80px_80px_120px_100px_36px] gap-2 items-center p-2 rounded-lg hover:bg-primary/5" data-field-id="${f.id}">
        <input type="text" placeholder="fieldName" value="${f.name}" data-prop="name"
          class="bg-bg-card border border-border rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:border-primary w-full" />
        <select data-prop="type" class="bg-bg-card border border-border rounded-lg px-2 py-1.5 text-sm focus:outline-none focus:border-primary">
          ${['text','email','number','checkbox','select','textarea'].map(t => `<option value="${t}" ${f.type===t?'selected':''}>${t}</option>`).join('')}
        </select>
        <label class="flex items-center gap-1.5 text-sm justify-center md:justify-start">
          <input type="checkbox" data-prop="required" ${f.required?'checked':''} class="rounded" />
          <span class="md:hidden text-text-muted">Req</span>
        </label>
        <input type="text" placeholder="min" value="${f.min}" data-prop="min"
          class="bg-bg-card border border-border rounded-lg px-2 py-1.5 text-sm focus:outline-none focus:border-primary w-full" />
        <input type="text" placeholder="max" value="${f.max}" data-prop="max"
          class="bg-bg-card border border-border rounded-lg px-2 py-1.5 text-sm focus:outline-none focus:border-primary w-full" />
        <input type="text" placeholder="regex" value="${f.pattern}" data-prop="pattern"
          class="bg-bg-card border border-border rounded-lg px-2 py-1.5 text-sm focus:outline-none focus:border-primary w-full" />
        <button data-remove="${f.id}" class="text-red-400 hover:text-red-500 text-lg leading-none flex items-center justify-center w-9 h-9 rounded-lg hover:bg-red-500/10 transition-colors">×</button>
      </div>
    `).join('');

    // Events
    container.querySelectorAll('[data-prop]').forEach(el => {
      const row = (el as HTMLElement).closest('[data-field-id]') as HTMLElement;
      const id = row.dataset.fieldId!;
      const prop = (el as HTMLElement).dataset.prop as keyof Field;
      el.addEventListener('input', (e) => {
        const target = e.target as HTMLInputElement;
        const f = fields.find(x => x.id === id)!;
        if (prop === 'required') {
          (f as any)[prop] = (target as HTMLInputElement).checked;
        } else {
          (f as any)[prop] = target.value;
        }
        generate();
      });
      el.addEventListener('change', (e) => {
        const target = e.target as HTMLInputElement;
        const f = fields.find(x => x.id === id)!;
        if (prop === 'required') {
          (f as any)[prop] = target.checked;
        } else {
          (f as any)[prop] = target.value;
        }
        generate();
      });
    });

    container.querySelectorAll('[data-remove]').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.remove!;
        fields = fields.filter(f => f.id !== id);
        renderFields();
        generate();
      });
    });
  }

  function getFormName(): string {
    return (document.getElementById('form-name') as HTMLInputElement).value.trim() || 'MyForm';
  }
  function getMode(): string {
    return (document.getElementById('validation-mode') as HTMLSelectElement).value;
  }
  function getSubmitLabel(): string {
    return (document.getElementById('submit-label') as HTMLInputElement).value.trim() || 'Submit';
  }

  function tsType(f: Field): string {
    if (f.type === 'number') return 'number';
    if (f.type === 'checkbox') return 'boolean';
    return 'string';
  }

  function generateHook(): string {
    const name = getFormName();
    const mode = getMode();
    const modeStr = mode === 'onSubmit' ? '' : `, mode: '${mode}'`;
    return `import { useForm } from 'react-hook-form';
import { zodResolver } from '@hookform/resolvers/zod';
import { ${name}Schema, type ${name}FormData } from './${name.toLowerCase()}.schema';

export function use${name}Form() {
  const {
    register,
    handleSubmit,
    formState: { errors, isSubmitting },
    reset,
  } = useForm<${name}FormData>({
    resolver: zodResolver(${name}Schema)${modeStr},
  });

  const onSubmit = async (data: ${name}FormData) => {
    try {
      console.log('Form data:', data);
      // TODO: handle submission
      reset();
    } catch (err) {
      console.error(err);
    }
  };

  return { register, handleSubmit: handleSubmit(onSubmit), errors, isSubmitting, reset };
}`;
  }

  function generateJSX(): string {
    const name = getFormName();
    const submitLabel = getSubmitLabel();

    const inputMap: Record<string, string> = {
      text: 'text',
      email: 'email',
      number: 'number',
      checkbox: 'checkbox',
      select: 'select',
      textarea: 'textarea',
    };

    const fieldJSX = fields.map(f => {
      const isCheckbox = f.type === 'checkbox';
      const isSelect = f.type === 'select';
      const isTextarea = f.type === 'textarea';

      let input = '';
      if (isCheckbox) {
        input = `      <input
        type="checkbox"
        {...register('${f.name}')}
        className="rounded border-gray-300"
      />`;
      } else if (isSelect) {
        input = `      <select
        {...register('${f.name}')}
        className="w-full border rounded-md px-3 py-2"
      >
        <option value="">Select...</option>
        {/* Add options here */}
      </select>`;
      } else if (isTextarea) {
        input = `      <textarea
        {...register('${f.name}')}
        rows={4}
        className="w-full border rounded-md px-3 py-2"
      />`;
      } else {
        input = `      <input
        type="${f.type}"
        {...register('${f.name}'${f.type === 'number' ? ', { valueAsNumber: true }' : ''})}
        className="w-full border rounded-md px-3 py-2"
      />`;
      }

      return `    <div className="flex flex-col gap-1">
      <label className="text-sm font-medium">${f.name}${f.required ? ' *' : ''}</label>
${input}
      {errors.${f.name} && (
        <p className="text-red-500 text-xs">{errors.${f.name}?.message}</p>
      )}
    </div>`;
    }).join('\n\n');

    return `import { use${name}Form } from './use${name}Form';

export function ${name}() {
  const { register, handleSubmit, errors, isSubmitting } = use${name}Form();

  return (
    <form onSubmit={handleSubmit} className="space-y-4 max-w-md">
${fieldJSX}

      <button
        type="submit"
        disabled={isSubmitting}
        className="w-full bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 disabled:opacity-50"
      >
        {isSubmitting ? 'Submitting...' : '${submitLabel}'}
      </button>
    </form>
  );
}`;
  }

  function generateZod(): string {
    const name = getFormName();
    const schemaFields = fields.map(f => {
      let chain = '';
      if (f.type === 'number') {
        chain = 'z.number()';
        if (f.min) chain += `.min(${f.min}, 'Minimum value is ${f.min}')`;
        if (f.max) chain += `.max(${f.max}, 'Maximum value is ${f.max}')`;
      } else if (f.type === 'checkbox') {
        chain = 'z.boolean()';
        if (f.required) chain += '.refine(val => val === true, { message: \'Must be checked\' })';
      } else if (f.type === 'email') {
        chain = `z.string().email('Invalid email address')`;
        if (f.required) chain += `.min(1, '${f.name} is required')`;
      } else {
        chain = 'z.string()';
        if (f.min) chain += `.min(${f.min}, 'Minimum ${f.min} characters required')`;
        if (f.max) chain += `.max(${f.max}, 'Maximum ${f.max} characters allowed')`;
        if (f.pattern) chain += `.regex(/${f.pattern}/, 'Invalid format')`;
        else if (f.required) chain += `.min(1, '${f.name} is required')`;
      }
      if (!f.required && f.type !== 'checkbox') chain += '.optional()';
      return `  ${f.name}: ${chain},`;
    }).join('\n');

    return `import { z } from 'zod';

export const ${name}Schema = z.object({
${schemaFields}
});

export type ${name}FormData = z.infer<typeof ${name}Schema>;`;
  }

  function generateTS(): string {
    const name = getFormName();
    const fields2 = fields.map(f => {
      const optional = !f.required ? '?' : '';
      return `  ${f.name}${optional}: ${tsType(f)};`;
    }).join('\n');

    return `// Auto-generated TypeScript interface for ${name}
// Use ${name}FormData from Zod schema for full type safety

export interface ${name}FormValues {
${fields2}
}

// Form state type
export interface ${name}FormState {
  data: ${name}FormValues | null;
  isLoading: boolean;
  error: string | null;
}`;
  }

  function generate(): void {
    const outputs: Record<string, () => string> = {
      hook: generateHook,
      jsx: generateJSX,
      zod: generateZod,
      ts: generateTS,
    };
    const code = outputs[activeTab]?.() ?? '';
    document.getElementById('code-output')!.textContent = code;
  }

  // Tab switching
  document.getElementById('tab-bar')!.addEventListener('click', e => {
    const btn = (e.target as HTMLElement).closest('[data-tab]') as HTMLElement;
    if (!btn) return;
    activeTab = btn.dataset.tab!;
    document.querySelectorAll('.tab-btn').forEach(b => {
      const isActive = (b as HTMLElement).dataset.tab === activeTab;
      b.className = isActive
        ? 'tab-btn px-3 py-1.5 text-sm rounded-lg border border-primary bg-primary text-white'
        : 'tab-btn px-3 py-1.5 text-sm rounded-lg border border-border text-text-muted hover:border-primary hover:text-primary transition-colors';
    });
    generate();
  });

  // Copy
  document.getElementById('copy-btn')!.addEventListener('click', () => {
    const text = document.getElementById('code-output')!.textContent ?? '';
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById('copy-btn')!;
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 1500);
    });
  });

  // Add field
  document.getElementById('add-field-btn')!.addEventListener('click', () => {
    fields.push({ id: uid(), name: `field${fields.length + 1}`, type: 'text', required: false, min: '', max: '', pattern: '' });
    renderFields();
    generate();
  });

  // Config inputs
  document.getElementById('form-name')!.addEventListener('input', generate);
  document.getElementById('validation-mode')!.addEventListener('change', generate);
  document.getElementById('submit-label')!.addEventListener('input', generate);

  renderFields();
  generate();
</script>
