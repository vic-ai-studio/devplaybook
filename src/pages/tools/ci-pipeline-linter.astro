---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CiPipelineLinter from '../../components/CiPipelineLinter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="CI Pipeline Linter — Validate GitHub Actions & GitLab CI YAML"
  description="Validate GitHub Actions and GitLab CI YAML files in your browser. Detects hardcoded secrets, missing required fields, mutable image tags, deprecated syntax, and security best practices. Free, no install needed."
  tool="CI Pipeline Linter, GitHub Actions validator, GitLab CI linter, CI YAML validator, GitHub Actions syntax checker"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "CI Pipeline Linter",
    "url": "https://devplaybook.cc/tools/ci-pipeline-linter",
    "description": "Lint GitHub Actions and GitLab CI YAML pipelines online. Checks for hardcoded secrets, mutable image tags, deprecated syntax, and security best practices. Runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">CI Pipeline Linter</h1>
  <p class="text-text-muted mb-6">
    Validate your <strong class="text-text">GitHub Actions</strong> or <strong class="text-text">GitLab CI</strong> YAML pipelines instantly.
    Catches hardcoded secrets, mutable image tags (<code class="font-mono bg-surface px-1 rounded text-sm">:latest</code>),
    missing required fields, deprecated <code class="font-mono bg-surface px-1 rounded text-sm">only:</code>/<code class="font-mono bg-surface px-1 rounded text-sm">except:</code> syntax,
    and common security issues. Runs entirely in your browser — nothing sent to any server.
  </p>
  <div class="flex items-center gap-4 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GitHub Actions &amp; GitLab CI</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Hardcoded secret detection</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Security best practices</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No data leaves your browser</span>
  </div>
  <CiPipelineLinter client:only="preact" />
  <ToolPageCta currentTool="CI Pipeline Linter" relatedTags={['ci-cd', 'devops', 'github-actions', 'gitlab', 'validation']} />
</BaseLayout>
