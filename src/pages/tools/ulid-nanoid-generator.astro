---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UlidNanoidGenerator from '../../components/UlidNanoidGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is a ULID and how is it different from a UUID?", answer: "ULID (Universally Unique Lexicographically Sortable Identifier) is a 26-character base32 ID with a 48-bit millisecond timestamp prefix. Unlike UUID v4 (which is completely random), ULIDs are naturally sortable by creation time — ideal for databases where you need chronological ordering without a separate timestamp column." },
  { question: "What is NanoID?", answer: "NanoID is a tiny, secure, URL-safe ID generator. By default it produces 21-character IDs using a 64-character alphabet. It's smaller than UUID (fewer characters for the same collision probability), supports custom alphabets, and is widely used for session tokens, short URL slugs, and client-side IDs." },
  { question: "How do I decode the timestamp from a ULID?", answer: "The first 10 characters of a ULID encode the Unix timestamp in milliseconds using Crockford Base32. This tool automatically decodes and displays the timestamp when you generate a single ULID, showing you the exact ISO date and time it was created." },
  { question: "What alphabet should I use for NanoID?", answer: "Use 'Default (URL-safe)' for most cases — it's the standard NanoID alphabet designed to be safe in URLs, file names, and HTML attributes. Use 'Alphanumeric' if you need IDs that are easier to read aloud or copy. Use 'Hex' for IDs that look like short hashes." },
  { question: "How many random bits does each ID type have?", answer: "UUID v4 has 122 random bits. ULID has 80 random bits (+ 48-bit timestamp). NanoID with the default alphabet and 21 characters has approximately 126 random bits. All three have astronomically low collision probabilities for practical use — pick based on sortability and size requirements." },
  { question: "Can I generate multiple IDs at once?", answer: "Yes. Set the Count field (up to 100) and click Generate. All IDs are displayed in a scrollable list. Click 'Copy All' to copy them as newline-separated text, or copy individual IDs by hovering and clicking Copy." },
];
---

<BaseLayout
  title="ULID / NanoID / UUID Generator — Free Online ID Generator"
  description="Free ID generator for ULID (sortable), NanoID (URL-safe, customizable), and UUID v4 (random). Generate up to 100 IDs at once. ULID timestamp decoder included. Choose alphabet and size for NanoID. Runs in your browser, no signup."
  tool="ULID Generator, NanoID Generator, UUID Generator, Sortable ID, URL-Safe ID, Unique ID Generator, Crockford Base32, NanoID Custom Alphabet"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">ULID / NanoID / UUID Generator</h1>
  <p class="text-text-muted mb-4">Generate <strong>ULID</strong> (chronologically sortable, timestamp-prefixed), <strong>NanoID</strong> (compact, URL-safe, customizable alphabet), or <strong>UUID v4</strong> (random, industry standard). Generate up to 100 IDs at once. ULID timestamp decoder included. All generation happens in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> ULID, NanoID, UUID v4</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Batch generation up to 100</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Cryptographically random</span>
  </div>
  <UlidNanoidGenerator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="ULID / NanoID Generator" relatedTags={['uuid', 'id-generation', 'security', 'database', 'backend', 'tokens']} />
</BaseLayout>
