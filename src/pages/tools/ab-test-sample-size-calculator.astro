---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "Why do I need to calculate sample size before running an A/B test?", answer: "Without a pre-determined sample size, you risk stopping the test too early (when results look significant by chance) or too late (wasting traffic). Pre-calculating sample size ensures your test has enough statistical power to reliably detect your target improvement and control your false-positive rate." },
  { question: "What is statistical power?", answer: "Statistical power (1-β) is the probability of detecting a real effect when one truly exists. An 80% power means you have an 80% chance of seeing a significant result if your variant really is better by the minimum detectable effect (MDE). Higher power requires larger samples. Most A/B tests use 80% or 90% power." },
  { question: "What is the Minimum Detectable Effect (MDE)?", answer: "MDE is the smallest relative improvement you care about detecting. If your baseline conversion rate is 5% and you want to detect a 20% relative improvement (to 6%), that's a 20% MDE. Smaller MDEs require much larger sample sizes — a 5% MDE might need 10x more traffic than a 20% MDE." },
  { question: "What significance level (alpha) should I use?", answer: "The standard is α = 0.05 (95% confidence), meaning a 5% false-positive rate. For high-stakes decisions (pricing, checkout flow), use α = 0.01. For exploratory tests where you'll validate winners anyway, α = 0.10 is acceptable. Never use α > 0.10 for production decisions." },
  { question: "What if I don't have enough traffic to reach the required sample?", answer: "Consider increasing MDE (accept only larger improvements), reducing variants (stick to A/B not A/B/C), or running the test longer. If your monthly traffic can't reach the sample within a reasonable timeframe (under 4-8 weeks), the test may not be feasible. Focus on higher-traffic pages or use Bayesian testing methods." },
  { question: "How do I estimate the test duration?", answer: "Test duration = required sample size per variant / (daily traffic × allocation percentage). If you need 5,000 visitors per variant with 1,000 daily visitors split 50/50, it takes 5,000 / 500 = 10 days. Add 10-20% buffer for weekday/weekend traffic variation." },
];
---

<BaseLayout
  title="A/B Test Sample Size Calculator — How Many Visitors Do You Need?"
  description="Free A/B test sample size calculator. Enter your baseline conversion rate, minimum detectable effect, significance level, and statistical power to get the required sample size per variant and estimated test duration."
  tool="AB test sample size calculator, A/B test visitors needed, statistical power calculator, conversion rate test size, MDE calculator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "A/B Test Sample Size Calculator",
    "url": "https://devplaybook.cc/tools/ab-test-sample-size-calculator",
    "description": "Calculate the minimum sample size needed for a statistically valid A/B test. Input baseline conversion, MDE, alpha, and power to get visitor requirements and duration estimates.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">A/B Test Sample Size Calculator</h1>
  <p class="text-text-muted mb-4">Calculate the minimum number of visitors needed per variant before starting your A/B test. Input your baseline rate, target improvement, and statistical parameters to get sample size and estimated duration.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Two-proportion z-test formula</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Configurable power & alpha</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Duration estimate by traffic</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multi-variant support (A/B/C)</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Inputs -->
    <div class="bg-bg-card border border-border rounded-xl p-5 flex flex-col gap-4">
      <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Test Parameters</h2>

      <div>
        <label class="block text-sm font-medium mb-1" for="baseline-rate">Baseline Conversion Rate (%)</label>
        <input id="baseline-rate" type="number" value="5" min="0.1" max="99.9" step="0.1" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
        <p class="text-xs text-text-muted mt-1">Your current conversion rate (e.g., 5 for 5%)</p>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" for="mde-pct">Minimum Detectable Effect (%)</label>
        <input id="mde-pct" type="number" value="20" min="1" max="200" step="1" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
        <p class="text-xs text-text-muted mt-1">Relative improvement to detect (e.g., 20 = detect 5% → 6%)</p>
        <p id="mde-absolute" class="text-xs text-accent mt-1"></p>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" for="alpha-level">Significance Level (α)</label>
        <select id="alpha-level" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors">
          <option value="0.01">1% (99% confidence) — high-stakes</option>
          <option value="0.05" selected>5% (95% confidence) — standard</option>
          <option value="0.10">10% (90% confidence) — exploratory</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" for="power-level">Statistical Power (1-β)</label>
        <select id="power-level" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors">
          <option value="0.80" selected>80% — standard</option>
          <option value="0.90">90% — high confidence</option>
          <option value="0.95">95% — very high</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" for="variants">Number of Variants</label>
        <select id="variants" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors">
          <option value="2">2 (A/B)</option>
          <option value="3">3 (A/B/C)</option>
          <option value="4">4 (A/B/C/D)</option>
        </select>
      </div>

      <div class="border-t border-border pt-4">
        <h3 class="text-sm font-medium mb-3">Duration Estimate</h3>
        <div>
          <label class="block text-sm font-medium mb-1" for="daily-traffic">Daily Visitors (total)</label>
          <input id="daily-traffic" type="number" value="1000" min="1" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
        </div>
        <div class="mt-3">
          <label class="block text-sm font-medium mb-1" for="traffic-alloc">Traffic Allocation (%)</label>
          <input id="traffic-alloc" type="number" value="100" min="1" max="100" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
          <p class="text-xs text-text-muted mt-1">% of traffic included in the test</p>
        </div>
      </div>
    </div>

    <!-- Results -->
    <div class="flex flex-col gap-4">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted mb-4">Results</h2>
        <div id="results-grid" class="grid grid-cols-2 gap-3 mb-4"></div>
        <div id="duration-card" class="bg-bg border border-border rounded-lg p-4 mb-3"></div>
        <div id="feasibility-note" class="text-sm rounded-lg p-3"></div>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted mb-3">MDE Sensitivity</h2>
        <p class="text-xs text-text-muted mb-3">Sample size per variant at different MDEs (same baseline/alpha/power):</p>
        <div id="sensitivity-table" class="text-sm"></div>
      </div>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="A/B Test Sample Size Calculator" relatedTags={['analytics', 'testing', 'statistics', 'calculator', 'marketing', 'conversion']} />
</BaseLayout>

<script>
function zScore(p: number): number {
  // Approximation of inverse normal CDF
  const a = [2.515517, 0.802853, 0.010328];
  const b = [1.432788, 0.189269, 0.001308];
  const t = Math.sqrt(-2 * Math.log(p));
  return t - (a[0] + a[1]*t + a[2]*t*t) / (1 + b[0]*t + b[1]*t*t + b[2]*t*t*t);
}

function calcSampleSize(baseline: number, mde: number, alpha: number, power: number): number {
  const p1 = baseline;
  const p2 = baseline * (1 + mde / 100);
  const za = zScore(alpha / 2);
  const zb = zScore(1 - power);
  const p_bar = (p1 + p2) / 2;
  const n = Math.pow((za * Math.sqrt(2 * p_bar * (1 - p_bar)) - zb * Math.sqrt(p1*(1-p1) + p2*(1-p2))), 2) / Math.pow(p2 - p1, 2);
  return Math.ceil(Math.abs(n));
}

function calculate() {
  const baseline = parseFloat((document.getElementById('baseline-rate') as HTMLInputElement).value) / 100;
  const mde = parseFloat((document.getElementById('mde-pct') as HTMLInputElement).value);
  const alpha = parseFloat((document.getElementById('alpha-level') as HTMLSelectElement).value);
  const power = parseFloat((document.getElementById('power-level') as HTMLSelectElement).value);
  const variants = parseInt((document.getElementById('variants') as HTMLSelectElement).value);
  const dailyTraffic = parseInt((document.getElementById('daily-traffic') as HTMLInputElement).value) || 1000;
  const alloc = parseFloat((document.getElementById('traffic-alloc') as HTMLInputElement).value) / 100;

  const p2 = baseline * (1 + mde / 100);
  document.getElementById('mde-absolute')!.textContent = `Absolute: ${(baseline*100).toFixed(2)}% → ${(p2*100).toFixed(2)}% (+${((p2-baseline)*100).toFixed(2)}pp)`;

  const samplePerVariant = calcSampleSize(baseline, mde, alpha, power);
  const totalSample = samplePerVariant * variants;

  const dailyPerVariant = (dailyTraffic * alloc) / variants;
  const daysNeeded = Math.ceil(samplePerVariant / dailyPerVariant);
  const weeksNeeded = (daysNeeded / 7).toFixed(1);

  document.getElementById('results-grid')!.innerHTML = `
    <div class="bg-bg border border-border rounded-lg p-4 text-center">
      <div class="text-xs text-text-muted mb-1">Per Variant</div>
      <div class="text-2xl font-bold text-accent">${samplePerVariant.toLocaleString()}</div>
      <div class="text-xs text-text-muted mt-1">visitors</div>
    </div>
    <div class="bg-bg border border-border rounded-lg p-4 text-center">
      <div class="text-xs text-text-muted mb-1">Total Needed</div>
      <div class="text-2xl font-bold text-accent">${totalSample.toLocaleString()}</div>
      <div class="text-xs text-text-muted mt-1">across ${variants} variants</div>
    </div>
    <div class="bg-bg border border-border rounded-lg p-4 text-center">
      <div class="text-xs text-text-muted mb-1">Expected Rate B</div>
      <div class="text-2xl font-bold text-green-400">${(p2*100).toFixed(2)}%</div>
      <div class="text-xs text-text-muted mt-1">after +${mde}% MDE</div>
    </div>
    <div class="bg-bg border border-border rounded-lg p-4 text-center">
      <div class="text-xs text-text-muted mb-1">Absolute Lift</div>
      <div class="text-2xl font-bold text-green-400">+${((p2-baseline)*100).toFixed(2)}pp</div>
      <div class="text-xs text-text-muted mt-1">percentage points</div>
    </div>
  `;

  document.getElementById('duration-card')!.innerHTML = `
    <div class="text-sm font-medium mb-2">Estimated Duration</div>
    <div class="text-3xl font-bold text-accent">${daysNeeded} days</div>
    <div class="text-text-muted text-sm mt-1">${weeksNeeded} weeks · ${dailyPerVariant.toFixed(0)} visitors/day per variant</div>
  `;

  const feasibility = document.getElementById('feasibility-note')!;
  if (daysNeeded <= 14) {
    feasibility.className = 'text-sm rounded-lg p-3 bg-green-500/10 border border-green-500/20 text-green-400';
    feasibility.textContent = '✅ Test feasible. Can complete in under 2 weeks with current traffic.';
  } else if (daysNeeded <= 42) {
    feasibility.className = 'text-sm rounded-lg p-3 bg-yellow-500/10 border border-yellow-500/20 text-yellow-400';
    feasibility.textContent = `⚠️ Test feasible but long (${weeksNeeded} weeks). Consider increasing MDE or traffic allocation.`;
  } else {
    feasibility.className = 'text-sm rounded-lg p-3 bg-red-500/10 border border-red-500/20 text-red-400';
    feasibility.textContent = `❌ Test may not be feasible (${weeksNeeded} weeks). Increase MDE, reduce variants, or test on a higher-traffic page.`;
  }

  // Sensitivity table
  const mdeValues = [5, 10, 15, 20, 30, 50];
  document.getElementById('sensitivity-table')!.innerHTML = `
    <table class="w-full text-xs">
      <thead><tr class="text-text-muted border-b border-border">
        <th class="text-left py-1">MDE</th>
        <th class="text-right py-1">Sample/variant</th>
        <th class="text-right py-1">Duration</th>
      </tr></thead>
      <tbody>
        ${mdeValues.map(m => {
          const s = calcSampleSize(baseline, m, alpha, power);
          const d = Math.ceil(s / dailyPerVariant);
          const isCurrent = m === mde;
          return `<tr class="${isCurrent ? 'bg-accent/10 font-semibold' : ''} border-b border-border/50">
            <td class="py-1.5">${m}%${isCurrent ? ' ←' : ''}</td>
            <td class="text-right py-1.5">${s.toLocaleString()}</td>
            <td class="text-right py-1.5">${d}d</td>
          </tr>`;
        }).join('')}
      </tbody>
    </table>
  `;
}

['baseline-rate','mde-pct','alpha-level','power-level','variants','daily-traffic','traffic-alloc'].forEach(id => {
  document.getElementById(id)!.addEventListener('input', calculate);
  document.getElementById(id)!.addEventListener('change', calculate);
});
calculate();
</script>
