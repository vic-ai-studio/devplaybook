---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  return tools.map((tool) => ({
    params: { slug: tool.id },
    props: { tool },
  }));
}

const { tool } = Astro.props;
const { Content } = await render(tool);

const siteUrl = 'https://devplaybook.cc';
const canonicalUrl = `${siteUrl}/tools/directory/${tool.id}`;

const categoryIcons: Record<string, string> = {
  'AI Coding': '🤖',
  'Performance Testing': '⚡',
  'Database GUI': '🗄️',
};
const icon = categoryIcons[tool.data.category] ?? '🛠️';

const pricingColors: Record<string, string> = {
  'Open Source': 'text-green-400 bg-green-400/10 border-green-400/30',
  'Freemium': 'text-blue-400 bg-blue-400/10 border-blue-400/30',
  'Paid': 'text-orange-400 bg-orange-400/10 border-orange-400/30',
};
const pricingClass = pricingColors[tool.data.pricing] ?? 'text-text-muted bg-card border-border';
---

<BaseLayout title={tool.data.title} description={tool.data.description} noDefaultJsonLd>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": tool.data.title,
    "description": tool.data.description,
    "url": canonicalUrl,
    "applicationCategory": "DeveloperApplication",
    "keywords": tool.data.tags.join(', '),
    "offers": {
      "@type": "Offer",
      "price": tool.data.pricing === 'Open Source' ? "0" : undefined,
      "priceCurrency": "USD",
      "description": tool.data.pricingDetail
    }
  })} />

  <article class="max-w-4xl mx-auto">
    <header class="mb-10">
      <div class="flex items-center gap-3 text-sm text-text-muted mb-4">
        <a href="/tools" class="hover:text-primary">&larr; All Tools</a>
        <span>·</span>
        <span>{icon} {tool.data.category}</span>
      </div>

      <h1 class="text-4xl font-bold mb-4">{tool.data.title}</h1>
      <p class="text-xl text-text-muted mb-6">{tool.data.description}</p>

      <!-- Pricing & Links -->
      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class={`text-xs font-medium px-3 py-1 rounded-full border ${pricingClass}`}>
          {tool.data.pricing}
        </span>
        {tool.data.pricingDetail && (
          <span class="text-sm text-text-muted">{tool.data.pricingDetail}</span>
        )}
      </div>

      <div class="flex flex-wrap gap-3 mb-6">
        <a
          href={tool.data.website}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors text-sm font-medium"
        >
          🌐 Visit Website
        </a>
        {tool.data.github && (
          <a
            href={tool.data.github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 bg-card border border-border rounded-lg hover:border-primary transition-colors text-sm font-medium text-text"
          >
            GitHub →
          </a>
        )}
      </div>

      <!-- Tags -->
      <div class="flex flex-wrap gap-2">
        {tool.data.tags.map((tag: string) => (
          <span class="text-xs px-2 py-1 bg-card rounded border border-border text-text-muted">{tag}</span>
        ))}
      </div>
    </header>

    <!-- Pros & Cons -->
    <div class="grid md:grid-cols-2 gap-6 mb-10">
      <div class="bg-card border border-border rounded-xl p-6">
        <h2 class="text-lg font-bold text-green-400 mb-4">✅ Pros</h2>
        <ul class="space-y-2">
          {tool.data.pros.map((pro: string) => (
            <li class="flex items-start gap-2 text-sm text-text-muted">
              <span class="text-green-400 mt-0.5">+</span>
              <span>{pro}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="bg-card border border-border rounded-xl p-6">
        <h2 class="text-lg font-bold text-red-400 mb-4">⚠️ Cons</h2>
        <ul class="space-y-2">
          {tool.data.cons.map((con: string) => (
            <li class="flex items-start gap-2 text-sm text-text-muted">
              <span class="text-red-400 mt-0.5">−</span>
              <span>{con}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Main Content -->
    <div class="prose prose-invert prose-lg max-w-none
      [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:mt-10 [&_h2]:mb-4 [&_h2]:text-text
      [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:mt-8 [&_h3]:mb-3 [&_h3]:text-text
      [&_p]:text-text-muted [&_p]:leading-relaxed [&_p]:mb-4
      [&_ul]:text-text-muted [&_ul]:mb-4 [&_ul]:ml-6 [&_ul]:list-disc
      [&_ol]:text-text-muted [&_ol]:mb-4 [&_ol]:ml-6 [&_ol]:list-decimal
      [&_li]:mb-2
      [&_a]:text-primary [&_a]:underline [&_a:hover]:text-secondary
      [&_code]:bg-card [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:text-sm [&_code]:text-secondary
      [&_pre]:bg-card [&_pre]:p-4 [&_pre]:rounded-lg [&_pre]:overflow-x-auto [&_pre]:mb-4 [&_pre]:border [&_pre]:border-border
      [&_pre_code]:bg-transparent [&_pre_code]:p-0
      [&_blockquote]:border-l-4 [&_blockquote]:border-primary [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-text-muted
      [&_table]:w-full [&_table]:mb-4
      [&_th]:text-left [&_th]:p-2 [&_th]:border-b [&_th]:border-border [&_th]:text-text
      [&_td]:p-2 [&_td]:border-b [&_td]:border-border [&_td]:text-text-muted
      [&_hr]:border-border [&_hr]:my-8
      [&_strong]:text-text [&_strong]:font-semibold
    ">
      <Content />
    </div>

    <!-- Updated date -->
    <footer class="mt-12 pt-6 border-t border-border text-sm text-text-muted">
      Last updated: <time datetime={tool.data.date}>{new Date(tool.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
    </footer>
  </article>
</BaseLayout>
