---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SqlIndexAdvisor from '../../components/SqlIndexAdvisor.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "How does this tool suggest indexes?",
    answer: "The advisor parses your SELECT query and identifies columns used in WHERE clauses (equality, range, LIKE), JOIN ON conditions, and ORDER BY clauses. It suggests single-column indexes for individual conditions, composite indexes when multiple columns on the same table appear in WHERE, and notes ORDER BY columns that benefit from indexing."
  },
  {
    question: "What is a composite index and when should I use it?",
    answer: "A composite index covers multiple columns in a defined order. Use it when your WHERE clause filters on multiple columns from the same table — the database can use one composite index instead of scanning separate single-column indexes. The most selective column (smallest cardinality) should typically come first, with range columns last."
  },
  {
    question: "Why should I index foreign key columns?",
    answer: "Foreign key columns used in JOIN ON conditions cause full table scans if unindexed — the database must scan every row of the joined table to find matches. An index on the foreign key column turns this into an index lookup, reducing JOIN cost from O(n) to O(log n)."
  },
  {
    question: "What is the cardinality rule for composite indexes?",
    answer: "Put higher-cardinality columns (more unique values) first in composite indexes. For example, if filtering by country (low cardinality, ~250 values) and user_id (high cardinality, millions of values), the index should be (user_id, country) for queries that filter on user_id, or (country, user_id) for queries filtering on country first."
  },
  {
    question: "How many indexes is too many?",
    answer: "Every index adds overhead to INSERT, UPDATE, and DELETE operations because the database must update all indexes on write. As a rough guideline, 3–5 indexes per table is a reasonable range for OLTP workloads. Profile actual query performance with EXPLAIN ANALYZE before adding indexes in production."
  },
  {
    question: "Does this tool send my SQL to a server?",
    answer: "No. All analysis runs entirely in your browser using JavaScript. Your SQL never leaves your machine."
  },
];
---

<BaseLayout
  title="SQL Index Advisor — Index Suggestions from SELECT Queries"
  description="Paste a SQL SELECT query and get CREATE INDEX suggestions. Analyzes WHERE, JOIN, and ORDER BY clauses to recommend single-column and composite indexes. Outputs ready-to-run SQL."
  tool="SQL Index Advisor, Database Index Optimizer, SQL Query Index Generator, CREATE INDEX Tool"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "SQL Index Advisor",
    "url": "https://devplaybook.cc/tools/sql-index-advisor",
    "description": "Analyzes SQL SELECT queries and suggests optimal CREATE INDEX statements. Covers WHERE clause filters, JOIN foreign keys, and ORDER BY columns.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">SQL Index Advisor</h1>
  <p class="text-text-muted mb-4">
    Paste a SQL <code class="font-mono bg-surface px-1 rounded text-sm">SELECT</code> query and get <code class="font-mono bg-surface px-1 rounded text-sm">CREATE INDEX</code> suggestions. The advisor analyzes <code class="font-mono bg-surface px-1 rounded text-sm">WHERE</code>, <code class="font-mono bg-surface px-1 rounded text-sm">JOIN ON</code>, and <code class="font-mono bg-surface px-1 rounded text-sm">ORDER BY</code> clauses to recommend single-column and composite indexes.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> WHERE / JOIN / ORDER BY analysis</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Composite index suggestions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <SqlIndexAdvisor client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SQL Index Advisor" relatedTags={['sql', 'database', 'performance', 'indexing', 'developer-tools']} />
</BaseLayout>
