---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceWorkerCacheStrategyGenerator from '../../components/ServiceWorkerCacheStrategyGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a Service Worker cache strategy?",
    answer: "A cache strategy defines how a Service Worker handles fetch requests — whether to serve from cache first, network first, or a hybrid approach. Choosing the right strategy per route type (API vs static assets vs HTML) is key to a fast, reliable PWA."
  },
  {
    question: "When should I use Network First vs Cache First?",
    answer: "Use Network First for dynamic content like API responses and HTML pages where freshness matters — fall back to cache when offline. Use Cache First for static assets like images, fonts, and versioned JS/CSS files where stale content is acceptable and speed is the priority."
  },
  {
    question: "What is Stale While Revalidate?",
    answer: "Stale While Revalidate (SWR) serves the cached version immediately for speed, then fetches a fresh version from the network in the background to update the cache. It's ideal for non-critical content that changes occasionally — like avatars, settings data, or content feeds — where you want fast responses but eventually-fresh data."
  },
  {
    question: "Do I need Workbox to use these strategies?",
    answer: "No. This tool generates pure vanilla Service Worker code with no Workbox or other dependencies. The expiration and pattern matching logic is inlined directly into the generated sw.js file. This keeps your bundle small and avoids third-party dependencies."
  },
  {
    question: "How do route patterns work?",
    answer: "Patterns support glob-style matching: use * as a wildcard (e.g., /api/*, *.css, /images/*). Routes are evaluated in order — the first matching pattern wins. A pattern that matches everything (/*) acts as a catch-all fallback and should be placed last."
  },
  {
    question: "How do I register the generated Service Worker?",
    answer: "Add this snippet to your main JavaScript bundle: if ('serviceWorker' in navigator) { window.addEventListener('load', () => { navigator.serviceWorker.register('/sw.js'); }); } Make sure sw.js is served from your domain root with Cache-Control: no-cache so updates are detected immediately."
  },
];
---

<BaseLayout
  title="Service Worker Cache Strategy Generator — PWA sw.js Builder"
  description="Generate a complete Service Worker (sw.js) with per-route caching strategies. Configure Network First, Cache First, Stale While Revalidate, Cache Only, and Network Only per URL pattern. No Workbox required."
  tool="Service Worker Generator, PWA Cache Strategy, sw.js Builder, Workbox Alternative, Service Worker Cache"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Service Worker Cache Strategy Generator",
    "url": "https://devplaybook.cc/tools/service-worker-cache-strategy-generator",
    "description": "Generate a complete Service Worker with per-route cache strategies. Network First, Cache First, Stale While Revalidate, and more — with expiration and precaching. No Workbox required.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Service Worker Cache Strategy Generator</h1>
  <p class="text-text-muted mb-4">
    Build a complete <code class="font-mono bg-surface px-1 rounded text-sm">sw.js</code> with per-route caching strategies.
    Define patterns, choose Network First / Cache First / Stale While Revalidate / Cache Only / Network Only per route,
    set expiration rules, and download a ready-to-deploy Service Worker with no Workbox dependency.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 cache strategies</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Per-route patterns</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Expiration + precaching</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No Workbox — pure vanilla JS</span>
  </div>
  <ServiceWorkerCacheStrategyGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Service Worker Cache Strategy Generator" relatedTags={['pwa', 'service-worker', 'caching', 'performance', 'web-development', 'developer-tools']} />
</BaseLayout>
