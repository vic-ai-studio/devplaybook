---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is Mock Service Worker (MSW)?", answer: "Mock Service Worker (MSW) is an API mocking library that intercepts HTTP requests at the network level using a Service Worker (in the browser) or Node.js interceptors (in tests/Node). Unlike mock libraries that patch fetch/axios, MSW intercepts real network requests, making mocks transparent and realistic." },
  { question: "When should I use MSW instead of mocking fetch directly?", answer: "Use MSW when you want mocks to work across all HTTP libraries (fetch, axios, ky), when you want to test UI components against realistic network behavior, and when you want the same handlers to work in both browser development and Jest/Vitest tests. Direct fetch mocking is brittle and library-specific." },
  { question: "What is the difference between rest and graphql handlers?", answer: "rest handlers match REST API requests by method and path (e.g., http.get('/api/users', ...)). graphql handlers match GraphQL operations by operation name regardless of URL. MSW v2 uses the http namespace for REST and graphql namespace for GraphQL operations." },
  { question: "How do I use the generated handler in my project?", answer: "Install MSW (npm install msw --save-dev), then run npx msw init public/ to register the service worker. Create a handlers.js with your handler, pass it to setupWorker (browser) or setupServer (Node/Jest). Call worker.start() in your app entry or server.listen() in your test setup file." },
  { question: "What does passthrough() do?", answer: "passthrough() tells MSW to not intercept the request and let it proceed to the real network. This is useful for selectively mocking some endpoints while letting others through to real APIs during development." },
];
---

<BaseLayout
  title="MSW Handler Builder — Generate Mock Service Worker Request Handlers Online"
  description="Free online MSW (Mock Service Worker) handler builder. Configure method, path, response status, headers, and body. Generates ready-to-use MSW v2 handler code for browser and Node."
  tool="MSW handler generator, Mock Service Worker builder, API mock generator, msw request handler, msw v2 handler"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "MSW Handler Builder",
    "url": "https://devplaybook.cc/tools/msw-handler-builder",
    "description": "Generate Mock Service Worker (MSW) v2 request handlers for browser and Node.js testing environments.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">MSW Handler Builder</h1>
  <p class="text-text-muted mb-4">Generate <a href="https://mswjs.io" class="text-accent hover:underline" target="_blank" rel="noopener">Mock Service Worker</a> v2 request handlers for API mocking in browser and Node.js tests. Configure your endpoint, response, and copy the ready-to-use handler code.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> MSW v2 syntax (http namespace)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> REST & GraphQL handlers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Custom status, headers, body</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Delay simulation support</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Config Panel -->
    <div class="flex flex-col gap-4">
      <div class="bg-bg-card border border-border rounded-xl p-5 flex flex-col gap-4">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Handler Configuration</h2>

        <div>
          <label class="block text-sm font-medium mb-1" for="handler-type">Handler Type</label>
          <select id="handler-type" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors">
            <option value="rest">REST API</option>
            <option value="graphql">GraphQL</option>
          </select>
        </div>

        <div id="rest-fields">
          <div class="mb-3">
            <label class="block text-sm font-medium mb-1" for="http-method">HTTP Method</label>
            <select id="http-method" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors">
              <option value="get">GET</option>
              <option value="post">POST</option>
              <option value="put">PUT</option>
              <option value="patch">PATCH</option>
              <option value="delete">DELETE</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1" for="endpoint-path">Endpoint Path</label>
            <input id="endpoint-path" type="text" value="/api/users" placeholder="/api/users/:id" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
          </div>
        </div>

        <div id="graphql-fields" class="hidden">
          <div class="mb-3">
            <label class="block text-sm font-medium mb-1" for="gql-type">Operation Type</label>
            <select id="gql-type" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors">
              <option value="query">Query</option>
              <option value="mutation">Mutation</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1" for="gql-name">Operation Name</label>
            <input id="gql-name" type="text" value="GetUser" placeholder="GetUser" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium mb-1" for="status-code">Response Status</label>
          <select id="status-code" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors">
            <option value="200">200 OK</option>
            <option value="201">201 Created</option>
            <option value="204">204 No Content</option>
            <option value="400">400 Bad Request</option>
            <option value="401">401 Unauthorized</option>
            <option value="403">403 Forbidden</option>
            <option value="404">404 Not Found</option>
            <option value="500">500 Internal Server Error</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium mb-1" for="delay-ms">Simulated Delay (ms)</label>
          <input id="delay-ms" type="number" value="0" min="0" max="10000" step="100" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
          <p class="text-xs text-text-muted mt-1">0 = no delay. Use to simulate network latency.</p>
        </div>

        <div>
          <label class="block text-sm font-medium mb-1" for="response-body">Response Body (JSON)</label>
          <textarea id="response-body" rows="6" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm font-mono focus:outline-none focus:border-accent transition-colors resize-y" placeholder='{ "id": 1, "name": "Alice" }'>{ "id": 1, "name": "Alice", "email": "alice@example.com" }</textarea>
        </div>

        <div>
          <label class="block text-sm font-medium mb-1">Extra Response Headers (optional)</label>
          <input id="extra-headers" type="text" placeholder='X-Rate-Limit: 100' class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm font-mono focus:outline-none focus:border-accent transition-colors" />
          <p class="text-xs text-text-muted mt-1">Format: <code>Header-Name: value</code> (one per line or comma-separated)</p>
        </div>

        <button id="generate-btn" class="w-full bg-accent hover:bg-accent/90 text-white font-semibold px-4 py-2.5 rounded-lg transition-colors text-sm">
          Generate Handler
        </button>
      </div>
    </div>

    <!-- Output Panel -->
    <div class="flex flex-col gap-4">
      <div class="bg-bg-card border border-border rounded-xl p-5 flex flex-col gap-3 h-full">
        <div class="flex items-center justify-between">
          <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Generated Handler</h2>
          <button id="copy-btn" class="flex items-center gap-1.5 text-xs bg-bg border border-border hover:border-accent text-text-muted hover:text-accent px-3 py-1.5 rounded-lg transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            Copy
          </button>
        </div>
        <pre id="output" class="flex-1 bg-bg rounded-lg p-4 text-sm font-mono overflow-x-auto whitespace-pre text-text border border-border min-h-64"></pre>
        <div id="setup-hint" class="text-xs text-text-muted bg-bg border border-border rounded-lg p-3 hidden">
          <strong class="text-text">Quick setup:</strong>
          <code class="block mt-1 text-accent">npm install msw --save-dev</code>
          <code class="block mt-1 text-accent">npx msw init public/</code>
          <span class="block mt-1">Then import this handler in your <code>handlers.js</code> and pass to <code>setupWorker</code> or <code>setupServer</code>.</span>
        </div>
      </div>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="MSW Handler Builder" relatedTags={['testing', 'api', 'mocking', 'javascript', 'developer-tools']} />
</BaseLayout>

<script>
function generate() {
  const type = (document.getElementById('handler-type') as HTMLSelectElement).value;
  const status = parseInt((document.getElementById('status-code') as HTMLSelectElement).value);
  const delay = parseInt((document.getElementById('delay-ms') as HTMLInputElement).value) || 0;
  const bodyRaw = (document.getElementById('response-body') as HTMLTextAreaElement).value.trim();
  const extraHeaders = (document.getElementById('extra-headers') as HTMLInputElement).value.trim();

  let bodyObj = '{}';
  try { JSON.parse(bodyRaw); bodyObj = bodyRaw; } catch { bodyObj = '{}'; }

  let headersCode = '';
  if (extraHeaders) {
    const pairs = extraHeaders.split(/[\n,]+/).map(h => h.trim()).filter(Boolean);
    const headerLines = pairs.map(p => {
      const idx = p.indexOf(':');
      if (idx === -1) return '';
      const key = p.slice(0, idx).trim();
      const val = p.slice(idx + 1).trim();
      return `      '${key}': '${val}',`;
    }).filter(Boolean).join('\n');
    if (headerLines) headersCode = `\n      headers: {\n${headerLines}\n      },`;
  }

  const delayLine = delay > 0 ? `  await delay(${delay});\n  ` : '';
  const delayImport = delay > 0 ? ', delay' : '';

  let code = '';

  if (type === 'rest') {
    const method = (document.getElementById('http-method') as HTMLSelectElement).value;
    const path = (document.getElementById('endpoint-path') as HTMLInputElement).value.trim() || '/api/resource';

    if (status === 204) {
      code = `import { http${delayImport} } from 'msw';

export const handler = http.${method}('${path}', async () => {
  ${delayLine}return new Response(null, { status: 204 });
});

// Add to your handlers array:
// export const handlers = [handler];`;
    } else {
      code = `import { http, HttpResponse${delayImport} } from 'msw';

export const handler = http.${method}('${path}', async () => {
  ${delayLine}return HttpResponse.json(
    ${bodyObj},
    {
      status: ${status},${headersCode}
    }
  );
});

// Add to your handlers array:
// export const handlers = [handler];`;
    }
  } else {
    const gqlType = (document.getElementById('gql-type') as HTMLSelectElement).value;
    const opName = (document.getElementById('gql-name') as HTMLInputElement).value.trim() || 'GetUser';

    code = `import { graphql, HttpResponse${delayImport} } from 'msw';

export const handler = graphql.${gqlType}('${opName}', async () => {
  ${delayLine}return HttpResponse.json({
    data: ${bodyObj},
  });
});

// Add to your handlers array:
// export const handlers = [handler];`;
  }

  (document.getElementById('output') as HTMLElement).textContent = code;
  (document.getElementById('setup-hint') as HTMLElement).classList.remove('hidden');
}

document.getElementById('generate-btn')!.addEventListener('click', generate);

document.getElementById('handler-type')!.addEventListener('change', function() {
  const isGraphQL = (this as HTMLSelectElement).value === 'graphql';
  document.getElementById('rest-fields')!.classList.toggle('hidden', isGraphQL);
  document.getElementById('graphql-fields')!.classList.toggle('hidden', !isGraphQL);
  generate();
});

document.getElementById('copy-btn')!.addEventListener('click', function() {
  const code = (document.getElementById('output') as HTMLElement).textContent || '';
  navigator.clipboard.writeText(code).then(() => {
    const btn = this as HTMLElement;
    const orig = btn.innerHTML;
    btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Copied!';
    setTimeout(() => { btn.innerHTML = orig; }, 2000);
  });
});

// Generate on load
generate();
</script>
