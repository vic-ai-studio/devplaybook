---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CssAnimationGenerator from "../../components/CssAnimationGenerator.tsx";
import ToolPageCta from "../../components/ToolPageCta.astro";
import FaqSection from "../../components/FaqSection.astro";

const faq = [
  { question: "What is a CSS keyframe animation?", answer: "CSS @keyframes animations let you define a sequence of styles that an element transitions through over time. Unlike CSS transitions (which animate between two states), keyframe animations support multiple intermediate steps, loops, delays, and direction control — all with no JavaScript required." },
  { question: "What CSS easing functions are available?", answer: "CSS supports built-in easings: linear (constant speed), ease (slow start and end), ease-in (slow start), ease-out (slow end), and ease-in-out (slow start and end). You can also define custom curves with cubic-bezier(x1,y1,x2,y2) or use step-based timing with steps()." },
  { question: "How do I make a CSS animation loop forever?", answer: "Set animation-iteration-count: infinite in your CSS, or select 'infinite' in this generator's iterations field. Combine with animation-direction: alternate to make the animation ping-pong back and forth instead of jumping back to the start." },
  { question: "What is the difference between animation-fill-mode values?", answer: "none: element reverts to original state after animation. forwards: element keeps the final keyframe state. backwards: element starts in the first keyframe state during the delay period. both: applies both forwards and backwards behavior." },
  { question: "Can I use CSS animations in React or Vue?", answer: "Yes. The generated CSS is framework-agnostic — paste the @keyframes block and animation properties into any CSS file, CSS module, styled-components, or Tailwind @layer. In React, assign the animation via className or style prop. No extra libraries needed." },
];
---

<BaseLayout
  title="CSS Animation Generator — Free CSS Keyframe Builder Online"
  description="Build CSS keyframe animations with live preview. Choose from 10 presets (fade, bounce, shake, spin, slide), configure duration, easing, delay, and iterations. Copy ready-to-use CSS @keyframes instantly. Free, no signup."
  tool="CSS Animation Generator, CSS Keyframe Generator, CSS Transition Builder, Animation CSS Online, @keyframes Generator, CSS Bounce Fade Spin"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">CSS Animation Generator</h1>
  <p class="text-text-muted mb-4">Build CSS <code class="font-mono text-sm bg-surface px-1 rounded">@keyframes</code> animations with a live preview. Pick a preset, tweak timing, easing, and iterations, then copy the ready-to-paste CSS. Edit keyframes directly for custom animations.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live preview — no install needed</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <CssAnimationGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CSS Animation Generator" relatedTags={["css", "animation", "keyframes", "design", "frontend"]} />
</BaseLayout>
