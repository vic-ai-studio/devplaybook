---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CssAnimationGenerator from '../../components/CssAnimationGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="CSS Animation Generator"
  description="Generate CSS keyframe animations with live preview. Choose from 10 presets (fade, slide, bounce, shake, spin), configure duration, easing, delay, and iterations. Copy ready-to-use CSS instantly."
  tool="CSS Animation Generator, Keyframe Generator, CSS Transition Builder, Animation Tool"
>
  <h1 class="text-3xl font-bold mb-2">CSS Animation Generator</h1>
  <p class="text-text-muted mb-8">Build CSS <code>@keyframes</code> animations with a live preview. Pick a preset, tweak timing, easing, and iterations, then copy the ready-to-paste CSS. Edit keyframes directly for custom animations.</p>
  <CssAnimationGenerator client:only="preact" />
  <ToolPageCta currentTool="CSS Animation Generator" relatedTags={['css', 'animation', 'keyframes', 'design', 'frontend']} />
</BaseLayout>
