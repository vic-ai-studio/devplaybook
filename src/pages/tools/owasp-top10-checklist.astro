---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is the OWASP Top 10?", answer: "The OWASP Top 10 is a standard awareness document representing the most critical security risks to web applications. Published by the Open Web Application Security Project, it is updated periodically (most recently for 2021, with 2024 updates) based on data from hundreds of organizations and thousands of applications. It serves as a baseline checklist for secure development practices." },
  { question: "What is the difference between SQL injection and NoSQL injection?", answer: "SQL injection targets relational databases by inserting malicious SQL syntax into queries. NoSQL injection targets document databases like MongoDB by exploiting JSON/BSON query operators — for example, passing &#123;'$gt': ''&#125; as a password to bypass authentication. Both require parameterized queries or input sanitization. In MongoDB, always use parameterized queries and validate that inputs are the expected type (string, not object)." },
  { question: "How do I prevent XSS in a React or Vue application?", answer: "React and Vue escape output by default when using JSX / template syntax. XSS risks occur when using dangerouslySetInnerHTML (React) or v-html (Vue) — avoid these with untrusted content. Use a library like DOMPurify to sanitize HTML before rendering. For backend-rendered HTML, use context-aware output encoding: HTML-encode for HTML context, JavaScript-encode for JS context, URL-encode for URL params." },
  { question: "What is an IDOR vulnerability and how do I prevent it?", answer: "Insecure Direct Object Reference (IDOR) occurs when an application exposes internal identifiers (database IDs, filenames) directly and doesn't verify the requesting user is authorized to access that resource. Prevention: always perform authorization checks server-side before returning any object — never rely on the client to enforce access control. Use indirect references (UUIDs instead of sequential integers) and log access attempts." },
  { question: "What is security misconfiguration and what are common examples?", answer: "Security misconfiguration is the most common OWASP category. Examples include: running services with default credentials, leaving debug mode enabled in production, exposing stack traces in error messages, unnecessary open ports or services, missing security headers (CSP, HSTS, X-Frame-Options), public cloud storage buckets (S3), and overly permissive CORS policies. Remediation involves hardening guides, automated config scanning, and infrastructure-as-code reviews." },
  { question: "What are cryptographic failures and what algorithms should I use in 2024?", answer: "Cryptographic failures include using broken algorithms (MD5, SHA-1 for passwords, DES), transmitting sensitive data unencrypted, weak key sizes, or misusing cryptographic primitives. For passwords use bcrypt, Argon2id, or scrypt — never SHA-256 alone. For symmetric encryption use AES-256-GCM. For hashing use SHA-256 or SHA-3. For key exchange use ECDH with P-256 or X25519. Always use TLS 1.2+ for data in transit." },
];
---

<BaseLayout
  title="OWASP Top 10 2024 Security Checklist"
  description="Complete OWASP Top 10 security checklist for developers. Covers injection, broken authentication, XSS, IDOR, security misconfiguration, and cryptographic failures with real code examples."
  tool="OWASP Top 10, Web Security Checklist, SQL Injection Prevention, XSS Prevention, Security Audit"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "OWASP Top 10 2024 Security Checklist",
    "url": "https://devplaybook.cc/tools/owasp-top10-checklist",
    "description": "Complete OWASP Top 10 security checklist for developers with code examples for SQL injection prevention, XSS, CORS misconfiguration, and more.",
  })} />

  <h1 class="text-3xl font-bold mb-2">OWASP Top 10 2024 Security Checklist</h1>
  <p class="text-text-muted mb-6">A developer-focused checklist covering the most critical web application security risks. Use this during code review, security audits, and pre-launch hardening.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All 10 OWASP categories</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Code examples & fixes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Printable checklist</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 2024 updated guidance</span>
  </div>

  <h2 class="text-xl font-semibold mb-3">The OWASP Top 10 — Quick Reference Table</h2>
  <div class="overflow-x-auto mb-8">
    <table class="w-full text-sm mb-6">
      <thead>
        <tr class="border-b border-border text-left text-text-muted">
          <th class="py-2 pr-4">#</th>
          <th class="py-2 pr-4">Category</th>
          <th class="py-2 pr-4">Risk Level</th>
          <th class="py-2">Key Fix</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <tr><td class="py-2 pr-4 font-mono text-xs">A01</td><td class="py-2 pr-4">Broken Access Control</td><td class="py-2 pr-4 text-red-500 font-medium">Critical</td><td class="py-2 text-text-muted">Enforce authz server-side on every request</td></tr>
        <tr><td class="py-2 pr-4 font-mono text-xs">A02</td><td class="py-2 pr-4">Cryptographic Failures</td><td class="py-2 pr-4 text-red-500 font-medium">Critical</td><td class="py-2 text-text-muted">Use Argon2id for passwords, AES-GCM for data</td></tr>
        <tr><td class="py-2 pr-4 font-mono text-xs">A03</td><td class="py-2 pr-4">Injection (SQL, NoSQL, OS)</td><td class="py-2 pr-4 text-red-500 font-medium">Critical</td><td class="py-2 text-text-muted">Parameterized queries, input validation</td></tr>
        <tr><td class="py-2 pr-4 font-mono text-xs">A04</td><td class="py-2 pr-4">Insecure Design</td><td class="py-2 pr-4 text-orange-500 font-medium">High</td><td class="py-2 text-text-muted">Threat modeling, secure design patterns</td></tr>
        <tr><td class="py-2 pr-4 font-mono text-xs">A05</td><td class="py-2 pr-4">Security Misconfiguration</td><td class="py-2 pr-4 text-orange-500 font-medium">High</td><td class="py-2 text-text-muted">Harden defaults, disable unused features</td></tr>
        <tr><td class="py-2 pr-4 font-mono text-xs">A06</td><td class="py-2 pr-4">Vulnerable Components</td><td class="py-2 pr-4 text-orange-500 font-medium">High</td><td class="py-2 text-text-muted">SCA tools, automated dependency updates</td></tr>
        <tr><td class="py-2 pr-4 font-mono text-xs">A07</td><td class="py-2 pr-4">Auth & Session Failures</td><td class="py-2 pr-4 text-orange-500 font-medium">High</td><td class="py-2 text-text-muted">MFA, secure session management</td></tr>
        <tr><td class="py-2 pr-4 font-mono text-xs">A08</td><td class="py-2 pr-4">Software & Data Integrity</td><td class="py-2 pr-4 text-yellow-500 font-medium">Medium</td><td class="py-2 text-text-muted">Verify signatures, pin dependencies</td></tr>
        <tr><td class="py-2 pr-4 font-mono text-xs">A09</td><td class="py-2 pr-4">Logging & Monitoring Failures</td><td class="py-2 pr-4 text-yellow-500 font-medium">Medium</td><td class="py-2 text-text-muted">Centralized logs, alerting on anomalies</td></tr>
        <tr><td class="py-2 pr-4 font-mono text-xs">A10</td><td class="py-2 pr-4">SSRF</td><td class="py-2 pr-4 text-yellow-500 font-medium">Medium</td><td class="py-2 text-text-muted">Allowlist outbound URLs, block internal ranges</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mb-3">A03 — Injection Prevention</h2>
  <p class="text-text-muted mb-4">Injection attacks occur when untrusted data is sent to an interpreter as part of a command or query. SQL injection remains the most exploited vulnerability across all languages and frameworks.</p>

  <h3 class="text-base font-semibold mb-2">Vulnerable SQL (Never do this)</h3>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// ❌ VULNERABLE — direct string interpolation
const query = `SELECT * FROM users WHERE email = '&#123;req.body.email&#125;'`;
// Attacker input: ' OR '1'='1
// Resulting query: SELECT * FROM users WHERE email = '' OR '1'='1'
// Returns ALL users!</pre>

  <h3 class="text-base font-semibold mb-2">Safe Parameterized Query (Node.js / pg)</h3>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// ✅ SAFE — parameterized query
const result = await pool.query(
  'SELECT * FROM users WHERE email = $1',
  [req.body.email]  // value is never interpolated into SQL
);

// ✅ SAFE — with an ORM (Prisma)
const user = await prisma.user.findFirst(&#123;
  where: &#123; email: req.body.email &#125;
&#125;);</pre>

  <h3 class="text-base font-semibold mb-2">Python SQLAlchemy (Safe)</h3>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-6">from sqlalchemy import text

# ✅ SAFE — bound parameters
result = db.execute(
    text("SELECT * FROM users WHERE email = :email"),
    &#123;"email": email_input&#125;
)

# ❌ VULNERABLE — f-string in query
result = db.execute(f"SELECT * FROM users WHERE email = '&#123;email_input&#125;'")</pre>

  <h2 class="text-xl font-semibold mb-3">A03 — XSS Prevention</h2>
  <p class="text-text-muted mb-4">Cross-Site Scripting (XSS) lets attackers inject client-side scripts into pages viewed by other users. Reflected XSS comes from request data; stored XSS persists in the database; DOM-based XSS manipulates client-side code.</p>

  <h3 class="text-base font-semibold mb-2">Content Security Policy Header</h3>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Nginx — strong CSP header
add_header Content-Security-Policy
  "default-src 'self';
   script-src 'self' 'nonce-&#123;NONCE&#125;';
   style-src 'self' 'unsafe-inline';
   img-src 'self' data: https:;
   font-src 'self';
   connect-src 'self' https://api.yourapp.com;
   frame-ancestors 'none';"
  always;</pre>

  <h3 class="text-base font-semibold mb-2">Sanitize HTML before rendering (DOMPurify)</h3>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-6">import DOMPurify from 'dompurify';

// ❌ XSS risk — never do this with user content
element.innerHTML = userContent;

// ✅ SAFE — sanitize first
const clean = DOMPurify.sanitize(userContent, &#123;
  ALLOWED_TAGS: ['b', 'i', 'em', 'strong', 'a'],
  ALLOWED_ATTR: ['href']
&#125;);
element.innerHTML = clean;</pre>

  <h2 class="text-xl font-semibold mb-3">A05 — Security Misconfiguration: CORS</h2>
  <p class="text-text-muted mb-4">CORS misconfiguration is one of the most common real-world vulnerabilities. A wildcard <code class="text-primary">Access-Control-Allow-Origin: *</code> combined with <code class="text-primary">Access-Control-Allow-Credentials: true</code> is a critical vulnerability that allows any origin to make credentialed requests.</p>

  <h3 class="text-base font-semibold mb-2">Misconfigured CORS (Dangerous)</h3>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// ❌ DANGEROUS — wildcard with credentials
app.use(cors(&#123;
  origin: '*',
  credentials: true  // This combination is a critical vuln!
&#125;));

// ❌ DANGEROUS — reflecting Origin header without validation
app.use((req, res, next) => &#123;
  res.header('Access-Control-Allow-Origin', req.headers.origin);
  res.header('Access-Control-Allow-Credentials', 'true');
  next();
&#125;);</pre>

  <h3 class="text-base font-semibold mb-2">Correct CORS Configuration (Express)</h3>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-6">// ✅ SAFE — explicit allowlist
const ALLOWED_ORIGINS = [
  'https://app.yourcompany.com',
  'https://admin.yourcompany.com',
];

app.use(cors(&#123;
  origin: (origin, callback) => &#123;
    if (!origin || ALLOWED_ORIGINS.includes(origin)) &#123;
      callback(null, true);
    &#125; else &#123;
      callback(new Error('Not allowed by CORS'));
    &#125;
  &#125;,
  credentials: true,
  methods: ['GET', 'POST', 'PUT', 'DELETE'],
  allowedHeaders: ['Content-Type', 'Authorization'],
&#125;));</pre>

  <h2 class="text-xl font-semibold mb-3">A01 — Broken Access Control (IDOR)</h2>
  <p class="text-text-muted mb-4">Access control enforces that users can only act within their intended permissions. IDOR (Insecure Direct Object Reference) is the most common access control failure found in bug bounty programs.</p>

  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// ❌ VULNERABLE — no authorization check
app.get('/api/invoices/:id', async (req, res) => &#123;
  const invoice = await db.invoices.findById(req.params.id);
  res.json(invoice);  // Any authenticated user can read any invoice!
&#125;);

// ✅ SAFE — verify ownership
app.get('/api/invoices/:id', authenticate, async (req, res) => &#123;
  const invoice = await db.invoices.findOne(&#123;
    id: req.params.id,
    userId: req.user.id  // Must belong to requesting user
  &#125;);
  if (!invoice) return res.status(404).json(&#123; error: 'Not found' &#125;);
  res.json(invoice);
&#125;);</pre>

  <h2 class="text-xl font-semibold mb-3">Security Headers Checklist</h2>
  <div class="overflow-x-auto mb-8">
    <table class="w-full text-sm mb-6">
      <thead>
        <tr class="border-b border-border text-left text-text-muted">
          <th class="py-2 pr-4">Header</th>
          <th class="py-2 pr-4">Recommended Value</th>
          <th class="py-2">Protects Against</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <tr><td class="py-2 pr-4 font-mono text-xs">Strict-Transport-Security</td><td class="py-2 pr-4 font-mono text-xs">max-age=63072000; includeSubDomains; preload</td><td class="py-2 text-text-muted">SSL stripping, MITM</td></tr>
        <tr><td class="py-2 pr-4 font-mono text-xs">X-Frame-Options</td><td class="py-2 pr-4 font-mono text-xs">DENY</td><td class="py-2 text-text-muted">Clickjacking</td></tr>
        <tr><td class="py-2 pr-4 font-mono text-xs">X-Content-Type-Options</td><td class="py-2 pr-4 font-mono text-xs">nosniff</td><td class="py-2 text-text-muted">MIME sniffing attacks</td></tr>
        <tr><td class="py-2 pr-4 font-mono text-xs">Referrer-Policy</td><td class="py-2 pr-4 font-mono text-xs">strict-origin-when-cross-origin</td><td class="py-2 text-text-muted">Data leakage in Referer</td></tr>
        <tr><td class="py-2 pr-4 font-mono text-xs">Permissions-Policy</td><td class="py-2 pr-4 font-mono text-xs">camera=(), microphone=(), geolocation=()</td><td class="py-2 text-text-muted">Feature abuse</td></tr>
        <tr><td class="py-2 pr-4 font-mono text-xs">Content-Security-Policy</td><td class="py-2 pr-4 font-mono text-xs">default-src 'self'; ...</td><td class="py-2 text-text-muted">XSS, data injection</td></tr>
      </tbody>
    </table>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="OWASP Top 10 Checklist" relatedTags={['security', 'web', 'backend']} />
</BaseLayout>
