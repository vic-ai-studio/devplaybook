---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HttpStatusReference from '../../components/HttpStatusReference.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is an HTTP status code?", answer: "HTTP status codes are 3-digit numbers returned by a server to indicate the result of a request. They're grouped into 5 classes: 1xx (informational), 2xx (success), 3xx (redirection), 4xx (client error), and 5xx (server error). Every HTTP response includes a status code." },
  { question: "What's the difference between 401 and 403?", answer: "401 Unauthorized means the request lacks valid authentication — the server doesn't know who you are. 403 Forbidden means the server knows who you are, but you don't have permission to access the resource. Use 401 when credentials are missing or invalid; use 403 when the user is authenticated but unauthorized." },
  { question: "When should I use 404 vs 410?", answer: "Use 404 Not Found when a resource doesn't exist or you don't want to reveal whether it exists. Use 410 Gone when a resource existed but has been permanently deleted — this tells search crawlers to deindex the URL. If you don't track deletions, 404 is fine in most cases." },
  { question: "What is the difference between 301 and 302 redirects?", answer: "301 Moved Permanently tells browsers and search engines to permanently update their records — link equity transfers and the redirect is cached. 302 Found is temporary, so browsers keep the original URL and don't cache the redirect. For SEO-safe URL changes, use 301. For login flows or A/B testing, use 302." },
  { question: "What does HTTP 429 Too Many Requests mean?", answer: "429 indicates rate limiting — the client has sent too many requests in a given window. Best practice is to include a Retry-After header indicating when the client can retry. Clients should implement exponential backoff and jitter when they receive 429 responses from APIs." },
  { question: "When should a REST API return 422 vs 400?", answer: "400 Bad Request is for syntactically malformed requests (invalid JSON, missing Content-Type). 422 Unprocessable Entity is for requests that are syntactically valid but semantically wrong (correct JSON structure, but a field fails validation like 'age' being negative). Most modern APIs use 422 for form/field validation errors." },
];
---

<BaseLayout
  title="HTTP Status Code Reference — All 1xx–5xx Codes Explained"
  description="Complete HTTP status code reference. Search all 1xx–5xx codes with descriptions, real-world use cases, and examples. The developer's cheat sheet for REST APIs."
  tool="HTTP Status Codes, HTTP Response Codes Reference, REST API Status Codes"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">HTTP Status Code Reference</h1>
  <p class="text-text-muted mb-4">Every HTTP status code explained — with real-world use cases. Filter by category or search by code number, name, or keyword.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Covers all 1xx–5xx codes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <HttpStatusReference client:only="preact" />
  <!-- Ad slot below tool output — highest CTR position (user pauses after using the tool) -->
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <AffiliateSection category="deployment" />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Need to build and test HTTP requests?</p>
    <a href="/tools/api-tester" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">API Request Tester →</a>
  </div>
  <ToolPageCta currentTool="HTTP Status Code Reference" relatedTags={['http', 'api', 'rest', 'web', 'debugging']} />
</BaseLayout>
