---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HttpStatusReference from '../../components/HttpStatusReference.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="HTTP Status Code Reference"
  description="Complete interactive HTTP status code reference. Search all 1xx, 2xx, 3xx, 4xx, and 5xx codes with descriptions, use cases, and examples. The developer's cheat sheet."
  tool="HTTP Status Codes, HTTP Response Codes Reference, REST API Status Codes"
>
  <h1 class="text-3xl font-bold mb-2">HTTP Status Code Reference</h1>
  <p class="text-text-muted mb-8">Every HTTP status code explained — with real-world use cases. Filter by category or search by code number, name, or keyword.</p>
  <HttpStatusReference client:only="preact" />
  <ToolPageCta currentTool="HTTP Status Reference" relatedTags={['http', 'api', 'rest', 'web', 'debugging']} />
</BaseLayout>
