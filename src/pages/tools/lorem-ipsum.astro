---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LoremIpsum from '../../components/LoremIpsum.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Lorem Ipsum Generator"
  description="Generate Lorem Ipsum placeholder text — paragraphs, sentences, or words. Instantly copy and use in mockups, wireframes, or templates. No signup needed."
  tool="Lorem Ipsum Generator, Placeholder Text, Dummy Text Generator"
>
  <h1 class="text-3xl font-bold mb-2">Lorem Ipsum Generator</h1>
  <p class="text-text-muted mb-8">Generate classic Lorem Ipsum placeholder text for your mockups, wireframes, and design templates. Choose paragraphs, sentences, or words, and start with the traditional opening line.</p>
  <LoremIpsum client:only="preact" />
  <ToolPageCta currentTool="Lorem Ipsum Generator" relatedTags={['text', 'design', 'placeholder', 'frontend']} />
</BaseLayout>
