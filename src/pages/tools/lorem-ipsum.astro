---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LoremIpsum from '../../components/LoremIpsum.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Lorem Ipsum?", answer: "Lorem Ipsum is placeholder text derived from a scrambled passage of Cicero's 'de Finibus Bonorum et Malorum' (45 BC). It has been the standard dummy text in typesetting since the 1500s. Designers use it to focus on visual layout without being distracted by readable content." },
  { question: "Why do designers use Lorem Ipsum instead of real text?", answer: "Real text draws attention to meaning and phrasing, not layout. Lorem Ipsum looks like natural language — it has varied letter frequencies and word lengths — but carries no meaning, so reviewers focus purely on the visual design, spacing, and typography." },
  { question: "What is the difference between paragraphs, sentences, and words mode?", answer: "Paragraphs mode generates full multi-sentence blocks — ideal for article mockups and content sections. Sentences mode generates individual sentences — useful for card descriptions or captions. Words mode generates a word list — handy for labels, tags, or short UI strings." },
  { question: "Is Lorem Ipsum Latin?", answer: "Partly. The original Lorem Ipsum passage is scrambled Latin, but additional pseudo-Latin words have been added over centuries so the text fills space at a natural density. The words 'lorem ipsum' themselves are a corruption of 'dolorem ipsum' meaning 'pain itself' in Cicero's original." },
  { question: "Can I use Lorem Ipsum in production?", answer: "No. Lorem Ipsum is strictly a design placeholder. Always replace it with real, meaningful content before publishing. Leaving placeholder text in production hurts SEO (search engines penalise meaningless content), confuses real users, and looks unprofessional." },
];
---

<BaseLayout
  title="Lorem Ipsum Generator — Placeholder Text for Mockups & Wireframes"
  description="Free Lorem Ipsum generator. Generate paragraphs, sentences, or words of placeholder text. Starts with the classic opening line. Copy with one click. No signup needed — runs in your browser."
  tool="Lorem Ipsum Generator, Placeholder Text Generator, Dummy Text, Lorem Ipsum Paragraphs, Fake Text Generator, Design Placeholder"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Lorem Ipsum Generator</h1>
  <p class="text-text-muted mb-4">Generate classic Lorem Ipsum placeholder text for your mockups, wireframes, and design templates. Choose paragraphs, sentences, or words, and optionally start with the traditional opening line. Copy with one click — everything runs in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <LoremIpsum client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Lorem Ipsum Generator" relatedTags={['text', 'design', 'placeholder', 'frontend']} />
</BaseLayout>
