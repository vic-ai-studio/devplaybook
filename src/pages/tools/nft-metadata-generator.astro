---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is NFT metadata?", answer: "NFT metadata is a JSON file that describes the token's properties: name, description, image URL, and attributes (traits). ERC-721 and ERC-1155 tokens return a tokenURI that points to this JSON. Marketplaces like OpenSea, Blur, and Rarible read this metadata to display the NFT." },
  { question: "What is the OpenSea metadata standard?", answer: "OpenSea's metadata standard extends the ERC-721 metadata JSON schema. Key fields: name, description, image, external_url, background_color, animation_url. The attributes array contains trait objects with trait_type and value. Numeric traits can include display_type (number, boost_number, boost_percentage, date)." },
  { question: "Where should I host NFT metadata?", answer: "IPFS is the standard for decentralized storage. Use Pinata or NFT.Storage to upload. The tokenURI will be ipfs://CID/tokenId.json. You can also use Arweave for permanent storage ($AR fee) or centralized storage (not recommended for serious projects — can be changed or deleted)." },
  { question: "What is ERC-1155 metadata?", answer: "ERC-1155 is a multi-token standard where one contract can hold multiple token types (both fungible and non-fungible). Its uri() function returns a template URL with {id} placeholder. The metadata format is similar to ERC-721 but the token ID is hex-encoded and zero-padded to 64 characters." },
];
---

<BaseLayout
  title="NFT Metadata Generator — ERC-721 & ERC-1155 JSON Generator"
  description="Generate NFT metadata JSON for ERC-721 and ERC-1155 tokens. Follows OpenSea metadata standard with name, description, image, and attributes. Export ready-to-upload JSON."
  tool="NFT Metadata Generator, ERC-721 Metadata, ERC-1155 JSON, OpenSea Metadata Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">NFT Metadata Generator</h1>
  <p class="text-text-muted mb-4">Generate standard-compliant NFT metadata JSON for ERC-721 and ERC-1155 tokens. Follows the OpenSea metadata standard.</p>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
    <!-- Config -->
    <div class="space-y-4">
      <div class="bg-bg-card border border-border rounded-xl p-5 space-y-3">
        <h2 class="text-base font-semibold">Token Standard</h2>
        <div class="flex gap-3">
          <label class="flex items-center gap-2 text-sm"><input type="radio" name="standard" value="721" id="std-721" checked /> ERC-721</label>
          <label class="flex items-center gap-2 text-sm"><input type="radio" name="standard" value="1155" id="std-1155" /> ERC-1155</label>
        </div>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5 space-y-3">
        <h2 class="text-base font-semibold">Basic Info</h2>
        <div><label class="block text-xs font-medium mb-1">Name</label>
          <input id="nft-name" type="text" value="Cool NFT #1" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" /></div>
        <div><label class="block text-xs font-medium mb-1">Description</label>
          <textarea id="nft-desc" rows="2" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary resize-none">A unique collectible NFT from the Cool Collection.</textarea></div>
        <div><label class="block text-xs font-medium mb-1">Image URL (IPFS or HTTPS)</label>
          <input id="nft-image" type="text" value="ipfs://QmHash.../1.png" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" /></div>
        <div><label class="block text-xs font-medium mb-1">External URL (optional)</label>
          <input id="nft-external" type="text" placeholder="https://yourproject.io/token/1" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" /></div>
        <div><label class="block text-xs font-medium mb-1">Background Color (6-char hex, no #)</label>
          <input id="nft-bg" type="text" placeholder="FFFFFF" maxlength="6" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" /></div>
        <div id="animation-row">
          <label class="block text-xs font-medium mb-1">Animation URL (optional, video/audio/HTML)</label>
          <input id="nft-animation" type="text" placeholder="ipfs://QmHash.../1.mp4" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" /></div>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5 space-y-3">
        <div class="flex items-center justify-between">
          <h2 class="text-base font-semibold">Attributes / Traits</h2>
          <button id="add-attr" class="text-xs bg-primary/10 text-primary border border-primary/30 px-2 py-1 rounded hover:bg-primary/20">+ Add</button>
        </div>
        <div id="attrs-list" class="space-y-2"></div>
      </div>
    </div>

    <!-- Output -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-semibold">Generated Metadata JSON</h2>
        <div class="flex gap-2">
          <button id="copy-json" class="text-xs text-text-muted border border-border px-2 py-1 rounded hover:bg-bg">Copy</button>
          <button id="download-json" class="text-xs bg-primary/10 text-primary border border-primary/30 px-2 py-1 rounded hover:bg-primary/20">Download</button>
        </div>
      </div>
      <pre id="json-output" class="text-xs font-mono bg-bg rounded-lg p-3 overflow-auto text-text-muted whitespace-pre max-h-[70vh]"></pre>
    </div>
  </div>

  <AdUnit slot="in-content" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="NFT Metadata Generator" relatedTags={['blockchain', 'ethereum', 'nft', 'web3', 'smart-contracts']} />
</BaseLayout>

<script>
interface Attr { trait_type: string; value: string; display_type?: string; }

let attrs: Attr[] = [
  { trait_type: 'Background', value: 'Blue' },
  { trait_type: 'Eyes', value: 'Laser' },
  { trait_type: 'Rarity Score', value: '85', display_type: 'number' },
];

function sv(id: string) { return (document.getElementById(id) as HTMLInputElement)?.value || ''; }

function renderAttrs() {
  const list = document.getElementById('attrs-list')!;
  list.innerHTML = attrs.map((a, i) => `
    <div class="flex gap-2 items-start">
      <div class="flex-1 space-y-1">
        <input data-i="${i}" data-f="trait_type" type="text" value="${a.trait_type}"
          placeholder="Trait Type" class="attr-field w-full bg-bg border border-border rounded px-2 py-1 text-xs focus:outline-none focus:border-primary" />
        <input data-i="${i}" data-f="value" type="text" value="${a.value}"
          placeholder="Value" class="attr-field w-full bg-bg border border-border rounded px-2 py-1 text-xs focus:outline-none focus:border-primary" />
      </div>
      <div class="flex-1">
        <select data-i="${i}" data-f="display_type" class="attr-field w-full bg-bg border border-border rounded px-2 py-1 text-xs focus:outline-none focus:border-primary">
          <option value="">String trait</option>
          <option value="number" ${a.display_type==='number'?'selected':''}>Number</option>
          <option value="boost_number" ${a.display_type==='boost_number'?'selected':''}>Boost (number)</option>
          <option value="boost_percentage" ${a.display_type==='boost_percentage'?'selected':''}>Boost (%)</option>
          <option value="date" ${a.display_type==='date'?'selected':''}>Date (Unix timestamp)</option>
        </select>
      </div>
      <button data-del="${i}" class="attr-del text-red-400 text-xs px-2 py-1 mt-0.5 hover:text-red-300">✕</button>
    </div>
  `).join('');

  list.querySelectorAll('.attr-field').forEach(el => {
    el.addEventListener('input', (e) => {
      const t = e.target as HTMLInputElement;
      const i = parseInt(t.dataset.i!);
      const f = t.dataset.f! as keyof Attr;
      (attrs[i] as any)[f] = t.value;
      update();
    });
    el.addEventListener('change', (e) => {
      const t = e.target as HTMLSelectElement;
      const i = parseInt(t.dataset.i!);
      attrs[i].display_type = t.value || undefined;
      update();
    });
  });

  list.querySelectorAll('.attr-del').forEach(el => {
    el.addEventListener('click', (e) => {
      const i = parseInt((e.target as HTMLElement).dataset.del!);
      attrs.splice(i, 1);
      renderAttrs();
      update();
    });
  });
}

function update() {
  const std = (document.querySelector('input[name="standard"]:checked') as HTMLInputElement).value;
  const name = sv('nft-name') || 'Unnamed NFT';
  const desc = sv('nft-desc');
  const image = sv('nft-image');
  const external = sv('nft-external');
  const bg = sv('nft-bg');
  const animation = sv('nft-animation');

  const meta: Record<string, unknown> = { name, description: desc, image };
  if (external) meta.external_url = external;
  if (bg) meta.background_color = bg;
  if (animation) meta.animation_url = animation;

  const attrOut = attrs.filter(a => a.trait_type || a.value).map(a => {
    const obj: Record<string, unknown> = { trait_type: a.trait_type, value: a.display_type && a.display_type !== '' ? Number(a.value) || a.value : a.value };
    if (a.display_type) obj.display_type = a.display_type;
    return obj;
  });
  if (attrOut.length) meta.attributes = attrOut;

  if (std === '1155') {
    meta.decimals = 0;
    meta.properties = { files: [{ uri: image, type: 'image/png' }] };
  }

  document.getElementById('json-output')!.textContent = JSON.stringify(meta, null, 2);
}

document.getElementById('add-attr')!.addEventListener('click', () => {
  attrs.push({ trait_type: '', value: '' });
  renderAttrs();
  update();
});

document.querySelectorAll('input[name="standard"]').forEach(el => el.addEventListener('change', update));
['nft-name','nft-desc','nft-image','nft-external','nft-bg','nft-animation'].forEach(id => {
  document.getElementById(id)?.addEventListener('input', update);
});

document.getElementById('copy-json')!.addEventListener('click', () => {
  navigator.clipboard.writeText(document.getElementById('json-output')!.textContent || '');
});

document.getElementById('download-json')!.addEventListener('click', () => {
  const blob = new Blob([document.getElementById('json-output')!.textContent || ''], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = 'metadata.json'; a.click();
  URL.revokeObjectURL(url);
});

renderAttrs();
update();
</script>
