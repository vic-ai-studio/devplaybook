---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a Grafana dashboard JSON model?", answer: "Every Grafana dashboard is stored as a JSON document describing panels, data sources, variables, and layout. You can export/import dashboards as JSON, store them in version control, and provision them automatically via Grafana's provisioning system. The JSON model is the source of truth for Infrastructure as Code (IaC) dashboard management." },
  { question: "What is the difference between time_series and stat panels?", answer: "time_series panels show metrics over time as line/bar/area charts — ideal for CPU, request rate, latency trends. stat panels show a single current value (with optional thresholds and color) — ideal for uptime, current error rate, or latest metric value. For dashboards, combine time_series for trends and stat for at-a-glance health." },
  { question: "How do Grafana variables work?", answer: "Variables let users filter dashboards dynamically. A query variable runs a Prometheus/Loki query to populate a dropdown (e.g., all running pods). An interval variable controls the step of metric queries. Use $variable_name in your panel queries to make them dynamic. Variables are defined in the templating section of the dashboard JSON." },
  { question: "What is Grafana provisioning?", answer: "Grafana provisioning lets you define dashboards and datasources as YAML/JSON files on disk, automatically loaded at startup. This enables GitOps workflows where dashboards are code-reviewed and deployed via CI/CD. Place dashboard JSON files in /var/lib/grafana/dashboards/ and configure a YAML provider in /etc/grafana/provisioning/dashboards/." },
  { question: "How do I set thresholds on panels?", answer: "Thresholds define color zones for stat and gauge panels. Define steps as an array: { color: 'green', value: null } sets the base color, { color: 'yellow', value: 80 } turns yellow above 80, { color: 'red', value: 90 } turns red above 90. In JSON they live under fieldConfig.defaults.thresholds.steps." },
];
---

<BaseLayout
  title="Grafana Dashboard JSON Builder — Visual Panel Builder with Query Templates"
  description="Build Grafana dashboard JSON visually. Add time series, stat, and gauge panels with Prometheus query templates, thresholds, and variables. Export ready-to-import dashboard JSON. Free online tool."
  tool="Grafana dashboard JSON builder, Grafana panel generator, Grafana JSON export, Grafana provisioning, Prometheus query template"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Grafana Dashboard JSON Builder",
    "url": "https://devplaybook.cc/tools/grafana-dashboard-json-builder",
    "description": "Build Grafana dashboard JSON visually with panel templates and Prometheus query snippets. Export and import directly into Grafana.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Grafana Dashboard JSON Builder</h1>
  <p class="text-text-muted mb-4">Add panels visually, configure Prometheus queries and thresholds, then export production-ready Grafana dashboard JSON for direct import or provisioning.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> time_series / stat / gauge panels</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Prometheus query templates</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Threshold color zones</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Import-ready JSON</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <div class="space-y-4">
      <!-- Dashboard meta -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold mb-3">Dashboard</h2>
        <div class="space-y-2">
          <div>
            <label class="block text-xs text-text-muted mb-1">Title</label>
            <input type="text" id="dash-title" value="Service Overview" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
          </div>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="block text-xs text-text-muted mb-1">UID (optional)</label>
              <input type="text" id="dash-uid" placeholder="auto-generated" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">Refresh</label>
              <select id="dash-refresh" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
                <option value="">Off</option>
                <option value="5s">5s</option>
                <option value="30s" selected>30s</option>
                <option value="1m">1m</option>
                <option value="5m">5m</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <!-- Add panel -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold mb-3">Add Panel</h2>
        <div class="space-y-2">
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="block text-xs text-text-muted mb-1">Panel Title</label>
              <input type="text" id="panel-title" value="Request Rate" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">Type</label>
              <select id="panel-type" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
                <option value="timeseries">time_series</option>
                <option value="stat">stat</option>
                <option value="gauge">gauge</option>
              </select>
            </div>
          </div>
          <div>
            <label class="block text-xs text-text-muted mb-1">Prometheus Query</label>
            <input type="text" id="panel-query" value="rate(http_requests_total[5m])" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
          </div>
          <div>
            <label class="block text-xs text-text-muted mb-1">Unit</label>
            <select id="panel-unit" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="short">short (auto)</option>
              <option value="reqps">requests/sec</option>
              <option value="ms">milliseconds</option>
              <option value="s">seconds</option>
              <option value="percent">percent (0-100)</option>
              <option value="percentunit">percent (0-1)</option>
              <option value="bytes">bytes</option>
              <option value="Bps">bytes/sec</option>
            </select>
          </div>
          <div class="flex gap-2 flex-wrap">
            <span class="text-xs text-text-muted">Quick queries:</span>
            <button class="qbtn text-xs text-primary border border-border rounded px-2 py-0.5 hover:border-primary" data-q="rate(http_requests_total{job=&quot;$job&quot;}[5m])">req/s</button>
            <button class="qbtn text-xs text-primary border border-border rounded px-2 py-0.5 hover:border-primary" data-q="histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m]))">p99 latency</button>
            <button class="qbtn text-xs text-primary border border-border rounded px-2 py-0.5 hover:border-primary" data-q="100 - avg(rate(node_cpu_seconds_total{mode=&quot;idle&quot;}[1m])) * 100">CPU %</button>
            <button class="qbtn text-xs text-primary border border-border rounded px-2 py-0.5 hover:border-primary" data-q="(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100">Memory %</button>
          </div>
          <button id="add-panel-btn" class="w-full py-2 bg-primary/10 text-primary border border-primary/30 text-sm rounded-lg hover:bg-primary/20 transition-colors">+ Add Panel</button>
        </div>
      </div>

      <!-- Panel list -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold">Panels (<span id="panel-count">0</span>)</h2>
          <button id="clear-panels" class="text-xs text-text-muted hover:text-primary">Clear all</button>
        </div>
        <div id="panel-list" class="space-y-2 text-sm text-text-muted">
          <p class="text-xs italic">No panels yet — add one above.</p>
        </div>
      </div>

      <button id="export-btn" class="w-full py-2.5 bg-primary text-white font-medium rounded-lg hover:bg-primary/80 transition-colors">Export Dashboard JSON</button>
    </div>

    <!-- Output -->
    <div>
      <div class="bg-bg-card border border-border rounded-xl p-5 h-full flex flex-col">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold">dashboard.json</h2>
          <button id="copy-btn" class="text-xs border border-border text-text-muted rounded px-2 py-0.5 hover:border-primary hover:text-primary">Copy</button>
        </div>
        <pre id="output" class="font-mono text-xs bg-bg rounded p-3 border border-border overflow-auto flex-1 whitespace-pre text-text min-h-96">Click "Export Dashboard JSON" to generate output.</pre>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Grafana Dashboard JSON Builder" relatedTags={['grafana', 'monitoring', 'prometheus', 'observability', 'devops', 'metrics']} />
</BaseLayout>

<script>
  interface Panel { title: string; type: string; query: string; unit: string; id: number }
  let panels: Panel[] = [];
  let nextId = 1;

  document.querySelectorAll('.qbtn').forEach(btn => {
    btn.addEventListener('click', () => {
      (document.getElementById('panel-query') as HTMLInputElement).value = (btn as HTMLElement).dataset.q || '';
    });
  });

  document.getElementById('add-panel-btn')!.addEventListener('click', () => {
    const title = (document.getElementById('panel-title') as HTMLInputElement).value || 'Panel';
    const type = (document.getElementById('panel-type') as HTMLSelectElement).value;
    const query = (document.getElementById('panel-query') as HTMLInputElement).value || 'up';
    const unit = (document.getElementById('panel-unit') as HTMLSelectElement).value;
    panels.push({ title, type, query, unit, id: nextId++ });
    renderPanelList();
  });

  document.getElementById('clear-panels')!.addEventListener('click', () => {
    panels = [];
    renderPanelList();
  });

  function renderPanelList() {
    const list = document.getElementById('panel-list') as HTMLDivElement;
    (document.getElementById('panel-count') as HTMLSpanElement).textContent = String(panels.length);
    if (panels.length === 0) {
      list.innerHTML = '<p class="text-xs italic">No panels yet — add one above.</p>';
      return;
    }
    list.innerHTML = panels.map(p => `
      <div class="flex items-center justify-between bg-bg border border-border rounded p-2">
        <div>
          <span class="font-medium text-text">${p.title}</span>
          <span class="ml-2 text-xs text-text-muted">[${p.type}]</span>
          <div class="text-xs text-text-muted font-mono truncate max-w-48">${p.query}</div>
        </div>
        <button class="del-panel text-xs text-red-400 hover:text-red-600 ml-2 flex-shrink-0" data-id="${p.id}">✕</button>
      </div>
    `).join('');
    document.querySelectorAll('.del-panel').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = parseInt((btn as HTMLElement).dataset.id || '0');
        panels = panels.filter(p => p.id !== id);
        renderPanelList();
      });
    });
  }

  function buildDashboard() {
    const title = (document.getElementById('dash-title') as HTMLInputElement).value || 'My Dashboard';
    const uid = (document.getElementById('dash-uid') as HTMLInputElement).value || undefined;
    const refresh = (document.getElementById('dash-refresh') as HTMLSelectElement).value;
    const cols = 24;
    const panelW = 12;

    const builtPanels = panels.map((p, i) => {
      const x = (i % 2) * panelW;
      const y = Math.floor(i / 2) * 8;
      const panel: Record<string, unknown> = {
        id: p.id,
        title: p.title,
        type: p.type,
        gridPos: { x, y, w: panelW, h: 8 },
        targets: [{ expr: p.query, refId: 'A', legendFormat: '{{instance}}' }],
        fieldConfig: {
          defaults: {
            unit: p.unit,
            color: { mode: 'palette-classic' },
          },
          overrides: [],
        },
        options: p.type === 'stat' ? { reduceOptions: { calcs: ['lastNotNull'] }, colorMode: 'background', graphMode: 'area', justifyMode: 'center' } :
                 p.type === 'gauge' ? { reduceOptions: { calcs: ['lastNotNull'] }, showThresholdLabels: false } : {},
      };
      return panel;
    });

    const dashboard: Record<string, unknown> = {
      title,
      ...(uid ? { uid } : {}),
      refresh: refresh || false,
      schemaVersion: 38,
      version: 1,
      panels: builtPanels,
      time: { from: 'now-1h', to: 'now' },
      timepicker: {},
      templating: { list: [] },
      annotations: { list: [] },
    };

    return JSON.stringify({ dashboard, overwrite: true, folderId: 0 }, null, 2);
  }

  document.getElementById('export-btn')!.addEventListener('click', () => {
    if (panels.length === 0) {
      (document.getElementById('output') as HTMLPreElement).textContent = '// Add at least one panel first.';
      return;
    }
    (document.getElementById('output') as HTMLPreElement).textContent = buildDashboard();
  });

  document.getElementById('copy-btn')!.addEventListener('click', () => {
    const txt = (document.getElementById('output') as HTMLPreElement).textContent || '';
    navigator.clipboard.writeText(txt);
    const btn = document.getElementById('copy-btn') as HTMLButtonElement;
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
  });
</script>
