---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GitCommitGenerator from '../../components/GitCommitGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Git Commit Message Generator — Conventional Commits"
  description="Generate well-formatted git commit messages following the Conventional Commits spec. Select type (feat, fix, docs…), optional scope, short description, body, breaking change flag, and issue references."
  tool="Git Commit Message Generator, Conventional Commits Generator, Git Commit Formatter, Commit Message Builder"
>
  <h1 class="text-3xl font-bold mb-2">Git Commit Message Generator</h1>
  <p class="text-text-muted mb-8">Generate clean, consistent commit messages following the <a href="https://www.conventionalcommits.org/" target="_blank" rel="noopener" class="text-primary hover:underline">Conventional Commits</a> spec. Select type, scope, write a description, and copy in one click.</p>
  <GitCommitGenerator client:load />
  <ToolPageCta currentTool="Git Commit Message Generator" relatedTags={['git', 'commits', 'version-control', 'developer-tools']} />
</BaseLayout>
