---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GitCommitGenerator from '../../components/GitCommitGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the Conventional Commits specification?", answer: "Conventional Commits is a lightweight convention on top of commit messages that provides an easy set of rules for creating an explicit commit history. Format: <type>[optional scope]: <description>. Common types: feat (new feature), fix (bug fix), docs, style, refactor, test, chore. This enables automated changelog generation and semantic versioning." },
  { question: "What commit types should I use?", answer: "Use 'feat' for new features, 'fix' for bug fixes, 'docs' for documentation changes, 'style' for code formatting (no logic change), 'refactor' for code restructuring, 'test' for adding tests, 'chore' for build process or tooling changes, and 'perf' for performance improvements." },
  { question: "When should I include a scope in my commit?", answer: "Add a scope when your change targets a specific part of the codebase, e.g., feat(auth): add OAuth2 support or fix(api): handle null response from /users. Use short, consistent scope names across the project. Omit scope for changes that span multiple areas." },
  { question: "How do I mark a breaking change in Conventional Commits?", answer: "Append an exclamation mark after the type/scope: feat!: remove legacy API. Or add a BREAKING CHANGE: footer in the commit body. This signals to semantic versioning tools to bump the major version, e.g., from 1.x.x to 2.0.0." },
  { question: "How does this tool differ from writing commits manually?", answer: "This generator ensures you never forget the Conventional Commits format by guiding you through each field: type, scope, short description, optional body, breaking change flag, and issue references. It produces correctly formatted output you can paste directly into git commit -m or a GUI client." },
];
---

<BaseLayout
  title="Git Commit Message Generator — Conventional Commits — Free"
  description="Generate clean git commit messages following the Conventional Commits spec. Select type (feat, fix, docs…), add scope, description, body, breaking change, and issue references. Copy in one click. Free, runs in your browser."
  tool="Git Commit Message Generator, Conventional Commits Generator, Git Commit Formatter, Commit Message Builder, feat fix docs chore"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Git Commit Message Generator</h1>
  <p class="text-text-muted mb-4">Generate clean, consistent commit messages following the <a href="https://www.conventionalcommits.org/" target="_blank" rel="noopener" class="text-primary hover:underline">Conventional Commits</a> spec. Select type, scope, write a description, and copy in one click.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Follows Conventional Commits spec</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <GitCommitGenerator client:load />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Git Commit Message Generator" relatedTags={['git', 'commits', 'version-control', 'developer-tools']} />
</BaseLayout>
