---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "How is AWS Lambda pricing calculated?", answer: "AWS Lambda charges on two dimensions: number of requests ($0.20 per 1M requests) and duration (GB-seconds of memory × execution time). Duration is billed in 1ms increments at $0.0000166667 per GB-second. The free tier includes 1M requests and 400,000 GB-seconds per month. For a 512MB function running for 100ms, that's 0.512 GB × 0.1s = 0.0512 GB-seconds per invocation." },
  { question: "How is Cloudflare Workers pricing calculated?", answer: "Workers has two plans: Free (100K requests/day, 10ms CPU/request) and Paid Bundled ($5/month for 10M requests, then $0.50/M additional, 50ms CPU). Workers Unbound is $0.015/M requests + $0.0000125/GB-second CPU time. Workers are significantly cheaper than Lambda for high-volume short requests because there's no per-GB-second charge on Bundled pricing." },
  { question: "How is Vercel Edge Functions pricing calculated?", answer: "Vercel Edge Functions on Pro plan ($20/month) include 1M invocations. Additional invocations cost $2/M on Pro. Edge Functions run on Vercel's edge network (powered by Cloudflare) with very low latency. They're best for auth middleware, redirects, A/B testing, and geolocation — not heavy compute." },
  { question: "Which platform is cheapest for high-volume APIs?", answer: "For very high volume (100M+ requests/month), Cloudflare Workers Unbound is often cheapest, especially for CPU-light workloads. For moderate volume (1-10M requests) with mixed compute, Lambda can be competitive. Vercel Edge is competitive for Next.js apps already on Vercel. Always compare at your specific request volume and duration profile." },
  { question: "What costs are NOT included in this calculator?", answer: "This calculator covers compute costs only. Not included: data transfer/egress costs (Lambda outbound: $0.09/GB), API Gateway costs ($3.50/M calls), KV/D1/R2 storage (Workers), DynamoDB/RDS (Lambda), cold start impact on user experience, monitoring/logging costs, and developer time for migration." },
];
---

<BaseLayout
  title="Serverless Cost Estimator — Lambda vs Cloudflare Workers vs Vercel Edge"
  description="Compare serverless compute costs across AWS Lambda, Cloudflare Workers, and Vercel Edge Functions. Enter requests per month, execution time, and memory to get monthly cost estimates. Free browser tool."
  tool="serverless cost estimator, lambda vs cloudflare workers cost, vercel edge functions pricing, serverless pricing calculator, aws lambda cost calculator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Serverless Architecture Cost Estimator",
    "url": "https://devplaybook.cc/tools/serverless-cost-estimator",
    "description": "Compare serverless compute costs across AWS Lambda, Cloudflare Workers, and Vercel Edge Functions.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Serverless Architecture Cost Estimator</h1>
  <p class="text-text-muted mb-4">Compare monthly compute costs for AWS Lambda, Cloudflare Workers, and Vercel Edge Functions based on your request volume, execution time, and memory.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Lambda / Workers / Vercel</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Free tier included</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Side-by-side comparison</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 2026 pricing</span>
  </div>

  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-semibold mb-3">Workload Configuration</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <div>
        <label class="block text-xs text-text-muted mb-1">Requests per Month</label>
        <input id="requests" type="number" value="5000000" min="1" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Avg Execution Time (ms)</label>
        <input id="duration" type="number" value="100" min="1" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Memory (Lambda/Workers)</label>
        <select id="memory" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="128">128 MB</option>
          <option value="256">256 MB</option>
          <option value="512" selected>512 MB</option>
          <option value="1024">1024 MB</option>
          <option value="2048">2048 MB</option>
          <option value="3008">3008 MB</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Region</label>
        <select id="region" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="us">US East/West</option>
          <option value="eu">EU (West)</option>
          <option value="ap">Asia Pacific</option>
        </select>
      </div>
    </div>
  </div>

  <div id="results" class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4"></div>

  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-semibold mb-3">Cost Comparison Chart</h2>
    <div id="chart" class="space-y-3"></div>
  </div>

  <div id="recommendation" class="bg-bg-card border border-border rounded-lg p-4 mb-4"></div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Serverless Cost Estimator" relatedTags={['aws', 'cloudflare', 'vercel', 'serverless', 'cost', 'pricing']} />
</BaseLayout>

<script is:inline>
(function() {
  function calcLambda(reqs, durationMs, memMB) {
    const FREE_REQS = 1000000;
    const FREE_GBS = 400000;
    const REQ_COST = 0.20 / 1000000;
    const DUR_COST = 0.0000166667; // per GB-second

    const billableReqs = Math.max(0, reqs - FREE_REQS);
    const gbSeconds = (memMB / 1024) * (durationMs / 1000) * reqs;
    const billableGbs = Math.max(0, gbSeconds - FREE_GBS);
    const cost = (billableReqs * REQ_COST) + (billableGbs * DUR_COST);
    return { cost, breakdown: [`Requests: ${fmt(billableReqs)}M billable × $0.20/M`, `Duration: ${gbSeconds.toFixed(0)} GB-s (${billableGbs.toFixed(0)} billable) × $0.0000166667`] };
  }

  function calcCfWorkers(reqs, durationMs, memMB) {
    // Paid Bundled: $5/mo for 10M reqs, $0.50 per additional 1M
    // Unbound: $0.015/M reqs + $0.0000125/GB-s CPU
    const BUNDLED_BASE = 5;
    const BUNDLED_FREE_REQS = 10000000;
    const BUNDLED_ADD = 0.50 / 1000000;
    const UNBOUND_REQ = 0.015 / 1000000;
    const UNBOUND_GBS = 0.0000125;

    const bundled = BUNDLED_BASE + Math.max(0, reqs - BUNDLED_FREE_REQS) * BUNDLED_ADD;
    const gbSeconds = (memMB / 1024) * (durationMs / 1000) * reqs;
    const unbound = (reqs * UNBOUND_REQ) + (gbSeconds * UNBOUND_GBS);
    const cost = Math.min(bundled, unbound);
    const plan = bundled < unbound ? 'Bundled' : 'Unbound';
    return { cost, plan, breakdown: [`Bundled: $${bundled.toFixed(2)}/mo`, `Unbound: $${unbound.toFixed(2)}/mo`, `Using: ${plan}`] };
  }

  function calcVercel(reqs) {
    // Pro: $20/mo, 1M invocations included, $2/M additional
    const PRO_BASE = 20;
    const PRO_FREE = 1000000;
    const PRO_ADD = 2 / 1000000;
    const cost = PRO_BASE + Math.max(0, reqs - PRO_FREE) * PRO_ADD;
    return { cost, breakdown: [`Pro plan base: $20/mo (1M included)`, `Additional: ${fmt(Math.max(0, reqs - PRO_FREE))}M × $2/M`] };
  }

  function fmt(n) { return (n / 1000000).toFixed(2); }
  function fmtCost(c) { return c < 0.01 ? '<$0.01' : '$' + c.toFixed(2); }

  function update() {
    const reqs = parseInt(document.getElementById('requests').value) || 1000000;
    const dur = parseInt(document.getElementById('duration').value) || 100;
    const mem = parseInt(document.getElementById('memory').value) || 512;

    const lambda = calcLambda(reqs, dur, mem);
    const workers = calcCfWorkers(reqs, dur, mem);
    const vercel = calcVercel(reqs);

    const platforms = [
      { name: 'AWS Lambda', color: 'text-yellow-400', bg: 'bg-yellow-500', data: lambda },
      { name: 'Cloudflare Workers', color: 'text-orange-400', bg: 'bg-orange-500', data: workers },
      { name: 'Vercel Edge', color: 'text-blue-400', bg: 'bg-blue-500', data: vercel },
    ];

    const minCost = Math.min(lambda.cost, workers.cost, vercel.cost);
    const maxCost = Math.max(lambda.cost, workers.cost, vercel.cost);

    document.getElementById('results').innerHTML = platforms.map(p => `
      <div class="bg-bg-card border border-border rounded-lg p-4 ${p.data.cost === minCost ? 'border-green-500/50' : ''}">
        <div class="flex justify-between items-start mb-2">
          <h3 class="text-sm font-semibold ${p.color}">${p.name}</h3>
          ${p.data.cost === minCost ? '<span class="text-xs bg-green-500/20 text-green-400 px-1.5 py-0.5 rounded">Cheapest</span>' : ''}
        </div>
        <div class="text-3xl font-bold mb-3">${fmtCost(p.data.cost)}<span class="text-sm font-normal text-text-muted">/mo</span></div>
        <div class="space-y-1 text-xs text-text-muted">
          ${p.data.breakdown.map(b => `<p>${b}</p>`).join('')}
        </div>
      </div>`).join('');

    document.getElementById('chart').innerHTML = platforms.sort((a,b) => a.data.cost - b.data.cost).map(p => {
      const pct = maxCost > 0 ? Math.max(3, Math.round((p.data.cost / maxCost) * 100)) : 3;
      return `<div class="flex items-center gap-3">
        <span class="text-xs w-36 shrink-0 ${p.color}">${p.name}</span>
        <div class="flex-1 bg-surface rounded h-6 overflow-hidden">
          <div class="h-6 rounded ${p.bg} opacity-80" style="width:${pct}%"></div>
        </div>
        <span class="text-xs w-20 text-right font-mono shrink-0">${fmtCost(p.data.cost)}/mo</span>
      </div>`;
    }).join('');

    const winner = platforms.find(p => p.data.cost === minCost);
    document.getElementById('recommendation').innerHTML = `
      <h2 class="text-sm font-semibold mb-2">Recommendation</h2>
      <p class="text-sm text-text-muted">For <strong>${(reqs/1000000).toFixed(1)}M requests/month</strong> at ${dur}ms avg with ${mem}MB memory:</p>
      <p class="text-sm mt-1"><strong class="${winner.color}">${winner.name}</strong> is cheapest at <strong>${fmtCost(winner.data.cost)}/mo</strong> — saving ${fmtCost(maxCost - minCost)}/mo vs the most expensive option.</p>
      ${dur <= 50 && mem <= 256 ? '<p class="text-xs text-text-muted mt-2">💡 Short CPU-light requests — Cloudflare Workers Bundled flat rate often wins here.</p>' : ''}
      ${dur > 1000 ? '<p class="text-xs text-text-muted mt-2">⚠️ Long-running functions (>1s) — consider Lambda over Cloudflare Workers (Workers have 30s wall clock limit).</p>' : ''}
      <p class="text-xs text-text-muted mt-2">Note: Excludes data transfer, API Gateway, storage, and operational costs.</p>`;
  }

  ['requests','duration','memory','region'].forEach(id => {
    document.getElementById(id).addEventListener('input', update);
    document.getElementById(id).addEventListener('change', update);
  });

  update();
})();
</script>
