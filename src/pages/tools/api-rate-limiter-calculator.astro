---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ApiRateLimiterCalculator from '../../components/ApiRateLimiterCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is the difference between Token Bucket and Leaky Bucket?",
    answer: "Token Bucket accumulates tokens over time and allows short bursts when tokens are saved up — if no requests came in for 5 seconds, the bucket fills and the next burst can fire quickly. Leaky Bucket processes requests at a strictly constant output rate regardless of how they arrive, acting more like a queue with a fixed drain speed. Token Bucket is better when occasional bursts are acceptable; Leaky Bucket is better when the downstream system requires perfectly smooth traffic.",
  },
  {
    question: "What is the boundary burst problem with Fixed Window rate limiting?",
    answer: "Fixed Window counters reset at fixed clock boundaries (e.g., every minute at :00). A client can send the full window quota in the last second of one window and immediately again in the first second of the next window — effectively sending 2× the intended rate without being throttled. Sliding Window algorithms solve this by evaluating the most recent N seconds at any point in time, with no hard resets.",
  },
  {
    question: "When should I use Sliding Window Log vs Sliding Window Counter?",
    answer: "Sliding Window Log stores every individual request timestamp, giving you mathematically exact rate limiting. Use it when precision is critical (financial transactions, audit-sensitive APIs). Sliding Window Counter uses just two counters with a weighted approximation, giving ~±10% accuracy at window boundaries. Use it when you need high scale and low memory — it is the algorithm behind Cloudflare's rate limiting and Nginx's limit_req_zone.",
  },
  {
    question: "How do I choose the right burst capacity for Token Bucket?",
    answer: "Burst capacity should reflect the largest legitimate traffic spike your API can absorb without degrading. A common rule: set burst capacity to 10–20% of your per-minute rate limit. For example, if your limit is 100 req/min (~1.67 req/s), a burst of 10–20 tokens lets clients make a batch of requests immediately, then they refill at the sustained rate. Set it too high and you lose protection against abuse; too low and normal clients hit 429 errors.",
  },
  {
    question: "How much Redis memory does sliding window rate limiting use?",
    answer: "Sliding Window Counter uses approximately 74 bytes per user (two counters + timestamp + key overhead) regardless of traffic volume — very memory-efficient at any scale. Sliding Window Log scales with the number of requests per window: if your limit is 100 req/min and the window is 60 seconds, you store up to 100 timestamps (8 bytes each) plus key overhead, totaling ~850 bytes per active user. For 100,000 active users that is about 85 MB — manageable but worth planning for.",
  },
  {
    question: "What HTTP status code and headers should rate-limited responses return?",
    answer: "Return HTTP 429 Too Many Requests. Include the following headers: Retry-After (seconds until the client can retry), X-RateLimit-Limit (total allowed requests in the window), X-RateLimit-Remaining (requests left in the current window), and X-RateLimit-Reset (Unix timestamp when the window resets). This allows well-behaved API clients to back off automatically and retry intelligently without polling your API.",
  },
];
---

<BaseLayout
  title="API Rate Limiter Calculator — Token Bucket, Sliding Window & More"
  description="Calculate API rate limiting metrics: effective RPS, burst capacity, rejection rate under load, and Redis memory estimates. Supports Token Bucket, Leaky Bucket, Fixed Window, Sliding Window Log, and Sliding Window Counter algorithms."
  tool="API Rate Limiter Calculator, Token Bucket Calculator, Sliding Window Rate Limit, Rate Limiting Algorithms, API Throttle Calculator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">API Rate Limiter Calculator</h1>
  <p class="text-text-muted mb-4">
    Calculate effective RPS, burst capacity, request rejection rates, and Redis memory usage for any rate limiting strategy.
    Compare Token Bucket, Leaky Bucket, Fixed Window, Sliding Window Log, and Sliding Window Counter side by side.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 rate limiting algorithms</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Rejection % under simultaneous load</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Redis memory estimates</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Common API limits reference</span>
  </div>
  <ApiRateLimiterCalculator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="API Rate Limiter Calculator" relatedTags={['api', 'rate-limiting', 'redis', 'http', 'developer-tools', 'backend']} />
</BaseLayout>
