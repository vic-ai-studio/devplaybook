---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is HashiCorp Nomad?", answer: "Nomad is a flexible workload orchestrator from HashiCorp. Unlike Kubernetes, it can schedule not just containers but also raw executables, Java applications, and VMs. It's simpler to operate than Kubernetes and integrates natively with Vault (secrets) and Consul (service mesh). Ideal for mixed workloads and teams transitioning to containers." },
  { question: "What is a Nomad job spec?", answer: "A job spec (job specification) is an HCL or JSON file that defines what to run, where, and how many instances. It includes the job type (service, batch, system), task groups (sets of co-located tasks), tasks (individual processes), resources (CPU/memory), network ports, and health checks. Submitted with `nomad job run job.hcl`." },
  { question: "What are the Nomad job types?", answer: "Three types: (1) service — long-running services that Nomad restarts if they fail, like web servers. (2) batch — short-lived tasks that run to completion, like data pipelines. (3) system — runs one instance on every eligible node, like log collectors or monitoring agents. Service jobs are most common for web applications." },
  { question: "How does Nomad handle service discovery?", answer: "Nomad integrates with Consul for service registration. Each task with a `service` block automatically registers in Consul when healthy. Other services can discover it via Consul DNS (`service-name.service.consul`) or the Consul HTTP API. Nomad also supports Nomad-native service discovery without Consul for simpler setups." },
  { question: "What is the difference between Nomad and Kubernetes?", answer: "Kubernetes is more feature-rich (CRDs, operators, extensive ecosystem) but complex to operate. Nomad is simpler, supports non-container workloads natively, has lower overhead, and is easier to self-host. Nomad excels in brownfield environments with mixed legacy apps. Kubernetes is better for greenfield, container-first teams with dedicated platform engineers." },
];
---

<BaseLayout
  title="Nomad Job Spec Builder — HashiCorp Nomad HCL Generator"
  description="Generate HashiCorp Nomad job specification HCL from form inputs. Build service, batch, and system jobs with task groups, resources, network ports, and Consul service registration."
  tool="Nomad Job Spec Builder, HashiCorp Nomad HCL Generator, Nomad Job Configuration, Nomad Task Group Builder, Nomad Service Job Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Nomad Job Spec Builder</h1>
  <p class="text-text-muted mb-4">Generate HashiCorp Nomad job specification HCL. Configure job type, task groups, resources, network, and Consul service registration from a visual form.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Service / batch / system jobs</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Docker + exec drivers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Consul service registration</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <!-- Left: Form -->
    <div class="space-y-4">
      <!-- Job config -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Job Configuration</h2>
        <div class="space-y-3">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium mb-1">Job Name</label>
              <input id="job-name" type="text" value="my-service"
                class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Job Type</label>
              <select id="job-type" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
                <option value="service">service</option>
                <option value="batch">batch</option>
                <option value="system">system</option>
              </select>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium mb-1">Datacenter</label>
              <input id="job-dc" type="text" value="dc1"
                class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Namespace</label>
              <input id="job-ns" type="text" value="default"
                class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
            </div>
          </div>
        </div>
      </div>

      <!-- Task group -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Task Group</h2>
        <div class="space-y-3">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium mb-1">Group Name</label>
              <input id="group-name" type="text" value="app"
                class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Count (replicas)</label>
              <input id="group-count" type="number" value="2" min="1"
                class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium mb-1">Driver</label>
              <select id="task-driver" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
                <option value="docker">docker</option>
                <option value="exec">exec</option>
                <option value="java">java</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Task Name</label>
              <input id="task-name" type="text" value="server"
                class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Docker Image</label>
            <input id="task-image" type="text" value="nginx:latest"
              class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
          </div>
        </div>
      </div>

      <!-- Resources -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Resources & Network</h2>
        <div class="grid grid-cols-2 gap-3 mb-3">
          <div>
            <label class="block text-sm font-medium mb-1">CPU (MHz)</label>
            <input id="res-cpu" type="number" value="500" min="100"
              class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Memory (MB)</label>
            <input id="res-mem" type="number" value="256" min="32"
              class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3 mb-3">
          <div>
            <label class="block text-sm font-medium mb-1">Port Label</label>
            <input id="port-label" type="text" value="http"
              class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Static Port (0 = dynamic)</label>
            <input id="port-static" type="number" value="0" min="0" max="65535"
              class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
          </div>
        </div>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="enable-service" checked /> Enable Consul service registration
        </label>
      </div>
    </div>

    <!-- Right: Output -->
    <div>
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-sm font-semibold">Generated HCL</h2>
        <button id="copy-nomad" class="text-xs border border-border text-text-muted rounded px-2 py-1 hover:border-primary">Copy</button>
      </div>
      <pre id="nomad-output" class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre-wrap min-h-[500px] max-h-[700px] overflow-y-auto"></pre>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Nomad Job Spec Builder" relatedTags={['nomad', 'hashicorp', 'devops', 'containers', 'orchestration', 'consul']} />
</BaseLayout>

<script>
  function getVal(id: string): string {
    return (document.getElementById(id) as HTMLInputElement | HTMLSelectElement)?.value || '';
  }
  function getChecked(id: string): boolean {
    return (document.getElementById(id) as HTMLInputElement)?.checked ?? false;
  }

  function generate() {
    const jobName = getVal('job-name');
    const jobType = getVal('job-type');
    const dc = getVal('job-dc');
    const ns = getVal('job-ns');
    const groupName = getVal('group-name');
    const count = getVal('group-count');
    const driver = getVal('task-driver');
    const taskName = getVal('task-name');
    const image = getVal('task-image');
    const cpu = getVal('res-cpu');
    const mem = getVal('res-mem');
    const portLabel = getVal('port-label');
    const portStatic = parseInt(getVal('port-static'));
    const enableService = getChecked('enable-service');

    const portSpec = portStatic > 0
      ? `port "${portLabel}" {\n        static = ${portStatic}\n      }`
      : `port "${portLabel}" {}`;

    const serviceBlock = enableService ? `
      service {
        name = "${jobName}"
        port = "${portLabel}"

        check {
          name     = "alive"
          type     = "tcp"
          interval = "10s"
          timeout  = "2s"
        }
      }` : '';

    const configBlock = driver === 'docker'
      ? `config {\n        image = "${image}"\n        ports = ["${portLabel}"]\n      }`
      : driver === 'exec'
      ? `config {\n        command = "/usr/local/bin/${jobName}"\n      }`
      : `config {\n        jar_path = "${jobName}.jar"\n        jvm_options = ["-Xmx256m", "-Xms64m"]\n      }`;

    const output = `job "${jobName}" {
  type      = "${jobType}"
  datacenters = ["${dc}"]
  namespace = "${ns}"

  group "${groupName}" {
    count = ${count}

    network {
      ${portSpec}
    }

    task "${taskName}" {
      driver = "${driver}"

      ${configBlock}

      resources {
        cpu    = ${cpu}
        memory = ${mem}
      }
${serviceBlock}

      env {
        APP_ENV  = "\${NOMAD_META_environment}"
        ALLOC_ID = "\${NOMAD_ALLOC_ID}"
      }
    }
  }

  update {
    max_parallel      = 1
    min_healthy_time  = "10s"
    healthy_deadline  = "3m"
    auto_revert       = true
  }
}`;

    document.getElementById('nomad-output')!.textContent = output;
  }

  document.querySelectorAll('input, select').forEach(el => {
    el.addEventListener('input', generate);
    el.addEventListener('change', generate);
  });

  document.getElementById('copy-nomad')!.addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('nomad-output')!.textContent || '');
    const btn = document.getElementById('copy-nomad')!; btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = 'Copy', 2000);
  });

  generate();
</script>
