---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What are Core Web Vitals?", answer: "Core Web Vitals are three user-centric performance metrics defined by Google: LCP (Largest Contentful Paint) measures loading speed, INP (Interaction to Next Paint) measures responsiveness, and CLS (Cumulative Layout Shift) measures visual stability. Google uses these as ranking signals in search results since 2021." },
  { question: "What replaced FID in Core Web Vitals?", answer: "INP (Interaction to Next Paint) replaced FID (First Input Delay) as an official Core Web Vital in March 2024. FID only measured the delay before the browser could start processing an interaction; INP measures the full input latency including processing and rendering, giving a more accurate picture of page responsiveness." },
  { question: "What are the Good thresholds for Core Web Vitals?", answer: "Good thresholds: LCP ≤ 2.5 seconds (loading), INP ≤ 200 milliseconds (responsiveness), CLS ≤ 0.1 (visual stability). Values in the 'Needs Improvement' range are between Good and Poor thresholds. Poor thresholds: LCP > 4.0s, INP > 500ms, CLS > 0.25." },
  { question: "How do I measure my site's Core Web Vitals?", answer: "Field data (real users): Google Search Console, Chrome User Experience Report (CrUX), and the web-vitals.js library. Lab data (simulated): Chrome DevTools Lighthouse, PageSpeed Insights, and WebPageTest. Field data is what Google uses for ranking — lab data is a proxy for debugging." },
  { question: "What is TTFB and how does it affect LCP?", answer: "TTFB (Time to First Byte) is the time from the request to the first byte of the response. A TTFB over 800ms delays LCP because the browser can't start loading resources until the HTML arrives. Improve TTFB with a CDN, server-side caching, and reducing backend query time." },
  { question: "Why does CLS happen and how do I fix it?", answer: "CLS is caused by images/embeds without explicit size attributes, dynamically injected content above existing content (ads, banners, cookie notices), and web fonts causing text reflow (FOIT/FOUT). Fix: always set width and height on images, use aspect-ratio CSS, load fonts with font-display: optional, and avoid inserting above-fold content after load." },
];
---

<BaseLayout
  title="Core Web Vitals Guide — LCP, INP & CLS Score Simulator"
  description="Learn Core Web Vitals with interactive explanations of LCP, INP, and CLS. Enter your metric values to see Pass/Fail ratings and actionable optimization tips. Free browser tool."
  tool="Core Web Vitals guide, LCP INP CLS checker, Core Web Vitals simulator, Google PageSpeed metrics, web performance scoring"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Core Web Vitals Guide & Score Simulator",
    "url": "https://devplaybook.cc/tools/core-web-vitals",
    "description": "Interactive guide to Google Core Web Vitals (LCP, INP, CLS) with a score simulator. Enter your metric values and get instant Pass/Fail ratings with optimization tips.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Core Web Vitals Guide</h1>
  <p class="text-text-muted mb-4">
    Understand Google's Core Web Vitals — LCP, INP, and CLS — with plain-English explanations and an interactive score simulator.
    Enter your measured values to get instant Pass/Fail ratings with targeted optimization tips.
  </p>
  <div class="flex items-center gap-3 mb-8 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 2024 INP thresholds</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Good / Needs Improvement / Poor</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Optimization tips per metric</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <!-- Metric Cards (educational) -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-10">
    <!-- LCP -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-10 h-10 rounded-lg bg-blue-500/10 flex items-center justify-center text-xl">⚡</div>
        <div>
          <div class="font-bold text-base">LCP</div>
          <div class="text-xs text-text-muted">Largest Contentful Paint</div>
        </div>
      </div>
      <p class="text-sm text-text-muted mb-4">Measures how quickly the largest visible content element (hero image, heading, or text block) renders. Tracks <strong>loading performance</strong>.</p>
      <div class="space-y-1.5 text-xs">
        <div class="flex items-center justify-between px-3 py-1.5 rounded-lg bg-green-500/10 border border-green-500/20">
          <span class="text-green-400 font-semibold">✓ Good</span>
          <span class="font-mono text-green-400">≤ 2.5s</span>
        </div>
        <div class="flex items-center justify-between px-3 py-1.5 rounded-lg bg-yellow-500/10 border border-yellow-500/20">
          <span class="text-yellow-400 font-semibold">⚠ Needs Improvement</span>
          <span class="font-mono text-yellow-400">2.5s – 4.0s</span>
        </div>
        <div class="flex items-center justify-between px-3 py-1.5 rounded-lg bg-red-500/10 border border-red-500/20">
          <span class="text-red-400 font-semibold">✗ Poor</span>
          <span class="font-mono text-red-400">&gt; 4.0s</span>
        </div>
      </div>
      <div class="mt-4 text-xs text-text-muted">
        <span class="font-semibold text-text">Key fixes:</span> CDN, preload hero image, reduce TTFB, WebP/AVIF images
      </div>
    </div>

    <!-- INP -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center text-xl">🖱️</div>
        <div>
          <div class="font-bold text-base">INP</div>
          <div class="text-xs text-text-muted">Interaction to Next Paint</div>
        </div>
      </div>
      <p class="text-sm text-text-muted mb-4">Measures the full latency of all click, tap, and keyboard interactions. Replaced FID in March 2024. Tracks <strong>responsiveness</strong>.</p>
      <div class="space-y-1.5 text-xs">
        <div class="flex items-center justify-between px-3 py-1.5 rounded-lg bg-green-500/10 border border-green-500/20">
          <span class="text-green-400 font-semibold">✓ Good</span>
          <span class="font-mono text-green-400">≤ 200ms</span>
        </div>
        <div class="flex items-center justify-between px-3 py-1.5 rounded-lg bg-yellow-500/10 border border-yellow-500/20">
          <span class="text-yellow-400 font-semibold">⚠ Needs Improvement</span>
          <span class="font-mono text-yellow-400">200ms – 500ms</span>
        </div>
        <div class="flex items-center justify-between px-3 py-1.5 rounded-lg bg-red-500/10 border border-red-500/20">
          <span class="text-red-400 font-semibold">✗ Poor</span>
          <span class="font-mono text-red-400">&gt; 500ms</span>
        </div>
      </div>
      <div class="mt-4 text-xs text-text-muted">
        <span class="font-semibold text-text">Key fixes:</span> Break long tasks, defer non-critical JS, use scheduler.yield()
      </div>
    </div>

    <!-- CLS -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-10 h-10 rounded-lg bg-orange-500/10 flex items-center justify-center text-xl">📐</div>
        <div>
          <div class="font-bold text-base">CLS</div>
          <div class="text-xs text-text-muted">Cumulative Layout Shift</div>
        </div>
      </div>
      <p class="text-sm text-text-muted mb-4">Measures unexpected visual layout shifts during the page lifecycle. A score of 0 means no shifting. Tracks <strong>visual stability</strong>.</p>
      <div class="space-y-1.5 text-xs">
        <div class="flex items-center justify-between px-3 py-1.5 rounded-lg bg-green-500/10 border border-green-500/20">
          <span class="text-green-400 font-semibold">✓ Good</span>
          <span class="font-mono text-green-400">≤ 0.1</span>
        </div>
        <div class="flex items-center justify-between px-3 py-1.5 rounded-lg bg-yellow-500/10 border border-yellow-500/20">
          <span class="text-yellow-400 font-semibold">⚠ Needs Improvement</span>
          <span class="font-mono text-yellow-400">0.1 – 0.25</span>
        </div>
        <div class="flex items-center justify-between px-3 py-1.5 rounded-lg bg-red-500/10 border border-red-500/20">
          <span class="text-red-400 font-semibold">✗ Poor</span>
          <span class="font-mono text-red-400">&gt; 0.25</span>
        </div>
      </div>
      <div class="mt-4 text-xs text-text-muted">
        <span class="font-semibold text-text">Key fixes:</span> Set image dimensions, reserve ad space, avoid above-fold injection
      </div>
    </div>
  </div>

  <!-- Score Simulator -->
  <div class="bg-bg-card border border-border rounded-xl p-6 mb-8">
    <h2 class="text-xl font-bold mb-1">Score Simulator</h2>
    <p class="text-sm text-text-muted mb-5">Enter your measured values from PageSpeed Insights or Chrome DevTools to check your Core Web Vitals status.</p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-5">
      <!-- LCP Input -->
      <div>
        <label class="block text-sm font-medium mb-1.5" for="sim-lcp">LCP <span class="text-text-muted font-normal">(seconds)</span></label>
        <input id="sim-lcp" type="number" min="0" step="0.1" placeholder="e.g. 2.8"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
        <div class="text-xs text-text-muted mt-1">Good ≤ 2.5s · Poor &gt; 4.0s</div>
      </div>
      <!-- INP Input -->
      <div>
        <label class="block text-sm font-medium mb-1.5" for="sim-inp">INP <span class="text-text-muted font-normal">(milliseconds)</span></label>
        <input id="sim-inp" type="number" min="0" step="1" placeholder="e.g. 250"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
        <div class="text-xs text-text-muted mt-1">Good ≤ 200ms · Poor &gt; 500ms</div>
      </div>
      <!-- CLS Input -->
      <div>
        <label class="block text-sm font-medium mb-1.5" for="sim-cls">CLS <span class="text-text-muted font-normal">(score)</span></label>
        <input id="sim-cls" type="number" min="0" step="0.01" placeholder="e.g. 0.05"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
        <div class="text-xs text-text-muted mt-1">Good ≤ 0.1 · Poor &gt; 0.25</div>
      </div>
    </div>

    <div class="flex gap-3 mb-5">
      <button id="sim-btn" class="bg-primary text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-primary/80 transition-colors">
        Check My Vitals
      </button>
      <button id="sim-reset" class="text-sm text-text-muted hover:text-red-400 transition-colors">
        Reset
      </button>
    </div>

    <!-- Results -->
    <div id="sim-results" class="hidden space-y-4">
      <div id="sim-overall" class="rounded-xl p-4 border"></div>
      <div id="sim-cards" class="grid grid-cols-1 sm:grid-cols-3 gap-3"></div>
      <div id="sim-tips" class="bg-bg border border-border rounded-xl p-4">
        <h3 class="font-semibold text-sm mb-3">Optimization Recommendations</h3>
        <div id="sim-tips-list" class="space-y-2"></div>
      </div>
    </div>
  </div>

  <!-- How to measure section -->
  <div class="bg-bg-card border border-border rounded-xl p-6 mb-8">
    <h2 class="text-xl font-bold mb-4">How to Measure Your Core Web Vitals</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wide text-text-muted mb-3">Lab Tools (Simulated)</h3>
        <div class="space-y-2">
          <div class="flex items-start gap-3 p-3 rounded-lg bg-bg border border-border text-sm">
            <span class="text-lg shrink-0">🔍</span>
            <div>
              <div class="font-medium">Chrome DevTools — Lighthouse</div>
              <div class="text-text-muted text-xs mt-0.5">Open DevTools → Lighthouse tab → Analyze page load. Good for fast iteration during development.</div>
            </div>
          </div>
          <div class="flex items-start gap-3 p-3 rounded-lg bg-bg border border-border text-sm">
            <span class="text-lg shrink-0">📊</span>
            <div>
              <div class="font-medium">PageSpeed Insights</div>
              <div class="text-text-muted text-xs mt-0.5">web.dev/measure — shows both lab data (Lighthouse) and field data (CrUX) in one view.</div>
            </div>
          </div>
          <div class="flex items-start gap-3 p-3 rounded-lg bg-bg border border-border text-sm">
            <span class="text-lg shrink-0">🌐</span>
            <div>
              <div class="font-medium">WebPageTest</div>
              <div class="text-text-muted text-xs mt-0.5">Run from real browsers worldwide. Great for testing CDN impact and waterfall analysis.</div>
            </div>
          </div>
        </div>
      </div>
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wide text-text-muted mb-3">Field Data (Real Users)</h3>
        <div class="space-y-2">
          <div class="flex items-start gap-3 p-3 rounded-lg bg-bg border border-border text-sm">
            <span class="text-lg shrink-0">🔎</span>
            <div>
              <div class="font-medium">Google Search Console</div>
              <div class="text-text-muted text-xs mt-0.5">Core Web Vitals report shows real-user data by URL group. This is what affects your rankings.</div>
            </div>
          </div>
          <div class="flex items-start gap-3 p-3 rounded-lg bg-bg border border-border text-sm">
            <span class="text-lg shrink-0">📈</span>
            <div>
              <div class="font-medium">Chrome UX Report (CrUX)</div>
              <div class="text-text-muted text-xs mt-0.5">BigQuery dataset of real Chrome user data. Queryable via Google Data Studio or API.</div>
            </div>
          </div>
          <div class="flex items-start gap-3 p-3 rounded-lg bg-bg border border-border text-sm">
            <span class="text-lg shrink-0">📦</span>
            <div>
              <div class="font-medium">web-vitals.js library</div>
              <div class="text-text-muted text-xs mt-0.5">Install the npm package to collect real-user metrics and send them to your analytics. npm install web-vitals</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Core Web Vitals Guide" relatedTags={['performance', 'seo', 'pwa', 'lighthouse', 'developer-tools']} />
</BaseLayout>

<script is:inline>
(function () {
  var METRICS = {
    lcp: {
      label: 'LCP', unit: 's', good: 2.5, poor: 4.0,
      tips: {
        good: 'LCP is fast. Maintain it by keeping a CDN, preloading hero images, and TTFB under 600ms.',
        needs: 'Improve LCP: preload the LCP image with <link rel="preload">, use a CDN, convert images to WebP/AVIF, and reduce server response time.',
        poor: 'LCP is critical. Prioritize: move to a CDN, preload the largest above-fold element, eliminate render-blocking scripts, and aggressively compress images.'
      }
    },
    inp: {
      label: 'INP', unit: 'ms', good: 200, poor: 500,
      tips: {
        good: 'INP is responsive. Keep it up by avoiding long JS tasks and using requestIdleCallback for non-critical work.',
        needs: 'Reduce INP: break long tasks (>50ms) with scheduler.yield(), minimize JS bundle size, defer non-critical scripts, and reduce event handler work.',
        poor: 'INP is failing. Profile in Chrome DevTools → Performance. Identify long tasks and move heavy computation off the main thread using Web Workers or async chunking.'
      }
    },
    cls: {
      label: 'CLS', unit: '', good: 0.1, poor: 0.25,
      tips: {
        good: 'Layout is stable. Maintain it by always specifying width/height on images and not injecting content above existing elements.',
        needs: 'Reduce CLS: add width/height to all images and iframes, reserve space for ads with CSS aspect-ratio or min-height, and use font-display: optional.',
        poor: 'CLS is critical. Add explicit dimensions to all media, stop inserting content above the fold after load, and switch from layout-changing animations to CSS transform.'
      }
    }
  };

  function getStatus(m, v) {
    return v <= m.good ? 'good' : v <= m.poor ? 'needs' : 'poor';
  }

  function cfg(s) {
    return {
      good:  { label: 'Good',              color: 'text-green-400',  bg: 'bg-green-500/10 border-green-500/30',  icon: '✓' },
      needs: { label: 'Needs Improvement', color: 'text-yellow-400', bg: 'bg-yellow-500/10 border-yellow-500/30', icon: '⚠' },
      poor:  { label: 'Poor',              color: 'text-red-400',    bg: 'bg-red-500/10 border-red-500/30',    icon: '✗' }
    }[s];
  }

  document.getElementById('sim-btn').addEventListener('click', function () {
    var vals = {
      lcp: parseFloat(document.getElementById('sim-lcp').value),
      inp: parseFloat(document.getElementById('sim-inp').value),
      cls: parseFloat(document.getElementById('sim-cls').value)
    };
    var statuses = {};
    var count = 0;
    ['lcp', 'inp', 'cls'].forEach(function (k) {
      if (!isNaN(vals[k]) && vals[k] >= 0) { statuses[k] = getStatus(METRICS[k], vals[k]); count++; }
    });
    if (!count) { alert('Please enter at least one metric value.'); return; }

    var sl = Object.values(statuses);
    var overall = sl.includes('poor') ? 'poor' : sl.includes('needs') ? 'needs' : 'good';
    var oc = cfg(overall);
    var overallEl = document.getElementById('sim-overall');
    overallEl.className = 'rounded-xl p-4 border ' + oc.bg;
    overallEl.innerHTML = '<div class="flex items-center gap-3">'
      + '<span class="text-3xl">' + (overall === 'good' ? '🟢' : overall === 'needs' ? '🟡' : '🔴') + '</span>'
      + '<div><div class="font-bold text-lg">' + (overall === 'good' ? 'Passing Core Web Vitals' : overall === 'needs' ? 'Needs Improvement' : 'Failing Core Web Vitals') + '</div>'
      + '<div class="text-sm text-text-muted">' + (overall === 'good' ? 'All measured metrics meet Google\'s Good threshold.' : overall === 'needs' ? 'Some metrics need improvement to reach Google\'s Good threshold.' : 'One or more metrics are Poor — this may negatively impact search rankings.') + '</div>'
      + '</div></div>';

    var cardsEl = document.getElementById('sim-cards');
    cardsEl.innerHTML = '';
    Object.keys(statuses).forEach(function (k) {
      var m = METRICS[k]; var s = statuses[k]; var c = cfg(s);
      var card = document.createElement('div');
      card.className = 'bg-bg rounded-xl p-4 border ' + (s === 'good' ? 'border-green-500/30' : s === 'needs' ? 'border-yellow-500/30' : 'border-red-500/30');
      card.innerHTML = '<div class="flex items-center justify-between mb-2">'
        + '<span class="font-semibold">' + m.label + '</span>'
        + '<span class="text-lg font-bold font-mono ' + c.color + '">' + vals[k] + m.unit + '</span>'
        + '</div>'
        + '<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold border ' + c.bg + ' ' + c.color + '">'
        + c.icon + ' ' + c.label + '</span>';
      cardsEl.appendChild(card);
    });

    var tipsEl = document.getElementById('sim-tips-list');
    tipsEl.innerHTML = '';
    Object.keys(statuses).forEach(function (k) {
      var m = METRICS[k]; var s = statuses[k]; var c = cfg(s);
      var div = document.createElement('div');
      div.className = 'flex items-start gap-3 p-3 rounded-lg bg-bg-card border border-border';
      div.innerHTML = '<span class="shrink-0 font-bold text-sm ' + c.color + '">' + m.label + '</span>'
        + '<p class="text-sm text-text-muted">' + m.tips[s] + '</p>';
      tipsEl.appendChild(div);
    });

    document.getElementById('sim-results').classList.remove('hidden');
    document.getElementById('sim-results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });

  document.getElementById('sim-reset').addEventListener('click', function () {
    ['lcp', 'inp', 'cls'].forEach(function (k) { document.getElementById('sim-' + k).value = ''; });
    document.getElementById('sim-results').classList.add('hidden');
  });
})();
</script>
