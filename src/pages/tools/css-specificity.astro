---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CssSpecificityCalculator from '../../components/CssSpecificityCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="CSS Specificity Calculator"
  description="Calculate and compare CSS selector specificity instantly. See inline, ID, class, and element scores as (a,b,c,d) notation. Free CSS specificity checker, no signup needed."
  tool="CSS Specificity, CSS Selector Specificity, CSS Cascade"
>
  <h1 class="text-3xl font-bold mb-2">CSS Specificity Calculator</h1>
  <p class="text-text-muted mb-8">Calculate the specificity of any CSS selector in (inline, ID, class, element) notation. Compare two selectors to see which one wins the cascade.</p>
  <CssSpecificityCalculator client:load />
  <ToolPageCta currentTool="CSS Specificity Calculator" relatedTags={['css', 'web', 'design', 'frontend']} />
</BaseLayout>
