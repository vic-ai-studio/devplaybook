---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SlugGenerator from '../../components/SlugGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a URL slug?", answer: "A URL slug is the human-readable part of a URL that identifies a page — like /blog/my-first-post. Good slugs are lowercase, use hyphens to separate words, contain no special characters, and describe the page content for both users and search engines." },
  { question: "How does this slug generator handle accented characters?", answer: "Accented characters are transliterated to their ASCII equivalents: é becomes e, ü becomes u, ñ becomes n, ø becomes o. This ensures your slugs work in all browsers and servers without encoding issues." },
  { question: "Should I use hyphens or underscores in URLs?", answer: "Google recommends hyphens (-) over underscores (_) for word separation in URLs. Google treats hyphens as word separators but underscores as word joiners, so my-blog-post is read as three words while my_blog_post is read as one. Always use hyphens for SEO." },
  { question: "How long should a URL slug be?", answer: "Keep slugs under 60 characters. Include only the essential words — remove stop words like 'the', 'and', 'of' when possible. Shorter slugs are easier to share, remember, and display in search results. Google truncates long URLs in SERPs." },
  { question: "Does this tool handle CJK characters and emoji?", answer: "CJK characters and emoji are removed by default since they can cause encoding issues in URLs. If you need to keep them, consider using percent-encoding (encodeURIComponent) for those specific characters." },
];
---

<BaseLayout
  title="URL Slug Generator — Clean SEO-Friendly Slugs"
  description="Convert any text into a clean, SEO-friendly URL slug. Handles camelCase, accented characters, spaces, and special chars. Choose hyphen, underscore, or no separator. Free, runs in your browser."
  tool="URL Slug Generator, Slug Converter, URL-friendly String, SEO Slug Tool"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">URL Slug Generator</h1>
  <p class="text-text-muted mb-4">Turn any title or text into a clean, URL-safe slug. Handles camelCase splitting, accented character transliteration, and special character removal. Perfect for blog URLs, page routes, and SEO-friendly paths.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <SlugGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="URL Slug Generator" relatedTags={['url', 'seo', 'text', 'web', 'encoding']} />
</BaseLayout>
