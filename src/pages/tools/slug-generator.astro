---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SlugGenerator from '../../components/SlugGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="URL Slug Generator"
  description="Convert any text into a clean URL slug. Handles camelCase, accented characters, spaces, and special chars. Choose hyphen, underscore, or no separator."
  tool="URL Slug Generator, Slug Converter, URL-friendly String, SEO Slug Tool"
>
  <h1 class="text-3xl font-bold mb-2">URL Slug Generator</h1>
  <p class="text-text-muted mb-8">Turn any title or text into a clean, URL-safe slug. Handles camelCase splitting, accented character transliteration, and special character removal. Perfect for blog URLs, page routes, and SEO-friendly paths.</p>
  <SlugGenerator client:only="preact" />
  <ToolPageCta currentTool="URL Slug Generator" relatedTags={['url', 'seo', 'text', 'web', 'encoding']} />
</BaseLayout>
