---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is CSS Grid?", answer: "CSS Grid Layout is a two-dimensional layout system that lets you place content in rows and columns simultaneously. Unlike Flexbox (which is one-dimensional), Grid gives you precise control over both axes at once. It's ideal for page-level layouts, dashboards, card grids, and any design that needs rows AND columns." },
  { question: "What does grid-template-columns do?", answer: "grid-template-columns defines the number and size of columns in your grid. You can use fixed lengths (200px), percentages (25%), fractions (1fr), auto, minmax(200px, 1fr), or repeat(). The fr unit is the most powerful — 1fr means 'one fraction of available space', so repeat(3, 1fr) creates three equal columns." },
  { question: "What is the difference between gap, column-gap, and row-gap?", answer: "gap is a shorthand that sets both row and column spacing at once (e.g., gap: 16px sets both to 16px, gap: 8px 16px sets row to 8px and column to 16px). column-gap and row-gap set each axis independently. gap replaces the older grid-gap property and now works in both Grid and Flexbox." },
  { question: "How do I make a responsive grid without media queries?", answer: "Use auto-fill or auto-fit with minmax(): grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)). This creates as many columns as fit in the container at 250px minimum, expanding them equally to fill the row. auto-fit collapses empty tracks; auto-fill keeps them. This is the most common responsive grid pattern." },
  { question: "When should I use Grid vs Flexbox?", answer: "Use Grid when you need two-dimensional layout (rows AND columns matter) — page layouts, image galleries, dashboards, form layouts. Use Flexbox when laying out items in one direction (a navigation bar, a row of buttons, a vertical stack). They complement each other: Grid for the macro layout, Flexbox for components inside grid cells." },
];
---

<BaseLayout
  title="CSS Grid Builder — Visual Grid Layout Generator with Live Preview"
  description="Build CSS Grid layouts visually. Set columns, rows, gap, and template values, see a live grid preview, then copy production-ready CSS including responsive breakpoints."
  tool="CSS Grid Builder, CSS Grid Generator, Grid Layout Tool, CSS Grid Preview, Responsive Grid Builder, grid-template-columns Generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "CSS Grid Builder",
    "description": "Visual CSS Grid layout builder with live preview and copy-ready CSS output.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">CSS Grid Builder</h1>
  <p class="text-text-muted mb-4">Configure your CSS Grid layout with columns, rows, gaps, and templates. See a live preview update instantly and copy the generated CSS with responsive breakpoints.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live visual preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Responsive breakpoints</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-ready CSS</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs in browser</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-5">
    <!-- Controls -->
    <div class="space-y-4">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Grid Settings</h2>
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium mb-1.5" for="col-template">grid-template-columns</label>
            <input id="col-template" type="text" value="repeat(3, 1fr)"
              placeholder="e.g. repeat(3, 1fr) or 200px 1fr 200px"
              class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5" for="row-template">grid-template-rows</label>
            <input id="row-template" type="text" value="auto"
              placeholder="e.g. auto or 100px 200px or repeat(3, 1fr)"
              class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium mb-1.5" for="col-gap">column-gap</label>
              <input id="col-gap" type="text" value="16px"
                placeholder="16px"
                class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
            </div>
            <div>
              <label class="block text-sm font-medium mb-1.5" for="row-gap">row-gap</label>
              <input id="row-gap" type="text" value="16px"
                placeholder="16px"
                class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5" for="justify-items">justify-items</label>
            <select id="justify-items" class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="stretch" selected>stretch</option>
              <option value="start">start</option>
              <option value="end">end</option>
              <option value="center">center</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5" for="align-items">align-items</label>
            <select id="align-items" class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="stretch" selected>stretch</option>
              <option value="start">start</option>
              <option value="end">end</option>
              <option value="center">center</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5" for="item-count">Preview Item Count</label>
            <input id="item-count" type="number" value="9" min="1" max="24"
              class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
          </div>
        </div>
      </div>

      <!-- Breakpoints -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">Responsive Breakpoints</h2>
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium mb-1.5">Mobile (&lt; 640px) — columns</label>
            <input id="bp-mobile" type="text" value="1fr" placeholder="1fr"
              class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5">Tablet (640px–1024px) — columns</label>
            <input id="bp-tablet" type="text" value="repeat(2, 1fr)" placeholder="repeat(2, 1fr)"
              class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
          </div>
        </div>
      </div>
    </div>

    <!-- Preview -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="text-base font-semibold mb-3">Live Preview</h2>
      <div id="grid-preview" class="w-full min-h-48 border border-border rounded-lg p-2 overflow-hidden" style="background: var(--color-bg-surface, #1e1e2e);">
      </div>
      <p class="text-xs text-text-muted mt-2">Preview uses your current settings above.</p>
    </div>
  </div>

  <!-- Generated CSS -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-base font-semibold">Generated CSS</h2>
      <button id="copy-css-btn" class="text-xs px-3 py-1.5 bg-bg-surface border border-border rounded-lg hover:border-primary hover:text-primary transition-colors">Copy CSS</button>
    </div>
    <pre id="css-output" class="font-mono text-sm bg-bg-surface rounded-lg p-4 overflow-x-auto text-text-muted whitespace-pre"></pre>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CSS Grid Builder" relatedTags={['css', 'grid', 'layout', 'frontend', 'web-design']} />
</BaseLayout>

<script>
  var ITEM_COLORS = ['#6366f1','#8b5cf6','#ec4899','#f59e0b','#10b981','#3b82f6','#ef4444','#14b8a6','#f97316'];

  function getVal(id) { return document.getElementById(id).value.trim(); }

  function buildPreview() {
    var colTemplate = getVal('col-template') || 'repeat(3, 1fr)';
    var rowTemplate = getVal('row-template') || 'auto';
    var colGap = getVal('col-gap') || '16px';
    var rowGap = getVal('row-gap') || '16px';
    var justifyItems = getVal('justify-items');
    var alignItems = getVal('align-items');
    var count = parseInt(document.getElementById('item-count').value) || 9;

    var preview = document.getElementById('grid-preview');
    preview.style.display = 'grid';
    preview.style.gridTemplateColumns = colTemplate;
    preview.style.gridTemplateRows = rowTemplate;
    preview.style.columnGap = colGap;
    preview.style.rowGap = rowGap;
    preview.style.justifyItems = justifyItems;
    preview.style.alignItems = alignItems;

    var html = '';
    for (var i = 0; i < count; i++) {
      var color = ITEM_COLORS[i % ITEM_COLORS.length];
      html += '<div style="background:' + color + '22;border:1px solid ' + color + '66;border-radius:6px;padding:8px 4px;text-align:center;font-size:11px;color:' + color + ';min-height:40px;display:flex;align-items:center;justify-content:center;">' + (i + 1) + '</div>';
    }
    preview.innerHTML = html;
  }

  function buildCSS() {
    var colTemplate = getVal('col-template') || 'repeat(3, 1fr)';
    var rowTemplate = getVal('row-template') || 'auto';
    var colGap = getVal('col-gap') || '16px';
    var rowGap = getVal('row-gap') || '16px';
    var justifyItems = getVal('justify-items');
    var alignItems = getVal('align-items');
    var mobile = getVal('bp-mobile') || '1fr';
    var tablet = getVal('bp-tablet') || 'repeat(2, 1fr)';

    var lines = [
      '.grid-container {',
      '  display: grid;',
      '  grid-template-columns: ' + colTemplate + ';',
    ];
    if (rowTemplate !== 'auto') {
      lines.push('  grid-template-rows: ' + rowTemplate + ';');
    }
    if (colGap === rowGap) {
      lines.push('  gap: ' + colGap + ';');
    } else {
      lines.push('  column-gap: ' + colGap + ';');
      lines.push('  row-gap: ' + rowGap + ';');
    }
    if (justifyItems !== 'stretch') lines.push('  justify-items: ' + justifyItems + ';');
    if (alignItems !== 'stretch') lines.push('  align-items: ' + alignItems + ';');
    lines.push('}', '');
    lines.push('/* Mobile — single column */',
      '@media (max-width: 639px) {',
      '  .grid-container {',
      '    grid-template-columns: ' + mobile + ';',
      '  }',
      '}', '');
    lines.push('/* Tablet */',
      '@media (min-width: 640px) and (max-width: 1023px) {',
      '  .grid-container {',
      '    grid-template-columns: ' + tablet + ';',
      '  }',
      '}');

    document.getElementById('css-output').textContent = lines.join('\n');
  }

  function update() {
    buildPreview();
    buildCSS();
  }

  var inputIds = ['col-template','row-template','col-gap','row-gap','justify-items','align-items','item-count','bp-mobile','bp-tablet'];
  inputIds.forEach(function(id) {
    document.getElementById(id).addEventListener('input', update);
  });

  document.getElementById('copy-css-btn').addEventListener('click', function() {
    var text = document.getElementById('css-output').textContent;
    navigator.clipboard.writeText(text).then(function() {
      document.getElementById('copy-css-btn').textContent = 'Copied!';
      setTimeout(function() { document.getElementById('copy-css-btn').textContent = 'Copy CSS'; }, 2000);
    });
  });

  update();
</script>
