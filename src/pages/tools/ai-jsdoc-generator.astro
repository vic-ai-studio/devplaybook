---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AiJsdocGenerator from '../../components/AiJsdocGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="AI JSDoc Generator — Generate JSDoc, TSDoc, Python Docstrings & Rust Doc Comments"
  description="Paste any function or class signature and get a complete JSDoc, TSDoc, Python docstring, or Rust doc comment generated instantly. Parses parameter types, return types, and async modifiers automatically."
  tool="AI JSDoc Generator, JSDoc Generator, TSDoc Generator, Python Docstring Generator, Rust Doc Comment Generator"
>
  <h1 class="text-3xl font-bold mb-2">AI JSDoc Generator</h1>
  <p class="text-text-muted mb-8">
    Paste any function or class signature and get a complete documentation comment generated instantly.
    Supports <strong>JSDoc</strong> (JavaScript), <strong>TSDoc</strong> (TypeScript), <strong>Python docstrings</strong>, and <strong>Rust doc comments</strong>.
    Automatically parses parameter names, types, return types, and <code class="font-mono text-sm bg-bg-card px-1 rounded">async</code> modifiers.
    No external API — runs entirely in your browser.
  </p>
  <AiJsdocGenerator client:load />
  <ToolPageCta currentTool="AI JSDoc Generator" relatedTags={['ai', 'documentation', 'developer-tools', 'typescript', 'javascript']} />
</BaseLayout>
