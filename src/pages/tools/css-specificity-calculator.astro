---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CssSpecificityCalculator from '../../components/CssSpecificityCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is CSS specificity?",
    answer: "CSS specificity is the algorithm browsers use to determine which CSS rule applies when multiple rules match the same element. It is represented as a 4-part value (inline, ID, class, element). Higher specificity wins. When two selectors have equal specificity, the one declared later in the stylesheet wins (the cascade)."
  },
  {
    question: "How is CSS specificity calculated?",
    answer: "Specificity is calculated as four separate columns: (inline, ID, class, element). Inline styles = 1,0,0,0. ID selectors (#foo) = 0,1,0,0. Class selectors (.foo), attribute selectors ([type='text']), and pseudo-classes (:hover) = 0,0,1,0. Element selectors (div, p) and pseudo-elements (::before) = 0,0,0,1. Combinators (+, ~, >, space) and the universal selector (*) contribute 0."
  },
  {
    question: "Which selector wins: .nav a vs nav a.link?",
    answer: ".nav a has specificity (0,0,1,1) — one class + one element. nav a.link has specificity (0,0,1,2) — one class + two elements. nav a.link wins because (0,0,1,2) > (0,0,1,1). Specificity is compared column by column from left to right; a tie in one column is broken by the next."
  },
  {
    question: "Does !important override specificity?",
    answer: "Yes. !important overrides the normal specificity algorithm entirely — an !important declaration always wins against a non-!important declaration, regardless of specificity. However, if two competing declarations both use !important, specificity is compared again. Using !important excessively makes CSS hard to maintain; prefer increasing specificity or restructuring your selectors."
  },
  {
    question: "What is the specificity of :not()?",
    answer: "The :not() pseudo-class itself contributes 0 to specificity, but its argument does count. For example, :not(.active) has specificity (0,0,1,0) because .active is a class selector. The same applies to :is() and :has() — the most specific argument within them is counted."
  },
  {
    question: "Why does :where() have zero specificity?",
    answer: ":where() was specifically designed to have zero specificity for all its arguments. This is useful for writing base styles or resets that you want to override easily without increasing specificity. Unlike :is() or :not(), :where(h1, h2, h3) always contributes (0,0,0,0)."
  },
];
---

<BaseLayout
  title="CSS Specificity Calculator — Calculate & Compare CSS Selectors"
  description="Calculate CSS selector specificity as (inline, ID, class, element) notation. Compare two selectors to see which wins the cascade. Supports :not, :is, :has, :where, attribute selectors, and pseudo-elements. Free, runs in your browser."
  tool="CSS Specificity Calculator, CSS Selector Specificity, CSS Cascade Calculator, CSS Specificity Checker"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "CSS Specificity Calculator",
    "url": "https://devplaybook.cc/tools/css-specificity-calculator",
    "description": "Calculate and compare CSS selector specificity in (inline, ID, class, element) notation. Supports :not(), :is(), :has(), :where(), attribute selectors, and pseudo-elements.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">CSS Specificity Calculator</h1>
  <p class="text-text-muted mb-4">
    Calculate the specificity of any CSS selector as <code class="bg-surface-2 px-1 rounded text-sm">(inline, ID, class, element)</code> notation.
    Compare two selectors to see which one wins the cascade. Supports pseudo-classes, pseudo-elements, attribute selectors, <code class="bg-surface-2 px-1 rounded text-sm">:not()</code>, <code class="bg-surface-2 px-1 rounded text-sm">:is()</code>, <code class="bg-surface-2 px-1 rounded text-sm">:where()</code>, and combinators.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Inline, ID, class, element breakdown</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Compare two selectors</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> :not / :is / :where support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100% browser — no server</span>
  </div>
  <CssSpecificityCalculator client:load />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CSS Specificity Calculator" relatedTags={['css', 'web', 'design', 'frontend', 'selector']} />
</BaseLayout>
