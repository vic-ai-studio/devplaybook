---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a system prompt?", answer: "A system prompt is a set of instructions you provide to an LLM before the conversation starts. It defines the AI's role, behavior, tone, and constraints — shaping every response in the conversation." },
  { question: "What makes an effective system prompt?", answer: "Good system prompts are specific, not vague. Define the role clearly (e.g., 'You are a senior Python engineer'), set concrete constraints (e.g., 'Never suggest deprecated APIs'), specify output format, and include 1-2 examples if possible." },
  { question: "How long should a system prompt be?", answer: "For most use cases, 100-500 tokens is ideal. Shorter prompts are cheaper and faster; longer prompts add precision. Avoid padding — every sentence should serve a purpose." },
  { question: "Does this tool work for ChatGPT, Claude, and Gemini?", answer: "Yes. The generated prompt works as a system message for OpenAI (GPT-4o), Anthropic (Claude), and Google (Gemini). Copy and paste it into the system prompt field or pass it as the 'system' parameter in API calls." },
  { question: "Can I save my prompts?", answer: "Prompts are stored in localStorage so they persist across browser sessions on the same device. Use the Export button to download your prompt as a .txt file for backup." },
];
---

<BaseLayout
  title="AI System Prompt Builder — Create Effective System Prompts"
  description="Build effective AI system prompts with structured fields: role, tone, constraints, output format, and examples. One-click copy to clipboard. Works for ChatGPT, Claude, and Gemini."
  tool="AI System Prompt Builder, System Prompt Generator, ChatGPT System Prompt, Claude Instructions Builder, Prompt Engineering Tool"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">AI System Prompt Builder</h1>
  <p class="text-text-muted mb-6">Craft structured, effective system prompts for any LLM. Fill in each field and get a ready-to-use prompt — works with ChatGPT, Claude, Gemini, and any OpenAI-compatible API.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Works with GPT-4o, Claude & Gemini</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Saved to localStorage</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> One-click copy</span>
  </div>

  <div id="prompt-builder" class="space-y-5">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Left: form -->
      <div class="space-y-4">

        <!-- Role -->
        <div>
          <label for="role" class="block text-sm font-medium mb-1">
            Role / Persona <span class="text-text-muted font-normal">(required)</span>
          </label>
          <input type="text" id="role" placeholder="e.g. You are a senior TypeScript engineer specializing in React and Next.js"
            class="w-full bg-bg-card border border-border rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
          <p class="text-xs text-text-muted mt-1">Define who the AI is and its core expertise</p>
        </div>

        <!-- Tone -->
        <div>
          <label for="tone" class="block text-sm font-medium mb-1">Tone & Communication Style</label>
          <div class="flex gap-2 flex-wrap mb-2" id="tone-presets">
            <button class="tone-preset px-3 py-1 text-xs rounded-full border border-border hover:border-primary hover:text-primary transition-colors" data-value="concise and direct">Concise</button>
            <button class="tone-preset px-3 py-1 text-xs rounded-full border border-border hover:border-primary hover:text-primary transition-colors" data-value="friendly and approachable">Friendly</button>
            <button class="tone-preset px-3 py-1 text-xs rounded-full border border-border hover:border-primary hover:text-primary transition-colors" data-value="formal and professional">Formal</button>
            <button class="tone-preset px-3 py-1 text-xs rounded-full border border-border hover:border-primary hover:text-primary transition-colors" data-value="technical and precise">Technical</button>
            <button class="tone-preset px-3 py-1 text-xs rounded-full border border-border hover:border-primary hover:text-primary transition-colors" data-value="educational and patient">Educational</button>
            <button class="tone-preset px-3 py-1 text-xs rounded-full border border-border hover:border-primary hover:text-primary transition-colors" data-value="creative and imaginative">Creative</button>
          </div>
          <input type="text" id="tone" placeholder="e.g. concise and direct, avoid jargon"
            class="w-full bg-bg-card border border-border rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
        </div>

        <!-- Constraints -->
        <div>
          <label for="constraints" class="block text-sm font-medium mb-1">Constraints & Rules</label>
          <textarea id="constraints" rows="3" placeholder="e.g.&#10;- Never suggest deprecated APIs&#10;- Always include error handling in code&#10;- Do not make up package names"
            class="w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-sm resize-y focus:outline-none focus:ring-2 focus:ring-primary"></textarea>
          <p class="text-xs text-text-muted mt-1">What the AI must never do or always do</p>
        </div>

        <!-- Output format -->
        <div>
          <label for="output-format" class="block text-sm font-medium mb-1">Output Format</label>
          <div class="flex gap-2 flex-wrap mb-2" id="format-presets">
            <button class="fmt-preset px-3 py-1 text-xs rounded-full border border-border hover:border-primary hover:text-primary transition-colors" data-value="Respond in plain text.">Plain text</button>
            <button class="fmt-preset px-3 py-1 text-xs rounded-full border border-border hover:border-primary hover:text-primary transition-colors" data-value="Use markdown formatting with headers and bullet points.">Markdown</button>
            <button class="fmt-preset px-3 py-1 text-xs rounded-full border border-border hover:border-primary hover:text-primary transition-colors" data-value="Return valid JSON only. No prose or explanation.">JSON only</button>
            <button class="fmt-preset px-3 py-1 text-xs rounded-full border border-border hover:border-primary hover:text-primary transition-colors" data-value="Use numbered steps for any procedural answers.">Numbered steps</button>
            <button class="fmt-preset px-3 py-1 text-xs rounded-full border border-border hover:border-primary hover:text-primary transition-colors" data-value="Start every response with a TL;DR summary, then expand.">TL;DR first</button>
          </div>
          <input type="text" id="output-format" placeholder="e.g. Always respond in markdown. Include code blocks with language tags."
            class="w-full bg-bg-card border border-border rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
        </div>

        <!-- Examples -->
        <div>
          <label for="examples" class="block text-sm font-medium mb-1">
            Examples <span class="text-text-muted font-normal">(optional)</span>
          </label>
          <textarea id="examples" rows="3" placeholder="e.g.&#10;User: How do I center a div?&#10;Assistant: Use flexbox: `display: flex; align-items: center; justify-content: center;`"
            class="w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-sm resize-y focus:outline-none focus:ring-2 focus:ring-primary"></textarea>
          <p class="text-xs text-text-muted mt-1">1-2 examples of ideal interactions (optional but powerful)</p>
        </div>

        <!-- Context window hint -->
        <div>
          <label for="additional" class="block text-sm font-medium mb-1">
            Additional Context <span class="text-text-muted font-normal">(optional)</span>
          </label>
          <input type="text" id="additional" placeholder="e.g. The user is building a SaaS product in TypeScript. Prefer React Query over Redux."
            class="w-full bg-bg-card border border-border rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
        </div>

        <!-- Action buttons -->
        <div class="flex gap-3 flex-wrap pt-1">
          <button id="copy-btn"
            class="flex-1 sm:flex-none bg-primary text-white px-5 py-2.5 rounded-lg text-sm font-medium hover:opacity-90 transition-opacity">
            Copy Prompt
          </button>
          <button id="export-btn"
            class="px-5 py-2.5 rounded-lg text-sm font-medium border border-border hover:border-primary hover:text-primary transition-colors">
            Export .txt
          </button>
          <button id="reset-btn"
            class="px-5 py-2.5 rounded-lg text-sm font-medium border border-border hover:border-red-400 hover:text-red-400 transition-colors">
            Reset
          </button>
        </div>
      </div>

      <!-- Right: preview -->
      <div class="flex flex-col">
        <div class="flex items-center justify-between mb-2">
          <p class="text-sm font-medium">Preview</p>
          <div class="flex items-center gap-2 text-xs text-text-muted">
            <span id="token-estimate">~0 tokens</span>
            <span id="copy-status" class="text-green-500 hidden">Copied!</span>
          </div>
        </div>
        <pre id="prompt-preview"
          class="flex-1 min-h-64 bg-bg-card border border-border rounded-xl p-4 text-xs font-mono leading-relaxed whitespace-pre-wrap overflow-auto text-text-muted italic">
Fill in the fields on the left to generate your system prompt...</pre>
      </div>
    </div>

    <!-- Templates -->
    <div>
      <p class="text-sm font-semibold mb-3">Quick Start Templates</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <button class="template-btn text-left bg-bg-card border border-border rounded-xl p-4 hover:border-primary transition-colors text-sm"
          data-role="You are a senior full-stack engineer specializing in TypeScript, React, and Node.js."
          data-tone="concise and direct"
          data-constraints="- Never suggest deprecated libraries\n- Always include TypeScript types\n- Prefer functional components over class components\n- Include error handling in every code example"
          data-format="Use markdown. Wrap all code in fenced code blocks with language tags."
          data-examples=""
          data-additional="">
          <p class="font-medium mb-1">🛠 Full-Stack Dev Assistant</p>
          <p class="text-xs text-text-muted">TypeScript + React + Node.js</p>
        </button>
        <button class="template-btn text-left bg-bg-card border border-border rounded-xl p-4 hover:border-primary transition-colors text-sm"
          data-role="You are a technical writing assistant helping developers write clear documentation."
          data-tone="clear, simple, and educational"
          data-constraints="- Avoid passive voice\n- Use concrete examples\n- Define acronyms on first use\n- Keep sentences under 20 words"
          data-format="Use markdown with a TL;DR at the top, then structured sections with headers."
          data-examples=""
          data-additional="">
          <p class="font-medium mb-1">📝 Docs Writer</p>
          <p class="text-xs text-text-muted">Technical documentation assistant</p>
        </button>
        <button class="template-btn text-left bg-bg-card border border-border rounded-xl p-4 hover:border-primary transition-colors text-sm"
          data-role="You are a code review assistant. Your job is to review code for bugs, security issues, and best practices."
          data-tone="constructive and precise"
          data-constraints="- Always explain WHY something is a problem\n- Suggest a concrete fix for every issue raised\n- Rate severity: Critical / High / Medium / Low"
          data-format="Return a markdown list of issues. Format each as: [SEVERITY] Issue description → Suggested fix."
          data-examples=""
          data-additional="">
          <p class="font-medium mb-1">🔍 Code Reviewer</p>
          <p class="text-xs text-text-muted">Security + best practices auditor</p>
        </button>
        <button class="template-btn text-left bg-bg-card border border-border rounded-xl p-4 hover:border-primary transition-colors text-sm"
          data-role="You are a customer support agent for a SaaS product. You are helpful, empathetic, and solution-focused."
          data-tone="warm, patient, and professional"
          data-constraints="- Never make promises about features not yet released\n- If unsure, say so and offer to escalate\n- Keep responses under 150 words"
          data-format="Plain text. Always end with a next step or question to move forward."
          data-examples=""
          data-additional="">
          <p class="font-medium mb-1">💬 Customer Support</p>
          <p class="text-xs text-text-muted">SaaS support agent</p>
        </button>
        <button class="template-btn text-left bg-bg-card border border-border rounded-xl p-4 hover:border-primary transition-colors text-sm"
          data-role="You are a SQL expert and data analyst. You help write efficient queries and interpret query results."
          data-tone="technical and precise"
          data-constraints="- Always include a brief explanation of each query\n- Flag potential N+1 query problems\n- Suggest indexes when relevant\n- Assume PostgreSQL unless told otherwise"
          data-format="Use markdown. SQL code in sql fenced blocks. Explain in bullet points below the code."
          data-examples=""
          data-additional="">
          <p class="font-medium mb-1">🗄 SQL Expert</p>
          <p class="text-xs text-text-muted">Query writing + data analysis</p>
        </button>
        <button class="template-btn text-left bg-bg-card border border-border rounded-xl p-4 hover:border-primary transition-colors text-sm"
          data-role="You are a startup advisor with expertise in product strategy, growth, and fundraising."
          data-tone="direct, honest, and experienced"
          data-constraints="- Challenge assumptions respectfully\n- Give concrete examples from real companies when possible\n- Don't sugarcoat problems"
          data-format="Use numbered action items. Lead with the most impactful advice first."
          data-examples=""
          data-additional="">
          <p class="font-medium mb-1">🚀 Startup Advisor</p>
          <p class="text-xs text-text-muted">Product strategy + growth</p>
        </button>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="AI System Prompt Builder" relatedTags={['ai', 'llm', 'openai', 'claude', 'prompts', 'prompt-engineering']} />
</BaseLayout>

<script>
  const STORAGE_KEY = 'dp-system-prompt-builder';

  function getFields() {
    return {
      role: (document.getElementById('role') as HTMLInputElement).value.trim(),
      tone: (document.getElementById('tone') as HTMLInputElement).value.trim(),
      constraints: (document.getElementById('constraints') as HTMLTextAreaElement).value.trim(),
      outputFormat: (document.getElementById('output-format') as HTMLInputElement).value.trim(),
      examples: (document.getElementById('examples') as HTMLTextAreaElement).value.trim(),
      additional: (document.getElementById('additional') as HTMLInputElement).value.trim(),
    };
  }

  function buildPrompt(f: ReturnType<typeof getFields>): string {
    const parts: string[] = [];

    if (f.role) parts.push(f.role);
    if (f.tone) parts.push(`\nTone: ${f.tone}.`);

    if (f.constraints) {
      parts.push('\nRules:');
      parts.push(f.constraints);
    }

    if (f.outputFormat) {
      parts.push('\nOutput format:');
      parts.push(f.outputFormat);
    }

    if (f.examples) {
      parts.push('\nExample:');
      parts.push(f.examples);
    }

    if (f.additional) {
      parts.push('\nContext:');
      parts.push(f.additional);
    }

    return parts.join('\n').trim();
  }

  function estimateTokens(text: string): number {
    if (!text) return 0;
    return Math.max(1, Math.round(text.length / 4));
  }

  function updatePreview() {
    const f = getFields();
    const prompt = buildPrompt(f);
    const preview = document.getElementById('prompt-preview') as HTMLPreElement;
    const tokenEl = document.getElementById('token-estimate') as HTMLElement;

    if (!prompt) {
      preview.textContent = 'Fill in the fields on the left to generate your system prompt...';
      preview.classList.add('italic', 'text-text-muted');
      tokenEl.textContent = '~0 tokens';
    } else {
      preview.textContent = prompt;
      preview.classList.remove('italic');
      tokenEl.textContent = `~${estimateTokens(prompt).toLocaleString()} tokens`;
    }

    // Persist
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(f)); } catch {}
  }

  function setField(id: string, value: string) {
    const el = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement;
    if (el) el.value = value;
  }

  function loadSaved() {
    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (!saved) return;
      const f = JSON.parse(saved);
      if (f.role) setField('role', f.role);
      if (f.tone) setField('tone', f.tone);
      if (f.constraints) setField('constraints', f.constraints);
      if (f.outputFormat) setField('output-format', f.outputFormat);
      if (f.examples) setField('examples', f.examples);
      if (f.additional) setField('additional', f.additional);
    } catch {}
  }

  // Wire up inputs
  ['role', 'tone', 'constraints', 'output-format', 'examples', 'additional'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', updatePreview);
  });

  // Tone presets
  document.querySelectorAll('.tone-preset').forEach(btn => {
    btn.addEventListener('click', () => {
      setField('tone', (btn as HTMLElement).dataset.value || '');
      updatePreview();
    });
  });

  // Format presets
  document.querySelectorAll('.fmt-preset').forEach(btn => {
    btn.addEventListener('click', () => {
      setField('output-format', (btn as HTMLElement).dataset.value || '');
      updatePreview();
    });
  });

  // Templates
  document.querySelectorAll('.template-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const d = (btn as HTMLElement).dataset;
      setField('role', d.role || '');
      setField('tone', d.tone || '');
      setField('constraints', (d.constraints || '').replace(/\\n/g, '\n'));
      setField('output-format', d.format || '');
      setField('examples', d.examples || '');
      setField('additional', d.additional || '');
      updatePreview();
    });
  });

  // Copy
  document.getElementById('copy-btn')?.addEventListener('click', () => {
    const f = getFields();
    const prompt = buildPrompt(f);
    if (!prompt) return;
    navigator.clipboard.writeText(prompt).then(() => {
      const status = document.getElementById('copy-status') as HTMLElement;
      status.classList.remove('hidden');
      setTimeout(() => status.classList.add('hidden'), 2000);
    });
  });

  // Export
  document.getElementById('export-btn')?.addEventListener('click', () => {
    const f = getFields();
    const prompt = buildPrompt(f);
    if (!prompt) return;
    const blob = new Blob([prompt], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'system-prompt.txt';
    a.click();
    URL.revokeObjectURL(url);
  });

  // Reset
  document.getElementById('reset-btn')?.addEventListener('click', () => {
    ['role', 'tone', 'constraints', 'output-format', 'examples', 'additional'].forEach(id => setField(id, ''));
    try { localStorage.removeItem(STORAGE_KEY); } catch {}
    updatePreview();
  });

  // Init
  loadSaved();
  updatePreview();
</script>
