---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RedisPipelineBuilder from '../../components/RedisPipelineBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a Redis pipeline?", answer: "A Redis pipeline batches multiple commands into a single network round-trip. Instead of sending each command and waiting for a reply, you queue all commands client-side, then flush them together. This dramatically reduces latency when executing many operations — especially important when Redis is on a remote server." },
  { question: "What's the difference between pipelining and transactions (MULTI/EXEC)?", answer: "Pipelining is a network optimization: commands are sent in bulk but may interleave with other clients on the server. MULTI/EXEC wraps commands in a transaction that executes atomically — no other client can interleave. Use pipelining for raw throughput; use MULTI/EXEC when atomicity matters." },
  { question: "Does pipelining guarantee command order?", answer: "Yes. Commands in a pipeline execute in the order you added them, and their responses come back in the same order. The pipeline is purely a client-side buffering mechanism — the server processes them in sequence." },
  { question: "How do I use the output in Node.js with ioredis?", answer: "Switch to the Node (ioredis) output format and copy the code. The generated snippet creates a pipeline with redis.pipeline(), chains your commands, then calls .exec() which returns an array of [error, result] pairs for each command." },
  { question: "Can I use pipelining for reads and writes together?", answer: "Yes. You can freely mix read commands (GET, HGET, LRANGE) and write commands (SET, LPUSH, HSET) in the same pipeline. The pipeline returns all results in order when flushed." },
];
---

<BaseLayout
  title="Redis Pipeline Builder — Build Redis Command Pipelines Online"
  description="Build Redis command pipelines visually. Add GET, SET, HSET, LPUSH, EXPIRE and other commands, reorder them, and export as a raw pipeline, redis-cli script, or Node.js ioredis code."
  tool="Redis pipeline builder, Redis batch commands, ioredis pipeline, Redis command sequence, Redis multi-command"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Redis Pipeline Builder",
    "url": "https://devplaybook.cc/tools/redis-pipeline-builder",
    "description": "Build Redis command pipelines visually. Add commands, reorder them, and export as raw pipeline, redis-cli, or Node.js ioredis code.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Redis Pipeline Builder</h1>
  <p class="text-text-muted mb-4">
    Build Redis command pipelines visually. Add
    <code class="font-mono bg-surface px-1 rounded text-sm">SET</code>,
    <code class="font-mono bg-surface px-1 rounded text-sm">HSET</code>,
    <code class="font-mono bg-surface px-1 rounded text-sm">LPUSH</code>,
    <code class="font-mono bg-surface px-1 rounded text-sm">EXPIRE</code>, and more — then export
    as a raw pipeline, <code class="font-mono bg-surface px-1 rounded text-sm">redis-cli</code> script,
    or <strong>Node.js ioredis</strong> code.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 24 Redis commands</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 3 export formats</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Drag-to-reorder pipeline</span>
  </div>
  <RedisPipelineBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Redis Pipeline Builder" relatedTags={['redis', 'database', 'cache', 'backend', 'developer-tools', 'nodejs']} />
</BaseLayout>
