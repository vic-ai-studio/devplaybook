---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is GraphQL SDL?", answer: "SDL stands for Schema Definition Language. It's the standard way to describe a GraphQL schema — defining types, fields, queries, mutations, and their relationships in a human-readable format." },
  { question: "What is the difference between a Type and an Input in GraphQL?", answer: "A Type is used for output (returned in query responses). An Input type is used for arguments — when you need to pass complex objects as mutation arguments, you define them as input types." },
  { question: "What are scalar types in GraphQL?", answer: "Scalars are primitive leaf values: String, Int, Float, Boolean, and ID are built-in. You can define custom scalars like Date, JSON, or URL. Fields on types must ultimately resolve to scalars." },
  { question: "How do I make a field required in GraphQL?", answer: "Add an exclamation mark after the type: String! means the field is non-null (required). String means it can be null. [String!]! means a non-null list of non-null strings." },
  { question: "Can I use this SDL output directly in my GraphQL server?", answer: "Yes. The generated SDL is compatible with Apollo Server, GraphQL Yoga, Hasura, and any standard GraphQL implementation. Copy it and use it as your schema file." },
];
---

<BaseLayout
  title="GraphQL Schema Generator — Visual SDL Builder — Free Online Tool"
  description="Build GraphQL SDL schemas visually. Add types, define fields with scalar types, mark nullable/required, and instantly generate a copy-ready GraphQL schema definition. Free, no signup."
  tool="GraphQL schema generator, SDL builder, GraphQL type generator, schema definition language"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">GraphQL Schema Generator</h1>
  <p class="text-text-muted mb-4">Build a GraphQL SDL schema visually. Add types, define fields, set scalar types and nullability — then copy the ready-to-use schema for Apollo Server, GraphQL Yoga, or any standard GraphQL backend.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Left: Builder -->
    <div class="space-y-4">
      <div class="bg-surface border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">Add Type</h2>
        <div class="flex gap-2 mb-3">
          <input id="gql-type-name" type="text" placeholder="e.g. User, Post, Product" autocomplete="off"
            class="flex-1 bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent" />
          <select id="gql-type-kind" class="bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent">
            <option value="type">type</option>
            <option value="input">input</option>
            <option value="interface">interface</option>
            <option value="enum">enum</option>
          </select>
          <button id="gql-add-type" class="bg-accent hover:bg-accent/80 text-white px-3 py-2 rounded-lg text-sm font-medium transition-colors">Add</button>
        </div>

        <div id="gql-types-list" class="space-y-3"></div>
      </div>

      <div class="bg-surface border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">Schema Extras</h2>
        <label class="flex items-center gap-2 mb-2 cursor-pointer text-sm">
          <input type="checkbox" id="gql-add-query" class="accent-accent" checked />
          Add Query type stub
        </label>
        <label class="flex items-center gap-2 cursor-pointer text-sm">
          <input type="checkbox" id="gql-add-mutation" class="accent-accent" />
          Add Mutation type stub
        </label>
      </div>
    </div>

    <!-- Right: Output -->
    <div class="bg-surface border border-border rounded-xl p-5 flex flex-col">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-base font-semibold">Generated SDL</h2>
        <button id="gql-copy" class="text-xs bg-background border border-border hover:bg-accent/20 px-3 py-1.5 rounded-lg transition-colors">Copy SDL</button>
      </div>
      <pre id="gql-output" class="flex-1 bg-background border border-border rounded-lg p-4 text-xs font-mono overflow-auto whitespace-pre min-h-[300px] text-text-muted"></pre>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="GraphQL Schema Generator" relatedTags={['graphql', 'api', 'backend', 'schema', 'typescript']} />
</BaseLayout>

<script>
(function () {
  const SCALARS = ['String', 'Int', 'Float', 'Boolean', 'ID', 'Date', 'JSON', 'Upload'];

  let types = [
    {
      id: 'type_User',
      kind: 'type',
      name: 'User',
      fields: [
        { name: 'id', scalar: 'ID', required: true, isList: false },
        { name: 'name', scalar: 'String', required: true, isList: false },
        { name: 'email', scalar: 'String', required: false, isList: false },
        { name: 'createdAt', scalar: 'Date', required: false, isList: false },
      ]
    }
  ];

  function uid() { return Math.random().toString(36).slice(2, 9); }

  function renderTypes() {
    const container = document.getElementById('gql-types-list');
    if (!types.length) {
      container.innerHTML = '<p class="text-sm text-text-muted">No types yet. Add one above.</p>';
      return;
    }
    container.innerHTML = types.map((t, ti) => `
      <div class="border border-border rounded-lg p-3 bg-background" data-typeid="${t.id}">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm font-medium font-mono">${t.kind} <span class="text-accent">${t.name}</span></span>
          <button onclick="window.__gql_removeType('${t.id}')" class="text-red-400 hover:text-red-300 text-xs">Remove</button>
        </div>
        ${t.kind === 'enum' ? `
          <div class="space-y-1 mb-2">
            ${(t.values || []).map((v, vi) => `
              <div class="flex items-center gap-2">
                <span class="text-xs font-mono flex-1">${v}</span>
                <button onclick="window.__gql_removeEnumValue('${t.id}',${vi})" class="text-xs text-red-400 hover:text-red-300">×</button>
              </div>
            `).join('')}
          </div>
          <div class="flex gap-2">
            <input id="ev-input-${t.id}" type="text" placeholder="ACTIVE, DRAFT…" autocomplete="off"
              class="flex-1 bg-surface border border-border rounded px-2 py-1 text-xs focus:outline-none focus:border-accent" />
            <button onclick="window.__gql_addEnumValue('${t.id}')" class="text-xs bg-accent/20 hover:bg-accent/40 px-2 py-1 rounded transition-colors">Add Value</button>
          </div>
        ` : `
          <div class="space-y-1 mb-2">
            ${t.fields.map((f, fi) => `
              <div class="flex items-center gap-1.5 flex-wrap">
                <span class="text-xs font-mono text-text-muted w-28 truncate">${f.name}</span>
                <span class="text-xs font-mono text-accent">${f.isList ? '[' : ''}${f.scalar}${f.required ? '!' : ''}${f.isList ? ']' : ''}</span>
                <button onclick="window.__gql_removeField('${t.id}',${fi})" class="text-xs text-red-400 hover:text-red-300 ml-auto">×</button>
              </div>
            `).join('')}
          </div>
          <div class="flex gap-1 flex-wrap">
            <input id="fn-${t.id}" type="text" placeholder="fieldName" autocomplete="off"
              class="w-28 bg-surface border border-border rounded px-2 py-1 text-xs focus:outline-none focus:border-accent" />
            <select id="fs-${t.id}" class="bg-surface border border-border rounded px-1 py-1 text-xs focus:outline-none focus:border-accent">
              ${SCALARS.map(s => `<option value="${s}">${s}</option>`).join('')}
            </select>
            <label class="flex items-center gap-1 text-xs cursor-pointer">
              <input type="checkbox" id="fr-${t.id}" class="accent-accent" checked /> Non-null
            </label>
            <label class="flex items-center gap-1 text-xs cursor-pointer">
              <input type="checkbox" id="fl-${t.id}" class="accent-accent" /> List
            </label>
            <button onclick="window.__gql_addField('${t.id}')" class="text-xs bg-accent/20 hover:bg-accent/40 px-2 py-1 rounded transition-colors">Add Field</button>
          </div>
        `}
      </div>
    `).join('');
  }

  function generateSDL() {
    const lines = [];
    lines.push('# Generated by DevPlaybook GraphQL Schema Generator');
    lines.push('# https://devplaybook.cc/tools/graphql-schema-generator');
    lines.push('');

    types.forEach(t => {
      if (t.kind === 'enum') {
        lines.push(`enum ${t.name} {`);
        (t.values || []).forEach(v => lines.push(`  ${v}`));
        lines.push('}');
        lines.push('');
      } else {
        lines.push(`${t.kind} ${t.name} {`);
        t.fields.forEach(f => {
          const typeStr = f.isList ? `[${f.scalar}${f.required ? '!' : ''}]` : `${f.scalar}${f.required ? '!' : ''}`;
          lines.push(`  ${f.name}: ${typeStr}`);
        });
        if (!t.fields.length) lines.push('  _placeholder: String');
        lines.push('}');
        lines.push('');
      }
    });

    const addQuery = document.getElementById('gql-add-query').checked;
    const addMutation = document.getElementById('gql-add-mutation').checked;

    if (addQuery) {
      lines.push('type Query {');
      types.filter(t => t.kind === 'type').forEach(t => {
        const lower = t.name.charAt(0).toLowerCase() + t.name.slice(1);
        lines.push(`  ${lower}(id: ID!): ${t.name}`);
        lines.push(`  ${lower}s: [${t.name}!]!`);
      });
      if (!types.filter(t => t.kind === 'type').length) lines.push('  _empty: String');
      lines.push('}');
      lines.push('');
    }

    if (addMutation) {
      lines.push('type Mutation {');
      types.filter(t => t.kind === 'type').forEach(t => {
        const lower = t.name.charAt(0).toLowerCase() + t.name.slice(1);
        lines.push(`  create${t.name}(input: Create${t.name}Input!): ${t.name}!`);
        lines.push(`  delete${t.name}(id: ID!): Boolean!`);
      });
      if (!types.filter(t => t.kind === 'type').length) lines.push('  _empty: String');
      lines.push('}');
      lines.push('');
    }

    return lines.join('\n');
  }

  window.__gql_removeType = function(id) {
    types = types.filter(t => t.id !== id);
    renderTypes(); updateOutput();
  };
  window.__gql_removeField = function(typeId, fi) {
    const t = types.find(x => x.id === typeId);
    if (t) { t.fields.splice(fi, 1); renderTypes(); updateOutput(); }
  };
  window.__gql_addField = function(typeId) {
    const t = types.find(x => x.id === typeId);
    if (!t) return;
    const name = document.getElementById(`fn-${typeId}`).value.trim();
    const scalar = document.getElementById(`fs-${typeId}`).value;
    const required = document.getElementById(`fr-${typeId}`).checked;
    const isList = document.getElementById(`fl-${typeId}`).checked;
    if (!name) return;
    if (!/^[a-zA-Z_][a-zA-Z0-9_]*$/.test(name)) { alert('Field names must start with a letter or underscore.'); return; }
    t.fields.push({ name, scalar, required, isList });
    document.getElementById(`fn-${typeId}`).value = '';
    renderTypes(); updateOutput();
  };
  window.__gql_addEnumValue = function(typeId) {
    const t = types.find(x => x.id === typeId);
    if (!t) return;
    const val = document.getElementById(`ev-input-${typeId}`).value.trim().toUpperCase().replace(/\s+/g, '_');
    if (!val) return;
    if (!t.values) t.values = [];
    t.values.push(val);
    document.getElementById(`ev-input-${typeId}`).value = '';
    renderTypes(); updateOutput();
  };
  window.__gql_removeEnumValue = function(typeId, vi) {
    const t = types.find(x => x.id === typeId);
    if (t && t.values) { t.values.splice(vi, 1); renderTypes(); updateOutput(); }
  };

  document.getElementById('gql-add-type').addEventListener('click', () => {
    const name = document.getElementById('gql-type-name').value.trim();
    const kind = document.getElementById('gql-type-kind').value;
    if (!name) return;
    if (!/^[A-Z][a-zA-Z0-9]*$/.test(name)) { alert('Type names must start with a capital letter (e.g. User, Post).'); return; }
    if (types.find(t => t.name === name)) { alert('Type name already exists.'); return; }
    types.push({ id: uid(), kind, name, fields: [], values: [] });
    document.getElementById('gql-type-name').value = '';
    renderTypes(); updateOutput();
  });

  document.getElementById('gql-add-query').addEventListener('change', updateOutput);
  document.getElementById('gql-add-mutation').addEventListener('change', updateOutput);

  document.getElementById('gql-copy').addEventListener('click', () => {
    const text = document.getElementById('gql-output').textContent;
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById('gql-copy');
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy SDL', 1500);
    });
  });

  function updateOutput() {
    document.getElementById('gql-output').textContent = generateSDL();
  }

  renderTypes();
  updateOutput();
})();
</script>
