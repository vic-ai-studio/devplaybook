---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "How is entropy calculated?", answer: "Entropy is calculated as: bits = length × log₂(charset_size). For a 16-char password using all character types (uppercase + lowercase + digits + symbols = ~95 chars), entropy ≈ 16 × 6.57 = 105 bits. Higher entropy means more combinations an attacker must try." },
  { question: "What does NIST SP 800-63B compliance mean?", answer: "NIST SP 800-63B recommends: minimum 8 characters, checking against known compromised passwords, no mandatory complexity rules (but length is paramount), and no forced periodic changes. A long passphrase like 'correct-horse-battery-staple' can be both NIST compliant and strong." },
  { question: "How is crack time estimated?", answer: "Crack time is estimated assuming an offline attack with modern GPU rigs (~100 billion hashes/sec for MD5). It's entropy-based: combinations = 2^entropy_bits, time = combinations / hashrate. Modern bcrypt/Argon2 hashing slows this dramatically — the estimate reflects worst-case unprotected storage." },
  { question: "Does this tool store my password?", answer: "No. All analysis runs entirely in your browser via JavaScript. Your password is never transmitted to any server and never stored anywhere." },
  { question: "What's the difference between this and a password generator?", answer: "This analyzer grades a password you provide. A generator creates a new random password. For maximum security: generate a random password, then analyze it here to confirm it meets your bar before using it." },
];
---

<BaseLayout
  title="Password Strength Analyzer — Entropy, NIST Compliance & Crack Time"
  description="Analyze password strength with real entropy calculation, NIST SP 800-63B compliance check, estimated crack time, and character class breakdown. Runs 100% in browser."
  tool="Password Strength Analyzer, Password Entropy Calculator, NIST Password Checker, Password Crack Time Estimator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Password Strength Analyzer</h1>
  <p class="text-text-muted mb-4">Enter any password to get entropy bits, estimated crack time, NIST SP 800-63B compliance, and a detailed character class breakdown. Nothing leaves your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Real entropy calculation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> NIST SP 800-63B compliance</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Password never stored or sent</span>
  </div>

  <div class="space-y-5">
    <!-- Input -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <label class="block text-sm font-medium mb-2">Password to Analyze</label>
      <div class="relative">
        <input id="pwd-input" type="password" placeholder="Type or paste a password..."
          class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-sm font-mono focus:outline-none focus:border-primary pr-24" />
        <button id="toggle-vis" class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-text-muted hover:text-text px-2 py-1 border border-border rounded">Show</button>
      </div>
    </div>

    <!-- Strength Meter -->
    <div id="result-section" class="hidden space-y-4">
      <!-- Score Bar -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <span class="text-sm font-medium">Strength</span>
          <span id="strength-label" class="text-sm font-bold"></span>
        </div>
        <div class="h-2.5 bg-bg rounded-full overflow-hidden">
          <div id="strength-bar" class="h-full rounded-full transition-all duration-300" style="width:0%"></div>
        </div>
      </div>

      <!-- Metrics Grid -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
          <div id="metric-entropy" class="text-2xl font-bold text-primary">—</div>
          <div class="text-xs text-text-muted mt-1">Entropy (bits)</div>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
          <div id="metric-length" class="text-2xl font-bold">—</div>
          <div class="text-xs text-text-muted mt-1">Length</div>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
          <div id="metric-charset" class="text-2xl font-bold">—</div>
          <div class="text-xs text-text-muted mt-1">Charset Size</div>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
          <div id="metric-crack" class="text-sm font-bold leading-tight">—</div>
          <div class="text-xs text-text-muted mt-1">Est. Crack Time</div>
        </div>
      </div>

      <!-- NIST Compliance -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold mb-3">NIST SP 800-63B Compliance</h2>
        <div id="nist-checks" class="space-y-2"></div>
      </div>

      <!-- Character Classes -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold mb-3">Character Class Breakdown</h2>
        <div id="char-classes" class="grid grid-cols-2 md:grid-cols-4 gap-3"></div>
      </div>

      <!-- Suggestions -->
      <div id="suggestions-box" class="bg-amber-500/10 border border-amber-500/30 rounded-xl p-4 hidden">
        <h2 class="text-sm font-semibold mb-2 text-amber-400">Suggestions</h2>
        <ul id="suggestions-list" class="text-sm text-text-muted space-y-1 list-disc list-inside"></ul>
      </div>
    </div>
  </div>

  <AdUnit slot="in-content" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Password Strength Analyzer" relatedTags={['security', 'password', 'encryption', 'auth', 'hashing']} />
</BaseLayout>

<script>
const input = document.getElementById('pwd-input') as HTMLInputElement;
const toggleBtn = document.getElementById('toggle-vis') as HTMLButtonElement;
const resultSection = document.getElementById('result-section')!;

toggleBtn.addEventListener('click', () => {
  const vis = input.type === 'password';
  input.type = vis ? 'text' : 'password';
  toggleBtn.textContent = vis ? 'Hide' : 'Show';
});

function calcEntropy(pwd: string): { entropy: number; charsetSize: number } {
  let size = 0;
  if (/[a-z]/.test(pwd)) size += 26;
  if (/[A-Z]/.test(pwd)) size += 26;
  if (/[0-9]/.test(pwd)) size += 10;
  if (/[ !"#$%&'()*+,\-./:;<=>?@[\\\]^_`{|}~]/.test(pwd)) size += 33;
  if (size === 0) size = 26;
  return { entropy: Math.round(pwd.length * Math.log2(size) * 10) / 10, charsetSize: size };
}

function crackTime(entropy: number): string {
  const combinations = Math.pow(2, entropy);
  const hashrate = 1e11; // 100B hashes/sec (offline GPU)
  const seconds = combinations / hashrate;
  if (seconds < 1) return '< 1 second';
  if (seconds < 60) return `${Math.round(seconds)} seconds`;
  if (seconds < 3600) return `${Math.round(seconds/60)} minutes`;
  if (seconds < 86400) return `${Math.round(seconds/3600)} hours`;
  if (seconds < 2592000) return `${Math.round(seconds/86400)} days`;
  if (seconds < 31536000) return `${Math.round(seconds/2592000)} months`;
  const years = seconds / 31536000;
  if (years < 1e6) return `${Math.round(years).toLocaleString()} years`;
  if (years < 1e9) return `${(years/1e6).toFixed(1)}M years`;
  if (years < 1e12) return `${(years/1e9).toFixed(1)}B years`;
  return `>${(years/1e12).toFixed(0)}T years`;
}

function getStrength(entropy: number): { label: string; color: string; pct: number } {
  if (entropy < 28) return { label: 'Very Weak', color: '#ef4444', pct: 10 };
  if (entropy < 36) return { label: 'Weak', color: '#f97316', pct: 25 };
  if (entropy < 60) return { label: 'Fair', color: '#eab308', pct: 50 };
  if (entropy < 80) return { label: 'Good', color: '#22c55e', pct: 75 };
  if (entropy < 100) return { label: 'Strong', color: '#3b82f6', pct: 88 };
  return { label: 'Very Strong', color: '#8b5cf6', pct: 100 };
}

function analyze(pwd: string) {
  if (!pwd) { resultSection.classList.add('hidden'); return; }
  resultSection.classList.remove('hidden');

  const { entropy, charsetSize } = calcEntropy(pwd);
  const { label, color, pct } = getStrength(entropy);

  document.getElementById('strength-label')!.textContent = label;
  document.getElementById('strength-label')!.style.color = color;
  const bar = document.getElementById('strength-bar')!;
  bar.style.width = pct + '%';
  bar.style.background = color;

  document.getElementById('metric-entropy')!.textContent = String(entropy);
  document.getElementById('metric-length')!.textContent = String(pwd.length);
  document.getElementById('metric-charset')!.textContent = String(charsetSize);
  document.getElementById('metric-crack')!.textContent = crackTime(entropy);

  // NIST checks
  const nist = [
    { label: 'At least 8 characters', pass: pwd.length >= 8 },
    { label: 'At least 12 characters (recommended)', pass: pwd.length >= 12 },
    { label: 'Not a single character repeated', pass: !/^(.)\1+$/.test(pwd) },
    { label: 'No leading/trailing spaces', pass: pwd === pwd.trim() },
    { label: 'Not keyboard walk (qwerty/asdf)', pass: !/(qwert|asdf|zxcv|1234|abcd)/i.test(pwd) },
    { label: 'No common patterns (password, 123456)', pass: !/(password|123456|letmein|admin|qwerty)/i.test(pwd) },
  ];
  const nistEl = document.getElementById('nist-checks')!;
  nistEl.innerHTML = nist.map(c => `
    <div class="flex items-center gap-2 text-sm">
      <span class="${c.pass ? 'text-green-500' : 'text-red-400'}">${c.pass ? '✓' : '✗'}</span>
      <span class="${c.pass ? '' : 'text-text-muted'}">${c.label}</span>
    </div>
  `).join('');

  // Char classes
  const classes = [
    { label: 'Lowercase', count: (pwd.match(/[a-z]/g)||[]).length, icon: 'a-z' },
    { label: 'Uppercase', count: (pwd.match(/[A-Z]/g)||[]).length, icon: 'A-Z' },
    { label: 'Digits', count: (pwd.match(/[0-9]/g)||[]).length, icon: '0-9' },
    { label: 'Symbols', count: (pwd.match(/[^a-zA-Z0-9]/g)||[]).length, icon: '!@#' },
  ];
  const ccEl = document.getElementById('char-classes')!;
  ccEl.innerHTML = classes.map(c => `
    <div class="bg-bg border border-border rounded-lg p-3 text-center">
      <div class="text-xs font-mono text-text-muted mb-1">${c.icon}</div>
      <div class="text-xl font-bold ${c.count > 0 ? 'text-primary' : 'text-text-muted'}">${c.count}</div>
      <div class="text-xs text-text-muted">${c.label}</div>
    </div>
  `).join('');

  // Suggestions
  const sugs: string[] = [];
  if (pwd.length < 12) sugs.push('Increase length to 12+ characters for strong security.');
  if (!/[A-Z]/.test(pwd)) sugs.push('Add uppercase letters to expand the character set.');
  if (!/[0-9]/.test(pwd)) sugs.push('Include digits to increase entropy.');
  if (!/[^a-zA-Z0-9]/.test(pwd)) sugs.push('Add symbols (!@#$%) for maximum entropy.');
  if (entropy < 60) sugs.push('Consider a passphrase (4+ random words) for a balance of strength and memorability.');
  const sugBox = document.getElementById('suggestions-box')!;
  const sugList = document.getElementById('suggestions-list')!;
  if (sugs.length) {
    sugBox.classList.remove('hidden');
    sugList.innerHTML = sugs.map(s => `<li>${s}</li>`).join('');
  } else {
    sugBox.classList.add('hidden');
  }
}

input.addEventListener('input', () => analyze(input.value));
</script>
