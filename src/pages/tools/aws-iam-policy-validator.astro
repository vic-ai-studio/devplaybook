---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AwsIamPolicyValidator from '../../components/AwsIamPolicyValidator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is an AWS IAM policy?",
    answer: "An IAM (Identity and Access Management) policy is a JSON document that defines permissions in AWS. It specifies what actions are allowed or denied, on which resources, and under what conditions. Policies are attached to IAM users, groups, or roles. There are two types: identity-based policies (attached to a principal) and resource-based policies (attached to a resource like an S3 bucket or KMS key). Every API call in AWS is evaluated against the applicable policies before being allowed."
  },
  {
    question: "Why is Action: '*' dangerous?",
    answer: "Action: '*' grants ALL permissions across ALL AWS services — this is equivalent to root access. If an IAM entity with Action: '*' is compromised, the attacker can create new admin users, delete data, spin up infrastructure, exfiltrate secrets, and more. Always replace Action: '*' with the specific actions your application actually needs. Use IAM Access Analyzer and CloudTrail to discover the minimum set of permissions actually used."
  },
  {
    question: "What are IAM privilege escalation attacks?",
    answer: "Privilege escalation occurs when an attacker uses existing limited permissions to grant themselves or another principal higher permissions. Common escalation paths: iam:CreateAccessKey (create new credentials for an existing admin user), iam:AttachUserPolicy (attach an existing admin policy to a controlled user), iam:UpdateLoginProfile (set a password on an admin account). AWS security researchers have documented over 20 escalation paths. Audit these actions carefully and require MFA conditions."
  },
  {
    question: "What is the principle of least privilege?",
    answer: "Least privilege means granting only the minimum permissions required to perform a task. Instead of ec2:* (all EC2 actions), grant only the specific operations needed — e.g. ec2:StartInstances and ec2:StopInstances. This limits the blast radius if credentials are compromised. Tools to help: IAM Access Analyzer generates least-privilege policies from CloudTrail logs, and the AWS Policy Simulator lets you test what permissions a policy actually grants."
  },
  {
    question: "What are IAM policy conditions?",
    answer: "Conditions add extra constraints to when a statement applies. Common examples: aws:MultiFactorAuthPresent (require MFA), aws:SourceIp (restrict by IP or CIDR range), aws:RequestedRegion (limit to specific AWS regions), aws:SecureTransport (require HTTPS), aws:CalledVia (restrict to actions called through specific services). Conditions are a powerful way to harden permissive policies — for example, allowing s3:* only from a specific VPC endpoint."
  },
  {
    question: "What is the difference between inline and managed IAM policies?",
    answer: "Managed policies are standalone policy documents that can be attached to multiple users, groups, or roles. AWS provides pre-built managed policies (like AmazonS3ReadOnlyAccess), or you can create customer managed policies. Inline policies are embedded directly into a single IAM entity and are deleted when that entity is deleted. Best practice: prefer customer managed policies over inline policies for reusability, version history, and easier auditing. Avoid AWS managed policies for production — they tend to be overly broad."
  },
];
---

<BaseLayout
  title="AWS IAM Policy Validator — Check IAM Policy JSON for Security Issues"
  description="Free online AWS IAM policy validator. Detects wildcard actions, privilege escalation risks, missing conditions, and structure errors in IAM policy JSON. Runs in your browser."
  tool="AWS IAM policy validator, IAM policy security checker, AWS permissions linter, IAM wildcard detector, AWS least privilege checker, IAM policy analyzer"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">AWS IAM Policy Validator</h1>
  <p class="text-text-muted mb-4">Paste your AWS IAM policy JSON and instantly check for security risks: wildcard actions, overly broad resource scopes, privilege escalation paths, missing MFA conditions, and structural errors — without touching the AWS Console.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 10 security checks</span>
  </div>
  <AwsIamPolicyValidator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="AWS IAM Policy Validator" relatedTags={['aws', 'cloud', 'devops', 'security', 'infrastructure']} />
</BaseLayout>
