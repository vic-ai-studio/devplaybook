---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AiCommitGenerator from '../../components/AiCommitGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="AI Commit Message Generator — From Plain English to Perfect Commits"
  description="Describe your code change in plain English and get multiple commit message suggestions — Conventional Commits, imperative, and bracket-style. Detects commit type and scope automatically."
  tool="AI Commit Message Generator, Commit Message Generator, Git Commit Generator, Conventional Commits Generator"
>
  <h1 class="text-3xl font-bold mb-2">AI Commit Message Generator</h1>
  <p class="text-text-muted mb-8">Describe what you changed in plain English — this tool infers the commit type (<code class="font-mono text-sm bg-bg-card px-1 rounded">feat</code>, <code class="font-mono text-sm bg-bg-card px-1 rounded">fix</code>, <code class="font-mono text-sm bg-bg-card px-1 rounded">refactor</code>…), scope, and generates multiple commit message styles instantly. No external API needed — runs in your browser.</p>
  <AiCommitGenerator client:load />
  <ToolPageCta currentTool="AI Commit Message Generator" relatedTags={['git', 'commits', 'developer-tools', 'productivity']} />
</BaseLayout>
