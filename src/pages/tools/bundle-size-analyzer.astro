---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "Why does bundle size matter for web performance?",
    answer: "Larger JavaScript bundles mean more bytes to download, parse, and execute. On a median mobile device, each 1KB of gzip JavaScript requires ~1ms to parse. A 300KB gzip bundle adds ~300ms of parse time on top of download time. Lighthouse penalizes pages where main-thread JavaScript takes over 3.5 seconds to execute. Reducing bundle size directly improves Time to Interactive (TTI), First Contentful Paint, and Lighthouse scores."
  },
  {
    question: "What does 'tree-shakeable' mean and why does it matter?",
    answer: "Tree-shaking is the process of removing unused code (dead code elimination) from the final bundle. A tree-shakeable package exports functions individually, so bundlers (webpack, Rollup, esbuild, Vite) can include only what you import. For example, importing { format } from 'date-fns' adds ~2KB instead of the full 70KB library. Non-tree-shakeable packages (like moment.js) include everything regardless of what you use. Always prefer tree-shakeable alternatives."
  },
  {
    question: "What is the difference between minified size and gzip size?",
    answer: "Minified size is the JavaScript after removing whitespace, comments, and shortening variable names. Gzip size is the minified code after gzip compression — the actual bytes transferred over the network. Gzip typically reduces size by 60-80% for JavaScript. The number you care about for network performance is gzip size. Bundlephobia reports both, and the sizes shown here are approximate gzip estimates. Brotli compression (supported by modern browsers) can reduce sizes even further by ~15-20%."
  },
  {
    question: "How do I reduce my JavaScript bundle size in practice?",
    answer: "Key strategies: 1) Code splitting — use dynamic import() to split routes, load on demand. 2) Replace heavy libraries — swap moment.js with date-fns/dayjs, lodash with native JS methods, axios with native fetch. 3) Lazy loading — load components only when needed. 4) Analyze your bundle — use webpack-bundle-analyzer or vite-bundle-visualizer to find the largest chunks. 5) Tree-shaking — import named exports, avoid default import of entire libraries. 6) CDN delivery — use CDN links to leverage browser caching across sites."
  },
  {
    question: "Should I use a CDN link or bundle the library?",
    answer: "CDN links (jsDelivr, unpkg) serve pre-built files but add external HTTP requests and introduce network dependency. Bundling the library lets your bundler optimize, tree-shake, and split code. Modern best practices favor bundling with tree-shaking over CDN links for most packages. CDN makes sense for large, rarely-updated libraries (like Chart.js ~60KB) where HTTP/2 and browser caching provide benefits. For small utilities, always bundle and tree-shake."
  }
];
---

<BaseLayout
  title="JavaScript Bundle Size Analyzer — Package Size Comparison Tool"
  description="Analyze JavaScript package bundle sizes. Compare gzip sizes, parse times, and tree-shaking support for React, Lodash, Moment, Axios, and 40+ popular packages. Find lighter alternatives. Free browser tool."
  tool="bundle size analyzer, javascript package size, npm bundle size, tree shaking checker, bundle size comparison"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "JavaScript Bundle Size Analyzer",
    "url": "https://devplaybook.cc/tools/bundle-size-analyzer",
    "description": "Analyze JavaScript package bundle sizes, parse times, tree-shaking support, and find lighter alternatives.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">JavaScript Bundle Size Analyzer</h1>
  <p class="text-text-muted mb-4">
    Check bundle size impact of popular npm packages. Enter package names to see gzip size,
    parse time, tree-shaking support, CDN links, and lighter alternatives.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 40+ packages in database</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Gzip size estimates</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Tree-shaking analysis</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Lighter alternatives</span>
  </div>

  <!-- Input -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <label class="block text-sm font-medium mb-2">Package Names (comma-separated)</label>
    <div class="flex gap-2">
      <input id="pkg-input" type="text" value="react, lodash, moment, axios" class="flex-1 bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
      <button id="analyze-btn" class="px-4 py-2 bg-primary text-white rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors shrink-0">Analyze</button>
    </div>
    <p class="text-xs text-text-muted mt-2">Try: react, vue, lodash, moment, date-fns, axios, zod, tailwindcss</p>
  </div>

  <!-- Quick picks -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-medium mb-3">Quick Presets</h2>
    <div class="flex flex-wrap gap-2" id="presets"></div>
  </div>

  <!-- Results table -->
  <div id="results-section" class="hidden mb-4">
    <h2 class="text-sm font-medium mb-3">Analysis Results</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm border border-border rounded-lg overflow-hidden">
        <thead>
          <tr class="bg-surface text-text-muted text-xs">
            <th class="text-left px-3 py-2 font-medium">Package</th>
            <th class="text-right px-3 py-2 font-medium">Minified</th>
            <th class="text-right px-3 py-2 font-medium">Gzip</th>
            <th class="text-center px-3 py-2 font-medium">Parse Time</th>
            <th class="text-center px-3 py-2 font-medium">Tree-Shake</th>
            <th class="text-left px-3 py-2 font-medium">Alternatives</th>
          </tr>
        </thead>
        <tbody id="results-body"></tbody>
      </table>
    </div>
    <div class="mt-3 p-3 bg-bg-card border border-border rounded-lg">
      <div class="flex items-center justify-between text-sm">
        <span class="text-text-muted">Total estimated gzip</span>
        <span id="total-gzip" class="font-bold text-accent"></span>
      </div>
      <div id="total-assessment" class="mt-1 text-xs text-text-muted"></div>
    </div>
  </div>

  <!-- Not found -->
  <div id="not-found-section" class="hidden bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-medium mb-2 text-yellow-400">Packages Not in Database</h2>
    <div id="not-found-list" class="text-sm text-text-muted"></div>
    <p class="text-xs text-text-muted mt-2">For precise sizes, check <a href="https://bundlephobia.com" target="_blank" rel="noopener" class="text-accent hover:underline">bundlephobia.com</a></p>
  </div>

  <!-- Tips -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-medium mb-3">Bundle Reduction Tips</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-xs text-text-muted">
      <div class="flex gap-2"><span class="text-green-500 shrink-0">→</span><span>Use <code class="text-accent">dynamic import()</code> for route-level code splitting</span></div>
      <div class="flex gap-2"><span class="text-green-500 shrink-0">→</span><span>Replace <code class="text-accent">moment.js</code> with <code class="text-accent">date-fns</code> or <code class="text-accent">dayjs</code> (90% smaller)</span></div>
      <div class="flex gap-2"><span class="text-green-500 shrink-0">→</span><span>Replace <code class="text-accent">lodash</code> with native JS methods or <code class="text-accent">lodash-es</code></span></div>
      <div class="flex gap-2"><span class="text-green-500 shrink-0">→</span><span>Use <code class="text-accent">webpack-bundle-analyzer</code> to visualize bundle composition</span></div>
      <div class="flex gap-2"><span class="text-green-500 shrink-0">→</span><span>Import named exports: <code class="text-accent">import &#123; format &#125; from 'date-fns'</code></span></div>
      <div class="flex gap-2"><span class="text-green-500 shrink-0">→</span><span>Use <code class="text-accent">axios</code> alternatives: native <code class="text-accent">fetch</code> or <code class="text-accent">ky</code> (2KB)</span></div>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Bundle Size Analyzer" relatedTags={['javascript', 'performance', 'webpack', 'vite', 'npm', 'optimization']} />
</BaseLayout>

<script is:inline>
(function() {
  const DB = {
    'react': { min: 144, gz: 46, parse: 35, tree: true, cdn: 'https://cdn.jsdelivr.net/npm/react/umd/react.production.min.js', alts: ['preact (3KB)', 'solid-js (7KB)'], category: 'framework' },
    'react-dom': { min: 1023, gz: 295, parse: 220, tree: false, cdn: 'https://cdn.jsdelivr.net/npm/react-dom/umd/react-dom.production.min.js', alts: ['preact/compat (4KB)'], category: 'framework' },
    'vue': { min: 200, gz: 72, parse: 55, tree: true, cdn: 'https://cdn.jsdelivr.net/npm/vue/dist/vue.esm-bundler.js', alts: ['petite-vue (6KB)'], category: 'framework' },
    'angular': { min: 1150, gz: 290, parse: 230, tree: true, cdn: null, alts: ['vue (72KB gz)', 'preact (3KB gz)'], category: 'framework' },
    'svelte': { min: 10, gz: 3, parse: 2, tree: true, cdn: null, alts: [], category: 'framework' },
    'lodash': { min: 531, gz: 72, parse: 55, tree: false, cdn: 'https://cdn.jsdelivr.net/npm/lodash/lodash.min.js', alts: ['lodash-es (tree-shakeable)', 'native JS methods', 'remeda'], category: 'utility' },
    'lodash-es': { min: 531, gz: 25, parse: 20, tree: true, cdn: null, alts: ['native JS methods'], category: 'utility' },
    'moment': { min: 531, gz: 73, parse: 55, tree: false, cdn: 'https://cdn.jsdelivr.net/npm/moment/moment.min.js', alts: ['date-fns (2-7KB tree-shaken)', 'dayjs (2KB)', 'luxon (22KB)'], category: 'date' },
    'date-fns': { min: 79, gz: 13, parse: 10, tree: true, cdn: null, alts: ['dayjs (2KB)'], category: 'date' },
    'dayjs': { min: 15, gz: 5, parse: 3, tree: false, cdn: 'https://cdn.jsdelivr.net/npm/dayjs/dayjs.min.js', alts: [], category: 'date' },
    'luxon': { min: 215, gz: 68, parse: 52, tree: false, cdn: 'https://cdn.jsdelivr.net/npm/luxon/build/global/luxon.min.js', alts: ['date-fns (tree-shakeable)', 'dayjs (2KB)'], category: 'date' },
    'axios': { min: 55, gz: 18, parse: 14, tree: false, cdn: 'https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js', alts: ['native fetch (0KB)', 'ky (2KB)', 'redaxios (0.8KB)'], category: 'http' },
    'ky': { min: 10, gz: 3, parse: 2, tree: true, cdn: null, alts: [], category: 'http' },
    'got': { min: 45, gz: 14, parse: 11, tree: false, cdn: null, alts: ['ky (3KB)', 'native fetch'], category: 'http' },
    'zod': { min: 57, gz: 14, parse: 10, tree: true, cdn: null, alts: ['yup (23KB)', 'joi (25KB)'], category: 'validation' },
    'yup': { min: 84, gz: 23, parse: 17, tree: false, cdn: null, alts: ['zod (14KB gz)', 'valibot (1.4KB)'], category: 'validation' },
    'joi': { min: 149, gz: 34, parse: 26, tree: false, cdn: 'https://cdn.jsdelivr.net/npm/joi/dist/joi.min.js', alts: ['zod (14KB gz)', 'valibot (1.4KB)'], category: 'validation' },
    'valibot': { min: 9, gz: 1.4, parse: 1, tree: true, cdn: null, alts: [], category: 'validation' },
    'redux': { min: 27, gz: 9, parse: 7, tree: true, cdn: null, alts: ['zustand (1KB)', 'jotai (3KB)'], category: 'state' },
    '@reduxjs/toolkit': { min: 142, gz: 44, parse: 33, tree: true, cdn: null, alts: ['zustand (1KB)', 'jotai (3KB)'], category: 'state' },
    'zustand': { min: 13, gz: 3, parse: 2, tree: true, cdn: null, alts: [], category: 'state' },
    'mobx': { min: 122, gz: 34, parse: 26, tree: false, cdn: null, alts: ['zustand (3KB)', 'jotai (3KB)'], category: 'state' },
    'recoil': { min: 125, gz: 40, parse: 30, tree: false, cdn: null, alts: ['jotai (3KB)', 'zustand (3KB)'], category: 'state' },
    'jotai': { min: 28, gz: 8, parse: 6, tree: true, cdn: null, alts: [], category: 'state' },
    'react-query': { min: 150, gz: 50, parse: 38, tree: true, cdn: null, alts: ['swr (5KB)'], category: 'data' },
    '@tanstack/react-query': { min: 150, gz: 50, parse: 38, tree: true, cdn: null, alts: ['swr (5KB)'], category: 'data' },
    'swr': { min: 31, gz: 9, parse: 7, tree: true, cdn: null, alts: [], category: 'data' },
    'chart.js': { min: 218, gz: 62, parse: 47, tree: true, cdn: 'https://cdn.jsdelivr.net/npm/chart.js/dist/chart.umd.min.js', alts: ['uplot (25KB gz)', 'lightweight-charts (35KB gz)'], category: 'visualization' },
    'd3': { min: 555, gz: 148, parse: 112, tree: true, cdn: 'https://cdn.jsdelivr.net/npm/d3/dist/d3.min.js', alts: ['individual d3-* packages (tree-shakeable)'], category: 'visualization' },
    'recharts': { min: 480, gz: 135, parse: 102, tree: false, cdn: null, alts: ['victory (60KB gz)', 'nivo (modular)'], category: 'visualization' },
    'three': { min: 645, gz: 158, parse: 120, tree: true, cdn: 'https://cdn.jsdelivr.net/npm/three/build/three.min.js', alts: [], category: 'graphics' },
    'gsap': { min: 115, gz: 35, parse: 27, tree: true, cdn: 'https://cdn.jsdelivr.net/npm/gsap/dist/gsap.min.js', alts: ['motion (19KB)', '@vueuse/motion'], category: 'animation' },
    'framer-motion': { min: 197, gz: 52, parse: 40, tree: true, cdn: null, alts: ['motion (19KB gz)', 'react-spring (37KB gz)'], category: 'animation' },
    'motion': { min: 90, gz: 28, parse: 21, tree: true, cdn: null, alts: [], category: 'animation' },
    'styled-components': { min: 200, gz: 57, parse: 43, tree: false, cdn: null, alts: ['linaria (0KB runtime)', 'vanilla-extract (0KB runtime)', 'tailwindcss'], category: 'css' },
    'tailwindcss': { min: 15, gz: 4, parse: 3, tree: true, cdn: 'https://cdn.tailwindcss.com', alts: [], category: 'css' },
    'classnames': { min: 2, gz: 0.8, parse: 0.5, tree: false, cdn: null, alts: ['clsx (0.5KB)', 'native template literals'], category: 'utility' },
    'clsx': { min: 2, gz: 0.5, parse: 0.4, tree: true, cdn: null, alts: [], category: 'utility' },
    'uuid': { min: 17, gz: 5, parse: 4, tree: true, cdn: null, alts: ['crypto.randomUUID() (0KB native)', 'nanoid (0.4KB)'], category: 'utility' },
    'nanoid': { min: 3, gz: 0.9, parse: 0.6, tree: true, cdn: null, alts: [], category: 'utility' },
    'i18next': { min: 78, gz: 24, parse: 18, tree: false, cdn: null, alts: ['paraglide-js (1KB)'], category: 'i18n' },
    'react-i18next': { min: 57, gz: 16, parse: 12, tree: false, cdn: null, alts: [], category: 'i18n' },
    'next': { min: 300, gz: 90, parse: 70, tree: true, cdn: null, alts: [], category: 'framework' },
    'typescript': { min: 8900, gz: 1980, parse: 0, tree: false, cdn: null, alts: ['Note: TS is compile-time only — 0KB in production'], category: 'tool' },
    '@emotion/react': { min: 45, gz: 15, parse: 11, tree: true, cdn: null, alts: ['styled-components', 'linaria (0KB runtime)'], category: 'css' },
    'immer': { min: 37, gz: 12, parse: 9, tree: true, cdn: null, alts: ['structuredClone() (0KB native)'], category: 'utility' },
    'rxjs': { min: 900, gz: 220, parse: 170, tree: true, cdn: null, alts: ['Use only needed operators (tree-shakeable)'], category: 'reactive' },
    'graphql': { min: 223, gz: 55, parse: 42, tree: true, cdn: null, alts: [], category: 'api' },
    '@apollo/client': { min: 365, gz: 95, parse: 73, tree: true, cdn: null, alts: ['urql (17KB gz)', 'graphql-request (5KB)'], category: 'api' },
  };

  const PRESETS = [
    { label: 'React app basics', pkgs: 'react, react-dom, react-query, zod, axios' },
    { label: 'Vue stack', pkgs: 'vue, zod, axios' },
    { label: 'Date libraries', pkgs: 'moment, date-fns, dayjs, luxon' },
    { label: 'HTTP clients', pkgs: 'axios, got, ky' },
    { label: 'State management', pkgs: 'redux, @reduxjs/toolkit, zustand, jotai, mobx' },
    { label: 'Validation', pkgs: 'zod, yup, joi, valibot' },
    { label: 'Animations', pkgs: 'framer-motion, gsap, motion' },
    { label: 'Charting', pkgs: 'chart.js, d3, recharts' },
  ];

  function formatKB(kb) {
    if (kb >= 1000) return (kb / 1000).toFixed(1) + ' MB';
    return kb.toFixed(1) + ' KB';
  }

  function sizeColor(gz) {
    if (gz <= 10) return 'text-green-400';
    if (gz <= 50) return 'text-yellow-400';
    return 'text-red-400';
  }

  function parseBadge(ms) {
    if (ms <= 5) return '<span class="text-green-400">Fast (&lt;5ms)</span>';
    if (ms <= 30) return '<span class="text-yellow-400">OK (' + ms + 'ms)</span>';
    return '<span class="text-red-400">Slow (' + ms + 'ms)</span>';
  }

  function analyze() {
    const raw = document.getElementById('pkg-input').value;
    const pkgs = raw.split(',').map(function(p) { return p.trim().toLowerCase(); }).filter(Boolean);

    const found = [];
    const notFound = [];

    for (var i = 0; i < pkgs.length; i++) {
      var pkg = pkgs[i];
      if (DB[pkg]) found.push(Object.assign({ name: pkg }, DB[pkg]));
      else notFound.push(pkg);
    }

    var resultsSection = document.getElementById('results-section');
    var notFoundSection = document.getElementById('not-found-section');

    if (found.length > 0) {
      resultsSection.classList.remove('hidden');
      var tbody = document.getElementById('results-body');
      tbody.innerHTML = found.map(function(p) {
        var treeBadge = p.tree
          ? '<span class="text-green-400 font-medium">Yes</span>'
          : '<span class="text-red-400">No</span>';
        var altsText = p.alts.length > 0 ? p.alts.join(', ') : '&mdash;';
        var cdnLink = p.cdn ? '<a href="' + p.cdn + '" target="_blank" rel="noopener" class="text-xs text-accent hover:underline">CDN</a>' : '';
        return '<tr class="border-t border-border hover:bg-surface/50 transition-colors">' +
          '<td class="px-3 py-3"><div class="font-mono font-medium">' + p.name + '</div>' +
          '<div class="text-xs text-text-muted capitalize">' + p.category + '</div>' + cdnLink + '</td>' +
          '<td class="px-3 py-3 text-right font-mono">' + formatKB(p.min) + '</td>' +
          '<td class="px-3 py-3 text-right font-mono ' + sizeColor(p.gz) + ' font-bold">' + formatKB(p.gz) + '</td>' +
          '<td class="px-3 py-3 text-center">' + parseBadge(p.parse) + '</td>' +
          '<td class="px-3 py-3 text-center">' + treeBadge + '</td>' +
          '<td class="px-3 py-3 text-xs text-text-muted">' + altsText + '</td>' +
          '</tr>';
      }).join('');

      var totalGz = found.reduce(function(sum, p) { return sum + p.gz; }, 0);
      document.getElementById('total-gzip').textContent = formatKB(totalGz);
      var assessment = '';
      if (totalGz <= 50) assessment = 'Excellent — well under the 50KB ideal budget';
      else if (totalGz <= 150) assessment = 'Good — within reasonable limits for most apps';
      else if (totalGz <= 300) assessment = 'Warning — consider replacing heavy dependencies';
      else assessment = 'Critical — significantly over budget; prioritize replacements';
      document.getElementById('total-assessment').textContent = assessment;
    } else {
      resultsSection.classList.add('hidden');
    }

    if (notFound.length > 0) {
      notFoundSection.classList.remove('hidden');
      document.getElementById('not-found-list').textContent = notFound.join(', ') + ' — not in local database';
    } else {
      notFoundSection.classList.add('hidden');
    }
  }

  function buildPresets() {
    var container = document.getElementById('presets');
    container.innerHTML = PRESETS.map(function(p) {
      return '<button class="preset-pkg px-3 py-1.5 bg-surface border border-border rounded-full text-xs text-text-muted hover:border-primary hover:text-foreground transition-colors" data-pkgs="' + p.pkgs + '">' + p.label + '</button>';
    }).join('');
    container.querySelectorAll('.preset-pkg').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.getElementById('pkg-input').value = btn.dataset.pkgs;
        analyze();
      });
    });
  }

  document.getElementById('analyze-btn').addEventListener('click', analyze);
  document.getElementById('pkg-input').addEventListener('keydown', function(e) { if (e.key === 'Enter') analyze(); });
  buildPresets();
  analyze();
})();
</script>
