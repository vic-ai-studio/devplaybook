---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PlanetScaleBranchManager from '../../components/PlanetScaleBranchManager.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is PlanetScale database branching?", answer: "PlanetScale branches are isolated copies of your database schema, similar to Git branches for code. You can create a feature branch, safely test schema changes (ALTER TABLE, CREATE INDEX), then open a deploy request to merge those changes into production — without locking tables or causing downtime." },
  { question: "What is a deploy request in PlanetScale?", answer: "A deploy request is PlanetScale's equivalent of a pull request for database schema changes. It shows the DDL diff between your feature branch and the target (usually main/production), lets your team review the changes, and deploys them using Online Schema Change (OSC) — zero-downtime migrations that don't lock tables." },
  { question: "How does PlanetScale handle zero-downtime migrations?", answer: "PlanetScale uses gh-ost (GitHub Online Schema Change) under the hood. Instead of ALTER TABLE which locks the table, it creates a shadow copy of the table, applies changes, syncs data via triggers, then swaps the tables atomically. Reads and writes continue uninterrupted throughout the migration." },
  { question: "Can I run raw SQL migrations on a PlanetScale branch?", answer: "Yes. Connect to your branch via pscale connect or pscale shell, then run DDL statements. However, note that PlanetScale's foreign key constraint support has limitations — they recommend using application-level foreign key enforcement instead of database-level constraints for the online migration system to work correctly." },
  { question: "What is the difference between pscale connect and pscale shell?", answer: "pscale connect opens a local MySQL-compatible proxy on a port (default 3306) — use this to connect your app or any MySQL client. pscale shell opens an interactive MySQL REPL directly in your terminal — useful for running quick queries, schema commands, or seeding data on a specific branch." },
  { question: "How do I use PlanetScale with Prisma or Drizzle?", answer: "For Prisma: use the @planetscale/database driver with DATA_PROXY or direct connection. Set databaseUrl in schema.prisma. For Drizzle: use drizzle-orm/planetscale-serverless with @planetscale/database for edge/serverless environments, or drizzle-orm/mysql2 for Node.js servers. Both support the PlanetScale branching workflow." },
];
---

<BaseLayout
  title="PlanetScale Branch Manager — DB Branch Visualizer & CLI Generator"
  description="Visualize PlanetScale database branch hierarchies and generate pscale CLI commands. Create branches, deploy requests, schema diffs, and connections. Free browser tool for PlanetScale developers."
  tool="PlanetScale branch manager, pscale CLI commands, planetscale deploy request, database branching visualizer, planetscale schema migration"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "PlanetScale Branch Manager",
    "url": "https://devplaybook.cc/tools/planetscale-branch-manager",
    "description": "Visualize PlanetScale database branch trees and generate pscale CLI commands for branching, deploy requests, schema diffs, and connections.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">PlanetScale Branch Manager</h1>
  <p class="text-text-muted mb-4">
    Visualize your <strong>PlanetScale database branch</strong> hierarchy and generate <strong>pscale CLI commands</strong> for every workflow step — branch creation, deploy requests, schema diffs, and connections.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Visual branch tree editor</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> pscale CLI command generator</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Deploy request workflow guide</span>
  </div>
  <PlanetScaleBranchManager client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="PlanetScale Branch Manager" relatedTags={['database', 'mysql', 'planetscale', 'migrations', 'developer-tools']} />
</BaseLayout>
