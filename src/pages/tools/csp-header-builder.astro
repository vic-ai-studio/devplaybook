---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CspHeaderBuilder from '../../components/CspHeaderBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a Content Security Policy (CSP)?",
    answer: "CSP is an HTTP response header that tells browsers which sources of content (scripts, styles, images, fonts) are allowed to load on a page. It's one of the most effective defenses against Cross-Site Scripting (XSS) and data injection attacks. By whitelisting trusted sources, you prevent injected malicious scripts from executing."
  },
  {
    question: "What does default-src do?",
    answer: "default-src is the fallback directive — it applies to any fetch directive that isn't explicitly set. If you set default-src 'self', then script-src, style-src, img-src, etc. all default to 'self' unless overridden. Always set default-src as a safe baseline before adding more permissive rules for specific directives."
  },
  {
    question: "Why is 'unsafe-inline' risky?",
    answer: "'unsafe-inline' allows inline scripts and styles (<script>...</script> or style attributes). This defeats the main protection of CSP because XSS injected as inline scripts would execute. For scripts, use nonces (script-src 'nonce-{random}') or hashes (script-src 'sha256-{hash}') instead. For styles, consider moving inline styles to external files."
  },
  {
    question: "What is the difference between frame-src and frame-ancestors?",
    answer: "frame-src controls which sources your page can load in iframes. frame-ancestors controls which external sites can embed your page in an iframe — it's a modern replacement for the X-Frame-Options header. To prevent clickjacking, set frame-ancestors 'none' (no embedding) or frame-ancestors 'self' (same origin only)."
  },
  {
    question: "How do I deploy CSP without breaking my site?",
    answer: "Use Content-Security-Policy-Report-Only first — same header format, but violations are only reported (via report-uri) without blocking content. Set report-uri to a logging endpoint, check the violation reports, adjust your policy, then switch to Content-Security-Policy. Many services like Report URI, Sentry, and Datadog can receive CSP reports."
  },
  {
    question: "What is upgrade-insecure-requests?",
    answer: "This directive tells browsers to automatically upgrade all HTTP requests to HTTPS before sending them. It's useful when migrating a site from HTTP to HTTPS — it fixes mixed content issues without manually updating every resource URL. It does NOT affect the page URL itself, only sub-resource requests (images, scripts, styles, etc.)."
  },
];
---

<BaseLayout
  title="CSP Header Builder — Content Security Policy Generator"
  description="Build a Content Security Policy (CSP) header visually. Toggle directives, set allowed sources, and get a ready-to-use CSP header string with nginx and Apache config snippets. Free, no signup."
  tool="CSP Generator, Content Security Policy Builder, CSP Header Generator, CSP Online Tool, XSS Protection Header"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "CSP Header Builder",
    "url": "https://devplaybook.cc/tools/csp-header-builder",
    "description": "Build Content Security Policy headers visually. Toggle directives, set sources, generate nginx and Apache config snippets.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">CSP Header Builder</h1>
  <p class="text-text-muted mb-4">
    Build a <strong>Content Security Policy</strong> header visually. Toggle directives, set allowed sources per directive,
    and get a ready-to-use CSP string with nginx and Apache config snippets.
    CSP is the most effective defense against XSS attacks.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 13 CSP directives</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> nginx + Apache snippets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> report-uri support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <CspHeaderBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CSP Header Builder" relatedTags={['security', 'http-headers', 'xss', 'web-security', 'devops']} />
</BaseLayout>
