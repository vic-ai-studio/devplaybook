---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Helm Chart Scaffolder — Generate Kubernetes Helm Chart Files"
  description="Generate Helm chart scaffolding for Kubernetes applications. Configure chart metadata, deployment specs, service, ingress, and configmap templates. Get the complete file structure with Chart.yaml, values.yaml, and templates. Runs in your browser."
  tool="Helm chart generator, Helm scaffolder, Kubernetes Helm, Chart.yaml, values.yaml, Helm templates, k8s deployment, Helm chart creator, cloud-native, DevOps"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Helm Chart Scaffolder",
    "url": "https://devplaybook.cc/tools/helm-chart-scaffolder",
    "description": "Generate Helm chart scaffolding for Kubernetes applications. Configure chart metadata, deployment specs, service, ingress, and configmap templates. Get the complete file structure with Chart.yaml, values.yaml, and templates.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Helm Chart Scaffolder</h1>
  <p class="text-text-muted mb-4">Generate a complete Helm chart scaffold for your Kubernetes application. Configure chart metadata, deployment specs, and which templates to include — then copy each file individually from the tab viewer.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Chart.yaml + values.yaml</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Deployment, Service, Ingress, ConfigMap templates</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Tab-based file viewer</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs entirely in your browser</span>
  </div>

  <!-- Chart Metadata -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-6">
    <h2 class="text-sm font-semibold mb-3 text-text-muted uppercase tracking-wide">Chart Metadata</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium mb-2">Chart Name <span class="text-red-400">*</span></label>
        <input id="chart-name" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="my-app" value="my-app" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Description</label>
        <input id="chart-description" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="A Helm chart for my application" value="A Helm chart for my application" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Chart Version</label>
        <input id="chart-version" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="0.1.0" value="0.1.0" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">App Version</label>
        <input id="app-version" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="1.0.0" value="1.0.0" />
      </div>
    </div>
  </div>

  <!-- Container Config -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-6">
    <h2 class="text-sm font-semibold mb-3 text-text-muted uppercase tracking-wide">Container Configuration</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium mb-2">Image Repository</label>
        <input id="image-repo" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="nginx" value="nginx" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Image Tag</label>
        <input id="image-tag" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="latest" value="latest" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Container Port</label>
        <input id="container-port" type="number" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="80" value="80" min="1" max="65535" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Replica Count</label>
        <input id="replica-count" type="number" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="2" value="2" min="1" max="99" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">CPU Request</label>
        <input id="cpu-request" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="100m" value="100m" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Memory Request</label>
        <input id="memory-request" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="128Mi" value="128Mi" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">CPU Limit</label>
        <input id="cpu-limit" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="500m" value="500m" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Memory Limit</label>
        <input id="memory-limit" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="256Mi" value="256Mi" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Service Type</label>
        <select id="service-type" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
          <option value="ClusterIP" selected>ClusterIP</option>
          <option value="NodePort">NodePort</option>
          <option value="LoadBalancer">LoadBalancer</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Templates to include -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-6">
    <h2 class="text-sm font-semibold mb-3 text-text-muted uppercase tracking-wide">Templates to Include</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      <label class="flex items-center gap-3 cursor-pointer p-3 border border-border rounded-lg hover:border-primary transition-colors">
        <input type="checkbox" id="tpl-deployment" checked class="w-4 h-4 accent-primary" />
        <div>
          <div class="text-sm font-medium">Deployment</div>
          <div class="text-xs text-text-muted">deployment.yaml</div>
        </div>
      </label>
      <label class="flex items-center gap-3 cursor-pointer p-3 border border-border rounded-lg hover:border-primary transition-colors">
        <input type="checkbox" id="tpl-service" checked class="w-4 h-4 accent-primary" />
        <div>
          <div class="text-sm font-medium">Service</div>
          <div class="text-xs text-text-muted">service.yaml</div>
        </div>
      </label>
      <label class="flex items-center gap-3 cursor-pointer p-3 border border-border rounded-lg hover:border-primary transition-colors">
        <input type="checkbox" id="tpl-ingress" class="w-4 h-4 accent-primary" />
        <div>
          <div class="text-sm font-medium">Ingress</div>
          <div class="text-xs text-text-muted">ingress.yaml</div>
        </div>
      </label>
      <label class="flex items-center gap-3 cursor-pointer p-3 border border-border rounded-lg hover:border-primary transition-colors">
        <input type="checkbox" id="tpl-configmap" class="w-4 h-4 accent-primary" />
        <div>
          <div class="text-sm font-medium">ConfigMap</div>
          <div class="text-xs text-text-muted">configmap.yaml</div>
        </div>
      </label>
      <label class="flex items-center gap-3 cursor-pointer p-3 border border-border rounded-lg hover:border-primary transition-colors">
        <input type="checkbox" id="tpl-serviceaccount" class="w-4 h-4 accent-primary" />
        <div>
          <div class="text-sm font-medium">ServiceAccount</div>
          <div class="text-xs text-text-muted">serviceaccount.yaml</div>
        </div>
      </label>
      <label class="flex items-center gap-3 cursor-pointer p-3 border border-border rounded-lg hover:border-primary transition-colors">
        <input type="checkbox" id="tpl-hpa" class="w-4 h-4 accent-primary" />
        <div>
          <div class="text-sm font-medium">HPA</div>
          <div class="text-xs text-text-muted">hpa.yaml</div>
        </div>
      </label>
    </div>
  </div>

  <!-- Ingress config (shown when ingress checked) -->
  <div id="ingress-config" class="bg-bg-card border border-border rounded-lg p-4 mb-6 hidden">
    <h2 class="text-sm font-semibold mb-3 text-text-muted uppercase tracking-wide">Ingress Configuration</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium mb-2">Ingress Host</label>
        <input id="ingress-host" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="myapp.example.com" value="myapp.example.com" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Ingress Class Name <span class="text-text-muted font-normal">(optional)</span></label>
        <input id="ingress-class" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="nginx" value="nginx" />
      </div>
      <div class="flex items-center gap-3">
        <input type="checkbox" id="ingress-tls" class="w-4 h-4 accent-primary" />
        <label for="ingress-tls" class="text-sm font-medium cursor-pointer">Enable TLS</label>
      </div>
    </div>
  </div>

  <div class="flex gap-3 mb-6 flex-wrap">
    <button id="btn-generate" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Generate Helm Chart</button>
    <button id="btn-clear" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Reset to Defaults</button>
  </div>

  <!-- Output: file tab viewer -->
  <div id="output-section" class="hidden">
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-lg font-semibold">Generated Files</h2>
        <div id="file-tree-badge" class="text-xs text-text-muted font-mono"></div>
      </div>

      <!-- File tabs -->
      <div id="file-tabs" class="flex gap-1 mb-4 border-b border-border flex-wrap"></div>

      <!-- File panels -->
      <div id="file-panels"></div>
    </div>
  </div>

  <ToolPageCta />
</BaseLayout>

<script>
// Show/hide ingress config panel
document.getElementById('tpl-ingress')?.addEventListener('change', (e) => {
  const panel = document.getElementById('ingress-config');
  if (panel) panel.classList.toggle('hidden', !(e.target as HTMLInputElement).checked);
});

document.getElementById('btn-clear')?.addEventListener('click', () => {
  (document.getElementById('chart-name') as HTMLInputElement).value = 'my-app';
  (document.getElementById('chart-description') as HTMLInputElement).value = 'A Helm chart for my application';
  (document.getElementById('chart-version') as HTMLInputElement).value = '0.1.0';
  (document.getElementById('app-version') as HTMLInputElement).value = '1.0.0';
  (document.getElementById('image-repo') as HTMLInputElement).value = 'nginx';
  (document.getElementById('image-tag') as HTMLInputElement).value = 'latest';
  (document.getElementById('container-port') as HTMLInputElement).value = '80';
  (document.getElementById('replica-count') as HTMLInputElement).value = '2';
  (document.getElementById('cpu-request') as HTMLInputElement).value = '100m';
  (document.getElementById('memory-request') as HTMLInputElement).value = '128Mi';
  (document.getElementById('cpu-limit') as HTMLInputElement).value = '500m';
  (document.getElementById('memory-limit') as HTMLInputElement).value = '256Mi';
  (document.getElementById('service-type') as HTMLSelectElement).value = 'ClusterIP';
  (document.getElementById('tpl-deployment') as HTMLInputElement).checked = true;
  (document.getElementById('tpl-service') as HTMLInputElement).checked = true;
  (document.getElementById('tpl-ingress') as HTMLInputElement).checked = false;
  (document.getElementById('tpl-configmap') as HTMLInputElement).checked = false;
  (document.getElementById('tpl-serviceaccount') as HTMLInputElement).checked = false;
  (document.getElementById('tpl-hpa') as HTMLInputElement).checked = false;
  document.getElementById('ingress-config')?.classList.add('hidden');
  document.getElementById('output-section')?.classList.add('hidden');
});

function val(id: string): string {
  return ((document.getElementById(id) as HTMLInputElement)?.value || '').trim();
}
function checked(id: string): boolean {
  return !!(document.getElementById(id) as HTMLInputElement)?.checked;
}

function generateFiles(): Record<string, string> {
  const chartName = val('chart-name') || 'my-app';
  const safeName = chartName.replace(/[^a-zA-Z0-9\-]/g, '-').toLowerCase();
  const description = val('chart-description') || 'A Helm chart for ' + safeName;
  const chartVersion = val('chart-version') || '0.1.0';
  const appVersion = val('app-version') || '1.0.0';
  const imageRepo = val('image-repo') || 'nginx';
  const imageTag = val('image-tag') || 'latest';
  const port = parseInt(val('container-port') || '80', 10) || 80;
  const replicas = parseInt(val('replica-count') || '2', 10) || 2;
  const cpuReq = val('cpu-request') || '100m';
  const memReq = val('memory-request') || '128Mi';
  const cpuLim = val('cpu-limit') || '500m';
  const memLim = val('memory-limit') || '256Mi';
  const svcType = val('service-type') || 'ClusterIP';
  const ingressHost = val('ingress-host') || 'myapp.example.com';
  const ingressClass = val('ingress-class') || 'nginx';
  const ingressTls = checked('ingress-tls');

  const inclDeployment = checked('tpl-deployment');
  const inclService = checked('tpl-service');
  const inclIngress = checked('tpl-ingress');
  const inclConfigmap = checked('tpl-configmap');
  const inclServiceAccount = checked('tpl-serviceaccount');
  const inclHpa = checked('tpl-hpa');

  const files: Record<string, string> = {};

  // Chart.yaml
  files['Chart.yaml'] = `apiVersion: v2
name: ${safeName}
description: ${description}
type: application
version: ${chartVersion}
appVersion: "${appVersion}"
`;

  // values.yaml
  let values = `# Default values for ${safeName}.
# This is a YAML-formatted file.
# Declare variables to be passed into your templates.

replicaCount: ${replicas}

image:
  repository: ${imageRepo}
  pullPolicy: IfNotPresent
  tag: "${imageTag}"

imagePullSecrets: []
nameOverride: ""
fullnameOverride: ""

`;
  if (inclServiceAccount) {
    values += `serviceAccount:
  # Specifies whether a service account should be created
  create: true
  # Annotations to add to the service account
  annotations: {}
  # The name of the service account to use.
  # If not set and create is true, a name is generated using the fullname template
  name: ""

`;
  }
  values += `podAnnotations: {}
podSecurityContext: {}
securityContext: {}

service:
  type: ${svcType}
  port: ${port}

`;
  if (inclIngress) {
    values += `ingress:
  enabled: true
  className: "${ingressClass}"
  annotations: {}
  hosts:
    - host: ${ingressHost}
      paths:
        - path: /
          pathType: Prefix
  tls:${ingressTls ? `
    - secretName: ${safeName}-tls
      hosts:
        - ${ingressHost}` : ' []'}

`;
  }
  values += `resources:
  limits:
    cpu: ${cpuLim}
    memory: ${memLim}
  requests:
    cpu: ${cpuReq}
    memory: ${memReq}

`;
  if (inclHpa) {
    values += `autoscaling:
  enabled: true
  minReplicas: ${replicas}
  maxReplicas: ${Math.max(replicas * 2, 5)}
  targetCPUUtilizationPercentage: 80
  # targetMemoryUtilizationPercentage: 80

`;
  }
  values += `nodeSelector: {}
tolerations: []
affinity: {}
`;
  files['values.yaml'] = values;

  // helpers
  files['templates/_helpers.tpl'] = `{{/*
Expand the name of the chart.
*/}}
{{- define "${safeName}.name" -}}
{{- default .Chart.Name .Values.nameOverride | trunc 63 | trimSuffix "-" }}
{{- end }}

{{/*
Create a default fully qualified app name.
*/}}
{{- define "${safeName}.fullname" -}}
{{- if .Values.fullnameOverride }}
{{- .Values.fullnameOverride | trunc 63 | trimSuffix "-" }}
{{- else }}
{{- $name := default .Chart.Name .Values.nameOverride }}
{{- if contains $name .Release.Name }}
{{- .Release.Name | trunc 63 | trimSuffix "-" }}
{{- else }}
{{- printf "%s-%s" .Release.Name $name | trunc 63 | trimSuffix "-" }}
{{- end }}
{{- end }}
{{- end }}

{{/*
Create chart label.
*/}}
{{- define "${safeName}.chart" -}}
{{- printf "%s-%s" .Chart.Name .Chart.Version | replace "+" "_" | trunc 63 | trimSuffix "-" }}
{{- end }}

{{/*
Common labels.
*/}}
{{- define "${safeName}.labels" -}}
helm.sh/chart: {{ include "${safeName}.chart" . }}
{{ include "${safeName}.selectorLabels" . }}
{{- if .Chart.AppVersion }}
app.kubernetes.io/version: {{ .Chart.AppVersion | quote }}
{{- end }}
app.kubernetes.io/managed-by: {{ .Release.Service }}
{{- end }}

{{/*
Selector labels.
*/}}
{{- define "${safeName}.selectorLabels" -}}
app.kubernetes.io/name: {{ include "${safeName}.name" . }}
app.kubernetes.io/instance: {{ .Release.Name }}
{{- end }}
${inclServiceAccount ? `
{{/*
Create the name of the service account to use.
*/}}
{{- define "${safeName}.serviceAccountName" -}}
{{- if .Values.serviceAccount.create }}
{{- default (include "${safeName}.fullname" .) .Values.serviceAccount.name }}
{{- else }}
{{- default "default" .Values.serviceAccount.name }}
{{- end }}
{{- end }}` : ''}
`;

  // Deployment
  if (inclDeployment) {
    files['templates/deployment.yaml'] = `apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ include "${safeName}.fullname" . }}
  labels:
    {{- include "${safeName}.labels" . | nindent 4 }}
spec:
  {{- if not .Values.autoscaling${inclHpa ? '' : ' | default false'} }}
  replicas: {{ .Values.replicaCount }}
  {{- end }}
  selector:
    matchLabels:
      {{- include "${safeName}.selectorLabels" . | nindent 6 }}
  template:
    metadata:
      {{- with .Values.podAnnotations }}
      annotations:
        {{- toYaml . | nindent 8 }}
      {{- end }}
      labels:
        {{- include "${safeName}.selectorLabels" . | nindent 8 }}
    spec:
      {{- with .Values.imagePullSecrets }}
      imagePullSecrets:
        {{- toYaml . | nindent 8 }}
      {{- end }}${inclServiceAccount ? `
      serviceAccountName: {{ include "${safeName}.serviceAccountName" . }}` : ''}
      securityContext:
        {{- toYaml .Values.podSecurityContext | nindent 8 }}
      containers:
        - name: {{ .Chart.Name }}
          securityContext:
            {{- toYaml .Values.securityContext | nindent 12 }}
          image: "{{ .Values.image.repository }}:{{ .Values.image.tag | default .Chart.AppVersion }}"
          imagePullPolicy: {{ .Values.image.pullPolicy }}
          ports:
            - name: http
              containerPort: ${port}
              protocol: TCP
          livenessProbe:
            httpGet:
              path: /
              port: http
          readinessProbe:
            httpGet:
              path: /
              port: http
          resources:
            {{- toYaml .Values.resources | nindent 12 }}
      {{- with .Values.nodeSelector }}
      nodeSelector:
        {{- toYaml . | nindent 8 }}
      {{- end }}
      {{- with .Values.affinity }}
      affinity:
        {{- toYaml . | nindent 8 }}
      {{- end }}
      {{- with .Values.tolerations }}
      tolerations:
        {{- toYaml . | nindent 8 }}
      {{- end }}
`;
  }

  // Service
  if (inclService) {
    files['templates/service.yaml'] = `apiVersion: v1
kind: Service
metadata:
  name: {{ include "${safeName}.fullname" . }}
  labels:
    {{- include "${safeName}.labels" . | nindent 4 }}
spec:
  type: {{ .Values.service.type }}
  ports:
    - port: {{ .Values.service.port }}
      targetPort: http
      protocol: TCP
      name: http
  selector:
    {{- include "${safeName}.selectorLabels" . | nindent 4 }}
`;
  }

  // Ingress
  if (inclIngress) {
    files['templates/ingress.yaml'] = `{{- if .Values.ingress.enabled -}}
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{ include "${safeName}.fullname" . }}
  labels:
    {{- include "${safeName}.labels" . | nindent 4 }}
  {{- with .Values.ingress.annotations }}
  annotations:
    {{- toYaml . | nindent 4 }}
  {{- end }}
spec:
  {{- if .Values.ingress.className }}
  ingressClassName: {{ .Values.ingress.className }}
  {{- end }}
  {{- if .Values.ingress.tls }}
  tls:
    {{- range .Values.ingress.tls }}
    - hosts:
        {{- range .hosts }}
        - {{ . | quote }}
        {{- end }}
      secretName: {{ .secretName }}
    {{- end }}
  {{- end }}
  rules:
    {{- range .Values.ingress.hosts }}
    - host: {{ .host | quote }}
      http:
        paths:
          {{- range .paths }}
          - path: {{ .path }}
            pathType: {{ .pathType }}
            backend:
              service:
                name: {{ include "${safeName}.fullname" $ }}
                port:
                  number: {{ $.Values.service.port }}
          {{- end }}
    {{- end }}
{{- end }}
`;
  }

  // ConfigMap
  if (inclConfigmap) {
    files['templates/configmap.yaml'] = `apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ include "${safeName}.fullname" . }}
  labels:
    {{- include "${safeName}.labels" . | nindent 4 }}
data:
  # Add your configuration key-value pairs here
  APP_ENV: "production"
  APP_PORT: "${port}"
`;
  }

  // ServiceAccount
  if (inclServiceAccount) {
    files['templates/serviceaccount.yaml'] = `{{- if .Values.serviceAccount.create -}}
apiVersion: v1
kind: ServiceAccount
metadata:
  name: {{ include "${safeName}.serviceAccountName" . }}
  labels:
    {{- include "${safeName}.labels" . | nindent 4 }}
  {{- with .Values.serviceAccount.annotations }}
  annotations:
    {{- toYaml . | nindent 4 }}
  {{- end }}
{{- end }}
`;
  }

  // HPA
  if (inclHpa) {
    files['templates/hpa.yaml'] = `{{- if .Values.autoscaling.enabled }}
apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
  name: {{ include "${safeName}.fullname" . }}
  labels:
    {{- include "${safeName}.labels" . | nindent 4 }}
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: {{ include "${safeName}.fullname" . }}
  minReplicas: {{ .Values.autoscaling.minReplicas }}
  maxReplicas: {{ .Values.autoscaling.maxReplicas }}
  metrics:
    {{- if .Values.autoscaling.targetCPUUtilizationPercentage }}
    - type: Resource
      resource:
        name: cpu
        target:
          type: Utilization
          averageUtilization: {{ .Values.autoscaling.targetCPUUtilizationPercentage }}
    {{- end }}
    {{- if .Values.autoscaling.targetMemoryUtilizationPercentage }}
    - type: Resource
      resource:
        name: memory
        target:
          type: Utilization
          averageUtilization: {{ .Values.autoscaling.targetMemoryUtilizationPercentage }}
    {{- end }}
{{- end }}
`;
  }

  // NOTES.txt
  files['templates/NOTES.txt'] = `1. Get the application URL by running these commands:
{{- if .Values.ingress.enabled }}
  http{{ if $.Values.ingress.tls }}s{{ end }}://{{ (index .Values.ingress.hosts 0).host }}{{ (index (index .Values.ingress.hosts 0).paths 0).path }}
{{- else if contains "NodePort" .Values.service.type }}
  export NODE_PORT=$(kubectl get --namespace {{ .Release.Namespace }} -o jsonpath="{.spec.ports[0].nodePort}" services {{ include "${safeName}.fullname" . }})
  export NODE_IP=$(kubectl get nodes --namespace {{ .Release.Namespace }} -o jsonpath="{.items[0].status.addresses[0].address}")
  echo http://$NODE_IP:$NODE_PORT
{{- else if contains "LoadBalancer" .Values.service.type }}
     NOTE: It may take a few minutes for the LoadBalancer IP to be available.
           You can watch its status by running 'kubectl get --namespace {{ .Release.Namespace }} svc -w {{ include "${safeName}.fullname" . }}'
  export SERVICE_IP=$(kubectl get svc --namespace {{ .Release.Namespace }} {{ include "${safeName}.fullname" . }} --template "{{"{{ range (index .status.loadBalancer.ingress 0) }}{{.}}{{ end }}"}}")
  echo http://$SERVICE_IP:{{ .Values.service.port }}
{{- else if contains "ClusterIP" .Values.service.type }}
  export POD_NAME=$(kubectl get pods --namespace {{ .Release.Namespace }} -l "app.kubernetes.io/name={{ include "${safeName}.name" . }},app.kubernetes.io/instance={{ .Release.Name }}" -o jsonpath="{.items[0].metadata.name}")
  export CONTAINER_PORT=$(kubectl get pod --namespace {{ .Release.Namespace }} $POD_NAME -o jsonpath="{.spec.containers[0].ports[0].containerPort}")
  echo "Visit http://127.0.0.1:8080 to use your application"
  kubectl --namespace {{ .Release.Namespace }} port-forward $POD_NAME 8080:$CONTAINER_PORT
{{- end }}
`;

  return files;
}

let currentFile = '';

function renderOutput(files: Record<string, string>) {
  const tabsEl = document.getElementById('file-tabs');
  const panelsEl = document.getElementById('file-panels');
  const treeEl = document.getElementById('file-tree-badge');
  if (!tabsEl || !panelsEl) return;

  const fileNames = Object.keys(files);
  if (treeEl) treeEl.textContent = `${fileNames.length} files`;

  tabsEl.innerHTML = '';
  panelsEl.innerHTML = '';

  if (!currentFile || !files[currentFile]) currentFile = fileNames[0];

  fileNames.forEach(name => {
    const isActive = name === currentFile;
    const shortName = name.replace('templates/', '');
    const btn = document.createElement('button');
    btn.className = `file-tab px-3 py-2 text-xs font-mono border-b-2 transition-colors ${isActive ? 'border-primary text-primary' : 'border-transparent text-text-muted hover:text-foreground'}`;
    btn.dataset.file = name;
    btn.textContent = shortName;
    btn.addEventListener('click', () => {
      currentFile = name;
      renderOutput(files);
    });
    tabsEl.appendChild(btn);

    const panel = document.createElement('div');
    panel.className = `file-panel ${isActive ? '' : 'hidden'}`;
    panel.dataset.file = name;
    panel.innerHTML = `
      <div class="flex justify-end mb-2">
        <button class="btn-copy-file px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-file="${name}">Copy</button>
      </div>
      <pre class="font-mono text-sm whitespace-pre text-green-300 overflow-x-auto max-h-[500px] overflow-y-auto">&#36;{escHtml(files[name])}</pre>
    `;
    panelsEl.appendChild(panel);
  });

  panelsEl.querySelectorAll('.btn-copy-file').forEach(btn => {
    btn.addEventListener('click', () => {
      const fname = (btn as HTMLElement).dataset.file || '';
      navigator.clipboard.writeText(files[fname] || '').then(() => {
        btn.textContent = 'Copied!';
        setTimeout(() => btn.textContent = 'Copy', 2000);
      });
    });
  });
}

function escHtml(str: string): string {
  return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

document.getElementById('btn-generate')?.addEventListener('click', () => {
  const chartName = (document.getElementById('chart-name') as HTMLInputElement)?.value?.trim();
  if (!chartName) { alert('Chart name is required.'); return; }

  const files = generateFiles();
  currentFile = 'Chart.yaml';

  const section = document.getElementById('output-section');
  section?.classList.remove('hidden');
  renderOutput(files);
  setTimeout(() => section?.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
});
</script>
