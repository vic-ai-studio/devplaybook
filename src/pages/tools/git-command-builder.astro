---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GitCommandBuilder from '../../components/GitCommandBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How does the Git Command Builder work?", answer: "Select a Git operation (commit, push, pull, merge, rebase, stash, etc.) from the dropdown, then toggle the flags and options you need. The tool assembles the full CLI command in real time so you can copy and paste it into your terminal." },
  { question: "Does this tool cover advanced Git commands?", answer: "Yes. It supports common operations like commit, push, pull, and branch as well as advanced ones like interactive rebase, cherry-pick, stash with untracked files, force-push with lease, and more — each with the most-used flags." },
  { question: "Is this a Git cheat sheet replacement?", answer: "It complements a cheat sheet. Instead of memorizing flag combinations, you build the command visually and learn the flags as you go. Great for beginners and experienced developers who use less-common options." },
  { question: "Can I use this offline?", answer: "Once the page loads, the tool runs entirely in your browser with no server calls. You can use it offline or on a restricted network — your commands never leave your machine." },
  { question: "What if the flag I need isn't listed?", answer: "The builder covers the most common flags for each command. For rarely-used options, copy the generated base command and append additional flags manually in your terminal." },
];
---

<BaseLayout
  title="Git Command Builder — Visual Git CLI Generator Free Online"
  description="Build complex Git commands visually step by step. Select from commit, push, pull, branch, merge, rebase, stash, cherry-pick and more. Toggle flags, copy the generated CLI command instantly. Free online tool — runs in your browser, no signup."
  tool="Git Command Builder, Git CLI Generator, Git Command Cheat Sheet, Git Visual Tool, Git Workflow Helper, Git Flags Reference"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Git Command Builder</h1>
  <p class="text-text-muted mb-4">Build any Git command visually — select an operation, toggle the flags you need, and copy the complete CLI command. Supports commit, push, pull, merge, rebase, stash, cherry-pick, and more with all common options.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <GitCommandBuilder client:load />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Git Command Builder" relatedTags={['git-hooks', 'automation', 'cli', 'devops']} />
</BaseLayout>
