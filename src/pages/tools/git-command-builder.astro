---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GitCommandBuilder from '../../components/GitCommandBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout title="Git Command Builder" description="Build complex Git commands visually step by step. Select from commit, push, pull, branch, merge, rebase, stash, and more. Generate accurate Git CLI commands with all common options. Free online tool." tool="Git Command Builder, Git CLI Generator, Git Command Cheat Sheet, Git Visual Tool, Git Workflow Helper"
  <h1 class="text-3xl font-bold mb-2">Git Command Builder</h1>
  <p class="text-text-muted mb-8">Select a Git command and build it visually with all available options.</p>
  <GitCommandBuilder client:load />
  <ToolPageCta currentTool="Git Command Builder" relatedTags={['git-hooks', 'automation', 'cli', 'devops']} />
</BaseLayout>
