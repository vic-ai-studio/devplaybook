---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DbSchemaVisualizer from '../../components/DbSchemaVisualizer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What SQL syntax does the schema visualizer support?",
    answer: "The visualizer parses standard SQL CREATE TABLE statements including column names, data types (VARCHAR, INTEGER, TEXT, TIMESTAMP, BOOLEAN, etc.), PRIMARY KEY, NOT NULL, UNIQUE, DEFAULT, and REFERENCES (foreign key) constraints. It handles both inline column constraints and table-level constraint definitions."
  },
  {
    question: "Can I paste multiple tables at once?",
    answer: "Yes. Paste multiple CREATE TABLE statements separated by semicolons and the visualizer will render all tables simultaneously in a grid layout, making it easy to see your full schema at once."
  },
  {
    question: "Does it show foreign key relationships?",
    answer: "Yes. When a column uses REFERENCES table(column) or a table-level FOREIGN KEY constraint, the visualizer annotates that column with a FK badge and shows the referenced table and column. This makes it easy to trace relationships across your schema."
  },
  {
    question: "Can I use this with PostgreSQL, MySQL, and SQLite schemas?",
    answer: "Yes. The parser handles standard ANSI SQL syntax compatible with PostgreSQL, MySQL, SQLite, and most other relational databases. Minor syntax differences (like PostgreSQL SERIAL vs MySQL AUTO_INCREMENT) are handled gracefully — the visualizer extracts the column structure regardless of dialect-specific keywords."
  },
  {
    question: "Is my schema data sent anywhere?",
    answer: "No. All parsing and rendering happens entirely in your browser using JavaScript. Your schema definitions never leave your machine and are never stored or logged anywhere."
  },
];
---

<BaseLayout
  title="Database Schema Visualizer — Paste SQL CREATE TABLE, Get ERD Cards"
  description="Paste SQL CREATE TABLE statements and get an instant visual ERD-style schema overview. Shows tables, columns, data types, primary keys, and foreign key relationships. Free, runs in your browser."
  tool="Database Schema Visualizer, ERD generator, SQL schema viewer, CREATE TABLE visualizer, database diagram tool"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Database Schema Visualizer",
    "url": "https://devplaybook.cc/tools/db-schema-visualizer",
    "description": "Paste SQL CREATE TABLE statements to get an instant visual schema overview with tables, columns, types, and foreign key relationships.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Database Schema Visualizer</h1>
  <p class="text-text-muted mb-4">
    Paste SQL <code class="font-mono bg-surface px-1 rounded text-sm">CREATE TABLE</code> statements and instantly see a visual ERD-style overview of your schema — tables, columns, data types, primary keys, and foreign key relationships. Runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> PK & FK relationship mapping</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multi-table support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <DbSchemaVisualizer client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Database Schema Visualizer" relatedTags={['database', 'sql', 'schema', 'erd', 'postgresql', 'mysql']} />
</BaseLayout>
