---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const installExample = `# Install Knip as a dev dependency
npm add -D knip

# Or run without installing
npx knip

# Auto-fix issues (removes unused exports, unlinks files, removes deps)
knip --fix

# Use the compact reporter for terse output
knip --reporter compact

# Check only specific issue types
knip --include files,dependencies

# Run in watch mode during development
knip --watch`;

const basicExample = `// knip.json — minimal config at the project root
{
  "entry": ["src/index.ts", "src/cli.ts"],
  "project": ["src/**/*.ts"]
}

// Then run:
// npx knip
//
// Sample output:
// Unused files (2)
//   src/utils/legacy-helper.ts
//   src/types/old-types.ts
//
// Unused exports (3)
//   src/utils/format.ts: formatDate, formatTime
//   src/api/client.ts: legacyFetch
//
// Unlisted dependencies (1)
//   lodash (used in src/utils/sort.ts but not in package.json)
//
// Unused devDependencies (2)
//   @types/node, ts-node`;

const monorepoExample = `// knip.json — monorepo workspace configuration
{
  "workspaces": {
    ".": {
      "entry": ["scripts/*.ts"],
      "project": ["scripts/**/*.ts"]
    },
    "packages/ui": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/api": {
      "entry": ["src/index.ts", "src/routes/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/web": {
      "entry": ["src/app/**/*.{ts,tsx}", "src/pages/**/*.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  }
}`;

const pluginExample = `// knip.json — using plugins for popular frameworks
{
  "entry": ["src/index.ts"],
  "project": ["src/**/*.ts"],
  // Knip auto-detects and activates plugins for installed tools.
  // You can override plugin config explicitly:
  "next": {
    "entry": ["src/app/**/*.{ts,tsx}", "src/pages/**/*.{ts,tsx}"]
  },
  "vitest": {
    "entry": ["src/**/*.test.ts", "src/**/*.spec.ts"]
  },
  "eslint": {
    "config": [".eslintrc.json"]
  }
}

// Knip ships plugins for 50+ tools including:
// Next.js, Remix, Astro, SvelteKit, Vite, Vitest, Jest,
// ESLint, Prettier, Tailwind CSS, Storybook, Playwright,
// TypeScript, tsup, Rollup, Webpack, esbuild, and more.`;

const ciExample = `# .github/workflows/knip.yml
name: Knip — Dead Code Check

on:
  pull_request:
  push:
    branches: [main]

jobs:
  knip:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: npm
      - run: npm ci
      - name: Run Knip
        run: npx knip --reporter compact`;

const faq = [
  {
    question: "What is Knip?",
    answer: "Knip is an open-source static analysis tool for JavaScript and TypeScript projects that finds unused files, exports, and dependencies. It reads your project's entry points, traces the dependency graph, and reports anything that is never imported or used. This helps you reduce bundle size, lower maintenance overhead, and keep codebases clean as they evolve."
  },
  {
    question: "What types of unused code does Knip find?",
    answer: "Knip reports: unused files (never imported anywhere), unused exports (exported symbols that are never imported by another module), unused types and interfaces, unlisted dependencies (used in code but missing from package.json), unused dependencies (listed in package.json but never imported), unused devDependencies, and exports that are only used in test files or type-only positions. Each category is reported separately so you can address them incrementally."
  },
  {
    question: "How does Knip handle monorepos?",
    answer: "Knip has first-class monorepo support via the workspaces key in knip.json. You define entry and project globs per workspace package, and Knip analyzes each package in context — understanding that a symbol exported from packages/ui may be consumed by apps/web. It correctly distinguishes between truly unused exports and cross-workspace references, so you do not get false positives for shared packages."
  },
  {
    question: "Can Knip auto-fix issues?",
    answer: "Yes. Running knip --fix applies safe automated fixes: it removes unused export keywords from source files, deletes files that are entirely unused, and removes unused entries from package.json dependencies and devDependencies. The fix mode is conservative and does not delete files that might have side effects. Always review the changes in a diff before committing — treat --fix as a productivity boost, not a blind autopilot."
  },
  {
    question: "How do I configure Knip for my project?",
    answer: "Create a knip.json (or knip.ts) at the project root with entry and project glob patterns. entry files are the known starting points of your app (index.ts, CLI entry points, page routes). project defines all source files Knip should consider. Knip auto-detects 50+ plugins based on your installed tools (Next.js, Vite, ESLint, etc.) and extends the entry pattern automatically. For most projects a minimal config — just entry and project — is enough to start."
  },
  {
    question: "Does Knip support TypeScript?",
    answer: "Yes, TypeScript is a first-class citizen in Knip. It uses the TypeScript compiler API to resolve imports and trace exports, so it correctly understands type-only imports, interface re-exports, declaration merging, and path aliases defined in tsconfig.json. Knip also reports unused TypeScript types and interfaces separately from runtime exports, giving you full visibility into dead TS code."
  },
];
---

<BaseLayout
  title="Knip — Unused Code Detector for JavaScript and TypeScript"
  description="Knip finds unused files, exports, and dependencies in JavaScript and TypeScript projects. Supports monorepos, 50+ framework plugins, and an auto-fix mode to clean up dead code automatically."
  tool="knip, unused code, dead code, javascript, typescript, refactoring, static analysis, dependencies"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Knip — Unused Code Detector for JavaScript and TypeScript",
    "url": "https://devplaybook.cc/tools/knip",
    "description": "Knip finds unused files, exports, and dependencies in JavaScript and TypeScript projects. Supports monorepos, 50+ plugins, and auto-fix.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Knip</h1>
  <p class="text-text-muted mb-6">
    Static analysis tool that finds unused files, exports, and dependencies in JavaScript and
    TypeScript projects. Supports monorepos, auto-detects 50+ frameworks via plugins, and can
    automatically remove dead code with the <code class="bg-bg-card px-1 rounded text-xs">--fix</code> flag.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Unused files &amp; exports</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Unused dependencies</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Monorepo support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 50+ framework plugins</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auto-fix mode</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Zero dependencies</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Knip?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Knip (a Dutch word for "snip" or "cut") is an open-source static analysis tool for JavaScript and TypeScript codebases. It traces your project's dependency graph starting from configured entry points and identifies everything that is never imported or consumed: unused source files, unused exported symbols, and packages listed in <code class="bg-bg-card px-1 rounded text-xs">package.json</code> that are never actually used.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    As projects grow, dead code accumulates silently. Developers rename functions without removing old versions, split files without deleting originals, or install packages that a feature pivot made redundant. Knip surfaces all of this in a single report so you can cut what no longer serves the codebase — reducing bundle size, speeding up builds, and lowering cognitive load for future maintainers.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Unused file detection</strong> — finds source files that are never imported from any entry point in the project graph</li>
    <li><strong>Unused export detection</strong> — reports exported functions, classes, types, and constants that no other module imports</li>
    <li><strong>Dependency auditing</strong> — identifies packages in <code class="bg-bg-card px-1 rounded text-xs">dependencies</code> and <code class="bg-bg-card px-1 rounded text-xs">devDependencies</code> that are never actually used</li>
    <li><strong>Monorepo support</strong> — per-workspace configuration with correct cross-package reference tracking to avoid false positives</li>
    <li><strong>50+ framework plugins</strong> — auto-detects and configures entry points for Next.js, Astro, Vite, Vitest, ESLint, Tailwind CSS, Storybook, and more</li>
    <li><strong>Test-only export reporting</strong> — flags exports consumed only in test files, which may be candidates for removal or internalization</li>
    <li><strong>Auto-fix mode</strong> — removes unused <code class="bg-bg-card px-1 rounded text-xs">export</code> keywords, deletes unused files, and prunes <code class="bg-bg-card px-1 rounded text-xs">package.json</code> entries</li>
    <li><strong>Zero dependencies</strong> — the Knip package itself has no runtime npm dependencies, keeping install fast and supply chain risk low</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Installation</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={installExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Basic Configuration and Output</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Create a <code class="bg-bg-card px-1 rounded text-xs">knip.json</code> at the project root with <code class="bg-bg-card px-1 rounded text-xs">entry</code> (known start files) and <code class="bg-bg-card px-1 rounded text-xs">project</code> (all source files to consider) glob patterns, then run <code class="bg-bg-card px-1 rounded text-xs">npx knip</code>.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={basicExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Monorepo Configuration</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Use the <code class="bg-bg-card px-1 rounded text-xs">workspaces</code> key to configure each package independently. Knip understands cross-workspace imports and will not flag symbols that are consumed by sibling packages.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={monorepoExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Framework Plugins</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Knip ships with plugins for 50+ tools. Plugins are auto-activated based on what is installed in your project. They extend the <code class="bg-bg-card px-1 rounded text-xs">entry</code> patterns so framework-specific files (page routes, config files, test suites) are correctly recognized as entry points rather than reported as unused.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={pluginExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">CI Integration</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Add Knip to your CI pipeline to catch dead code on every pull request. The process exits with a non-zero code when issues are found, blocking merges until the dead code is removed or explicitly ignored.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={ciExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Knip vs ESLint no-unused-vars</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">Knip</th>
          <th class="border border-border px-3 py-2 text-left">ESLint no-unused-vars</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2">Unused files</td><td class="border border-border px-3 py-2 text-green-400">Yes</td><td class="border border-border px-3 py-2">No</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Unused exports (cross-file)</td><td class="border border-border px-3 py-2 text-green-400">Yes</td><td class="border border-border px-3 py-2">No (file-scoped only)</td></tr>
        <tr><td class="border border-border px-3 py-2">Unused npm dependencies</td><td class="border border-border px-3 py-2 text-green-400">Yes</td><td class="border border-border px-3 py-2">No</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Monorepo workspace support</td><td class="border border-border px-3 py-2 text-green-400">Yes</td><td class="border border-border px-3 py-2">No</td></tr>
        <tr><td class="border border-border px-3 py-2">Auto-fix</td><td class="border border-border px-3 py-2 text-green-400">Yes (--fix flag)</td><td class="border border-border px-3 py-2">Partial (remove vars)</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Framework plugins</td><td class="border border-border px-3 py-2 text-green-400">50+ plugins</td><td class="border border-border px-3 py-2">None</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pros and Cons</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-green-400 mb-2">Pros</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✓ Finds dead code ESLint cannot: unused files and cross-file unused exports</li>
        <li>✓ Audits npm dependencies — catches packages you forgot to remove</li>
        <li>✓ 50+ framework plugins auto-activate with zero manual config</li>
        <li>✓ First-class monorepo support with correct cross-workspace resolution</li>
        <li>✓ Zero runtime dependencies — fast install, minimal supply chain risk</li>
        <li>✓ Auto-fix mode automates the cleanup work</li>
      </ul>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-red-400 mb-2">Cons</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✗ First run on a large legacy codebase can produce hundreds of reports</li>
        <li>✗ Requires accurate entry/project config — misconfiguration leads to false positives</li>
        <li>✗ Dynamic imports and runtime reflection can confuse the static analysis</li>
        <li>✗ --fix is conservative; some cleanup still requires manual intervention</li>
        <li>✗ Younger ecosystem than ESLint — fewer community resources</li>
      </ul>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="knip" relatedTags={['unused-code', 'dead-code', 'javascript', 'typescript', 'refactoring', 'ci-cd']} />
</BaseLayout>
