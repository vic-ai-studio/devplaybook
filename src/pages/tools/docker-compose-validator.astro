---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DockerComposeValidator from '../../components/DockerComposeValidator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What does this tool validate?",
    answer: "The validator checks for common docker-compose.yml issues: missing required keys (services, image/build per service), broken depends_on references, hardcoded secrets in environment variables, :latest image tags, privileged port usage, YAML tab characters, and missing restart policies."
  },
  {
    question: "Does it support all Compose file versions?",
    answer: "Yes. The validator works with Compose file format v2 and v3.x. It will warn if you use v1 format (no version key) since that format is deprecated and unsupported by modern Docker Compose V2 (the plugin)."
  },
  {
    question: "Why is :latest a warning?",
    answer: "Using :latest means your container image version can change between pulls, making builds non-reproducible. If the upstream image is updated with a breaking change, your deployment may fail unexpectedly. Pin to a specific version like nginx:1.25 or postgres:15.3 for stability."
  },
  {
    question: "How should I handle secrets instead of hardcoding them?",
    answer: "Use environment variable substitution (${MY_PASSWORD}) and provide values via a .env file or your CI/CD system's secret manager. For production, consider Docker Swarm secrets (docker secret) or external secrets managers like AWS Secrets Manager, Vault, or Kubernetes Secrets."
  },
  {
    question: "Does this tool send my compose file to a server?",
    answer: "No. Validation runs entirely in your browser using JavaScript. Your docker-compose.yml content never leaves your machine. This is especially important since compose files may contain sensitive configuration."
  },
  {
    question: "What is the difference between depends_on and wait-for-it?",
    answer: "depends_on only ensures the dependent container starts before yours — it does NOT wait for the service to be ready (e.g., database accepting connections). For readiness, use a health check with condition: service_healthy in depends_on, or a startup script like wait-for-it.sh."
  },
];
---

<BaseLayout
  title="Docker Compose Validator — Check docker-compose.yml Online"
  description="Paste your docker-compose.yml and validate it instantly. Checks for missing image/build, broken depends_on, hardcoded secrets, :latest tags, privileged ports, and YAML syntax issues. Runs 100% in your browser."
  tool="Docker Compose Validator, docker-compose.yml checker, Docker Compose linter, Docker syntax validator, DevOps tool"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Docker Compose Validator",
    "url": "https://devplaybook.cc/tools/docker-compose-validator",
    "description": "Validate docker-compose.yml files online. Catches common mistakes, hardcoded secrets, and structural errors. Runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Docker Compose Validator</h1>
  <p class="text-text-muted mb-4">
    Paste your <code class="font-mono bg-surface px-1 rounded text-sm">docker-compose.yml</code> and validate it instantly.
    Catches missing <code class="font-mono bg-surface px-1 rounded text-sm">image</code>/<code class="font-mono bg-surface px-1 rounded text-sm">build</code>,
    broken <code class="font-mono bg-surface px-1 rounded text-sm">depends_on</code> references, hardcoded secrets,
    <code class="font-mono bg-surface px-1 rounded text-sm">:latest</code> image tags, and common configuration mistakes.
    Nothing is sent to any server — runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 9 validation checks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Errors, warnings & suggestions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No data leaves your browser</span>
  </div>
  <DockerComposeValidator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Docker Compose Validator" relatedTags={['devops', 'docker', 'containers', 'ci-cd', 'validation']} />
</BaseLayout>
