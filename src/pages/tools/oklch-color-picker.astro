---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OklchColorPicker from '../../components/OklchColorPicker.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is OKLCH?", answer: "OKLCH is a modern CSS color space that is perceptually uniform — equal numeric changes produce equal perceived differences in color. It uses Lightness (0–100%), Chroma (color vividness), and Hue (0–360° angle on the color wheel). It's supported in all modern browsers via the oklch() CSS function." },
  { question: "What is the P3 color space?", answer: "Display P3 is a wide-gamut color space used by modern Apple displays, high-end Android phones, and most new monitors. It can show about 25% more colors than sRGB. When your OKLCH color falls outside sRGB, P3-capable browsers will render the richer version automatically using color(display-p3 ...)." },
  { question: "Why should I use OKLCH instead of HEX or HSL?", answer: "HSL and HEX are tied to the sRGB gamut and are not perceptually uniform — two colors with the same 'saturation' can look very different. OKLCH fixes this: changing L by 10 always looks like the same brightness shift regardless of hue. This makes it ideal for design systems, accessible color palettes, and smooth gradients." },
  { question: "What does chroma mean in OKLCH?", answer: "Chroma (C) controls color vividness — how far the color is from gray. A value of 0 produces a neutral gray at the chosen lightness. Higher values produce more vivid colors. The maximum useful chroma varies by hue and lightness; very high chroma may fall outside the sRGB gamut." },
  { question: "How do I use OKLCH in CSS today?", answer: "All modern browsers (Chrome 111+, Safari 15.4+, Firefox 113+) support oklch() natively. You can write: background: oklch(55.8% 0.228 264). For older browsers, include a hex fallback above the oklch() declaration." },
];
---

<BaseLayout
  title="OKLCH Color Picker — Modern CSS Color Space Tool"
  description="Explore OKLCH and P3 color space with an interactive picker. See hex, rgb, hsl, and oklch values simultaneously. Check sRGB gamut, generate shade scales, and copy CSS variables instantly."
  tool="OKLCH Color Picker, P3 Color Space, CSS oklch, OKLCH to HEX Converter"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">OKLCH Color Picker</h1>
  <p class="text-text-muted mb-4">
    Explore the modern OKLCH color space with perceptually uniform lightness, chroma, and hue sliders.
    See HEX, RGB, HSL, and OKLCH values simultaneously. Check P3 gamut, generate shade scales, and copy CSS variables.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <OklchColorPicker client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="OKLCH Color Picker" relatedTags={['color', 'css', 'oklch', 'design', 'p3', 'color-space']} />
</BaseLayout>
