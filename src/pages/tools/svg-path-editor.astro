---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SvgPathEditor from '../../components/SvgPathEditor.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is an SVG path d attribute?",
    answer: "The d attribute defines the shape of an SVG <path> element using a sequence of commands like M (move to), L (line to), C (cubic Bézier curve), Q (quadratic Bézier), A (arc), and Z (close path). It's the most flexible way to draw shapes in SVG."
  },
  {
    question: "How do I drag control points?",
    answer: "Click and drag any colored circle on the canvas to move that point. Round filled circles are anchor points (endpoints). Gray circles are Bézier control handles that affect curve shape without being on the path itself."
  },
  {
    question: "What is the difference between C and Q curves?",
    answer: "C (cubic Bézier) uses two control points per curve segment, giving you more precise control over curvature. Q (quadratic Bézier) uses one control point per segment, which is simpler but less flexible. Both are widely used in SVG illustrations and icon design."
  },
  {
    question: "How do I use this path in my SVG?",
    answer: "Copy the output d attribute and paste it into your SVG file: <path d=\"M 50 100 ...\" fill=\"none\" stroke=\"black\" stroke-width=\"2\" />. You can also use the color picker to set your desired stroke color before copying."
  },
  {
    question: "Can I edit the path as text?",
    answer: "Yes — the textarea below the canvas shows the raw path d attribute. Editing it updates the canvas in real time. You can type SVG path commands directly: M x y (move), L x y (line), C x1 y1 x2 y2 x y (cubic curve), Q x1 y1 x y (quadratic), Z (close)."
  },
];
---

<BaseLayout
  title="SVG Path Editor — Visual d Attribute Editor Online"
  description="Edit SVG path d attributes visually. Drag control points on a live canvas, choose from preset shapes, and copy the output. Supports M, L, C, Q, Z commands with Bézier curve handles. Runs 100% in your browser."
  tool="SVG Path Editor, SVG d attribute editor, SVG Bezier curve editor, SVG path generator, online SVG tool"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "SVG Path Editor",
    "url": "https://devplaybook.cc/tools/svg-path-editor",
    "description": "Visual SVG path editor. Drag control points, edit the d attribute, and copy the output. Runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">SVG Path Editor</h1>
  <p class="text-text-muted mb-4">
    Edit SVG <code class="font-mono bg-surface px-1 rounded text-sm">d</code> attributes visually.
    Drag control points on the canvas, pick from preset shapes, or type path commands directly.
    Supports M, L, C (cubic Bézier), Q (quadratic), and Z with live preview.
    Everything runs in your browser — nothing sent to any server.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Drag-and-drop control points</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Bézier curve handles</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live d attribute output</span>
  </div>
  <SvgPathEditor client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SVG Path Editor" relatedTags={['svg', 'frontend', 'css', 'design', 'graphics']} />
</BaseLayout>
