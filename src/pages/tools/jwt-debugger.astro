---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JwtDebugger from '../../components/JwtDebugger.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a JWT token?", answer: "A JWT (JSON Web Token) is a compact, URL-safe token format used for securely transmitting claims between parties. It consists of three Base64URL-encoded parts: header (algorithm and token type), payload (claims like user ID, roles, expiry), and signature (for verifying authenticity). JWTs are widely used in API authentication and OAuth 2.0 flows." },
  { question: "Is it safe to paste my JWT token here?", answer: "Yes — this tool runs entirely in your browser. Your token is never sent to any server. However, avoid pasting production tokens from sensitive systems into any online tool as a best practice. For debugging production issues, consider using a local tool or redacting sensitive claims." },
  { question: "Why is the signature shown but not verified?", answer: "JWT signature verification requires your secret key (for HMAC algorithms like HS256) or the public key (for RSA/EC algorithms like RS256/ES256). Since these keys should never be shared or sent to a browser, client-side signature verification is not possible. Use your backend or jwt.io for signature verification with your key." },
  { question: "What do iat, exp, nbf, sub, iss mean?", answer: "These are registered JWT claims: iat (Issued At) — Unix timestamp when the token was created. exp (Expiration) — Unix timestamp when it expires; tokens after this time are invalid. nbf (Not Before) — token is not valid before this time. sub (Subject) — the user or entity the token represents. iss (Issuer) — who created and signed the token." },
  { question: "What is the difference between HS256 and RS256?", answer: "HS256 (HMAC-SHA256) uses a shared secret key — the same key is used to sign and verify. It's simpler but requires all parties to share the secret. RS256 (RSA-SHA256) uses a public/private key pair — the private key signs, the public key verifies. RS256 is better for distributed systems where multiple services verify tokens without access to the signing key." },
];
---

<BaseLayout
  title="JWT Debugger — Decode & Inspect JWT Tokens"
  description="Free JWT debugger and decoder — paste any JSON Web Token to decode its header, payload, and signature. Inspect all claims (exp, iat, sub, iss, nbf), check expiry status, and debug OAuth 2.0 and API authentication tokens. Used for troubleshooting auth flows, verifying token contents, and learning JWT structure. Runs 100% in your browser."
  tool="JWT Debugger, JWT Decoder, JSON Web Token Inspector, JWT Parser, JWT Claims Viewer, JWT Expiry Checker, Decode JWT Online, JWT Header Payload"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">JWT Debugger</h1>
  <p class="text-text-muted mb-4">Paste any JWT to decode its header, payload, and signature. Inspect all claims with descriptions, check expiry status, and visualize the token structure — completely client-side, nothing sent to any server.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No tokens sent to any server</span>
  </div>
  <JwtDebugger client:only="preact" />
  <!-- Real-World Use Cases -->
  <section class="mt-12 mb-8">
    <h2 class="text-2xl font-bold mb-6">Real-World Use Cases</h2>

    <div class="space-y-6">
      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">1. Debugging a "401 Unauthorized" API Error</h3>
        <p class="text-text-muted mb-3">Your frontend gets a 401 from the API. Paste the JWT from the <code class="font-mono text-sm bg-bg-card px-1 rounded">Authorization: Bearer</code> header to check: Is the token expired? Does the <code class="font-mono text-sm bg-bg-card px-1 rounded">aud</code> claim match the expected audience?</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">What You See</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`Header: {"alg": "RS256", "typ": "JWT"}\n\nPayload:\n  "sub": "user_42"\n  "aud": "api.staging.com"  ← wrong!\n  "exp": 1712300000       ← expired\n  "iat": 1712296400`}</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Diagnosis</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`✗ Token expired 2 hours ago\n✗ Audience mismatch:\n  Expected: api.production.com\n  Got:      api.staging.com\n\nFix: refresh the token and\nensure AUTH_AUDIENCE env var\npoints to production.`}</pre>
          </div>
        </div>
      </div>

      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">2. Verifying OAuth 2.0 Scopes After Login</h3>
        <p class="text-text-muted mb-3">After implementing Google or GitHub OAuth, paste the <code class="font-mono text-sm bg-bg-card px-1 rounded">id_token</code> to verify the granted scopes, user email, and issuer match your OAuth configuration.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Decoded Payload</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`{\n  "iss": "https://accounts.google.com",\n  "sub": "1102938475610",\n  "email": "alice@gmail.com",\n  "email_verified": true,\n  "scope": "openid email profile",\n  "exp": 1712389200\n}`}</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Checklist</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`✓ Issuer matches Google\n✓ Email is verified\n✓ Scopes include "email"\n✓ Token valid for 50 more min\n\nSafe to create user session.`}</pre>
          </div>
        </div>
      </div>

      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">3. Comparing HS256 vs RS256 Token Structure</h3>
        <p class="text-text-muted mb-3">Learning about JWT algorithms? Paste tokens signed with different algorithms side-by-side. The debugger shows the <code class="font-mono text-sm bg-bg-card px-1 rounded">alg</code> field in the header, making it easy to see how HS256 (symmetric) and RS256 (asymmetric) differ in practice.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">HS256 Header</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`{"alg": "HS256", "typ": "JWT"}\n\n→ Signed with shared secret\n→ Signature: 32 bytes HMAC`}</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">RS256 Header</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`{"alg": "RS256", "typ": "JWT", "kid": "abc123"}\n\n→ Signed with private key\n→ Signature: 256 bytes RSA\n→ kid identifies which key`}</pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Step-by-Step Guide -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">How to Use — Step by Step</h2>
    <ol class="list-decimal list-inside space-y-3 text-text-muted">
      <li><strong>Copy the JWT</strong> — Grab the token from your browser DevTools (Application → Cookies or Network → Headers), API response, or auth library's debug output.</li>
      <li><strong>Paste the token</strong> — Paste the full <code class="font-mono text-sm bg-bg-card px-1 rounded">eyJhbG...</code> string into the input field. The tool splits and decodes all three parts instantly.</li>
      <li><strong>Check the header</strong> — Verify the algorithm (<code class="font-mono text-sm bg-bg-card px-1 rounded">alg</code>) matches what your backend expects. Mismatches cause verification failures.</li>
      <li><strong>Inspect the payload</strong> — Review claims like <code class="font-mono text-sm bg-bg-card px-1 rounded">exp</code> (expiry), <code class="font-mono text-sm bg-bg-card px-1 rounded">sub</code> (subject), and <code class="font-mono text-sm bg-bg-card px-1 rounded">iss</code> (issuer). The tool highlights expired tokens and explains each standard claim.</li>
      <li><strong>Debug</strong> — Use the decoded information to fix auth issues: wrong audience, expired token, missing roles, or algorithm mismatch.</li>
    </ol>
  </section>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="JWT Debugger" relatedTags={['jwt', 'auth', 'security', 'tokens', 'api']} />
</BaseLayout>
