---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What are text embeddings and how do they work?",
    answer: "Text embeddings are numerical representations of text as high-dimensional vectors. An embedding model converts a sentence, paragraph, or document into a list of floating-point numbers (e.g., 1536 numbers for text-embedding-3-small). Texts with similar meaning produce vectors that are close together in the vector space — measurable with cosine similarity. This mathematical relationship enables semantic search, RAG retrieval, clustering, classification, and duplicate detection."
  },
  {
    question: "What is the MTEB benchmark?",
    answer: "MTEB (Massive Text Embedding Benchmark) is the standard benchmark for evaluating embedding models across 56 tasks in 8 categories: retrieval, clustering, classification, reranking, STS, summarization, bitext mining, and pair classification. The MTEB leaderboard (huggingface.co/spaces/mteb/leaderboard) ranks hundreds of models. A high MTEB score, especially on the 'Retrieval' category, correlates strongly with RAG performance."
  },
  {
    question: "OpenAI text-embedding-3-small vs text-embedding-3-large: when to use each?",
    answer: "text-embedding-3-small (1536 dims, $0.02/1M tokens) is the best price-performance choice for most RAG applications — it outperforms the old ada-002 on MTEB while costing 5x less. text-embedding-3-large (3072 dims, $0.13/1M tokens) provides higher quality for complex reasoning, multilingual tasks, and applications where accuracy is critical and cost is secondary. The large model supports Matryoshka dimension reduction to 256 or 1024 dims."
  },
  {
    question: "What is Voyage AI and when should I use it?",
    answer: "Voyage AI provides specialized embedding models optimized for specific domains: voyage-code-2 for code retrieval, voyage-law-2 for legal documents, voyage-finance-2 for financial text, and voyage-3 for general use. Voyage models consistently rank at or near the top of MTEB retrieval benchmarks. Use Voyage when you need maximum retrieval accuracy for your specific domain and are willing to pay a modest premium over OpenAI embeddings."
  },
  {
    question: "What is Cohere embed-v3 good for?",
    answer: "Cohere embed-v3 (embed-english-v3.0 and embed-multilingual-v3.0) is especially strong for multilingual applications — it supports 100+ languages with consistent performance. A unique feature is input_type specification: you pass 'search_document' when embedding stored documents and 'search_query' when embedding user queries, which improves asymmetric retrieval quality. It also supports int8 and binary output for storage-efficient embeddings."
  },
  {
    question: "When should I use local/open-source embedding models?",
    answer: "Use local models (all-MiniLM-L6-v2, BGE-M3, nomic-embed-text, E5-large) when: (1) data privacy requires no external API calls, (2) you need zero per-token cost at large scale, (3) latency requirements are strict and network round-trips matter, (4) you want to avoid vendor lock-in. The trade-off: you manage model serving infrastructure. BGE-M3 and E5-Mistral-7B are competitive with OpenAI embeddings on MTEB."
  },
];

const models = [
  { provider: "OpenAI",       model: "text-embedding-3-small", dims: 1536,  ctx: 8191,  cost: "$0.02",  mteb: "62.3",  note: "Best price/performance. MRL configurable." },
  { provider: "OpenAI",       model: "text-embedding-3-large", dims: 3072,  ctx: 8191,  cost: "$0.13",  mteb: "64.6",  note: "Highest quality OpenAI model." },
  { provider: "OpenAI",       model: "text-embedding-ada-002", dims: 1536,  ctx: 8191,  cost: "$0.10",  mteb: "60.5",  note: "Legacy. Still widely deployed." },
  { provider: "Cohere",       model: "embed-english-v3.0",     dims: 1024,  ctx: 512,   cost: "$0.10",  mteb: "64.5",  note: "Strong multilingual, int8 output." },
  { provider: "Cohere",       model: "embed-multilingual-v3.0",dims: 1024,  ctx: 512,   cost: "$0.10",  mteb: "62.4",  note: "100+ languages, asymmetric retrieval." },
  { provider: "Voyage AI",    model: "voyage-3",               dims: 1024,  ctx: 32000, cost: "$0.06",  mteb: "67.1",  note: "Top MTEB general retrieval score." },
  { provider: "Voyage AI",    model: "voyage-code-2",          dims: 1536,  ctx: 16000, cost: "$0.12",  mteb: "—",     note: "Best for code retrieval tasks." },
  { provider: "Jina AI",      model: "jina-embeddings-v3",     dims: 1024,  ctx: 8192,  cost: "$0.02",  mteb: "65.3",  note: "Long context, task-specific LoRA." },
  { provider: "HuggingFace",  model: "BGE-M3",                 dims: 1024,  ctx: 8192,  cost: "Free",   mteb: "66.8",  note: "Open source, multi-func, multilingual." },
  { provider: "HuggingFace",  model: "all-MiniLM-L6-v2",       dims: 384,   ctx: 256,   cost: "Free",   mteb: "56.3",  note: "Ultra-fast, lightweight, great for local." },
  { provider: "Nomic AI",     model: "nomic-embed-text-v1.5",  dims: 768,   ctx: 8192,  cost: "Free",   mteb: "62.0",  note: "Open source, MRL configurable dims." },
];
---

<BaseLayout
  title="Embeddings API Comparison: OpenAI vs Cohere vs Voyage vs Jina"
  description="Complete embeddings API comparison — model dimensions, context length, cost per million tokens, MTEB benchmark scores. Compare OpenAI text-embedding-3-small/large, Cohere embed-v3, Voyage AI, Jina embeddings, and open-source BGE/MiniLM models."
  tool="embeddings API, OpenAI embeddings, Cohere embed, Voyage AI, text embeddings comparison"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"Embeddings API Comparison: OpenAI vs Cohere vs Voyage vs Jina","url":"https://devplaybook.cc/tools/embeddings-api-comparison","description":"Complete text embeddings API comparison — dimensions, context length, cost, MTEB scores for OpenAI, Cohere, Voyage AI, Jina, and open-source models."})} />

  <h1 class="text-3xl font-bold mb-2">Embeddings API Comparison: OpenAI vs Cohere vs Voyage vs Jina</h1>
  <p class="text-text-muted mb-6">Text embedding models convert text into high-dimensional vectors for semantic search, RAG retrieval, clustering, and classification. Choosing the right model involves balancing quality (MTEB score), context length, cost, and hosting requirements. This guide compares all major commercial and open-source embedding APIs side-by-side.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 11 models compared</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> MTEB benchmark scores</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Cost per 1M tokens</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Context length</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Open-source options included</span>
  </div>

  <ToolPageCta />

  <!-- Model Comparison Table -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">Full Model Comparison Table</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm min-w-[800px]">
        <thead>
          <tr class="text-text-muted text-xs uppercase border-b border-border">
            <th class="text-left pb-3 pr-4 font-medium">Provider</th>
            <th class="text-left pb-3 pr-4 font-medium">Model</th>
            <th class="text-right pb-3 pr-4 font-medium">Dims</th>
            <th class="text-right pb-3 pr-4 font-medium">Context</th>
            <th class="text-right pb-3 pr-4 font-medium">$/1M tokens</th>
            <th class="text-right pb-3 pr-4 font-medium">MTEB avg</th>
            <th class="text-left pb-3 font-medium">Notes</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border text-text-muted">
          {models.map(m => (
            <tr class="hover:bg-bg-card/50 transition-colors">
              <td class="py-3 pr-4 font-medium text-text">{m.provider}</td>
              <td class="py-3 pr-4 font-mono text-xs">{m.model}</td>
              <td class="py-3 pr-4 text-right tabular-nums font-mono">{m.dims.toLocaleString()}</td>
              <td class="py-3 pr-4 text-right tabular-nums font-mono">{m.ctx.toLocaleString()}</td>
              <td class={`py-3 pr-4 text-right tabular-nums font-mono ${m.cost === "Free" ? "text-green-500 font-medium" : ""}`}>{m.cost}</td>
              <td class="py-3 pr-4 text-right tabular-nums font-mono">{m.mteb}</td>
              <td class="py-3 text-xs">{m.note}</td>
            </tr>
          ))}
        </tbody>
      </table>
      <p class="text-xs text-text-muted mt-2">MTEB scores are approximate averages from the public leaderboard. Scores vary by task subset. Free = open-source, self-hosted. Costs as of 2026.</p>
    </div>
  </section>

  <!-- OpenAI Code Example -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">OpenAI Embeddings: text-embedding-3-small &amp; large</h2>
    <p class="text-text-muted mb-4">The most widely used embedding API — supports Matryoshka dimension reduction for storage optimization.</p>
    <pre class="bg-bg-card border border-border rounded-xl p-4 text-sm font-mono overflow-x-auto mb-4"><code class="text-green-400">from openai import OpenAI
import numpy as np

client = OpenAI()

# Standard embedding — 1536 dims
response = client.embeddings.create(
    model="text-embedding-3-small",
    input=["RAG combines retrieval with LLM generation",
           "Vector databases store high-dimensional embeddings"]
)
embeddings = [item.embedding for item in response.data]
print(f"Shape: &#123;len(embeddings)&#125; x &#123;len(embeddings[0])&#125; dims")

# Matryoshka dimension reduction — truncate to 512 dims (saves 66% storage)
response_small = client.embeddings.create(
    model="text-embedding-3-small",
    input=["Compact embedding for storage-optimized RAG"],
    dimensions=512    # reduce from 1536 to 512
)
print(f"Reduced dims: &#123;len(response_small.data[0].embedding)&#125;")

# Cosine similarity between two embeddings
def cosine_sim(a, b):
    a, b = np.array(a), np.array(b)
    return np.dot(a, b) / (np.linalg.norm(a) * np.linalg.norm(b))

sim = cosine_sim(embeddings[0], embeddings[1])
print(f"Cosine similarity: &#123;sim:.4f&#125;")  # ~0.7-0.8 for related topics</code></pre>
  </section>

  <!-- Cohere + Voyage Code Example -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">Cohere Embed v3 &amp; Voyage AI</h2>
    <p class="text-text-muted mb-4">Cohere requires specifying input_type for asymmetric retrieval. Voyage AI leads MTEB general retrieval benchmarks.</p>
    <pre class="bg-bg-card border border-border rounded-xl p-4 text-sm font-mono overflow-x-auto mb-4"><code class="text-green-400">import cohere
import voyageai

# COHERE — asymmetric retrieval with input_type
co = cohere.Client("YOUR_COHERE_KEY")

# Embed documents at indexing time
doc_embeddings = co.embed(
    texts=["Qdrant supports sparse and dense hybrid search",
           "pgvector adds vector search to PostgreSQL"],
    model="embed-english-v3.0",
    input_type="search_document",   # use this for indexed documents
    embedding_types=["float"]        # float | int8 | uint8 | binary
).embeddings.float

# Embed queries at search time
query_embeddings = co.embed(
    texts=["how does hybrid vector search work?"],
    model="embed-english-v3.0",
    input_type="search_query",      # use this for user queries
    embedding_types=["float"]
).embeddings.float

print(f"Doc dims: &#123;len(doc_embeddings[0])&#125;")    # 1024

# VOYAGE AI — top MTEB general retrieval performance
vo = voyageai.Client(api_key="YOUR_VOYAGE_KEY")

result = vo.embed(
    texts=["Voyage AI achieves state-of-the-art retrieval accuracy",
           "MTEB benchmark measures embedding quality across 56 tasks"],
    model="voyage-3",
    input_type="document"           # "document" or "query"
)
voyage_embeddings = result.embeddings
print(f"Voyage dims: &#123;len(voyage_embeddings[0])&#125;")  # 1024
print(f"Total tokens used: &#123;result.total_tokens&#125;")</code></pre>
  </section>

  <!-- Use Case Recommendations -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">Use Case Recommendations</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="bg-bg-card border border-border rounded-xl p-4">
        <h3 class="font-semibold mb-2 text-primary">General RAG (Best Value)</h3>
        <p class="text-sm text-text-muted">OpenAI <code class="text-xs bg-bg-surface px-1 rounded">text-embedding-3-small</code> — excellent MTEB score at $0.02/1M tokens. Most integrations support it natively.</p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-4">
        <h3 class="font-semibold mb-2 text-primary">Maximum Retrieval Accuracy</h3>
        <p class="text-sm text-text-muted">Voyage AI <code class="text-xs bg-bg-surface px-1 rounded">voyage-3</code> — leads MTEB retrieval benchmarks. Worth the premium for accuracy-critical apps.</p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-4">
        <h3 class="font-semibold mb-2 text-primary">Multilingual Applications</h3>
        <p class="text-sm text-text-muted">Cohere <code class="text-xs bg-bg-surface px-1 rounded">embed-multilingual-v3.0</code> — 100+ languages with consistent quality. Use input_type for best retrieval.</p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-4">
        <h3 class="font-semibold mb-2 text-primary">Code Retrieval</h3>
        <p class="text-sm text-text-muted">Voyage AI <code class="text-xs bg-bg-surface px-1 rounded">voyage-code-2</code> — purpose-trained for code search. Dramatically outperforms general models on code.</p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-4">
        <h3 class="font-semibold mb-2 text-primary">Privacy / Zero API Cost</h3>
        <p class="text-sm text-text-muted"><code class="text-xs bg-bg-surface px-1 rounded">BGE-M3</code> or <code class="text-xs bg-bg-surface px-1 rounded">nomic-embed-text-v1.5</code> — run locally, competitive MTEB, zero cost. Use with sentence-transformers.</p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-4">
        <h3 class="font-semibold mb-2 text-primary">Edge / Lightweight</h3>
        <p class="text-sm text-text-muted"><code class="text-xs bg-bg-surface px-1 rounded">all-MiniLM-L6-v2</code> — only 384 dims, runs on CPU, &lt;100ms latency. Ideal for edge devices and high-QPS local search.</p>
      </div>
    </div>
  </section>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Embeddings API Comparison Guide" relatedTags={['ai', 'embeddings', 'vector-database', 'rag', 'openai', 'llm', 'semantic-search']} />
</BaseLayout>
