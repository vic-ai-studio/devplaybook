---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What are Core Web Vitals?", answer: "Core Web Vitals are a set of real-world performance metrics defined by Google that measure the user experience of a web page. The three key metrics are LCP (Largest Contentful Paint), INP (Interaction to Next Paint), and CLS (Cumulative Layout Shift). Google uses these as ranking signals for search results." },
  { question: "What is LCP (Largest Contentful Paint)?", answer: "LCP measures how long it takes for the largest visible content element (image, video, or text block) to render. Good: ≤2.5s, Needs Improvement: ≤4.0s, Poor: >4.0s. Optimize LCP by improving server response time, using a CDN, preloading critical resources, and optimizing images." },
  { question: "What is INP (Interaction to Next Paint)?", answer: "INP measures the responsiveness of a page to user interactions. It replaced FID (First Input Delay) as of March 2024. Good: ≤200ms, Needs Improvement: ≤500ms, Poor: >500ms. Improve INP by reducing JavaScript execution time, breaking up long tasks, and using requestIdleCallback." },
  { question: "What is CLS (Cumulative Layout Shift)?", answer: "CLS measures visual stability — how much page elements move around during loading. Good: ≤0.1, Needs Improvement: ≤0.25, Poor: >0.25. Fix CLS by always specifying width/height for images and embeds, avoiding inserting content above existing content, and using CSS transform animations." },
  { question: "How do I measure my Core Web Vitals?", answer: "Use Chrome DevTools (Lighthouse, Performance tab), PageSpeed Insights (web.dev/measure), Chrome UX Report in Google Search Console, or install the web-vitals JavaScript library. Field data from real users is most accurate for ranking purposes." },
];
---

<BaseLayout
  title="Web Vitals Scorer — LCP / INP / CLS Pass/Fail Checker"
  description="Check your Core Web Vitals scores. Enter LCP, INP, and CLS values to see instant Pass/Fail ratings with Good/Needs Improvement/Poor thresholds and optimization tips."
  tool="Web Vitals Scorer, Core Web Vitals Checker, LCP INP CLS Calculator, PageSpeed Vitals, Lighthouse Score Checker"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Web Vitals Scorer",
    "url": "https://devplaybook.cc/tools/web-vitals-scorer",
    "description": "Check LCP, INP, and CLS values against Google Core Web Vitals thresholds. Get Pass/Fail ratings and optimization tips.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Web Vitals Scorer</h1>
  <p class="text-text-muted mb-4">Enter your LCP, INP, and CLS values to get instant Pass/Fail ratings against Google's Core Web Vitals thresholds — with actionable optimization tips for each metric.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 2024 INP thresholds (replaces FID)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Good / Needs Improvement / Poor</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Optimization tips per metric</span>
  </div>

  <!-- Tool -->
  <div class="space-y-5">
    <!-- Inputs -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <!-- LCP -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-2xl">⚡</span>
          <div>
            <div class="font-semibold">LCP</div>
            <div class="text-xs text-text-muted">Largest Contentful Paint</div>
          </div>
        </div>
        <div class="flex items-center gap-2 mb-2">
          <input id="lcp-input" type="number" min="0" step="0.1" placeholder="2.5"
            class="flex-1 bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          <span class="text-sm text-text-muted">s</span>
        </div>
        <div class="text-xs text-text-muted">Good ≤2.5s · Poor >4.0s</div>
        <div id="lcp-badge" class="mt-3 hidden"></div>
      </div>

      <!-- INP -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-2xl">🖱️</span>
          <div>
            <div class="font-semibold">INP</div>
            <div class="text-xs text-text-muted">Interaction to Next Paint</div>
          </div>
        </div>
        <div class="flex items-center gap-2 mb-2">
          <input id="inp-input" type="number" min="0" step="1" placeholder="200"
            class="flex-1 bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          <span class="text-sm text-text-muted">ms</span>
        </div>
        <div class="text-xs text-text-muted">Good ≤200ms · Poor >500ms</div>
        <div id="inp-badge" class="mt-3 hidden"></div>
      </div>

      <!-- CLS -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-2xl">📐</span>
          <div>
            <div class="font-semibold">CLS</div>
            <div class="text-xs text-text-muted">Cumulative Layout Shift</div>
          </div>
        </div>
        <div class="flex items-center gap-2 mb-2">
          <input id="cls-input" type="number" min="0" step="0.01" placeholder="0.1"
            class="flex-1 bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          <span class="text-sm text-text-muted">score</span>
        </div>
        <div class="text-xs text-text-muted">Good ≤0.1 · Poor >0.25</div>
        <div id="cls-badge" class="mt-3 hidden"></div>
      </div>
    </div>

    <!-- Score button -->
    <div class="flex gap-3">
      <button id="score-btn" class="bg-primary text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-primary/80 transition-colors">
        Score My Vitals
      </button>
      <button id="reset-btn" class="text-sm text-text-muted hover:text-red-400 transition-colors">
        Reset
      </button>
    </div>

    <!-- Results -->
    <div id="results" class="hidden space-y-4">
      <!-- Overall -->
      <div id="overall-card" class="rounded-xl p-5 border">
        <div class="flex items-center gap-3">
          <span id="overall-icon" class="text-3xl"></span>
          <div>
            <div id="overall-label" class="text-xl font-bold"></div>
            <div id="overall-sub" class="text-sm text-text-muted"></div>
          </div>
        </div>
      </div>

      <!-- Per-metric details -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4" id="metric-cards"></div>

      <!-- Tips -->
      <div id="tips-card" class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold mb-3">Optimization Tips</h2>
        <div id="tips-list" class="space-y-3"></div>
      </div>

      <!-- Thresholds reference -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted mb-3">Threshold Reference</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-text-muted text-xs uppercase tracking-wide border-b border-border">
                <th class="text-left py-2 pr-4">Metric</th>
                <th class="text-left py-2 pr-4 text-green-500">✓ Good</th>
                <th class="text-left py-2 pr-4 text-yellow-500">⚠ Needs Improvement</th>
                <th class="text-left py-2 text-red-500">✗ Poor</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border">
              <tr>
                <td class="py-2 pr-4 font-medium">LCP</td>
                <td class="py-2 pr-4 text-green-400">≤ 2.5s</td>
                <td class="py-2 pr-4 text-yellow-400">2.5s – 4.0s</td>
                <td class="py-2 text-red-400">&gt; 4.0s</td>
              </tr>
              <tr>
                <td class="py-2 pr-4 font-medium">INP</td>
                <td class="py-2 pr-4 text-green-400">≤ 200ms</td>
                <td class="py-2 pr-4 text-yellow-400">200ms – 500ms</td>
                <td class="py-2 text-red-400">&gt; 500ms</td>
              </tr>
              <tr>
                <td class="py-2 pr-4 font-medium">CLS</td>
                <td class="py-2 pr-4 text-green-400">≤ 0.1</td>
                <td class="py-2 pr-4 text-yellow-400">0.1 – 0.25</td>
                <td class="py-2 text-red-400">&gt; 0.25</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Web Vitals Scorer" relatedTags={['performance', 'seo', 'pwa', 'lighthouse', 'developer-tools']} />
</BaseLayout>

<script is:inline>
(function () {
  var METRICS = {
    lcp: {
      label: 'LCP',
      unit: 's',
      good: 2.5,
      poor: 4.0,
      tips: {
        good: 'LCP is fast. Keep it up by maintaining a CDN, preloading hero images, and keeping server TTFB under 600ms.',
        needs: 'Improve LCP: preload the LCP image with <link rel="preload">, use a CDN, compress images (WebP/AVIF), and reduce server response time.',
        poor: 'LCP is critical. Prioritize: serve from a CDN, preload the largest element, eliminate render-blocking scripts, and compress the LCP image.'
      }
    },
    inp: {
      label: 'INP',
      unit: 'ms',
      good: 200,
      poor: 500,
      tips: {
        good: 'INP is responsive. Maintain this by avoiding long JS tasks and using requestIdleCallback for non-critical work.',
        needs: 'Reduce INP: break up long tasks (>50ms) with scheduler.yield(), minimize JS bundle size, defer non-critical scripts.',
        poor: 'INP is failing. Urgent: profile with Chrome DevTools > Performance, identify long tasks, and move heavy work off the main thread with Web Workers.'
      }
    },
    cls: {
      label: 'CLS',
      unit: '',
      good: 0.1,
      poor: 0.25,
      tips: {
        good: 'Layout is stable. Maintain by always specifying width/height for images and avoiding dynamic content insertion above existing content.',
        needs: 'Reduce CLS: add explicit width/height to all images, reserve space for ads/embeds, use CSS aspect-ratio for media containers.',
        poor: 'CLS is critical. Immediately: add dimensions to all images and iframes, stop injecting content above the fold, use transform animations instead of layout-changing properties.'
      }
    }
  };

  function getStatus(metric, value) {
    if (value <= metric.good) return 'good';
    if (value <= metric.poor) return 'needs';
    return 'poor';
  }

  function statusConfig(status) {
    return {
      good: { label: 'Good', color: 'text-green-400', bg: 'bg-green-500/10 border-green-500/30', icon: '✓' },
      needs: { label: 'Needs Improvement', color: 'text-yellow-400', bg: 'bg-yellow-500/10 border-yellow-500/30', icon: '⚠' },
      poor: { label: 'Poor', color: 'text-red-400', bg: 'bg-red-500/10 border-red-500/30', icon: '✗' }
    }[status];
  }

  function renderBadge(el, status) {
    var cfg = statusConfig(status);
    el.className = 'mt-3 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold border ' + cfg.bg + ' ' + cfg.color;
    el.textContent = cfg.icon + ' ' + cfg.label;
    el.classList.remove('hidden');
  }

  document.getElementById('score-btn').addEventListener('click', function () {
    var lcpVal = parseFloat(document.getElementById('lcp-input').value);
    var inpVal = parseFloat(document.getElementById('inp-input').value);
    var clsVal = parseFloat(document.getElementById('cls-input').value);

    var values = { lcp: lcpVal, inp: inpVal, cls: clsVal };
    var statuses = {};
    var hasAny = false;

    ['lcp', 'inp', 'cls'].forEach(function (key) {
      var val = values[key];
      if (!isNaN(val) && val >= 0) {
        statuses[key] = getStatus(METRICS[key], val);
        hasAny = true;
        renderBadge(document.getElementById(key + '-badge'), statuses[key]);
      }
    });

    if (!hasAny) {
      alert('Please enter at least one metric value.');
      return;
    }

    // Overall verdict
    var statusList = Object.values(statuses);
    var overall = statusList.includes('poor') ? 'poor' : statusList.includes('needs') ? 'needs' : 'good';
    var overallCfg = statusConfig(overall);
    var overallCard = document.getElementById('overall-card');
    overallCard.className = 'rounded-xl p-5 border ' + overallCfg.bg;
    document.getElementById('overall-icon').textContent = overall === 'good' ? '🟢' : overall === 'needs' ? '🟡' : '🔴';
    document.getElementById('overall-label').textContent = overall === 'good' ? 'Passing Core Web Vitals' : overall === 'needs' ? 'Needs Improvement' : 'Failing Core Web Vitals';
    document.getElementById('overall-sub').textContent = overall === 'good'
      ? 'All measured metrics meet Google\'s Good threshold.'
      : overall === 'needs'
      ? 'Some metrics need improvement to meet Google\'s Good threshold.'
      : 'One or more metrics are in the Poor range — this may affect search rankings.';

    // Metric cards
    var cardsEl = document.getElementById('metric-cards');
    cardsEl.innerHTML = '';
    Object.keys(statuses).forEach(function (key) {
      var m = METRICS[key];
      var val = values[key];
      var s = statuses[key];
      var cfg = statusConfig(s);
      var card = document.createElement('div');
      card.className = 'bg-bg-card border rounded-xl p-4 ' + (s === 'good' ? 'border-green-500/30' : s === 'needs' ? 'border-yellow-500/30' : 'border-red-500/30');
      card.innerHTML = '<div class="flex items-center justify-between mb-1">'
        + '<span class="font-semibold">' + m.label + '</span>'
        + '<span class="text-lg font-bold ' + cfg.color + '">' + val + m.unit + '</span>'
        + '</div>'
        + '<div class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold border ' + cfg.bg + ' ' + cfg.color + '">'
        + cfg.icon + ' ' + cfg.label + '</div>';
      cardsEl.appendChild(card);
    });

    // Tips
    var tipsList = document.getElementById('tips-list');
    tipsList.innerHTML = '';
    Object.keys(statuses).forEach(function (key) {
      var m = METRICS[key];
      var s = statuses[key];
      var cfg = statusConfig(s);
      var div = document.createElement('div');
      div.className = 'flex items-start gap-3 p-3 rounded-lg bg-bg';
      div.innerHTML = '<span class="shrink-0 font-bold ' + cfg.color + '">' + m.label + '</span>'
        + '<p class="text-sm text-text-muted">' + m.tips[s] + '</p>';
      tipsList.appendChild(div);
    });

    document.getElementById('results').classList.remove('hidden');
    document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });

  document.getElementById('reset-btn').addEventListener('click', function () {
    ['lcp', 'inp', 'cls'].forEach(function (k) {
      document.getElementById(k + '-input').value = '';
      var badge = document.getElementById(k + '-badge');
      badge.className = 'mt-3 hidden';
      badge.textContent = '';
    });
    document.getElementById('results').classList.add('hidden');
  });
})();
</script>
