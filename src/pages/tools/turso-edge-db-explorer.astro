---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TursoEdgeDbExplorer from '../../components/TursoEdgeDbExplorer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Turso and how does it differ from regular SQLite?", answer: "Turso is an edge-native database platform built on libSQL, a fork of SQLite. It adds a server mode to SQLite, enabling remote connections over HTTP or WebSockets. Key additions: network access, multi-tenancy (thousands of databases), replication (embedded replicas), and a managed cloud platform — while keeping full SQLite compatibility for your SQL syntax." },
  { question: "What is the @libsql/client package?", answer: "@libsql/client is the official JavaScript/TypeScript client for libSQL databases. It supports three connection modes: WebSocket (libsql://) for full features including interactive transactions, HTTP (https://) for edge/serverless runtimes like Cloudflare Workers, and in-memory (:memory:) or local file (file:./local.db) for testing and development." },
  { question: "What is the difference between execute(), batch(), and transaction()?", answer: "execute() runs a single SQL statement and returns results. batch() runs multiple statements in a single network round-trip, all within an implicit transaction — best for related writes. transaction() opens an interactive transaction object where you can conditionally run statements based on intermediate results, then commit() or rollback() — best for read-then-write patterns like balance checks." },
  { question: "Does Turso work with Drizzle ORM?", answer: "Yes. Use drizzle-orm/libsql with the @libsql/client for full ORM support. Define your schema using SQLite column types (sqliteTable, text, integer, real, blob). Drizzle's query builder generates type-safe SQLite-compatible SQL that works perfectly with Turso's libSQL engine." },
  { question: "What are Turso embedded replicas?", answer: "Embedded replicas let you run a local SQLite file that continuously syncs with a remote Turso database. Reads are served from the local file (microsecond latency, zero network cost), while writes are forwarded to the primary. Ideal for edge deployments where you want fast local reads with cloud-backed durability. Initialize with the syncUrl and authToken options in createClient()." },
  { question: "How does Turso compare to other edge databases like Neon or PlanetScale?", answer: "Turso/libSQL is SQLite-based (great for simple schemas, low write concurrency, edge affinity). Neon is serverless PostgreSQL (complex queries, extensions, strong ACID). PlanetScale is serverless MySQL with Git-like branching (large-scale MySQL apps). Choose Turso for edge apps with many small databases (multi-tenant SaaS), Neon for relational complexity, PlanetScale for MySQL-heavy teams." },
];
---

<BaseLayout
  title="Turso Edge DB Explorer — libSQL Query Templates & Code Generator"
  description="Browse libSQL/Turso query templates for SELECT, INSERT, batch transactions, and Drizzle ORM. Generate @libsql/client TypeScript code with connection setup. Free browser tool."
  tool="Turso database explorer, libsql client examples, turso typescript queries, @libsql/client generator, turso drizzle orm, libSQL edge database"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Turso Edge DB Explorer",
    "url": "https://devplaybook.cc/tools/turso-edge-db-explorer",
    "description": "Interactive libSQL/Turso query template browser. Generates @libsql/client TypeScript code for SELECT, INSERT, batch transactions, interactive transactions, CREATE TABLE, and Drizzle ORM patterns.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Turso Edge DB Explorer</h1>
  <p class="text-text-muted mb-4">
    Browse ready-to-use <strong>@libsql/client</strong> TypeScript query templates for <strong>Turso</strong> (libSQL). Covers SELECT, INSERT, batch transactions, interactive transactions, schema creation, and <strong>Drizzle ORM</strong> patterns. Copy and paste directly into your project.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 6 query templates with TypeScript + SQL</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Connection setup for WebSocket, HTTP, in-memory</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Drizzle ORM + libSQL integration example</span>
  </div>
  <TursoEdgeDbExplorer client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Turso Edge DB Explorer" relatedTags={['database', 'sqlite', 'turso', 'serverless', 'typescript', 'developer-tools']} />
</BaseLayout>
