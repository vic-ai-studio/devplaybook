---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Milvus and when should I use it?",
    answer: "Milvus is a distributed, open-source vector database built for billion-scale similarity search. It was designed from the ground up for horizontal scaling — separating storage, query, and index nodes for independent scaling. Use Milvus when you need to search across hundreds of millions to billions of vectors with low latency, have DevOps capacity to manage a cluster, or want the managed Zilliz Cloud version."
  },
  {
    question: "What is the difference between Milvus standalone and cluster mode?",
    answer: "Standalone mode runs all Milvus components (proxy, root coordinator, data node, query node, index node) in a single Docker container. It suits development, small teams, and collections under ~10M vectors. Cluster mode on Kubernetes separates each component for independent horizontal scaling — data nodes scale for ingestion, query nodes for search throughput. Cluster mode is required for production at billion-scale."
  },
  {
    question: "What index types does Milvus support?",
    answer: "Milvus supports HNSW (best recall, high memory), IVF_FLAT (inverted file index, balanced), IVF_PQ (product quantization, low memory), IVF_SQ8 (scalar quantization), SCANN (Google's optimized ANN), and DiskANN (billion-scale with disk-based storage). For most RAG use cases, HNSW is recommended. DiskANN is ideal when you have more vectors than RAM can hold."
  },
  {
    question: "How does Milvus schema design work?",
    answer: "A Milvus collection has a schema with typed fields. Every collection requires a primary key field (INT64 or VARCHAR) and at least one FloatVector field for embeddings. You can add any number of scalar fields (INT8, INT64, FLOAT, VARCHAR, BOOL, JSON, ARRAY) as metadata. Unlike relational databases, you define the schema once at collection creation and cannot add fields later (without migration)."
  },
  {
    question: "What is Zilliz Cloud?",
    answer: "Zilliz Cloud is the fully managed, enterprise version of Milvus built and operated by the Milvus creators. It offers serverless and dedicated cluster tiers, automatic scaling, BYOC (Bring Your Own Cloud) for data residency, SOC 2 compliance, and a free tier with 1GB storage. It is API-compatible with Milvus SDK — you can switch from self-hosted to Zilliz Cloud by changing the connection URL."
  },
  {
    question: "How does Milvus compare to Qdrant for large-scale deployments?",
    answer: "Both are production-grade open-source vector databases. Milvus has more mature distributed architecture for billion-scale workloads and a wider ecosystem (Attu UI, Milvus Backup, CDC). Qdrant has simpler setup, better single-node performance, richer payload filtering, and native sparse vector support. For teams already on Kubernetes managing 100M+ vectors, Milvus is the battle-tested choice. For smaller teams wanting fast setup, Qdrant wins."
  },
];
---

<BaseLayout
  title="Milvus: Distributed Vector Database for Billion-Scale Search"
  description="Complete guide to Milvus vector database — standalone vs cluster architecture, collection schema, HNSW/IVF_FLAT/DiskANN index types, insert/search/filter, Python SDK examples, and comparison with Qdrant and Weaviate."
  tool="Milvus, distributed vector database, billion-scale search, HNSW, Zilliz"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"Milvus: Distributed Vector Database for Billion-Scale Search","url":"https://devplaybook.cc/tools/milvus","description":"Complete Milvus guide — architecture, schema design, index types, batch insert, filtered search, and Zilliz Cloud deployment."})} />

  <h1 class="text-3xl font-bold mb-2">Milvus: Distributed Vector Database for Billion-Scale Search</h1>
  <p class="text-text-muted mb-6">Milvus is the leading open-source distributed vector database, purpose-built for billion-scale similarity search. With a cloud-native, microservices architecture, it independently scales storage, indexing, and query nodes. Supporting 12+ index types including HNSW, DiskANN, and GPU-accelerated indexes, Milvus powers the largest AI applications at companies like Salesforce, Walmart, and Roblox.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Billion-scale distributed search</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 12+ index types (HNSW, DiskANN)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Standalone &amp; cluster modes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Scalar filtering</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Zilliz Cloud managed option</span>
  </div>

  <ToolPageCta />

  <!-- Setup and Schema -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">Quick Start: Docker Standalone &amp; Collection Schema</h2>
    <p class="text-text-muted mb-4">Run Milvus standalone locally with Docker, then define a typed collection schema.</p>
    <pre class="bg-bg-card border border-border rounded-xl p-4 text-sm font-mono overflow-x-auto mb-4"><code class="text-green-400"># Start Milvus standalone with Docker Compose
# curl -sfL https://raw.githubusercontent.com/milvus-io/milvus/master/scripts/standalone_embed.sh | bash

pip install pymilvus openai

from pymilvus import (
    MilvusClient, DataType, Collection,
    FieldSchema, CollectionSchema
)

# Connect to local Milvus
client = MilvusClient(uri="http://localhost:19530")

# Define schema — primary key + vector field + scalar metadata
schema = MilvusClient.create_schema(auto_id=False, enable_dynamic_field=True)
schema.add_field(field_name="id",       datatype=DataType.INT64,      is_primary=True)
schema.add_field(field_name="vector",   datatype=DataType.FLOAT_VECTOR, dim=1536)
schema.add_field(field_name="text",     datatype=DataType.VARCHAR,    max_length=2048)
schema.add_field(field_name="category", datatype=DataType.VARCHAR,    max_length=64)
schema.add_field(field_name="year",     datatype=DataType.INT32)

# Create collection
client.create_collection(
    collection_name="articles",
    schema=schema,
    consistency_level="Strong"    # Strong | Bounded | Eventually
)
print(client.describe_collection("articles"))</code></pre>
  </section>

  <!-- Index + Insert + Search -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">Create HNSW Index, Insert Vectors &amp; Search</h2>
    <p class="text-text-muted mb-4">Build an HNSW index on the vector field, insert data in batches, then run filtered ANN search.</p>
    <pre class="bg-bg-card border border-border rounded-xl p-4 text-sm font-mono overflow-x-auto mb-4"><code class="text-green-400">import openai

oa = openai.OpenAI()

# Build HNSW index before inserting large datasets
index_params = client.prepare_index_params()
index_params.add_index(
    field_name="vector",
    index_type="HNSW",           # HNSW | IVF_FLAT | IVF_PQ | DiskANN | SCANN
    metric_type="COSINE",        # COSINE | L2 | IP
    params=&#123;"M": 16, "efConstruction": 200&#125;
)
client.create_index(collection_name="articles", index_params=index_params)
client.load_collection("articles")  # load into memory for search

# Generate embeddings and insert
docs = [
    &#123;"id": 1, "text": "Milvus scales to billion vectors", "category": "db",  "year": 2024&#125;,
    &#123;"id": 2, "text": "HNSW provides high recall ANN search", "category": "ai", "year": 2024&#125;,
    &#123;"id": 3, "text": "DiskANN enables disk-based billion-scale search", "category": "db","year": 2023&#125;,
]
embs = oa.embeddings.create(model="text-embedding-3-small", input=[d["text"] for d in docs])
for d, e in zip(docs, embs.data):
    d["vector"] = e.embedding

client.insert(collection_name="articles", data=docs)
client.flush(collection_name="articles")   # ensure data is persisted

# Filtered ANN search
query_vec = oa.embeddings.create(
    model="text-embedding-3-small", input=["distributed vector search"]
).data[0].embedding

results = client.search(
    collection_name="articles",
    data=[query_vec],
    filter='category == "db" and year >= 2024',   # scalar filter
    limit=3,
    output_fields=["text", "category", "year"]
)
for hits in results:
    for hit in hits:
        print(f"score=&#123;hit['distance']:.4f&#125; | &#123;hit['entity']['text']&#125;")</code></pre>
  </section>

  <!-- DiskANN for Large Scale -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">DiskANN: Billion-Scale with Disk Storage</h2>
    <p class="text-text-muted mb-4">When your collection exceeds available RAM, DiskANN stores the index on SSD while maintaining good recall and latency.</p>
    <pre class="bg-bg-card border border-border rounded-xl p-4 text-sm font-mono overflow-x-auto mb-4"><code class="text-green-400"># DiskANN index — ideal for 100M+ vectors exceeding RAM
index_params = client.prepare_index_params()
index_params.add_index(
    field_name="vector",
    index_type="DISKANN",
    metric_type="COSINE",
    params=&#123;
        "search_list_size": 100,    # higher = better recall, slower build
        "max_degree": 56,           # graph degree
        "pq_code_budget_gb": 2.0,   # budget for PQ codes in RAM
        "build_dram_budget_gb": 32.0 # RAM for build phase
    &#125;
)

# Zilliz Cloud connection (API-compatible with PyMilvus)
cloud_client = MilvusClient(
    uri="https://YOUR_CLUSTER.api.gcp-us-west1.zillizcloud.com",
    token="YOUR_ZILLIZ_API_KEY"
)
# Same SDK — just change the connection URI</code></pre>
  </section>

  <!-- Comparison Table -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">Milvus vs Qdrant vs Weaviate vs Pinecone</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm min-w-[640px]">
        <thead>
          <tr class="text-text-muted text-xs uppercase border-b border-border">
            <th class="text-left pb-3 pr-4 font-medium">Feature</th>
            <th class="text-left pb-3 pr-4 font-medium">Milvus</th>
            <th class="text-left pb-3 pr-4 font-medium">Qdrant</th>
            <th class="text-left pb-3 pr-4 font-medium">Weaviate</th>
            <th class="text-left pb-3 font-medium">Pinecone</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border text-text-muted">
          <tr><td class="py-3 pr-4 font-medium text-text">Max scale</td><td class="py-3 pr-4 text-green-500">Billion+</td><td class="py-3 pr-4">100M+</td><td class="py-3 pr-4">100M+</td><td class="py-3">100M+</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Architecture</td><td class="py-3 pr-4 text-green-500">Distributed microservices</td><td class="py-3 pr-4">Single binary / cluster</td><td class="py-3 pr-4">Single binary / cluster</td><td class="py-3">Managed</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Index types</td><td class="py-3 pr-4 text-green-500">12+ (HNSW, DiskANN, GPU)</td><td class="py-3 pr-4">HNSW, Flat</td><td class="py-3 pr-4">HNSW</td><td class="py-3">Proprietary</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">GPU support</td><td class="py-3 pr-4 text-green-500">Yes</td><td class="py-3 pr-4">No</td><td class="py-3 pr-4">No</td><td class="py-3">No</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Managed cloud</td><td class="py-3 pr-4">Zilliz Cloud</td><td class="py-3 pr-4">Qdrant Cloud</td><td class="py-3 pr-4">Weaviate Cloud</td><td class="py-3 text-green-500">Yes (serverless)</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Hybrid search</td><td class="py-3 pr-4">Yes (sparse+dense)</td><td class="py-3 pr-4 text-green-500">Yes (native sparse)</td><td class="py-3 pr-4">Yes (BM25)</td><td class="py-3">Limited</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Setup complexity</td><td class="py-3 pr-4">Medium (Kubernetes)</td><td class="py-3 pr-4 text-green-500">Low</td><td class="py-3 pr-4">Low</td><td class="py-3 text-green-500">Minimal</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Milvus Vector Database Guide" relatedTags={['ai', 'vector-database', 'embeddings', 'rag', 'distributed', 'llm']} />
</BaseLayout>
