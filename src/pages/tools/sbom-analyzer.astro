---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SbomAnalyzer from '../../components/SbomAnalyzer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a Software Bill of Materials (SBOM)?",
    answer: "An SBOM is a formal, machine-readable inventory of every software component in an application — direct dependencies, transitive dependencies, their versions, suppliers, and license information. Think of it as the ingredient list on a food package, but for software. SBOMs are increasingly required by government agencies (US Executive Order 14028), financial institutions, and enterprise procurement. They enable rapid vulnerability response: when a new CVE drops, teams with SBOMs can immediately query which of their products are affected instead of manually auditing thousands of dependencies."
  },
  {
    question: "What is the difference between CycloneDX and SPDX formats?",
    answer: "Both are open SBOM standards, but with different origins and strengths. SPDX (Software Package Data Exchange) was created by the Linux Foundation in 2010 and is an ISO/IEC standard (5962:2021). It was originally designed for license compliance and is the older, more widely implemented format. CycloneDX was created by OWASP in 2017 with a security-first focus — it supports vulnerability data, service dependencies, hardware BOMs, and ML model BOMs in addition to software packages. CycloneDX JSON is typically more compact and developer-friendly; SPDX has more tooling support in legal/compliance workflows. Both are acceptable under US government SBOM guidance. This tool auto-detects which format you paste."
  },
  {
    question: "What license compliance risks does an SBOM reveal?",
    answer: "Components with no license information (NOASSERTION or missing) are the highest risk — you cannot distribute software that includes unlicensed code without legal exposure. Copyleft licenses (GPL-2.0, GPL-3.0, AGPL-3.0) require that derivative works also be open-sourced under the same terms, which can conflict with proprietary software distribution. License incompatibilities between components can also block distribution. This tool highlights unlicensed components in red and shows a license distribution table so you can quickly spot unexpected copyleft or missing license entries."
  },
  {
    question: "How do I generate an SBOM for my project?",
    answer: "For Node.js: use 'npx @cyclonedx/cyclonedx-npm --output-format JSON > sbom.json'. For Python: use 'pip install cyclonedx-bom && cyclonedx-py -o sbom.json'. For Java/Maven: use the CycloneDX Maven plugin. For Go: use 'go install github.com/CycloneDX/cyclonedx-gomod && cyclonedx-gomod app -json -output sbom.json'. For Docker images: use 'syft image:tag -o cyclonedx-json > sbom.json' (Syft by Anchore works across languages). GitHub's Dependency Graph also exports SPDX SBOMs from the repository Security tab. Paste the output JSON into this tool to analyze it."
  }
];
---

<BaseLayout
  title="SBOM Analyzer — Validate &amp; Inspect CycloneDX / SPDX Bills of Materials"
  description="Paste a CycloneDX or SPDX SBOM JSON to analyze component counts, license distribution, and compliance gaps. Identify unlicensed components and validate format. Free, runs in browser."
  tool="SBOM Analyzer, CycloneDX Validator, SPDX Parser, Software Bill of Materials, License Compliance, SBOM Inspector, Dependency License Checker"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "SBOM Analyzer — Validate & Inspect CycloneDX / SPDX",
    "url": "https://devplaybook.cc/tools/sbom-analyzer",
    "description": "Paste a CycloneDX or SPDX SBOM JSON to analyze component counts, license distribution, and compliance gaps. Identify unlicensed components and validate format.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">SBOM Analyzer</h1>
  <p class="text-text-muted mb-4">
    Paste a <code class="font-mono bg-surface px-1 rounded text-sm">CycloneDX</code> or <code class="font-mono bg-surface px-1 rounded text-sm">SPDX</code> Software Bill of Materials JSON.
    Instantly see component counts, license distribution, and any components missing license info — a key compliance risk.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CycloneDX &amp; SPDX auto-detect</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> License breakdown</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Unlicensed component highlighting</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <SbomAnalyzer client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SBOM Analyzer" relatedTags={['security', 'devops', 'open-source', 'compliance', 'dependencies', 'developer-tools']} />
</BaseLayout>
