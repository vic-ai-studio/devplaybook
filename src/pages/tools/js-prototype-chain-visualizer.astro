---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the JavaScript prototype chain?",
    answer: "Every JavaScript object has an internal link called [[Prototype]] that points to another object (or null). When you access a property that doesn't exist directly on an object, the engine walks up this chain of linked objects until it finds the property or reaches null. This is the prototype chain — the foundation of JavaScript's inheritance model."
  },
  {
    question: "What is [[Prototype]] and how is it different from .prototype?",
    answer: "[[Prototype]] is the internal slot on every object that links it to its parent in the chain. It can be read with Object.getPrototypeOf(obj) or the non-standard __proto__ accessor. The .prototype property is different — it only exists on functions and defines the [[Prototype]] that will be assigned to objects created with new ThatFunction(). So MyClass.prototype is the object that instances will inherit from, while an instance's [[Prototype]] points to MyClass.prototype."
  },
  {
    question: "What does Object.create() do to the prototype chain?",
    answer: "Object.create(proto) creates a brand-new object whose [[Prototype]] is set to proto. This lets you set up inheritance relationships explicitly, without using classes or constructor functions. For example, Object.create(Animal.prototype) creates an object that inherits all of Animal's prototype methods. It is also how older code implemented classical inheritance before the class keyword was introduced in ES2015."
  },
  {
    question: "How does class inheritance affect the prototype chain?",
    answer: "When you write class Dog extends Animal, two prototype links are created. First, Dog.prototype.[[Prototype]] is set to Animal.prototype — so instances of Dog inherit Animal's instance methods. Second, Dog.[[Prototype]] is set to Animal itself — so Dog inherits Animal's static methods. Using extends with class is syntactic sugar over the same Object.setPrototypeOf calls you would make manually in ES5."
  },
  {
    question: "What is hasOwnProperty and when should I use it?",
    answer: "obj.hasOwnProperty(key) returns true only if key is defined directly on obj — not anywhere up the prototype chain. Use it when iterating with for...in (which walks the chain) to skip inherited properties. In modern code, prefer Object.hasOwn(obj, key) which does the same thing but works even if hasOwnProperty is shadowed on the object. You can also use Object.keys() which only returns own enumerable properties."
  },
  {
    question: "Why does the chain always end with null?",
    answer: "Object.prototype is at the top of every prototype chain for regular objects. It provides universal methods like toString(), valueOf(), and hasOwnProperty(). Its own [[Prototype]] is null, which is the sentinel that tells the property lookup engine to stop searching. If a property is not found before reaching null, the result is undefined (for property access) or a TypeError (for method calls)."
  },
];
---

<BaseLayout
  title="JS Prototype Chain Visualizer — Explore JavaScript Inheritance Online"
  description="Visualize the prototype chain for built-in JavaScript types and your own classes. See how Array, Map, Promise, Error, and custom classes link through Object.prototype to null. Runs in your browser."
  tool="JavaScript prototype chain, JS inheritance visualizer, prototype chain diagram, [[Prototype]] explorer, Object.prototype, JavaScript class inheritance, prototype-based inheritance"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "JS Prototype Chain Visualizer",
    "url": "https://devplaybook.cc/tools/js-prototype-chain-visualizer",
    "description": "Visualize the JavaScript prototype chain for built-in types and custom classes. Interactive diagram shows [[Prototype]] links, own methods, and property lookup paths.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">JS Prototype Chain Visualizer</h1>
  <p class="text-text-muted mb-4">
    Select a built-in type or define your own class to explore the full
    <code class="text-accent font-mono text-sm">[[Prototype]]</code> chain.
    Click any node to highlight the methods inherited from that level.
    Everything runs in your browser — no server involved.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Built-in types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Custom classes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Property lookup path</span>
  </div>

  <!-- Preset selector -->
  <div class="flex flex-wrap gap-2 mb-4" id="preset-btns">
    <button data-preset="Array"    class="preset-btn px-4 py-2 rounded-lg border border-border text-sm font-medium hover:border-accent hover:text-accent transition-colors">Array</button>
    <button data-preset="Map"      class="preset-btn px-4 py-2 rounded-lg border border-border text-sm font-medium hover:border-accent hover:text-accent transition-colors">Map</button>
    <button data-preset="Promise"  class="preset-btn px-4 py-2 rounded-lg border border-border text-sm font-medium hover:border-accent hover:text-accent transition-colors">Promise</button>
    <button data-preset="Error"    class="preset-btn px-4 py-2 rounded-lg border border-border text-sm font-medium hover:border-accent hover:text-accent transition-colors">Error</button>
    <button data-preset="RegExp"   class="preset-btn px-4 py-2 rounded-lg border border-border text-sm font-medium hover:border-accent hover:text-accent transition-colors">RegExp</button>
    <button data-preset="Function" class="preset-btn px-4 py-2 rounded-lg border border-border text-sm font-medium hover:border-accent hover:text-accent transition-colors">Function</button>
    <button data-preset="ClassExample" class="preset-btn px-4 py-2 rounded-lg border border-border text-sm font-medium hover:border-accent hover:text-accent transition-colors">Class Example</button>
    <button data-preset="Custom"   class="preset-btn px-4 py-2 rounded-lg border border-border text-sm font-medium hover:border-accent hover:text-accent transition-colors">Custom</button>
  </div>

  <!-- Custom textarea -->
  <div id="custom-area" class="hidden mb-4">
    <label class="text-sm font-medium block mb-2" for="custom-code">Your class definition</label>
    <textarea
      id="custom-code"
      rows="8"
      placeholder="class Animal {&#10;  constructor(name) { this.name = name; }&#10;  speak() {}&#10;  toString() { return this.name; }&#10;}&#10;&#10;class Dog extends Animal {&#10;  bark() {}&#10;  fetch() {}&#10;}"
      class="w-full px-4 py-3 rounded-xl bg-bg border border-border text-text placeholder:text-text-muted focus:outline-none focus:border-accent transition-colors font-mono text-xs resize-y"
      spellcheck="false"
    ></textarea>
    <button
      id="run-custom-btn"
      class="mt-3 px-6 py-2.5 rounded-xl bg-accent hover:bg-accent/80 text-white font-bold text-sm transition-colors"
    >
      Visualize Chain
    </button>
    <span id="custom-error" class="ml-3 text-xs text-red-400 hidden"></span>
  </div>

  <!-- Chain diagram -->
  <div
    id="chain-diagram"
    class="min-h-[200px] rounded-2xl border border-border bg-bg p-6 overflow-x-auto mb-6 flex items-center justify-center"
  >
    <p class="text-text-muted text-sm">Select a preset above to visualize the prototype chain.</p>
  </div>

  <!-- Lookup explanation panel -->
  <div id="lookup-panel" class="hidden rounded-2xl border border-border bg-bg p-5 mb-6">
    <h2 class="text-sm font-semibold mb-3 text-text">Property Lookup Path</h2>
    <div id="lookup-content" class="space-y-1 text-sm"></div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="JS Prototype Chain Visualizer" relatedTags={['javascript', 'typescript', 'frontend', 'debugging', 'oop', 'es6']} />
</BaseLayout>

<script is:inline>
  // ── Static chain data ────────────────────────────────────────────────────────
  // Each entry: { name, ownMethods[], isNull? }
  // Chain is ordered from instance → ... → Object.prototype → null

  const BUILTIN_CHAINS = {
    Array: [
      {
        name: 'Array instance [ ]',
        ownMethods: ['length (own)', '0, 1, 2 … (indices)'],
        note: 'new Array() / [] literal'
      },
      {
        name: 'Array.prototype',
        ownMethods: ['push', 'pop', 'slice', 'map', 'filter', 'reduce', 'forEach', 'find', 'indexOf', 'splice', 'sort', 'flat', 'flatMap', 'includes', 'join', 'reverse', 'fill', 'entries', 'keys', 'values'],
      },
      {
        name: 'Object.prototype',
        ownMethods: ['toString', 'valueOf', 'hasOwnProperty', 'isPrototypeOf', 'propertyIsEnumerable', 'toLocaleString'],
      },
      { name: 'null', isNull: true },
    ],
    Map: [
      {
        name: 'Map instance',
        ownMethods: ['(internal [[MapData]])'],
        note: 'new Map()'
      },
      {
        name: 'Map.prototype',
        ownMethods: ['set', 'get', 'has', 'delete', 'clear', 'forEach', 'entries', 'keys', 'values', 'size (getter)', Symbol.iterator + ' [@@iterator]'],
      },
      {
        name: 'Object.prototype',
        ownMethods: ['toString', 'valueOf', 'hasOwnProperty', 'isPrototypeOf', 'propertyIsEnumerable', 'toLocaleString'],
      },
      { name: 'null', isNull: true },
    ],
    Promise: [
      {
        name: 'Promise instance',
        ownMethods: ['(internal [[PromiseState]], [[PromiseResult]])'],
        note: 'new Promise(executor)'
      },
      {
        name: 'Promise.prototype',
        ownMethods: ['then', 'catch', 'finally', Symbol.toStringTag + ' [@@toStringTag]'],
      },
      {
        name: 'Object.prototype',
        ownMethods: ['toString', 'valueOf', 'hasOwnProperty', 'isPrototypeOf', 'propertyIsEnumerable', 'toLocaleString'],
      },
      { name: 'null', isNull: true },
    ],
    Error: [
      {
        name: 'Error instance',
        ownMethods: ['message (own)', 'stack (own)'],
        note: 'new Error("msg")'
      },
      {
        name: 'Error.prototype',
        ownMethods: ['name', 'message', 'toString', 'stack (non-standard)'],
      },
      {
        name: 'Object.prototype',
        ownMethods: ['toString', 'valueOf', 'hasOwnProperty', 'isPrototypeOf', 'propertyIsEnumerable', 'toLocaleString'],
      },
      { name: 'null', isNull: true },
    ],
    RegExp: [
      {
        name: 'RegExp instance',
        ownMethods: ['source (own)', 'flags (own)', 'lastIndex (own)'],
        note: '/pattern/flags or new RegExp()'
      },
      {
        name: 'RegExp.prototype',
        ownMethods: ['exec', 'test', 'toString', 'compile (legacy)', Symbol.match + ' [@@match]', Symbol.replace + ' [@@replace]', Symbol.search + ' [@@search]', Symbol.split + ' [@@split]'],
      },
      {
        name: 'Object.prototype',
        ownMethods: ['toString', 'valueOf', 'hasOwnProperty', 'isPrototypeOf', 'propertyIsEnumerable', 'toLocaleString'],
      },
      { name: 'null', isNull: true },
    ],
    Function: [
      {
        name: 'Function instance',
        ownMethods: ['name (own)', 'length (own)', 'prototype (own)'],
        note: 'function foo(){} / ()=>{}'
      },
      {
        name: 'Function.prototype',
        ownMethods: ['call', 'apply', 'bind', 'toString', Symbol.hasInstance + ' [@@hasInstance]'],
      },
      {
        name: 'Object.prototype',
        ownMethods: ['toString', 'valueOf', 'hasOwnProperty', 'isPrototypeOf', 'propertyIsEnumerable', 'toLocaleString'],
      },
      { name: 'null', isNull: true },
    ],
    ClassExample: [
      {
        name: 'dog  (Dog instance)',
        ownMethods: ['name (own)', 'breed (own)'],
        note: 'new Dog("Rex", "Lab")'
      },
      {
        name: 'Dog.prototype',
        ownMethods: ['constructor', 'bark', 'fetch'],
      },
      {
        name: 'Animal.prototype',
        ownMethods: ['constructor', 'speak', 'eat', 'toString'],
      },
      {
        name: 'Object.prototype',
        ownMethods: ['toString', 'valueOf', 'hasOwnProperty', 'isPrototypeOf', 'propertyIsEnumerable', 'toLocaleString'],
      },
      { name: 'null', isNull: true },
    ],
  };

  const MAX_METHODS_SHOWN = 6;

  // ── Colours per depth ────────────────────────────────────────────────────────
  const DEPTH_COLORS = [
    { border: '#6366f1', bg: 'rgba(99,102,241,0.08)', label: '#a5b4fc' },
    { border: '#06b6d4', bg: 'rgba(6,182,212,0.08)',  label: '#67e8f9' },
    { border: '#10b981', bg: 'rgba(16,185,129,0.08)', label: '#6ee7b7' },
    { border: '#f59e0b', bg: 'rgba(245,158,11,0.08)', label: '#fcd34d' },
    { border: '#ec4899', bg: 'rgba(236,72,153,0.08)', label: '#f9a8d4' },
  ];

  function depthColor(i) {
    return DEPTH_COLORS[i % DEPTH_COLORS.length];
  }

  // ── Render ───────────────────────────────────────────────────────────────────
  function renderChain(chain, highlightIndex) {
    const diagram = document.getElementById('chain-diagram');
    const lookupPanel = document.getElementById('lookup-panel');
    const lookupContent = document.getElementById('lookup-content');

    let html = '<div class="flex flex-wrap items-center gap-1 min-w-0">';

    chain.forEach((node, i) => {
      const c = depthColor(i);
      const isHighlighted = highlightIndex === i;

      if (node.isNull) {
        html += `
          <div class="flex items-center gap-1 shrink-0">
            <div class="chain-arrow text-text-muted text-lg select-none">→</div>
            <div
              class="chain-node rounded-xl px-4 py-3 cursor-default select-none"
              style="border:1px solid #4b5563; background:rgba(75,85,99,0.1);"
            >
              <div class="font-mono text-xs font-bold text-gray-400">null</div>
              <div class="text-xs text-gray-500 mt-1">end of chain</div>
            </div>
          </div>`;
        return;
      }

      const methods = node.ownMethods || [];
      const shown = methods.slice(0, MAX_METHODS_SHOWN);
      const hidden = methods.length - shown.length;

      const borderStyle = isHighlighted
        ? `border:2px solid ${c.border}; box-shadow: 0 0 0 3px ${c.border}33;`
        : `border:1px solid ${c.border}55;`;

      html += `
        <div class="flex items-center gap-1 shrink-0">
          ${i > 0 ? `<div class="chain-arrow text-text-muted text-lg select-none px-1">→</div>` : ''}
          <div
            class="chain-node rounded-xl px-4 py-3 cursor-pointer transition-all duration-150 hover:scale-[1.02]"
            style="${borderStyle} background:${c.bg}; min-width:160px; max-width:220px;"
            data-index="${i}"
          >
            <div class="font-mono text-xs font-bold mb-2 truncate" style="color:${c.label};" title="${escHtml(node.name)}">${escHtml(node.name)}</div>
            ${node.note ? `<div class="text-xs text-text-muted mb-2 italic">${escHtml(node.note)}</div>` : ''}
            <ul class="space-y-0.5">
              ${shown.map(m => `<li class="text-xs text-text-muted font-mono truncate" title="${escHtml(String(m))}">${escHtml(String(m))}</li>`).join('')}
              ${hidden > 0 ? `<li class="text-xs text-text-muted/60">+${hidden} more</li>` : ''}
            </ul>
          </div>
        </div>`;
    });

    html += '</div>';
    diagram.innerHTML = html;

    // Click handlers
    diagram.querySelectorAll('.chain-node[data-index]').forEach(el => {
      el.addEventListener('click', () => {
        const idx = parseInt(el.getAttribute('data-index'), 10);
        renderChain(chain, idx);
        renderLookupPanel(chain, idx);
      });
    });

    // Lookup panel
    if (highlightIndex !== null && highlightIndex !== undefined) {
      renderLookupPanel(chain, highlightIndex);
    }
  }

  function renderLookupPanel(chain, highlightIndex) {
    const panel = document.getElementById('lookup-panel');
    const content = document.getElementById('lookup-content');
    panel.classList.remove('hidden');

    const node = chain[highlightIndex];
    if (!node || node.isNull) {
      content.innerHTML = '<p class="text-text-muted text-xs">null — property lookup stops here.</p>';
      return;
    }

    const c = depthColor(highlightIndex);
    const methods = node.ownMethods || [];

    let html = `<p class="text-text-muted text-xs mb-3">
      Properties found at <span class="font-mono font-bold" style="color:${c.label}">${escHtml(node.name)}</span>
      (depth ${highlightIndex}).
      When you access one of these, the engine stops searching here.
    </p>`;

    if (highlightIndex > 0) {
      html += `<p class="text-text-muted text-xs mb-3">
        To reach this level, the engine walked up ${highlightIndex} link${highlightIndex > 1 ? 's' : ''}:
        ${chain.slice(0, highlightIndex).map((n, i) => `<span class="font-mono" style="color:${depthColor(i).label}">${escHtml(n.name)}</span>`).join(' → ')} → <span class="font-mono font-bold" style="color:${c.label}">${escHtml(node.name)}</span>
      </p>`;
    }

    html += `<div class="flex flex-wrap gap-1.5">`;
    methods.forEach(m => {
      html += `<span class="px-2 py-0.5 rounded font-mono text-xs" style="background:${c.bg}; border:1px solid ${c.border}55; color:${c.label}">${escHtml(String(m))}</span>`;
    });
    html += '</div>';

    content.innerHTML = html;
  }

  // ── Custom class walker ──────────────────────────────────────────────────────
  function buildCustomChain(code) {
    // Evaluate the code in a controlled scope and extract the last class defined.
    // We use Function constructor to avoid direct eval at global scope.
    let classes = [];
    const patchedCode = code + `\n__classes__ = [${extractClassNames(code).join(',')}];`;
    let captured = [];
    try {
      const fn = new Function('__classes__ref', patchedCode.replace('__classes__', '__classes__ref'));
      // Can't pass by ref easily; use a different approach
      throw new Error('retry');
    } catch (_) {
      // Fallback: just eval the code + pull class names
      try {
        const names = extractClassNames(code);
        if (!names.length) throw new Error('No class definitions found.');
        // Build a function that returns an array of constructors
        const wrapper = new Function(`${code}\nreturn [${names.join(',')}];`);
        captured = wrapper();
      } catch (e) {
        throw new Error(e.message);
      }
    }

    // Find the "deepest" class (one that is not a base of another)
    // i.e. pick the last class that extends something, otherwise just the last
    const target = captured[captured.length - 1];

    // Walk the prototype chain of the constructor's prototype
    const chain = [];
    let proto = target.prototype;
    const visitedNames = new Set();

    while (proto !== null) {
      const name = proto.constructor && proto.constructor.name ? proto.constructor.name + '.prototype' : '(anonymous).prototype';
      if (visitedNames.has(name)) break;
      visitedNames.add(name);

      const ownKeys = Object.getOwnPropertyNames(proto).filter(k => k !== '__proto__');
      chain.push({
        name,
        ownMethods: ownKeys.slice(0, 12),
        note: proto.constructor === target ? `new ${target.name}(...)` : undefined,
      });
      proto = Object.getPrototypeOf(proto);
    }

    chain.push({ name: 'null', isNull: true });
    // Prepend instance node
    chain.unshift({
      name: `${target.name} instance`,
      ownMethods: ['(own properties set in constructor)'],
      note: `new ${target.name}(...)`,
    });

    return chain;
  }

  function extractClassNames(code) {
    const matches = [...code.matchAll(/\bclass\s+([A-Za-z_$][A-Za-z0-9_$]*)/g)];
    return matches.map(m => m[1]);
  }

  // ── Active preset state ──────────────────────────────────────────────────────
  let activeChain = null;

  function setActivePreset(name) {
    document.querySelectorAll('.preset-btn').forEach(btn => {
      const isActive = btn.getAttribute('data-preset') === name;
      btn.classList.toggle('border-accent', isActive);
      btn.classList.toggle('text-accent', isActive);
      btn.classList.toggle('bg-accent/10', isActive);
    });
  }

  // ── Wire presets ─────────────────────────────────────────────────────────────
  document.querySelectorAll('.preset-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const preset = btn.getAttribute('data-preset');
      setActivePreset(preset);

      const customArea = document.getElementById('custom-area');
      const lookupPanel = document.getElementById('lookup-panel');

      if (preset === 'Custom') {
        customArea.classList.remove('hidden');
        document.getElementById('chain-diagram').innerHTML =
          '<p class="text-text-muted text-sm">Define your classes above and click Visualize Chain.</p>';
        lookupPanel.classList.add('hidden');
        return;
      }

      customArea.classList.add('hidden');
      const chain = BUILTIN_CHAINS[preset];
      if (!chain) return;
      activeChain = chain;
      renderChain(chain, null);
      lookupPanel.classList.add('hidden');
    });
  });

  // ── Custom run button ────────────────────────────────────────────────────────
  document.getElementById('run-custom-btn').addEventListener('click', () => {
    const code = document.getElementById('custom-code').value.trim();
    const errEl = document.getElementById('custom-error');
    errEl.classList.add('hidden');

    if (!code) {
      errEl.textContent = 'Paste a class definition first.';
      errEl.classList.remove('hidden');
      return;
    }

    try {
      const chain = buildCustomChain(code);
      activeChain = chain;
      renderChain(chain, null);
      document.getElementById('lookup-panel').classList.add('hidden');
    } catch (e) {
      errEl.textContent = 'Error: ' + e.message;
      errEl.classList.remove('hidden');
    }
  });

  function escHtml(s) {
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }
</script>
