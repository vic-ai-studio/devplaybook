---
import BaseLayout from '../../layouts/BaseLayout.astro';
import KyselyQueryBuilder from '../../components/KyselyQueryBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Kysely?",
    answer: "Kysely is a type-safe TypeScript SQL query builder. Unlike ORMs, Kysely doesn't abstract away SQL — you write queries that look like SQL but get full TypeScript inference on column names, return types, and parameters. It works with PostgreSQL, MySQL, SQLite, and more. If your database schema is typed (via Database interface), Kysely will catch column name typos at compile time."
  },
  {
    question: "How does Kysely differ from Prisma or Drizzle?",
    answer: "Prisma generates a client from your schema and abstracts SQL behind a JavaScript API. Drizzle is also a type-safe query builder but uses a schema-declaration-first approach. Kysely is closer to raw SQL — you write .selectFrom().where().execute() chains, which makes it great for complex queries. Kysely also has a lighter runtime footprint than Prisma and doesn't require code generation."
  },
  {
    question: "How do I set up the Kysely database instance?",
    answer: "Install kysely and a dialect: npm install kysely pg (for PostgreSQL). Create a db.ts file: import { Kysely, PostgresDialect } from 'kysely'; import { Pool } from 'pg'; export const db = new Kysely<Database>({ dialect: new PostgresDialect({ pool: new Pool({ connectionString: process.env.DATABASE_URL }) }) }); The Database interface maps table names to their TypeScript row types — the generated types tab shows you the structure."
  },
  {
    question: "What is the Database interface?",
    answer: "The Database interface is the type-level schema Kysely uses to infer column names and return types. Each key is a table name, and the value is an interface describing the columns. Kysely uses Generated<T> for auto-increment columns, Selectable<T> / Insertable<T> / Updateable<T> utility types to derive variants for each use case. This tool generates the base table interface — add it to your central Database type."
  },
  {
    question: "What is the Generated<T> type for?",
    answer: "Generated<T> marks a column as auto-generated by the database (e.g. SERIAL / AUTO_INCREMENT id columns, default timestamps). When you insert a row, you don't provide these columns. Kysely's Insertable<T> utility automatically makes Generated<T> columns optional so TypeScript doesn't require them on insert while still returning them on select."
  },
  {
    question: "Can I use Kysely with Edge runtimes or serverless?",
    answer: "Yes — Kysely supports multiple dialects. For Cloudflare Workers and edge environments, use kysely-d1 (Cloudflare D1) or the neon-http dialect for Neon Postgres over HTTP. For PlanetScale, use kysely-planetscale. For local SQLite in Bun or Node.js, use the built-in SqliteDialect with better-sqlite3. The core query builder is dialect-agnostic."
  },
];
---

<BaseLayout
  title="Kysely Query Builder — Type-Safe TypeScript SQL Generator"
  description="Build type-safe Kysely queries visually. Add WHERE, JOIN, ORDER BY, and pagination — generates TypeScript Kysely code and Database interfaces. Free."
  tool="kysely query builder, kysely typescript sql, type-safe sql generator, kysely selectFrom"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Kysely Query Builder",
    "url": "https://devplaybook.cc/tools/kysely-query-builder",
    "description": "Build type-safe SQL queries with Kysely TypeScript query builder. Visual interface for SELECT, WHERE, JOIN, ORDER BY, and pagination.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Kysely Query Builder</h1>
  <p class="text-text-muted mb-4">
    Build <strong>type-safe Kysely queries</strong> visually. Configure your table, select columns with optional aggregates,
    add WHERE conditions, JOINs, ORDER BY, and pagination — then get complete
    <code class="font-mono bg-surface px-1 rounded text-sm">await db.selectFrom()</code> code
    and TypeScript <code class="font-mono bg-surface px-1 rounded text-sm">Database</code> interface ready to drop in.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> SELECT / WHERE / JOIN</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Aggregate functions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript DB interface</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <KyselyQueryBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Kysely Query Builder" relatedTags={['database', 'typescript', 'sql', 'postgresql', 'developer-tools']} />
</BaseLayout>
