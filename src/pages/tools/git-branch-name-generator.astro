---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GitBranchNameGenerator from '../../components/GitBranchNameGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a good Git branch naming convention?", answer: "A common convention is type/description — for example feature/user-auth, bugfix/login-crash, hotfix/payment-null-ref. Using a prefix makes branches easy to scan in a branch list and enables automation (auto-labeling PRs, status dashboards). GitFlow popularized this pattern." },
  { question: "What characters are allowed in Git branch names?", answer: "Git allows most characters except spaces, ~, ^, :, ?, *, [, \\, and control characters. Dots are allowed but branch names can't start with a dot or end with .lock. Best practice: stick to lowercase letters, numbers, and hyphens for maximum compatibility with all tools and shells." },
  { question: "Should I include the ticket number in a branch name?", answer: "Yes — including the JIRA/GitHub ticket ID (e.g. feature/JIRA-123-add-oauth) links your branch to the issue automatically in most project management tools. GitHub, GitLab, and Linear can auto-link PRs to issues when the branch name contains the issue identifier." },
  { question: "What is the difference between feature, bugfix, and hotfix branches?", answer: "Feature branches (feature/) are for new functionality. Bugfix branches (bugfix/) fix non-critical bugs in development. Hotfix branches (hotfix/) are urgent fixes applied directly to production — they typically branch from main/master rather than develop. This distinction helps teams understand priority and merge targets." },
  { question: "How long should a Git branch name be?", answer: "Keep branch names under 60–80 characters. Longer names are hard to read in terminal output, PR titles, and some git UI tools. Focus on the key action: what is changing? Use kebab-case for readability. Avoid abbreviations that are not universally understood by your team." },
];
---

<BaseLayout
  title="Git Branch Name Generator — Free Online Tool"
  description="Generate clean Git branch names from ticket descriptions. Select your convention (feature/, bugfix/, hotfix/), auto-extract ticket IDs, and copy the branch name or git checkout command. Free, runs in your browser."
  tool="Git Branch Name Generator, Git Branch Convention, Feature Branch Naming, JIRA Git Branch, Kebab Case Branch"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Git Branch Name Generator</h1>
  <p class="text-text-muted mb-4">Turn ticket descriptions into clean, kebab-case Git branch names. Auto-detects ticket IDs (JIRA-123, VIC-456…), supports all common conventions (feature/, bugfix/, hotfix/, chore/, docs/), and copies the git checkout command with one click.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <GitBranchNameGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Git Branch Name Generator" relatedTags={['git', 'workflow', 'productivity', 'developer-tools', 'naming']} />
</BaseLayout>
