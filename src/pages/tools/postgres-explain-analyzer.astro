---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostgresExplainAnalyzer from '../../components/PostgresExplainAnalyzer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is EXPLAIN ANALYZE in PostgreSQL?", answer: "EXPLAIN shows the query planner's execution plan — the strategy PostgreSQL will use to execute your query. EXPLAIN ANALYZE actually runs the query and shows real timing and row counts alongside the estimates. Always use EXPLAIN ANALYZE for performance tuning." },
  { question: "What does 'cost' mean in a PostgreSQL plan?", answer: "Cost is a unitless estimate based on disk I/O and CPU operations. It has two parts: startup cost (work before the first row is returned) and total cost (work to return all rows). Lower total cost generally means a faster query, but cost doesn't map directly to milliseconds." },
  { question: "What is a Seq Scan and why is it slow?", answer: "A Sequential Scan reads every row in a table from start to finish. It's fast for small tables or when you need most rows, but slow on large tables with selective WHERE filters. The analyzer will flag Seq Scans on tables with many estimated rows and suggest adding an index." },
  { question: "What is the difference between Index Scan and Index Only Scan?", answer: "Index Scan follows the index to find matching rows, then fetches those rows from the heap (table storage). Index Only Scan returns all needed data directly from the index without touching the heap — much faster when your query only needs indexed columns." },
  { question: "Why does my query have a high cost node?", answer: "Nodes are colored by their percentage of the maximum cost in the plan. Red nodes (>70%) are your biggest bottlenecks. Common causes: missing indexes, large sequential scans, expensive sorts, or nested loops on large datasets." },
  { question: "Is my query data sent to any server?", answer: "No. This tool runs entirely in your browser. Your SQL queries and query plans never leave your machine." },
];
---

<BaseLayout
  title="PostgreSQL EXPLAIN Analyzer — Visualize Query Plans Free"
  description="Paste PostgreSQL EXPLAIN or EXPLAIN ANALYZE output and get a visual cost breakdown with node labels, optimization suggestions, and actual vs estimated rows. Free, runs in browser."
  tool="PostgreSQL EXPLAIN analyzer, postgres query plan visualizer, EXPLAIN ANALYZE tool, postgres performance, query optimizer"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "PostgreSQL EXPLAIN Analyzer",
    "url": "https://devplaybook.cc/tools/postgres-explain-analyzer",
    "description": "Visualize PostgreSQL EXPLAIN ANALYZE output with cost breakdowns, node type labels, and optimization suggestions.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">PostgreSQL EXPLAIN Analyzer</h1>
  <p class="text-text-muted mb-4">
    Paste <code class="font-mono bg-surface px-1 rounded text-sm">EXPLAIN</code> or <code class="font-mono bg-surface px-1 rounded text-sm">EXPLAIN ANALYZE</code> output and get a visual breakdown of each node's cost, actual timing, row estimates, and optimization suggestions. Runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Visual cost breakdown per node</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Optimization suggestions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Actual vs estimated rows</span>
  </div>
  <PostgresExplainAnalyzer client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="PostgreSQL EXPLAIN Analyzer" relatedTags={['postgresql', 'database', 'sql', 'performance', 'developer-tools']} />
</BaseLayout>
