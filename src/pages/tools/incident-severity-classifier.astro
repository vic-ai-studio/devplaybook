---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the difference between P0 and P1 incidents?", answer: "P0 (Critical) incidents represent complete service outages affecting all users or causing data loss/corruption — requiring immediate all-hands response within 15 minutes. P1 (High) incidents are major degradations affecting a significant portion of users or critical business functions, requiring response within 30 minutes. The key distinction is scope and reversibility: P0 impacts are immediate, widespread, and potentially irreversible." },
  { question: "How should blast radius factor into severity classification?", answer: "Blast radius measures how many services, teams, or customers are affected. A single microservice failure isolated to one team is low blast radius; a shared authentication service failure is extremely high. When blast radius is high, escalate the severity by at least one level regardless of other factors, because cascading failures can rapidly worsen the situation." },
  { question: "When is a workaround sufficient to lower incident severity?", answer: "A workaround can justify reducing severity by one level only if: it is documented, reproducible, doesn't require special access, and the customer experience degradation is minimal. If the workaround requires customers to change their behavior significantly or affects SLA-covered functionality, it should not reduce severity." },
  { question: "What should the escalation path look like for a P0 incident?", answer: "P0 escalation should follow: on-call engineer → on-call manager (within 5 min) → VP Engineering (within 15 min) → CTO/CEO for prolonged outages (>30 min). A dedicated incident commander should be assigned to coordinate communication, separate from the engineers actively debugging. War room / dedicated channel should be opened immediately." },
  { question: "How do you calculate revenue impact per hour for severity scoring?", answer: "Revenue impact per hour = (annual revenue / 8760 hours) × affected percentage. For customer-facing services, also include indirect costs: SLA penalties, customer churn risk, support ticket volume. For internal tools, use productivity loss: (average engineer hourly cost × engineers blocked). Document your baseline so you can make consistent severity decisions under pressure." },
];
---

<BaseLayout
  title="Incident Severity Classifier — P0/P1/P2/P3/P4 Calculator"
  description="Classify incident severity from P0 to P4 based on customer impact, blast radius, revenue loss, and service criticality. Get response SLAs, escalation paths, and recommended actions."
  tool="Incident Severity Classifier, P0 P1 P2 Incident Calculator, Incident Response SLA, Blast Radius Calculator, On-Call Escalation Tool"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Incident Severity Classifier</h1>
  <p class="text-text-muted mb-4">Classify incidents from P0 to P4 based on impact, blast radius, and business criticality. Get response SLAs, escalation paths, and recommended actions instantly.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> P0–P4 severity classification</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Response SLA & escalation path</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Recommended remediation actions</span>
  </div>

  <!-- Impact Inputs -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Incident Impact</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Affected Users</label>
        <input id="affected-users" type="number" value="5000" min="0"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Revenue Impact ($/hour)</label>
        <input id="revenue-impact" type="number" value="10000" min="0"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Number of Affected Services</label>
        <input id="affected-services" type="number" value="3" min="1" max="100"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Customer-Facing Service?</label>
        <select id="customer-facing" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="yes">Yes</option>
          <option value="no">No</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Data Loss Involved?</label>
        <select id="data-loss" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="no">No</option>
          <option value="yes">Yes</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Workaround Available?</label>
        <select id="workaround" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="no">No</option>
          <option value="yes">Yes</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Results -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Classification Result</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-5">
      <div class="bg-bg-card border border-border rounded-lg p-3 text-center">
        <div id="severity-level" class="text-2xl font-bold text-primary mb-1">P1</div>
        <div class="text-xs text-text-muted">Severity Level</div>
      </div>
      <div class="bg-bg-card border border-border rounded-lg p-3 text-center">
        <div id="response-sla" class="text-2xl font-bold text-primary mb-1">30m</div>
        <div class="text-xs text-text-muted">Response SLA</div>
      </div>
      <div class="bg-bg-card border border-border rounded-lg p-3 text-center">
        <div id="oncall-req" class="text-2xl font-bold text-primary mb-1">Yes</div>
        <div class="text-xs text-text-muted">On-Call Required</div>
      </div>
      <div class="bg-bg-card border border-border rounded-lg p-3 text-center">
        <div id="score-display" class="text-2xl font-bold text-primary mb-1">72</div>
        <div class="text-xs text-text-muted">Impact Score</div>
      </div>
    </div>
    <div id="escalation-path" class="bg-bg-card border border-border rounded-lg p-4 mb-3 text-sm"></div>
    <div id="recommended-actions" class="bg-bg-card border border-border rounded-lg p-4 text-sm"></div>
  </div>

  <!-- Severity Reference -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-3">Severity Reference</h2>
    <div id="severity-table" class="overflow-x-auto"></div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Incident Severity Classifier" relatedTags={['devops', 'sre', 'incident', 'oncall', 'reliability']} />
</BaseLayout>

<script>
  function getVal(id: string): number {
    return parseFloat((document.getElementById(id) as HTMLInputElement).value) || 0;
  }
  function getSel(id: string): string {
    return (document.getElementById(id) as HTMLSelectElement).value;
  }

  function calculate() {
    const affectedUsers = getVal('affected-users');
    const revenuePerHour = getVal('revenue-impact');
    const affectedServices = getVal('affected-services');
    const customerFacing = getSel('customer-facing') === 'yes';
    const dataLoss = getSel('data-loss') === 'yes';
    const workaround = getSel('workaround') === 'yes';

    // Score components (0-100)
    let score = 0;

    // User impact (0-30)
    if (affectedUsers >= 100000) score += 30;
    else if (affectedUsers >= 10000) score += 24;
    else if (affectedUsers >= 1000) score += 18;
    else if (affectedUsers >= 100) score += 10;
    else score += 4;

    // Revenue impact (0-25)
    if (revenuePerHour >= 100000) score += 25;
    else if (revenuePerHour >= 10000) score += 20;
    else if (revenuePerHour >= 1000) score += 13;
    else if (revenuePerHour >= 100) score += 7;
    else score += 2;

    // Blast radius / services (0-20)
    if (affectedServices >= 10) score += 20;
    else if (affectedServices >= 5) score += 15;
    else if (affectedServices >= 3) score += 10;
    else score += 4;

    // Customer facing (0-10)
    if (customerFacing) score += 10;

    // Data loss (0-15)
    if (dataLoss) score += 15;

    // Workaround reduces score
    if (workaround) score = Math.max(0, score - 10);

    // Map score to severity
    let severity: string, color: string, responseSla: string, oncall: string;
    if (score >= 80 || dataLoss) {
      severity = 'P0'; color = 'text-red-500'; responseSla = '15m'; oncall = 'Mandatory';
    } else if (score >= 60) {
      severity = 'P1'; color = 'text-orange-500'; responseSla = '30m'; oncall = 'Required';
    } else if (score >= 35) {
      severity = 'P2'; color = 'text-yellow-500'; responseSla = '2h'; oncall = 'Notify';
    } else if (score >= 15) {
      severity = 'P3'; color = 'text-blue-400'; responseSla = '8h'; oncall = 'Next shift';
    } else {
      severity = 'P4'; color = 'text-text-muted'; responseSla = '24h'; oncall = 'No';
    }

    document.getElementById('severity-level')!.textContent = severity;
    document.getElementById('severity-level')!.className = `text-2xl font-bold mb-1 ${color}`;
    document.getElementById('response-sla')!.textContent = responseSla;
    document.getElementById('oncall-req')!.textContent = oncall;
    document.getElementById('score-display')!.textContent = String(score);

    const escalationPaths: Record<string, string> = {
      P0: '🔴 <strong>P0 Escalation:</strong> On-call Engineer → On-call Manager (5 min) → VP Engineering (15 min) → CTO (30 min). Open war room channel. Page all stakeholders now.',
      P1: '🟠 <strong>P1 Escalation:</strong> On-call Engineer → On-call Manager (15 min) → Engineering Lead (30 min). Create incident channel and post status update.',
      P2: '🟡 <strong>P2 Escalation:</strong> On-call Engineer → Team Lead (1 hour). Post in team Slack channel. Schedule follow-up review.',
      P3: '🔵 <strong>P3 Escalation:</strong> Assign to next available engineer. Track in issue tracker. No immediate escalation required.',
      P4: '⚪ <strong>P4 Escalation:</strong> Create ticket. Prioritize in next sprint. No escalation needed.',
    };

    const actions: Record<string, string[]> = {
      P0: ['Declare incident immediately and assign Incident Commander', 'Page all on-call engineers and open war room', 'Post customer-facing status page update within 5 minutes', 'Enable circuit breakers / rollback if possible', 'Start 5-minute update cadence in incident channel', 'Prepare executive summary every 30 minutes'],
      P1: ['Assign incident lead and open dedicated Slack channel', 'Page on-call team and relevant service owners', 'Assess rollback viability', 'Update status page with investigation notice', 'Set 15-minute check-in cadence'],
      P2: ['Assign to on-call engineer', 'Investigate root cause, check recent deploys and config changes', 'Notify affected team leads via Slack', 'Post internal status update', 'Consider partial rollback if root cause found'],
      P3: ['Create detailed issue ticket', 'Investigate during business hours', 'Document impact and workaround', 'Schedule fix for next sprint'],
      P4: ['Log issue in tracker', 'Investigate when bandwidth allows', 'No immediate communication required'],
    };

    document.getElementById('escalation-path')!.innerHTML = escalationPaths[severity] || '';
    document.getElementById('recommended-actions')!.innerHTML = `
      <div class="font-medium mb-2">Recommended Actions</div>
      <ul class="space-y-1 text-text-muted">
        ${(actions[severity] || []).map(a => `<li class="flex items-start gap-2"><span class="mt-0.5 text-green-500">→</span><span>${a}</span></li>`).join('')}
      </ul>
    `;

    // Severity reference table
    const levels = [
      { p: 'P0', name: 'Critical', color: 'text-red-500', sla: '15 min', desc: 'Complete outage, data loss, all users affected', oncall: 'Mandatory all-hands' },
      { p: 'P1', name: 'High', color: 'text-orange-500', sla: '30 min', desc: 'Major degradation, large user segment affected', oncall: 'On-call required' },
      { p: 'P2', name: 'Medium', color: 'text-yellow-500', sla: '2 hours', desc: 'Partial outage, workaround available, small segment', oncall: 'Notify on-call' },
      { p: 'P3', name: 'Low', color: 'text-blue-400', sla: '8 hours', desc: 'Minor degradation, minimal user impact', oncall: 'Next shift' },
      { p: 'P4', name: 'Info', color: 'text-text-muted', sla: '24 hours', desc: 'Cosmetic issue, single user report', oncall: 'Not required' },
    ];
    document.getElementById('severity-table')!.innerHTML = `
      <table class="w-full text-sm min-w-[500px]">
        <thead><tr class="text-text-muted text-xs uppercase border-b border-border">
          <th class="text-left pb-2 pr-4">Level</th>
          <th class="text-left pb-2 pr-4">Name</th>
          <th class="text-left pb-2 pr-4">Response SLA</th>
          <th class="text-left pb-2 pr-4">Description</th>
          <th class="text-left pb-2">On-Call</th>
        </tr></thead>
        <tbody class="divide-y divide-border">
          ${levels.map(l => `<tr class="${l.p === severity ? 'bg-primary/5' : ''}">
            <td class="py-2.5 pr-4 font-bold ${l.color}">${l.p}</td>
            <td class="py-2.5 pr-4 font-medium">${l.name}</td>
            <td class="py-2.5 pr-4 font-mono">${l.sla}</td>
            <td class="py-2.5 pr-4 text-text-muted">${l.desc}</td>
            <td class="py-2.5 text-text-muted">${l.oncall}</td>
          </tr>`).join('')}
        </tbody>
      </table>
    `;
  }

  document.querySelectorAll('input, select').forEach(el => el.addEventListener('input', calculate));
  calculate();
</script>
