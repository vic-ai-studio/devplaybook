---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Zod and why use it for schema validation?", answer: "Zod is a TypeScript-first schema validation library that lets you define the shape of your data declaratively. It infers TypeScript types from the schema (no duplication), validates at runtime, and generates helpful error messages. It's widely used in tRPC, Next.js, React Hook Form, and most modern TypeScript stacks." },
  { question: "How does TypeScript type inference work with Zod?", answer: "With `const schema = z.object({ name: z.string() })`, you get the TypeScript type via `type User = z.infer<typeof schema>`. This means you define your schema once and get both runtime validation AND compile-time type checking from the same source — the single source of truth pattern." },
  { question: "When should I use z.string().email() vs z.string()?", answer: "Use the more specific validator whenever possible. z.string().email() validates that the string is a valid email format, z.string().url() validates URLs, z.string().uuid() validates UUIDs, z.string().min(1) prevents empty strings. More specific validators catch data quality issues earlier and generate better error messages." },
  { question: "What is a factory function pattern for mock data?", answer: "A factory function creates a new object with realistic-looking data each time it's called. Pattern: `function createUser(overrides = {}) { return { id: uuid(), name: 'Alice Chen', ...overrides }; }`. You can call it as `createUser()` for a full mock or `createUser({ name: 'Bob' })` to override specific fields in tests." },
  { question: "Can I use this tool with Prisma or Drizzle ORM schemas?", answer: "The generated TypeScript types are compatible with any ORM or database layer. For Prisma, you'd typically use Zod alongside Prisma-generated types for input validation. Libraries like `zod-prisma-types` or `prisma-zod-generator` can automatically generate Zod schemas from your Prisma schema file." },
];

const SAMPLE = JSON.stringify({
  id: "usr_abc123",
  name: "Alice Chen",
  email: "alice@example.com",
  age: 29,
  isPremium: true,
  score: 98.5,
  tags: ["developer", "designer"],
  address: {
    street: "123 Main St",
    city: "San Francisco",
    country: "US",
    zip: "94102"
  },
  createdAt: "2024-01-15T10:30:00Z",
  metadata: null
}, null, 2);
---

<BaseLayout
  title="Mock Data Schema Builder — TypeScript Types, Zod Schema & Factory Functions"
  description="Generate TypeScript interfaces, Zod schemas, and mock factory functions from any JSON object. Client-side inference, no dependencies required."
  tool="TypeScript Schema Generator, Zod Schema Builder, Mock Data Factory, JSON to TypeScript, JSON to Zod"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Mock Data Schema Builder</h1>
  <p class="text-text-muted mb-4">Paste any JSON object to instantly generate a TypeScript type definition, Zod validation schema, and a mock factory function with realistic data.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript type inference</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Zod schema generation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Mock factory function</span>
  </div>

  <!-- Input -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <div class="flex justify-between items-center mb-2">
      <label class="text-sm font-medium">JSON Object</label>
      <div class="flex gap-3">
        <input id="mds-typename" type="text" value="MyType" placeholder="Type name"
          class="bg-bg-card border border-border rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:border-primary font-mono w-32" />
        <button id="mds-generate" class="bg-primary text-white rounded-lg px-4 py-1.5 text-sm font-semibold hover:opacity-90 transition-opacity">Generate</button>
      </div>
    </div>
    <textarea id="mds-input" rows="12"
      class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono resize-y"
    ></textarea>
    <div id="mds-error" class="text-sm text-red-500 mt-2 hidden"></div>
  </div>

  <!-- Output Tabs -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <div class="flex gap-1 mb-4 border-b border-border">
      <button class="mds-tab px-4 py-2 text-sm font-medium rounded-t-lg border-b-2 border-primary text-primary" data-tab="ts">TypeScript</button>
      <button class="mds-tab px-4 py-2 text-sm font-medium rounded-t-lg border-b-2 border-transparent text-text-muted hover:text-primary" data-tab="zod">Zod Schema</button>
      <button class="mds-tab px-4 py-2 text-sm font-medium rounded-t-lg border-b-2 border-transparent text-text-muted hover:text-primary" data-tab="mock">Mock Factory</button>
    </div>
    <div id="mds-tab-ts" class="mds-tab-panel">
      <div class="flex justify-between items-center mb-2">
        <span class="text-xs text-text-muted font-mono">typescript</span>
        <button class="mds-copy text-xs text-primary hover:underline" data-target="out-ts">Copy</button>
      </div>
      <pre id="out-ts" class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto whitespace-pre-wrap text-text-muted">Enter JSON and click Generate</pre>
    </div>
    <div id="mds-tab-zod" class="mds-tab-panel hidden">
      <div class="flex justify-between items-center mb-2">
        <span class="text-xs text-text-muted font-mono">typescript</span>
        <button class="mds-copy text-xs text-primary hover:underline" data-target="out-zod">Copy</button>
      </div>
      <pre id="out-zod" class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto whitespace-pre-wrap text-text-muted">Enter JSON and click Generate</pre>
    </div>
    <div id="mds-tab-mock" class="mds-tab-panel hidden">
      <div class="flex justify-between items-center mb-2">
        <span class="text-xs text-text-muted font-mono">typescript</span>
        <button class="mds-copy text-xs text-primary hover:underline" data-target="out-mock">Copy</button>
      </div>
      <pre id="out-mock" class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto whitespace-pre-wrap text-text-muted">Enter JSON and click Generate</pre>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Mock Data Schema Builder" relatedTags={['typescript', 'zod', 'mock', 'schema', 'testing', 'json']} />
</BaseLayout>

<script>
  const SAMPLE_JSON = `{
  "id": "usr_abc123",
  "name": "Alice Chen",
  "email": "alice@example.com",
  "age": 29,
  "isPremium": true,
  "score": 98.5,
  "tags": ["developer", "designer"],
  "address": {
    "street": "123 Main St",
    "city": "San Francisco",
    "country": "US",
    "zip": "94102"
  },
  "createdAt": "2024-01-15T10:30:00Z",
  "metadata": null
}`;

  function capitalize(s: string): string {
    return s.charAt(0).toUpperCase() + s.slice(1);
  }

  function inferTypeScriptType(value: any, typeName: string, indent: number, defs: string[]): string {
    const pad = '  '.repeat(indent);
    if (value === null) return 'null';
    if (Array.isArray(value)) {
      if (value.length === 0) return 'unknown[]';
      const itemType = inferTypeScriptType(value[0], typeName + 'Item', indent, defs);
      return `${itemType}[]`;
    }
    if (typeof value === 'object') {
      const innerName = capitalize(typeName);
      const fields = Object.entries(value).map(([k, v]) => {
        const ft = inferTypeScriptType(v, innerName + capitalize(k), indent + 1, defs);
        return `${'  '.repeat(indent + 1)}${k}: ${ft};`;
      });
      const def = `interface ${innerName} {\n${fields.join('\n')}\n${pad}}`;
      if (!defs.includes(def)) defs.push(def);
      return innerName;
    }
    if (typeof value === 'string') {
      // Detect ISO date
      if (/^\d{4}-\d{2}-\d{2}T/.test(value)) return 'string'; // Date ISO
      // Detect UUID-like
      if (/^[a-z]+_[a-z0-9]+$/.test(value)) return 'string';
      return 'string';
    }
    if (typeof value === 'number') {
      return Number.isInteger(value) ? 'number' : 'number';
    }
    if (typeof value === 'boolean') return 'boolean';
    return 'unknown';
  }

  function generateTypeScript(data: any, rootName: string): string {
    const defs: string[] = [];
    const rootFields = Object.entries(data).map(([k, v]) => {
      const t = inferTypeScriptType(v, capitalize(k), 1, defs);
      return `  ${k}: ${t};`;
    });
    const root = `interface ${rootName} {\n${rootFields.join('\n')}\n}`;
    const allDefs = [...defs.reverse(), root];
    return allDefs.join('\n\n');
  }

  function inferZodType(value: any, fieldKey: string, defs: string[]): string {
    if (value === null) return 'z.null()';
    if (Array.isArray(value)) {
      if (value.length === 0) return 'z.array(z.unknown())';
      return `z.array(${inferZodType(value[0], fieldKey, defs)})`;
    }
    if (typeof value === 'object') {
      const schemaName = capitalize(fieldKey) + 'Schema';
      const fields = Object.entries(value).map(([k, v]) => {
        return `  ${k}: ${inferZodType(v, k, defs)},`;
      });
      const def = `const ${schemaName} = z.object({\n${fields.join('\n')}\n});`;
      if (!defs.find(d => d.startsWith(`const ${schemaName}`))) defs.push(def);
      return schemaName;
    }
    if (typeof value === 'string') {
      if (/^\d{4}-\d{2}-\d{2}T/.test(value)) return 'z.string().datetime()';
      if (/^[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}$/.test(value)) return 'z.string().email()';
      if (/^https?:\/\//.test(value)) return 'z.string().url()';
      if (/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/.test(value)) return 'z.string().uuid()';
      return 'z.string()';
    }
    if (typeof value === 'number') return Number.isInteger(value) ? 'z.number().int()' : 'z.number()';
    if (typeof value === 'boolean') return 'z.boolean()';
    return 'z.unknown()';
  }

  function generateZod(data: any, rootName: string): string {
    const defs: string[] = [];
    const rootFields = Object.entries(data).map(([k, v]) => {
      return `  ${k}: ${inferZodType(v, k, defs)},`;
    });
    const rootSchema = `const ${rootName}Schema = z.object({\n${rootFields.join('\n')}\n});\n\ntype ${rootName} = z.infer<typeof ${rootName}Schema>;`;
    return `import { z } from 'zod';\n\n${defs.join('\n\n')}${defs.length ? '\n\n' : ''}${rootSchema}`;
  }

  function mockValue(value: any, key: string): any {
    if (value === null) return null;
    if (Array.isArray(value)) {
      return value.slice(0, 2).map(v => mockValue(v, key));
    }
    if (typeof value === 'object') {
      const result: any = {};
      Object.entries(value).forEach(([k, v]) => { result[k] = mockValue(v, k); });
      return result;
    }
    if (typeof value === 'string') {
      const k = key.toLowerCase();
      if (k.includes('email')) return 'alice@example.com';
      if (k.includes('name') && k.includes('first')) return 'Alice';
      if (k.includes('name') && k.includes('last')) return 'Chen';
      if (k.includes('name')) return 'Alice Chen';
      if (k.includes('url') || k.includes('link')) return 'https://example.com';
      if (k.includes('phone')) return '+1-555-0100';
      if (k.includes('city')) return 'San Francisco';
      if (k.includes('country')) return 'US';
      if (k.includes('street') || k.includes('address')) return '123 Main St';
      if (k.includes('zip') || k.includes('postal')) return '94102';
      if (k.includes('id') || k.includes('_id')) return `${key}_abc123`;
      if (/^\d{4}-\d{2}-\d{2}T/.test(value)) return '2024-01-15T10:30:00.000Z';
      return value;
    }
    return value;
  }

  function generateMock(data: any, rootName: string): string {
    const mockObj = mockValue(data, rootName);
    const objStr = JSON.stringify(mockObj, null, 2)
      .replace(/"([^"]+)":/g, '$1:')
      .replace(/"/g, "'");

    return `import { v4 as uuidv4 } from 'uuid'; // optional: for UUID IDs\n\nfunction create${rootName}(overrides: Partial<${rootName}> = {}): ${rootName} {\n  return {\n${
      Object.entries(mockObj).map(([k, v]) => {
        const valStr = JSON.stringify(v, null, 4)
          .replace(/"([^"]+)":/g, '$1:')
          .replace(/"/g, "'");
        return `    ${k}: ${valStr},`;
      }).join('\n')
    }\n    ...overrides,\n  };\n}\n\n// Usage:\n// const user = create${rootName}();\n// const admin = create${rootName}({ isPremium: true });\n// const batch = Array.from({ length: 10 }, (_, i) => create${rootName}({ id: \`id_\${i}\` }));`;
  }

  function generate() {
    const raw = (document.getElementById('mds-input') as HTMLTextAreaElement).value.trim();
    const typeName = ((document.getElementById('mds-typename') as HTMLInputElement).value.trim()) || 'MyType';
    const errEl = document.getElementById('mds-error')!;
    errEl.classList.add('hidden');

    let data: any;
    try {
      data = JSON.parse(raw);
      if (Array.isArray(data)) data = data[0];
      if (typeof data !== 'object' || data === null) throw new Error('Must be a JSON object (or array of objects)');
    } catch (e: any) {
      errEl.textContent = e.message;
      errEl.classList.remove('hidden');
      return;
    }

    const rootName = capitalize(typeName);

    try {
      (document.getElementById('out-ts') as HTMLElement).textContent = generateTypeScript(data, rootName);
      (document.getElementById('out-zod') as HTMLElement).textContent = generateZod(data, rootName);
      (document.getElementById('out-mock') as HTMLElement).textContent = generateMock(data, rootName);
    } catch (e: any) {
      errEl.textContent = 'Generation error: ' + e.message;
      errEl.classList.remove('hidden');
    }
  }

  // Tab switching
  document.querySelectorAll('.mds-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = (btn as HTMLElement).dataset.tab!;
      document.querySelectorAll('.mds-tab').forEach(b => {
        b.classList.remove('border-primary', 'text-primary');
        b.classList.add('border-transparent', 'text-text-muted');
      });
      btn.classList.add('border-primary', 'text-primary');
      btn.classList.remove('border-transparent', 'text-text-muted');
      document.querySelectorAll('.mds-tab-panel').forEach(p => p.classList.add('hidden'));
      document.getElementById('mds-tab-' + tab)!.classList.remove('hidden');
    });
  });

  // Copy buttons
  document.querySelectorAll('.mds-copy').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = (btn as HTMLElement).dataset.target!;
      const text = (document.getElementById(target) as HTMLElement).textContent || '';
      navigator.clipboard.writeText(text).then(() => {
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
      });
    });
  });

  document.getElementById('mds-generate')!.addEventListener('click', generate);

  // Load sample and generate
  (document.getElementById('mds-input') as HTMLTextAreaElement).value = SAMPLE_JSON;
  generate();
</script>
