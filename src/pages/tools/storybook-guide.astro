---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is Storybook and why do teams use it?", answer: "Storybook is an open-source tool for developing and documenting UI components in isolation. Rather than building components inside your full application (where dependencies, routing, and data fetching complicate things), Storybook provides a standalone workshop where each component state — called a 'story' — can be built, tested, and reviewed independently. Teams use it to build design systems, onboard new developers, run visual regression tests, and maintain living documentation." },
  { question: "What is the Component Story Format (CSF)?", answer: "CSF (Component Story Format) is the standard format for writing Storybook stories. CSF3 (the current version) uses a default export with metadata (component, title, decorators) and named exports for each story. Each named export is an object with an args property that defines the component's props. This declarative format is portable — it works with Storybook's addons, interaction testing, and tools like Chromatic for visual regression." },
  { question: "What are Storybook addons?", answer: "Addons extend Storybook's functionality. The most important built-in addons are: Controls (interactive prop editing in the Addons panel), Actions (log event callbacks like onClick), Docs (auto-generate documentation from JSDoc and stories), a11y (accessibility audit via axe-core), and Interactions (run user events and make assertions via play functions). Community addons cover styling, theming, internationalization, and integration with Figma." },
  { question: "What is a play function in Storybook?", answer: "A play function is an async function attached to a story that simulates user interactions after the component renders. It uses @storybook/test (a wrapper around Testing Library) to find elements and fire events. Play functions make stories interactive and testable — they run automatically in Storybook's UI and can be executed headlessly in CI via the test-storybook runner. This enables interaction testing without Cypress or Playwright." },
  { question: "What is Chromatic and how does it relate to Storybook?", answer: "Chromatic is a visual testing and review service built by the Storybook maintainers. It snapshots every story in every browser on every commit and shows you a visual diff for review. When a PR changes a component, Chromatic flags the visual change and requires a team member to accept or reject it — preventing accidental UI regressions. Chromatic also hosts your Storybook as a shareable URL for design review without a local setup." },
  { question: "How do I use decorators in Storybook?", answer: "Decorators are wrapper functions that add context to stories — themes, router providers, global state, or design tokens. Define decorators in .storybook/preview.ts (applies to all stories) or in the story file's default export (applies to that component's stories). Example: wrapping all stories with a ThemeProvider ensures components always render with the correct theme, eliminating the need to repeat setup in every story." },
];
---

<BaseLayout
  title="Storybook Guide — UI Component Development Workshop Reference"
  description="Complete Storybook guide covering CSF3 stories, args, decorators, play functions, addons, and visual testing with Chromatic. Compare Storybook vs Ladle vs Histoire. Free developer reference."
  tool="Storybook guide, Storybook CSF3, Storybook play functions, Storybook addons, component testing, design system, UI workshop"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Storybook Component Development Guide",
    "url": "https://devplaybook.cc/tools/storybook-guide",
    "description": "Complete guide to Storybook — the UI component workshop. Covers CSF3 story format, args, decorators, play functions, addons, and visual regression testing with Chromatic.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Storybook Guide</h1>
  <p class="text-text-muted mb-6">
    The complete reference for <strong>Storybook</strong> — the UI component workshop used by Netflix, Airbnb, and thousands of teams. Covers CSF3 stories, args, decorators, play functions, addons, and visual regression testing.
  </p>

  <div class="flex items-center gap-3 mb-8 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Isolated component development</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CSF3 story format</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Play function testing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Visual regression</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Addon ecosystem</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Storybook?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Storybook is an open-source workshop for building, documenting, and testing UI components in isolation. Instead of navigating through your application to reach a specific component state (say, an error state deep in a form flow), Storybook lets you define every state as a "story" — a named configuration with specific props — and jump directly to any state instantly.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    This isolation-first approach transforms how teams build design systems. Designers can review components in every state without a developer running the full app. New developers can explore the component library as living documentation. QA engineers can verify edge-case states that are hard to reproduce in the real application. And with Chromatic or other visual testing tools, every pixel change is caught automatically in CI.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Installation</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Automatic setup (detects your framework)
npx storybook@latest init

# For an existing React + Vite project
npx storybook@latest init --type react

# Run Storybook
npm run storybook          # http://localhost:6006

# Build static Storybook for deployment
npm run build-storybook

# Run interaction tests headlessly
npx test-storybook</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Writing Stories: CSF3 Format</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Component Story Format 3 (CSF3) is the standard way to write Storybook stories. A story file has one default export (component metadata) and multiple named exports (individual states).
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// src/components/Button.stories.tsx
import type { Meta, StoryObj } from '@storybook/react';
import { Button } from './Button';

// Default export: component metadata
const meta: Meta&lt;typeof Button&gt; = {
  title: 'UI/Button',         // Sidebar navigation path
  component: Button,
  tags: ['autodocs'],          // Auto-generate Docs page
  argTypes: {
    variant: {
      control: 'select',
      options: ['primary', 'secondary', 'danger'],
    },
    size: { control: 'radio', options: ['sm', 'md', 'lg'] },
  },
};

export default meta;
type Story = StoryObj&lt;typeof Button&gt;;

// Named exports: individual stories
export const Primary: Story = {
  args: { label: 'Click me', variant: 'primary', size: 'md' },
};

export const Secondary: Story = {
  args: { label: 'Cancel', variant: 'secondary', size: 'md' },
};

export const Danger: Story = {
  args: { label: 'Delete', variant: 'danger', size: 'md' },
};

export const Loading: Story = {
  args: { label: 'Saving...', variant: 'primary', disabled: true, loading: true },
};</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Decorators: Global Context Providers</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// .storybook/preview.tsx — applies to ALL stories
import { ThemeProvider } from '../src/theme';
import type { Preview } from '@storybook/react';

const preview: Preview = {
  decorators: [
    (Story) => (
      &lt;ThemeProvider theme="light"&gt;
        &lt;div style={{ padding: '1rem' }}&gt;
          &lt;Story /&gt;
        &lt;/div&gt;
      &lt;/ThemeProvider&gt;
    ),
  ],
  parameters: {
    backgrounds: {
      default: 'light',
      values: [
        { name: 'light', value: '#ffffff' },
        { name: 'dark', value: '#1a1a1a' },
      ],
    },
  },
};

export default preview;</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Play Functions: Interaction Testing</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// LoginForm.stories.tsx
import { within, userEvent, expect } from '@storybook/test';

export const FilledAndSubmitted: Story = {
  args: { onSubmit: fn() },
  play: async ({ canvasElement, args }) => {
    const canvas = within(canvasElement);

    // Simulate user interactions
    await userEvent.type(canvas.getByLabelText('Email'), 'user@example.com');
    await userEvent.type(canvas.getByLabelText('Password'), 'secret123');
    await userEvent.click(canvas.getByRole('button', { name: 'Sign in' }));

    // Assert the outcome
    await expect(args.onSubmit).toHaveBeenCalledWith({
      email: 'user@example.com',
      password: 'secret123',
    });
  },
};

export const ValidationErrors: Story = {
  play: async ({ canvasElement }) => {
    const canvas = within(canvasElement);
    await userEvent.click(canvas.getByRole('button', { name: 'Sign in' }));
    await expect(canvas.getByText('Email is required')).toBeVisible();
  },
};</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Isolated development</strong> — build components without running the full application</li>
    <li><strong>Controls addon</strong> — edit any prop interactively in the UI without code changes</li>
    <li><strong>Docs addon</strong> — auto-generate API documentation from TypeScript types and JSDoc</li>
    <li><strong>Accessibility addon</strong> — axe-core audit runs on every story automatically</li>
    <li><strong>Play functions</strong> — interaction tests that run in CI via test-storybook</li>
    <li><strong>Chromatic integration</strong> — pixel-perfect visual regression on every commit</li>
    <li><strong>Framework support</strong> — React, Vue, Angular, Svelte, Web Components, Solid</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Comparison: Storybook vs Alternatives</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse mb-6">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">Storybook</th>
          <th class="border border-border px-3 py-2 text-left">Ladle</th>
          <th class="border border-border px-3 py-2 text-left">Histoire</th>
          <th class="border border-border px-3 py-2 text-left">Docz</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-border px-3 py-2">Framework support</td>
          <td class="border border-border px-3 py-2 text-green-400">All major</td>
          <td class="border border-border px-3 py-2 text-yellow-400">React only</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Vue + Svelte</td>
          <td class="border border-border px-3 py-2 text-yellow-400">React</td>
        </tr>
        <tr class="bg-bg-card/50">
          <td class="border border-border px-3 py-2">Build speed</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Moderate (Webpack)</td>
          <td class="border border-border px-3 py-2 text-green-400">Fast (Vite)</td>
          <td class="border border-border px-3 py-2 text-green-400">Fast (Vite)</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Moderate</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">Addon ecosystem</td>
          <td class="border border-border px-3 py-2 text-green-400">200+ addons</td>
          <td class="border border-border px-3 py-2 text-red-400">Minimal</td>
          <td class="border border-border px-3 py-2 text-red-400">Minimal</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Limited</td>
        </tr>
        <tr class="bg-bg-card/50">
          <td class="border border-border px-3 py-2">Play functions</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">Community size</td>
          <td class="border border-border px-3 py-2 text-green-400">Very large</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Small</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Small</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Small</td>
        </tr>
        <tr class="bg-bg-card/50">
          <td class="border border-border px-3 py-2">Visual regression</td>
          <td class="border border-border px-3 py-2 text-green-400">Chromatic</td>
          <td class="border border-border px-3 py-2 text-red-400">DIY</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Limited</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pros &amp; Cons</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-green-400 mb-2">Pros</h3>
      <ul class="list-disc list-inside text-text-muted space-y-1 text-sm">
        <li>Industry standard with massive adoption and community</li>
        <li>Supports every major UI framework</li>
        <li>Rich addon ecosystem (200+ addons)</li>
        <li>Play functions enable CI interaction testing</li>
        <li>Chromatic integration for visual regression</li>
        <li>Living documentation auto-generated from stories</li>
      </ul>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-red-400 mb-2">Cons</h3>
      <ul class="list-disc list-inside text-text-muted space-y-1 text-sm">
        <li>Slow build times with Webpack (Vite builder helps)</li>
        <li>Complex configuration for custom webpack setups</li>
        <li>Heavy dependency footprint</li>
        <li>Chromatic visual testing has a cost at scale</li>
        <li>Can diverge from real app environment</li>
      </ul>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Storybook Guide" relatedTags={['storybook', 'component-testing', 'ui', 'developer-tools', 'react']} />
</BaseLayout>
