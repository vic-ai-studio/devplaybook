---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a Solidity smart contract?",
    answer: "A Solidity smart contract is self-executing code deployed on a blockchain (Ethereum, Polygon, BNB Chain, etc.). Once deployed, contracts are immutable and execute automatically when conditions are met — no third party needed. Contracts manage token balances, ownership, voting, and virtually any logic that requires trustless execution."
  },
  {
    question: "What is ERC-20?",
    answer: "ERC-20 is the standard interface for fungible tokens on Ethereum. Tokens like USDC, DAI, and UNI follow this standard. It defines functions like transfer(), balanceOf(), approve(), and transferFrom(), allowing any ERC-20 token to work with any wallet, DEX, or DeFi protocol without custom integration."
  },
  {
    question: "What is ERC-721 (NFT)?",
    answer: "ERC-721 is the standard for non-fungible tokens (NFTs). Each token has a unique ID and can represent ownership of a unique asset — art, collectibles, game items, domain names, etc. Unlike ERC-20 tokens, ERC-721 tokens are not interchangeable: one token is not equal to another. OpenSea, Rarible, and most NFT marketplaces support ERC-721."
  },
  {
    question: "What is ERC-1155?",
    answer: "ERC-1155 is a multi-token standard that supports both fungible and non-fungible tokens in a single contract. It's more gas-efficient for batch transfers. Game assets are a common use case: a single ERC-1155 contract can manage thousands of different item types. Introduced by Enjin and now widely used in gaming and metaverse projects."
  },
  {
    question: "What is OpenZeppelin?",
    answer: "OpenZeppelin is a library of secure, community-audited smart contract implementations. It provides production-ready implementations of ERC-20, ERC-721, ERC-1155, AccessControl, Ownable, Pausable, and more. Using OpenZeppelin reduces security risk compared to writing contracts from scratch — their contracts are battle-tested with billions in value locked."
  },
  {
    question: "What does the Ownable pattern do?",
    answer: "The Ownable pattern (from OpenZeppelin) restricts certain functions to a single owner address. The deployer is typically the initial owner. Functions marked with the onlyOwner modifier revert if called by anyone other than the owner. Ownership can be transferred with transferOwnership() or renounced with renounceOwnership() (making the contract permanently ownerless)."
  },
  {
    question: "What is the difference between mint and burn?",
    answer: "Minting creates new tokens and increases total supply. Burning destroys tokens by sending them to a zero address (0x000...0), removing them from circulation and decreasing total supply. Minting is typically restricted to the owner or a minter role. Burning can be open to any token holder (they can burn their own tokens) or also restricted."
  },
];
---

<BaseLayout
  title="Solidity Contract Generator — ERC-20, ERC-721, ERC-1155 Templates"
  description="Generate Solidity smart contract templates instantly. Select ERC-20, ERC-721 NFT, ERC-1155, storage, or Ownable contracts. Configure name, symbol, supply. Get OpenZeppelin-based Solidity code with copy button."
  tool="Solidity Contract Generator, ERC-20 Generator, ERC-721 NFT Generator, Solidity Code Generator, Smart Contract Template, OpenZeppelin Contract Generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Solidity Contract Generator",
    "url": "https://devplaybook.cc/tools/solidity-contract-generator",
    "description": "Generate Solidity smart contract templates. ERC-20, ERC-721, ERC-1155, storage, and Ownable contracts with OpenZeppelin integration.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Solidity Contract Generator</h1>
  <p class="text-text-muted mb-4">
    Generate Solidity smart contract templates for Ethereum and EVM-compatible chains.
    Select a contract type, configure name, symbol, and supply, then copy the OpenZeppelin-based Solidity code into your project.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 contract types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> OpenZeppelin imports</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <div id="solidity-app" class="space-y-5">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <!-- Config -->
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-semibold mb-1">Contract Type</label>
          <div class="grid grid-cols-1 gap-2">
            <label class="flex items-start gap-3 p-3 bg-surface border border-border rounded-lg cursor-pointer hover:border-accent/50 transition-colors has-[:checked]:border-accent has-[:checked]:bg-accent/5">
              <input type="radio" name="contract-type" value="erc20" checked class="mt-0.5 accent-accent" />
              <div>
                <p class="text-sm font-medium">ERC-20 — Fungible Token</p>
                <p class="text-xs text-text-muted">Standard token (USDC, DAI style). Mintable, burnable, with supply cap.</p>
              </div>
            </label>
            <label class="flex items-start gap-3 p-3 bg-surface border border-border rounded-lg cursor-pointer hover:border-accent/50 transition-colors has-[:checked]:border-accent has-[:checked]:bg-accent/5">
              <input type="radio" name="contract-type" value="erc721" class="mt-0.5 accent-accent" />
              <div>
                <p class="text-sm font-medium">ERC-721 — NFT</p>
                <p class="text-xs text-text-muted">Non-fungible token. Unique token IDs, tokenURI, owner-only mint.</p>
              </div>
            </label>
            <label class="flex items-start gap-3 p-3 bg-surface border border-border rounded-lg cursor-pointer hover:border-accent/50 transition-colors has-[:checked]:border-accent has-[:checked]:bg-accent/5">
              <input type="radio" name="contract-type" value="erc1155" class="mt-0.5 accent-accent" />
              <div>
                <p class="text-sm font-medium">ERC-1155 — Multi-Token</p>
                <p class="text-xs text-text-muted">Mixed fungible/non-fungible. Batch operations. Ideal for game assets.</p>
              </div>
            </label>
            <label class="flex items-start gap-3 p-3 bg-surface border border-border rounded-lg cursor-pointer hover:border-accent/50 transition-colors has-[:checked]:border-accent has-[:checked]:bg-accent/5">
              <input type="radio" name="contract-type" value="ownable" class="mt-0.5 accent-accent" />
              <div>
                <p class="text-sm font-medium">Simple Ownable Storage</p>
                <p class="text-xs text-text-muted">Basic contract with Ownable pattern and a stored string value.</p>
              </div>
            </label>
            <label class="flex items-start gap-3 p-3 bg-surface border border-border rounded-lg cursor-pointer hover:border-accent/50 transition-colors has-[:checked]:border-accent has-[:checked]:bg-accent/5">
              <input type="radio" name="contract-type" value="storage" class="mt-0.5 accent-accent" />
              <div>
                <p class="text-sm font-medium">Simple Storage</p>
                <p class="text-xs text-text-muted">Minimal contract. Get/set a value. Great for learning Solidity basics.</p>
              </div>
            </label>
          </div>
        </div>

        <div id="token-fields" class="space-y-3">
          <div>
            <label class="block text-sm font-semibold mb-1" for="contract-name">Contract / Token Name</label>
            <input id="contract-name" type="text" value="MyToken" placeholder="MyToken" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text font-mono focus:outline-none focus:border-accent" />
          </div>
          <div id="symbol-field">
            <label class="block text-sm font-semibold mb-1" for="token-symbol">Token Symbol</label>
            <input id="token-symbol" type="text" value="MTK" placeholder="MTK" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text font-mono focus:outline-none focus:border-accent" />
          </div>
          <div id="supply-field">
            <label class="block text-sm font-semibold mb-1" for="initial-supply">Initial Supply (tokens)</label>
            <input id="initial-supply" type="text" value="1000000" placeholder="1000000" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text font-mono focus:outline-none focus:border-accent" />
          </div>
        </div>

        <div class="space-y-2">
          <p class="text-xs font-semibold text-text-muted uppercase tracking-wide">Options</p>
          <label id="opt-mintable-wrap" class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" id="opt-mintable" checked class="accent-accent" />
            <span class="text-sm">Mintable (owner can mint more)</span>
          </label>
          <label id="opt-burnable-wrap" class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" id="opt-burnable" class="accent-accent" />
            <span class="text-sm">Burnable (holders can burn tokens)</span>
          </label>
          <label id="opt-pausable-wrap" class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" id="opt-pausable" class="accent-accent" />
            <span class="text-sm">Pausable (owner can pause transfers)</span>
          </label>
        </div>

        <div>
          <label class="block text-sm font-semibold mb-1">Solidity Version</label>
          <select id="solidity-version" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent">
            <option value="0.8.20">^0.8.20 (latest stable)</option>
            <option value="0.8.19">^0.8.19</option>
            <option value="0.8.18">^0.8.18</option>
          </select>
        </div>
      </div>

      <!-- Output -->
      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <p class="text-sm font-semibold">Generated Solidity Code</p>
          <button id="btn-copy" class="text-xs text-accent hover:underline font-medium">Copy code</button>
        </div>
        <pre id="code-output" class="bg-surface border border-border rounded-lg p-4 text-xs font-mono overflow-auto min-h-96 text-text leading-relaxed whitespace-pre"></pre>
        <div id="copy-toast" class="hidden text-xs text-green-500 font-medium">Copied to clipboard!</div>
        <div id="note-panel" class="text-xs text-text-muted bg-surface border border-border rounded-lg p-3 leading-relaxed"></div>
      </div>
    </div>
  </div>

  <script>
    (function () {
      function getVal(id) { return (document.getElementById(id)?.value || '').trim(); }
      function getChecked(id) { return document.getElementById(id)?.checked || false; }
      function getContractType() {
        const r = document.querySelector('input[name="contract-type"]:checked');
        return r ? r.value : 'erc20';
      }

      function generateERC20(name, symbol, supply, version, mintable, burnable, pausable) {
        const imports = ['@openzeppelin/contracts/token/ERC20/ERC20.sol'];
        const inherits = ['ERC20'];
        const extra = [];

        if (mintable) { inherits.push('Ownable'); imports.push('@openzeppelin/contracts/access/Ownable.sol'); }
        if (burnable) { inherits.push('ERC20Burnable'); imports.push('@openzeppelin/contracts/token/ERC20/extensions/ERC20Burnable.sol'); }
        if (pausable) { inherits.push('Pausable'); imports.push('@openzeppelin/contracts/utils/Pausable.sol'); }

        const importLines = [...new Set(imports)].map(i => `import "${i}";`).join('\n');
        const inheritStr = inherits.join(', ');
        const ctorArgs = mintable ? 'address initialOwner' : '';
        const ctorCall = mintable ? `ERC20("${name}", "${symbol}") Ownable(initialOwner)` : `ERC20("${name}", "${symbol}")`;

        let ctor = `    constructor(${ctorArgs}) ${ctorCall} {\n`;
        if (supply) ctor += `        _mint(msg.sender, ${supply} * 10 ** decimals());\n`;
        ctor += `    }`;

        if (mintable) {
          extra.push(`\n    function mint(address to, uint256 amount) public onlyOwner {\n        _mint(to, amount);\n    }`);
        }
        if (pausable) {
          extra.push(`\n    function pause() public onlyOwner { _pause(); }\n    function unpause() public onlyOwner { _unpause(); }`);
          extra.push(`\n    function _update(address from, address to, uint256 value)\n        internal\n        override(ERC20)\n        whenNotPaused\n    {\n        super._update(from, to, value);\n    }`);
        }

        return `// SPDX-License-Identifier: MIT\npragma solidity ^${version};\n\n${importLines}\n\ncontract ${name} is ${inheritStr} {\n${ctor}${extra.join('\n')}\n}`;
      }

      function generateERC721(name, symbol, version, mintable, burnable, pausable) {
        const imports = [
          '@openzeppelin/contracts/token/ERC721/ERC721.sol',
          '@openzeppelin/contracts/access/Ownable.sol',
        ];
        const inherits = ['ERC721', 'Ownable'];
        const extra = [];
        let stateVars = '    uint256 private _nextTokenId;\n';

        if (burnable) { imports.push('@openzeppelin/contracts/token/ERC721/extensions/ERC721Burnable.sol'); inherits.push('ERC721Burnable'); }
        if (pausable) { imports.push('@openzeppelin/contracts/utils/Pausable.sol'); inherits.push('Pausable'); }

        imports.push('@openzeppelin/contracts/token/ERC721/extensions/ERC721URIStorage.sol');
        inherits.splice(1, 0, 'ERC721URIStorage');

        const importLines = [...new Set(imports)].map(i => `import "${i}";`).join('\n');
        const inheritStr = inherits.join(', ');

        const ctor = `    constructor(address initialOwner)\n        ERC721("${name}", "${symbol}")\n        Ownable(initialOwner)\n    {}`;

        extra.push(`\n    function safeMint(address to, string memory uri) public onlyOwner {\n        uint256 tokenId = _nextTokenId++;\n        _safeMint(to, tokenId);\n        _setTokenURI(tokenId, uri);\n    }`);

        if (pausable) {
          extra.push(`\n    function pause() public onlyOwner { _pause(); }\n    function unpause() public onlyOwner { _unpause(); }`);
        }

        extra.push(`\n    // Required overrides\n    function tokenURI(uint256 tokenId)\n        public view override(ERC721, ERC721URIStorage)\n        returns (string memory)\n    {\n        return super.tokenURI(tokenId);\n    }\n\n    function supportsInterface(bytes4 interfaceId)\n        public view override(ERC721, ERC721URIStorage)\n        returns (bool)\n    {\n        return super.supportsInterface(interfaceId);\n    }`);

        return `// SPDX-License-Identifier: MIT\npragma solidity ^${version};\n\n${importLines}\n\ncontract ${name} is ${inheritStr} {\n${stateVars}\n${ctor}${extra.join('\n')}\n}`;
      }

      function generateERC1155(name, version, mintable, burnable, pausable) {
        const imports = [
          '@openzeppelin/contracts/token/ERC1155/ERC1155.sol',
          '@openzeppelin/contracts/access/Ownable.sol',
        ];
        const inherits = ['ERC1155', 'Ownable'];

        if (burnable) { imports.push('@openzeppelin/contracts/token/ERC1155/extensions/ERC1155Burnable.sol'); inherits.push('ERC1155Burnable'); }
        if (pausable) { imports.push('@openzeppelin/contracts/utils/Pausable.sol'); inherits.push('Pausable'); }
        if (mintable || true) { imports.push('@openzeppelin/contracts/token/ERC1155/extensions/ERC1155Supply.sol'); inherits.push('ERC1155Supply'); }

        const importLines = [...new Set(imports)].map(i => `import "${i}";`).join('\n');
        const inheritStr = inherits.join(', ');

        const ctor = `    constructor(address initialOwner)\n        ERC1155("")\n        Ownable(initialOwner)\n    {}`;
        let extra = [];

        extra.push(`\n    function setURI(string memory newuri) public onlyOwner {\n        _setURI(newuri);\n    }`);
        if (mintable) {
          extra.push(`\n    function mint(address account, uint256 id, uint256 amount, bytes memory data)\n        public onlyOwner\n    {\n        _mint(account, id, amount, data);\n    }\n\n    function mintBatch(address to, uint256[] memory ids, uint256[] memory amounts, bytes memory data)\n        public onlyOwner\n    {\n        _mintBatch(to, ids, amounts, data);\n    }`);
        }
        if (pausable) {
          extra.push(`\n    function pause() public onlyOwner { _pause(); }\n    function unpause() public onlyOwner { _unpause(); }`);
        }

        extra.push(`\n    // Required overrides\n    function _update(address from, address to, uint256[] memory ids, uint256[] memory values)\n        internal\n        override(ERC1155, ERC1155Supply)\n    {\n        super._update(from, to, ids, values);\n    }`);

        return `// SPDX-License-Identifier: MIT\npragma solidity ^${version};\n\n${importLines}\n\ncontract ${name} is ${inheritStr} {\n\n${ctor}${extra.join('\n')}\n}`;
      }

      function generateOwnable(name, version) {
        return `// SPDX-License-Identifier: MIT\npragma solidity ^${version};\n\nimport "@openzeppelin/contracts/access/Ownable.sol";\n\ncontract ${name} is Ownable {\n    string private _value;\n\n    event ValueChanged(string newValue);\n\n    constructor(address initialOwner) Ownable(initialOwner) {\n        _value = "initial value";\n    }\n\n    function setValue(string memory newValue) public onlyOwner {\n        _value = newValue;\n        emit ValueChanged(newValue);\n    }\n\n    function getValue() public view returns (string memory) {\n        return _value;\n    }\n}`;
      }

      function generateStorage(name, version) {
        return `// SPDX-License-Identifier: MIT\npragma solidity ^${version};\n\ncontract ${name} {\n    uint256 private _storedValue;\n\n    event ValueStored(uint256 newValue);\n\n    function store(uint256 value) public {\n        _storedValue = value;\n        emit ValueStored(value);\n    }\n\n    function retrieve() public view returns (uint256) {\n        return _storedValue;\n    }\n}`;
      }

      const notes = {
        erc20: 'Install OpenZeppelin: npm install @openzeppelin/contracts\nDeploy with Remix IDE or Hardhat. Pass your wallet address as initialOwner.',
        erc721: 'Install OpenZeppelin: npm install @openzeppelin/contracts\nSet token URI to an IPFS JSON metadata URL (e.g. ipfs://QmHash/1.json).',
        erc1155: 'Install OpenZeppelin: npm install @openzeppelin/contracts\nPass URI with {id} placeholder for token metadata (EIP-1155 standard).',
        ownable: 'Install OpenZeppelin: npm install @openzeppelin/contracts\nOwner can call setValue(). Anyone can call getValue().',
        storage: 'No dependencies needed. Minimal Solidity example — great for learning basics.',
      };

      function updateOutput() {
        const type = getContractType();
        const name = getVal('contract-name') || 'MyToken';
        const symbol = getVal('token-symbol') || 'MTK';
        const supply = getVal('initial-supply') || '1000000';
        const version = getVal('solidity-version') || '0.8.20';
        const mintable = getChecked('opt-mintable');
        const burnable = getChecked('opt-burnable');
        const pausable = getChecked('opt-pausable');

        let code = '';
        if (type === 'erc20') code = generateERC20(name, symbol, supply, version, mintable, burnable, pausable);
        else if (type === 'erc721') code = generateERC721(name, symbol, version, mintable, burnable, pausable);
        else if (type === 'erc1155') code = generateERC1155(name, version, mintable, burnable, pausable);
        else if (type === 'ownable') code = generateOwnable(name, version);
        else if (type === 'storage') code = generateStorage(name, version);

        document.getElementById('code-output').textContent = code;
        document.getElementById('note-panel').textContent = notes[type] || '';
      }

      function updateVisibility() {
        const type = getContractType();
        const hasToken = type === 'erc20' || type === 'erc721' || type === 'erc1155';
        const hasSymbol = type === 'erc20' || type === 'erc721';
        const hasSupply = type === 'erc20';

        document.getElementById('symbol-field').classList.toggle('hidden', !hasSymbol);
        document.getElementById('supply-field').classList.toggle('hidden', !hasSupply);
        document.getElementById('opt-mintable-wrap').classList.toggle('hidden', type === 'storage');
        document.getElementById('opt-burnable-wrap').classList.toggle('hidden', type === 'storage' || type === 'ownable');
        document.getElementById('opt-pausable-wrap').classList.toggle('hidden', type === 'storage');

        const nameLabel = document.querySelector('label[for="contract-name"]');
        if (nameLabel) nameLabel.textContent = hasToken ? 'Contract / Token Name' : 'Contract Name';

        updateOutput();
      }

      document.querySelectorAll('input[name="contract-type"]').forEach(r => r.addEventListener('change', updateVisibility));
      document.querySelectorAll('#solidity-app input:not([name="contract-type"]), #solidity-app select').forEach(el => {
        el.addEventListener('input', updateOutput);
        el.addEventListener('change', updateOutput);
      });

      document.getElementById('btn-copy').addEventListener('click', function () {
        const code = document.getElementById('code-output').textContent;
        navigator.clipboard.writeText(code).then(() => {
          const toast = document.getElementById('copy-toast');
          toast.classList.remove('hidden');
          setTimeout(() => toast.classList.add('hidden'), 2000);
        });
      });

      updateVisibility();
    })();
  </script>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Solidity Contract Generator" relatedTags={['solidity', 'ethereum', 'blockchain', 'web3', 'smart-contracts', 'nft']} />
</BaseLayout>
