---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PackageJsonGenerator from '../../components/PackageJsonGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is the difference between 'type: module' and 'type: commonjs'?",
    answer: "type: module makes .js files use ES module syntax (import/export). type: commonjs (the default when omitted) makes .js files use CommonJS syntax (require/module.exports). Choose module for modern Node.js projects, Vite, and libraries targeting ESM consumers. Choose commonjs for older Node.js projects or tools that don't support ESM. You can always use .mjs and .cjs extensions to override the type field for individual files."
  },
  {
    question: "What should I put in the 'scripts' section?",
    answer: "At minimum: 'dev' (development server), 'build' (production build), 'test' (test runner), 'lint' (code quality). Good additions: 'typecheck' (tsc --noEmit for type validation), 'format' (prettier --write), 'clean' (rm -rf dist). Keep script names consistent across projects — dev, build, test, lint are the standard npm conventions most tools expect."
  },
  {
    question: "What is the 'private' field used for?",
    answer: "Setting private: true prevents accidental npm publish. Use it for any project that's not intended to be a reusable npm package — apps, monorepo roots, internal tools. Without private: true, anyone with npm credentials on your machine could accidentally run npm publish and push your app to the public registry."
  },
  {
    question: "What is the 'engines' field?",
    answer: "The engines field specifies which Node.js (and npm/yarn) versions your package supports: { \"node\": \">=20.0.0\" }. Tools like npm warn when installing on incompatible versions. In .nvmrc or .node-version files you set the exact version for local development; in engines you set the minimum supported version for consumers."
  },
  {
    question: "What is the difference between dependencies and devDependencies?",
    answer: "dependencies are packages needed at runtime — they're installed when someone runs 'npm install' in your project. devDependencies are only needed during development (tests, build tools, linters) — they're not installed when your package is used as a library. For apps deployed to servers, both are installed since you control the environment. For libraries published to npm, only list dependencies that consumers need to run your code."
  },
  {
    question: "Should I commit package-lock.json?",
    answer: "Yes, always commit package-lock.json (npm), yarn.lock (Yarn), or pnpm-lock.yaml (pnpm). Lock files record exact versions of every installed package, ensuring reproducible installs across machines and CI. Without a lock file, 'npm install' could install different versions on different machines. Add it to .gitignore only for globally-installed CLI tools, never for apps or libraries."
  },
];
---

<BaseLayout
  title="package.json Generator — Visual npm Package Config Builder"
  description="Generate a package.json file visually. Fill in name, version, license, scripts, and select common dependencies (React, TypeScript, Vite, ESLint, Prisma). Copy ready-to-use config. Free, browser-based."
  tool="package.json Generator, npm package config, package.json builder, Node.js project setup, npm scripts generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "package.json Generator",
    "url": "https://devplaybook.cc/tools/package-json-generator",
    "description": "Generate a package.json file visually. Configure name, version, scripts, dependencies, and license. Supports React, TypeScript, Vite, testing, linting, and database packages.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">package.json Generator</h1>
  <p class="text-text-muted mb-4">
    Build a complete <code class="text-accent font-mono">package.json</code> visually.
    Fill in project metadata, toggle npm scripts, and select dependencies from a curated list of
    popular packages. Copy the result and run <code class="text-accent font-mono">npm install</code> to get started.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Scripts with editable commands</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 25+ popular packages to choose from</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auto-separates deps / devDeps</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <PackageJsonGenerator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="package.json Generator" relatedTags={['javascript', 'typescript', 'nodejs', 'npm', 'development', 'build']} />
</BaseLayout>
