---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TextEncryption from '../../components/TextEncryption.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What encryption algorithm does this tool use?", answer: "AES-256-GCM (Advanced Encryption Standard, 256-bit key, Galois/Counter Mode). AES-256 is the industry standard used by governments and financial institutions worldwide. GCM mode provides both confidentiality (nobody can read the data) and authenticity (tamper detection). The key is derived from your password using PBKDF2 with 100,000 iterations and SHA-256." },
  { question: "Is my data sent to a server?", answer: "No. All encryption and decryption happens entirely in your browser using the Web Crypto API, which is built into all modern browsers. Your text and password never leave your device. This tool works offline once the page is loaded." },
  { question: "Why does encrypting the same text twice produce different results?", answer: "Each encryption operation generates a random 16-byte salt and 12-byte IV (Initialization Vector). These are included in the encrypted token. This randomness means encrypting the same plaintext with the same password will produce a different token each time — which is a security feature that prevents pattern analysis attacks." },
  { question: "How strong is the encryption?", answer: "AES-256-GCM with PBKDF2 key derivation (100k iterations) is considered very strong. Breaking it by brute force is computationally infeasible. However, the security ultimately depends on password strength — a weak or reused password significantly reduces security. Use a long, random passphrase for maximum protection." },
  { question: "What happens if I forget my password?", answer: "The encryption is one-way: if you lose the password, the data cannot be recovered. There is no backdoor, recovery key, or master password. This is by design — if recovery were possible, so would unauthorized decryption. Always store your password securely (a password manager is recommended)." },
  { question: "What is this tool good for?", answer: "Encrypting short pieces of sensitive text before sharing them over insecure channels (email, chat, GitHub issues). Examples: API keys, passwords, configuration values, personal notes. For large file encryption, database encryption, or enterprise use cases, use purpose-built tools like GPG, 1Password, or your cloud provider's KMS." },
];
---

<BaseLayout
  title="Text Encryption Tool — AES-256 Browser Encryption | Free Online"
  description="Encrypt and decrypt text in your browser using AES-256-GCM. No server calls — uses Web Crypto API. PBKDF2 key derivation, random salt and IV per operation. Secure, private, and free."
  tool="Text Encryption, AES-256 Encryption, Browser Encryption, AES-GCM, Web Crypto API, Text Decrypt Online"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Text Encryption Tool",
    "url": "https://devplaybook.cc/tools/text-encryption",
    "description": "Encrypt and decrypt text using AES-256-GCM in your browser. Uses Web Crypto API — no server, no data upload. PBKDF2 key derivation, random salt and IV.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Text Encryption / Decryption Tool</h1>
  <p class="text-text-muted mb-4">Encrypt and decrypt text with <strong>AES-256-GCM</strong> — the same standard used by governments and financial institutions. Everything runs in your browser using the built-in Web Crypto API. No server calls, no data uploaded, works offline. Uses PBKDF2 key derivation (100k iterations) and a random salt + IV for every encryption.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> AES-256-GCM encryption</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Web Crypto API — no server</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Works offline</span>
  </div>
  <TextEncryption client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Text Encryption Tool" relatedTags={['security', 'encryption', 'privacy', 'crypto', 'utilities']} />
</BaseLayout>
