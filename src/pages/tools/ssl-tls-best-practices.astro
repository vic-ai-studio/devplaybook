---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is the difference between TLS 1.2 and TLS 1.3?", answer: "TLS 1.3 (RFC 8446, 2018) is a major redesign with significant improvements: 1-RTT handshake (vs 2-RTT in TLS 1.2), 0-RTT resumption for repeat connections, removal of all weak cipher suites (RC4, DES, 3DES, MD5, SHA-1, CBC mode), perfect forward secrecy is now mandatory (ephemeral ECDH only), and simplified cipher suite negotiation. TLS 1.3 is 30-40% faster for new connections and should be used exclusively. TLS 1.0 and 1.1 are deprecated by RFC 8996 and disabled in all modern browsers." },
  { question: "What is HSTS and how do I enable it?", answer: "HTTP Strict Transport Security (HSTS) tells browsers to only connect to your domain over HTTPS, even if the user types http://. Once a browser sees the Strict-Transport-Security header, it will automatically upgrade all future requests to HTTPS for the specified max-age duration, preventing SSL stripping attacks. Set: Strict-Transport-Security: max-age=63072000; includeSubDomains; preload (2 years). To add your domain to the HSTS preload list (hardcoded in browsers), submit at hstspreload.org — this is permanent, so only do it when fully committed to HTTPS." },
  { question: "How often should I rotate TLS certificates?", answer: "Let's Encrypt certificates expire every 90 days and should be renewed at 60 days (30 days before expiry). Commercial certificates are typically issued for 1 year (maximum since 2020). Best practice: automate renewal with certbot or acme.sh — never rely on manual renewal. Set up monitoring to alert when certificates are within 30 days of expiry. For internal services, use automated certificate management like HashiCorp Vault PKI Secrets Engine or AWS Certificate Manager Private CA." },
  { question: "What cipher suites should I use in 2026?", answer: "For TLS 1.3, cipher suites are fixed and non-negotiable: TLS_AES_256_GCM_SHA384, TLS_CHACHA20_POLY1305_SHA256, TLS_AES_128_GCM_SHA256. For TLS 1.2 compatibility, use ECDHE+AESGCM+SHA256/384. Disable: CBC mode ciphers (BEAST/POODLE), RC4, 3DES, export ciphers, DH key exchange under 2048-bit. Mozilla's SSL Configuration Generator at ssl-config.mozilla.org is the gold standard reference and is updated as vulnerabilities are discovered." },
  { question: "What is certificate pinning and when should I use it?", answer: "Certificate pinning associates a specific TLS certificate (or public key hash) with an application, so the app refuses connections if the certificate doesn't match — even if it's signed by a trusted CA. It protects against compromised CAs or MITM with a fraudulently issued certificate. Use in: mobile apps with fixed server connections, high-security financial applications. Avoid for general web browsers (makes cert rotation difficult). Prefer public key pinning over full certificate pinning to allow cert renewal without app update. Google removed Chrome's HPKP support in 2018 due to site lockout risks." },
  { question: "How do I test my TLS configuration?", answer: "Use SSL Labs (ssllabs.com/ssltest) for a detailed A+ grade report including certificate chain, protocol versions, cipher suites, and known vulnerabilities (BEAST, POODLE, Heartbleed, ROBOT, etc.). Command-line testing: 'openssl s_client -connect yourhost:443 -tls1_3' to verify TLS 1.3 works. 'nmap --script ssl-enum-ciphers -p 443 yourhost' to enumerate all supported ciphers. 'testssl.sh' for comprehensive command-line testing. Run these tests after any server configuration change." },
];
---

<BaseLayout
  title="SSL/TLS Best Practices 2026: TLS 1.3, HSTS & Cert Management"
  description="Complete SSL/TLS best practices guide for 2026. Covers TLS 1.2 vs 1.3 comparison, cipher suites, HSTS setup, certificate rotation, Let's Encrypt automation, and Nginx/Apache configuration."
  tool="SSL TLS Best Practices, TLS 1.3 Configuration, HSTS Setup, Let's Encrypt, Nginx SSL Config"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "SSL/TLS Best Practices 2026: TLS 1.3, HSTS & Cert Management",
    "url": "https://devplaybook.cc/tools/ssl-tls-best-practices",
    "description": "Complete SSL/TLS best practices for 2026 including TLS 1.3, cipher suites, HSTS, certificate rotation, Let's Encrypt, and Nginx/Apache configuration.",
  })} />

  <h1 class="text-3xl font-bold mb-2">SSL/TLS Best Practices 2026</h1>
  <p class="text-text-muted mb-6">A comprehensive guide to deploying and maintaining secure TLS configurations. Covers TLS 1.3 migration, cipher suite hardening, HSTS, automated certificate management, and production-ready server configs.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TLS 1.2 vs 1.3 comparison</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> HSTS & preload setup</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Let's Encrypt automation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Nginx & Apache configs</span>
  </div>

  <h2 class="text-xl font-semibold mb-3">TLS 1.2 vs TLS 1.3 Comparison</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm mb-6">
      <thead>
        <tr class="border-b border-border text-left text-text-muted">
          <th class="py-2 pr-4">Feature</th>
          <th class="py-2 pr-4">TLS 1.2</th>
          <th class="py-2">TLS 1.3</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <tr><td class="py-2 pr-4">Handshake RTT</td><td class="py-2 pr-4 text-yellow-500">2-RTT</td><td class="py-2 text-green-500">1-RTT (0-RTT resumption)</td></tr>
        <tr><td class="py-2 pr-4">Cipher suite count</td><td class="py-2 pr-4 text-yellow-500">37+ (many weak)</td><td class="py-2 text-green-500">5 (all strong)</td></tr>
        <tr><td class="py-2 pr-4">Forward Secrecy</td><td class="py-2 pr-4 text-yellow-500">Optional</td><td class="py-2 text-green-500">Mandatory (ECDHE only)</td></tr>
        <tr><td class="py-2 pr-4">CBC mode ciphers</td><td class="py-2 pr-4 text-red-500">Supported (BEAST/POODLE)</td><td class="py-2 text-green-500">Removed</td></tr>
        <tr><td class="py-2 pr-4">RSA key exchange</td><td class="py-2 pr-4 text-red-500">Supported (no FS)</td><td class="py-2 text-green-500">Removed</td></tr>
        <tr><td class="py-2 pr-4">SHA-1 / MD5</td><td class="py-2 pr-4 text-red-500">Allowed in some configs</td><td class="py-2 text-green-500">Removed</td></tr>
        <tr><td class="py-2 pr-4">Encrypted handshake</td><td class="py-2 pr-4 text-yellow-500">Partial</td><td class="py-2 text-green-500">Most fields encrypted</td></tr>
        <tr><td class="py-2 pr-4">Browser support</td><td class="py-2 pr-4">Universal</td><td class="py-2 text-green-500">96%+ global (2026)</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mb-3">Nginx: Modern TLS Configuration</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-6">server &#123;
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name yourapp.com www.yourapp.com;

    # Certificate paths (Let's Encrypt)
    ssl_certificate     /etc/letsencrypt/live/yourapp.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/yourapp.com/privkey.pem;

    # Modern TLS protocols (disable 1.0, 1.1)
    ssl_protocols TLSv1.2 TLSv1.3;

    # TLS 1.3 ciphers (auto-selected, best practice to list explicitly)
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256;
    ssl_prefer_server_ciphers off;  # Let client choose (TLS 1.3)

    # Elliptic curves — prefer X25519, P-256
    ssl_ecdh_curve X25519:prime256v1:secp384r1;

    # Session resumption
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;  # Disable for forward secrecy

    # OCSP stapling (reduces handshake latency)
    ssl_stapling on;
    ssl_stapling_verify on;
    ssl_trusted_certificate /etc/letsencrypt/live/yourapp.com/chain.pem;
    resolver 1.1.1.1 8.8.8.8 valid=300s;

    # DH params (generate: openssl dhparam -out /etc/nginx/dhparam.pem 2048)
    ssl_dhparam /etc/nginx/dhparam.pem;

    # Security headers
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
    add_header X-Frame-Options DENY always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
&#125;

# HTTP → HTTPS redirect
server &#123;
    listen 80;
    listen [::]:80;
    server_name yourapp.com www.yourapp.com;
    return 301 https://$host$request_uri;
&#125;</pre>

  <h2 class="text-xl font-semibold mb-3">Let's Encrypt: Automated Certificate Management</h2>
  <h3 class="text-base font-semibold mb-2">Initial Setup with Certbot</h3>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Install certbot (Ubuntu/Debian)
sudo apt install certbot python3-certbot-nginx

# Obtain certificate + auto-configure nginx
sudo certbot --nginx -d yourapp.com -d www.yourapp.com

# Test renewal process
sudo certbot renew --dry-run

# Certbot auto-renewal is enabled via systemd timer:
sudo systemctl status certbot.timer</pre>

  <h3 class="text-base font-semibold mb-2">acme.sh Alternative (More Flexible)</h3>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Install acme.sh
curl https://get.acme.sh | sh

# Issue certificate (standalone mode)
acme.sh --issue -d yourapp.com -d www.yourapp.com --standalone

# Install to nginx paths
acme.sh --install-cert -d yourapp.com \
  --cert-file      /etc/nginx/ssl/cert.pem \
  --key-file       /etc/nginx/ssl/key.pem \
  --fullchain-file /etc/nginx/ssl/fullchain.pem \
  --reloadcmd      "systemctl reload nginx"

# Renews automatically via cron (added by acme.sh installer)</pre>

  <h3 class="text-base font-semibold mb-2">Certificate Expiry Monitoring</h3>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-6">#!/bin/bash
# check-cert-expiry.sh — run via cron, alert if < 30 days
DOMAIN="yourapp.com"
THRESHOLD=30  # days

EXPIRY=$(echo | openssl s_client -connect $&#123;DOMAIN&#125;:443 -servername $&#123;DOMAIN&#125; 2>/dev/null \
  | openssl x509 -noout -enddate 2>/dev/null \
  | cut -d= -f2)

EXPIRY_EPOCH=$(date -d "$&#123;EXPIRY&#125;" +%s)
TODAY_EPOCH=$(date +%s)
DAYS_LEFT=$(( (EXPIRY_EPOCH - TODAY_EPOCH) / 86400 ))

echo "Certificate expires in $&#123;DAYS_LEFT&#125; days"

if [ $&#123;DAYS_LEFT&#125; -lt $&#123;THRESHOLD&#125; ]; then
    # Send alert (webhook, email, PagerDuty, etc.)
    curl -X POST $&#123;SLACK_WEBHOOK&#125; \
      -d "&#123;\"text\":\"⚠️ TLS cert for $&#123;DOMAIN&#125; expires in $&#123;DAYS_LEFT&#125; days\"&#125;"
fi</pre>

  <h2 class="text-xl font-semibold mb-3">Apache TLS Configuration</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-6">&lt;VirtualHost *:443&gt;
    ServerName yourapp.com
    DocumentRoot /var/www/html

    SSLEngine on
    SSLCertificateFile      /etc/letsencrypt/live/yourapp.com/cert.pem
    SSLCertificateKeyFile   /etc/letsencrypt/live/yourapp.com/privkey.pem
    SSLCertificateChainFile /etc/letsencrypt/live/yourapp.com/chain.pem

    # Modern TLS only
    SSLProtocol -all +TLSv1.2 +TLSv1.3
    SSLCipherSuite ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305
    SSLHonorCipherOrder off  # TLS 1.3 ignores this

    # OCSP Stapling
    SSLUseStapling on
    SSLStaplingCache "shmcb:/var/run/ocsp(128000)"

    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
&lt;/VirtualHost&gt;</pre>

  <h2 class="text-xl font-semibold mb-3">TLS Security Checklist</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm mb-6">
      <thead>
        <tr class="border-b border-border text-left text-text-muted">
          <th class="py-2 pr-4">Check</th>
          <th class="py-2 pr-4">Requirement</th>
          <th class="py-2">Verify With</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <tr><td class="py-2 pr-4">Protocol version</td><td class="py-2 pr-4">TLS 1.2+ only</td><td class="py-2 text-text-muted">SSL Labs test</td></tr>
        <tr><td class="py-2 pr-4">Forward secrecy</td><td class="py-2 pr-4">ECDHE or DHE key exchange</td><td class="py-2 text-text-muted">ssl-enum-ciphers</td></tr>
        <tr><td class="py-2 pr-4">HSTS header</td><td class="py-2 pr-4">max-age ≥ 31536000</td><td class="py-2 text-text-muted">curl -I yourhost</td></tr>
        <tr><td class="py-2 pr-4">OCSP stapling</td><td class="py-2 pr-4">Enabled and verified</td><td class="py-2 text-text-muted">openssl s_client -status</td></tr>
        <tr><td class="py-2 pr-4">Certificate chain</td><td class="py-2 pr-4">Complete chain, not expired</td><td class="py-2 text-text-muted">SSL Labs / certbot</td></tr>
        <tr><td class="py-2 pr-4">Renewal automation</td><td class="py-2 pr-4">Certbot/acme.sh timer active</td><td class="py-2 text-text-muted">systemctl status certbot.timer</td></tr>
        <tr><td class="py-2 pr-4">HTTP redirect</td><td class="py-2 pr-4">301 from HTTP to HTTPS</td><td class="py-2 text-text-muted">curl -L http://yourhost</td></tr>
      </tbody>
    </table>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SSL TLS Best Practices" relatedTags={['security', 'devops', 'backend', 'web']} />
</BaseLayout>
