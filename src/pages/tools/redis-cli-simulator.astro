---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RedisCLISimulator from '../../components/RedisCLISimulator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Redis CLI Simulator — Test Redis Commands Online"
  description="Simulate Redis commands in your browser with no install needed. Run SET, GET, DEL, EXPIRE, TTL, HSET, LPUSH, SADD and more. In-memory Redis playground with command history. Free online Redis CLI."
  tool="Redis CLI Online, Redis Command Simulator, Test Redis Commands, Redis Playground"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Redis CLI Simulator",
    "url": "https://devplaybook.cc/tools/redis-cli-simulator",
    "description": "Simulate Redis commands in your browser. Run SET, GET, DEL, EXPIRE, TTL, HSET, LPUSH, SADD, and more with no install needed.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Redis CLI Simulator</h1>
  <p class="text-text-muted mb-8">
    Run Redis commands directly in your browser — no install, no server. Test
    <code class="font-mono bg-surface px-1 rounded">SET</code>,
    <code class="font-mono bg-surface px-1 rounded">GET</code>,
    <code class="font-mono bg-surface px-1 rounded">HSET</code>,
    <code class="font-mono bg-surface px-1 rounded">LPUSH</code>,
    <code class="font-mono bg-surface px-1 rounded">EXPIRE</code>,
    and more. Results are syntax-highlighted and all data lives in-memory in your tab.
    Great for learning Redis commands or quickly prototyping data structures.
  </p>
  <RedisCLISimulator client:only="preact" />
  <ToolPageCta currentTool="Redis CLI Simulator" relatedTags={['redis', 'database', 'cache', 'cli', 'developer-tools']} />
</BaseLayout>
