---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HttpMethods from '../../components/HttpMethods.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="HTTP Methods Reference"
  description="Complete HTTP methods reference: GET, POST, PUT, PATCH, DELETE, HEAD, OPTIONS, CONNECT, TRACE. Covers safe, idempotent, and cacheable properties with examples."
  tool="HTTP Methods Reference, REST API Methods, GET POST PUT DELETE, HTTP Verbs Guide"
>
  <h1 class="text-3xl font-bold mb-2">HTTP Methods Reference</h1>
  <p class="text-text-muted mb-8">Quick reference for all HTTP methods with safe, idempotent, and cacheable properties. Click any method for a detailed description, use case, and example request.</p>
  <HttpMethods client:only="preact" />
  <ToolPageCta currentTool="HTTP Methods Reference" relatedTags={['api', 'http', 'rest', 'networking', 'backend']} />
</BaseLayout>
