---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="AI Regex Explainer — Pro Tool | DevPlaybook"
  description="Paste any regular expression and get a plain-English breakdown, match examples, and gotchas. DevPlaybook Pro feature."
  tool="AI Regex Explainer, Regex Analyzer, Regular Expression Explainer"
>
  <!-- Pro Gate loading -->
  <div id="pro-loading" class="max-w-2xl mx-auto py-16 text-center text-text-muted">
    Checking your account...
  </div>

  <!-- Not Pro: Upgrade Gate -->
  <div id="pro-gate" class="hidden max-w-2xl mx-auto py-16 px-4 text-center">
    <div class="text-6xl mb-6">🔎</div>
    <h1 class="text-3xl font-bold mb-3">AI Regex Explainer is a <span class="text-primary">Pro</span> feature</h1>
    <p class="text-text-muted text-lg mb-8">
      Demystify any regex in seconds — plain English breakdown, match examples, and gotcha warnings.
    </p>
    <div class="bg-bg-card border border-border rounded-2xl p-8 mb-8 text-left">
      <h2 class="font-semibold mb-4">Pro includes:</h2>
      <ul class="space-y-2 text-text-muted text-sm">
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> AI Regex Explainer (this tool)</li>
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> AI Code Review</li>
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> AI Test Generator</li>
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> AI Error Explainer, SQL Builder & more</li>
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> 7-day free trial, cancel anytime</li>
      </ul>
    </div>
    <a href="/pricing" class="inline-block bg-primary hover:bg-primary-dark text-white font-bold px-10 py-4 rounded-xl transition-colors text-lg">
      Start Free Trial — $9/mo
    </a>
    <p class="text-text-muted text-sm mt-4">
      Already subscribed? <a href="/signin" class="text-primary hover:underline">Sign in</a>
    </p>
  </div>

  <!-- Pro Tool UI -->
  <div id="pro-tool" class="hidden">
    <div class="flex items-center gap-3 mb-2">
      <h1 class="text-3xl font-bold">AI Regex Explainer</h1>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-primary/20 text-primary border border-primary/30">PRO</span>
    </div>
    <p class="text-text-muted mb-8">Paste any regular expression and get a part-by-part breakdown in plain English, with match examples and gotchas.</p>

    <!-- Input section -->
    <div class="bg-bg-card border border-border rounded-xl p-6 mb-6">
      <label class="block text-sm font-medium mb-3" for="pattern-input">Regular Expression</label>
      <div class="flex gap-2 mb-4">
        <div class="flex-1 flex items-center gap-0 rounded-lg border border-border overflow-hidden bg-bg focus-within:border-primary transition-colors">
          <span class="px-3 py-2.5 text-text-muted font-mono text-sm select-none border-r border-border">/</span>
          <input
            id="pattern-input"
            type="text"
            placeholder="^[\w.-]+@[\w.-]+\.\w{2,}$"
            class="flex-1 px-3 py-2.5 bg-transparent text-text font-mono text-sm focus:outline-none"
          />
          <span class="px-3 py-2.5 text-text-muted font-mono text-sm select-none border-l border-border">/</span>
          <input
            id="flags-input"
            type="text"
            placeholder="gi"
            maxlength="8"
            class="w-16 px-2 py-2.5 bg-transparent text-text font-mono text-sm focus:outline-none"
          />
        </div>
        <button
          id="explain-btn"
          class="px-6 py-2.5 rounded-lg bg-primary hover:bg-primary-dark text-white font-bold transition-colors duration-200 disabled:opacity-50 whitespace-nowrap"
        >
          Explain
        </button>
      </div>
      <p class="text-xs text-text-muted">Enter the pattern without surrounding slashes. Add flags (g, i, m, s) in the flags field.</p>
      <p id="explain-error" class="text-xs text-red-400 hidden mt-2"></p>

      <!-- Quick examples -->
      <div class="mt-4 flex flex-wrap gap-2">
        <span class="text-xs text-text-muted mr-1">Try:</span>
        {[
          { label: 'Email', pattern: '^[\\w.-]+@[\\w.-]+\\.\\w{2,}$', flags: '' },
          { label: 'URL', pattern: 'https?:\\/\\/(www\\.)?[-\\w@:%._+~#=]{1,256}\\.[a-z]{2,6}\\b([-\\w@:%_+.~#?&/=]*)', flags: 'i' },
          { label: 'IPv4', pattern: '^((25[0-5]|2[0-4]\\d|[01]?\\d\\d?)\\.){3}(25[0-5]|2[0-4]\\d|[01]?\\d\\d?)$', flags: '' },
          { label: 'ISO Date', pattern: '\\d{4}-(0[1-9]|1[0-2])-(0[1-9]|[12]\\d|3[01])', flags: '' },
        ].map(ex => (
          <button
            data-pattern={ex.pattern}
            data-flags={ex.flags}
            class="example-btn text-xs px-2.5 py-1 rounded-full border border-border hover:border-primary hover:text-primary text-text-muted transition-colors"
          >
            {ex.label}
          </button>
        ))}
      </div>
    </div>

    <!-- Output -->
    <div
      id="output-placeholder"
      class="min-h-[300px] rounded-xl bg-bg border border-border flex items-center justify-center text-text-muted text-sm"
    >
      Your regex explanation will appear here
    </div>
    <div
      id="output-loading"
      class="hidden min-h-[300px] rounded-xl bg-bg border border-border flex items-center justify-center text-text-muted text-sm"
    >
      <div class="text-center">
        <div class="animate-pulse text-3xl mb-3">🔎</div>
        <p>Analyzing your regex...</p>
      </div>
    </div>
    <div
      id="output-content"
      class="hidden rounded-xl bg-bg border border-border p-6 text-sm prose prose-invert prose-sm max-w-none"
    >
      <div class="flex items-center justify-between mb-4">
        <span class="text-xs text-text-muted font-mono" id="pattern-display"></span>
        <button id="copy-btn" class="text-xs text-text-muted hover:text-primary transition-colors">Copy explanation</button>
      </div>
      <div id="output-body"></div>
    </div>

    <div class="mt-8 p-4 bg-bg-card border border-border rounded-xl text-xs text-text-muted">
      <strong>Pro tip:</strong> For complex regex, the AI will warn you about catastrophic backtracking risks — a common source of production performance issues.
    </div>
  </div>

  <ToolPageCta currentTool="AI Regex Explainer" relatedTags={['ai', 'regex', 'development']} />
</BaseLayout>

<script is:inline>
  function renderMarkdown(md) {
    return md
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
      .replace(/^### (.+)$/gm, '<h3 class="font-semibold text-base mt-4 mb-1">$1</h3>')
      .replace(/^## (.+)$/gm, '<h2 class="font-bold text-lg mt-5 mb-2">$1</h2>')
      .replace(/^# (.+)$/gm, '<h1 class="font-bold text-xl mt-5 mb-2">$1</h1>')
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/`([^`]+)`/g, '<code class="bg-bg-card px-1 rounded text-primary font-mono">$1</code>')
      .replace(/^```[\w]*\n([\s\S]*?)```/gm, '<pre class="bg-bg-card border border-border rounded-lg p-3 overflow-auto font-mono text-xs my-2"><code>$1</code></pre>')
      .replace(/^\|(.+)\|$/gm, (row) => {
        const cells = row.split('|').slice(1, -1).map(c => `<td class="px-3 py-1.5 border-b border-border">${c.trim()}</td>`).join('');
        return `<tr>${cells}</tr>`;
      })
      .replace(/(<tr>.*<\/tr>\n?)+/g, (m) => {
        const rows = m.replace(/^(<tr>.*?<\/tr>)/, '<thead class="text-text-muted font-semibold bg-bg-card">$1</thead><tbody>') + '</tbody>';
        return `<table class="w-full text-xs border border-border rounded-lg overflow-hidden my-3">${rows}</table>`;
      })
      .replace(/^---+$/gm, '')
      .replace(/^[-*] (.+)$/gm, '<li class="ml-4 list-disc">$1</li>')
      .replace(/(<li[^>]*>.*<\/li>\n?)+/g, (m) => `<ul class="space-y-1 my-2">${m}</ul>`)
      .replace(/\n\n/g, '</p><p class="mb-2">')
      .replace(/^(?!<[hult])(.+)$/gm, (m) => m.trim() ? m : '')
      .trim();
  }

  async function init() {
    let session;
    try {
      const res = await fetch('/api/auth/session');
      session = await res.json();
    } catch {
      session = { loggedIn: false };
    }

    document.getElementById('pro-loading').classList.add('hidden');

    if (!session.loggedIn || !session.isPro) {
      document.getElementById('pro-gate').classList.remove('hidden');
      return;
    }

    document.getElementById('pro-tool').classList.remove('hidden');

    const btn = document.getElementById('explain-btn');
    const patternInput = document.getElementById('pattern-input');
    const flagsInput = document.getElementById('flags-input');
    const errorMsg = document.getElementById('explain-error');
    const placeholder = document.getElementById('output-placeholder');
    const loading = document.getElementById('output-loading');
    const outputContent = document.getElementById('output-content');
    const outputBody = document.getElementById('output-body');
    const patternDisplay = document.getElementById('pattern-display');
    const copyBtn = document.getElementById('copy-btn');

    // Example buttons
    document.querySelectorAll('.example-btn').forEach(exBtn => {
      exBtn.addEventListener('click', () => {
        patternInput.value = exBtn.dataset.pattern;
        flagsInput.value = exBtn.dataset.flags || '';
      });
    });

    let lastExplanation = '';

    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(lastExplanation).then(() => {
        copyBtn.textContent = 'Copied!';
        setTimeout(() => { copyBtn.textContent = 'Copy explanation'; }, 2000);
      });
    });

    async function explain() {
      const pattern = patternInput.value.trim();
      if (!pattern) { errorMsg.textContent = 'Please enter a regex pattern first.'; errorMsg.classList.remove('hidden'); return; }
      errorMsg.classList.add('hidden');

      btn.disabled = true;
      btn.textContent = 'Analyzing...';
      placeholder.classList.add('hidden');
      outputContent.classList.add('hidden');
      loading.classList.remove('hidden');

      const flags = flagsInput.value.trim();

      try {
        const res = await fetch('/api/ai/regex-explainer', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ pattern, flags }),
        });
        const data = await res.json();

        if (!res.ok) {
          if (res.status === 403) {
            errorMsg.textContent = 'Pro subscription required. Refresh to check your status.';
          } else if (res.status === 401) {
            errorMsg.textContent = 'Session expired — please sign in again.';
          } else {
            errorMsg.textContent = data.error || 'Something went wrong.';
          }
          errorMsg.classList.remove('hidden');
          loading.classList.add('hidden');
          placeholder.classList.remove('hidden');
        } else {
          lastExplanation = data.explanation;
          patternDisplay.textContent = flags ? `/${pattern}/${flags}` : `/${pattern}/`;
          outputBody.innerHTML = '<p class="mb-2">' + renderMarkdown(data.explanation) + '</p>';
          loading.classList.add('hidden');
          outputContent.classList.remove('hidden');
        }
      } catch {
        errorMsg.textContent = 'Network error — please try again.';
        errorMsg.classList.remove('hidden');
        loading.classList.add('hidden');
        placeholder.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Explain';
      }
    }

    btn.addEventListener('click', explain);
    patternInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') explain(); });
  }

  init();
</script>
