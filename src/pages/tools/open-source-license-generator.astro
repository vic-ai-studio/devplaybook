---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OpenSourceLicenseGenerator from '../../components/OpenSourceLicenseGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "Which open source license should I choose?", answer: "MIT is the most popular choice — it's simple, permissive, and lets anyone use your code with attribution. Apache 2.0 is similar but adds patent protection, making it preferred by companies. GPL-3.0 is copyleft — anyone who distributes derived works must also use GPL. BSD-3-Clause is like MIT but adds a non-endorsement clause. ISC is functionally identical to MIT, just shorter. MPL-2.0 is file-level copyleft — modified files stay MPL, but you can link with proprietary code." },
  { question: "What is the difference between permissive and copyleft licenses?", answer: "Permissive licenses (MIT, Apache, BSD, ISC) allow anyone to use, modify, and redistribute your code — even in proprietary software — as long as they keep your copyright notice. Copyleft licenses (GPL, AGPL, MPL) require that derivative works also be distributed under the same license. Strong copyleft (GPL) covers the entire combined work; weak copyleft (MPL, LGPL) only covers the original files." },
  { question: "Do I need a license file on my GitHub repo?", answer: "Without a license, your code is under exclusive copyright by default — others cannot legally use, copy, or distribute it, even if it's public. Always add a LICENSE file to make your intent clear. GitHub won't show the license badge without a recognized LICENSE file in the root of your repository." },
  { question: "What is the Apache 2.0 patent grant?", answer: "Apache 2.0 includes an explicit patent license: contributors grant users a patent license for any patents they hold that are necessarily infringed by the contribution. If a contributor later sues you for patent infringement related to the project, your Apache license terminates. This makes Apache 2.0 safer than MIT when dealing with large corporations." },
  { question: "Can I use MIT-licensed code in a commercial product?", answer: "Yes. MIT, Apache 2.0, BSD, and ISC are all permissive licenses that explicitly allow commercial use. The only requirement is that you keep the original copyright notice and license text somewhere in your distribution (usually in a NOTICES file, LICENSE file, or About screen). You do NOT need to open-source your proprietary code when using MIT-licensed libraries." },
];
---

<BaseLayout
  title="Open Source License Generator — MIT, Apache, GPL, BSD — Free Online Tool"
  description="Generate the full license text for MIT, Apache 2.0, GPL-3.0, BSD-3-Clause, ISC, and MPL-2.0. Enter your name and year to get a ready-to-use LICENSE file for your GitHub repository."
  tool="open source license generator, MIT license template, Apache license text, GPL license, BSD license, ISC license, MPL license"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Open Source License Generator</h1>
  <p class="text-text-muted mb-4">
    Pick a license, enter your name and year, and get the complete <code class="bg-surface px-1 rounded text-sm">LICENSE</code> file text ready to paste into your repository.
    Covers MIT, Apache 2.0, GPL-3.0, BSD-3-Clause, ISC, and MPL-2.0.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 6 major licenses</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> SPDX identifiers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GitHub-recognized format</span>
  </div>
  <OpenSourceLicenseGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Open Source License Generator" relatedTags={['git', 'github', 'open-source', 'license', 'legal']} />
</BaseLayout>
