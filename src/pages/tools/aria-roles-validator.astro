---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AriaRolesValidator from '../../components/AriaRolesValidator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What are ARIA roles and why do they matter?",
    answer: "ARIA (Accessible Rich Internet Applications) roles define the purpose of an HTML element for assistive technologies like screen readers. They are critical for web accessibility compliance (WCAG 2.1) and help users with disabilities navigate and interact with web applications correctly."
  },
  {
    question: "When should I use ARIA roles vs native HTML elements?",
    answer: "The first rule of ARIA is: don't use ARIA if you can use a native HTML element. Native elements like <button>, <nav>, <input>, and <dialog> come with built-in role semantics. ARIA roles are needed when you're building custom widgets (e.g., a custom dropdown) using non-semantic elements like <div> or <span>."
  },
  {
    question: "What are required ARIA attributes?",
    answer: "Some roles require specific attributes to function correctly. For example, role='checkbox' requires aria-checked to communicate its state, role='slider' requires aria-valuenow/min/max, and role='combobox' requires aria-expanded. Without these, the role is incomplete and screen readers may announce incorrect information."
  },
  {
    question: "What is the difference between aria-label and aria-labelledby?",
    answer: "aria-label provides an inline accessible name as a string value (e.g., aria-label='Close dialog'). aria-labelledby references another element's ID that contains the label text (e.g., aria-labelledby='modal-title'). Prefer aria-labelledby when visible text already describes the element, as it ties the visible label to the accessible name."
  },
  {
    question: "What is aria-hidden and when should I use it?",
    answer: "aria-hidden='true' hides an element and all its children from the accessibility tree. Use it for decorative icons, duplicated visible text, and visual-only elements. Never use aria-hidden on interactive elements (buttons, links, inputs) as it removes them from keyboard navigation."
  },
  {
    question: "How do live regions work?",
    answer: "ARIA live regions (role='alert', 'status', 'log') automatically announce dynamic content changes to screen readers. aria-live='assertive' interrupts the user immediately (use sparingly, for errors). aria-live='polite' waits until the user is idle. role='alert' implies aria-live='assertive' automatically."
  },
];
---

<BaseLayout
  title="ARIA Roles Validator — Web Accessibility ARIA Compliance Checker"
  description="Validate ARIA roles and attributes for web accessibility compliance. Check required attributes, avoid redundant roles, and browse all ARIA role definitions with descriptions."
  tool="ARIA Roles Validator, Accessibility Checker, WAI-ARIA Validator, ARIA Attributes Checker"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "ARIA Roles Validator",
    "url": "https://devplaybook.cc/tools/aria-roles-validator",
    "description": "Validate ARIA roles and attributes for web accessibility. Check required attributes, redundant role usage, and browse WAI-ARIA role definitions.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">ARIA Roles Validator</h1>
  <p class="text-text-muted mb-4">
    Validate ARIA roles and attributes for web accessibility compliance. Check required attributes,
    detect redundant role usage, and browse all WAI-ARIA role definitions with descriptions.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 50+ ARIA roles</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Required attribute check</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Native HTML redundancy detection</span>
  </div>
  <AriaRolesValidator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="ARIA Roles Validator" relatedTags={['accessibility', 'html', 'web', 'a11y', 'developer-tools']} />
</BaseLayout>
