---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DataSizeConverter from '../../components/DataSizeConverter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the difference between binary and decimal units?", answer: "Binary (IEC) uses powers of 1024: 1 KiB = 1,024 bytes. Decimal (SI) uses powers of 1000: 1 KB = 1,000 bytes. Operating systems like Windows report file sizes in binary but label them as KB/MB/GB. Mac and Linux use decimal. This causes the apparent discrepancy when a '1 TB' drive shows up as ~931 GB on Windows." },
  { question: "How many bytes is 1 GB?", answer: "In binary (IEC), 1 GiB = 1,073,741,824 bytes (1024³). In decimal (SI), 1 GB = 1,000,000,000 bytes (1000³). Hard drive manufacturers use decimal, which is why a '1 TB' drive actually stores 1,000,000,000,000 bytes — about 931 binary GiB." },
  { question: "What are KB, MB, GB, TB in binary vs decimal?", answer: "Binary: 1 KB = 1,024 B, 1 MB = 1,048,576 B, 1 GB = 1,073,741,824 B, 1 TB = 1,099,511,627,776 B. Decimal: 1 KB = 1,000 B, 1 MB = 1,000,000 B, 1 GB = 1,000,000,000 B, 1 TB = 1,000,000,000,000 B." },
  { question: "Why does my file look smaller on disk?", answer: "Filesystems allocate space in blocks (typically 4 KB). Even a 1-byte file occupies one full 4 KB block on disk. This is why 'size on disk' is always a multiple of the block size and often larger than the actual file size." },
  { question: "How do I convert MB to GB?", answer: "Divide MB by 1,024 (binary) or 1,000 (decimal) to get GB. For example, 2,048 MB ÷ 1,024 = 2 GiB. Use this tool to convert any data size instantly by entering a value and selecting the source unit." },
];
---

<BaseLayout
  title="Data Size Converter — Free Online Tool | Bytes KB MB GB TB"
  description="Convert between bytes, KB, MB, GB, TB, PB instantly. Supports both binary (1024) and decimal (1000) modes. Shows common file size references. Free, runs in your browser."
  tool="Data Size Converter, Bytes to MB, MB to GB, GB to TB, Binary vs Decimal, File Size Calculator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Data Size Converter</h1>
  <p class="text-text-muted mb-4">Convert between bytes, KB, MB, GB, TB, and PB. Switch between binary (powers of 1024, IEC standard) and decimal (powers of 1000, SI standard) modes. Includes common file size references to put numbers in context.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <DataSizeConverter client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Data Size Converter" relatedTags={['utilities', 'data', 'storage', 'units', 'calculator']} />
</BaseLayout>
