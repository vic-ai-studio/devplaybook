let activeProvider = 'all';
let searchQuery    = '';

// ─── Render helpers ───────────────────────────────────────────────────────────
function escapeHtml(str: string) {
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function formatDownloads(dl: string) {
  return `<span class="font-semibold text-text">${dl}</span><span class="text-text-muted">/wk</span>`;
}

function renderCard(m: TFModule) {
  const pm = PROVIDER_META[m.provider];
  return `
    <div
      class="module-card bg-bg-card border border-border rounded-xl p-4 flex flex-col gap-3 hover:border-primary/60 transition-colors cursor-pointer"
      data-id="${m.id}"
      role="button"
      tabindex="0"
      aria-label="View details for ${escapeHtml(m.name)}"
    >
      <div class="flex items-start justify-between gap-2">
        <div class="flex items-center gap-2 flex-wrap">
          <span class="text-xs px-2 py-0.5 rounded-full font-medium ${pm.color} ${pm.bg}">
            ${pm.icon} ${pm.label}
          </span>
          <span class="text-xs text-text-muted border border-border rounded-full px-2 py-0.5">${escapeHtml(m.category)}</span>
        </div>
        ${m.verified ? `
          <span class="flex items-center gap-1 text-xs text-blue-400 flex-shrink-0" title="Verified by provider">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Verified
          </span>` : ''}
      </div>

      <div>
        <h3 class="font-semibold text-sm leading-snug">${escapeHtml(m.name)}</h3>
        <p class="text-xs text-text-muted font-mono mt-0.5 truncate" title="${escapeHtml(m.source)}">${escapeHtml(m.source)}</p>
      </div>

      <p class="text-xs text-text-muted line-clamp-2 leading-relaxed flex-1">${escapeHtml(m.description)}</p>

      <div class="flex items-center justify-between pt-1 border-t border-border mt-auto">
        <span class="text-xs font-mono text-primary">${escapeHtml(m.version)}</span>
        <span class="text-xs">${formatDownloads(m.weeklyDownloads)}</span>
        <button
          class="copy-source-btn text-xs px-2.5 py-1 bg-primary/10 text-primary rounded-lg hover:bg-primary/20 transition-colors font-medium"
          data-id="${m.id}"
          title="Copy module source line"
        >Copy source</button>
      </div>
    </div>
  `;
}

function getFilteredModules() {
  const q = searchQuery.toLowerCase().trim();
  return MODULES.filter(m => {
    const providerMatch = activeProvider === 'all' || m.provider === activeProvider;
    if (!providerMatch) return false;
    if (!q) return true;
    return (
      m.name.toLowerCase().includes(q) ||
      m.source.toLowerCase().includes(q) ||
      m.category.toLowerCase().includes(q) ||
      m.description.toLowerCase().includes(q) ||
      m.provider.toLowerCase().includes(q)
    );
  });
}

function renderGrid() {
  const grid   = document.getElementById('module-grid')!;
  const empty  = document.getElementById('empty-state')!;
  const count  = document.getElementById('result-count')!;
  const mods   = getFilteredModules();

  count.textContent = `${mods.length} module${mods.length !== 1 ? 's' : ''}`;

  if (mods.length === 0) {
    grid.innerHTML = '';
    empty.classList.remove('hidden');
  } else {
    empty.classList.add('hidden');
    grid.innerHTML = mods.map(renderCard).join('');
    // Re-attach card events after re-render
    attachCardEvents();
  }
}

// ─── Modal ────────────────────────────────────────────────────────────────────
function openModal(id: string) {
  const m = MODULES.find(x => x.id === id);
  if (!m) return;
  const pm = PROVIDER_META[m.provider];
  const modal = document.getElementById('module-modal')!;

  const badge = document.getElementById('modal-provider-badge')!;
  badge.textContent = `${pm.icon} ${pm.label}`;
  badge.className = `text-xs px-2 py-0.5 rounded-full font-medium ${pm.color} ${pm.bg}`;

  const verifiedEl = document.getElementById('modal-verified')!;
  if (m.verified) {
    verifiedEl.classList.remove('hidden');
    verifiedEl.classList.add('flex');
  } else {
    verifiedEl.classList.add('hidden');
    verifiedEl.classList.remove('flex');
  }

  (document.getElementById('modal-title')! as HTMLElement).textContent = m.name;
  (document.getElementById('modal-source')! as HTMLElement).textContent = m.source;
  (document.getElementById('modal-description')! as HTMLElement).textContent = m.description;
  (document.getElementById('modal-version')! as HTMLElement).textContent = `v${m.version}`;
  (document.getElementById('modal-downloads')! as HTMLElement).textContent = `${m.weeklyDownloads}`;

  const regLink = document.getElementById('modal-registry-link') as HTMLAnchorElement;
  const regUrl = `https://registry.terraform.io/modules/${m.source}`;
  regLink.href    = regUrl;
  regLink.textContent = regUrl.replace('https://', '');

  const sourceLine = `module "${m.name.toLowerCase().replace(/[^a-z0-9]+/g, '_')}" {\n  source  = "${m.source}"\n  version = "~> ${m.version.split('.').slice(0,2).join('.')}"\n}`;
  (document.getElementById('modal-source-block')! as HTMLElement).textContent = sourceLine;

  (document.getElementById('modal-hcl')! as HTMLElement).textContent = m.hcl;

  const reqVarsEl = document.getElementById('modal-required-vars')!;
  reqVarsEl.innerHTML = m.requiredVars.map(v =>
    `<span class="text-xs font-mono px-2 py-0.5 bg-amber-400/10 text-amber-400 rounded border border-amber-400/20">${escapeHtml(v)}</span>`
  ).join('');

  const outputsEl = document.getElementById('modal-outputs')!;
  outputsEl.innerHTML = m.outputs.map(o =>
    `<span class="text-xs font-mono px-2 py-0.5 bg-green-400/10 text-green-400 rounded border border-green-400/20">${escapeHtml(o)}</span>`
  ).join('');

  modal.classList.remove('hidden');
  document.body.style.overflow = 'hidden';

  // Copy source button
  document.getElementById('modal-copy-source')!.onclick = () => {
    navigator.clipboard.writeText(sourceLine).then(() => {
      const btn = document.getElementById('modal-copy-source')!;
      const orig = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = orig; }, 1500);
    });
  };

  // Copy HCL button
  document.getElementById('modal-copy-hcl')!.onclick = () => {
    navigator.clipboard.writeText(m.hcl).then(() => {
      const btn = document.getElementById('modal-copy-hcl')!;
      const orig = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = orig; }, 1500);
    });
  };
}

function closeModal() {
  document.getElementById('module-modal')!.classList.add('hidden');
  document.body.style.overflow = '';
}

// ─── Event attachment ─────────────────────────────────────────────────────────
function attachCardEvents() {
  document.querySelectorAll<HTMLElement>('.module-card').forEach(card => {
    card.addEventListener('click', (e) => {
      const tgt = e.target as HTMLElement;
      if (tgt.classList.contains('copy-source-btn') || tgt.closest('.copy-source-btn')) return;
      openModal(card.dataset.id!);
    });
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') openModal(card.dataset.id!);
    });
  });

  document.querySelectorAll<HTMLElement>('.copy-source-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const m = MODULES.find(x => x.id === btn.dataset.id!);
      if (!m) return;
      const line = `source  = "${m.source}"\nversion = "~> ${m.version.split('.').slice(0,2).join('.')}"`;
      navigator.clipboard.writeText(line).then(() => {
        const orig = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = orig; }, 1500);
      });
    });
  });
}

// ─── Bootstrap ────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  // Initial render
  renderGrid();

  // Search
  document.getElementById('search-input')!.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value;
    renderGrid();
  });

  // Provider filter buttons
  document.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      activeProvider = btn.dataset.provider!;
      document.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach(b => {
        b.classList.remove('active', 'border-primary', 'bg-primary/10', 'text-primary');
        b.classList.add('border-border');
      });
      btn.classList.add('active', 'border-primary', 'bg-primary/10', 'text-primary');
      btn.classList.remove('border-border');
      renderGrid();
    });
  });

  // Modal close
  document.getElementById('modal-close')!.addEventListener('click', closeModal);
  document.getElementById('module-modal')!.addEventListener('click', (e) => {
    if (e.target === document.getElementById('module-modal')) closeModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
});
</script>
