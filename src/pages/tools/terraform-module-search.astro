---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is a Terraform module and why should I use one?",
    answer: "A Terraform module is a reusable package of Terraform configuration that encapsulates a set of resources with a defined interface (input variables and outputs). Instead of writing hundreds of lines of HCL to configure an EKS cluster from scratch, you call a community-maintained module and pass a handful of variables. Modules enforce best practices, reduce copy-paste drift across environments, and make your root configuration readable. The Terraform Registry at registry.terraform.io hosts thousands of free, open-source modules — the most popular ones have been downloaded hundreds of millions of times and are maintained by cloud vendors or large community contributors."
  },
  {
    question: "How does Terraform module versioning work?",
    answer: "Module versions follow Semantic Versioning (semver: MAJOR.MINOR.PATCH). In your module block you set a version constraint using operators like = (exact), ~> (pessimistic constraint — allows only patch/minor bumps), >= / <= (range), or != (exclude). The ~> operator is the most common: version = \"~> 5.0\" means >= 5.0.0, < 6.0.0. Always pin to at least a minor version in production — never omit the version constraint, or Terraform will use the latest at plan time, which can cause unexpected drift. Run terraform init -upgrade to pull the latest version matching your constraint."
  },
  {
    question: "What does the 'Verified' badge on the Terraform Registry mean?",
    answer: "A verified badge (blue checkmark) on the Terraform Registry means the module is published and maintained by the official technology partner or cloud vendor — for example, terraform-aws-modules/vpc/aws is maintained by the terraform-aws-modules GitHub organization, whose members include HashiCorp employees and recognized AWS community contributors. Verified modules are expected to follow registry quality standards, include documentation, test coverage, and regular updates. Non-verified community modules can still be excellent, but always check the last update date, open issues, and download count before adopting one in production."
  },
  {
    question: "Should I use a monorepo or separate repos for Terraform modules?",
    answer: "Both patterns are widely used, and the right choice depends on team size and release cadence. A monorepo (all modules in one repo, versioned together) is simpler to set up, easier to make cross-module changes atomically, and well-suited for small-to-medium teams. Separate module repos (one repo per module, each with its own semantic version tag) give consumers explicit version pinning, independent changelogs, and the ability to adopt upgrades module by module — preferred by large platform teams. A practical middle ground is a modules monorepo with subdirectory-based versioning using tools like terraform-docs, terratest, and release-please to automate versioning per subdirectory."
  },
  {
    question: "How do I test a Terraform module before using it in production?",
    answer: "There are three common testing strategies. (1) terraform validate: built-in, checks HCL syntax and configuration consistency — fast but shallow. (2) Terratest: a Go testing library from Gruntwork that deploys real infrastructure, runs assertions, and destroys it — thorough but slow and costly. (3) terraform test (native, added in Terraform 1.6): runs .tftest.hcl files that spin up mock or real resources and assert outputs — the recommended approach for 2024+ projects. For modules you pull from the registry, check the /tests directory in the GitHub repo to see what the maintainer tests, and always run terraform plan against a non-production workspace before applying."
  }
];
---

<BaseLayout
  title="Terraform Registry Module Finder — Browse Popular Terraform Modules"
  description="Browse and search 30+ popular Terraform modules for AWS, GCP, Azure, Kubernetes, and more. Filter by provider, search by keyword, view usage HCL snippets, and copy module source lines instantly."
  tool="terraform module search, terraform registry modules, terraform aws modules, terraform eks module, terraform vpc module, terraform rds module, iac modules"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Terraform Registry Module Finder",
    "url": "https://devplaybook.cc/tools/terraform-module-search",
    "description": "Browse popular Terraform modules for AWS, GCP, Azure, and Kubernetes. View usage snippets and copy module source lines.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Terraform Registry Module Finder</h1>
  <p class="text-text-muted mb-4">Browse 30+ popular Terraform modules for AWS, GCP, Azure, Kubernetes, and more. Search by keyword, filter by provider, view HCL usage examples, and copy the module source line with one click.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 30+ curated popular modules</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Filter by AWS / GCP / Azure / Generic</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> HCL usage snippets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy module source line</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No API calls — fully offline</span>
  </div>

  <!-- Search + Filter Bar -->
  <div class="flex flex-wrap items-center gap-3 mb-4">
    <div class="relative flex-1 min-w-48">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-text-muted pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
      </svg>
      <input
        id="search-input"
        type="text"
        placeholder="Search modules… (vpc, eks, rds, gke…)"
        class="w-full pl-9 pr-4 py-2 bg-bg-card border border-border rounded-lg text-sm focus:outline-none focus:border-primary transition-colors"
      />
    </div>
    <div id="provider-filters" class="flex flex-wrap gap-2">
      <button class="filter-btn active text-xs px-3 py-1.5 rounded-lg border border-primary bg-primary/10 text-primary transition-colors" data-provider="all">All</button>
      <button class="filter-btn text-xs px-3 py-1.5 rounded-lg border border-border hover:border-primary transition-colors" data-provider="aws">
        <span class="text-orange-400 mr-1">▲</span>AWS
      </button>
      <button class="filter-btn text-xs px-3 py-1.5 rounded-lg border border-border hover:border-primary transition-colors" data-provider="gcp">
        <span class="text-blue-400 mr-1">◆</span>GCP
      </button>
      <button class="filter-btn text-xs px-3 py-1.5 rounded-lg border border-border hover:border-primary transition-colors" data-provider="azure">
        <span class="text-sky-400 mr-1">■</span>Azure
      </button>
      <button class="filter-btn text-xs px-3 py-1.5 rounded-lg border border-border hover:border-primary transition-colors" data-provider="generic">
        <span class="text-purple-400 mr-1">●</span>Generic
      </button>
    </div>
    <span id="result-count" class="text-xs text-text-muted ml-auto"></span>
  </div>

  <!-- Module Grid -->
  <div id="module-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 mb-6"></div>

  <!-- Empty state -->
  <div id="empty-state" class="hidden text-center py-16 text-text-muted">
    <svg class="w-12 h-12 mx-auto mb-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 0 1 5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" />
    </svg>
    <p class="text-sm">No modules match your search.</p>
    <p class="text-xs mt-1">Try a different keyword or provider filter.</p>
  </div>

  <!-- Module Detail Modal -->
  <div id="module-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm" role="dialog" aria-modal="true">
    <div class="bg-bg-card border border-border rounded-xl w-full max-w-2xl max-h-[90vh] overflow-y-auto shadow-2xl">
      <div class="flex items-start justify-between p-5 border-b border-border sticky top-0 bg-bg-card z-10">
        <div>
          <div class="flex items-center gap-2 mb-1">
            <span id="modal-provider-badge" class="text-xs px-2 py-0.5 rounded-full font-medium"></span>
            <span id="modal-verified" class="hidden items-center gap-1 text-xs text-blue-400 font-medium">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
              Verified
            </span>
          </div>
          <h2 id="modal-title" class="text-base font-semibold"></h2>
          <p id="modal-source" class="text-xs text-text-muted font-mono mt-0.5"></p>
        </div>
        <button id="modal-close" class="p-1.5 hover:bg-bg-card rounded-lg transition-colors text-text-muted hover:text-text ml-4 flex-shrink-0" aria-label="Close">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>

      <div class="p-5 space-y-5">
        <p id="modal-description" class="text-sm text-text-muted"></p>

        <!-- Stats row -->
        <div class="flex flex-wrap gap-4 text-xs">
          <div class="flex flex-col gap-0.5">
            <span class="text-text-muted">Latest version</span>
            <span id="modal-version" class="font-mono font-semibold text-primary"></span>
          </div>
          <div class="flex flex-col gap-0.5">
            <span class="text-text-muted">Weekly downloads</span>
            <span id="modal-downloads" class="font-semibold"></span>
          </div>
          <div class="flex flex-col gap-0.5">
            <span class="text-text-muted">Registry URL</span>
            <a id="modal-registry-link" href="#" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline truncate max-w-xs"></a>
          </div>
        </div>

        <!-- Copy module source -->
        <div>
          <div class="flex items-center justify-between mb-2">
            <span class="text-xs font-medium text-text-muted uppercase tracking-wide">Module Source Line</span>
            <button id="modal-copy-source" class="text-xs px-3 py-1 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors font-medium">Copy</button>
          </div>
          <pre id="modal-source-block" class="bg-bg border border-border rounded-lg p-3 text-xs font-mono text-green-400 overflow-x-auto whitespace-pre"></pre>
        </div>

        <!-- Usage snippet -->
        <div>
          <div class="flex items-center justify-between mb-2">
            <span class="text-xs font-medium text-text-muted uppercase tracking-wide">Usage Example</span>
            <button id="modal-copy-hcl" class="text-xs px-3 py-1 bg-bg-card border border-border rounded-lg hover:border-primary transition-colors">Copy HCL</button>
          </div>
          <pre id="modal-hcl" class="bg-bg border border-border rounded-lg p-3 text-xs font-mono overflow-x-auto whitespace-pre leading-relaxed"></pre>
        </div>

        <!-- Required variables -->
        <div>
          <span class="text-xs font-medium text-text-muted uppercase tracking-wide block mb-2">Required Variables</span>
          <div id="modal-required-vars" class="flex flex-wrap gap-2"></div>
        </div>

        <!-- Outputs -->
        <div>
          <span class="text-xs font-medium text-text-muted uppercase tracking-wide block mb-2">Key Outputs</span>
          <div id="modal-outputs" class="flex flex-wrap gap-2"></div>
        </div>
      </div>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Terraform Registry Module Finder" relatedTags={['terraform', 'hcl', 'infrastructure', 'devops', 'iac', 'aws', 'kubernetes']} />
</BaseLayout>

<script>
// ─── Module Data ──────────────────────────────────────────────────────────────
interface TFModule {
  id: string;
  name: string;
  namespace: string;
  provider: 'aws' | 'gcp' | 'azure' | 'generic';
  category: string;
  source: string;
  version: string;
  verified: boolean;
  weeklyDownloads: string;
  description: string;
  hcl: string;
  requiredVars: string[];
  outputs: string[];
}

const MODULES: TFModule[] = [
  // ── AWS ──────────────────────────────────────────────────────────────────
  {
    id: 'aws-vpc',
    name: 'VPC',
    namespace: 'terraform-aws-modules',
    provider: 'aws',
    category: 'Networking',
    source: 'terraform-aws-modules/vpc/aws',
    version: '5.8.1',
    verified: true,
    weeklyDownloads: '1.2M',
    description: 'Creates a fully-featured AWS VPC with public/private subnets, NAT gateways, route tables, and internet gateway. The most-downloaded Terraform module on the registry.',
    hcl: `module "vpc" {
  source  = "terraform-aws-modules/vpc/aws"
  version = "~> 5.8"

  name = "my-vpc"
  cidr = "10.0.0.0/16"

  azs             = ["us-east-1a", "us-east-1b", "us-east-1c"]
  private_subnets = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
  public_subnets  = ["10.0.101.0/24", "10.0.102.0/24", "10.0.103.0/24"]

  enable_nat_gateway = true
  single_nat_gateway = true

  tags = {
    Environment = "production"
    Terraform   = "true"
  }
}`,
    requiredVars: ['name', 'cidr', 'azs'],
    outputs: ['vpc_id', 'private_subnets', 'public_subnets', 'nat_public_ips'],
  },
  {
    id: 'aws-eks',
    name: 'EKS',
    namespace: 'terraform-aws-modules',
    provider: 'aws',
    category: 'Compute',
    source: 'terraform-aws-modules/eks/aws',
    version: '20.24.3',
    verified: true,
    weeklyDownloads: '620K',
    description: 'Deploys an Amazon EKS cluster with managed node groups, IRSA, add-ons, and cluster access entries. Supports both AL2 and Bottlerocket AMIs.',
    hcl: `module "eks" {
  source  = "terraform-aws-modules/eks/aws"
  version = "~> 20.24"

  cluster_name    = "my-cluster"
  cluster_version = "1.31"

  vpc_id     = module.vpc.vpc_id
  subnet_ids = module.vpc.private_subnets

  cluster_endpoint_public_access = true

  eks_managed_node_groups = {
    general = {
      instance_types = ["m6i.large"]
      min_size       = 2
      max_size       = 6
      desired_size   = 3
    }
  }

  tags = {
    Environment = "production"
    Terraform   = "true"
  }
}`,
    requiredVars: ['cluster_name', 'cluster_version', 'vpc_id', 'subnet_ids'],
    outputs: ['cluster_endpoint', 'cluster_certificate_authority_data', 'cluster_name', 'oidc_provider_arn'],
  },
  {
    id: 'aws-rds',
    name: 'RDS',
    namespace: 'terraform-aws-modules',
    provider: 'aws',
    category: 'Database',
    source: 'terraform-aws-modules/rds/aws',
    version: '6.10.0',
    verified: true,
    weeklyDownloads: '480K',
    description: 'Provisions an AWS RDS instance (MySQL, PostgreSQL, MariaDB, Oracle, MSSQL) with subnet groups, parameter groups, option groups, and CloudWatch alarms.',
    hcl: `module "db" {
  source  = "terraform-aws-modules/rds/aws"
  version = "~> 6.10"

  identifier = "my-postgres-db"

  engine            = "postgres"
  engine_version    = "16"
  instance_class    = "db.t4g.large"
  allocated_storage = 20

  db_name  = "myapp"
  username = "dbadmin"
  port     = "5432"

  vpc_security_group_ids = [module.security_group.security_group_id]
  subnet_ids             = module.vpc.private_subnets

  deletion_protection = true

  tags = {
    Environment = "production"
  }
}`,
    requiredVars: ['identifier', 'engine', 'instance_class', 'db_name', 'username'],
    outputs: ['db_instance_endpoint', 'db_instance_arn', 'db_instance_name'],
  },
  {
    id: 'aws-s3-bucket',
    name: 'S3 Bucket',
    namespace: 'terraform-aws-modules',
    provider: 'aws',
    category: 'Storage',
    source: 'terraform-aws-modules/s3-bucket/aws',
    version: '4.2.2',
    verified: true,
    weeklyDownloads: '720K',
    description: 'Creates an S3 bucket with configurable versioning, encryption, lifecycle rules, access controls, CORS, and bucket policies. Handles all common S3 configurations.',
    hcl: `module "s3_bucket" {
  source  = "terraform-aws-modules/s3-bucket/aws"
  version = "~> 4.2"

  bucket = "my-unique-bucket-name"

  versioning = {
    enabled = true
  }

  server_side_encryption_configuration = {
    rule = {
      apply_server_side_encryption_by_default = {
        sse_algorithm = "AES256"
      }
    }
  }

  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true

  tags = {
    Environment = "production"
  }
}`,
    requiredVars: ['bucket'],
    outputs: ['s3_bucket_id', 's3_bucket_arn', 's3_bucket_bucket_domain_name'],
  },
  {
    id: 'aws-iam',
    name: 'IAM',
    namespace: 'terraform-aws-modules',
    provider: 'aws',
    category: 'Security',
    source: 'terraform-aws-modules/iam/aws',
    version: '5.48.0',
    verified: true,
    weeklyDownloads: '390K',
    description: 'Collection of submodules for AWS IAM: assumable roles, groups with users, policies, EKS role for service accounts (IRSA), read-only policies, and instance profiles.',
    hcl: `module "iam_assumable_role" {
  source  = "terraform-aws-modules/iam/aws//modules/iam-assumable-role"
  version = "~> 5.48"

  trusted_role_arns = [
    "arn:aws:iam::123456789012:root",
  ]

  create_role       = true
  role_name         = "my-app-role"
  role_requires_mfa = false

  custom_role_policy_arns = [
    "arn:aws:iam::aws:policy/ReadOnlyAccess",
  ]
}`,
    requiredVars: ['trusted_role_arns', 'role_name'],
    outputs: ['iam_role_arn', 'iam_role_name', 'iam_role_path'],
  },
  {
    id: 'aws-lambda',
    name: 'Lambda',
    namespace: 'terraform-aws-modules',
    provider: 'aws',
    category: 'Compute',
    source: 'terraform-aws-modules/lambda/aws',
    version: '7.20.1',
    verified: true,
    weeklyDownloads: '380K',
    description: 'Deploys AWS Lambda functions with IAM roles, event source mappings, aliases, VPC configuration, layers, and automatic packaging of local source code.',
    hcl: `module "lambda_function" {
  source  = "terraform-aws-modules/lambda/aws"
  version = "~> 7.20"

  function_name = "my-lambda"
  description   = "My Lambda function"
  handler       = "index.lambda_handler"
  runtime       = "python3.12"

  source_path = "./src"

  environment_variables = {
    APP_ENV = "production"
  }

  tags = {
    Environment = "production"
  }
}`,
    requiredVars: ['function_name', 'handler', 'runtime'],
    outputs: ['lambda_function_arn', 'lambda_function_name', 'lambda_function_invoke_arn'],
  },
  {
    id: 'aws-alb',
    name: 'ALB',
    namespace: 'terraform-aws-modules',
    provider: 'aws',
    category: 'Networking',
    source: 'terraform-aws-modules/alb/aws',
    version: '9.12.0',
    verified: true,
    weeklyDownloads: '310K',
    description: 'Creates an Application Load Balancer (or NLB) with listeners, target groups, listener rules, and associated security groups. Supports HTTP/HTTPS and WebSocket.',
    hcl: `module "alb" {
  source  = "terraform-aws-modules/alb/aws"
  version = "~> 9.12"

  name    = "my-alb"
  vpc_id  = module.vpc.vpc_id
  subnets = module.vpc.public_subnets

  security_groups = [module.alb_sg.security_group_id]

  listeners = {
    https = {
      port            = 443
      protocol        = "HTTPS"
      certificate_arn = aws_acm_certificate.this.arn
      forward = {
        target_group_key = "app"
      }
    }
  }

  target_groups = {
    app = {
      name_prefix       = "app-"
      protocol          = "HTTP"
      port              = 8080
      target_type       = "ip"
    }
  }
}`,
    requiredVars: ['name', 'vpc_id', 'subnets'],
    outputs: ['lb_arn', 'lb_dns_name', 'target_groups'],
  },
  {
    id: 'aws-asg',
    name: 'Auto Scaling Group',
    namespace: 'terraform-aws-modules',
    provider: 'aws',
    category: 'Compute',
    source: 'terraform-aws-modules/autoscaling/aws',
    version: '8.1.0',
    verified: true,
    weeklyDownloads: '270K',
    description: 'Creates an EC2 Auto Scaling Group with launch template, mixed instances policy, scaling policies, lifecycle hooks, and warm pool support.',
    hcl: `module "asg" {
  source  = "terraform-aws-modules/autoscaling/aws"
  version = "~> 8.1"

  name = "my-asg"

  vpc_zone_identifier = module.vpc.private_subnets
  target_group_arns   = module.alb.target_groups.*.arn
  health_check_type   = "ELB"

  min_size         = 2
  max_size         = 10
  desired_capacity = 4

  image_id      = data.aws_ami.amazon_linux.id
  instance_type = "t3.medium"

  tags = {
    Environment = "production"
  }
}`,
    requiredVars: ['name', 'vpc_zone_identifier', 'image_id', 'instance_type'],
    outputs: ['autoscaling_group_id', 'autoscaling_group_arn', 'launch_template_id'],
  },
  {
    id: 'aws-security-group',
    name: 'Security Group',
    namespace: 'terraform-aws-modules',
    provider: 'aws',
    category: 'Security',
    source: 'terraform-aws-modules/security-group/aws',
    version: '5.3.0',
    verified: true,
    weeklyDownloads: '890K',
    description: 'Creates AWS Security Groups with computed ingress/egress rules. Includes predefined rules for common services (HTTP, HTTPS, SSH, PostgreSQL, Redis, etc.).',
    hcl: `module "web_sg" {
  source  = "terraform-aws-modules/security-group/aws"
  version = "~> 5.3"

  name        = "web-server-sg"
  description = "Security group for web servers"
  vpc_id      = module.vpc.vpc_id

  ingress_cidr_blocks = ["0.0.0.0/0"]
  ingress_rules       = ["https-443-tcp", "http-80-tcp"]

  egress_rules = ["all-all"]

  tags = {
    Environment = "production"
  }
}`,
    requiredVars: ['name', 'vpc_id'],
    outputs: ['security_group_id', 'security_group_arn', 'security_group_name'],
  },
  {
    id: 'aws-acm',
    name: 'ACM Certificate',
    namespace: 'terraform-aws-modules',
    provider: 'aws',
    category: 'Security',
    source: 'terraform-aws-modules/acm/aws',
    version: '5.1.1',
