---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is string padding?", answer: "String padding adds characters to the start or end of a string to reach a target length. Left-padding (padStart in JavaScript, ljust/rjust in Python) is used for right-aligning numbers in columns — '7' becomes '   7' in a 4-wide field. Right-padding (padEnd) is used for left-aligning text — 'name' becomes 'name    ' in an 8-wide column. Zero-padding is a special case of left-padding with '0': '42' becomes '042' with width 3. Common in formatting logs, alignment, fixed-width file formats, and number formatting." },
  { question: "What is string truncation with ellipsis?", answer: "Truncation shortens a string to a maximum length, optionally appending an ellipsis ('...') to indicate the text was cut. For UI display, 'This is a very long product description' becomes 'This is a very lon...' at 20 characters. CSS has the text-overflow: ellipsis property for visual truncation, but for actual string manipulation (API responses, database storage, log messages), programmatic truncation is needed. Word-boundary truncation breaks at a word rather than mid-character, producing 'This is a very...' instead of 'This is a very lon...'." },
  { question: "What is string repetition and wrapping?", answer: "String repetition (repeat) creates a string repeated N times: '-'.repeat(40) creates a 40-character divider line. Useful for generating separator lines, test data, or visual formatting. Text wrapping breaks long text at a specified column width, adding line breaks to prevent lines exceeding the limit — useful for terminal output, email bodies, and fixed-width formats. Word-wrapping breaks only at spaces; hard wrapping breaks exactly at the column regardless of word boundaries." },
  { question: "How does center alignment work?", answer: "Center alignment distributes padding evenly on both sides of a string to center it within a target width. If the padding is odd, the extra character goes to the right side by convention. Example: 'hi'.center(10, '-') in Python gives '----hi----'. In JavaScript: const s='hi'; const total=10; const left=Math.floor((total-s.length)/2); s.padStart(s.length+left).padEnd(total) achieves the same. Center alignment is used in text-based UIs, fixed-width reports, and ASCII art." },
];
---

<BaseLayout
  title="String Padding Formatter — Pad, Truncate, Repeat, Wrap"
  description="Format strings with padding (left, right, center), truncation with ellipsis, repetition, and word wrapping. See JavaScript and Python code snippets for each operation."
  tool="string padding formatter, padStart padEnd JavaScript, string truncate ellipsis, text wrap column width, string repeat, center align text"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "String Padding Formatter — Pad, Truncate, Repeat, Wrap",
    "url": "https://devplaybook.cc/tools/string-padding-formatter",
    "description": "Format strings with padding, truncation, repetition, and word wrapping. Includes JavaScript and Python code snippets.",
  })} />

  <h1 class="text-3xl font-bold mb-2">String Padding Formatter</h1>
  <p class="text-text-muted mb-6">
    Format strings with <strong>padding</strong> (left, right, center), <strong>truncation</strong>,
    <strong>repetition</strong>, and <strong>word wrapping</strong>. Each operation shows
    the JavaScript and Python code.
  </p>

  <div class="mb-4">
    <label class="block text-sm font-medium mb-2">Input String</label>
    <input
      type="text" id="inputStr"
      class="w-full bg-bg-card border border-border rounded-xl p-3 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary"
      value="Hello, World!"
    />
    <div class="text-xs text-text-muted mt-1">Length: <span id="inputLen">13</span> characters</div>
  </div>

  <div class="grid md:grid-cols-2 gap-6 mb-6">
    <!-- Padding Section -->
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold mb-3">Padding</h3>
      <div class="flex gap-2 mb-2 flex-wrap">
        <select id="padDir" class="bg-bg-card border border-border rounded px-2 py-1 text-sm">
          <option value="start">Left (padStart)</option>
          <option value="end">Right (padEnd)</option>
          <option value="center">Center</option>
        </select>
        <input type="number" id="padWidth" value="20" min="1" max="200" class="w-20 bg-bg-card border border-border rounded px-2 py-1 text-sm" placeholder="width" />
        <input type="text" id="padChar" value=" " maxlength="1" class="w-12 bg-bg-card border border-border rounded px-2 py-1 text-sm font-mono" placeholder="char" />
      </div>
      <div class="bg-bg-100 rounded p-2 font-mono text-xs border border-border min-h-[2rem] mb-2" id="padResult"></div>
      <pre class="text-xs text-text-muted" id="padCode"></pre>
    </div>

    <!-- Truncate Section -->
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold mb-3">Truncate</h3>
      <div class="flex gap-2 mb-2 flex-wrap">
        <input type="number" id="truncLen" value="10" min="1" class="w-20 bg-bg-card border border-border rounded px-2 py-1 text-sm" placeholder="max len" />
        <input type="text" id="truncSuffix" value="..." class="w-16 bg-bg-card border border-border rounded px-2 py-1 text-sm font-mono" placeholder="suffix" />
        <label class="flex items-center gap-1 text-sm"><input type="checkbox" id="wordBound" class="accent-primary" checked /> Word boundary</label>
      </div>
      <div class="bg-bg-100 rounded p-2 font-mono text-xs border border-border min-h-[2rem] mb-2" id="truncResult"></div>
      <pre class="text-xs text-text-muted" id="truncCode"></pre>
    </div>

    <!-- Repeat Section -->
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold mb-3">Repeat</h3>
      <div class="flex gap-2 mb-2">
        <input type="number" id="repeatCount" value="3" min="1" max="100" class="w-20 bg-bg-card border border-border rounded px-2 py-1 text-sm" placeholder="times" />
        <input type="text" id="repeatSep" value="" class="w-16 bg-bg-card border border-border rounded px-2 py-1 text-sm font-mono" placeholder="separator" />
      </div>
      <div class="bg-bg-100 rounded p-2 font-mono text-xs border border-border min-h-[2rem] mb-2 break-all" id="repeatResult"></div>
      <pre class="text-xs text-text-muted" id="repeatCode"></pre>
    </div>

    <!-- Wrap Section -->
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold mb-3">Word Wrap</h3>
      <div class="flex gap-2 mb-2">
        <input type="number" id="wrapWidth" value="30" min="5" max="200" class="w-20 bg-bg-card border border-border rounded px-2 py-1 text-sm" placeholder="width" />
      </div>
      <div class="bg-bg-100 rounded p-2 font-mono text-xs border border-border min-h-[2rem] mb-2 whitespace-pre-wrap" id="wrapResult"></div>
      <pre class="text-xs text-text-muted" id="wrapCode"></pre>
    </div>
  </div>

  <ToolPageCta />
  <FaqSection faqs={faq} />
</BaseLayout>

<script>
function getInput() {
  return (document.getElementById('inputStr') as HTMLInputElement).value;
}

function pad(s: string, width: number, char: string, dir: string): string {
  if (s.length >= width) return s;
  const fill = char || ' ';
  if (dir === 'start') return s.padStart(width, fill);
  if (dir === 'end') return s.padEnd(width, fill);
  const total = width - s.length;
  const left = Math.floor(total / 2);
  const right = total - left;
  return fill.repeat(left) + s + fill.repeat(right);
}

function truncate(s: string, maxLen: number, suffix: string, wordBound: boolean): string {
  if (s.length <= maxLen) return s;
  const trimLen = maxLen - suffix.length;
  if (!wordBound) return s.slice(0, trimLen) + suffix;
  const trimmed = s.slice(0, trimLen);
  const lastSpace = trimmed.lastIndexOf(' ');
  return (lastSpace > 0 ? trimmed.slice(0, lastSpace) : trimmed) + suffix;
}

function wordWrap(s: string, width: number): string {
  const words = s.split(' ');
  const lines: string[] = [];
  let current = '';
  for (const word of words) {
    if ((current + ' ' + word).trim().length <= width) {
      current = (current + ' ' + word).trim();
    } else {
      if (current) lines.push(current);
      current = word;
    }
  }
  if (current) lines.push(current);
  return lines.join('\n');
}

function update() {
  const s = getInput();
  (document.getElementById('inputLen') as HTMLElement).textContent = String(s.length);

  const dir = (document.getElementById('padDir') as HTMLSelectElement).value;
  const width = parseInt((document.getElementById('padWidth') as HTMLInputElement).value) || 20;
  const char = (document.getElementById('padChar') as HTMLInputElement).value || ' ';
  const padded = pad(s, width, char, dir);
  (document.getElementById('padResult') as HTMLElement).textContent = `"${padded}"`;
  const charEsc = char === "'" ? '"\'"' : `'${char}'`;
  const jsMethod = dir === 'start' ? 'padStart' : dir === 'end' ? 'padEnd' : null;
  (document.getElementById('padCode') as HTMLElement).textContent = jsMethod
    ? `// JavaScript\nstr.${jsMethod}(${width}, ${charEsc})\n// Python\nstr.${dir==='start'?'rjust':'ljust'}(${width}, ${charEsc})`
    : `// JavaScript (center)\nconst l = Math.floor((${width}-str.length)/2);\nstr.padStart(str.length+l,${charEsc}).padEnd(${width},${charEsc})`;

  const maxLen = parseInt((document.getElementById('truncLen') as HTMLInputElement).value) || 10;
  const suffix = (document.getElementById('truncSuffix') as HTMLInputElement).value;
  const wb = (document.getElementById('wordBound') as HTMLInputElement).checked;
  (document.getElementById('truncResult') as HTMLElement).textContent = `"${truncate(s, maxLen, suffix, wb)}"`;
  (document.getElementById('truncCode') as HTMLElement).textContent = `// JavaScript\nstr.length > ${maxLen} ? str.slice(0, ${maxLen - suffix.length}) + '${suffix}' : str`;

  const count = parseInt((document.getElementById('repeatCount') as HTMLInputElement).value) || 3;
  const sep = (document.getElementById('repeatSep') as HTMLInputElement).value;
  const repeated = sep ? Array(count).fill(s).join(sep) : s.repeat(count);
  (document.getElementById('repeatResult') as HTMLElement).textContent = `"${repeated.slice(0, 200)}${repeated.length > 200 ? '...' : ''}"`;
  (document.getElementById('repeatCode') as HTMLElement).textContent = sep
    ? `// JavaScript\nArray(${count}).fill(str).join('${sep}')\n// Python\n'${sep}'.join([str]*${count})`
    : `// JavaScript\nstr.repeat(${count})\n// Python\nstr * ${count}`;

  const ww = parseInt((document.getElementById('wrapWidth') as HTMLInputElement).value) || 30;
  (document.getElementById('wrapResult') as HTMLElement).textContent = wordWrap(s, ww);
  (document.getElementById('wrapCode') as HTMLElement).textContent = `// Python\nimport textwrap\ntextwrap.fill(str, width=${ww})`;
}

['inputStr','padDir','padWidth','padChar','truncLen','truncSuffix','wordBound','repeatCount','repeatSep','wrapWidth'].forEach(id => {
  document.getElementById(id)?.addEventListener('input', update);
  document.getElementById(id)?.addEventListener('change', update);
});
update();
</script>
