---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "How do I check my current React Native version?",
    answer: "Run 'npx react-native --version' in your project directory to see the installed version. You can also check package.json under the 'react-native' dependency. The installed version in node_modules may differ from the version in package.json if you haven't run npm install after updating the lockfile."
  },
  {
    question: "How do I check if a package is compatible with my React Native version?",
    answer: "Check the package's README and CHANGELOG for listed RN version compatibility. Tools like react-native-compatibility-table aggregate compatibility data. The react-native-community packages generally document minimum RN versions. When in doubt, check the package's GitHub issues for reports of your specific RN version."
  },
  {
    question: "What does 'peer dependency conflict' mean in React Native?",
    answer: "A peer dependency conflict means a package requires a specific version of React Native (or another package) that differs from what you have installed. In npm 7+, this causes install failures by default. You can resolve it by upgrading React Native, downgrading the package, or using --legacy-peer-deps as a last resort. Check if a newer version of the conflicting package supports your RN version."
  },
  {
    question: "How do I upgrade React Native safely?",
    answer: "Use the React Native Upgrade Helper at react-native-community.github.io/upgrade-helper/. Enter your current and target versions to get a diff of all required changes. Use 'npx react-native upgrade' for minor patches, but always review the Upgrade Helper diff manually for major versions. Run 'npx react-native doctor' before and after to verify your environment."
  },
  {
    question: "Why do some packages only work with specific React Native versions?",
    answer: "React Native packages that include native code must be compiled against the correct native APIs. Breaking changes in RN's native layer (e.g., the New Architecture JSI changes in 0.68+, Fabric renderer changes) require packages to update their native bindings. Pure JavaScript packages are generally version-agnostic."
  },
  {
    question: "What is the difference between React Native version and Expo SDK version?",
    answer: "Each Expo SDK version bundles a specific React Native version. Expo SDK 51 includes React Native 0.74, SDK 52 includes 0.76, and so on. If you're using Expo, you upgrade React Native by upgrading the Expo SDK — you generally should not upgrade React Native independently in a managed Expo project. Check expo.dev/changelog for the React Native version bundled in each Expo SDK."
  }
];
---
<BaseLayout
  title="React Native Version Checker & Package Compatibility Guide"
  description="Check React Native version compatibility, understand package conflicts, and follow the correct upgrade path. Covers react-native-doctor, Upgrade Helper, peer dependency conflicts, and New Architecture compatibility."
  tool="react-native-version-checker"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"React Native Version Checker & Package Compatibility Guide","url":"https://devplaybook.cc/tools/react-native-version-checker","description":"Check React Native version compatibility, understand package conflicts, and follow the correct upgrade path."})} />

  <h1 class="text-3xl font-bold mb-2">React Native Version Checker & Package Compatibility Guide</h1>
  <p class="text-text-muted mb-6">Understand React Native versioning, check package compatibility, and navigate upgrades safely. Includes commands to verify your environment, detect conflicts, and follow the correct upgrade path.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Version check commands</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Package compatibility patterns</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Upgrade path guide</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> New Architecture compatibility</span>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Check Your Current React Native Version</h2>
  <p class="mb-4">React Native version checks operate at three levels: the CLI, the installed package, and the native layer. All three should agree.</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm"># Check React Native CLI version
npx react-native --version

# Check installed package version in node_modules
node -e "console.log(require('react-native/package.json').version)"

# Check your project's declared version
cat package.json | grep '"react-native"'

# Run the full environment health check
npx react-native doctor</code></pre>
  <p class="mb-4">The <code>react-native doctor</code> command is the most useful diagnostic — it checks your Xcode version, Android SDK, JDK, CocoaPods, and environment variables in one pass, flagging anything that could cause build failures.</p>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Checking Package Compatibility</h2>
  <p class="mb-4">Before installing a new package, verify it supports your React Native version. Most packages document compatibility in their README under "Requirements" or "Installation".</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm"># Check a package's peer dependencies before installing
npm info react-native-reanimated peerDependencies

# Example output:
# &#123; 'react-native': '>=0.68.0', react: '>=17.0.0' &#125;

# List all peer dependency warnings in your project
npm ls --depth=0 2>&1 | grep WARN

# For Expo projects, use expo install instead of npm install
# It automatically selects the compatible version
npx expo install react-native-reanimated</code></pre>
  <p class="mb-4">Expo's <code>expo install</code> command resolves compatibility automatically — it selects the package version that matches your Expo SDK's bundled React Native version. For bare React Native projects, you must check compatibility manually or use <code>npx expo install</code> if you're on an Expo-managed setup.</p>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Common Version-Related Issues</h2>
  <p class="mb-4">The most common problems that arise from version mismatches:</p>

  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 font-semibold">Issue</th>
          <th class="text-left py-2 pr-4 font-semibold">Likely Cause</th>
          <th class="text-left py-2 font-semibold">Fix</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <tr>
          <td class="py-2 pr-4"><code>Invariant Violation: Native module cannot be null</code></td>
          <td class="py-2 pr-4">Package linked for wrong RN version</td>
          <td class="py-2">Rebuild native code: <code>cd ios && pod install</code></td>
        </tr>
        <tr>
          <td class="py-2 pr-4"><code>Cannot find native module</code></td>
          <td class="py-2 pr-4">Auto-linking failed or pod not installed</td>
          <td class="py-2">Run <code>npx pod-install</code> then rebuild</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">App crashes on launch after upgrade</td>
          <td class="py-2 pr-4">Stale build cache with old native code</td>
          <td class="py-2">Clean build: <code>cd android && ./gradlew clean</code></td>
        </tr>
        <tr>
          <td class="py-2 pr-4">Peer dependency conflict on install</td>
          <td class="py-2 pr-4">Package requires different RN version</td>
          <td class="py-2">Check compatible version in package's CHANGELOG</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">New Architecture module not found</td>
          <td class="py-2 pr-4">Package not yet updated for JSI/TurboModules</td>
          <td class="py-2">Disable new arch or check for beta release</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Upgrade Path Guide</h2>
  <p class="mb-4">Upgrading React Native requires updating both JavaScript dependencies and the native template files (android/, ios/). The React Native Upgrade Helper generates a diff between versions:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm"># Step 1: Check the Upgrade Helper diff
# Visit: https://react-native-community.github.io/upgrade-helper/
# Enter your current and target versions

# Step 2: Update package.json
npm install react-native@0.76.0

# Step 3: Update React peer dependency
npm install react@18.3.1

# Step 4: Apply native file changes from Upgrade Helper diff
# Manually edit android/ and ios/ files as shown in the diff

# Step 5: Update iOS dependencies
cd ios && pod install && cd ..

# Step 6: Clean and rebuild
npx react-native clean
npx react-native run-ios
npx react-native run-android</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">New Architecture Compatibility Check</h2>
  <p class="mb-4">React Native's New Architecture (JSI + Fabric + TurboModules) is the default in 0.73+. Not all packages support it yet. Check compatibility before enabling:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm"># Check if a package supports New Architecture
# Look for these indicators in the package repo:

# 1. turbo-module-spec in package.json
# 2. 'fabric' or 'turbomodule' in the package keywords
# 3. A "New Architecture" section in the README
# 4. The reactNativeMetadata field in package.json:
npm info react-native-reanimated | grep -i "fabric\|turbo\|new arch"

# For Expo projects, check compatibility with expo-doctor
npx expo-doctor

# Temporarily disable New Architecture if a package blocks you
# In android/gradle.properties:
# newArchEnabled=false</code></pre>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="react-native-version-checker" relatedTags={['react-native', 'mobile', 'javascript', 'ios', 'android', 'expo']} />
</BaseLayout>
