---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ResponsiveBreakpointTester from '../../components/ResponsiveBreakpointTester.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "Why does some sites show blank in the preview?",
    answer: "Many websites use X-Frame-Options: DENY or Content-Security-Policy: frame-ancestors 'none' HTTP headers to prevent embedding in iframes. This is a security measure to prevent clickjacking attacks. If the page shows blank, the site is actively blocking iframe embedding. To test those sites, use Chrome DevTools device toolbar (F12 → toggle device) or the Responsive Design Mode in Firefox DevTools."
  },
  {
    question: "What are the standard responsive breakpoints?",
    answer: "Common breakpoints: 320px (small mobile), 375px (iPhone standard), 768px (tablet/iPad portrait), 1024px (tablet landscape / small laptop), 1280px (laptop), 1440px (desktop), 1920px (wide desktop). Tailwind CSS uses: sm=640px, md=768px, lg=1024px, xl=1280px, 2xl=1536px. Bootstrap 5 uses: sm=576px, md=768px, lg=992px, xl=1200px, xxl=1400px."
  },
  {
    question: "What viewport width should I optimize for first?",
    answer: "Design mobile-first. As of 2024, ~60% of global web traffic comes from mobile devices. Start with 375px (iPhone standard), ensure usability at 390px (iPhone 14/15 Pro), then progressively enhance for tablet (768px) and desktop (1024px+). Focus most optimization effort on the 375-430px range for the best mobile coverage."
  },
  {
    question: "How do I test responsive design without a tool?",
    answer: "In Chrome DevTools (F12), click the device toolbar icon or press Ctrl+Shift+M (Cmd+Shift+M on Mac). This gives you a responsive emulator with preset devices and custom dimensions. Firefox has a similar Responsive Design Mode (F12 → device icon). Both tools also simulate touch events, device pixel ratios, and network throttling."
  },
  {
    question: "What is the difference between viewport width and screen resolution?",
    answer: "Screen resolution is the physical pixel count of the display (e.g. 2560×1440 for a 27\" 1440p monitor). Viewport width is the CSS pixel width the browser uses for layout (e.g. 1440px). On high-DPI (Retina) displays, screen resolution is 2-3× the CSS viewport. Use CSS pixels for responsive breakpoints, not physical pixels."
  },
];
---

<BaseLayout
  title="Responsive Breakpoint Tester — Preview Any URL at Mobile, Tablet & Desktop"
  description="Enter any URL and preview it at standard responsive breakpoints: 375px, 768px, 1024px, and 1440px. Test mobile-first layouts instantly. Free, runs in your browser."
  tool="responsive breakpoint tester, responsive design tester, mobile viewport tester, iframe breakpoint viewer, responsive preview tool"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Responsive Breakpoint Tester",
    "url": "https://devplaybook.cc/tools/responsive-breakpoint-tester",
    "description": "Preview any URL at standard responsive breakpoints: mobile (375px), tablet (768px), laptop (1024px), and desktop (1440px).",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Responsive Breakpoint Tester</h1>
  <p class="text-text-muted mb-4">
    Enter a URL and instantly preview it at standard responsive breakpoints — mobile (375px), tablet (768px), laptop (1024px), and desktop (1440px). Use the custom width input for precise testing.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 preset breakpoints</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Custom width input</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Tailwind breakpoint labels</span>
  </div>
  <ResponsiveBreakpointTester client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Responsive Breakpoint Tester" relatedTags={['responsive', 'css', 'mobile', 'design', 'viewport', 'breakpoints']} />
</BaseLayout>
