---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a code smell?", answer: "A code smell is a surface indicator in source code that usually corresponds to a deeper problem. The term was popularized by Martin Fowler in 'Refactoring'. Smells don't indicate bugs — code with smells can work correctly — but they signal areas where the code will be harder to maintain, extend, or test. Common smells: long methods, magic numbers, deep nesting, duplicated code, god classes." },
  { question: "What is a magic number and why is it a problem?", answer: "A magic number is a numeric literal used directly in code without explanation: if (retries > 3) or timeout = 30000. They're problems because the intent is unclear (why 3? why 30000?), they're hard to update consistently, and they make code impossible to read without context. Fix: extract to named constants: const MAX_RETRIES = 3 or const TIMEOUT_MS = 30_000." },
  { question: "What is a god class?", answer: "A god class (or god object) is a class that knows too much or does too much — it has too many responsibilities, too many methods, and too many dependencies. Signs: classes longer than 300 lines, more than 10 public methods, more than 7 fields. God classes violate the Single Responsibility Principle and become bottlenecks where every change risks breaking unrelated functionality." },
  { question: "When should I refactor detected smells?", answer: "Not all smells need immediate refactoring. Prioritize by: (1) smells in code you're actively changing ('the boy scout rule'), (2) smells causing bugs or making tests impossible, (3) smells in hot paths that slow development velocity. Never refactor just for cleanliness in stable, untouched code — the risk of introducing bugs outweighs the benefit." },
  { question: "What is the DRY principle?", answer: "DRY (Don't Repeat Yourself) states that every piece of knowledge should have a single, unambiguous representation in a system. Duplicated code violates DRY — when logic changes, you must find and update every copy. Fix by extracting shared logic into functions or modules. Caveat: not all similar code should be merged; sometimes duplication is accidental, not structural, and merging it creates harmful coupling." },
];
---

<BaseLayout
  title="Code Smell Detector — Find Long Methods, Magic Numbers & More"
  description="Paste code to detect common code smells: long methods, magic numbers, deep nesting, god class indicators, TODO/FIXME, and more. Get severity ratings and refactoring suggestions. Runs in your browser."
  tool="Code Smell Detector, code smells, long method, magic number, deep nesting, god class, DRY violation, TODO detector, code quality, refactoring"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Code Smell Detector",
    "url": "https://devplaybook.cc/tools/code-smell-detector",
    "description": "Detect code smells like long methods, magic numbers, deep nesting, and more. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Code Smell Detector</h1>
  <p class="text-text-muted mb-4">Paste any code snippet to automatically detect <strong>code smells</strong> — common patterns that indicate maintenance or design problems. Each finding includes a severity level, explanation, and refactoring suggestion.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 12 smell categories</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Severity ratings (Info/Warning/Error)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Refactoring suggestions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No code leaves your browser</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-6">
    <!-- Input -->
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <div class="flex items-center justify-between mb-3">
        <label class="text-sm font-semibold">Paste Code</label>
        <button id="btn-example-smell" class="text-xs text-primary hover:underline">Load Example</button>
      </div>
      <textarea id="smell-input" class="w-full bg-bg-page border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary resize-y" rows="18" placeholder="// Paste JavaScript, TypeScript, Python, or any code here..."></textarea>
      <button id="btn-analyze-smell" class="mt-3 w-full px-4 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Detect Smells</button>
    </div>

    <!-- Results -->
    <div class="space-y-4">
      <!-- Summary -->
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <h2 class="text-sm font-semibold mb-3">Summary</h2>
        <div class="flex gap-3">
          <div class="flex-1 bg-red-500/10 border border-red-500/20 rounded-lg p-3 text-center">
            <div class="text-2xl font-bold text-red-400" id="count-error">—</div>
            <div class="text-xs text-text-muted">Error</div>
          </div>
          <div class="flex-1 bg-yellow-500/10 border border-yellow-500/20 rounded-lg p-3 text-center">
            <div class="text-2xl font-bold text-yellow-400" id="count-warning">—</div>
            <div class="text-xs text-text-muted">Warning</div>
          </div>
          <div class="flex-1 bg-blue-500/10 border border-blue-500/20 rounded-lg p-3 text-center">
            <div class="text-2xl font-bold text-blue-400" id="count-info">—</div>
            <div class="text-xs text-text-muted">Info</div>
          </div>
        </div>
      </div>

      <!-- Findings list -->
      <div class="bg-bg-card border border-border rounded-lg p-4 max-h-[480px] overflow-y-auto">
        <h2 class="text-sm font-semibold mb-3">Findings</h2>
        <div id="findings-list" class="space-y-3">
          <p class="text-xs text-text-muted italic">Run analysis to see findings.</p>
        </div>
      </div>
    </div>
  </div>

  <ToolPageCta currentTool="Code Smell Detector" relatedTags={['code-quality', 'refactoring', 'clean-code', 'javascript', 'typescript']} />
  <FaqSection faq={faq} />
</BaseLayout>

<script>
const EXAMPLE_SMELL = `class UserManager {
  // TODO: refactor this mess
  data = [];
  cache = {};
  tempData = null;
  x = 0;
  y = 0;
  z = 0;
  a = 0;
  b = 0;
  c = 0;
  d = 0;
  e = 0;

  processUser(u, flag, mode, extra, opt1, opt2, opt3) {
    if (u) {
      if (u.age > 18) {
        if (u.active) {
          if (mode === 'admin') {
            if (flag) {
              if (u.verified) {
                // do something
                setTimeout(() => {}, 5000);
                let result = u.score * 0.15 + 42;
                if (result > 100) {
                  result = 100;
                }
                return result;
              }
            }
          }
        }
      }
    }
    return null;
  }

  // Duplicate of processUser above
  handleUser(u, flag, mode, extra, opt1, opt2, opt3) {
    if (u) {
      if (u.age > 18) {
        if (u.active) {
          return u.score * 0.15 + 42;
        }
      }
    }
    return null;
  }

  doEverything() {
    // 150 line method...
    const line1 = 1;
    const line2 = 2;
    const line3 = 3;
    // ... many more lines
    eval("console.log('dangerous')");
  }
}`;

interface Smell {
  name: string;
  severity: 'error' | 'warning' | 'info';
  description: string;
  fix: string;
  detect: (code: string) => string | null;
}

const SMELLS: Smell[] = [
  {
    name: 'Long Method',
    severity: 'warning',
    description: 'Function/method has more than 30 lines.',
    fix: 'Extract logical sections into well-named helper functions. Aim for functions under 20 lines.',
    detect: (code) => {
      const fnMatches = code.match(/(?:function\s+\w+|(?:\w+\s*[=:]\s*(?:async\s+)?(?:function|\([^)]*\)\s*=>)))[^{]*\{/g);
      const lines = code.split('\n').length;
      if (lines > 30) return `~${lines} lines of code detected`;
      return null;
    }
  },
  {
    name: 'Magic Numbers',
    severity: 'warning',
    description: 'Unexplained numeric literals found in logic.',
    fix: 'Extract to named constants: const MAX_RETRIES = 3 or const TIMEOUT_MS = 5000.',
    detect: (code) => {
      const matches = code.match(/(?<![.\w])(?<!['"`])(?:[-]?\b(?:[2-9]|[1-9]\d+)\b)(?![.\w'"`])/g);
      if (matches && matches.length >= 2) return `${matches.length} numeric literals: ${[...new Set(matches)].slice(0, 5).join(', ')}`;
      return null;
    }
  },
  {
    name: 'Deep Nesting',
    severity: 'error',
    description: 'Code nesting exceeds 4 levels (arrow antipattern).',
    fix: 'Use early returns (guard clauses), extract inner blocks to functions, or use async/await to flatten promise chains.',
    detect: (code) => {
      let depth = 0, maxDepth = 0;
      for (const ch of code) {
        if (ch === '{') { depth++; maxDepth = Math.max(maxDepth, depth); }
        else if (ch === '}') depth--;
      }
      if (maxDepth >= 5) return `Maximum nesting depth: ${maxDepth}`;
      return null;
    }
  },
  {
    name: 'Long Parameter List',
    severity: 'warning',
    description: 'Function takes more than 4 parameters.',
    fix: 'Group related parameters into an options object: function doThing({ userId, mode, flags }) {...}',
    detect: (code) => {
      const m = code.match(/function\s+\w+\s*\(([^)]+)\)/g);
      if (m) {
        for (const fn of m) {
          const params = fn.replace(/function\s+\w+\s*\(/, '').replace(/\)$/, '').split(',').filter(p => p.trim());
          if (params.length > 4) return `${params.length} parameters in one function`;
        }
      }
      return null;
    }
  },
  {
    name: 'TODO / FIXME / HACK',
    severity: 'info',
    description: 'Unresolved technical debt markers found.',
    fix: 'Convert each TODO/FIXME to a tracked issue. Do not leave them as permanent comments.',
    detect: (code) => {
      const m = code.match(/\b(?:TODO|FIXME|HACK|XXX|TEMP|BUG)\b/gi);
      if (m && m.length > 0) return `${m.length} marker${m.length > 1 ? 's' : ''}: ${[...new Set(m.map(x => x.toUpperCase()))].join(', ')}`;
      return null;
    }
  },
  {
    name: 'God Class Indicator',
    severity: 'error',
    description: 'Class has too many fields (>7) — likely violates SRP.',
    fix: 'Split into smaller classes by responsibility. Each class should have one reason to change.',
    detect: (code) => {
      const fields = code.match(/^\s+(?:this\.\w+|(?:public|private|protected|readonly)?\s+\w+)\s*=/gm);
      if (fields && fields.length > 7) return `~${fields.length} class fields detected`;
      return null;
    }
  },
  {
    name: 'eval() Usage',
    severity: 'error',
    description: 'eval() executes arbitrary strings as code — security risk and performance killer.',
    fix: 'Replace eval() with JSON.parse() for JSON, or refactor logic to avoid dynamic code execution.',
    detect: (code) => {
      if (/\beval\s*\(/.test(code)) return 'eval() call detected';
      return null;
    }
  },
  {
    name: 'setTimeout with Magic Delay',
    severity: 'info',
    description: 'setTimeout/setInterval with hardcoded delay values.',
    fix: 'Extract delay to a named constant. Consider if a delay is truly needed or if proper async/await would be cleaner.',
    detect: (code) => {
      const m = code.match(/setTimeout|setInterval/g);
      if (m && /setTimeout\s*\([^,]+,\s*\d+/.test(code)) return `${m.length} timer call(s) with hardcoded delay`;
      return null;
    }
  },
  {
    name: 'Deeply Nested Callbacks',
    severity: 'warning',
    description: 'Callback hell: functions nested within callbacks more than 3 levels deep.',
    fix: 'Refactor to async/await or Promise chaining. Extract callback bodies to named functions.',
    detect: (code) => {
      const depth = (code.match(/function\s*\([^)]*\)\s*\{/g) || []).length;
      if (depth >= 3 && /function.*function.*function/s.test(code)) return `${depth} nested anonymous function(s)`;
      return null;
    }
  },
  {
    name: 'Variable Names Too Short',
    severity: 'info',
    description: 'Single-letter variables used outside of loop indexes.',
    fix: 'Use descriptive names. Exception: i/j/k in for-loops, x/y for coordinates, e for event handlers.',
    detect: (code) => {
      const m = code.match(/\b(?:const|let|var)\s+([a-df-wyzA-Z])\s*=/g);
      if (m && m.length >= 3) return `${m.length} single-letter variable${m.length > 1 ? 's' : ''} (excluding common exceptions)`;
      return null;
    }
  },
  {
    name: 'console.log Left in Code',
    severity: 'info',
    description: 'Debug console.log statements found.',
    fix: 'Remove debug logs or replace with a proper logging library that can be disabled in production.',
    detect: (code) => {
      const m = code.match(/console\.(log|debug|warn|error)\s*\(/g);
      if (m && m.length > 0) return `${m.length} console statement${m.length > 1 ? 's' : ''}`;
      return null;
    }
  },
  {
    name: 'Commented-Out Code',
    severity: 'info',
    description: 'Blocks of code commented out rather than deleted.',
    fix: 'Delete commented-out code — it is already in git history. Live code should not have dead code blocks.',
    detect: (code) => {
      const lines = code.split('\n');
      const commented = lines.filter(l => l.trim().startsWith('//') && /[;{}()]/.test(l));
      if (commented.length >= 3) return `${commented.length} lines of commented-out code`;
      return null;
    }
  },
];

function detectSmells() {
  const code = (document.getElementById('smell-input') as HTMLTextAreaElement).value;
  if (!code.trim()) return;

  const findings: { smell: Smell; detail: string }[] = [];
  for (const smell of SMELLS) {
    const detail = smell.detect(code);
    if (detail) findings.push({ smell, detail });
  }

  const errors = findings.filter(f => f.smell.severity === 'error').length;
  const warnings = findings.filter(f => f.smell.severity === 'warning').length;
  const infos = findings.filter(f => f.smell.severity === 'info').length;

  document.getElementById('count-error')!.textContent = String(errors);
  document.getElementById('count-warning')!.textContent = String(warnings);
  document.getElementById('count-info')!.textContent = String(infos);

  const severityConfig = {
    error: { bg: 'bg-red-500/10', border: 'border-red-500/30', badge: 'bg-red-500/20 text-red-400', icon: '✕' },
    warning: { bg: 'bg-yellow-500/10', border: 'border-yellow-500/30', badge: 'bg-yellow-500/20 text-yellow-400', icon: '⚠' },
    info: { bg: 'bg-blue-500/10', border: 'border-blue-500/30', badge: 'bg-blue-500/20 text-blue-400', icon: 'ℹ' },
  };

  const list = document.getElementById('findings-list')!;
  if (findings.length === 0) {
    list.innerHTML = '<div class="flex items-center gap-2 text-green-400 text-sm"><span>✓</span><span>No common code smells detected. Code looks clean!</span></div>';
    return;
  }

  list.innerHTML = findings.map(({ smell, detail }) => {
    const s = severityConfig[smell.severity];
    return `<div class="${s.bg} border ${s.border} rounded-lg p-3">
      <div class="flex items-center gap-2 mb-1">
        <span class="inline-flex px-2 py-0.5 rounded text-xs font-semibold ${s.badge}">${s.icon} ${smell.severity.toUpperCase()}</span>
        <span class="text-sm font-semibold">${smell.name}</span>
      </div>
      <p class="text-xs text-text-muted mb-1">${detail}</p>
      <p class="text-xs text-foreground/70"><strong>Fix:</strong> ${smell.fix}</p>
    </div>`;
  }).join('');
}

document.getElementById('btn-analyze-smell')?.addEventListener('click', detectSmells);
document.getElementById('btn-example-smell')?.addEventListener('click', () => {
  (document.getElementById('smell-input') as HTMLTextAreaElement).value = EXAMPLE_SMELL;
  detectSmells();
});
</script>
