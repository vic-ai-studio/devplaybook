---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TextToBinary from '../../components/TextToBinary.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How does text to binary conversion work?", answer: "Each character is converted to its ASCII (or Unicode) code point, then that number is expressed as an 8-bit binary string. For example, 'H' is ASCII 72, which is 01001000 in binary." },
  { question: "What is hexadecimal and why is it used?", answer: "Hexadecimal (base 16) uses digits 0-9 and letters A-F. It's more compact than binary — each hex digit represents exactly 4 bits, so a byte is two hex digits (e.g., 0xFF). Hex is common in color codes, memory addresses, and cryptographic hashes." },
  { question: "How do I convert binary back to text?", answer: "Select 'Binary → Text' mode, paste binary digits (spaces are ignored), and the converter groups them into 8-bit chunks and converts each to its ASCII character." },
  { question: "What character encoding is used?", answer: "The converter uses ASCII code points (charCodeAt / fromCharCode), which handles standard ASCII characters (0-127) correctly. For non-ASCII Unicode characters, the binary representation will use the character's Unicode code point." },
];
---

<BaseLayout
  title="Text to Binary Converter — Text, Binary & Hex Converter"
  description="Convert text to binary, binary to text, text to hexadecimal, and hex to text. Free online converter with separator options. Runs entirely in your browser."
  tool="text to binary, binary to text, text to hex, hex to text, ASCII binary converter, binary converter online"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Text ↔ Binary ↔ Hex Converter</h1>
  <p class="text-text-muted mb-4">Convert between plain text, binary (base 2), and hexadecimal (base 16). Choose your separator (space, dash, or none) for binary and hex output. Handles ASCII characters with instant conversion.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No data leaves your machine</span>
  </div>
  <TextToBinary client:only="preact" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more free developer tools?</p>
    <a href="/tools" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Browse All Free Tools →</a>
  </div>
  <ToolPageCta currentTool="Text to Binary Converter" relatedTags={['encoding', 'binary', 'hex', 'converter']} />
</BaseLayout>
