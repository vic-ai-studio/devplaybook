---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is WCAG and why does contrast matter?", answer: "WCAG (Web Content Accessibility Guidelines) is the international standard for web accessibility, published by the W3C. Color contrast requirements ensure that people with low vision or color blindness can read text on your website. WCAG 2.1 Level AA (the most commonly required standard) mandates at least 4.5:1 contrast for normal text and 3:1 for large text (18pt+ or 14pt bold)." },
  { question: "What counts as 'large text' in WCAG?", answer: "Large text is defined as 18pt (24px) or larger for regular weight, or 14pt (approximately 18.67px) or larger for bold text. The contrast requirement for large text is lower (3:1 for AA, 4.5:1 for AAA) because larger text is easier to read even at lower contrast ratios." },
  { question: "What is the difference between WCAG AA and AAA?", answer: "AA is the minimum standard required by most accessibility laws (including the ADA, EN 301 549, and AODA). AA requires 4.5:1 for normal text and 3:1 for large text. AAA is the enhanced standard — it requires 7:1 for normal text and 4.5:1 for large text. Most projects target AA; AAA is recommended for critical content like medical or legal information." },
  { question: "How is the contrast ratio calculated?", answer: "The WCAG formula converts hex colors to relative luminance values using the sRGB color space. Each channel (R, G, B) is linearized, then luminance L = 0.2126R + 0.7152G + 0.0722B. The contrast ratio is (L1 + 0.05) / (L2 + 0.05), where L1 is the lighter of the two luminances. This formula is standardized in WCAG 2.x and used by all major accessibility testing tools." },
  { question: "My design fails AA — what should I do?", answer: "Use this tool's alternative suggestions to find the closest passing shade. Common fixes: darken light text colors, lighten dark text on light backgrounds, or increase font size to meet the lower large-text threshold. Also consider using Tailwind's color scale steps — moving from gray-400 to gray-600 typically adds 2-3x contrast." },
];
---

<BaseLayout
  title="WCAG Color Contrast Checker — AA/AAA Accessibility Tester"
  description="Check WCAG color contrast ratio between any two colors. See pass/fail for AA and AAA normal and large text, get 5 accessible alternatives, and preview text samples live."
  tool="WCAG Contrast Checker, Color Contrast Ratio, Accessibility Color Checker, AA AAA Contrast Test, Color Blind Accessibility, Relative Luminance Calculator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Accessibility Color Contrast Checker</h1>
  <p class="text-text-muted mb-4">Check WCAG 2.1 contrast ratio between foreground and background colors. Instant pass/fail for AA and AAA standards, live text preview, and accessible color suggestions.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> WCAG 2.1 AA & AAA</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 accessible alternatives</span>
  </div>

  <!-- Presets -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-3">Color Presets</h2>
    <div class="flex flex-wrap gap-2" id="presets-container">
      <!-- Filled by JS -->
    </div>
  </div>

  <!-- Color Inputs -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Color Pair</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label class="block text-sm font-medium mb-1.5">Foreground Color (text)</label>
        <div class="flex items-center gap-3">
          <input id="fg-picker" type="color" value="#111827"
            class="w-12 h-10 rounded-lg border border-border cursor-pointer bg-transparent p-0.5" />
          <input id="fg-hex" type="text" value="#111827" maxlength="7" placeholder="#000000"
            class="flex-1 bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Background Color</label>
        <div class="flex items-center gap-3">
          <input id="bg-picker" type="color" value="#ffffff"
            class="w-12 h-10 rounded-lg border border-border cursor-pointer bg-transparent p-0.5" />
          <input id="bg-hex" type="text" value="#ffffff" maxlength="7" placeholder="#ffffff"
            class="flex-1 bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>
      </div>
    </div>
    <div class="flex justify-center mt-4">
      <button id="swap-btn" class="flex items-center gap-2 text-sm px-4 py-2 bg-bg-surface border border-border rounded-lg hover:border-primary text-text-muted hover:text-primary transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/></svg>
        Swap Colors
      </button>
    </div>
  </div>

  <!-- Results -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-5">
    <!-- Ratio + badges -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="text-base font-semibold mb-4">Contrast Analysis</h2>
      <div class="text-center mb-5">
        <div id="ratio-display" class="text-5xl font-bold mb-1 text-primary">—</div>
        <div class="text-sm text-text-muted">Contrast Ratio</div>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div class="bg-bg-surface border border-border rounded-xl p-3 text-center">
          <div class="text-xs text-text-muted mb-1">AA Normal Text</div>
          <div id="aa-normal" class="text-lg font-bold">—</div>
          <div class="text-xs text-text-muted mt-0.5">Min 4.5:1</div>
        </div>
        <div class="bg-bg-surface border border-border rounded-xl p-3 text-center">
          <div class="text-xs text-text-muted mb-1">AA Large Text</div>
          <div id="aa-large" class="text-lg font-bold">—</div>
          <div class="text-xs text-text-muted mt-0.5">Min 3:1</div>
        </div>
        <div class="bg-bg-surface border border-border rounded-xl p-3 text-center">
          <div class="text-xs text-text-muted mb-1">AAA Normal Text</div>
          <div id="aaa-normal" class="text-lg font-bold">—</div>
          <div class="text-xs text-text-muted mt-0.5">Min 7:1</div>
        </div>
        <div class="bg-bg-surface border border-border rounded-xl p-3 text-center">
          <div class="text-xs text-text-muted mb-1">AAA Large Text</div>
          <div id="aaa-large" class="text-lg font-bold">—</div>
          <div class="text-xs text-text-muted mt-0.5">Min 4.5:1</div>
        </div>
      </div>
    </div>

    <!-- Text preview -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="text-base font-semibold mb-4">Live Text Preview</h2>
      <div id="preview-box" class="rounded-xl p-5 border border-border space-y-3 transition-colors duration-200">
        <div id="preview-small" class="text-xs leading-relaxed">Small text (12px) — The quick brown fox jumps over the lazy dog.</div>
        <div id="preview-body" class="text-sm leading-relaxed">Body text (16px) — The quick brown fox jumps over the lazy dog. Pack my box with five dozen liquor jugs.</div>
        <div id="preview-large" class="text-xl font-medium leading-snug">Large text (20px bold) — Sample heading</div>
        <div id="preview-heading" class="text-3xl font-bold leading-tight">Display (30px)</div>
        <div id="preview-link" class="text-sm underline cursor-pointer">Link text sample</div>
      </div>
    </div>
  </div>

  <!-- Accessible Alternatives -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-1">Accessible Foreground Alternatives</h2>
    <p class="text-xs text-text-muted mb-4">5 closest colors to your foreground that pass WCAG AA normal text (4.5:1)</p>
    <div id="alternatives-grid" class="grid grid-cols-1 sm:grid-cols-5 gap-3"></div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Accessibility Color Contrast Checker" relatedTags={['accessibility', 'wcag', 'color', 'design', 'a11y', 'contrast']} />
</BaseLayout>

<script>
  var PRESETS = [
    { label: 'Black / White', fg: '#000000', bg: '#ffffff' },
    { label: 'White / Black', fg: '#ffffff', bg: '#000000' },
    { label: 'Dark / Light gray', fg: '#1f2937', bg: '#f9fafb' },
    { label: 'Blue / White', fg: '#1d4ed8', bg: '#ffffff' },
    { label: 'Green / White', fg: '#15803d', bg: '#ffffff' },
    { label: 'Red / White', fg: '#dc2626', bg: '#ffffff' },
    { label: 'Yellow / Black', fg: '#fbbf24', bg: '#000000' },
    { label: 'White / Blue', fg: '#ffffff', bg: '#1d4ed8' },
  ];

  function hexToRgb(hex) {
    var clean = hex.replace('#', '');
    if (clean.length === 3) clean = clean.split('').map(function(c) { return c + c; }).join('');
    if (clean.length !== 6) return null;
    var n = parseInt(clean, 16);
    if (isNaN(n)) return null;
    return { r: (n >> 16) & 255, g: (n >> 8) & 255, b: n & 255 };
  }

  function linearize(c) {
    var v = c / 255;
    return v <= 0.04045 ? v / 12.92 : Math.pow((v + 0.055) / 1.055, 2.4);
  }

  function luminance(hex) {
    var rgb = hexToRgb(hex);
    if (!rgb) return 0;
    var r = linearize(rgb.r);
    var g = linearize(rgb.g);
    var b = linearize(rgb.b);
    return 0.2126 * r + 0.7152 * g + 0.0722 * b;
  }

  function contrastRatio(hex1, hex2) {
    var l1 = luminance(hex1);
    var l2 = luminance(hex2);
    var lighter = Math.max(l1, l2);
    var darker = Math.min(l1, l2);
    return (lighter + 0.05) / (darker + 0.05);
  }

  function passBadge(passes) {
    if (passes) return '<span class="text-green-500 font-bold">Pass ✓</span>';
    return '<span class="text-red-500 font-bold">Fail ✗</span>';
  }

  function clamp(v, min, max) {
    return Math.max(min, Math.min(max, v));
  }

  function rgbToHex(r, g, b) {
    return '#' + [r, g, b].map(function(v) {
      return clamp(Math.round(v), 0, 255).toString(16).padStart(2, '0');
    }).join('');
  }

  function shiftLightness(hex, delta) {
    var rgb = hexToRgb(hex);
    if (!rgb) return hex;
    return rgbToHex(rgb.r + delta, rgb.g + delta, rgb.b + delta);
  }

  function generateAlternatives(fgHex, bgHex) {
    var alts = [];
    var bgLum = luminance(bgHex);
    var directions = bgLum > 0.5
      ? [-10, -20, -35, -50, -70]
      : [10, 20, 35, 50, 70];

    for (var i = 0; i < directions.length; i++) {
      var candidate = shiftLightness(fgHex, directions[i]);
      var ratio = contrastRatio(candidate, bgHex);
      alts.push({ hex: candidate, ratio: ratio, passes: ratio >= 4.5 });
    }
    return alts;
  }

  function isValidHex(hex) {
    return /^#[0-9a-fA-F]{6}$/.test(hex);
  }

  function render() {
    var fg = document.getElementById('fg-hex').value.trim();
    var bg = document.getElementById('bg-hex').value.trim();

    if (!fg.startsWith('#')) fg = '#' + fg;
    if (!bg.startsWith('#')) bg = '#' + bg;

    if (!isValidHex(fg) || !isValidHex(bg)) return;

    var ratio = contrastRatio(fg, bg);
    var ratioStr = ratio.toFixed(2) + ':1';

    document.getElementById('ratio-display').textContent = ratioStr;

    document.getElementById('aa-normal').innerHTML = passBadge(ratio >= 4.5);
    document.getElementById('aa-large').innerHTML = passBadge(ratio >= 3);
    document.getElementById('aaa-normal').innerHTML = passBadge(ratio >= 7);
    document.getElementById('aaa-large').innerHTML = passBadge(ratio >= 4.5);

    // Preview
    var box = document.getElementById('preview-box');
    box.style.backgroundColor = bg;
    ['preview-small', 'preview-body', 'preview-large', 'preview-heading', 'preview-link'].forEach(function(id) {
      document.getElementById(id).style.color = fg;
    });

    // Alternatives
    var alts = generateAlternatives(fg, bg);
    var grid = document.getElementById('alternatives-grid');
    grid.innerHTML = alts.map(function(alt) {
      var borderClass = alt.passes ? 'border-green-500' : 'border-border';
      var badge = alt.passes
        ? '<span class="text-xs text-green-400 font-semibold">AA ✓</span>'
        : '<span class="text-xs text-red-400">Fail</span>';
      return '<div class="border ' + borderClass + ' rounded-xl overflow-hidden cursor-pointer alt-swatch" data-hex="' + alt.hex + '">' +
        '<div class="h-14" style="background-color:' + bg + '">' +
        '<div class="h-full flex items-center justify-center text-sm font-medium" style="color:' + alt.hex + '">Sample</div>' +
        '</div>' +
        '<div class="p-2 bg-bg-surface text-center">' +
        '<div class="font-mono text-xs">' + alt.hex + '</div>' +
        '<div class="text-xs text-text-muted">' + alt.ratio.toFixed(2) + ':1</div>' +
        badge +
        '</div></div>';
    }).join('');

    // Alt swatch click
    document.querySelectorAll('.alt-swatch').forEach(function(el) {
      el.addEventListener('click', function() {
        var hex = el.getAttribute('data-hex');
        document.getElementById('fg-hex').value = hex;
        document.getElementById('fg-picker').value = hex;
        render();
      });
    });
  }

  function syncPicker(pickerId, hexId) {
    document.getElementById(pickerId).addEventListener('input', function() {
      document.getElementById(hexId).value = this.value;
      render();
    });
  }

  function syncHex(hexId, pickerId) {
    document.getElementById(hexId).addEventListener('input', function() {
      var val = this.value.trim();
      if (!val.startsWith('#')) val = '#' + val;
      if (isValidHex(val)) {
        document.getElementById(pickerId).value = val;
        render();
      }
    });
  }

  syncPicker('fg-picker', 'fg-hex');
  syncPicker('bg-picker', 'bg-hex');
  syncHex('fg-hex', 'fg-picker');
  syncHex('bg-hex', 'bg-picker');

  document.getElementById('swap-btn').addEventListener('click', function() {
    var fg = document.getElementById('fg-hex').value;
    var bg = document.getElementById('bg-hex').value;
    document.getElementById('fg-hex').value = bg;
    document.getElementById('bg-hex').value = fg;
    document.getElementById('fg-picker').value = bg;
    document.getElementById('bg-picker').value = fg;
    render();
  });

  // Presets
  var presetsEl = document.getElementById('presets-container');
  presetsEl.innerHTML = PRESETS.map(function(p) {
    return '<button class="preset-btn flex items-center gap-2 text-xs px-3 py-1.5 bg-bg-surface border border-border rounded-lg hover:border-primary text-text-muted hover:text-primary transition-colors" data-fg="' + p.fg + '" data-bg="' + p.bg + '">' +
      '<span class="w-3 h-3 rounded-sm border border-border/50 inline-block" style="background:' + p.fg + '"></span>' +
      '<span class="w-3 h-3 rounded-sm border border-border/50 inline-block" style="background:' + p.bg + '"></span>' +
      p.label + '</button>';
  }).join('');

  document.querySelectorAll('.preset-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var fg = btn.getAttribute('data-fg');
      var bg = btn.getAttribute('data-bg');
      document.getElementById('fg-hex').value = fg;
      document.getElementById('bg-hex').value = bg;
      document.getElementById('fg-picker').value = fg;
      document.getElementById('bg-picker').value = bg;
      render();
    });
  });

  render();
</script>
