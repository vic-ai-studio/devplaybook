---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OpenGraphPreview from '../../components/OpenGraphPreview.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What are Open Graph meta tags and why do they matter?", answer: "Open Graph (OG) meta tags are HTML tags that control how your page appears when shared on social platforms like Twitter/X, Facebook, LinkedIn, and iMessage. Without them, social networks scrape random text and images — often poorly. With proper OG tags, you control the title, description, image, and URL preview. A good OG preview dramatically increases click-through rates on shared links." },
  { question: "What are the essential meta tags every page needs?", answer: "At minimum: og:title (max ~60 chars), og:description (max ~200 chars), og:image (1200×630px recommended), og:url (canonical URL). For Twitter/X: twitter:card set to 'summary_large_image' for full-width image previews. For search engines: <title> (50–60 chars) and <meta name='description'> (150–160 chars). Also add og:type (usually 'website' or 'article') and og:site_name." },
  { question: "What image size should I use for og:image?", answer: "Use 1200×630 pixels (1.91:1 ratio) — this works on all major platforms. Twitter/X minimum is 300×157px (summary_large_image). Facebook recommends 1200×630px. LinkedIn renders best at 1200×627px. Keep image file size under 8MB. Use JPG or PNG — avoid GIFs. Use an absolute URL (starting with https://) — relative paths don't work for og:image." },
  { question: "What's the difference between twitter:card types?", answer: "'summary' shows a small square thumbnail with text (good for general pages). 'summary_large_image' shows a large landscape image above the text (best for articles and content). 'app' is for app store links. 'player' is for video/audio embeds. Most sites should use summary_large_image for all content pages to maximize visual impact in feeds." },
  { question: "Why doesn't my og:image show when I share my link?", answer: "Common causes: (1) Image URL is relative, not absolute. Use the full https:// URL. (2) Image is behind authentication or returns 4xx/5xx. (3) Image is too small — platforms may ignore images below 200×200px. (4) Platform cached the old preview — use Facebook's Sharing Debugger or Twitter's Card Validator to force re-scrape. (5) og:image tag is missing from the <head> section. (6) Robots.txt blocks the crawler from fetching the image URL." },
  { question: "How do I add meta tags in Next.js, Astro, and other frameworks?", answer: "Next.js 13+ App Router: export const metadata = { openGraph: { title: '...', images: ['...'] } } in layout.tsx. Next.js Pages: use <Head> component from next/head. Astro: set them in the layout's <head> or use the built-in SEO props. Gatsby: use react-helmet or gatsby-plugin-react-helmet. React (SPA): use react-helmet-async. All frameworks ultimately output <meta property='og:...'> tags in the <head>." },
];
---

<BaseLayout
  title="Meta Tags Preview — See How Your Page Looks on Google, Twitter & Facebook"
  description="Preview how your web page appears when shared on Twitter/X, Facebook, and LinkedIn. Configure og:title, og:description, og:image, and twitter:card. Live preview in your browser."
  tool="meta tags preview, open graph preview, og image preview, Twitter card preview, social media preview tool, Facebook link preview"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Meta Tags Preview",
    "url": "https://devplaybook.cc/tools/meta-tags-preview",
    "description": "Preview how your page appears when shared on Twitter/X, Facebook, and LinkedIn. Configure Open Graph and Twitter Card meta tags and see live previews.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Meta Tags Preview</h1>
  <p class="text-text-muted mb-4">
    See exactly how your page will appear when shared on <strong>Twitter/X</strong>, <strong>Facebook</strong>, and <strong>LinkedIn</strong>. Enter your Open Graph and Twitter Card meta tag values and get a live social preview. No URL needed — all previews run in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Twitter/X, Facebook, LinkedIn previews</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> og:title, og:description, og:image</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live preview — no URL needed</span>
  </div>
  <OpenGraphPreview client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Meta Tags Preview" relatedTags={['seo', 'meta-tags', 'open-graph', 'social-media', 'developer-tools']} />
</BaseLayout>
