---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CorsPolicyBuilder from '../../components/CorsPolicyBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is CORS and why do I need to configure it?",
    answer: "CORS (Cross-Origin Resource Sharing) is a browser security policy that blocks web pages from making requests to a different domain, protocol, or port unless the server explicitly allows it. If your API at api.example.com needs to accept requests from a frontend at app.example.com, you must add CORS headers to your API responses. Without them, browsers will block the response even if the request reached your server.",
  },
  {
    question: "What's the difference between a simple request and a preflight?",
    answer: "Simple requests (GET, POST with standard content types) are sent directly with the origin header. Non-simple requests (PUT, DELETE, custom headers, JSON content-type) trigger a preflight: the browser first sends an OPTIONS request to check if the server permits the actual request. Your server must respond to the OPTIONS request with Access-Control-Allow-Methods and Access-Control-Allow-Headers, or the actual request will never be sent.",
  },
  {
    question: "Why can't I use Access-Control-Allow-Origin: * with credentials?",
    answer: "The CORS spec explicitly prohibits this combination. When a request includes credentials (cookies, Authorization headers), the browser requires the server to echo back the exact requesting origin — not a wildcard. Using * with credentials: true is a security risk (any site could make credentialed requests), so browsers reject it. Use an origin allowlist and dynamically echo back the requesting origin if it's on the list.",
  },
  {
    question: "What is Access-Control-Max-Age?",
    answer: "Access-Control-Max-Age tells the browser how many seconds to cache the preflight response. While the preflight is cached, the browser skips the OPTIONS request for subsequent requests to the same endpoint from the same origin. The default (if omitted) is 5 seconds in most browsers. Increase it (e.g., 3600 = 1 hour, 86400 = 24 hours) to reduce preflight latency for frequently-called APIs.",
  },
  {
    question: "How do I allow multiple origins dynamically?",
    answer: "You can't list multiple values in Access-Control-Allow-Origin — it only accepts a single origin or *. To support multiple specific origins, check the incoming Origin header in your server code against a whitelist, then echo back the matching origin. This tool generates that pattern for Express, FastAPI, Django, and other frameworks automatically.",
  },
  {
    question: "Why is my CORS config not working in production?",
    answer: "Common issues: 1) Your CDN or reverse proxy (Nginx, Cloudflare) strips or overrides CORS headers — add headers at the proxy layer too. 2) The preflight OPTIONS request isn't being handled (add a route or middleware for it). 3) You're allowing * but the request includes credentials. 4) You forgot to include the specific Content-Type or Authorization in Access-Control-Allow-Headers. 5) Your server is returning a 4xx/5xx error before the CORS middleware runs — CORS headers are still needed on error responses.",
  },
];
---

<BaseLayout
  title="CORS Policy Builder — Generate CORS Config for Express, Nginx, FastAPI & More"
  description="Build CORS policy configuration for Express.js, Nginx, FastAPI, Django, Koa, Laravel, and Spring Boot. Set allowed origins, methods, headers, credentials, and max-age. Generate ready-to-paste config code. Free, runs in your browser."
  tool="CORS Policy Builder, CORS Config Generator, Express CORS Setup, Nginx CORS Headers, FastAPI CORS Middleware, Django CORS Config"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "CORS Policy Builder",
    "url": "https://devplaybook.cc/tools/cors-policy-builder",
    "description": "Generate CORS configuration for Express.js, Nginx, FastAPI, Django, Koa, Laravel, and Spring Boot. Set origins, methods, headers, and credentials.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">CORS Policy Builder</h1>
  <p class="text-text-muted mb-4">
    Generate <strong>CORS configuration code</strong> for any framework. Set your allowed origins, methods, headers, and credentials — get ready-to-paste config for <strong>Express.js, Nginx, FastAPI, Django, Koa, Laravel, and Spring Boot</strong>.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 8 frameworks supported</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multiple origin support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Credentials & preflight config</span>
  </div>
  <CorsPolicyBuilder client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CORS Policy Builder" relatedTags={['cors', 'api', 'backend', 'security', 'express', 'nginx', 'developer-tools']} />
</BaseLayout>
