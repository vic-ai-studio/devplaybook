---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NginxConfigGenerator from '../../components/NginxConfigGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is nginx and when should I use it?", answer: "nginx (engine-x) is a high-performance web server and reverse proxy. Use it to serve static sites with incredible speed, proxy requests to Node.js/Python/PHP apps, terminate SSL/TLS, and add security headers. It handles 10,000+ concurrent connections with minimal RAM — far more efficient than Apache for most workloads." },
  { question: "What is the difference between nginx and Apache?", answer: "nginx uses an event-driven, asynchronous architecture — one worker process handles many connections simultaneously. Apache uses a process/thread-per-connection model. Result: nginx uses less memory and performs better under high concurrency. Apache's .htaccess per-directory config is more flexible but slower. For modern deployments, nginx is the dominant choice." },
  { question: "How do I enable HTTPS with Let's Encrypt?", answer: "Install Certbot: sudo apt install certbot python3-certbot-nginx. Run: sudo certbot --nginx -d example.com -d www.example.com. Certbot will obtain certificates and automatically update your nginx config. It also sets up auto-renewal via a systemd timer." },
  { question: "What does 'proxy_pass http://127.0.0.1:3000' do?", answer: "It forwards incoming requests from nginx to a backend server running locally on port 3000 (e.g., a Node.js app). nginx acts as a reverse proxy — clients connect to nginx (port 80/443), and nginx forwards the request internally. This lets you run multiple apps on one server and handle SSL at the nginx layer." },
  { question: "What are the most important security headers to include?", answer: "Key security headers: X-Frame-Options: SAMEORIGIN (prevents clickjacking), X-Content-Type-Options: nosniff (prevents MIME sniffing), X-XSS-Protection (legacy XSS filter), Referrer-Policy: no-referrer-when-downgrade (controls referrer info), and Strict-Transport-Security (HSTS, forces HTTPS). For CSP (Content-Security-Policy), add it manually tailored to your app." },
  { question: "How do I test my nginx config before applying it?", answer: "Run: sudo nginx -t. This validates the configuration syntax without reloading. If it shows 'syntax is ok', apply with: sudo systemctl reload nginx (graceful, zero-downtime). Never use restart unless necessary — reload sends a SIGHUP which allows existing connections to finish." },
];
---

<BaseLayout
  title="nginx Config Generator — Static, Proxy, PHP, SSL — Free Online Tool"
  description="Generate production-ready nginx server blocks instantly. Supports static sites, reverse proxy (Node.js, API), PHP-FPM, and HTTPS redirects. Includes SSL/TLS, gzip, cache headers, security headers, and HSTS. Copy-ready nginx.conf output."
  tool="nginx config generator, nginx reverse proxy, nginx SSL config, nginx static site, nginx PHP, nginx security headers, nginx gzip"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">nginx Config Generator</h1>
  <p class="text-text-muted mb-8">Generate a production-ready nginx server block for your use case — static site, reverse proxy, PHP-FPM, or redirect. Includes SSL, gzip, caching, and security headers. No need to memorize nginx syntax.</p>
  <NginxConfigGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="nginx Config Generator" relatedTags={['nginx', 'server', 'devops', 'ssl', 'web-server']} />
</BaseLayout>
