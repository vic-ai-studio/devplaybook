---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EpochConverter from '../../components/EpochConverter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a Unix epoch timestamp?", answer: "Unix epoch (or Unix time) is the number of seconds elapsed since January 1, 1970, 00:00:00 UTC. It is a standard way to represent timestamps in programming because it is timezone-independent, compact, and easy to compare and calculate with." },
  { question: "How do I convert epoch to a human-readable date?", answer: "Paste your Unix timestamp into the 'Epoch → Date' field. The tool converts it instantly to multiple formats: human-readable, ISO 8601, RFC 2822, and relative time (e.g. '3 days ago'). Select any timezone to see the local time." },
  { question: "How do I convert a date to epoch?", answer: "Switch to 'Date → Epoch' mode. Enter your date in YYYY-MM-DD or YYYY-MM-DD HH:MM:SS format, select the timezone the date is in, and the tool outputs the Unix epoch in both seconds and milliseconds." },
  { question: "What is the difference between seconds and milliseconds epoch?", answer: "Most Unix systems use seconds (10-digit numbers like 1700000000). JavaScript's Date.now() and many APIs use milliseconds (13-digit numbers). The tool auto-detects which one you entered and you can switch with the dropdown." },
  { question: "Why do some APIs use milliseconds instead of seconds?", answer: "JavaScript's Date object works in milliseconds, so many web APIs (Redis, Kafka, browser localStorage) follow suit. Database systems like PostgreSQL typically use seconds. Always check the API documentation to avoid off-by-1000x bugs." },
];
---

<BaseLayout
  title="Unix Epoch Converter — Timestamp to Date | Multiple Timezones"
  description="Convert Unix epoch timestamps to human-readable dates (and back). Supports seconds and milliseconds auto-detection, 19 timezones, relative time display, ISO 8601, and RFC 2822 output. Essential for debugging API timestamps, Kafka offsets, database records, and log analysis. Includes a live epoch counter. Free, runs in your browser."
  tool="epoch converter, unix timestamp converter, epoch to date, date to epoch, unix time converter, timestamp to datetime"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Unix Epoch Converter</h1>
  <p class="text-text-muted mb-4">Convert Unix timestamps to human-readable dates and back. Supports seconds and milliseconds, multiple timezones, relative time display, and ISO 8601 / RFC 2822 formats. Includes a live epoch clock.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 19 timezones supported</span>
  </div>
  <EpochConverter client:only="preact" />
  <!-- Real-World Use Cases -->
  <section class="mt-12 mb-8">
    <h2 class="text-2xl font-bold mb-6">Real-World Use Cases</h2>

    <div class="space-y-6">
      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">1. Debugging API Token Expiry Times</h3>
        <p class="text-text-muted mb-3">Your JWT token has <code class="font-mono text-sm bg-bg-card px-1 rounded">"exp": 1712300000</code> in the payload. Paste the epoch value here to see exactly when the token expires in your local timezone — no mental math needed.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Input (seconds)</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">1712300000</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Converted Output</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`Fri Apr 05 2024 14:13:20 UTC\nISO: 2024-04-05T14:13:20.000Z\nRelative: about 2 years ago\n\n→ Token is long expired!`}</pre>
          </div>
        </div>
      </div>

      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">2. Converting JavaScript Date.now() Milliseconds</h3>
        <p class="text-text-muted mb-3">You see <code class="font-mono text-sm bg-bg-card px-1 rounded">1712345678901</code> in a console log from <code class="font-mono text-sm bg-bg-card px-1 rounded">Date.now()</code>. The tool auto-detects it's milliseconds (13 digits) and converts it correctly without you needing to divide by 1000.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Input (milliseconds)</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">1712345678901</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Auto-Detected &amp; Converted</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`Format: milliseconds (auto)\n\nFri Apr 05 2024 14:54:38 UTC\nRFC 2822: Fri, 05 Apr 2024\n  14:54:38 +0000`}</pre>
          </div>
        </div>
      </div>

      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">3. Creating Epoch Timestamps for Database Queries</h3>
        <p class="text-text-muted mb-3">You need to filter records created after a specific date. Switch to "Date → Epoch" mode, enter the date, and get the epoch value for your SQL <code class="font-mono text-sm bg-bg-card px-1 rounded">WHERE created_at &gt;</code> clause.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Input Date</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`2026-01-01 00:00:00\nTimezone: Asia/Taipei (UTC+8)`}</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Epoch Output</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`Seconds:      1767196800\nMilliseconds: 1767196800000\n\nSQL: WHERE created_at &gt;\n  1767196800`}</pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Step-by-Step Guide -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">How to Use — Step by Step</h2>
    <ol class="list-decimal list-inside space-y-3 text-text-muted">
      <li><strong>Choose direction</strong> — Select "Epoch → Date" to decode a timestamp, or "Date → Epoch" to generate one.</li>
      <li><strong>Enter your value</strong> — Paste a Unix timestamp (10 or 13 digits) or type a date in <code class="font-mono text-sm bg-bg-card px-1 rounded">YYYY-MM-DD HH:MM:SS</code> format.</li>
      <li><strong>Select timezone</strong> — Choose from 19 common timezones. The conversion adjusts automatically for UTC offset.</li>
      <li><strong>Read the output</strong> — See the result in multiple formats: human-readable, ISO 8601, RFC 2822, and relative time (e.g. "3 days ago").</li>
      <li><strong>Copy</strong> — Click copy to grab the value you need for your code, database query, or API request.</li>
    </ol>
  </section>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Epoch Converter" relatedTags={['time', 'datetime', 'unix', 'timestamp', 'converter']} />
</BaseLayout>
