---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EpochConverter from '../../components/EpochConverter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a Unix epoch timestamp?", answer: "Unix epoch (or Unix time) is the number of seconds elapsed since January 1, 1970, 00:00:00 UTC. It is a standard way to represent timestamps in programming because it is timezone-independent, compact, and easy to compare and calculate with." },
  { question: "How do I convert epoch to a human-readable date?", answer: "Paste your Unix timestamp into the 'Epoch → Date' field. The tool converts it instantly to multiple formats: human-readable, ISO 8601, RFC 2822, and relative time (e.g. '3 days ago'). Select any timezone to see the local time." },
  { question: "How do I convert a date to epoch?", answer: "Switch to 'Date → Epoch' mode. Enter your date in YYYY-MM-DD or YYYY-MM-DD HH:MM:SS format, select the timezone the date is in, and the tool outputs the Unix epoch in both seconds and milliseconds." },
  { question: "What is the difference between seconds and milliseconds epoch?", answer: "Most Unix systems use seconds (10-digit numbers like 1700000000). JavaScript's Date.now() and many APIs use milliseconds (13-digit numbers). The tool auto-detects which one you entered and you can switch with the dropdown." },
  { question: "Why do some APIs use milliseconds instead of seconds?", answer: "JavaScript's Date object works in milliseconds, so many web APIs (Redis, Kafka, browser localStorage) follow suit. Database systems like PostgreSQL typically use seconds. Always check the API documentation to avoid off-by-1000x bugs." },
];
---

<BaseLayout
  title="Unix Epoch Converter — Timestamp to Date | Multiple Timezones"
  description="Convert Unix epoch timestamps to human-readable dates (and back). Supports seconds and milliseconds, 19 timezones, relative time display, ISO 8601, RFC 2822, and a live epoch counter. Free, runs in your browser."
  tool="epoch converter, unix timestamp converter, epoch to date, date to epoch, unix time converter, timestamp to datetime"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Unix Epoch Converter</h1>
  <p class="text-text-muted mb-4">Convert Unix timestamps to human-readable dates and back. Supports seconds and milliseconds, multiple timezones, relative time display, and ISO 8601 / RFC 2822 formats. Includes a live epoch clock.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 19 timezones supported</span>
  </div>
  <EpochConverter client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Epoch Converter" relatedTags={['time', 'datetime', 'unix', 'timestamp', 'converter']} />
</BaseLayout>
