---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WasmTextConverter from '../../components/WasmTextConverter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is WAT (WebAssembly Text Format)?",
    answer: "WAT is the S-expression based human-readable text representation of WebAssembly. Every .wasm binary has an equivalent .wat form that can be round-tripped via the wabt toolchain. WAT uses parenthesized expressions like (func $add (param i32 i32) (result i32) ...) to describe modules. It's the primary format for hand-authoring small WASM modules, debugging disassembled binaries, and learning WASM internals."
  },
  {
    question: "How do I compile WAT to a WASM binary?",
    answer: "Install wabt (WebAssembly Binary Toolkit): 'npm install -g wabt' or 'brew install wabt'. Then run: wat2wasm module.wat -o module.wasm. To go the other direction (disassemble): wasm2wat module.wasm -o module.wat. You can also validate without producing output: wat2wasm module.wat --output=-. The online wat.js project lets you compile WAT in the browser via JavaScript."
  },
  {
    question: "What are the WASM value types?",
    answer: "WebAssembly MVP supports four value types: i32 (32-bit integer), i64 (64-bit integer), f32 (32-bit float), f64 (64-bit float). The post-MVP additions include v128 (128-bit SIMD vector), funcref (function reference), and externref (host object reference). There is no boolean type — conditions use i32 where 0 is false and non-zero is true. Strings are not a native type; they're stored in linear memory as UTF-8 bytes."
  },
  {
    question: "What is the WASM stack machine model?",
    answer: "WebAssembly uses a stack-based virtual machine. Instructions push values onto and pop values off an implicit stack. For example, 'i32.add' pops two i32 values from the stack and pushes their sum. 'local.get $x' pushes the value of local variable $x. Function parameters and locals are indexed. The WAT text format also supports a folded (S-expression) notation that looks more like a tree: (i32.add (local.get $a) (local.get $b))."
  },
  {
    question: "How does linear memory work in WASM?",
    answer: "WASM linear memory is a contiguous, byte-addressable buffer (WebAssembly.Memory). It starts at a specified size (in 64KB pages) and can grow with memory.grow. You declare it as (memory 1) for one 64KB page. JavaScript can read/write it via typed arrays on the buffer: new Uint8Array(instance.exports.memory.buffer). The (data ...) instruction initializes memory at module load. Pointers in WASM are just i32 byte offsets into this linear address space."
  },
];
---

<BaseLayout
  title="WAT to WASM Converter — WebAssembly Text Format Editor & Validator"
  description="Write and validate WebAssembly Text Format (WAT) code in your browser. Syntax highlighting, structure analysis, example snippets, and wat2wasm toolchain command reference included."
  tool="WAT editor, WebAssembly text format, wat2wasm, wasm text converter, WAT syntax, WASM toolchain"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">WAT to WASM Converter</h1>
  <p class="text-text-muted mb-4">Write, validate, and explore WebAssembly Text Format (WAT). Includes syntax highlighting, module structure analysis, 5 example snippets, and toolchain commands.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> WAT syntax highlighting</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Module structure analysis</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 example snippets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> wat2wasm commands</span>
  </div>

  <WasmTextConverter client:only="preact" />

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="WAT to WASM Converter" relatedTags={['webassembly', 'wasm', 'wat', 'compiler', 'systems', 'low-level']} />
</BaseLayout>
