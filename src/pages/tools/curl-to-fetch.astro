---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CurlToFetch from '../../components/CurlToFetch.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "Why convert cURL to fetch?",
    answer: "cURL is the universal HTTP client for terminals, but most JavaScript/TypeScript projects use fetch() (built-in browsers, Node 18+), axios, or node-fetch. Converting lets you copy API examples from documentation, Stack Overflow, or AI assistants — which commonly use cURL — directly into your JS code without manually translating headers, methods, and body formats."
  },
  {
    question: "What is the difference between fetch() and axios?",
    answer: "fetch() is built into modern browsers and Node.js 18+ with no dependencies. It returns a Response object — you must call .json() or .text() manually, and non-2xx responses don't throw by default. axios is a library that auto-parses JSON, throws on non-2xx status codes, supports request/response interceptors, has built-in timeout support, and works consistently across environments. For simple use cases, fetch() is fine; for complex API clients, axios adds convenience."
  },
  {
    question: "How does the converter handle JSON bodies?",
    answer: "When the cURL -d flag contains a JSON string (starting with '{' or '['), or when the Content-Type header is application/json, the converter auto-detects it as JSON. For fetch/axios, it wraps the body with JSON.stringify() and preserves the object structure. For form-encoded data (application/x-www-form-urlencoded or --data-urlencode), it keeps it as a raw string."
  },
  {
    question: "What happens to Basic Auth (-u user:pass)?",
    answer: "The -u user:pass flag gets converted to an Authorization: Basic header with the base64-encoded credentials. In JavaScript, this is btoa('user:pass'). The converter encodes it directly and includes it in the headers object, so the output works without additional libraries."
  },
  {
    question: "Does the converter handle multiline cURL commands?",
    answer: "Yes. cURL commands split across multiple lines with backslash continuations (\\) are normalized before parsing. You can paste the full multi-line command and it will be processed correctly."
  },
  {
    question: "What cURL flags are ignored?",
    answer: "Flags that don't have a direct HTTP equivalent are silently ignored: -L (follow redirects — fetch does this by default), -v (verbose), -s (silent), -k (insecure — fetch has no direct equivalent, use node-fetch with rejectUnauthorized for Node.js), -i (include headers in output), and timing flags like --max-time. If you need these behaviors, configure them separately in your HTTP client."
  },
];
---

<BaseLayout
  title="cURL to Fetch Converter — Convert cURL to JavaScript fetch(), axios, node-fetch"
  description="Paste a cURL command and instantly get the equivalent JavaScript fetch(), TypeScript fetch, axios, or node-fetch code. Supports headers, JSON body, basic auth, cookies, and all common HTTP methods."
  tool="curl to fetch, curl to javascript, curl converter, curl to axios, curl to node-fetch, convert curl command"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "cURL to Fetch Converter",
    "url": "https://devplaybook.cc/tools/curl-to-fetch",
    "description": "Convert cURL commands to JavaScript fetch(), TypeScript fetch, axios, or node-fetch. Handles headers, JSON body, auth, cookies, and all HTTP methods.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">cURL to Fetch Converter</h1>
  <p class="text-text-muted mb-4">
    Paste a cURL command and get the equivalent JavaScript code instantly. Supports <code class="font-mono bg-surface px-1 rounded text-sm">fetch()</code>, TypeScript fetch, <code class="font-mono bg-surface px-1 rounded text-sm">axios</code>, and <code class="font-mono bg-surface px-1 rounded text-sm">node-fetch</code>. Handles headers, JSON body, basic auth, and cookies — runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> fetch / axios / node-fetch</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Handles auth, JSON, cookies</span>
  </div>
  <CurlToFetch client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="cURL to Fetch Converter" relatedTags={['api', 'http', 'javascript', 'developer-tools', 'fetch', 'axios']} />
</BaseLayout>
