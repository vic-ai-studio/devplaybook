---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HmacGenerator from '../../components/HmacGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is HMAC and how is it different from a regular hash?",
    answer: "A regular hash (SHA-256, MD5) is a one-way transformation of data — anyone with the data can reproduce the hash. HMAC (Hash-based Message Authentication Code) adds a secret key to the process. Only someone with both the message and the key can produce the correct HMAC, so it proves both integrity (message not tampered) and authenticity (sender has the key)."
  },
  {
    question: "What is HMAC-SHA256 used for?",
    answer: "HMAC-SHA256 is the standard for: JWT HS256 signatures (the third segment), webhook verification (GitHub, Stripe, Slack all sign payloads with HMAC-SHA256), API request signing (AWS Signature v4, Shopify webhooks), and session token validation. It's the de facto standard for proving message authenticity in web APIs."
  },
  {
    question: "Which algorithm should I use?",
    answer: "Use HMAC-SHA256 for most cases — it's the industry standard with 256 bits of security and near-universal library support. Use HMAC-SHA512 for extra security or when dealing with very sensitive data. Avoid HMAC-SHA1 for new systems — it's considered weak and should only be used for compatibility with legacy services."
  },
  {
    question: "What is the difference between hex and base64 output?",
    answer: "Both represent the same HMAC bytes in different encodings. Hex uses 0-9 and a-f characters — always 64 chars for HMAC-SHA256. Base64 uses A-Z, a-z, 0-9, +, / characters — 44 chars for HMAC-SHA256. Use hex for debugging and logging. Use base64 when transmitting in HTTP headers or URLs."
  },
  {
    question: "How do I verify a GitHub webhook signature?",
    answer: "GitHub sends X-Hub-Signature-256: sha256=<HMAC> in the webhook header. To verify: compute HMAC-SHA256 of the raw request body using your webhook secret as the key, encode as hex, and compare the result to the value after sha256= in the header. Use a constant-time comparison to prevent timing attacks."
  },
  {
    question: "Is it safe to generate HMACs in the browser?",
    answer: "This tool uses the Web Crypto API (crypto.subtle.sign) which runs entirely in your browser — the message and key never leave your machine. However, do not use real production secrets in any online tool as a general security practice. Use this tool to understand HMAC or verify implementations with known test vectors."
  },
];
---

<BaseLayout
  title="HMAC Generator — HMAC-SHA256 / SHA512 Online"
  description="Generate HMAC hashes online using HMAC-SHA256, HMAC-SHA512, or HMAC-SHA1. Enter a message and secret key, choose hex or base64 output. Uses Web Crypto API — runs entirely in your browser. No data sent to any server."
  tool="HMAC Generator, HMAC-SHA256, HMAC Calculator, HMAC Online, Webhook Signature Generator, Message Authentication Code"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "HMAC Generator",
    "url": "https://devplaybook.cc/tools/hmac-generator",
    "description": "Generate HMAC hashes online using HMAC-SHA256, HMAC-SHA512, or HMAC-SHA1. Runs in your browser via Web Crypto API.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">HMAC Generator</h1>
  <p class="text-text-muted mb-4">
    Generate HMAC authentication codes using HMAC-SHA256, HMAC-SHA512, or HMAC-SHA1.
    Enter your message and secret key to get the hex or base64 HMAC instantly.
    Used for JWT signatures, webhook verification (GitHub, Stripe), and API request signing.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> HMAC-SHA256 / SHA512 / SHA1</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Hex + Base64 output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Web Crypto API — 100% in-browser</span>
  </div>
  <HmacGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="HMAC Generator" relatedTags={['security', 'authentication', 'api', 'webhooks', 'cryptography']} />
</BaseLayout>
