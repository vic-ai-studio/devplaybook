---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RestApiBuilder from '../../components/RestApiBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "Does this tool actually send HTTP requests?",
    answer: "No. This tool is a code generator only. It builds syntactically correct curl, fetch, and axios snippets based on your inputs — nothing is sent to any server. Copy the generated code and run it in your terminal or application."
  },
  {
    question: "How do I add authentication headers?",
    answer: "Add an Authorization header with your token value (e.g. 'Bearer your-token-here' for JWT/OAuth2, or 'Basic base64(user:pass)' for Basic auth). For API keys, common header names include X-API-Key, x-api-key, or the service-specific header like x-auth-token."
  },
  {
    question: "What body format should I use for POST requests?",
    answer: "For JSON APIs (most REST APIs), set Content-Type: application/json and provide a JSON object as the body. For form submissions, use Content-Type: application/x-www-form-urlencoded with key=value&key2=value2 format. The tool generates the correct curl -d and fetch body handling for both."
  },
  {
    question: "What is the difference between PUT and PATCH?",
    answer: "PUT replaces the entire resource — you must send all fields, even unchanged ones. PATCH applies a partial update — send only the fields you want to change. Use PATCH for efficiency when updating a few fields of a large resource. Most REST APIs support both, but prefer PATCH for partial updates."
  },
  {
    question: "How do I handle multipart form data file uploads?",
    answer: "For file uploads, set the method to POST and use Content-Type: multipart/form-data. The generated curl snippet will use -F 'file=@/path/to/file' syntax. For fetch, use a FormData object: const fd = new FormData(); fd.append('file', fileInput.files[0]); fetch(url, { method: 'POST', body: fd })."
  },
];
---

<BaseLayout
  title="REST API Request Builder — Generate curl, fetch & axios Code Snippets"
  description="Build HTTP requests visually and generate ready-to-use curl, fetch, and axios code snippets. Add headers, set method and body, copy the output. Free, runs entirely in your browser."
  tool="REST API Request Builder, curl generator, fetch code generator, axios snippet, HTTP request builder, API testing tool"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "REST API Request Builder",
    "url": "https://devplaybook.cc/tools/rest-api-builder",
    "description": "Build HTTP requests visually and generate ready-to-use curl, fetch, and axios code snippets. Free, runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">REST API Request Builder</h1>
  <p class="text-text-muted mb-4">
    Configure your HTTP request visually — method, URL, headers, and body — then get ready-to-copy <code class="font-mono bg-surface px-1 rounded text-sm">curl</code>, <code class="font-mono bg-surface px-1 rounded text-sm">fetch</code>, and <code class="font-mono bg-surface px-1 rounded text-sm">axios</code> code snippets instantly. Nothing is sent to any server.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> curl / fetch / axios output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Custom headers & body</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <RestApiBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="REST API Request Builder" relatedTags={['api', 'http', 'curl', 'fetch', 'axios', 'rest', 'developer-tools']} />
</BaseLayout>
