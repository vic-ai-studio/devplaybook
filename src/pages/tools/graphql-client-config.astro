---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "Which GraphQL client should I use?", answer: "Apollo Client is the most feature-rich: caching, local state, subscriptions, DevTools. Best for complex apps. urql is lighter, more composable, and excellent for Next.js/RSC. graphql-request is minimal — just sends requests, no cache. Use Apollo for enterprise apps, urql for modern React/Next.js, graphql-request for simple scripts or server-side fetching." },
  { question: "What is the Apollo InMemoryCache?", answer: "InMemoryCache is Apollo's normalized cache. It stores query results by type and ID (e.g., Todo:1, User:42). When a mutation updates an object, any query containing that object automatically updates — no manual cache management needed. Configure typePolicies to control how objects are identified and merged." },
  { question: "What are Apollo cache policies?", answer: "cache-first (default): read from cache, only fetch if missing. network-only: always fetch, write to cache. cache-only: never fetch, throw if missing. no-cache: always fetch, never write. cache-and-network: return cache immediately, then update from network. Use cache-and-network for data that should feel instant but stay fresh." },
  { question: "How does urql handle caching differently?", answer: "urql uses exchanges (middleware-like composable layers). The default Document Cache caches by query + variables hash — simple but effective. The Normalized Cache (from @urql/exchange-graphcache) works like Apollo's InMemoryCache with entity normalization. The key difference: urql's architecture lets you swap or compose caching strategies without changing your components." },
  { question: "What is graphql-request best for?", answer: "graphql-request is a minimal GraphQL client (~2KB) with zero configuration. It's perfect for: server-side data fetching in Next.js, scripts, CLI tools, or any scenario where you want to send a GraphQL query without managing a cache. It pairs well with TanStack Query or SWR — you use graphql-request as the fetcher function." },
  { question: "How do I handle authentication headers in GraphQL clients?", answer: "Apollo: pass headers in the authLink using setContext. urql: use fetchOptions to return dynamic headers. graphql-request: pass headers directly to the GraphQLClient constructor or per-request. For all clients, read the auth token from localStorage/cookies in the header function — never hardcode tokens in source code." },
];
---

<BaseLayout
  title="GraphQL Client Configurator — Apollo Client, urql, graphql-request Setup Generator"
  description="Generate GraphQL client configuration code. Choose Apollo Client, urql, or graphql-request. Configure caching, authentication, error handling, and subscriptions. TypeScript ready."
  tool="GraphQL Client Configurator, Apollo Client Setup Generator, urql Configuration Builder, graphql-request TypeScript Setup, GraphQL Authentication Headers"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">GraphQL Client Configurator</h1>
  <p class="text-text-muted mb-4">Choose your GraphQL client and configure it visually. Generate production-ready TypeScript setup code for Apollo Client, urql, or graphql-request with auth, error handling, and caching.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Apollo / urql / graphql-request</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auth headers builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Cache policy configurator</span>
  </div>

  <!-- Client Selector -->
  <div class="flex gap-3 mb-5">
    <button data-client="apollo" class="client-btn flex-1 border-2 rounded-xl p-4 text-center transition-all border-primary bg-primary/5">
      <div class="font-bold text-sm">Apollo Client</div>
      <div class="text-xs text-text-muted mt-1">Full-featured, normalized cache</div>
    </button>
    <button data-client="urql" class="client-btn flex-1 border-2 rounded-xl p-4 text-center transition-all border-border">
      <div class="font-bold text-sm">urql</div>
      <div class="text-xs text-text-muted mt-1">Lightweight, composable exchanges</div>
    </button>
    <button data-client="gql-request" class="client-btn flex-1 border-2 rounded-xl p-4 text-center transition-all border-border">
      <div class="font-bold text-sm">graphql-request</div>
      <div class="text-xs text-text-muted mt-1">Minimal, no cache, perfect for SSR</div>
    </button>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-5">
    <!-- Config Panel -->
    <div class="space-y-4">
      <!-- Connection -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Connection</h2>
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium mb-1">GraphQL Endpoint</label>
            <input id="endpoint" type="text" value="https://api.example.com/graphql"
              class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
          </div>
          <div id="ws-section">
            <label class="flex items-center gap-2 text-sm cursor-pointer">
              <input type="checkbox" id="use-ws" class="rounded" />
              <span>Enable WebSocket Subscriptions</span>
            </label>
            <input id="ws-endpoint" type="text" value="wss://api.example.com/graphql" placeholder="wss://endpoint"
              class="w-full mt-2 bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary hidden" />
          </div>
        </div>
      </div>

      <!-- Authentication -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Authentication</h2>
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium mb-1">Auth Strategy</label>
            <select id="auth-strategy" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="none">None</option>
              <option value="bearer" selected>Bearer Token (localStorage)</option>
              <option value="cookie">HTTP-only Cookie</option>
              <option value="apikey">API Key Header</option>
            </select>
          </div>
          <div id="auth-header-name-row">
            <label class="block text-sm font-medium mb-1">Header Name</label>
            <input id="auth-header-name" type="text" value="Authorization"
              class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
          </div>
        </div>
      </div>

      <!-- Cache & Error (Apollo/urql only) -->
      <div id="cache-section" class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Cache & Error Handling</h2>
        <div class="space-y-3">
          <div id="cache-policy-row">
            <label class="block text-sm font-medium mb-1">Default Cache Policy</label>
            <select id="cache-policy" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="cache-first" selected>cache-first (default)</option>
              <option value="cache-and-network">cache-and-network</option>
              <option value="network-only">network-only</option>
              <option value="no-cache">no-cache</option>
              <option value="cache-only">cache-only</option>
            </select>
          </div>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="error-link" checked class="rounded" />
            <span>Error handling link (log + toast on error)</span>
          </label>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="retry-link" class="rounded" />
            <span>Retry link (auto-retry on network error)</span>
          </label>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="devtools" class="rounded" />
            <span>Apollo DevTools (connectToDevTools)</span>
          </label>
        </div>
      </div>
    </div>

    <!-- Code Output -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-base font-semibold">Generated Code</h2>
        <button id="copy-btn" class="text-xs bg-primary/10 text-primary border border-primary/30 rounded-lg px-3 py-1.5 hover:bg-primary/20 transition-colors">Copy</button>
      </div>
      <pre id="code-output" class="text-xs font-mono bg-bg-card border border-border rounded-lg p-4 overflow-auto max-h-[600px] whitespace-pre-wrap text-text-muted"></pre>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="GraphQL Client Configurator" relatedTags={['graphql', 'apollo', 'react', 'typescript', 'data-fetching']} />
</BaseLayout>

<script>
  let activeClient = 'apollo';

  function getVal(id: string): string {
    const el = document.getElementById(id);
    if (!el) return '';
    return (el as HTMLInputElement | HTMLSelectElement).value;
  }
  function getBool(id: string): boolean {
    const el = document.getElementById(id);
    return el ? (el as HTMLInputElement).checked : false;
  }

  function generateApollo(): string {
    const endpoint = getVal('endpoint') || 'https://api.example.com/graphql';
    const auth = getVal('auth-strategy');
    const headerName = getVal('auth-header-name') || 'Authorization';
    const cachePolicy = getVal('cache-policy');
    const useWs = getBool('use-ws');
    const wsEndpoint = getVal('ws-endpoint') || 'wss://api.example.com/graphql';
    const useError = getBool('error-link');
    const useRetry = getBool('retry-link');
    const useDevtools = getBool('devtools');

    const imports = [`import { ApolloClient, InMemoryCache, createHttpLink, from } from '@apollo/client';`];
    if (auth !== 'none') imports.push(`import { setContext } from '@apollo/client/link/context';`);
    if (useError) imports.push(`import { onError } from '@apollo/client/link/error';`);
    if (useRetry) imports.push(`import { RetryLink } from '@apollo/client/link/retry';`);
    if (useWs) imports.push(`import { GraphQLWsLink } from '@apollo/client/link/subscriptions';`, `import { createClient } from 'graphql-ws';`, `import { getMainDefinition } from '@apollo/client/utilities';`, `import { split } from '@apollo/client';`);

    let authCode = '';
    if (auth === 'bearer') {
      authCode = `\nconst authLink = setContext((_, { headers }) => {
  const token = localStorage.getItem('auth_token');
  return {
    headers: {
      ...headers,
      ${headerName}: token ? \`Bearer \${token}\` : '',
    },
  };
});`;
    } else if (auth === 'apikey') {
      authCode = `\nconst authLink = setContext((_, { headers }) => ({
  headers: { ...headers, '${headerName}': process.env.NEXT_PUBLIC_API_KEY || '' },
}));`;
    }

    let errorCode = '';
    if (useError) {
      errorCode = `\nconst errorLink = onError(({ graphQLErrors, networkError }) => {
  if (graphQLErrors) graphQLErrors.forEach(({ message, locations, path }) =>
    console.error(\`[GraphQL error]: \${message}\`, { locations, path })
  );
  if (networkError) console.error('[Network error]:', networkError);
});`;
    }

    let retryCode = '';
    if (useRetry) {
      retryCode = `\nconst retryLink = new RetryLink({
  delay: { initial: 300, max: 3000, jitter: true },
  attempts: { max: 3, retryIf: (error) => !!error.networkError },
});`;
    }

    const httpLink = `const httpLink = createHttpLink({ uri: '${endpoint}' });`;

    let wsCode = '';
    let splitCode = '';
    if (useWs) {
      wsCode = `\nconst wsLink = new GraphQLWsLink(createClient({ url: '${wsEndpoint}' }));`;
      splitCode = `\nconst splitLink = split(
  ({ query }) => {
    const def = getMainDefinition(query);
    return def.kind === 'OperationDefinition' && def.operation === 'subscription';
  },
  wsLink,
  httpLink,
);`;
    }

    const links: string[] = [];
    if (useError) links.push('errorLink');
    if (useRetry) links.push('retryLink');
    if (auth !== 'none' && auth !== 'cookie') links.push('authLink');
    links.push(useWs ? 'splitLink' : 'httpLink');

    const clientCode = `\nexport const client = new ApolloClient({
  link: from([${links.join(', ')}]),
  cache: new InMemoryCache(),
  defaultOptions: {
    watchQuery: { fetchPolicy: '${cachePolicy}' },
    query: { fetchPolicy: '${cachePolicy}' },
  },${useDevtools ? '\n  connectToDevTools: true,' : ''}
});`;

    return [imports.join('\n'), '', httpLink, authCode, errorCode, retryCode, wsCode, splitCode, clientCode].filter(Boolean).join('\n');
  }

  function generateUrql(): string {
    const endpoint = getVal('endpoint');
    const auth = getVal('auth-strategy');
    const headerName = getVal('auth-header-name');
    const useError = getBool('error-link');

    let authOption = '';
    if (auth === 'bearer') {
      authOption = `  fetchOptions: () => {
    const token = localStorage.getItem('auth_token');
    return { headers: { ${headerName}: token ? \`Bearer \${token}\` : '' } };
  },`;
    } else if (auth === 'apikey') {
      authOption = `  fetchOptions: { headers: { '${headerName}': process.env.NEXT_PUBLIC_API_KEY || '' } },`;
    }

    return `import { createClient, cacheExchange, fetchExchange${useError ? ', mapExchange' : ''} } from 'urql';

${useError ? `const errorExchange = mapExchange({
  onError: (error) => {
    console.error('[urql error]:', error.message);
  },
});

` : ''}export const client = createClient({
  url: '${endpoint}',
${authOption}
  exchanges: [
    cacheExchange,
${useError ? '    errorExchange,\n' : ''}    fetchExchange,
  ],
});

// For Next.js App Router (SSR):
// import { registerUrql } from '@urql/next/rsc';
// export const { getClient } = registerUrql(() => createClient({ url: '${endpoint}' }));

// React usage:
import { Provider, useQuery, useMutation } from 'urql';

function App() {
  return <Provider value={client}><YourApp /></Provider>;
}

// Query hook
const TODOS_QUERY = \`
  query GetTodos {
    todos { id title completed }
  }
\`;

function TodoList() {
  const [{ data, fetching, error }] = useQuery({ query: TODOS_QUERY });
  if (fetching) return <div>Loading...</div>;
  if (error) return <div>Error: {error.message}</div>;
  return <ul>{data?.todos.map(t => <li key={t.id}>{t.title}</li>)}</ul>;
}`;
  }

  function generateGqlRequest(): string {
    const endpoint = getVal('endpoint');
    const auth = getVal('auth-strategy');
    const headerName = getVal('auth-header-name');

    let headerCode = '';
    if (auth === 'bearer') {
      headerCode = `  ${headerName}: \`Bearer \${localStorage.getItem('auth_token') || ''}\`,`;
    } else if (auth === 'apikey') {
      headerCode = `  '${headerName}': process.env.NEXT_PUBLIC_API_KEY || '',`;
    } else if (auth === 'cookie') {
      headerCode = `  // Cookies sent automatically with credentials: 'include'`;
    }

    return `import { GraphQLClient, gql } from 'graphql-request';

// Create a reusable client instance
export const gqlClient = new GraphQLClient('${endpoint}', {
  headers: {
${headerCode}
  },${auth === 'cookie' ? "\n  credentials: 'include'," : ''}
});

// Define queries with gql tag (enables syntax highlighting + type-gen)
const GET_TODOS = gql\`
  query GetTodos($userId: ID!) {
    todos(userId: $userId) {
      id
      title
      completed
    }
  }
\`;

// TypeScript with codegen types
interface Todo { id: string; title: string; completed: boolean; }
interface GetTodosQuery { todos: Todo[]; }
interface GetTodosVariables { userId: string; }

// Usage: direct call (works great with TanStack Query or SWR)
export async function getTodos(userId: string): Promise<Todo[]> {
  const data = await gqlClient.request<GetTodosQuery, GetTodosVariables>(
    GET_TODOS,
    { userId }
  );
  return data.todos;
}

// Combine with TanStack Query:
import { useQuery } from '@tanstack/react-query';

export function useTodos(userId: string) {
  return useQuery({
    queryKey: ['todos', userId],
    queryFn: () => getTodos(userId),
  });
}`;
  }

  function generateCode(): string {
    switch (activeClient) {
      case 'apollo': return generateApollo();
      case 'urql': return generateUrql();
      case 'gql-request': return generateGqlRequest();
      default: return '';
    }
  }

  function update() {
    document.getElementById('code-output')!.textContent = generateCode();

    // Toggle ws endpoint visibility
    const wsInput = document.getElementById('ws-endpoint')!;
    wsInput.classList.toggle('hidden', !getBool('use-ws'));

    // Hide Apollo-specific options for other clients
    const cacheSection = document.getElementById('cache-section')!;
    cacheSection.style.display = activeClient === 'gql-request' ? 'none' : '';
  }

  document.querySelectorAll('.client-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      activeClient = btn.getAttribute('data-client')!;
      document.querySelectorAll('.client-btn').forEach(b => {
        b.classList.remove('border-primary', 'bg-primary/5');
        b.classList.add('border-border');
      });
      btn.classList.add('border-primary', 'bg-primary/5');
      btn.classList.remove('border-border');
      update();
    });
  });

  document.querySelectorAll('input, select').forEach(el => {
    el.addEventListener('input', update);
    el.addEventListener('change', update);
  });

  document.getElementById('copy-btn')!.addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('code-output')!.textContent || '');
    const btn = document.getElementById('copy-btn')!;
    btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = 'Copy', 1500);
  });

  update();
</script>
