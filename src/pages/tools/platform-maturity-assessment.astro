---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What are the 5 dimensions of platform engineering maturity?",
    answer: "Developer Experience (DX): How well the platform reduces cognitive load and friction for product engineers. Automation: How much of the software delivery lifecycle is automated — builds, tests, deployments, rollbacks. Observability: How well teams can understand what their systems are doing in production (metrics, logs, traces, alerting). Security: How early and consistently security controls are applied across the platform. Self-Service: How much teams can provision infrastructure, environments, and services without opening tickets or waiting for platform team help."
  },
  {
    question: "What do the 4 maturity levels mean?",
    answer: "Level 1 — Reactive: Platform engineering is ad-hoc. Individuals heroically solve problems but there is no standardization. Level 2 — Repeatable: Core practices exist and are documented but adoption is inconsistent. Level 3 — Scalable: Practices are standardized, enforced, and adopted across most teams. Platform team focuses on enablement. Level 4 — Optimizing: Continuous improvement loops, data-driven decision making, and developer experience metrics drive all platform investments."
  },
  {
    question: "How often should I run this assessment?",
    answer: "Run the assessment at the start of each quarter to track progress, before and after major platform initiatives to measure impact, and when onboarding new leadership to establish a baseline. Share results with your engineering leaders to align on investment priorities. A good target cadence is quarterly with a full team retrospective twice a year."
  },
  {
    question: "What should I do after getting my score?",
    answer: "Focus on the top 3 recommendations shown after the assessment. Each recommendation targets your lowest-scoring dimensions. Start with one concrete initiative per quarter — trying to improve all dimensions simultaneously rarely works. Common first steps: if DX is weak, start a developer satisfaction survey and internal developer portal; if Automation is weak, standardize your CI pipeline with a golden path template; if Security is weak, implement SAST in your default CI workflow."
  },
  {
    question: "How does the radar chart work?",
    answer: "The radar (spider) chart shows your score for each of the 5 dimensions on a 0–3 scale (matching the Not Started / Basic / Intermediate / Advanced radio options). Each axis represents one dimension. A perfectly balanced, fully filled pentagon means Advanced on all dimensions. Gaps in the chart reveal which dimensions lag behind. The chart is drawn with SVG and updates in real-time as you answer questions — no external libraries required."
  }
];
---

<BaseLayout
  title="Platform Engineering Maturity Assessment — Score Your Platform Across 5 Dimensions"
  description="Assess your platform engineering maturity across Developer Experience, Automation, Observability, Security, and Self-Service. Get a radar chart, maturity level (1–4), and top 3 improvement recommendations."
  tool="platform engineering maturity, platform maturity model, developer experience assessment, DORA metrics, platform team assessment, DevOps maturity"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Platform Engineering Maturity Assessment",
    "url": "https://devplaybook.cc/tools/platform-maturity-assessment",
    "description": "Score your platform engineering maturity across 5 dimensions with a radar chart and improvement recommendations. Free, runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Platform Engineering Maturity Assessment</h1>
  <p class="text-text-muted mb-4">Answer 20 questions across 5 dimensions to score your platform maturity. Get a radar chart, an overall level (1–4), and targeted improvement recommendations for your weakest areas.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 dimensions, 20 questions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> SVG radar chart — no external libs</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Level 1–4: Reactive → Optimizing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Top 3 recommendations</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 mb-8">

    <!-- Questions panel -->
    <div class="lg:col-span-3 space-y-6" id="questions-panel">

      <!-- Dimension 1: Developer Experience -->
      <div class="bg-bg-card border border-border rounded-lg p-5" data-dim="dx">
        <h2 class="text-base font-semibold mb-4 flex items-center gap-2">
          <span class="w-7 h-7 rounded-full bg-violet-500/20 text-violet-400 text-xs font-bold flex items-center justify-center">DX</span>
          Developer Experience
        </h2>
        <div class="space-y-5">
          <div class="q-group">
            <p class="text-sm mb-2">How easy is it for a new engineer to go from zero to first deployment?</p>
            <div class="flex flex-wrap gap-3">
              <label class="radio-opt"><input type="radio" name="dx_q1" value="0" class="mr-1.5 accent-primary" /> <span class="text-xs">Not started</span></label>
              <label class="radio-opt"><input type="radio" name="dx_q1" value="1" class="mr-1.5 accent-primary" /> <span class="text-xs">Basic</span></label>
              <label class="radio-opt"><input type="radio" name="dx_q1" value="2" class="mr-1.5 accent-primary" /> <span class="text-xs">Intermediate</span></label>
              <label class="radio-opt"><input type="radio" name="dx_q1" value="3" class="mr-1.5 accent-primary" /> <span class="text-xs">Advanced</span></label>
            </div>
          </div>
          <div class="q-group">
            <p class="text-sm mb-2">Is there a central Internal Developer Portal (catalog, docs, self-service)?</p>
            <div class="flex flex-wrap gap-3">
              <label class="radio-opt"><input type="radio" name="dx_q2" value="0" class="mr-1.5 accent-primary" /> <span class="text-xs">Not started</span></label>
              <label class="radio-opt"><input type="radio" name="dx_q2" value="1" class="mr-1.5 accent-primary" /> <span class="text-xs">Basic</span></label>
              <label class="radio-opt"><input type="radio" name="dx_q2" value="2" class="mr-1.5 accent-primary" /> <span class="text-xs">Intermediate</span></label>
              <label class="radio-opt"><input type="radio" name="dx_q2" value="3" class="mr-1.5 accent-primary" /> <span class="text-xs">Advanced</span></label>
            </div>
          </div>
          <div class="q-group">
            <p class="text-sm mb-2">How consistently are Golden Path templates adopted across teams?</p>
            <div class="flex flex-wrap gap-3">
              <label class="radio-opt"><input type="radio" name="dx_q3" value="0" class="mr-1.5 accent-primary" /> <span class="text-xs">Not started</span></label>
              <label class="radio-opt"><input type="radio" name="dx_q3" value="1" class="mr-1.5 accent-primary" /> <span class="text-xs">Basic</span></label>
              <label class="radio-opt"><input type="radio" name="dx_q3" value="2" class="mr-1.5 accent-primary" /> <span class="text-xs">Intermediate</span></label>
              <label class="radio-opt"><input type="radio" name="dx_q3" value="3" class="mr-1.5 accent-primary" /> <span class="text-xs">Advanced</span></label>
            </div>
          </div>
          <div class="q-group">
            <p class="text-sm mb-2">Is developer satisfaction (DX NPS or similar) measured and acted on?</p>
            <div class="flex flex-wrap gap-3">
              <label class="radio-opt"><input type="radio" name="dx_q4" value="0" class="mr-1.5 accent-primary" /> <span class="text-xs">Not started</span></label>
              <label class="radio-opt"><input type="radio" name="dx_q4" value="1" class="mr-1.5 accent-primary" /> <span class="text-xs">Basic</span></label>
              <label class="radio-opt"><input type="radio" name="dx_q4" value="2" class="mr-1.5 accent-primary" /> <span class="text-xs">Intermediate</span></label>
              <label class="radio-opt"><input type="radio" name="dx_q4" value="3" class="mr-1.5 accent-primary" /> <span class="text-xs">Advanced</span></label>
            </div>
          </div>
        </div>
      </div>

      <!-- Dimension 2: Automation -->
      <div class="bg-bg-card border border-border rounded-lg p-5" data-dim="auto">
        <h2 class="text-base font-semibold mb-4 flex items-center gap-2">
          <span class="w-7 h-7 rounded-full bg-blue-500/20 text-blue-400 text-xs font-bold flex items-center justify-center">AU</span>
          Automation
        </h2>
        <div class="space-y-5">
          <div class="q-group">
            <p class="text-sm mb-2">How mature is your CI/CD pipeline (test coverage, gates, speed)?</p>
            <div class="flex flex-wrap gap-3">
              <label class="radio-opt"><input type="radio" name="auto_q1" value="0" class="mr-1.5 accent-primary" /> <span class="text-xs">Not started</span></label>
              <label class="radio-opt"><input type="radio" name="auto_q1" value="1" class="mr-1.5 accent-primary" /> <span class="text-xs">Basic</span></label>
              <label class="radio-opt"><input type="radio" name="auto_q1" value="2" class="mr-1.5 accent-primary" /> <span class="text-xs">Intermediate</span></label>
              <label class="radio-opt"><input type="radio" name="auto_q1" value="3" class="mr-1.5 accent-primary" /> <span class="text-xs">Advanced</span></label>
            </div>
          </div>
          <div class="q-group">
            <p class="text-sm mb-2">How automated is infrastructure provisioning (IaC coverage)?</p>
            <div class="flex flex-wrap gap-3">
              <label class="radio-opt"><input type="radio" name="auto_q2" value="0" class="mr-1.5 accent-primary" /> <span class="text-xs">Not started</span></label>
              <label class="radio-opt"><input type="radio" name="auto_q2" value="1" class="mr-1.5 accent-primary" /> <span class="text-xs">Basic</span></label>
              <label class="radio-opt"><input type="radio" name="auto_q2" value="2" class="mr-1.5 accent-primary" /> <span class="text-xs">Intermediate</span></label>
              <label class="radio-opt"><input type="radio" name="auto_q2" value="3" class="mr-1.5 accent-primary" /> <span class="text-xs">Advanced</span></label>
            </div>
          </div>
          <div class="q-group">
            <p class="text-sm mb-2">How reliably can you perform rollback without manual steps?</p>
            <div class="flex flex-wrap gap-3">
              <label class="radio-opt"><input type="radio" name="auto_q3" value="0" class="mr-1.5 accent-primary" /> <span class="text-xs">Not started</span></label>
              <label class="radio-opt"><input type="radio" name="auto_q3" value="1" class="mr-1.5 accent-primary" /> <span class="text-xs">Basic</span></label>
              <label class="radio-opt"><input type="radio" name="auto_q3" value="2" class="mr-1.5 accent-primary" /> <span class="text-xs">Intermediate</span></label>
              <label class="radio-opt"><input type="radio" name="auto_q3" value="3" class="mr-1.5 accent-primary" /> <span class="text-xs">Advanced</span></label>
            </div>
          </div>
          <div class="q-group">
            <p class="text-sm mb-2">Are database migrations and config changes automated in the pipeline?</p>
            <div class="flex flex-wrap gap-3">
              <label class="radio-opt"><input type="radio" name="auto_q4" value="0" class="mr-1.5 accent-primary" /> <span class="text-xs">Not started</span></label>
              <label class="radio-opt"><input type="radio" name="auto_q4" value="1" class="mr-1.5 accent-primary" /> <span class="text-xs">Basic</span></label>
              <label class="radio-opt"><input type="radio" name="auto_q4" value="2" class="mr-1.5 accent-primary" /> <span class="text-xs">Intermediate</span></label>
              <label class="radio-opt"><input type="radio" name="auto_q4" value="3" class="mr-1.5 accent-primary" /> <span class="text-xs">Advanced</span></label>
            </div>
          </div>
        </div>
      </div>

      <!-- Dimension 3: Observability -->
      <div class="bg-bg-card border border-border rounded-lg p-5" data-dim="obs">
        <h2 class="text-base font-semibold mb-4 flex items-center gap-2">
          <span class="w-7 h-7 rounded-full bg-emerald-500/20 text-emerald-400 text-xs font-bold flex items-center justify-center">OB</span>
          Observability
        </h2>
        <div class="space-y-5">
          <div class="q-group">
            <p class="text-sm mb-2">Do all production services emit metrics, structured logs, and traces?</p>
            <div class="flex flex-wrap gap-3">
              <label class="radio-opt"><input type="radio" name="obs_q1" value="0" class="mr-1.5 accent-primary" /> <span class="text-xs">Not started</span></label>
              <label class="radio-opt"><input type="radio" name="obs_q1" value="1" class="mr-1.5 accent-primary" /> <span class="text-xs">Basic</span></label>
              <label class="radio-opt"><input type="radio" name="obs_q1" value="2" class="mr-1.5 accent-primary" /> <span class="text-xs">Intermediate</span></label>
              <label class="radio-opt"><input type="radio" name="obs_q1" value="3" class="mr-1.5 accent-primary" /> <span class="text-xs">Advanced</span></label>
            </div>
          </div>
          <div class="q-group">
            <p class="text-sm mb-2">Are SLOs defined and error budgets actively tracked per service?</p>
            <div class="flex flex-wrap gap-3">
              <label class="radio-opt"><input type="radio" name="obs_q2" value="0" class="mr-1.5 accent-primary" /> <span class="text-xs">Not started</span></label>
              <label class="radio-opt"><input type="radio" name="obs_q2" value="1" class="mr-1.5 accent-primary" /> <span class="text-xs">Basic</span></label>
              <label class="radio-opt"><input type="radio" name="obs_q2" value="2" class="mr-1.5 accent-primary" /> <span class="text-xs">Intermediate</span></label>
              <label class="radio-opt"><input type="radio" name="obs_q2" value="3" class="mr-1.5 accent-primary" /> <span class="text-xs">Advanced</span></label>
            </div>
          </div>
          <div class="q-group">
            <p class="text-sm mb-2">How fast can you detect and diagnose a P1 incident end-to-end?</p>
            <div class="flex flex-wrap gap-3">
              <label class="radio-opt"><input type="radio" name="obs_q3" value="0" class="mr-1.5 accent-primary" /> <span class="text-xs">Not started</span></label>
              <label class="radio-opt"><input type="radio" name="obs_q3" value="1" class="mr-1.5 accent-primary" /> <span class="text-xs">Basic</span></label>
              <label class="radio-opt"><input type="radio" name="obs_q3" value="2" class="mr-1.5 accent-primary" /> <span class="text-xs">Intermediate</span></label>
              <label class="radio-opt"><input type="radio" name="obs_q3" value="3" class="mr-1.5 accent-primary" /> <span class="text-xs">Advanced</span></label>
            </div>
          </div>
          <div class="q-group">
            <p class="text-sm mb-2">Is alerting actionable (low noise, clear ownership, runbooks linked)?</p>
            <div class="flex flex-wrap gap-3">
              <label class="radio-opt"><input type="radio" name="obs_q4" value="0" class="mr-1.5 accent-primary" /> <span class="text-xs">Not started</span></label>
              <label class="radio-opt"><input type="radio" name="obs_q4" value="1" class="mr-1.5 accent-primary" /> <span class="text-xs">Basic</span></label>
              <label class="radio-opt"><input type="radio" name="obs_q4" value="2" class="mr-1.5 accent-primary" /> <span class="text-xs">Intermediate</span></label>
              <label class="radio-opt"><input type="radio" name="obs_q4" value="3" class="mr-1.5 accent-primary" /> <span class="text-xs">Advanced</span></label>
            </div>
          </div>
        </div>
      </div>

      <!-- Dimension 4: Security -->
      <div class="bg-bg-card border border-border rounded-lg p-5" data-dim="sec">
        <h2 class="text-base font-semibold mb-4 flex items-center gap-2">
          <span class="w-7 h-7 rounded-full bg-orange-500/20 text-orange-400 text-xs font-bold flex items-center justify-center">SE</span>
          Security
        </h2>
        <div class="space-y-5">
          <div class="q-group">
            <p class="text-sm mb-2">Is SAST / dependency scanning integrated in the default CI pipeline?</p>
            <div class="flex flex-wrap gap-3">
              <label class="radio-opt"><input type="radio" name="sec_q1" value="0" class="mr-1.5 accent-primary" /> <span class="text-xs">Not started</span></label>
              <label class="radio-opt"><input type="radio" name="sec_q1" value="1" class="mr-1.5 accent-primary" /> <span class="text-xs">Basic</span></label>
              <label class="radio-opt"><input type="radio" name="sec_q1" value="2" class="mr-1.5 accent-primary" /> <span class="text-xs">Intermediate</span></label>
              <label class="radio-opt"><input type="radio" name="sec_q1" value="3" class="mr-1.5 accent-primary" /> <span class="text-xs">Advanced</span></label>
            </div>
          </div>
          <div class="q-group">
            <p class="text-sm mb-2">How consistently are secrets managed via a vault / secret manager (no plain-text secrets)?</p>
            <div class="flex flex-wrap gap-3">
              <label class="radio-opt"><input type="radio" name="sec_q2" value="0" class="mr-1.5 accent-primary" /> <span class="text-xs">Not started</span></label>
              <label class="radio-opt"><input type="radio" name="sec_q2" value="1" class="mr-1.5 accent-primary" /> <span class="text-xs">Basic</span></label>
              <label class="radio-opt"><input type="radio" name="sec_q2" value="2" class="mr-1.5 accent-primary" /> <span class="text-xs">Intermediate</span></label>
              <label class="radio-opt"><input type="radio" name="sec_q2" value="3" class="mr-1.5 accent-primary" /> <span class="text-xs">Advanced</span></label>
            </div>
          </div>
          <div class="q-group">
            <p class="text-sm mb-2">Is RBAC enforced across platform tooling (IDP, CI/CD, cloud console)?</p>
            <div class="flex flex-wrap gap-3">
              <label class="radio-opt"><input type="radio" name="sec_q3" value="0" class="mr-1.5 accent-primary" /> <span class="text-xs">Not started</span></label>
              <label class="radio-opt"><input type="radio" name="sec_q3" value="1" class="mr-1.5 accent-primary" /> <span class="text-xs">Basic</span></label>
              <label class="radio-opt"><input type="radio" name="sec_q3" value="2" class="mr-1.5 accent-primary" /> <span class="text-xs">Intermediate</span></label>
              <label class="radio-opt"><input type="radio" name="sec_q3" value="3" class="mr-1.5 accent-primary" /> <span class="text-xs">Advanced</span></label>
            </div>
          </div>
          <div class="q-group">
            <p class="text-sm mb-2">Are container images scanned for CVEs before production deployment?</p>
            <div class="flex flex-wrap gap-3">
              <label class="radio-opt"><input type="radio" name="sec_q4" value="0" class="mr-1.5 accent-primary" /> <span class="text-xs">Not started</span></label>
              <label class="radio-opt"><input type="radio" name="sec_q4" value="1" class="mr-1.5 accent-primary" /> <span class="text-xs">Basic</span></label>
              <label class="radio-opt"><input type="radio" name="sec_q4" value="2" class="mr-1.5 accent-primary" /> <span class="text-xs">Intermediate</span></label>
              <label class="radio-opt"><input type="radio" name="sec_q4" value="3" class="mr-1.5 accent-primary" /> <span class="text-xs">Advanced</span></label>
            </div>
          </div>
        </div>
      </div>

      <!-- Dimension 5: Self-Service -->
      <div class="bg-bg-card border border-border rounded-lg p-5" data-dim="ss">
        <h2 class="text-base font-semibold mb-4 flex items-center gap-2">
          <span class="w-7 h-7 rounded-full bg-rose-500/20 text-rose-400 text-xs font-bold flex items-center justify-center">SS</span>
          Self-Service
        </h2>
        <div class="space-y-5">
          <div class="q-group">
            <p class="text-sm mb-2">Can engineers create a new service without filing a ticket (scaffolding, repo, CI/CD)?</p>
            <div class="flex flex-wrap gap-3">
              <label class="radio-opt"><input type="radio" name="ss_q1" value="0" class="mr-1.5 accent-primary" /> <span class="text-xs">Not started</span></label>
              <label class="radio-opt"><input type="radio" name="ss_q1" value="1" class="mr-1.5 accent-primary" /> <span class="text-xs">Basic</span></label>
              <label class="radio-opt"><input type="radio" name="ss_q1" value="2" class="mr-1.5 accent-primary" /> <span class="text-xs">Intermediate</span></label>
              <label class="radio-opt"><input type="radio" name="ss_q1" value="3" class="mr-1.5 accent-primary" /> <span class="text-xs">Advanced</span></label>
            </div>
          </div>
          <div class="q-group">
            <p class="text-sm mb-2">Can engineers spin up a dev or staging environment on demand?</p>
            <div class="flex flex-wrap gap-3">
              <label class="radio-opt"><input type="radio" name="ss_q2" value="0" class="mr-1.5 accent-primary" /> <span class="text-xs">Not started</span></label>
              <label class="radio-opt"><input type="radio" name="ss_q2" value="1" class="mr-1.5 accent-primary" /> <span class="text-xs">Basic</span></label>
              <label class="radio-opt"><input type="radio" name="ss_q2" value="2" class="mr-1.5 accent-primary" /> <span class="text-xs">Intermediate</span></label>
              <label class="radio-opt"><input type="radio" name="ss_q2" value="3" class="mr-1.5 accent-primary" /> <span class="text-xs">Advanced</span></label>
            </div>
          </div>
          <div class="q-group">
            <p class="text-sm mb-2">Can engineers request and rotate secrets without platform team involvement?</p>
            <div class="flex flex-wrap gap-3">
              <label class="radio-opt"><input type="radio" name="ss_q3" value="0" class="mr-1.5 accent-primary" /> <span class="text-xs">Not started</span></label>
              <label class="radio-opt"><input type="radio" name="ss_q3" value="1" class="mr-1.5 accent-primary" /> <span class="text-xs">Basic</span></label>
              <label class="radio-opt"><input type="radio" name="ss_q3" value="2" class="mr-1.5 accent-primary" /> <span class="text-xs">Intermediate</span></label>
              <label class="radio-opt"><input type="radio" name="ss_q3" value="3" class="mr-1.5 accent-primary" /> <span class="text-xs">Advanced</span></label>
            </div>
          </div>
          <div class="q-group">
            <p class="text-sm mb-2">What percentage of platform features are available as self-service APIs or UI actions?</p>
            <div class="flex flex-wrap gap-3">
              <label class="radio-opt"><input type="radio" name="ss_q4" value="0" class="mr-1.5 accent-primary" /> <span class="text-xs">Not started</span></label>
              <label class="radio-opt"><input type="radio" name="ss_q4" value="1" class="mr-1.5 accent-primary" /> <span class="text-xs">Basic</span></label>
              <label class="radio-opt"><input type="radio" name="ss_q4" value="2" class="mr-1.5 accent-primary" /> <span class="text-xs">Intermediate</span></label>
              <label class="radio-opt"><input type="radio" name="ss_q4" value="3" class="mr-1.5 accent-primary" /> <span class="text-xs">Advanced</span></label>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- Results sidebar -->
    <div class="lg:col-span-2 space-y-5">

      <!-- Radar chart -->
      <div class="bg-bg-card border border-border rounded-lg p-5 sticky top-4">
        <h3 class="text-sm font-semibold mb-4 text-center">Maturity Radar</h3>
        <svg id="radar-svg" viewBox="0 0 300 300" width="100%" class="block mx-auto" aria-label="Platform maturity radar chart">
          <!-- Grid rings -->
          <g id="radar-grid"></g>
          <!-- Filled polygon -->
          <polygon id="radar-fill" points="" fill="rgba(99,102,241,0.2)" stroke="rgb(99,102,241)" stroke-width="2" />
          <!-- Axis lines -->
          <g id="radar-axes"></g>
          <!-- Labels -->
          <g id="radar-labels"></g>
          <!-- Axis dots -->
          <g id="radar-dots"></g>
        </svg>

        <!-- Overall score -->
        <div class="mt-4 text-center">
          <div class="text-3xl font-bold font-mono text-primary" id="overall-pct">0%</div>
          <div id="maturity-badge" class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold mt-1 bg-slate-700 text-slate-300">Level 1 — Reactive</div>
        </div>

        <!-- Dimension scores -->
        <div class="mt-4 space-y-2" id="dim-scores">
          <div class="flex justify-between text-xs text-text-muted"><span>Developer Experience</span><span id="score-dx">0/12</span></div>
          <div class="flex justify-between text-xs text-text-muted"><span>Automation</span><span id="score-auto">0/12</span></div>
          <div class="flex justify-between text-xs text-text-muted"><span>Observability</span><span id="score-obs">0/12</span></div>
          <div class="flex justify-between text-xs text-text-muted"><span>Security</span><span id="score-sec">0/12</span></div>
          <div class="flex justify-between text-xs text-text-muted"><span>Self-Service</span><span id="score-ss">0/12</span></div>
        </div>
      </div>

      <!-- Recommendations -->
      <div class="bg-bg-card border border-border rounded-lg p-5">
        <h3 class="text-sm font-semibold mb-3">Top 3 Recommendations</h3>
        <div id="recommendations" class="space-y-3 text-sm text-text-muted">
          <p class="text-xs italic">Answer the questions to see tailored recommendations.</p>
        </div>
      </div>

    </div>
  </div>

  <!-- Reset -->
  <div class="flex gap-3 mb-8">
    <button id="btn-reset" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Reset Assessment</button>
  </div>

  <ToolPageCta />
  <FaqSection faq={faq} />
</BaseLayout>

<script is:inline>
// Radar chart constants
const CX = 150, CY = 150, R = 110;
const DIMS = ['DX', 'Automation', 'Observability', 'Security', 'Self-Service'];
const DIM_KEYS = ['dx', 'auto', 'obs', 'sec', 'ss'];
const Q_NAMES = {
  dx:   ['dx_q1','dx_q2','dx_q3','dx_q4'],
  auto: ['auto_q1','auto_q2','auto_q3','auto_q4'],
  obs:  ['obs_q1','obs_q2','obs_q3','obs_q4'],
  sec:  ['sec_q1','sec_q2','sec_q3','sec_q4'],
  ss:   ['ss_q1','ss_q2','ss_q3','ss_q4'],
};
const MAX_PER_DIM = 12; // 4 questions × 3 max each

const RECS = {
  dx:   [
    'Build or adopt an Internal Developer Portal (Backstage, Port, or Cortex) to centralize service catalog, docs, and self-service.',
    'Define and publish Golden Path templates for your top 2 service types.',
    'Run a quarterly Developer Experience survey (SPACE framework or simple NPS) and action the top pain point each quarter.',
  ],
  auto: [
    'Standardize your CI pipeline with automated test gates, SAST, and coverage thresholds via a golden path.',
    'Implement Infrastructure-as-Code (Terraform / Pulumi) for all new environments and backfill critical existing ones.',
    'Automate rollback — deploy with feature flags or use Argo Rollouts / Flagger for canary deploys with automatic rollback on SLO breach.',
  ],
  obs: [
    'Instrument all services with OpenTelemetry (metrics + traces + logs) and centralize in a single observability backend.',
    'Define SLOs for your top 5 user-facing services and create error budget burn rate alerts.',
    'Reduce alert noise: audit your existing alerts, delete or tune any that have not triggered a real incident in 90 days.',
  ],
  sec: [
    'Add SAST (Semgrep, CodeQL) and dependency scanning (Dependabot, Snyk) to your default CI pipeline golden path.',
    'Migrate all secrets to a secrets manager (HashiCorp Vault, AWS SSM, Azure Key Vault) and enforce via policy-as-code.',
    'Implement container image signing and CVE scanning (Trivy, Grype) in your build pipeline with a critical CVE gate.',
  ],
  ss: [
    'Build a self-service scaffolding workflow: new repo + CI + catalog entry with a single IDP form submission.',
    'Enable ephemeral preview environments on every pull request using Kubernetes namespaces or Vercel-style previews.',
    'Publish a self-service secrets API so engineers can create, rotate, and scope secrets without a platform team ticket.',
  ],
};

function getScore(dim) {
  return Q_NAMES[dim].reduce((sum, name) => {
    const checked = document.querySelector(`input[name="${name}"]:checked`);
    return sum + (checked ? parseInt(checked.value) : 0);
  }, 0);
}

function polarToXY(angleDeg, radius) {
  const rad = (angleDeg - 90) * Math.PI / 180;
  return { x: CX + radius * Math.cos(rad), y: CY + radius * Math.sin(rad) };
}

function buildRadarGrid() {
  const grid = document.getElementById('radar-grid');
  const axes = document.getElementById('radar-axes');
  const labels = document.getElementById('radar-labels');
  grid.innerHTML = '';
  axes.innerHTML = '';
  labels.innerHTML = '';

  // Draw 3 grid rings at 1/3, 2/3, 3/3 of max
  [1, 2, 3].forEach(ring => {
    const pts = DIMS.map((_, i) => {
      const angle = (360 / DIMS.length) * i;
      const p = polarToXY(angle, R * (ring / 3));
      return `${p.x},${p.y}`;
    }).join(' ');
    const poly = document.createElementNS('http://www.w3.org/2000/svg', 'polygon');
    poly.setAttribute('points', pts);
    poly.setAttribute('fill', 'none');
    poly.setAttribute('stroke', 'rgba(255,255,255,0.08)');
    poly.setAttribute('stroke-width', '1');
    grid.appendChild(poly);
  });

  // Draw axes and labels
  DIMS.forEach((dim, i) => {
    const angle = (360 / DIMS.length) * i;
    const outer = polarToXY(angle, R);
    const center = { x: CX, y: CY };

    const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
    line.setAttribute('x1', center.x); line.setAttribute('y1', center.y);
    line.setAttribute('x2', outer.x);  line.setAttribute('y2', outer.y);
    line.setAttribute('stroke', 'rgba(255,255,255,0.12)');
    line.setAttribute('stroke-width', '1');
    axes.appendChild(line);

    // Label placement — push slightly beyond axis tip
    const lp = polarToXY(angle, R + 22);
    const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    text.setAttribute('x', lp.x);
    text.setAttribute('y', lp.y);
    text.setAttribute('text-anchor', 'middle');
    text.setAttribute('dominant-baseline', 'middle');
    text.setAttribute('font-size', '10');
    text.setAttribute('fill', 'rgba(255,255,255,0.55)');
    text.textContent = dim;
    labels.appendChild(text);
  });
}

function updateRadar(scores) {
  const pts = DIM_KEYS.map((key, i) => {
    const angle = (360 / DIM_KEYS.length) * i;
    const ratio = scores[key] / MAX_PER_DIM;
    const p = polarToXY(angle, R * ratio);
    return `${p.x},${p.y}`;
  }).join(' ');
  document.getElementById('radar-fill').setAttribute('points', pts);
}

function updateUI() {
  const scores = {};
  DIM_KEYS.forEach(k => { scores[k] = getScore(k); });

  updateRadar(scores);

  const totalMax = DIM_KEYS.length * MAX_PER_DIM;
  const totalScore = Object.values(scores).reduce((a, b) => a + b, 0);
  const pct = Math.round((totalScore / totalMax) * 100);

  document.getElementById('overall-pct').textContent = pct + '%';

  // Update per-dim scores
  DIM_KEYS.forEach(k => {
    const el = document.getElementById(`score-${k}`);
    if (el) el.textContent = `${scores[k]}/${MAX_PER_DIM}`;
  });

  // Maturity level
  let level, levelClass;
  if (pct < 25) {
    level = 'Level 1 — Reactive';
    levelClass = 'bg-slate-700 text-slate-300';
  } else if (pct < 50) {
    level = 'Level 2 — Repeatable';
    levelClass = 'bg-blue-900/50 text-blue-300';
  } else if (pct < 75) {
    level = 'Level 3 — Scalable';
    levelClass = 'bg-violet-900/50 text-violet-300';
  } else {
    level = 'Level 4 — Optimizing';
    levelClass = 'bg-green-900/50 text-green-300';
  }
  const badge = document.getElementById('maturity-badge');
  badge.className = `inline-flex items-center px-3 py-1 rounded-full text-xs font-bold mt-1 ${levelClass}`;
  badge.textContent = level;

  // Top 3 recommendations — pick weakest 3 dimensions
  const sorted = DIM_KEYS.slice().sort((a, b) => scores[a] - scores[b]);
  const top3 = sorted.slice(0, 3);
  const recContainer = document.getElementById('recommendations');
  recContainer.innerHTML = top3.map((key, rank) => {
    const dimName = DIMS[DIM_KEYS.indexOf(key)];
    const rec = RECS[key][rank] || RECS[key][0];
    return `<div class="flex gap-2">
      <span class="shrink-0 w-5 h-5 rounded-full bg-primary/20 text-primary text-xs font-bold flex items-center justify-center mt-0.5">${rank + 1}</span>
      <div><span class="font-medium text-foreground">${dimName}: </span>${rec}</div>
    </div>`;
  }).join('');
}

// Build static radar structure
buildRadarGrid();

// Attach change listeners
document.querySelectorAll('.radio-opt input[type="radio"]').forEach(radio => {
  radio.addEventListener('change', updateUI);
});

document.getElementById('btn-reset')?.addEventListener('click', () => {
  document.querySelectorAll('.radio-opt input[type="radio"]').forEach(r => { r.checked = false; });
  updateUI();
});

// Initialize
updateUI();
</script>
