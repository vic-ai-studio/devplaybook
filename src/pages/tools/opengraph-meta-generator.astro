---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OpenGraphPreview from '../../components/OpenGraphPreview.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the Open Graph protocol?", answer: "Open Graph is a protocol developed by Facebook that controls how URLs are displayed when shared on social media. By adding og: meta tags to your HTML <head>, you can specify the title, description, image, and type of your page — ensuring it looks great on Facebook, X (Twitter), LinkedIn, Slack, and other platforms." },
  { question: "What is the recommended image size for OG tags?", answer: "The ideal Open Graph image size is 1200×630 pixels (1.91:1 ratio). This renders well on all platforms. Minimum size is 600×315px — anything smaller may not display at all. Use PNG or JPEG with a file size under 8 MB. Twitter/X additionally supports 1200×675px (summary_large_image format)." },
  { question: "What is the difference between og:type values?", answer: "Common og:type values: 'website' (default for any page), 'article' (blog posts, news), 'video.movie' or 'video.episode', 'music.song', 'profile' (personal pages). For most landing pages, 'website' is correct. 'article' unlocks additional tags like og:article:author and og:article:published_time." },
  { question: "Do I need Twitter Card tags if I already have OG tags?", answer: "Yes — Twitter/X has its own meta tag format (twitter:card, twitter:title, etc.) that takes precedence over OG tags for X previews. If Twitter Card tags are missing, X will fall back to OG tags, but the preview may look different. This generator outputs both OG and Twitter Card tags." },
  { question: "Where do I put OG meta tags in my HTML?", answer: "Place all OG and Twitter Card meta tags inside the <head> element of your HTML document, before the closing </head> tag. They must appear on the canonical page URL — not in JavaScript-rendered content, as social media crawlers often don't execute JavaScript." },
  { question: "How do I test if my OG tags are working?", answer: "Use official debugging tools: Facebook Sharing Debugger (developers.facebook.com/tools/debug), Twitter Card Validator (cards-dev.twitter.com/validator), and LinkedIn Post Inspector (linkedin.com/post-inspector). These tools fetch and display how your URL will appear when shared." },
];
---

<BaseLayout
  title="OpenGraph Meta Tag Generator — Free OG + Twitter Card Builder"
  description="Generate complete Open Graph and Twitter Card meta tags from a simple form. Live social media preview for X/Twitter, Facebook, and Slack. Copy all tags in one click. Runs 100% in your browser."
  tool="OpenGraph meta generator, og meta tags, Twitter card generator, og:image generator, social media preview, OG tag builder, open graph preview"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "OpenGraph Meta Tag Generator",
    "url": "https://devplaybook.cc/tools/opengraph-meta-generator",
    "description": "Generate complete Open Graph and Twitter Card meta tags instantly. Live social media preview for X/Twitter, Facebook, and Slack. Runs 100% in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">OpenGraph Meta Tag Generator</h1>
  <p class="text-text-muted mb-4">
    Fill in your page details and instantly generate complete <code class="bg-bg-secondary px-1 rounded text-sm">og:</code> and <code class="bg-bg-secondary px-1 rounded text-sm">twitter:</code> meta tags. Live preview shows exactly how your URL will look when shared on X/Twitter, Facebook, and Slack.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> OG + Twitter Card tags</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live social preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <OpenGraphPreview client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="OpenGraph Meta Tag Generator" relatedTags={['seo', 'social-media', 'meta-tags', 'marketing', 'web']} />
</BaseLayout>
