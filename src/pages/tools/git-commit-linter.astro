---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is Conventional Commits?",
    answer: "Conventional Commits is a specification for structuring commit messages: <type>(<scope>): <description>. Common types are feat (new feature), fix (bug fix), docs, style, refactor, test, and chore. This format enables automated changelog generation, semantic versioning, and makes git history scannable. It's used by Angular, Vue, and many major open source projects."
  },
  {
    question: "What is the difference between feat and fix?",
    answer: "feat is for commits that add a new feature visible to users or consumers of the library. fix is for commits that fix a bug. In semantic versioning, feat triggers a minor version bump (1.0.0 → 1.1.0) and fix triggers a patch bump (1.0.0 → 1.0.1). A BREAKING CHANGE footer triggers a major bump (1.0.0 → 2.0.0)."
  },
  {
    question: "Should the commit message description start with a capital letter?",
    answer: "The Conventional Commits specification recommends lowercase for the description. The rationale: consistency makes grep and automated tooling simpler. Most linters (commitlint) default to enforcing lowercase. However, many teams use capitalized descriptions — the important thing is team consistency. This linter flags both conventions."
  },
  {
    question: "How long should a commit message be?",
    answer: "The subject line (first line) should be 50 characters or less for git log readability, with a hard limit of 72 characters. GitHub truncates subjects longer than 72 characters in list views. If you need more context, add a blank line after the subject followed by a body paragraph. The body should wrap at 72 characters."
  },
  {
    question: "What does BREAKING CHANGE mean in a commit?",
    answer: "A BREAKING CHANGE is a change that is not backwards-compatible — it requires users to update their code. In Conventional Commits, you signal this with BREAKING CHANGE: description in the commit footer, or by adding a ! after the type: feat!: remove deprecated API. Either triggers a major version bump in semantic versioning."
  }
];
---

<BaseLayout
  title="Git Commit Message Linter — Conventional Commits Validator"
  description="Validate git commit messages against the Conventional Commits specification. Get instant feedback on type, scope, description format, line length, and breaking changes. Free browser tool."
  tool="conventional commits, commit message linter, git commit format, commit message validator, conventional commit checker"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Git Commit Message Linter",
    "url": "https://devplaybook.cc/tools/git-commit-linter",
    "description": "Validate git commit messages against Conventional Commits specification. Get instant feedback and fix suggestions.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Git Commit Message Linter</h1>
  <p class="text-text-muted mb-4">
    Validate your commit messages against the <a href="https://www.conventionalcommits.org" class="text-accent hover:underline" target="_blank" rel="noopener">Conventional Commits</a> specification.
    Get instant warnings, errors, and suggestions with examples.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Conventional Commits spec</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Type, scope & description</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Line length checks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Breaking change detection</span>
  </div>

  <!-- Input -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <label class="block text-sm font-medium mb-2" for="commit-input">Commit message</label>
    <textarea
      id="commit-input"
      rows="5"
      placeholder="feat(auth): add OAuth2 login with Google&#10;&#10;Implement Google OAuth2 flow using passport.js.&#10;Adds callback endpoint and session handling.&#10;&#10;Closes #123"
      class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary resize-y"
    ></textarea>
    <div class="flex flex-wrap gap-2 mt-2">
      <span class="text-xs text-text-muted self-center">Examples:</span>
      {[
        'feat(auth): add OAuth2 login',
        'fix: handle null pointer in user service',
        'docs: update README installation steps',
        'refactor(api)!: rename endpoint to v2',
        'Added new feature',
        'WIP fix stuff',
      ].map(ex => (
        <button class="example-btn px-2.5 py-1 bg-surface border border-border rounded text-xs hover:border-primary transition-colors text-text-muted" data-msg={ex}>{ex.length > 28 ? ex.slice(0,28)+'…' : ex}</button>
      ))}
    </div>
  </div>

  <!-- Score + results -->
  <div id="lint-results" class="hidden mb-4">
    <!-- Score bar -->
    <div class="bg-bg-card border border-border rounded-lg p-4 mb-3 flex items-center gap-4">
      <div id="score-ring" class="relative w-16 h-16 shrink-0">
        <svg class="w-16 h-16 -rotate-90" viewBox="0 0 64 64">
          <circle cx="32" cy="32" r="26" fill="none" stroke="currentColor" stroke-width="6" class="text-border" />
          <circle id="score-circle" cx="32" cy="32" r="26" fill="none" stroke="currentColor" stroke-width="6" stroke-linecap="round" class="text-green-500" stroke-dasharray="163.4" stroke-dashoffset="0" />
        </svg>
        <span id="score-text" class="absolute inset-0 flex items-center justify-center text-lg font-bold">100</span>
      </div>
      <div>
        <div id="score-label" class="font-semibold text-green-500 text-base">Valid commit</div>
        <div id="score-sub" class="text-xs text-text-muted mt-0.5">Follows Conventional Commits specification</div>
      </div>
    </div>

    <!-- Issues list -->
    <div id="issues-list" class="space-y-2 mb-3"></div>

    <!-- Parsed breakdown -->
    <div id="parsed-card" class="bg-bg-card border border-border rounded-lg p-4">
      <h2 class="text-sm font-medium mb-3">Parsed commit</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 text-sm">
        <div><span class="text-xs text-text-muted block mb-1">Type</span><span id="p-type" class="font-mono text-accent">—</span></div>
        <div><span class="text-xs text-text-muted block mb-1">Scope</span><span id="p-scope" class="font-mono text-accent">—</span></div>
        <div><span class="text-xs text-text-muted block mb-1">Breaking</span><span id="p-breaking" class="font-mono">—</span></div>
        <div><span class="text-xs text-text-muted block mb-1">Subject length</span><span id="p-len" class="font-mono">—</span></div>
      </div>
      <div class="mt-3"><span class="text-xs text-text-muted block mb-1">Description</span><span id="p-desc" class="text-sm">—</span></div>
    </div>
  </div>

  <!-- Reference card -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-medium mb-3">Conventional Commits Format</h2>
    <pre class="bg-surface rounded-lg p-3 text-xs font-mono text-foreground/90 overflow-x-auto"><span class="text-accent">type</span><span class="text-text-muted">(optional scope)</span><span class="text-yellow-400">!</span>: <span class="text-foreground">description</span>

<span class="text-text-muted">[optional body]</span>

<span class="text-text-muted">BREAKING CHANGE: description
Closes #123</span></pre>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 mt-3">
      {[
        {type:'feat',desc:'New feature'},
        {type:'fix',desc:'Bug fix'},
        {type:'docs',desc:'Documentation'},
        {type:'style',desc:'Formatting'},
        {type:'refactor',desc:'Code refactor'},
        {type:'test',desc:'Tests'},
        {type:'chore',desc:'Maintenance'},
        {type:'perf',desc:'Performance'},
        {type:'ci',desc:'CI/CD'},
        {type:'build',desc:'Build system'},
        {type:'revert',desc:'Revert commit'},
        {type:'security',desc:'Security fix'},
      ].map(t => (
        <div class="flex gap-1.5 items-center text-xs">
          <span class="font-mono text-accent">{t.type}</span>
          <span class="text-text-muted">— {t.desc}</span>
        </div>
      ))}
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Git Commit Message Linter" relatedTags={['git', 'conventional-commits', 'linter', 'code-quality', 'developer-tools']} />
</BaseLayout>

<script is:inline>
(function() {
  const VALID_TYPES = ['feat','fix','docs','style','refactor','test','chore','perf','ci','build','revert','security','wip','hotfix','release','deps'];

  function lint(msg) {
    if (!msg.trim()) return { score: 0, issues: [], parsed: null };
    const lines = msg.split('\n');
    const subject = lines[0];
    const issues = [];

    // Parse subject
    const match = subject.match(/^([a-z][a-z0-9_-]*)(\(([^)]*)\))?(!)?: (.+)$/);
    const loosematch = subject.match(/^([A-Za-z][A-Za-z0-9_-]*)(\(([^)]*)\))?(!)?: (.+)$/);

    let type = null, scope = null, breaking = false, desc = null;

    if (match) {
      type = match[1];
      scope = match[3] || null;
      breaking = match[4] === '!';
      desc = match[5];
    } else if (loosematch) {
      type = loosematch[1];
      scope = loosematch[3] || null;
      breaking = loosematch[4] === '!';
      desc = loosematch[5];
      if (type !== type.toLowerCase()) {
        issues.push({ level: 'error', msg: `Type must be lowercase. Got "${type}", expected "${type.toLowerCase()}".`, fix: `Change "${type}" to "${type.toLowerCase()}"` });
      }
    } else {
      issues.push({ level: 'error', msg: `Commit subject doesn't follow Conventional Commits format.`, fix: `Use: <type>(<scope>): <description>\nExample: feat(auth): add login button` });
    }

    if (type) {
      if (!VALID_TYPES.includes(type.toLowerCase())) {
        issues.push({ level: 'warning', msg: `"${type}" is not a standard Conventional Commits type.`, fix: `Use one of: feat, fix, docs, style, refactor, test, chore, perf, ci, build, revert` });
      }
    }

    if (desc) {
      if (desc[0] === desc[0].toUpperCase() && /[a-zA-Z]/.test(desc[0])) {
        issues.push({ level: 'warning', msg: `Description starts with uppercase. Most linters prefer lowercase.`, fix: `Change "${desc}" to "${desc[0].toLowerCase() + desc.slice(1)}"` });
      }
      if (desc.endsWith('.')) {
        issues.push({ level: 'warning', msg: `Description ends with a period. Omit the trailing dot.`, fix: `Remove the period: "${desc.slice(0, -1)}"` });
      }
      if (desc.trim() !== desc) {
        issues.push({ level: 'error', msg: `Description has leading or trailing whitespace.`, fix: `Trim whitespace from: "${desc}"` });
      }
    }

    if (subject.length > 72) {
      issues.push({ level: 'error', msg: `Subject line is ${subject.length} characters (max 72). GitHub truncates long subjects.`, fix: `Shorten subject to 72 chars or less` });
    } else if (subject.length > 50) {
      issues.push({ level: 'warning', msg: `Subject line is ${subject.length} chars (recommended max: 50).`, fix: `Consider shortening to 50 characters` });
    }

    if (lines.length > 1 && lines[1] !== '') {
      issues.push({ level: 'error', msg: `Missing blank line between subject and body.`, fix: `Add an empty line after the subject:\n"${subject}"\n\n"${lines.slice(1).join('\n')}"` });
    }

    lines.slice(2).forEach((line, i) => {
      if (line.length > 72) {
        issues.push({ level: 'warning', msg: `Body line ${i + 3} is ${line.length} chars (max 72).`, fix: `Wrap body lines at 72 characters` });
      }
    });

    // Check for BREAKING CHANGE in footer
    const footer = lines.slice(2).join('\n');
    if (footer.includes('BREAKING CHANGE:') || footer.includes('BREAKING-CHANGE:')) {
      breaking = true;
    }

    const errorCount = issues.filter(i => i.level === 'error').length;
    const warnCount = issues.filter(i => i.level === 'warning').length;
    const score = Math.max(0, 100 - errorCount * 30 - warnCount * 10);

    return { score, issues, parsed: { type, scope, breaking, desc, subjectLen: subject.length } };
  }

  function render(msg) {
    const { score, issues, parsed } = lint(msg);
    const area = document.getElementById('lint-results');

    if (!msg.trim()) { area.classList.add('hidden'); return; }
    area.classList.remove('hidden');

    // Score ring
    const circumference = 163.4;
    const offset = circumference - (score / 100) * circumference;
    document.getElementById('score-circle').style.strokeDashoffset = offset;
    document.getElementById('score-text').textContent = score;
    const ring = document.getElementById('score-circle');
    const label = document.getElementById('score-label');
    const sub = document.getElementById('score-sub');
    if (score >= 90) {
      ring.className = ring.className.replace(/text-\w+-\d+/, 'text-green-500');
      label.className = 'font-semibold text-green-500 text-base';
      label.textContent = 'Valid commit';
      sub.textContent = 'Follows Conventional Commits specification';
    } else if (score >= 60) {
      ring.className = ring.className.replace(/text-\w+-\d+/, 'text-yellow-400');
      label.className = 'font-semibold text-yellow-400 text-base';
      label.textContent = 'Needs improvement';
      sub.textContent = `${issues.filter(i=>i.level==='warning').length} warning(s), ${issues.filter(i=>i.level==='error').length} error(s)`;
    } else {
      ring.className = ring.className.replace(/text-\w+-\d+/, 'text-red-400');
      label.className = 'font-semibold text-red-400 text-base';
      label.textContent = 'Invalid format';
      sub.textContent = `${issues.filter(i=>i.level==='error').length} error(s) found`;
    }

    // Issues
    document.getElementById('issues-list').innerHTML = issues.length === 0
      ? '<div class="bg-green-500/10 border border-green-500/30 rounded-lg p-3 text-sm text-green-400">✓ No issues found — looks good!</div>'
      : issues.map(is => `
        <div class="${is.level === 'error' ? 'bg-red-500/10 border-red-500/30 text-red-400' : 'bg-yellow-400/10 border-yellow-400/30 text-yellow-300'} border rounded-lg p-3 text-sm">
          <div class="font-medium mb-1">${is.level === 'error' ? '✗ Error' : '⚠ Warning'}: ${is.msg}</div>
          ${is.fix ? `<div class="text-xs opacity-80 font-mono whitespace-pre-wrap">→ ${is.fix}</div>` : ''}
        </div>
      `).join('');

    // Parsed
    if (parsed) {
      document.getElementById('p-type').textContent = parsed.type || '—';
      document.getElementById('p-scope').textContent = parsed.scope || '(none)';
      document.getElementById('p-breaking').textContent = parsed.breaking ? '⚠ Yes' : 'No';
      document.getElementById('p-breaking').className = parsed.breaking ? 'font-mono text-yellow-400' : 'font-mono text-text-muted';
      document.getElementById('p-len').textContent = parsed.subjectLen + ' chars';
      document.getElementById('p-len').className = 'font-mono ' + (parsed.subjectLen > 72 ? 'text-red-400' : parsed.subjectLen > 50 ? 'text-yellow-400' : 'text-green-500');
      document.getElementById('p-desc').textContent = parsed.desc || '—';
    }
  }

  const inp = document.getElementById('commit-input');
  inp.addEventListener('input', () => render(inp.value));

  document.querySelectorAll('.example-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      inp.value = btn.dataset.msg;
      render(inp.value);
    });
  });
})();
</script>
