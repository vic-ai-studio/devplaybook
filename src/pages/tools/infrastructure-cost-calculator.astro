---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "How accurate are these estimates?", answer: "These estimates are based on on-demand pricing for major instance types and may differ from actual bills due to: reserved instances/savings plans (up to 72% discount), spot instances (up to 90% discount), egress costs, storage I/O, support plan charges, and regional pricing differences. Use as a planning baseline, then refine with your specific pricing agreement." },
  { question: "What is the difference between reserved and on-demand pricing?", answer: "On-demand: pay per hour, no commitment. Reserved Instances (1-year, no upfront): typically 40% cheaper. Reserved (3-year, all upfront): up to 72% cheaper. Savings Plans: more flexible than reserved instances, apply across instance families. For predictable, steady-state workloads, reserved or savings plans dramatically reduce costs." },
  { question: "How do I estimate data transfer costs?", answer: "Data transfer within a region (AZ to AZ) is typically $0.01/GB. Transfer to internet: first 1GB free, then $0.09/GB (AWS), $0.12/GB (Azure), $0.08/GB (GCP). Using a CDN (CloudFront, Azure CDN, Cloud CDN) reduces egress costs significantly. Egress is often the surprise on cloud bills." },
  { question: "When should I use spot/preemptible instances?", answer: "Spot (AWS), Preemptible (GCP), and Spot VMs (Azure) offer 60-90% discounts but can be interrupted with ~2 minutes notice. Good for: batch processing, CI/CD runners, ML training jobs, dev/test environments. Not suitable for: production databases, stateful services, or any workload that can't handle interruption." },
];
---

<BaseLayout
  title="Infrastructure Cost Calculator — AWS vs Azure vs GCP VM Cost Comparison"
  description="Estimate and compare monthly infrastructure costs for AWS EC2, Azure VMs, and Google Compute Engine. Add multiple instances, storage, and data transfer to get a total monthly estimate."
  tool="Infrastructure Cost Calculator, AWS Cost Calculator, Azure VM Cost, GCP Compute Cost, Cloud Cost Comparison"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Infrastructure Cost Calculator</h1>
  <p class="text-text-muted mb-4">Estimate monthly cloud costs for EC2, Azure VM, and Google Compute Engine instances. Compare across providers and add storage costs.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> AWS, Azure, GCP pricing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multi-instance support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> On-demand vs reserved comparison</span>
  </div>

  <div class="space-y-5">
    <!-- Instance Builder -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-base font-semibold">VM Instances</h2>
        <button id="add-instance" class="text-xs bg-primary/10 text-primary border border-primary/30 rounded-lg px-3 py-1.5 hover:bg-primary/20 transition-colors">+ Add Instance</button>
      </div>
      <div id="instances-list" class="space-y-3"></div>
    </div>

    <!-- Storage & Transfer -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="bg-bg-card border border-border rounded-xl p-5 space-y-3">
        <h2 class="text-base font-semibold">Storage</h2>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium mb-1">SSD (GB)</label>
            <input id="ssd-gb" type="number" value="100" min="0" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" /></div>
          <div><label class="block text-xs font-medium mb-1">HDD (GB)</label>
            <input id="hdd-gb" type="number" value="0" min="0" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" /></div>
        </div>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-5 space-y-3">
        <h2 class="text-base font-semibold">Data Transfer</h2>
        <div><label class="block text-xs font-medium mb-1">Outbound to Internet (GB/mo)</label>
          <input id="egress-gb" type="number" value="50" min="0" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" /></div>
      </div>
    </div>

    <!-- Results -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {['aws','azure','gcp'].map(p => (
        <div class={`bg-bg-card border border-border rounded-xl p-5 provider-card`} data-provider={p}>
          <div class="flex items-center gap-2 mb-4">
            <div class={`w-3 h-3 rounded-full ${p==='aws'?'bg-amber-400':p==='azure'?'bg-blue-400':'bg-green-400'}`}></div>
            <h2 class="text-sm font-semibold uppercase">{p === 'aws' ? 'Amazon AWS' : p === 'azure' ? 'Microsoft Azure' : 'Google Cloud'}</h2>
          </div>
          <div class={`total-cost text-3xl font-bold mb-1 ${p==='aws'?'text-amber-400':p==='azure'?'text-blue-400':'text-green-400'}`}>—</div>
          <div class="text-xs text-text-muted mb-3">per month (on-demand)</div>
          <div class={`reserved-cost text-sm font-medium mb-3`}>Reserved (1yr): —</div>
          <div class="breakdown text-xs text-text-muted space-y-1"></div>
        </div>
      ))}
    </div>
  </div>

  <AdUnit slot="in-content" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Infrastructure Cost Calculator" relatedTags={['devops', 'cloud', 'aws', 'azure', 'gcp', 'infrastructure']} />
</BaseLayout>

<script>
// On-demand hourly pricing (USD) — approximate 2026 us-east-1
const PRICING = {
  aws: {
    'nano (0.5 CPU, 0.5 GB)': { cpu: 0.5, ram: 0.5, price: 0.0052 },
    'micro (1 CPU, 1 GB)': { cpu: 1, ram: 1, price: 0.0116 },
    'small (2 CPU, 2 GB)': { cpu: 2, ram: 2, price: 0.023 },
    'medium (2 CPU, 4 GB)': { cpu: 2, ram: 4, price: 0.046 },
    'large (2 CPU, 8 GB)': { cpu: 2, ram: 8, price: 0.0928 },
    'xlarge (4 CPU, 16 GB)': { cpu: 4, ram: 16, price: 0.1856 },
    '2xlarge (8 CPU, 32 GB)': { cpu: 8, ram: 32, price: 0.3712 },
    '4xlarge (16 CPU, 64 GB)': { cpu: 16, ram: 64, price: 0.7424 },
    '8xlarge (32 CPU, 128 GB)': { cpu: 32, ram: 128, price: 1.4848 },
  },
  azure: {
    'nano (0.5 CPU, 0.5 GB)': { cpu: 0.5, ram: 0.5, price: 0.0060 },
    'micro (1 CPU, 1 GB)': { cpu: 1, ram: 1, price: 0.0135 },
    'small (2 CPU, 2 GB)': { cpu: 2, ram: 2, price: 0.027 },
    'medium (2 CPU, 4 GB)': { cpu: 2, ram: 4, price: 0.048 },
    'large (2 CPU, 8 GB)': { cpu: 2, ram: 8, price: 0.096 },
    'xlarge (4 CPU, 16 GB)': { cpu: 4, ram: 16, price: 0.192 },
    '2xlarge (8 CPU, 32 GB)': { cpu: 8, ram: 32, price: 0.384 },
    '4xlarge (16 CPU, 64 GB)': { cpu: 16, ram: 64, price: 0.768 },
    '8xlarge (32 CPU, 128 GB)': { cpu: 32, ram: 128, price: 1.536 },
  },
  gcp: {
    'nano (0.5 CPU, 0.5 GB)': { cpu: 0.5, ram: 0.5, price: 0.005 },
    'micro (1 CPU, 1 GB)': { cpu: 1, ram: 1, price: 0.0105 },
    'small (2 CPU, 2 GB)': { cpu: 2, ram: 2, price: 0.021 },
    'medium (2 CPU, 4 GB)': { cpu: 2, ram: 4, price: 0.0485 },
    'large (2 CPU, 8 GB)': { cpu: 2, ram: 8, price: 0.097 },
    'xlarge (4 CPU, 16 GB)': { cpu: 4, ram: 16, price: 0.194 },
    '2xlarge (8 CPU, 32 GB)': { cpu: 8, ram: 32, price: 0.388 },
    '4xlarge (16 CPU, 64 GB)': { cpu: 16, ram: 64, price: 0.776 },
    '8xlarge (32 CPU, 128 GB)': { cpu: 32, ram: 128, price: 1.552 },
  },
};

const STORAGE_PRICING = { aws: { ssd: 0.10, hdd: 0.045 }, azure: { ssd: 0.12, hdd: 0.05 }, gcp: { ssd: 0.17, hdd: 0.04 } };
const EGRESS_PRICING = { aws: 0.09, azure: 0.087, gcp: 0.085 };
const RESERVED_DISCOUNT = 0.40; // 1-year reserved ~40% off
const HOURS_PER_MONTH = 730;

let instanceCount = 0;

function addInstance() {
  instanceCount++;
  const id = instanceCount;
  const container = document.getElementById('instances-list')!;
  const row = document.createElement('div');
  row.id = `inst-${id}`;
  row.className = 'grid grid-cols-12 gap-2 items-end';

  const sizeOptions = Object.keys(PRICING.aws).map(k => `<option value="${k}">${k}</option>`).join('');

  row.innerHTML = `
    <div class="col-span-3">
      <label class="block text-xs text-text-muted mb-1">Name</label>
      <input type="text" value="server-${id}" class="inst-name w-full bg-bg border border-border rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:border-primary" />
    </div>
    <div class="col-span-4">
      <label class="block text-xs text-text-muted mb-1">Instance Size</label>
      <select class="inst-size w-full bg-bg border border-border rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:border-primary">
        ${sizeOptions}
      </select>
    </div>
    <div class="col-span-2">
      <label class="block text-xs text-text-muted mb-1">Count</label>
      <input type="number" value="1" min="1" class="inst-count w-full bg-bg border border-border rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:border-primary" />
    </div>
    <div class="col-span-2">
      <label class="block text-xs text-text-muted mb-1">Hours/day</label>
      <input type="number" value="24" min="1" max="24" class="inst-hours w-full bg-bg border border-border rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:border-primary" />
    </div>
    <div class="col-span-1">
      <button class="remove-inst text-xs text-red-400 border border-red-400/30 rounded-lg px-2 py-1.5 hover:bg-red-500/10 w-full">✕</button>
    </div>
  `;

  container.appendChild(row);
  row.querySelector('.remove-inst')!.addEventListener('click', () => { row.remove(); update(); });
  row.querySelectorAll('input, select').forEach(el => el.addEventListener('input', update));
  update();
}

function getInstances() {
  return Array.from(document.querySelectorAll<HTMLDivElement>('[id^="inst-"]')).map(row => ({
    name: (row.querySelector<HTMLInputElement>('.inst-name')?.value || 'server'),
    size: (row.querySelector<HTMLSelectElement>('.inst-size')?.value || ''),
    count: Number(row.querySelector<HTMLInputElement>('.inst-count')?.value) || 1,
    hours: Number(row.querySelector<HTMLInputElement>('.inst-hours')?.value) || 24,
  }));
}

function update() {
  const instances = getInstances();
  const ssdGb = Number((document.getElementById('ssd-gb') as HTMLInputElement).value) || 0;
  const hddGb = Number((document.getElementById('hdd-gb') as HTMLInputElement).value) || 0;
  const egressGb = Number((document.getElementById('egress-gb') as HTMLInputElement).value) || 0;

  (['aws', 'azure', 'gcp'] as const).forEach(provider => {
    const card = document.querySelector(`[data-provider="${provider}"]`)!;
    const pricingData = PRICING[provider];

    let vmCost = 0;
    const breakdownLines: string[] = [];

    instances.forEach(inst => {
      const tier = pricingData[inst.size as keyof typeof pricingData];
      if (!tier) return;
      const hoursPerMonth = (inst.hours / 24) * 30 * 24;
      const cost = tier.price * hoursPerMonth * inst.count;
      vmCost += cost;
      breakdownLines.push(`${inst.name} ×${inst.count}: $${cost.toFixed(2)}/mo`);
    });

    const storagePricing = STORAGE_PRICING[provider];
    const storageCost = ssdGb * storagePricing.ssd + hddGb * storagePricing.hdd;
    if (storageCost > 0) breakdownLines.push(`Storage: $${storageCost.toFixed(2)}/mo`);

    const egressCost = Math.max(0, egressGb - 1) * EGRESS_PRICING[provider];
    if (egressCost > 0) breakdownLines.push(`Egress: $${egressCost.toFixed(2)}/mo`);

    const total = vmCost + storageCost + egressCost;
    const reserved = total * (1 - RESERVED_DISCOUNT);

    const colors = { aws: 'text-amber-400', azure: 'text-blue-400', gcp: 'text-green-400' };
    card.querySelector('.total-cost')!.textContent = `$${total.toFixed(2)}`;
    card.querySelector('.reserved-cost')!.textContent = `Reserved (1yr): $${reserved.toFixed(2)}/mo`;
    card.querySelector('.breakdown')!.innerHTML = breakdownLines.map(l => `<div>${l}</div>`).join('') || '<div>No instances added.</div>';
  });
}

document.getElementById('add-instance')!.addEventListener('click', addInstance);
document.getElementById('ssd-gb')!.addEventListener('input', update);
document.getElementById('hdd-gb')!.addEventListener('input', update);
document.getElementById('egress-gb')!.addEventListener('input', update);

// Init with sample instance
addInstance();
</script>
