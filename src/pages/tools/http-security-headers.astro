---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HttpSecurityHeaders from '../../components/HttpSecurityHeaders.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What are HTTP security headers?", answer: "HTTP security headers are response headers that browsers use to protect against common web vulnerabilities like XSS, clickjacking, MIME sniffing, and data injection. Setting them is a quick win for web security." },
  { question: "Which security headers should every site have?", answer: "At minimum: Strict-Transport-Security (HSTS), X-Frame-Options, X-Content-Type-Options, and Referrer-Policy. Content-Security-Policy is the most powerful but requires careful configuration." },
  { question: "What is Content-Security-Policy (CSP)?", answer: "CSP is a header that controls which sources of scripts, styles, images, and other resources the browser is allowed to load. A strong CSP prevents XSS attacks by blocking inline scripts and untrusted sources." },
  { question: "What is HSTS?", answer: "HTTP Strict Transport Security (HSTS) tells browsers to always use HTTPS for your domain. Once a browser sees the header, it won't load your site over HTTP for the duration of max-age. The includeSubDomains directive extends this to all subdomains." },
];
---

<BaseLayout
  title="HTTP Security Headers Generator — nginx & Apache Config"
  description="Generate HTTP security headers configuration for nginx and Apache. Configure HSTS, CSP, X-Frame-Options, Referrer-Policy, and more with toggle switches. Copy ready-to-use configs."
  tool="HTTP security headers, security headers generator, HSTS, Content-Security-Policy, X-Frame-Options, nginx headers, Apache headers"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">HTTP Security Headers Generator</h1>
  <p class="text-text-muted mb-4">Toggle and configure HTTP security headers to protect your web app. Generates ready-to-use nginx and Apache configuration snippets. Includes HSTS, CSP, X-Frame-Options, Referrer-Policy, and more.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> nginx & Apache configs</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <HttpSecurityHeaders client:only="preact" />
  <FaqSection faq={faq} />
  <AffiliateSection category={['hosting', 'deployment']} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more free developer tools?</p>
    <a href="/tools" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Browse All Free Tools →</a>
  </div>
  <ToolPageCta currentTool="HTTP Security Headers Generator" relatedTags={['security', 'http', 'nginx', 'web']} />
</BaseLayout>
