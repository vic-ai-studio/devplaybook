---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is WSGI and how does it work?", answer: "WSGI (Web Server Gateway Interface, PEP 3333) is the Python standard for synchronous web applications. A WSGI application is a callable that takes (environ, start_response) and returns an iterable of response bytes. The WSGI server (Gunicorn, uWSGI) calls this function per request, blocking until the response is complete. All of Django and Flask's core routing is built on WSGI." },
  { question: "What is ASGI and what problems does it solve?", answer: "ASGI (Asynchronous Server Gateway Interface) extends WSGI to support async Python. It handles three protocol types: HTTP, WebSocket, and lifespan events. An ASGI app is an async callable: async def app(scope, receive, send). This enables handling WebSocket connections, long-polling, server-sent events, and high-concurrency I/O-bound workloads — things that block an entire WSGI worker thread." },
  { question: "Can I run Django with ASGI?", answer: "Yes. Django 3.1+ added ASGI support. You can run Django with Uvicorn or Daphne, and use async def views for I/O-bound handlers. However, Django's ORM is synchronous — you must use sync_to_async() wrappers or Django Channels for full async database access. FastAPI is natively async throughout, making it simpler for fully async workloads." },
  { question: "What is the difference between Gunicorn and Uvicorn?", answer: "Gunicorn is a mature WSGI server that spawns multiple worker processes. Uvicorn is a lightning-fast ASGI server built on uvloop and httptools. A common production pattern: Gunicorn as the process manager with Uvicorn workers (--worker-class uvicorn.workers.UvicornWorker). This gives you Gunicorn's battle-tested process management with Uvicorn's async performance." },
  { question: "Does using ASGI automatically make my app faster?", answer: "Not necessarily. ASGI makes I/O-bound concurrency faster — handling many simultaneous connections with long waits (DB queries, external APIs, WebSockets). CPU-bound workloads see no benefit from async. A poorly written async app (sync blocking code in an async function) can be slower than WSGI. The key benefit is handling many concurrent connections with fewer OS threads." },
  { question: "What Python web frameworks support ASGI?", answer: "ASGI frameworks: FastAPI (full native support), Starlette (ASGI core), Django 3.1+ (partial, with sync ORM), Quart (async Flask clone), Litestar (formerly Ormar). WSGI-only frameworks: Flask, Bottle, Pyramid, Falcon (WSGI mode). Uvicorn, Daphne, and Hypercorn are the main ASGI servers. Gunicorn with UvicornWorker bridges WSGI management with ASGI performance." },
];
---

<BaseLayout
  title="WSGI vs ASGI — Python Web Server Comparison Tool 2025"
  description="Compare WSGI and ASGI Python web server interfaces. Understand sync vs async, Gunicorn vs Uvicorn, Django vs FastAPI, performance characteristics, and when to choose each."
  tool="WSGI vs ASGI comparison, Python web server interface, Gunicorn vs Uvicorn, async Python web, FastAPI vs Django performance"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "WSGI vs ASGI Comparison",
    "url": "https://devplaybook.cc/tools/wsgi-vs-asgi",
    "description": "Interactive comparison of WSGI and ASGI Python web server interfaces. Find the right server setup for your use case.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">WSGI vs ASGI — Python Web Server Comparison</h1>
  <p class="text-text-muted mb-4">
    Compare <strong>WSGI</strong> (synchronous) and <strong>ASGI</strong> (asynchronous) Python web interfaces. Understand Gunicorn vs Uvicorn, Django vs FastAPI performance, and when to use each.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Sync vs async explained</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Server recommendations</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Use-case selector</span>
  </div>

  <!-- Use-case selector -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-3">Find the Right Interface for Your Use Case</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-4">
      <div>
        <label class="text-xs text-text-muted block mb-1">What are you building?</label>
        <select id="use-case" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="rest-api">REST API (CRUD)</option>
          <option value="websocket">WebSockets / Real-time</option>
          <option value="django-app">Django web application</option>
          <option value="flask-app">Flask web application</option>
          <option value="ml-api">ML model serving API</option>
          <option value="sse">Server-Sent Events / Streaming</option>
          <option value="high-concurrency">High concurrency (1000+ req/s)</option>
          <option value="background">Background task processing</option>
        </select>
      </div>
      <div>
        <label class="text-xs text-text-muted block mb-1">Team Python experience</label>
        <select id="experience" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="beginner">Beginner / learning</option>
          <option value="intermediate">Intermediate</option>
          <option value="advanced">Advanced (async-native)</option>
        </select>
      </div>
    </div>
    <div id="rec-box" class="bg-primary/10 border border-primary/30 rounded-lg p-4"></div>
  </div>

  <!-- Side-by-side comparison -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-6">
    <!-- WSGI -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center gap-2 mb-3">
        <span class="w-8 h-8 bg-blue-500/20 text-blue-400 rounded-lg flex items-center justify-center font-bold text-sm">W</span>
        <div>
          <h2 class="font-bold">WSGI</h2>
          <p class="text-xs text-text-muted">Synchronous • PEP 3333</p>
        </div>
      </div>
      <div class="space-y-3 text-sm">
        <div class="flex items-start gap-2"><span class="text-green-500 mt-0.5">✓</span><span>Mature, battle-tested ecosystem</span></div>
        <div class="flex items-start gap-2"><span class="text-green-500 mt-0.5">✓</span><span>Simpler mental model — one request per thread</span></div>
        <div class="flex items-start gap-2"><span class="text-green-500 mt-0.5">✓</span><span>All Django/Flask apps run on WSGI</span></div>
        <div class="flex items-start gap-2"><span class="text-red-400 mt-0.5">✗</span><span>Cannot handle WebSockets natively</span></div>
        <div class="flex items-start gap-2"><span class="text-red-400 mt-0.5">✗</span><span>One thread blocked per request</span></div>
        <div class="flex items-start gap-2"><span class="text-red-400 mt-0.5">✗</span><span>No streaming responses</span></div>
      </div>
      <div class="mt-4 pt-4 border-t border-border">
        <p class="text-xs font-medium text-text-muted mb-2">Servers</p>
        <div class="flex flex-wrap gap-1.5">
          {['Gunicorn', 'uWSGI', 'mod_wsgi', 'Waitress'].map(s => (
            <span class="px-2 py-0.5 bg-blue-500/10 text-blue-400 border border-blue-500/20 rounded text-xs font-mono">{s}</span>
          ))}
        </div>
      </div>
      <div class="mt-3">
        <p class="text-xs font-medium text-text-muted mb-2">Frameworks</p>
        <div class="flex flex-wrap gap-1.5">
          {['Django', 'Flask', 'Bottle', 'Pyramid', 'Falcon'].map(f => (
            <span class="px-2 py-0.5 bg-bg-page border border-border rounded text-xs font-mono">{f}</span>
          ))}
        </div>
      </div>
    </div>

    <!-- ASGI -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center gap-2 mb-3">
        <span class="w-8 h-8 bg-green-500/20 text-green-400 rounded-lg flex items-center justify-center font-bold text-sm">A</span>
        <div>
          <h2 class="font-bold">ASGI</h2>
          <p class="text-xs text-text-muted">Asynchronous • PEP 3333 extension</p>
        </div>
      </div>
      <div class="space-y-3 text-sm">
        <div class="flex items-start gap-2"><span class="text-green-500 mt-0.5">✓</span><span>Native WebSocket and HTTP/2 support</span></div>
        <div class="flex items-start gap-2"><span class="text-green-500 mt-0.5">✓</span><span>Handle 1000s of concurrent connections</span></div>
        <div class="flex items-start gap-2"><span class="text-green-500 mt-0.5">✓</span><span>Streaming responses & Server-Sent Events</span></div>
        <div class="flex items-start gap-2"><span class="text-green-500 mt-0.5">✓</span><span>FastAPI, Starlette, Django Channels</span></div>
        <div class="flex items-start gap-2"><span class="text-yellow-400 mt-0.5">⚠</span><span>Requires async-aware libraries (DB, Redis)</span></div>
        <div class="flex items-start gap-2"><span class="text-yellow-400 mt-0.5">⚠</span><span>Steeper learning curve for async patterns</span></div>
      </div>
      <div class="mt-4 pt-4 border-t border-border">
        <p class="text-xs font-medium text-text-muted mb-2">Servers</p>
        <div class="flex flex-wrap gap-1.5">
          {['Uvicorn', 'Daphne', 'Hypercorn', 'Gunicorn+UvicornWorker'].map(s => (
            <span class="px-2 py-0.5 bg-green-500/10 text-green-400 border border-green-500/20 rounded text-xs font-mono">{s}</span>
          ))}
        </div>
      </div>
      <div class="mt-3">
        <p class="text-xs font-medium text-text-muted mb-2">Frameworks</p>
        <div class="flex flex-wrap gap-1.5">
          {['FastAPI', 'Starlette', 'Django 3.1+', 'Quart', 'Litestar'].map(f => (
            <span class="px-2 py-0.5 bg-bg-page border border-border rounded text-xs font-mono">{f}</span>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Performance model -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-4">Concurrency Model Explained</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <h3 class="text-sm font-semibold mb-2 text-blue-400">WSGI — Thread-Per-Request</h3>
        <div id="wsgi-viz" class="space-y-1.5 mb-3"></div>
        <p class="text-xs text-text-muted">Each worker thread handles one request at a time. During I/O (DB query, API call), the thread blocks and cannot handle other requests.</p>
      </div>
      <div>
        <h3 class="text-sm font-semibold mb-2 text-green-400">ASGI — Event Loop</h3>
        <div id="asgi-viz" class="space-y-1.5 mb-3"></div>
        <p class="text-xs text-text-muted">A single event loop handles many requests concurrently. During I/O, control yields to other requests — no blocking.</p>
      </div>
    </div>
  </div>

  <!-- Production config examples -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-4">Production Config Examples</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <p class="text-xs text-text-muted mb-1.5">WSGI — Gunicorn + Django</p>
        <pre class="bg-bg-page border border-border rounded-lg p-3 text-xs font-mono overflow-x-auto">gunicorn myproject.wsgi:application \
  --workers 4 \
  --bind 0.0.0.0:8000 \
  --timeout 30</pre>
      </div>
      <div>
        <p class="text-xs text-text-muted mb-1.5">ASGI — Uvicorn + FastAPI</p>
        <pre class="bg-bg-page border border-border rounded-lg p-3 text-xs font-mono overflow-x-auto">uvicorn main:app \
  --host 0.0.0.0 \
  --port 8000 \
  --workers 4</pre>
      </div>
      <div>
        <p class="text-xs text-text-muted mb-1.5">ASGI — Gunicorn + UvicornWorker (recommended)</p>
        <pre class="bg-bg-page border border-border rounded-lg p-3 text-xs font-mono overflow-x-auto">gunicorn main:app \
  -k uvicorn.workers.UvicornWorker \
  --workers 4 \
  --bind 0.0.0.0:8000</pre>
      </div>
      <div>
        <p class="text-xs text-text-muted mb-1.5">ASGI — Django Channels (WebSocket)</p>
        <pre class="bg-bg-page border border-border rounded-lg p-3 text-xs font-mono overflow-x-auto">daphne -b 0.0.0.0 -p 8000 \
  myproject.asgi:application</pre>
      </div>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="WSGI vs ASGI Comparison" relatedTags={['python', 'backend', 'fastapi', 'django', 'async', 'web-server']} />
</BaseLayout>

<script is:inline>
const recommendations = {
  'rest-api': {
    beginner: { interface: 'WSGI', server: 'Gunicorn', framework: 'Flask or Django REST Framework', reason: 'Simpler sync model — great for learning. WSGI handles standard REST APIs well.' },
    intermediate: { interface: 'ASGI', server: 'Uvicorn', framework: 'FastAPI', reason: 'FastAPI + Uvicorn is the modern choice: fast, type-safe, auto-docs via OpenAPI.' },
    advanced: { interface: 'ASGI', server: 'Gunicorn + UvicornWorker', framework: 'FastAPI or Starlette', reason: 'Production pattern: Gunicorn process management + Uvicorn async performance.' },
  },
  'websocket': {
    beginner: { interface: 'ASGI', server: 'Daphne', framework: 'Django Channels', reason: 'Django Channels handles WebSocket with familiar Django patterns.' },
    intermediate: { interface: 'ASGI', server: 'Uvicorn', framework: 'FastAPI WebSocket', reason: 'FastAPI has native WebSocket support with async/await.' },
    advanced: { interface: 'ASGI', server: 'Uvicorn', framework: 'Starlette', reason: 'Starlette gives you full control over ASGI lifecycle and WebSocket handling.' },
  },
  'django-app': {
    beginner: { interface: 'WSGI', server: 'Gunicorn', framework: 'Django', reason: 'Standard Django + Gunicorn is the proven, well-documented production stack.' },
    intermediate: { interface: 'WSGI', server: 'Gunicorn', framework: 'Django + DRF', reason: 'Django REST Framework on WSGI handles most REST workloads efficiently.' },
    advanced: { interface: 'ASGI', server: 'Uvicorn / Daphne', framework: 'Django 3.1+ ASGI', reason: 'Use Django ASGI for WebSocket support via Channels. Most views can stay sync.' },
  },
  'flask-app': {
    beginner: { interface: 'WSGI', server: 'Gunicorn', framework: 'Flask', reason: 'Flask is a WSGI framework. Gunicorn is the standard production server choice.' },
    intermediate: { interface: 'WSGI', server: 'Gunicorn', framework: 'Flask', reason: 'Flask + Gunicorn scales well for most web apps with multiple workers.' },
    advanced: { interface: 'ASGI', server: 'Uvicorn', framework: 'Quart (async Flask)', reason: 'Quart is an async Flask clone that runs on ASGI for high-concurrency workloads.' },
  },
  'ml-api': {
    beginner: { interface: 'WSGI', server: 'Gunicorn', framework: 'Flask', reason: 'Flask is popular for ML APIs — simple, and ML inference is CPU-bound (sync is fine).' },
    intermediate: { interface: 'ASGI', server: 'Uvicorn', framework: 'FastAPI', reason: 'FastAPI is the modern standard for ML APIs: async I/O, Pydantic validation, auto-docs.' },
    advanced: { interface: 'ASGI', server: 'Gunicorn + UvicornWorker', framework: 'FastAPI + BackgroundTasks', reason: 'FastAPI with background tasks and async I/O handles concurrent inference requests well.' },
  },
  'sse': {
    beginner: { interface: 'ASGI', server: 'Uvicorn', framework: 'FastAPI', reason: 'FastAPI StreamingResponse makes Server-Sent Events straightforward with async generators.' },
    intermediate: { interface: 'ASGI', server: 'Uvicorn', framework: 'FastAPI', reason: 'Use FastAPI StreamingResponse or EventSourceResponse for SSE streaming.' },
    advanced: { interface: 'ASGI', server: 'Uvicorn', framework: 'Starlette', reason: 'Starlette gives low-level control over streaming — ideal for high-volume SSE.' },
  },
  'high-concurrency': {
    beginner: { interface: 'ASGI', server: 'Uvicorn', framework: 'FastAPI', reason: 'FastAPI + Uvicorn handles thousands of concurrent connections with async I/O.' },
    intermediate: { interface: 'ASGI', server: 'Gunicorn + UvicornWorker', framework: 'FastAPI', reason: 'Multiple Uvicorn workers + async I/O maximizes throughput on multi-core servers.' },
    advanced: { interface: 'ASGI', server: 'Gunicorn + UvicornWorker', framework: 'Starlette / FastAPI', reason: 'Tune worker count = CPU cores * 2 + 1. Use connection pooling for DB (asyncpg, aiomysql).' },
  },
  'background': {
    beginner: { interface: 'WSGI', server: 'Gunicorn', framework: 'Django + Celery', reason: 'Django + Celery is the standard for background task processing.' },
    intermediate: { interface: 'ASGI', server: 'Uvicorn', framework: 'FastAPI + BackgroundTasks', reason: 'FastAPI BackgroundTasks for lightweight tasks; add Celery/ARQ for heavy workloads.' },
    advanced: { interface: 'ASGI', server: 'Uvicorn', framework: 'FastAPI + ARQ / Dramatiq', reason: 'ARQ (async task queue built on Redis) pairs naturally with async FastAPI apps.' },
  },
};

function updateRec() {
  const uc = document.getElementById('use-case').value;
  const exp = document.getElementById('experience').value;
  const r = recommendations[uc]?.[exp];
  if (!r) return;
  const color = r.interface === 'ASGI' ? 'text-green-400' : 'text-blue-400';
  document.getElementById('rec-box').innerHTML = `
    <div class="flex flex-wrap gap-4">
      <div><p class="text-xs text-text-muted mb-0.5">Interface</p><p class="font-bold ${color}">${r.interface}</p></div>
      <div><p class="text-xs text-text-muted mb-0.5">Server</p><p class="font-semibold font-mono text-sm">${r.server}</p></div>
      <div><p class="text-xs text-text-muted mb-0.5">Framework</p><p class="font-semibold font-mono text-sm">${r.framework}</p></div>
    </div>
    <p class="text-text-muted text-xs mt-3">${r.reason}</p>
  `;
}

['use-case', 'experience'].forEach(id => {
  document.getElementById(id)?.addEventListener('change', updateRec);
});
updateRec();

// Visualization
function renderViz() {
  const wsgiViz = document.getElementById('wsgi-viz');
  const asgiViz = document.getElementById('asgi-viz');

  // WSGI: 4 workers, each handling 1 request
  const wsgiWorkers = ['Worker 1', 'Worker 2', 'Worker 3', 'Worker 4'];
  const wsgiStates = ['Processing req #1', 'BLOCKED (DB wait)', 'Processing req #3', 'BLOCKED (API wait)'];
  wsgiViz.innerHTML = wsgiWorkers.map((w, i) => {
    const blocked = wsgiStates[i].includes('BLOCKED');
    return `<div class="flex items-center gap-2 text-xs">
      <span class="w-16 font-mono text-text-muted">${w}</span>
      <div class="flex-1 h-5 rounded ${blocked ? 'bg-red-500/20 border border-red-500/30' : 'bg-green-500/20 border border-green-500/30'} flex items-center px-2">
        <span class="${blocked ? 'text-red-400' : 'text-green-400'}">${wsgiStates[i]}</span>
      </div>
    </div>`;
  }).join('');

  // ASGI: 1 event loop, many concurrent
  const reqs = [
    { name: 'Req #1', state: 'await db.query()', color: 'yellow' },
    { name: 'Req #2', state: 'Processing', color: 'green' },
    { name: 'Req #3', state: 'await http.get()', color: 'yellow' },
    { name: 'Req #4', state: 'Processing', color: 'green' },
    { name: 'Req #5', state: 'Sending response', color: 'blue' },
    { name: 'Req #6', state: 'await db.query()', color: 'yellow' },
  ];
  asgiViz.innerHTML = `<div class="text-xs text-text-muted mb-1">Event Loop (1 thread, N concurrent)</div>` +
    reqs.map(r => {
      const cls = r.color === 'green' ? 'bg-green-500/20 border-green-500/30 text-green-400' :
                  r.color === 'yellow' ? 'bg-yellow-500/20 border-yellow-500/30 text-yellow-400' :
                  'bg-blue-500/20 border-blue-500/30 text-blue-400';
      return `<div class="flex items-center gap-2 text-xs">
        <span class="w-12 font-mono text-text-muted">${r.name}</span>
        <div class="flex-1 h-5 rounded border ${cls} flex items-center px-2">
          <span>${r.state}</span>
        </div>
      </div>`;
    }).join('');
}

renderViz();
</script>
