---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is CrewAI?",
    answer: "CrewAI is a Python framework for orchestrating multi-agent AI systems. You define a 'crew' of AI agents, each with a role, goal, and backstory, plus tasks they need to accomplish. The crew works together, with agents collaborating, delegating, and using tools to complete complex workflows. It's designed for role-based agent systems where different agents have specialized expertise."
  },
  {
    question: "What is the difference between an Agent's role, goal, and backstory?",
    answer: "In CrewAI: Role defines what the agent is (e.g., 'Senior Research Analyst') — affects how it approaches problems. Goal defines what the agent wants to achieve (e.g., 'Uncover cutting-edge AI developments') — drives motivation and decision-making. Backstory provides context and personality (e.g., 'You are a seasoned researcher with 10 years of experience') — shapes communication style and depth of analysis."
  },
  {
    question: "What are CrewAI tasks and how are they different from agents?",
    answer: "Agents are the 'who' — autonomous entities with persistent roles, goals, and tools. Tasks are the 'what' — specific pieces of work assigned to agents with defined descriptions, expected outputs, and optional context from previous tasks. An agent can be assigned multiple tasks, and tasks can reference outputs from other tasks to build complex workflows."
  },
  {
    question: "What tools can CrewAI agents use?",
    answer: "CrewAI supports: built-in tools (SerperDevTool for search, FileReadTool, CodeInterpreterTool, ScrapeWebsiteTool), LangChain tools (any tool from the LangChain ecosystem), and custom tools (create with @tool decorator). Tools extend what agents can do beyond pure LLM generation — they can browse the web, read files, execute code, query databases, and call APIs."
  },
  {
    question: "What is agent delegation in CrewAI?",
    answer: "When allow_delegation=True, an agent can ask other agents in the crew for help. For example, a manager agent might delegate research to a researcher agent and writing to a writer agent. This enables hierarchical agent systems where a lead agent coordinates specialized workers. Set allow_delegation=False for agents that should work independently without asking for help."
  }
];
---

<BaseLayout
  title="CrewAI Agent Config Generator — Generate Agent YAML Configurations"
  description="Build CrewAI agent configurations with role, goal, backstory, and tool settings. Generate YAML or Python code for multi-agent workflows. Visualize agent relationships."
  tool="crewai agent config generator, crewai yaml generator, crewai agent builder, crewai multi-agent setup, crewai configuration"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "CrewAI Agent Config Generator",
    "url": "https://devplaybook.cc/tools/crewai-agent-config-generator",
    "description": "Generate CrewAI agent YAML configurations with role, goal, backstory, tools, and task assignments. Build multi-agent crews with visual configuration.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">CrewAI Agent Config Generator</h1>
  <p class="text-text-muted mb-4">
    Build CrewAI agent configurations visually. Define roles, goals, backstories, and tools, then generate YAML or Python code.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multi-agent crew builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> YAML & Python output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Task assignment</span>
  </div>

  <!-- Templates -->
  <div class="mb-6">
    <label class="block text-sm font-medium mb-2">Start with a Template</label>
    <div class="flex flex-wrap gap-2">
      <button class="template-btn text-xs px-3 py-1.5 rounded-full border border-border hover:border-primary hover:text-primary transition-all" data-template="research">Research Team</button>
      <button class="template-btn text-xs px-3 py-1.5 rounded-full border border-border hover:border-primary hover:text-primary transition-all" data-template="content">Content Creation</button>
      <button class="template-btn text-xs px-3 py-1.5 rounded-full border border-border hover:border-primary hover:text-primary transition-all" data-template="dev">Dev Team</button>
      <button class="template-btn text-xs px-3 py-1.5 rounded-full border border-border hover:border-primary hover:text-primary transition-all" data-template="sales">Sales Crew</button>
    </div>
  </div>

  <!-- Agent editor -->
  <div class="space-y-4 mb-6">
    <div class="flex items-center justify-between">
      <h2 class="text-base font-semibold">Agents</h2>
      <button id="btn-add-agent" class="text-xs px-3 py-1.5 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors">+ Add Agent</button>
    </div>
    <div id="agents-list" class="space-y-4"></div>
  </div>

  <!-- Tasks editor -->
  <div class="space-y-4 mb-6">
    <div class="flex items-center justify-between">
      <h2 class="text-base font-semibold">Tasks</h2>
      <button id="btn-add-task" class="text-xs px-3 py-1.5 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors">+ Add Task</button>
    </div>
    <div id="tasks-list" class="space-y-3"></div>
  </div>

  <!-- Output -->
  <div class="border border-border rounded-xl p-5 mb-6">
    <div class="flex items-center justify-between mb-3">
      <div class="flex gap-2">
        <button class="output-tab active text-sm px-3 py-1 rounded-lg border border-primary bg-primary/10 text-primary" data-tab="yaml">YAML</button>
        <button class="output-tab text-sm px-3 py-1 rounded-lg border border-border text-text-muted hover:border-primary hover:text-primary" data-tab="python">Python</button>
      </div>
      <button id="btn-copy-output" class="text-xs px-3 py-1 bg-surface border border-border rounded hover:border-primary hover:text-primary transition-colors">Copy</button>
    </div>
    <pre id="code-output" class="text-xs font-mono text-accent bg-surface rounded-lg p-4 overflow-x-auto whitespace-pre max-h-96"></pre>
  </div>

  <AdUnit />
  <ToolPageCta />

<script>
(() => {
  const TOOLS_LIST = ['SerperDevTool', 'FileReadTool', 'FileWriterTool', 'ScrapeWebsiteTool', 'CodeInterpreterTool', 'BrowserbaseTool', 'EXASearchTool', 'YoutubeVideoSearchTool', 'GithubSearchTool'];

  const TEMPLATES = {
    research: {
      agents: [
        { id: 'a1', role: 'Senior Research Analyst', goal: 'Uncover cutting-edge developments in AI and technology', backstory: 'You are a seasoned research analyst with 10+ years of experience in AI. You excel at finding reliable sources, synthesizing complex information, and identifying key trends. Known for thorough, unbiased analysis.', tools: ['SerperDevTool', 'ScrapeWebsiteTool'], verbose: true, delegation: false },
        { id: 'a2', role: 'Research Summarizer', goal: 'Transform complex research into clear, actionable insights', backstory: 'You are an expert at distilling complex technical research into concise summaries. You ensure accuracy while making content accessible to non-technical stakeholders.', tools: ['FileReadTool'], verbose: true, delegation: false },
      ],
      tasks: [
        { id: 't1', name: 'research_task', description: 'Research the latest developments in {topic}. Identify key trends, innovations, and implications.', expected: 'Comprehensive report with 5+ key findings, source citations, and trend analysis', agent: 'a1' },
        { id: 't2', name: 'summary_task', description: 'Summarize the research findings into an executive brief. Focus on actionable insights.', expected: '1-page executive summary with bullet points and recommendations', agent: 'a2' },
      ]
    },
    content: {
      agents: [
        { id: 'a1', role: 'Content Strategist', goal: 'Develop high-impact content strategies that drive engagement and SEO', backstory: 'You are a content marketing expert with deep knowledge of SEO, audience psychology, and content distribution. You create strategies that resonate with target audiences.', tools: ['SerperDevTool'], verbose: true, delegation: true },
        { id: 'a2', role: 'Senior Content Writer', goal: 'Create compelling, well-researched content that ranks and converts', backstory: 'You are a skilled writer specializing in technical and marketing content. You balance SEO requirements with engaging narrative, citing authoritative sources throughout.', tools: ['SerperDevTool', 'ScrapeWebsiteTool'], verbose: false, delegation: false },
        { id: 'a3', role: 'Content Editor', goal: 'Ensure all content meets quality, accuracy, and brand standards', backstory: 'You are a meticulous editor with an eye for detail, consistency, and clarity. You improve readability while preserving the writer\'s voice.', tools: [], verbose: false, delegation: false },
      ],
      tasks: [
        { id: 't1', name: 'strategy_task', description: 'Develop a content strategy for {topic} including keyword targets and outline.', expected: 'Content brief with title, keywords, outline, and target audience analysis', agent: 'a1' },
        { id: 't2', name: 'write_task', description: 'Write a 2000-word article following the content brief.', expected: 'Full article with introduction, 5+ sections, conclusion, and internal links', agent: 'a2' },
        { id: 't3', name: 'edit_task', description: 'Edit and polish the article for publication.', expected: 'Final publication-ready article with corrected grammar and improved clarity', agent: 'a3' },
      ]
    },
    dev: {
      agents: [
        { id: 'a1', role: 'Tech Lead', goal: 'Design scalable, maintainable software architecture', backstory: 'Seasoned software architect with 15 years of experience building production systems. Expert in system design, code review, and technical decision-making.', tools: ['GithubSearchTool', 'ScrapeWebsiteTool'], verbose: true, delegation: true },
        { id: 'a2', role: 'Senior Developer', goal: 'Implement clean, tested, production-ready code', backstory: 'Full-stack developer specializing in Python and TypeScript. You write clean code with comprehensive tests and clear documentation.', tools: ['CodeInterpreterTool', 'FileReadTool', 'FileWriterTool'], verbose: true, delegation: false },
        { id: 'a3', role: 'QA Engineer', goal: 'Ensure code quality through comprehensive testing strategies', backstory: 'QA engineer with expertise in test automation, edge case identification, and performance testing.', tools: ['CodeInterpreterTool'], verbose: false, delegation: false },
      ],
      tasks: [
        { id: 't1', name: 'design_task', description: 'Design the architecture for {feature}. Document decisions and trade-offs.', expected: 'Architecture doc with component diagram, API contracts, and data models', agent: 'a1' },
        { id: 't2', name: 'implement_task', description: 'Implement the solution following the architecture design.', expected: 'Production-ready code with docstrings and type hints', agent: 'a2' },
        { id: 't3', name: 'test_task', description: 'Write comprehensive tests for the implementation.', expected: 'Test suite with unit, integration tests. Coverage > 80%.', agent: 'a3' },
      ]
    },
    sales: {
      agents: [
        { id: 'a1', role: 'Sales Intelligence Analyst', goal: 'Research and qualify leads to maximize sales opportunities', backstory: 'Expert in B2B lead research and qualification. You use data-driven approaches to identify high-value prospects.', tools: ['SerperDevTool', 'ScrapeWebsiteTool', 'EXASearchTool'], verbose: true, delegation: false },
        { id: 'a2', role: 'Sales Outreach Specialist', goal: 'Craft personalized outreach that drives responses and meetings', backstory: 'Skilled in personalized sales communication. You write outreach that feels human, relevant, and compelling.', tools: [], verbose: false, delegation: false },
      ],
      tasks: [
        { id: 't1', name: 'research_lead', description: 'Research the prospect {company_name}. Find pain points, recent news, and decision makers.', expected: 'Lead profile with company overview, pain points, decision makers, and approach strategy', agent: 'a1' },
        { id: 't2', name: 'write_outreach', description: 'Write a personalized cold email and LinkedIn message based on the lead research.', expected: 'Personalized email (150 words) + LinkedIn message (75 words) with clear value proposition', agent: 'a2' },
      ]
    }
  };

  let agents = [];
  let tasks = [];
  let activeTab = 'yaml';
  let agentCounter = 0;
  let taskCounter = 0;

  function newAgent() {
    agentCounter++;
    return {
      id: 'a' + agentCounter,
      role: 'Agent ' + agentCounter,
      goal: 'Accomplish the assigned tasks with high quality',
      backstory: 'An experienced AI agent specialized in this domain.',
      tools: [],
      verbose: true,
      delegation: false
    };
  }

  function newTask() {
    taskCounter++;
    return {
      id: 't' + taskCounter,
      name: 'task_' + taskCounter,
      description: 'Describe what this task should accomplish.',
      expected: 'The expected output of this task.',
      agent: agents[0]?.id || ''
    };
  }

  function renderAgents() {
    document.getElementById('agents-list').innerHTML = agents.map((a, i) => `
      <div class="border border-border rounded-xl p-4 space-y-3" data-agent-id="${a.id}">
        <div class="flex items-center justify-between">
          <span class="text-sm font-semibold text-primary">Agent ${i + 1}</span>
          <button class="btn-remove-agent text-xs text-red-400 hover:text-red-300" data-id="${a.id}">Remove</button>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <label class="block text-xs text-text-muted mb-1">Role</label>
            <input type="text" class="agent-role w-full px-3 py-1.5 bg-surface border border-border rounded text-sm focus:outline-none focus:ring-1 focus:ring-primary/50" value="${a.role}" data-id="${a.id}">
          </div>
          <div>
            <label class="block text-xs text-text-muted mb-1">Goal</label>
            <input type="text" class="agent-goal w-full px-3 py-1.5 bg-surface border border-border rounded text-sm focus:outline-none focus:ring-1 focus:ring-primary/50" value="${a.goal}" data-id="${a.id}">
          </div>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">Backstory</label>
          <textarea class="agent-backstory w-full px-3 py-1.5 bg-surface border border-border rounded text-sm resize-none focus:outline-none focus:ring-1 focus:ring-primary/50" rows="2" data-id="${a.id}">${a.backstory}</textarea>
        </div>
        <div class="flex flex-wrap gap-3">
          <div class="flex-1 min-w-[150px]">
            <label class="block text-xs text-text-muted mb-1">Tools</label>
            <div class="flex flex-wrap gap-1">
              ${TOOLS_LIST.map(t => `<label class="flex items-center gap-1 text-xs cursor-pointer"><input type="checkbox" class="agent-tool" data-id="${a.id}" data-tool="${t}" ${a.tools.includes(t) ? 'checked' : ''}><span>${t}</span></label>`).join('')}
            </div>
          </div>
          <div class="flex gap-4 items-end">
            <label class="flex items-center gap-1.5 text-xs cursor-pointer"><input type="checkbox" class="agent-verbose" data-id="${a.id}" ${a.verbose ? 'checked' : ''}><span>verbose</span></label>
            <label class="flex items-center gap-1.5 text-xs cursor-pointer"><input type="checkbox" class="agent-delegation" data-id="${a.id}" ${a.delegation ? 'checked' : ''}><span>allow_delegation</span></label>
          </div>
        </div>
      </div>
    `).join('');

    // Bind inputs
    document.querySelectorAll('.agent-role').forEach(el => el.addEventListener('input', e => updateAgent(e.target.dataset.id, 'role', e.target.value)));
    document.querySelectorAll('.agent-goal').forEach(el => el.addEventListener('input', e => updateAgent(e.target.dataset.id, 'goal', e.target.value)));
    document.querySelectorAll('.agent-backstory').forEach(el => el.addEventListener('input', e => updateAgent(e.target.dataset.id, 'backstory', e.target.value)));
    document.querySelectorAll('.agent-verbose').forEach(el => el.addEventListener('change', e => updateAgent(e.target.dataset.id, 'verbose', e.target.checked)));
    document.querySelectorAll('.agent-delegation').forEach(el => el.addEventListener('change', e => updateAgent(e.target.dataset.id, 'delegation', e.target.checked)));
    document.querySelectorAll('.agent-tool').forEach(el => el.addEventListener('change', e => {
      const agent = agents.find(a => a.id === e.target.dataset.id);
      if (!agent) return;
      if (e.target.checked) agent.tools.push(e.target.dataset.tool);
      else agent.tools = agent.tools.filter(t => t !== e.target.dataset.tool);
      generateOutput();
    }));
    document.querySelectorAll('.btn-remove-agent').forEach(btn => btn.addEventListener('click', e => {
      agents = agents.filter(a => a.id !== btn.dataset.id);
      renderAgents();
      generateOutput();
    }));
    generateOutput();
  }

  function renderTasks() {
    document.getElementById('tasks-list').innerHTML = tasks.map((t, i) => `
      <div class="border border-border rounded-xl p-4 space-y-3" data-task-id="${t.id}">
        <div class="flex items-center justify-between">
          <span class="text-sm font-semibold text-accent">Task ${i + 1}</span>
          <button class="btn-remove-task text-xs text-red-400 hover:text-red-300" data-id="${t.id}">Remove</button>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <label class="block text-xs text-text-muted mb-1">Task Name</label>
            <input type="text" class="task-name w-full px-3 py-1.5 bg-surface border border-border rounded text-sm focus:outline-none" value="${t.name}" data-id="${t.id}">
          </div>
          <div>
            <label class="block text-xs text-text-muted mb-1">Assigned Agent</label>
            <select class="task-agent w-full px-3 py-1.5 bg-surface border border-border rounded text-sm focus:outline-none" data-id="${t.id}">
              ${agents.map(a => `<option value="${a.id}" ${t.agent === a.id ? 'selected' : ''}>${a.role}</option>`).join('')}
            </select>
          </div>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">Description</label>
          <textarea class="task-desc w-full px-3 py-1.5 bg-surface border border-border rounded text-sm resize-none focus:outline-none" rows="2" data-id="${t.id}">${t.description}</textarea>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">Expected Output</label>
          <input type="text" class="task-expected w-full px-3 py-1.5 bg-surface border border-border rounded text-sm focus:outline-none" value="${t.expected}" data-id="${t.id}">
        </div>
      </div>
    `).join('');

    document.querySelectorAll('.task-name').forEach(el => el.addEventListener('input', e => updateTask(e.target.dataset.id, 'name', e.target.value)));
    document.querySelectorAll('.task-agent').forEach(el => el.addEventListener('change', e => updateTask(e.target.dataset.id, 'agent', e.target.value)));
    document.querySelectorAll('.task-desc').forEach(el => el.addEventListener('input', e => updateTask(e.target.dataset.id, 'description', e.target.value)));
    document.querySelectorAll('.task-expected').forEach(el => el.addEventListener('input', e => updateTask(e.target.dataset.id, 'expected', e.target.value)));
    document.querySelectorAll('.btn-remove-task').forEach(btn => btn.addEventListener('click', e => {
      tasks = tasks.filter(t => t.id !== btn.dataset.id);
      renderTasks();
      generateOutput();
    }));
    generateOutput();
  }

  function updateAgent(id, field, value) {
    const agent = agents.find(a => a.id === id);
    if (agent) { agent[field] = value; generateOutput(); }
  }

  function updateTask(id, field, value) {
    const task = tasks.find(t => t.id === id);
    if (task) { task[field] = value; generateOutput(); }
  }

  function generateYAML() {
    let yaml = '# CrewAI Configuration\n# Generated by devplaybook.cc/tools/crewai-agent-config-generator\n\n';
    yaml += 'agents:\n';
    agents.forEach(a => {
      const varName = a.role.toLowerCase().replace(/\s+/g, '_').replace(/[^a-z0-9_]/g, '');
      yaml += `  ${varName}:\n`;
      yaml += `    role: "${a.role}"\n`;
      yaml += `    goal: "${a.goal}"\n`;
      yaml += `    backstory: |\n      ${a.backstory}\n`;
      yaml += `    verbose: ${a.verbose}\n`;
      yaml += `    allow_delegation: ${a.delegation}\n`;
      if (a.tools.length > 0) {
        yaml += `    tools:\n${a.tools.map(t => `      - ${t}`).join('\n')}\n`;
      }
      yaml += '\n';
    });

    yaml += 'tasks:\n';
    tasks.forEach(t => {
      const agentObj = agents.find(a => a.id === t.agent);
      const agentVar = agentObj ? agentObj.role.toLowerCase().replace(/\s+/g, '_').replace(/[^a-z0-9_]/g, '') : 'agent';
      yaml += `  ${t.name}:\n`;
      yaml += `    description: |\n      ${t.description}\n`;
      yaml += `    expected_output: "${t.expected}"\n`;
      yaml += `    agent: ${agentVar}\n\n`;
    });

    return yaml;
  }

  function generatePython() {
    const toolImports = [...new Set(agents.flatMap(a => a.tools))];
    let code = `# CrewAI Multi-Agent System\n# Generated by devplaybook.cc/tools/crewai-agent-config-generator\n\n`;
    code += `from crewai import Agent, Task, Crew, Process\n`;
    if (toolImports.length > 0) {
      code += `from crewai_tools import ${toolImports.join(', ')}\n`;
    }
    code += `\n# Initialize tools\n`;
    toolImports.forEach(t => { code += `${t.toLowerCase().replace(/tool$/i, '_tool')} = ${t}()\n`; });
    code += `\n# Define agents\n`;
    agents.forEach(a => {
      const varName = a.role.toLowerCase().replace(/\s+/g, '_').replace(/[^a-z0-9_]/g, '');
      code += `${varName} = Agent(\n`;
      code += `    role="${a.role}",\n`;
      code += `    goal="${a.goal}",\n`;
      code += `    backstory="""\n        ${a.backstory}\n    """,\n`;
      code += `    verbose=${a.verbose},\n`;
      code += `    allow_delegation=${a.delegation},\n`;
      if (a.tools.length > 0) {
        code += `    tools=[${a.tools.map(t => t.toLowerCase().replace(/tool$/i, '_tool')).join(', ')}],\n`;
      }
      code += `)\n\n`;
    });

    code += `# Define tasks\n`;
    tasks.forEach(t => {
      const agentObj = agents.find(a => a.id === t.agent);
      const agentVar = agentObj ? agentObj.role.toLowerCase().replace(/\s+/g, '_').replace(/[^a-z0-9_]/g, '') : 'agent';
      code += `${t.name} = Task(\n`;
      code += `    description="""\n        ${t.description}\n    """,\n`;
      code += `    expected_output="${t.expected}",\n`;
      code += `    agent=${agentVar},\n`;
      code += `)\n\n`;
    });

    const agentVars = agents.map(a => a.role.toLowerCase().replace(/\s+/g, '_').replace(/[^a-z0-9_]/g, ''));
    const taskVars = tasks.map(t => t.name);
    code += `# Assemble crew\ncrew = Crew(\n`;
    code += `    agents=[${agentVars.join(', ')}],\n`;
    code += `    tasks=[${taskVars.join(', ')}],\n`;
    code += `    process=Process.sequential,\n`;
    code += `    verbose=True,\n)\n\n`;
    code += `# Run the crew\nresult = crew.kickoff(inputs={"topic": "your topic here"})\nprint(result)\n`;
    return code;
  }

  function generateOutput() {
    document.getElementById('code-output').textContent = activeTab === 'yaml' ? generateYAML() : generatePython();
  }

  document.getElementById('btn-add-agent').addEventListener('click', () => {
    agents.push(newAgent());
    renderAgents();
    renderTasks();
  });

  document.getElementById('btn-add-task').addEventListener('click', () => {
    tasks.push(newTask());
    renderTasks();
  });

  document.querySelectorAll('.output-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.output-tab').forEach(b => b.classList.remove('active', 'border-primary', 'text-primary', 'bg-primary/10'));
      btn.classList.add('active', 'border-primary', 'text-primary', 'bg-primary/10');
      activeTab = btn.dataset.tab;
      generateOutput();
    });
  });

  document.getElementById('btn-copy-output').addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('code-output').textContent).then(() => {
      const btn = document.getElementById('btn-copy-output');
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 1500);
    });
  });

  document.querySelectorAll('.template-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tpl = TEMPLATES[btn.dataset.template];
      agentCounter = 0; taskCounter = 0;
      agents = tpl.agents.map(a => ({ ...a }));
      tasks = tpl.tasks.map(t => ({ ...t }));
      renderAgents();
      renderTasks();
    });
  });

  // Load default template
  const tpl = TEMPLATES.research;
  agents = tpl.agents.map(a => ({ ...a }));
  tasks = tpl.tasks.map(t => ({ ...t }));
  renderAgents();
  renderTasks();
})();
</script>

  <FaqSection faq={faq} />
</BaseLayout>
