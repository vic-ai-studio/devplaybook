---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is the difference between prefetch, preload, and preconnect?", answer: "Preload (`rel='preload'`) fetches a resource needed for the current page at high priority — use for LCP images, critical fonts, and key scripts. Prefetch (`rel='prefetch'`) downloads a resource for a future navigation at low priority during idle time — use for next-page assets. Preconnect (`rel='preconnect'`) establishes a TCP+TLS connection to an origin without downloading anything — use for third-party origins you'll definitely need (CDN, fonts, APIs). DNS-prefetch is cheaper than preconnect (only DNS, no TLS) — use for origins you might need." },
  { question: "When should I use preload vs prefetch?", answer: "Use preload for resources the current page needs urgently (within the first few seconds): the LCP hero image, the main font, critical above-fold scripts. Over-preloading wastes bandwidth and competes with critical resources. Use prefetch for resources the user will likely need next: the next page's main JS chunk, the next blog post's images, a modal component that's likely to be opened. Never preload everything — it defeats the purpose." },
  { question: "Can I preload dynamic imports in webpack/Vite?", answer: "Yes. Webpack supports magic comments: `import(/* webpackPrefetch: true */ './NextPage')` adds a prefetch hint automatically. For preload: `import(/* webpackPreload: true */ './CriticalModule')`. In Vite/Rollup, use `/* @vite-ignore */` or configure `build.rollupOptions.output.experimentalMinChunkSize`. React Router, Next.js, and Astro all auto-generate prefetch hints for in-viewport links by default." },
  { question: "What is the modulepreload link type?", answer: "The `rel='modulepreload'` link type preloads ES module scripts (and their dependencies) ahead of time, including parsing and compilation. It's more efficient than `rel='preload' as='script'` for ES modules because the browser can parse and compile the module immediately, not just download it. Use it for critical ES module entry points. Modern bundlers like Vite automatically generate modulepreload links for split chunks in the build output." },
];
---

<BaseLayout
  title="Prefetch, Preload & Preconnect Guide — Resource Hints for Faster Navigation"
  description="Use browser resource hints correctly: preload critical assets, prefetch next-page resources, preconnect to third-party origins, and avoid over-preloading that wastes bandwidth."
  tool="preload, prefetch, preconnect, dns-prefetch, resource hints, modulepreload, LCP, performance, link rel"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Prefetch Preload Preconnect Resource Hints Guide",
    "url": "https://devplaybook.cc/tools/prefetch-preload-guide",
    "description": "Use preload, prefetch, and preconnect hints correctly to speed up page loads and navigation.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Prefetch, Preload & Preconnect Guide</h1>
  <p class="text-text-muted mb-6">
    <strong>Resource hints</strong> tell the browser what to fetch, compile, or connect to before it's needed. Used correctly, they eliminate critical resource delays. Used incorrectly, they waste bandwidth and compete with important assets.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> preload vs prefetch</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> preconnect setup</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> modulepreload</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Webpack magic comments</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Resource Hints Quick Reference</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Hint</th>
          <th class="border border-border px-3 py-2 text-left">What It Does</th>
          <th class="border border-border px-3 py-2 text-left">Priority</th>
          <th class="border border-border px-3 py-2 text-left">Use For</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2 font-mono text-xs">preload</td><td class="border border-border px-3 py-2">Download resource for current page</td><td class="border border-border px-3 py-2 text-green-400">High</td><td class="border border-border px-3 py-2">LCP image, critical font, key script</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2 font-mono text-xs">prefetch</td><td class="border border-border px-3 py-2">Download resource for next page (idle)</td><td class="border border-border px-3 py-2 text-yellow-400">Lowest</td><td class="border border-border px-3 py-2">Next route JS chunk, future images</td></tr>
        <tr><td class="border border-border px-3 py-2 font-mono text-xs">preconnect</td><td class="border border-border px-3 py-2">DNS + TCP + TLS handshake to origin</td><td class="border border-border px-3 py-2 text-yellow-400">Medium</td><td class="border border-border px-3 py-2">CDN, fonts.gstatic.com, API origins</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2 font-mono text-xs">dns-prefetch</td><td class="border border-border px-3 py-2">DNS lookup only (cheap)</td><td class="border border-border px-3 py-2 text-green-400">Low</td><td class="border border-border px-3 py-2">Origins you might need</td></tr>
        <tr><td class="border border-border px-3 py-2 font-mono text-xs">modulepreload</td><td class="border border-border px-3 py-2">Fetch + parse + compile ES module</td><td class="border border-border px-3 py-2 text-green-400">High</td><td class="border border-border px-3 py-2">Critical ES module entry points</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">HTML Usage Examples</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">&lt;head&gt;
  &lt;!-- Preload LCP hero image (critical — always include) --&gt;
  &lt;link rel="preload" as="image" href="/hero.avif" fetchpriority="high"&gt;

  &lt;!-- Preload critical font --&gt;
  &lt;link rel="preload" as="font" href="/fonts/inter-var.woff2"
    type="font/woff2" crossorigin&gt;

  &lt;!-- Preconnect to critical third-party origins --&gt;
  &lt;link rel="preconnect" href="https://fonts.gstatic.com" crossorigin&gt;
  &lt;link rel="preconnect" href="https://cdn.example.com"&gt;

  &lt;!-- DNS-prefetch for analytics (may use, not certain) --&gt;
  &lt;link rel="dns-prefetch" href="https://analytics.example.com"&gt;

  &lt;!-- Prefetch next page bundle (user likely to navigate) --&gt;
  &lt;link rel="prefetch" href="/js/dashboard.chunk.js" as="script"&gt;

  &lt;!-- modulepreload for ES module entry point --&gt;
  &lt;link rel="modulepreload" href="/js/app.mjs"&gt;
&lt;/head&gt;</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Webpack Magic Comments</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// Prefetch: low-priority load during idle time
// → generates &lt;link rel="prefetch"&gt; for the chunk
const NextPage = React.lazy(
  () => import(/* webpackPrefetch: true */ './pages/NextPage')
);

// Preload: high-priority, loaded with parent chunk
// → generates &lt;link rel="preload"&gt; for the chunk
const CriticalModule = React.lazy(
  () => import(/* webpackPreload: true */ './CriticalModule')
);

// Named chunk + prefetch
const AdminPage = React.lazy(
  () => import(
    /* webpackChunkName: "admin" */
    /* webpackPrefetch: true */
    './pages/Admin'
  )
);</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Programmatic Prefetch</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// Prefetch on hover (user likely to click)
function PrefetchLink(&#123; href, children &#125;) &#123;
  const prefetch = () => &#123;
    const link = document.createElement('link');
    link.rel = 'prefetch';
    link.href = href;
    document.head.appendChild(link);
  &#125;;

  return (
    &lt;a href=&#123;href&#125; onMouseEnter=&#123;prefetch&#125; onFocus=&#123;prefetch&#125;&gt;
      &#123;children&#125;
    &lt;/a&gt;
  );
&#125;

// Prefetch when link enters viewport (Intersection Observer)
const io = new IntersectionObserver(entries => &#123;
  entries.forEach(entry => &#123;
    if (entry.isIntersecting) &#123;
      const url = entry.target.getAttribute('data-prefetch');
      if (url) fetch(url, &#123; priority: 'low' &#125;);
    &#125;
  &#125;);
&#125;);

document.querySelectorAll('[data-prefetch]').forEach(el => io.observe(el));</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Common Mistakes to Avoid</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Preloading too many resources</strong> — Each preload competes for bandwidth. Limit to 2–3 critical assets</li>
    <li><strong>Missing <code class="font-mono text-xs bg-bg-card px-1 rounded">as</code> attribute on preload</strong> — Without <code class="font-mono text-xs bg-bg-card px-1 rounded">as</code>, the browser downloads twice (once for preload, once for use)</li>
    <li><strong>Missing <code class="font-mono text-xs bg-bg-card px-1 rounded">crossorigin</code> on font preload</strong> — Fonts fetched without CORS attributes trigger a duplicate download</li>
    <li><strong>Preconnecting to every third party</strong> — Unused preconnections tie up sockets. Limit to 4–6 origins</li>
    <li><strong>Using prefetch for current-page resources</strong> — Prefetch has lowest priority; use preload instead</li>
  </ul>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Prefetch Preload Preconnect Guide" relatedTags={['performance', 'resource-hints', 'preload', 'prefetch', 'lcp', 'core-web-vitals']} />
</BaseLayout>
