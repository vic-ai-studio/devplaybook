---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What should I do if I accidentally committed a secret to Git?", answer: "Act immediately — assume the secret is compromised. (1) Revoke the secret: rotate your API key, database password, or credential NOW — before any cleanup. (2) Remove from Git history using git-filter-repo (preferred over filter-branch): 'pip install git-filter-repo && git filter-repo --path .env --invert-paths'. (3) Force-push to all branches (coordinate with team). (4) If pushed to a public repo, the secret has been scraped by bots within seconds — revocation is the only real fix. GitHub Secret Scanning can alert you automatically if you enable it." },
  { question: "What is the difference between environment variables and a secrets manager?", answer: "Environment variables are simple name-value pairs injected into process memory at startup. They're easy to use but have limitations: no versioning, no audit trail, no automatic rotation, accessible to any process in the same environment, often end up in CI logs or crash dumps. Secrets managers (Vault, AWS Secrets Manager, GCP Secret Manager) add: centralized storage with encryption at rest, fine-grained access control, automatic rotation, full audit logs, secret leasing with TTLs, and dynamic secrets (new credentials generated per-request). For serious production use, a secrets manager is worth the complexity." },
  { question: "What are dynamic secrets and why are they valuable?", answer: "Dynamic secrets are credentials generated on-demand for a specific request, with a short TTL, and automatically revoked when the lease expires. HashiCorp Vault can generate dynamic database credentials (a unique username/password per application instance), AWS IAM credentials, or SSH certificates. The value: if credentials are compromised, they expire quickly; there's no long-lived static secret to steal; and every access is audited. For databases, dynamic secrets mean zero shared passwords — each service gets its own unique credentials." },
  { question: "How do I inject secrets into Kubernetes pods securely?", answer: "Options from least to most secure: (1) Kubernetes Secrets (base64-encoded, etcd stored) — better than ConfigMaps but not encrypted by default. Enable encryption at rest and restrict RBAC. (2) External Secrets Operator — syncs secrets from Vault/AWS/GCP into Kubernetes Secrets, with automatic refresh. (3) Vault Agent Sidecar — injects secrets as files into the pod, auto-renews, never stored in etcd. (4) CSI Secrets Store Driver — mounts secrets as files from external providers. Avoid environment variables for sensitive secrets in Kubernetes — they're visible in pod specs and logs." },
  { question: "What is secret zero / bootstrapping problem in secrets management?", answer: "Secret zero is the chicken-and-egg problem: to fetch secrets from a secrets manager, your application needs a credential to authenticate to that manager — but how do you securely provide that initial credential? Solutions: (1) Cloud IAM roles — on AWS, use EC2/ECS/Lambda instance profiles; no secret needed, authentication is via metadata service. (2) Vault AppRole with wrapped tokens — short-lived, single-use tokens injected at deploy time. (3) Kubernetes service accounts — pods authenticate to Vault using their Kubernetes JWT, no static secret required. Platform-provided identity (IAM roles) is the gold standard solution." },
  { question: "How do I prevent secrets from appearing in CI/CD logs?", answer: "CI/CD platforms (GitHub Actions, GitLab CI, CircleCI) mask registered secrets in logs, but this isn't foolproof — secrets in unexpected contexts or sub-commands may not be masked. Best practices: (1) Register all secrets as masked/protected variables in your CI platform. (2) Never echo or print secret values — use 'set +x' in bash before secret-using commands. (3) Use OIDC-based authentication (GitHub Actions OIDC → AWS IAM) to eliminate static secrets entirely. (4) Add a pre-commit hook with detect-secrets or truffleHog to catch secrets before they're committed. (5) Run truffleHog or gitleaks in CI to scan the git history." },
];
---

<BaseLayout
  title="Secrets Management Guide: HashiCorp Vault, AWS Secrets Manager & Best Practices"
  description="Complete secrets management guide covering .env best practices, HashiCorp Vault, AWS Secrets Manager, GCP Secret Manager, Doppler, and CI/CD secret injection. Never commit secrets again."
  tool="Secrets Management, HashiCorp Vault, AWS Secrets Manager, Doppler, Secret Zero, CI/CD Secrets"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Secrets Management Guide: HashiCorp Vault, AWS Secrets Manager & Best Practices",
    "url": "https://devplaybook.cc/tools/secrets-management-guide",
    "description": "Complete guide to secrets management covering Vault, AWS Secrets Manager, GCP, Doppler, .env best practices, and CI/CD injection.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Secrets Management Guide</h1>
  <p class="text-text-muted mb-6">API keys, database passwords, and certificates are the most sensitive assets in your infrastructure. This guide covers everything from basic .env hygiene to enterprise-grade secrets management with HashiCorp Vault and cloud-native solutions.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> .env best practices</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Vault & AWS Secrets Manager</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CI/CD secret injection</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Git secret scanning</span>
  </div>

  <h2 class="text-xl font-semibold mb-3">The Golden Rules of Secrets</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
    <div class="bg-bg-card border border-red-500/30 rounded-xl p-4">
      <h3 class="font-semibold text-red-400 mb-2">Never Do These</h3>
      <ul class="text-sm text-text-muted space-y-1">
        <li>❌ Commit .env files or secrets to Git</li>
        <li>❌ Hardcode secrets in source code</li>
        <li>❌ Log secret values (even at debug level)</li>
        <li>❌ Pass secrets as CLI arguments (visible in ps)</li>
        <li>❌ Store secrets in Docker image layers</li>
        <li>❌ Share secrets over Slack or email</li>
        <li>❌ Use the same secret across environments</li>
      </ul>
    </div>
    <div class="bg-bg-card border border-green-500/30 rounded-xl p-4">
      <h3 class="font-semibold text-green-400 mb-2">Always Do These</h3>
      <ul class="text-sm text-text-muted space-y-1">
        <li>✅ Add .env to .gitignore immediately</li>
        <li>✅ Rotate secrets regularly and on suspected compromise</li>
        <li>✅ Use least-privilege access for all secrets</li>
        <li>✅ Audit who accessed what secret and when</li>
        <li>✅ Use different secrets per environment</li>
        <li>✅ Use platform IAM roles when possible (no static secrets)</li>
        <li>✅ Scan git history regularly with truffleHog</li>
      </ul>
    </div>
  </div>

  <h2 class="text-xl font-semibold mb-3">.env File Best Practices</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># .gitignore — add these immediately
.env
.env.local
.env.*.local
.env.production
*.pem
*.key
secrets.json
credentials.json</pre>

  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># .env.example — commit this (no real values)
# Copy to .env and fill in values
DATABASE_URL=postgresql://user:password@localhost:5432/mydb
API_KEY=your-api-key-here
JWT_SECRET=your-256-bit-random-secret
STRIPE_SECRET_KEY=sk_test_...
SENDGRID_API_KEY=SG....</pre>

  <h3 class="text-base font-semibold mb-2">Validate Required Env Vars at Startup</h3>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-6">// config.ts — validate secrets at app startup, fail fast
import &#123; z &#125; from 'zod';

const envSchema = z.object(&#123;
  DATABASE_URL: z.string().url(),
  JWT_SECRET: z.string().min(32, 'JWT_SECRET must be at least 32 chars'),
  API_KEY: z.string().min(20),
  NODE_ENV: z.enum(['development', 'production', 'test']),
&#125;);

const _env = envSchema.safeParse(process.env);
if (!_env.success) &#123;
  console.error('❌ Invalid environment variables:', _env.error.flatten().fieldErrors);
  process.exit(1);  // Fail loudly at startup
&#125;

export const env = _env.data;</pre>

  <h2 class="text-xl font-semibold mb-3">HashiCorp Vault</h2>
  <p class="text-text-muted mb-4">Vault is the most feature-complete open-source secrets manager. It provides dynamic secrets, secret leasing, automatic rotation, fine-grained policies, and multiple auth methods.</p>

  <h3 class="text-base font-semibold mb-2">Basic Setup & KV Secrets</h3>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Start dev server (for testing only — data not persisted)
vault server -dev

# Set environment
export VAULT_ADDR='http://127.0.0.1:8200'
export VAULT_TOKEN='your-root-token'

# Enable KV v2 secrets engine
vault secrets enable -path=secret kv-v2

# Write a secret
vault kv put secret/myapp/database \
  url="postgresql://..." \
  password="super-secret-pass"

# Read a secret
vault kv get secret/myapp/database

# Read as JSON (for scripting)
vault kv get -format=json secret/myapp/database \
  | jq -r '.data.data.password'</pre>

  <h3 class="text-base font-semibold mb-2">Dynamic Database Credentials</h3>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Enable database secrets engine
vault secrets enable database

# Configure PostgreSQL connection
vault write database/config/mydb \
  plugin_name=postgresql-database-plugin \
  allowed_roles="app-role" \
  connection_url="postgresql://&#123;&#123;username&#125;&#125;:&#123;&#123;password&#125;&#125;@db.example.com:5432/mydb" \
  username="vault-admin" \
  password="vault-admin-pass"

# Create a role — Vault generates unique creds per request
vault write database/roles/app-role \
  db_name=mydb \
  creation_statements="CREATE ROLE \"&#123;&#123;name&#125;&#125;\" WITH LOGIN PASSWORD '&#123;&#123;password&#125;&#125;' VALID UNTIL '&#123;&#123;expiration&#125;&#125;'; GRANT SELECT ON ALL TABLES IN SCHEMA public TO \"&#123;&#123;name&#125;&#125;\";" \
  default_ttl="1h" \
  max_ttl="24h"

# Generate dynamic credentials
vault read database/creds/app-role
# Returns: username=v-myapp-xxxx, password=A1b2C3d4 (expires in 1h)</pre>

  <h3 class="text-base font-semibold mb-2">Node.js Vault Client</h3>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-6">import NodeVault from 'node-vault';

const vault = NodeVault(&#123;
  apiVersion: 'v1',
  endpoint: process.env.VAULT_ADDR,
  token: process.env.VAULT_TOKEN,  // Or use AppRole auth
&#125;);

async function getSecret(path: string): Promise<Record<string, string>> &#123;
  const result = await vault.read(path);
  return result.data.data;  // KV v2
&#125;

// At startup: fetch all needed secrets
const dbSecrets = await getSecret('secret/myapp/database');
const db = createPool(&#123; connectionString: dbSecrets.url &#125;);</pre>

  <h2 class="text-xl font-semibold mb-3">AWS Secrets Manager</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Create a secret
aws secretsmanager create-secret \
  --name "prod/myapp/database" \
  --description "Production DB credentials" \
  --secret-string '&#123;"url":"postgresql://...","password":"..."&#125;'

# Retrieve in shell
aws secretsmanager get-secret-value \
  --secret-id "prod/myapp/database" \
  --query SecretString \
  --output text | jq '.'

# Enable automatic rotation (requires Lambda rotation function)
aws secretsmanager rotate-secret \
  --secret-id "prod/myapp/database" \
  --rotation-lambda-arn arn:aws:lambda:... \
  --rotation-rules AutomaticallyAfterDays=30</pre>

  <h3 class="text-base font-semibold mb-2">Node.js AWS SDK Integration</h3>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-6">import &#123; SecretsManagerClient, GetSecretValueCommand &#125; from "@aws-sdk/client-secrets-manager";

const client = new SecretsManagerClient(&#123; region: "us-east-1" &#125;);
// Uses EC2 instance profile / ECS task role — no static credentials!

async function getSecret(secretId: string): Promise<Record<string, string>> &#123;
  const response = await client.send(
    new GetSecretValueCommand(&#123; SecretId: secretId &#125;)
  );
  return JSON.parse(response.SecretString!);
&#125;

// Cache at startup, refresh periodically
let cachedSecrets: Record<string, string> | null = null;
export async function getDbConfig() &#123;
  if (!cachedSecrets) &#123;
    cachedSecrets = await getSecret('prod/myapp/database');
  &#125;
  return cachedSecrets;
&#125;</pre>

  <h2 class="text-xl font-semibold mb-3">Secrets Manager Comparison</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm mb-6">
      <thead>
        <tr class="border-b border-border text-left text-text-muted">
          <th class="py-2 pr-4">Tool</th>
          <th class="py-2 pr-4">Cost</th>
          <th class="py-2 pr-4">Dynamic Secrets</th>
          <th class="py-2 pr-4">Auto Rotation</th>
          <th class="py-2">Best For</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <tr><td class="py-2 pr-4 font-medium">HashiCorp Vault</td><td class="py-2 pr-4">Open source / Enterprise</td><td class="py-2 pr-4 text-green-500">Yes (core feature)</td><td class="py-2 pr-4 text-green-500">Yes</td><td class="py-2 text-text-muted">Self-hosted, complex needs</td></tr>
        <tr><td class="py-2 pr-4 font-medium">AWS Secrets Manager</td><td class="py-2 pr-4">$0.40/secret/month</td><td class="py-2 pr-4 text-yellow-500">Via Lambda</td><td class="py-2 pr-4 text-green-500">Yes (native)</td><td class="py-2 text-text-muted">AWS-native workloads</td></tr>
        <tr><td class="py-2 pr-4 font-medium">GCP Secret Manager</td><td class="py-2 pr-4">$0.06/version/month</td><td class="py-2 pr-4 text-red-500">No</td><td class="py-2 pr-4 text-yellow-500">Manual</td><td class="py-2 text-text-muted">GCP workloads</td></tr>
        <tr><td class="py-2 pr-4 font-medium">Doppler</td><td class="py-2 pr-4">Free tier / $6/user</td><td class="py-2 pr-4 text-red-500">No</td><td class="py-2 pr-4 text-yellow-500">Some integrations</td><td class="py-2 text-text-muted">Developer UX, multi-cloud</td></tr>
        <tr><td class="py-2 pr-4 font-medium">Azure Key Vault</td><td class="py-2 pr-4">$0.03/10k operations</td><td class="py-2 pr-4 text-red-500">No</td><td class="py-2 pr-4 text-green-500">Yes</td><td class="py-2 text-text-muted">Azure workloads</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mb-3">Scanning Git History for Leaked Secrets</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># truffleHog — scans git history for high-entropy strings and regex patterns
pip install trufflehog
trufflehog git https://github.com/yourorg/yourrepo --only-verified

# gitleaks — fast Go-based scanner
brew install gitleaks
gitleaks detect --source . -v

# Run as pre-commit hook (.pre-commit-config.yaml)
# repos:
#   - repo: https://github.com/gitleaks/gitleaks
#     rev: v8.18.0
#     hooks:
#       - id: gitleaks

# detect-secrets — Yelp's tool, good for CI
pip install detect-secrets
detect-secrets scan > .secrets.baseline
detect-secrets audit .secrets.baseline  # review findings</pre>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Secrets Management Guide" relatedTags={['security', 'devops', 'backend', 'cloud']} />
</BaseLayout>
