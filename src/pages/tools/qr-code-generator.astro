---
import BaseLayout from '../../layouts/BaseLayout.astro';
import QrCodeGenerator from '../../components/QrCodeGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What types of content can I encode in a QR code?", answer: "This tool generates QR codes for URLs, plain text, email addresses, phone numbers, WiFi credentials (SSID, password, encryption type), and SMS messages. Each type follows the standard URI scheme so any QR scanner can read it." },
  { question: "What is error correction level and which should I use?", answer: "Error correction lets a QR code remain scannable even when partially damaged. Level L recovers ~7%, M ~15%, Q ~25%, and H ~30% of data. Use L for digital screens (clean environment) and H for printed materials that may get scratched or dirty." },
  { question: "Can I customize the colors of my QR code?", answer: "Yes. You can set both the foreground (dark modules) and background colors. Keep high contrast between them — scanners need a clear difference. Avoid light foreground on dark background, as some readers struggle with inverted codes." },
  { question: "What image format is the download?", answer: "QR codes are downloaded as PNG images at the size you choose. PNG is ideal because it preserves sharp edges at any resolution. For print, generate at a larger size (e.g. 1024px) to avoid pixelation." },
  { question: "Is there a character limit for QR codes?", answer: "Yes. QR codes can encode up to ~4,296 alphanumeric characters or ~2,953 bytes of binary data. In practice, shorter content produces smaller, faster-to-scan codes. URLs under 100 characters work best for reliable scanning." },
];
---

<BaseLayout
  title="QR Code Generator — Free Online QR Code Creator (URL, WiFi, Text)"
  description="Generate QR codes for URLs, text, WiFi credentials, email, phone numbers, and SMS messages. Customize foreground and background colors, choose error correction levels (L/M/Q/H), and download as high-resolution PNG. Perfect for restaurant menus, event check-ins, WiFi sharing, and app deep links. Free, no signup, no watermark."
  tool="QR Code Generator, Free QR Code, WiFi QR Code, URL QR Code, Custom QR Code"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">QR Code Generator</h1>
  <p class="text-text-muted mb-4">Generate QR codes for URLs, text, email addresses, phone numbers, WiFi credentials, and SMS. Customize colors, error correction level, and size. Download as PNG — no signup, no watermark.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <QrCodeGenerator client:only="preact" />
  <!-- Real-World Use Cases -->
  <section class="mt-12 mb-8">
    <h2 class="text-2xl font-bold mb-6">Real-World Use Cases</h2>

    <div class="space-y-6">
      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">1. Guest WiFi QR Code for Your Office or Cafe</h3>
        <p class="text-text-muted mb-3">Instead of printing the WiFi password on a card, generate a QR code that guests scan to connect automatically. Works on both iOS and Android — no typing needed.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Settings</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`Type: WiFi\nSSID: CafeGuest\nPassword: welcome2026\nEncryption: WPA\nError Correction: H (high)`}</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Result</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`Encoded: WIFI:T:WPA;S:CafeGuest;\n         P:welcome2026;;\n\nScan with phone camera\n→ Auto-joins WiFi network\n→ Download as 1024px PNG for print`}</pre>
          </div>
        </div>
      </div>

      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">2. Event Check-In with URL QR Codes</h3>
        <p class="text-text-muted mb-3">Print QR codes on conference badges or event tickets that link to a check-in page with attendee ID. Attendees scan the code to confirm attendance instantly.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Input URL</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`https://event.example.com\n/checkin?id=ATT-2026-0405`}</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Settings</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`Size: 512px (good for badges)\nError Correction: Q (25%)\nColors: brand navy + white\n\n→ Print at 300 DPI on badge`}</pre>
          </div>
        </div>
      </div>

      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">3. App Store Deep Link for Product Packaging</h3>
        <p class="text-text-muted mb-3">Place a QR code on your product's physical packaging that opens the companion app on both iOS and Android using a universal link or smart redirect URL.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Input URL</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">https://myapp.com/download</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Settings</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`Size: 1024px (print-ready)\nError Correction: H (30%)\n  → survives scratches\nColors: black + transparent BG\n\n→ Export PNG for print designer`}</pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Step-by-Step Guide -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">How to Use — Step by Step</h2>
    <ol class="list-decimal list-inside space-y-3 text-text-muted">
      <li><strong>Choose content type</strong> — Select URL, Text, WiFi, Email, Phone, or SMS from the type selector. Each type formats the data correctly for universal scanner compatibility.</li>
      <li><strong>Enter your content</strong> — Paste a URL, type WiFi credentials, or enter the text to encode. The QR code preview updates in real-time.</li>
      <li><strong>Set error correction</strong> — Use <strong>L</strong> (7%) for screens, <strong>M</strong> (15%) for general use, <strong>Q</strong> (25%) for printed materials, or <strong>H</strong> (30%) for harsh environments.</li>
      <li><strong>Customize colors</strong> — Pick foreground and background colors. Keep high contrast for reliable scanning — dark foreground on light background works best.</li>
      <li><strong>Download</strong> — Click download to save as PNG at your chosen size. For print, use 1024px or larger to avoid pixelation at 300 DPI.</li>
    </ol>
  </section>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="QR Code Generator" relatedTags={['qr', 'url', 'encoding', 'sharing', 'mobile']} />
</BaseLayout>
