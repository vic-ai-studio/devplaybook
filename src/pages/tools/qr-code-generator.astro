---
import BaseLayout from '../../layouts/BaseLayout.astro';
import QrCodeGenerator from '../../components/QrCodeGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="QR Code Generator"
  description="Generate QR codes for URLs, text, WiFi credentials, email, phone numbers, and more. Custom colors, error correction levels, and PNG download. Free, no signup."
  tool="QR Code Generator, Free QR Code, WiFi QR Code, URL QR Code, Custom QR Code"
>
  <h1 class="text-3xl font-bold mb-2">QR Code Generator</h1>
  <p class="text-text-muted mb-8">Generate QR codes for URLs, text, email addresses, phone numbers, WiFi credentials, and SMS. Customize colors, error correction level, and size. Download as PNG — no signup, no watermark.</p>
  <QrCodeGenerator client:only="preact" />
  <ToolPageCta currentTool="QR Code Generator" relatedTags={['qr', 'url', 'encoding', 'sharing', 'mobile']} />
</BaseLayout>
