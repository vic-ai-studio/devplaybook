---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is the learning rate and why does it matter?",
    answer: "The learning rate (LR) is a hyperparameter that controls how much model weights change in response to the estimated error during training. Too high and the model diverges or oscillates; too low and training is painfully slow and can get stuck in local minima. It is arguably the most impactful single hyperparameter to tune — the right LR can mean the difference between a model that converges in hours versus one that never converges at all."
  },
  {
    question: "What is the LR Range Test (LR Finder)?",
    answer: "The LR Range Test, introduced by Leslie Smith in 2015, involves starting training with a very small LR (e.g., 1e-7) and exponentially increasing it each mini-batch. You plot the loss against the LR — the loss will initially decrease, then start rising steeply. The optimal LR is typically 1–2 orders of magnitude below the point of steepest increase. This test takes only a few hundred iterations and is far more efficient than a full grid search."
  },
  {
    question: "What is learning rate warmup and when should I use it?",
    answer: "Warmup gradually increases the LR from a small value (near zero) to the target LR over the first N steps. It prevents early instability when model weights are random and gradients are noisy. Warmup is strongly recommended for: (1) transformer/attention-based models (BERT, GPT, ViT), (2) large batch training (batch size ≥ 512), (3) Adam and its variants, (4) fine-tuning pretrained models. A common rule is warmup for 5–10% of total training steps."
  },
  {
    question: "What is the difference between step decay, cosine annealing, and cyclical LR?",
    answer: "Step decay reduces the LR by a fixed factor (e.g., ÷10) every N epochs — simple and predictable. Cosine annealing smoothly decays the LR following a cosine curve from max to min, which often leads to better final loss because the smooth transitions avoid jarring changes. Cyclical LR (CLR) oscillates between a minimum and maximum LR, allowing the model to periodically escape local minima — effective for training from scratch. For modern deep learning, cosine annealing with warmup (used by most SOTA papers) is the default safe choice."
  },
  {
    question: "How does batch size affect the learning rate?",
    answer: "Larger batches produce more accurate gradient estimates, which means you can use a proportionally higher LR without instability. The 'linear scaling rule' (Goyal et al., 2017) suggests scaling LR linearly with batch size: if you double the batch size, double the LR. However, this rule breaks down for very large batches (> 8K) where warmup and careful tuning become essential. Smaller batches introduce noise that acts as a regularizer, allowing smaller models to sometimes generalize better with lower LRs."
  },
];
---

<BaseLayout
  title="Neural Network Learning Rate Calculator & Finder — LR Schedule, Warmup, Range Test"
  description="Calculate the optimal learning rate for your neural network. Get recommendations for SGD, Adam, RMSprop, AdaGrad with step decay, cosine annealing, and cyclical LR schedules. Includes warmup steps and LR range test bounds."
  tool="learning rate calculator, LR finder, learning rate schedule, neural network hyperparameter tuning, cosine annealing, learning rate warmup"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Neural Network Learning Rate Calculator</h1>
  <p class="text-text-muted mb-4">Input your training setup to get a recommended initial learning rate, schedule strategy, warmup steps, and LR range test bounds — all based on established deep learning best practices.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 4 optimizers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 3 LR schedules</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Warmup calculator</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> LR range test bounds</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Visual schedule curve</span>
  </div>

  <!-- Inputs -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-5 space-y-4">
      <h2 class="text-base font-semibold">Training Configuration</h2>

      <div>
        <label class="block text-xs font-medium text-text-muted mb-1.5">Optimizer</label>
        <select id="optimizer"
          class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-primary">
          <option value="adam">Adam / AdamW</option>
          <option value="sgd">SGD (with momentum)</option>
          <option value="rmsprop">RMSprop</option>
          <option value="adagrad">AdaGrad</option>
        </select>
      </div>

      <div>
        <label class="block text-xs font-medium text-text-muted mb-1.5">Task Type</label>
        <select id="task-type"
          class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-primary">
          <option value="classification">Image / Tabular Classification</option>
          <option value="regression">Regression</option>
          <option value="nlp">NLP / Transformer Fine-tuning</option>
        </select>
      </div>

      <div>
        <label class="block text-xs font-medium text-text-muted mb-1.5">Model Architecture Size</label>
        <select id="model-size"
          class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-primary">
          <option value="small">Small (&lt; 10M params — MobileNet, tiny MLP)</option>
          <option value="medium" selected>Medium (10M–100M — ResNet-50, BERT-base)</option>
          <option value="large">Large (100M–1B — ResNet-152, GPT-2)</option>
          <option value="xl">XL (&gt; 1B — GPT-3 scale, LLM)</option>
        </select>
      </div>
    </div>

    <div class="bg-bg-card border border-border rounded-xl p-5 space-y-4">
      <h2 class="text-base font-semibold">Dataset & Training Settings</h2>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1.5">Batch Size</label>
          <input id="batch-size" type="number" value="32" min="1"
            class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-primary font-mono" />
          <div class="flex gap-1.5 mt-1.5 flex-wrap">
            <button class="bs-preset text-xs px-2 py-0.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-val="16">16</button>
            <button class="bs-preset text-xs px-2 py-0.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-val="32">32</button>
            <button class="bs-preset text-xs px-2 py-0.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-val="64">64</button>
            <button class="bs-preset text-xs px-2 py-0.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-val="128">128</button>
            <button class="bs-preset text-xs px-2 py-0.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-val="256">256</button>
          </div>
        </div>

        <div>
          <label class="block text-xs font-medium text-text-muted mb-1.5">Dataset Size (samples)</label>
          <input id="dataset-size" type="number" value="50000" min="1"
            class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-primary font-mono" />
          <div class="flex gap-1.5 mt-1.5 flex-wrap">
            <button class="ds-preset text-xs px-2 py-0.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-val="1000">1K</button>
            <button class="ds-preset text-xs px-2 py-0.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-val="10000">10K</button>
            <button class="ds-preset text-xs px-2 py-0.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-val="50000">50K</button>
            <button class="ds-preset text-xs px-2 py-0.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-val="1000000">1M</button>
          </div>
        </div>
      </div>

      <div>
        <label class="block text-xs font-medium text-text-muted mb-1.5">Number of Epochs</label>
        <input id="num-epochs" type="number" value="50" min="1"
          class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:border-primary font-mono" />
        <div class="flex gap-1.5 mt-1.5 flex-wrap">
          <button class="ep-preset text-xs px-2 py-0.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-val="10">10</button>
          <button class="ep-preset text-xs px-2 py-0.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-val="30">30</button>
          <button class="ep-preset text-xs px-2 py-0.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-val="50">50</button>
          <button class="ep-preset text-xs px-2 py-0.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-val="100">100</button>
          <button class="ep-preset text-xs px-2 py-0.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-val="300">300</button>
        </div>
      </div>

      <button id="calc-btn"
        class="w-full py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">
        Calculate Learning Rate
      </button>
    </div>
  </div>

  <!-- Results -->
  <div id="results-section" class="hidden space-y-5 mb-6">

    <!-- Key outputs row -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
        <p class="text-xs text-text-muted mb-1">Recommended Initial LR</p>
        <p id="res-initial-lr" class="text-2xl font-bold font-mono text-primary">—</p>
        <p class="text-xs text-text-muted mt-1">starting value</p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
        <p class="text-xs text-text-muted mb-1">Minimum LR</p>
        <p id="res-min-lr" class="text-2xl font-bold font-mono text-blue-400">—</p>
        <p class="text-xs text-text-muted mt-1">end-of-schedule</p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
        <p class="text-xs text-text-muted mb-1">Warmup Steps</p>
        <p id="res-warmup-steps" class="text-2xl font-bold font-mono text-yellow-400">—</p>
        <p class="text-xs text-text-muted mt-1" id="res-warmup-pct">—</p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
        <p class="text-xs text-text-muted mb-1">Total Steps</p>
        <p id="res-total-steps" class="text-2xl font-bold font-mono text-text-muted">—</p>
        <p class="text-xs text-text-muted mt-1">training iterations</p>
      </div>
    </div>

    <!-- LR Range Test -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="text-base font-semibold mb-3">LR Range Test (LR Finder)</h2>
      <p class="text-xs text-text-muted mb-4">Run a short LR sweep from <strong id="range-start" class="text-text-primary">—</strong> to <strong id="range-end" class="text-text-primary">—</strong>, plot loss vs LR, and pick the LR at the steepest descent — roughly 1 order of magnitude below the divergence point.</p>
      <div class="grid grid-cols-3 gap-3">
        <div class="bg-bg-surface border border-border rounded-lg p-3 text-center">
          <p class="text-xs text-text-muted mb-1">Sweep Start</p>
          <p id="range-start-val" class="text-base font-bold font-mono text-green-500">—</p>
        </div>
        <div class="bg-bg-surface border border-border rounded-lg p-3 text-center">
          <p class="text-xs text-text-muted mb-1">Optimal Zone</p>
          <p id="range-opt-val" class="text-base font-bold font-mono text-primary">—</p>
        </div>
        <div class="bg-bg-surface border border-border rounded-lg p-3 text-center">
          <p class="text-xs text-text-muted mb-1">Sweep End (max)</p>
          <p id="range-end-val" class="text-base font-bold font-mono text-red-400">—</p>
        </div>
      </div>
    </div>

    <!-- LR Schedule Recommendations -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="text-base font-semibold mb-4">LR Schedule Recommendations</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4" id="schedule-cards">
        <!-- Filled by JS -->
      </div>
    </div>

    <!-- Visual schedule curve -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="text-base font-semibold mb-1">Visual LR Schedule Curve</h2>
      <p class="text-xs text-text-muted mb-4">Illustrative LR over training steps for all three schedules. Warmup phase shown in yellow.</p>
      <canvas id="lr-canvas" width="800" height="200" class="w-full rounded-lg bg-bg-surface border border-border"></canvas>
      <div class="flex gap-4 mt-3 text-xs text-text-muted flex-wrap">
        <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-1 rounded bg-yellow-400"></span> Warmup</span>
        <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-1 rounded bg-primary"></span> Cosine Annealing</span>
        <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-1 rounded bg-blue-400"></span> Step Decay</span>
        <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-1 rounded bg-orange-400"></span> Cyclical</span>
      </div>
    </div>

    <!-- Warmup Recommendation Box -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="text-base font-semibold mb-3">Warmup Recommendation</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <p class="text-xs text-text-muted mb-2">Warmup strategy for your setup:</p>
          <p id="warmup-strategy" class="text-sm text-text-primary"></p>
        </div>
        <div class="bg-bg-surface border border-border rounded-lg p-3 text-xs text-text-muted space-y-1.5">
          <p id="warmup-note-1"></p>
          <p id="warmup-note-2"></p>
        </div>
      </div>
    </div>

    <!-- Config snippet -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-base font-semibold">PyTorch Config Snippet</h2>
        <button id="copy-btn"
          class="text-xs px-3 py-1.5 border border-border rounded-lg text-text-muted hover:border-primary hover:text-primary transition-all">
          Copy
        </button>
      </div>
      <pre id="code-snippet" class="bg-bg-surface border border-border rounded-lg p-4 text-xs font-mono text-text-primary overflow-x-auto leading-relaxed whitespace-pre"></pre>
    </div>

  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Neural Network Learning Rate Calculator" relatedTags={['machine-learning', 'deep-learning', 'neural-network', 'pytorch', 'training', 'optimizer', 'hyperparameter']} />
</BaseLayout>

<script>
  // ─── Config tables ───────────────────────────────────────────────────────────

  var BASE_LR: Record<string, Record<string, number>> = {
    adam: {
      small: 1e-3,
      medium: 3e-4,
      large: 1e-4,
      xl: 3e-5,
    },
    sgd: {
      small: 1e-1,
      medium: 1e-2,
      large: 5e-3,
      xl: 1e-3,
    },
    rmsprop: {
      small: 1e-3,
      medium: 5e-4,
      large: 1e-4,
      xl: 5e-5,
    },
    adagrad: {
      small: 1e-2,
      medium: 5e-3,
      large: 1e-3,
      xl: 5e-4,
    },
  };

  var TASK_LR_FACTOR: Record<string, number> = {
    classification: 1.0,
    regression: 0.5,
    nlp: 0.1,
  };

  // LR scales linearly with batch size relative to reference batch of 32
  var REF_BATCH = 32;

  function getBaseLR(optimizer: string, modelSize: string, taskType: string, batchSize: number): number {
    var base = BASE_LR[optimizer][modelSize];
    var taskFactor = TASK_LR_FACTOR[taskType];
    var batchFactor = Math.sqrt(batchSize / REF_BATCH); // sqrt scaling (safer than linear for large batches)
    return base * taskFactor * batchFactor;
  }

  function formatLR(lr: number): string {
    if (lr === 0) return '0';
    var exp = Math.floor(Math.log10(lr));
    var mantissa = lr / Math.pow(10, exp);
    var mantissaStr = mantissa.toFixed(2).replace(/\.?0+$/, '');
    if (mantissaStr === '1') return '1e' + exp;
    return mantissaStr + 'e' + exp;
  }

  function formatLRFull(lr: number): string {
    if (lr >= 0.001) return lr.toFixed(6).replace(/0+$/, '').replace(/\.$/, '');
    return lr.toExponential(2);
  }

  function calcWarmupSteps(totalSteps: number, optimizer: string, taskType: string, modelSize: string): { steps: number; pct: number } {
    var needsWarmup = optimizer === 'adam' || taskType === 'nlp' || modelSize === 'large' || modelSize === 'xl';
    var pct = 0;
    if (taskType === 'nlp') pct = 0.06;
    else if (needsWarmup && modelSize === 'xl') pct = 0.05;
    else if (needsWarmup) pct = 0.03;
    else pct = 0;
    var steps = Math.round(totalSteps * pct);
    return { steps, pct };
  }

  // ─── Schedule builders ───────────────────────────────────────────────────────

  function cosineSchedule(step: number, totalSteps: number, lrMax: number, lrMin: number, warmupSteps: number): number {
    if (step < warmupSteps) {
      return lrMin * 0.01 + (lrMax - lrMin * 0.01) * (step / Math.max(1, warmupSteps));
    }
    var t = (step - warmupSteps) / Math.max(1, totalSteps - warmupSteps);
    return lrMin + (lrMax - lrMin) * 0.5 * (1 + Math.cos(Math.PI * t));
  }

  function stepDecaySchedule(step: number, totalSteps: number, lrMax: number, lrMin: number, warmupSteps: number): number {
    if (step < warmupSteps) {
      return lrMin * 0.01 + (lrMax - lrMin * 0.01) * (step / Math.max(1, warmupSteps));
    }
    var decaySteps = 3;
    var decayFactor = Math.pow(lrMin / lrMax, 1 / decaySteps);
    var stepsPerDecay = Math.floor((totalSteps - warmupSteps) / decaySteps);
    var decayApplied = Math.min(Math.floor((step - warmupSteps) / Math.max(1, stepsPerDecay)), decaySteps);
    return lrMax * Math.pow(decayFactor, decayApplied);
  }

  function cyclicalSchedule(step: number, totalSteps: number, lrMax: number, lrMin: number, warmupSteps: number): number {
    if (step < warmupSteps) {
      return lrMin * 0.01 + (lrMax - lrMin * 0.01) * (step / Math.max(1, warmupSteps));
    }
    var cycleLen = Math.floor((totalSteps - warmupSteps) / 4);
    if (cycleLen < 1) cycleLen = 1;
    var pos = (step - warmupSteps) % (cycleLen * 2);
    var t = pos < cycleLen ? pos / cycleLen : 2 - pos / cycleLen;
    return lrMin + (lrMax - lrMin) * t;
  }

  // ─── Draw canvas ─────────────────────────────────────────────────────────────

  function drawCanvas(totalSteps: number, lrMax: number, lrMin: number, warmupSteps: number): void {
    var canvas = document.getElementById('lr-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    if (!ctx) return;

    var W = canvas.width;
    var H = canvas.height;
    var PAD = { top: 16, right: 16, bottom: 28, left: 52 };
    var plotW = W - PAD.left - PAD.right;
    var plotH = H - PAD.top - PAD.bottom;

    ctx.clearRect(0, 0, W, H);

    // Background
    ctx.fillStyle = 'rgba(0,0,0,0)';
    ctx.fillRect(0, 0, W, H);

    // Grid lines
    ctx.strokeStyle = 'rgba(255,255,255,0.05)';
    ctx.lineWidth = 1;
    for (var i = 0; i <= 4; i++) {
      var yG = PAD.top + plotH - (i / 4) * plotH;
      ctx.beginPath();
      ctx.moveTo(PAD.left, yG);
      ctx.lineTo(PAD.left + plotW, yG);
      ctx.stroke();
    }

    // Y axis labels
    ctx.fillStyle = 'rgba(255,255,255,0.35)';
    ctx.font = '10px monospace';
    ctx.textAlign = 'right';
    for (var j = 0; j <= 4; j++) {
      var lr = lrMin + (lrMax - lrMin) * (j / 4);
      var yL = PAD.top + plotH - (j / 4) * plotH;
      ctx.fillText(formatLR(lr), PAD.left - 6, yL + 3);
    }

    // Warmup region background
    if (warmupSteps > 0) {
      var warmupX = PAD.left + (warmupSteps / totalSteps) * plotW;
      ctx.fillStyle = 'rgba(250,204,21,0.07)';
      ctx.fillRect(PAD.left, PAD.top, warmupX - PAD.left, plotH);
      ctx.fillStyle = 'rgba(250,204,21,0.6)';
      ctx.font = '9px sans-serif';
      ctx.textAlign = 'left';
      ctx.fillText('warmup', PAD.left + 3, PAD.top + 11);
    }

    var STEPS = 200;

    function lrToY(lr: number): number {
      var t = (lr - lrMin) / Math.max(1e-12, lrMax - lrMin);
      return PAD.top + plotH - t * plotH;
    }

    function drawLine(scheduleFn: (s: number, t: number, lrMax: number, lrMin: number, ws: number) => number, color: string): void {
      if (!ctx) return;
      ctx.beginPath();
      ctx.strokeStyle = color;
      ctx.lineWidth = 2;
      for (var s = 0; s <= STEPS; s++) {
        var step = Math.round((s / STEPS) * totalSteps);
        var lr = scheduleFn(step, totalSteps, lrMax, lrMin, warmupSteps);
        var x = PAD.left + (s / STEPS) * plotW;
        var y = lrToY(lr);
        if (s === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      ctx.stroke();
    }

    drawLine(cosineSchedule, 'rgba(139,92,246,0.9)');   // primary purple
    drawLine(stepDecaySchedule, 'rgba(96,165,250,0.9)'); // blue
    drawLine(cyclicalSchedule, 'rgba(251,146,60,0.9)');  // orange

    // X axis labels
    ctx.fillStyle = 'rgba(255,255,255,0.35)';
    ctx.font = '10px monospace';
    ctx.textAlign = 'center';
    for (var k = 0; k <= 4; k++) {
      var xL = PAD.left + (k / 4) * plotW;
      ctx.fillText(Math.round((k / 4) * totalSteps).toLocaleString(), xL, PAD.top + plotH + 18);
    }
    ctx.fillStyle = 'rgba(255,255,255,0.2)';
    ctx.textAlign = 'center';
    ctx.fillText('steps →', PAD.left + plotW / 2, H - 2);
  }

  // ─── Schedule card content ───────────────────────────────────────────────────

  function buildScheduleCards(totalSteps: number, lrMax: number, lrMin: number, warmupSteps: number, numEpochs: number): void {
    var container = document.getElementById('schedule-cards');
    if (!container) return;

    var stepsPerDecay = Math.max(1, Math.floor((totalSteps - warmupSteps) / 3));
    var epochsPerDecay = Math.max(1, Math.round(numEpochs / 3));

    var schedules = [
      {
        name: 'Cosine Annealing',
        tag: 'Recommended',
        tagColor: 'text-green-400 bg-green-500/10 border border-green-500/20',
        color: 'border-t-2 border-t-primary',
        description: 'Smooth decay following a cosine curve. Best convergence for most architectures.',
        params: [
          { label: 'T_max (steps)', value: (totalSteps - warmupSteps).toLocaleString() },
          { label: 'eta_min', value: formatLR(lrMin) },
          { label: 'Warmup', value: warmupSteps > 0 ? warmupSteps.toLocaleString() + ' steps' : 'None' },
        ],
        code: 'torch.optim.lr_scheduler.CosineAnnealingLR\n(optimizer, T_max=' + (totalSteps - warmupSteps) + ',\n eta_min=' + formatLRFull(lrMin) + ')',
      },
      {
        name: 'Step Decay',
        tag: 'Simple',
        tagColor: 'text-blue-400 bg-blue-500/10 border border-blue-500/20',
        color: 'border-t-2 border-t-blue-400',
        description: 'Multiply LR by gamma every N steps. Predictable and easy to reason about.',
        params: [
          { label: 'step_size', value: stepsPerDecay.toLocaleString() + ' steps (~' + epochsPerDecay + ' epochs)' },
          { label: 'gamma', value: '0.1' },
          { label: 'Decay rounds', value: '3×' },
        ],
        code: 'torch.optim.lr_scheduler.StepLR\n(optimizer, step_size=' + stepsPerDecay + ',\n gamma=0.1)',
      },
      {
        name: 'Cyclical LR',
        tag: 'Exploratory',
        tagColor: 'text-orange-400 bg-orange-500/10 border border-orange-500/20',
        color: 'border-t-2 border-t-orange-400',
        description: 'Oscillate between min and max LR. Helps escape local minima during training from scratch.',
        params: [
          { label: 'base_lr', value: formatLR(lrMin) },
          { label: 'max_lr', value: formatLR(lrMax) },
          { label: 'step_size_up', value: Math.round((totalSteps - warmupSteps) / 8).toLocaleString() + ' steps' },
        ],
        code: 'torch.optim.lr_scheduler.CyclicLR\n(optimizer, base_lr=' + formatLRFull(lrMin) + ',\n max_lr=' + formatLRFull(lrMax) + ',\n step_size_up=' + Math.round((totalSteps - warmupSteps) / 8) + ')',
      },
    ];

    container.innerHTML = schedules.map(function(s) {
      return '<div class="bg-bg-surface border border-border rounded-xl p-4 ' + s.color + '">' +
        '<div class="flex items-center justify-between mb-2">' +
        '<span class="text-sm font-semibold">' + s.name + '</span>' +
        '<span class="text-xs px-2 py-0.5 rounded-full ' + s.tagColor + '">' + s.tag + '</span>' +
        '</div>' +
        '<p class="text-xs text-text-muted mb-3">' + s.description + '</p>' +
        '<div class="space-y-1.5 mb-3">' +
        s.params.map(function(p) {
          return '<div class="flex justify-between text-xs">' +
            '<span class="text-text-muted">' + p.label + '</span>' +
            '<span class="font-mono font-medium">' + p.value + '</span>' +
            '</div>';
        }).join('') +
        '</div>' +
        '<pre class="bg-bg-card border border-border rounded-lg p-2 text-xs font-mono text-text-muted overflow-x-auto whitespace-pre">' + s.code + '</pre>' +
        '</div>';
    }).join('');
  }

  // ─── Warmup strategy text ─────────────────────────────────────────────────────

  function getWarmupText(optimizer: string, taskType: string, modelSize: string, warmupSteps: number, lrMax: number): { strategy: string; note1: string; note2: string } {
    if (warmupSteps === 0) {
      return {
        strategy: 'No warmup recommended for this configuration. SGD with small/medium models and non-NLP tasks generally does not benefit from warmup.',
        note1: 'If training becomes unstable in the first epoch, add 1–3% warmup steps.',
        note2: 'You can safely start directly at ' + formatLR(lrMax) + '.',
      };
    }
    var strategies: Record<string, string> = {
      nlp: 'Linear warmup over ' + warmupSteps.toLocaleString() + ' steps from ~0 to ' + formatLR(lrMax) + '. This is standard for all transformer-based fine-tuning (BERT, GPT, T5). The Hugging Face Trainer uses this by default.',
      xl: 'Linear warmup over ' + warmupSteps.toLocaleString() + ' steps. Large models need warmup to stabilize Adam\'s moving averages before full LR is applied. Without warmup, very large gradients in early steps can corrupt the model.',
    };
    var strategy = taskType === 'nlp' ? strategies.nlp : (modelSize === 'xl' ? strategies.xl : 'Linear warmup over ' + warmupSteps.toLocaleString() + ' steps from ~0 to ' + formatLR(lrMax) + '. Recommended for Adam optimizer to allow the optimizer state to warm up before full LR is applied.');
    return {
      strategy,
      note1: 'Start from LR = ' + formatLR(lrMax * 0.01) + ' and linearly ramp up each step.',
      note2: 'Use a linear warmup scheduler: LR(step) = max_lr × (step / warmup_steps).',
    };
  }

  // ─── Code snippet ─────────────────────────────────────────────────────────────

  function buildCodeSnippet(optimizer: string, lrMax: number, lrMin: number, warmupSteps: number, totalSteps: number): string {
    var optMap: Record<string, string> = {
      adam: 'torch.optim.AdamW(model.parameters(), lr=' + formatLRFull(lrMax) + ', weight_decay=1e-2)',
      sgd: 'torch.optim.SGD(model.parameters(), lr=' + formatLRFull(lrMax) + ', momentum=0.9, weight_decay=1e-4)',
      rmsprop: 'torch.optim.RMSprop(model.parameters(), lr=' + formatLRFull(lrMax) + ', alpha=0.99)',
      adagrad: 'torch.optim.Adagrad(model.parameters(), lr=' + formatLRFull(lrMax) + ')',
    };
    var warmupBlock = warmupSteps > 0
      ? '\n# Warmup + Cosine Annealing\nfrom transformers import get_cosine_schedule_with_warmup\nscheduler = get_cosine_schedule_with_warmup(\n    optimizer,\n    num_warmup_steps=' + warmupSteps + ',\n    num_training_steps=' + totalSteps + '\n)'
      : '\n# Cosine Annealing (no warmup)\nscheduler = torch.optim.lr_scheduler.CosineAnnealingLR(\n    optimizer,\n    T_max=' + (totalSteps - warmupSteps) + ',\n    eta_min=' + formatLRFull(lrMin) + '\n)';
    return '# Recommended configuration\noptimizer = ' + optMap[optimizer] + warmupBlock + '\n\n# Training loop\nfor step, batch in enumerate(train_loader):\n    optimizer.zero_grad()\n    loss = model(batch)\n    loss.backward()\n    torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)  # gradient clip\n    optimizer.step()\n    scheduler.step()';
  }

  // ─── Main calculate ───────────────────────────────────────────────────────────

  function calculate(): void {
    var optimizer = (document.getElementById('optimizer') as HTMLSelectElement).value;
    var taskType = (document.getElementById('task-type') as HTMLSelectElement).value;
    var modelSize = (document.getElementById('model-size') as HTMLSelectElement).value;
    var batchSize = parseInt((document.getElementById('batch-size') as HTMLInputElement).value) || 32;
    var datasetSize = parseInt((document.getElementById('dataset-size') as HTMLInputElement).value) || 50000;
    var numEpochs = parseInt((document.getElementById('num-epochs') as HTMLInputElement).value) || 50;

    var stepsPerEpoch = Math.ceil(datasetSize / batchSize);
    var totalSteps = stepsPerEpoch * numEpochs;
    var lrMax = getBaseLR(optimizer, modelSize, taskType, batchSize);
    var lrMin = lrMax / 100;
    var warmupInfo = calcWarmupSteps(totalSteps, optimizer, taskType, modelSize);

    // Update key outputs
    var setText = function(id: string, val: string) {
      var el = document.getElementById(id);
      if (el) el.textContent = val;
    };

    setText('res-initial-lr', formatLR(lrMax));
    setText('res-min-lr', formatLR(lrMin));
    setText('res-warmup-steps', warmupInfo.steps.toLocaleString());
    setText('res-warmup-pct', warmupInfo.pct > 0 ? (warmupInfo.pct * 100).toFixed(0) + '% of total steps' : 'not needed');
    setText('res-total-steps', totalSteps.toLocaleString());

    // LR Range test
    var rangeStart = lrMax * 0.001;
    var rangeEnd = lrMax * 10;
    var rangeOpt = formatLR(lrMax * 0.1) + ' – ' + formatLR(lrMax);
    setText('range-start', formatLR(rangeStart));
    setText('range-end', formatLR(rangeEnd));
    setText('range-start-val', formatLR(rangeStart));
    setText('range-opt-val', rangeOpt);
    setText('range-end-val', formatLR(rangeEnd));

    // Schedule cards
    buildScheduleCards(totalSteps, lrMax, lrMin, warmupInfo.steps, numEpochs);

    // Warmup text
    var wt = getWarmupText(optimizer, taskType, modelSize, warmupInfo.steps, lrMax);
    setText('warmup-strategy', wt.strategy);
    setText('warmup-note-1', wt.note1);
    setText('warmup-note-2', wt.note2);

    // Code snippet
    var snippet = buildCodeSnippet(optimizer, lrMax, lrMin, warmupInfo.steps, totalSteps);
    var snippetEl = document.getElementById('code-snippet');
    if (snippetEl) snippetEl.textContent = snippet;

    // Draw canvas
    drawCanvas(totalSteps, lrMax, lrMin, warmupInfo.steps);

    // Show results
    var resultsSection = document.getElementById('results-section');
    if (resultsSection) resultsSection.classList.remove('hidden');
  }

  // ─── Event listeners ──────────────────────────────────────────────────────────

  var calcBtn = document.getElementById('calc-btn');
  if (calcBtn) calcBtn.addEventListener('click', calculate);

  // Preset buttons
  document.querySelectorAll('.bs-preset').forEach(function(btn) {
    btn.addEventListener('click', function(this: HTMLElement) {
      var input = document.getElementById('batch-size') as HTMLInputElement;
      if (input) input.value = this.getAttribute('data-val') || '32';
    });
  });

  document.querySelectorAll('.ds-preset').forEach(function(btn) {
    btn.addEventListener('click', function(this: HTMLElement) {
      var input = document.getElementById('dataset-size') as HTMLInputElement;
      if (input) input.value = this.getAttribute('data-val') || '50000';
    });
  });

  document.querySelectorAll('.ep-preset').forEach(function(btn) {
    btn.addEventListener('click', function(this: HTMLElement) {
      var input = document.getElementById('num-epochs') as HTMLInputElement;
      if (input) input.value = this.getAttribute('data-val') || '50';
    });
  });

  // Copy button
  var copyBtn = document.getElementById('copy-btn');
  if (copyBtn) {
    copyBtn.addEventListener('click', function() {
      var snippet = document.getElementById('code-snippet');
      if (snippet && snippet.textContent) {
        navigator.clipboard.writeText(snippet.textContent).then(function() {
          if (copyBtn) copyBtn.textContent = 'Copied!';
          setTimeout(function() {
            if (copyBtn) copyBtn.textContent = 'Copy';
          }, 2000);
        });
      }
    });
  }

  // Auto-calculate on load with defaults
  calculate();
</script>
