---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CssClipPathGenerator from '../../components/CssClipPathGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is CSS clip-path?", answer: "CSS clip-path clips an element to a shape, hiding anything outside that shape. It's GPU-accelerated and can be animated. Common values are polygon() for custom shapes, circle() and ellipse() for round crops, and inset() for rectangular clipping with optional rounded corners." },
  { question: "How do I make a triangle with CSS clip-path?", answer: "Use polygon() with three points: clip-path: polygon(50% 0%, 100% 100%, 0% 100%) creates an upward triangle. Each pair of values is an X Y coordinate as a percentage of the element's width and height." },
  { question: "Can I animate CSS clip-path?", answer: "Yes — clip-path is GPU-accelerated and transitions smoothly between shapes with the same number of points. Add transition: clip-path 0.4s ease to your element, then change the clip-path value on hover or with JavaScript to reveal/hide content smoothly." },
  { question: "What is the difference between clip-path and overflow: hidden?", answer: "overflow: hidden only clips to a rectangle. clip-path can clip to any shape including triangles, stars, polygons, circles, and custom curves. clip-path is also GPU-accelerated, so animations are smoother. Use overflow for simple rectangular clipping and clip-path for anything else." },
  { question: "Is clip-path supported in all browsers?", answer: "clip-path is supported in all modern browsers (Chrome, Firefox, Safari, Edge). The -webkit-clip-path prefix is still needed for some older Safari versions. Internet Explorer does not support clip-path. This generator outputs both prefixed and non-prefixed versions for maximum compatibility." },
  { question: "How do I create a CSS clip-path divider between sections?", answer: "Apply clip-path: polygon(0 0, 100% 0, 100% 85%, 0 100%) to a section element. This creates a diagonal bottom edge. Combine with a matching section below to create a seamless slanted divider effect. Use negative margin to close any gap." },
];
---

<BaseLayout
  title="CSS Clip-Path Generator — Free Online Tool"
  description="Generate CSS clip-path values visually. Choose from 16 polygon presets (triangle, star, arrow, hexagon), circle, ellipse, and inset shapes. Live preview, one-click copy. Free, no signup."
  tool="CSS Clip-Path Generator, CSS clip path, polygon clip path, CSS shape generator, CSS mask generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">CSS Clip-Path Generator</h1>
  <p class="text-text-muted mb-4">Create CSS <code>clip-path</code> shapes visually — triangle, star, hexagon, arrow, circle, ellipse, inset, and more. Pick a preset, customize, and copy the ready-to-use CSS with <code>-webkit-clip-path</code> for full browser support. <span class="text-xs text-text-muted">(100% client-side)</span></p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 16 polygon presets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Circle, ellipse & inset modes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <CssClipPathGenerator client:load />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CSS Clip-Path Generator" relatedTags={['css', 'design', 'frontend', 'animation']} />
</BaseLayout>
