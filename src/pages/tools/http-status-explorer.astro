---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HttpStatusExplorer from '../../components/HttpStatusExplorer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the difference between 401 and 403?", answer: "401 Unauthorized means you are not authenticated — you need to provide credentials (login, API key, JWT). 403 Forbidden means you are authenticated but do not have permission — the server knows who you are but refuses your request. In practice: 401 means log in, 403 means your role lacks the required permissions." },
  { question: "When should I use 422 instead of 400?", answer: "Use 400 Bad Request for syntactically malformed requests (invalid JSON, wrong content-type, missing required top-level parameter). Use 422 Unprocessable Entity for semantically invalid requests where the structure is valid but the values fail business rules — wrong email format, date in the past, value out of allowed range. Many APIs use 400 for both, but 422 is more precise for validation errors." },
  { question: "What is the difference between 301 and 308?", answer: "Both are permanent redirects, but 308 Permanent Redirect guarantees the HTTP method is preserved. With 301, browsers may change POST requests to GET on redirect (and many do). With 308, POST stays POST. Same relationship exists for temporary redirects: 302 may change POST to GET, 307 does not." },
  { question: "Should my API return 200 or 204 for DELETE?", answer: "Use 200 OK if you return a response body (e.g., the deleted resource or a confirmation message). Use 204 No Content if you return nothing. Both are valid — 204 is slightly more semantic but 200 is more common in REST APIs. Never return 200 with an empty body when you could return 204." },
  { question: "How should I handle 429 Too Many Requests?", answer: "Always include a Retry-After header with the number of seconds until the rate limit resets. Also include X-RateLimit-Limit (total requests allowed), X-RateLimit-Remaining (requests left in window), and X-RateLimit-Reset (Unix timestamp when window resets). Clients should exponential backoff on 429 — retry after Retry-After seconds, doubling on successive failures." },
  { question: "What HTTP status codes are cacheable by default?", answer: "Cacheable by default (no cache headers needed): 200, 203, 204, 206, 300, 301, 404, 405, 410, 414, 501. Not cacheable by default: 302, 303, 307, 308 (unless Cache-Control is explicitly set). Always cacheable: 200 with Cache-Control or Expires. Override caching with Cache-Control: no-store for sensitive responses." },
];
---

<BaseLayout
  title="HTTP Status Code Explorer — Searchable Reference with Examples"
  description="Searchable HTTP status code reference. Browse all 1xx-5xx codes with descriptions, real-world use cases, examples, and cacheability. Filter by category. Free developer tool."
  tool="HTTP status codes, HTTP status code reference, HTTP status code list, 404 not found, 401 unauthorized, 429 too many requests, REST API status codes, HTTP response codes"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "HTTP Status Code Explorer",
    "url": "https://devplaybook.cc/tools/http-status-explorer",
    "description": "Searchable reference for all HTTP status codes (1xx-5xx) with descriptions, use cases, examples, and cacheability. Filter by category or search by code/name.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">HTTP Status Code Explorer</h1>
  <p class="text-text-muted mb-4">
    Searchable reference for all HTTP status codes. Click any code to expand real-world use cases, response examples,
    cacheability, and retry guidance.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All 1xx-5xx codes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Real-world use cases</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Cacheable & retryable flags</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Response body examples</span>
  </div>
  <HttpStatusExplorer client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="HTTP Status Code Explorer" relatedTags={['http', 'api', 'rest', 'web', 'developer-tools']} />
</BaseLayout>
