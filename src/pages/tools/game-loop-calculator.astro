---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GameLoopCalculator from '../../components/GameLoopCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is a fixed timestep game loop?", answer: "A fixed timestep loop decouples physics updates from rendering. Physics runs at a constant rate (e.g., 60 Hz) regardless of how fast the CPU renders. This makes simulations deterministic and reproducible — the same inputs always produce the same outputs. Variable-timestep loops can cause objects to tunnel through walls at low FPS or behave erratically at high FPS." },
  { question: "Why cap delta time to 250ms?", answer: "If the tab is hidden, the device sleeps, or there's a garbage collection pause, the next frame's delta can be enormous. Without a cap, your game might try to simulate 5 seconds of physics in one step, causing objects to teleport or explode. Capping at 250ms (a few frames) means the simulation just 'pauses' briefly rather than going haywire." },
  { question: "What is render interpolation (alpha)?", answer: "When your render rate (e.g., 60 FPS) doesn't divide evenly into your physics rate, there's leftover time in the accumulator at render time. The alpha value (0 to 1) represents how far between the previous and current physics state the render is. Interpolating renders smoothly avoids objects 'snapping' between physics positions." },
  { question: "Should physics Hz match my FPS target?", answer: "Not necessarily. For browser games, 60 Hz physics with any FPS works well. For platformers, 60 Hz feels responsive. For physics simulations or racing games, higher Hz (120-240) reduces numerical error. For mobile or low-power devices, 30 Hz physics with 30 FPS rendering is common. The key is that physics Hz should be fixed and predictable." },
  { question: "What does render scale do?", answer: "Render scale lets you render at a different resolution than the display. At 75% scale, you render at 1440×810 and upscale to 1920×1080, saving ~44% GPU work. At 200% scale (supersampling), you render at double resolution then downsample for anti-aliasing. Dynamic resolution scaling adjusts this at runtime to hit FPS targets." },
  { question: "What is the 80% CPU budget rule?", answer: "The 80% budget means leaving 20% of your frame time as a buffer. A 60 FPS target gives 16.67ms per frame. At 80%, your actual game code has 13.3ms. This buffer absorbs garbage collection spikes, driver overhead, system interrupts, and occasional expensive frames without dropping below target FPS." },
];
---

<BaseLayout
  title="Game Loop Calculator — Fixed Timestep, FPS & Physics Hz Planner"
  description="Calculate game loop timing for any FPS target and physics rate. Get frame time budget, fixed delta time, ticks-per-frame, render interpolation alpha, and copy ready-to-use JavaScript game loop code."
  tool="Game Loop Calculator, Fixed Timestep Calculator, requestAnimationFrame FPS, Physics Hz Planner, Game Dev Timing Tool"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Game Loop Calculator</h1>
  <p class="text-text-muted mb-4">Plan your game loop timing. Set your target FPS and physics update rate to get frame budget, fixed delta time, physics ticks per frame, interpolation alpha, and copy the generated loop code.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Fixed timestep + interpolation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Frame timeline visualization</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-ready JS loop code</span>
  </div>
  <GameLoopCalculator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Game Loop Calculator" relatedTags={['game-dev', 'javascript', 'animation', 'performance', 'canvas']} />
</BaseLayout>
