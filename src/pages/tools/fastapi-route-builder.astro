---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is FastAPI and why use it?", answer: "FastAPI is a modern Python web framework for building APIs, built on Starlette and Pydantic. It's one of the fastest Python frameworks available (on par with NodeJS/Go for async workloads). Key advantages: automatic OpenAPI/Swagger docs generation, type-safe request/response validation via Pydantic, native async support, and Python type hints for editor autocomplete." },
  { question: "What is the difference between GET, POST, PUT, and DELETE in FastAPI?", answer: "These are HTTP methods that map to CRUD operations. GET retrieves data (read-only, no body). POST creates new resources (body with data). PUT replaces an entire resource. PATCH partially updates a resource. DELETE removes a resource. FastAPI decorators (@app.get, @app.post, etc.) bind a function to a specific method + path combination." },
  { question: "What is a Pydantic model in FastAPI?", answer: "A Pydantic model is a Python class that inherits from BaseModel and defines the shape of request/response data with type annotations. FastAPI uses these for automatic validation and serialization. If a request body doesn't match the model, FastAPI returns a 422 error with details about what's wrong — without any extra validation code." },
  { question: "What is dependency injection in FastAPI?", answer: "Dependency injection (DI) in FastAPI uses the Depends() function to declare shared logic — database sessions, authentication, query parameter parsing — that gets injected into route functions automatically. It avoids code duplication and makes routes testable. Example: def get_db() returns a DB session; routes declare db: Session = Depends(get_db)." },
  { question: "What is a path parameter vs a query parameter?", answer: "Path parameters are part of the URL path: /users/{user_id} — FastAPI extracts them from the URL. Query parameters come after '?': /items?skip=0&limit=10 — FastAPI reads them from the query string. Both are type-validated. Path params are required; query params can be optional with default values." },
  { question: "How do I add authentication to a FastAPI route?", answer: "The most common patterns: OAuth2 with password flow (built-in FastAPI OAuth2PasswordBearer), API keys in headers (x-api-key), or JWT tokens. Use Depends() to inject an auth check into any route. FastAPI includes HTTPBearer and APIKeyHeader security schemes that integrate with the auto-generated Swagger UI." },
];
---

<BaseLayout
  title="FastAPI Route Builder — Visual FastAPI Endpoint Generator"
  description="Generate FastAPI route code instantly. Choose HTTP method, path, path/query params, request body, response model, and authentication. Get production-ready Python code with Pydantic schemas."
  tool="FastAPI Route Builder, FastAPI endpoint generator, FastAPI code generator, Python API builder, FastAPI Pydantic schema"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "FastAPI Route Builder",
    "url": "https://devplaybook.cc/tools/fastapi-route-builder",
    "description": "Visual FastAPI route and schema generator. Configure your endpoint and get production-ready Python code.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">FastAPI Route Builder</h1>
  <p class="text-text-muted mb-4">
    Configure your <strong>FastAPI endpoint</strong> — method, path, parameters, request body, response model, auth — and get production-ready Python code with Pydantic schemas.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Full route + Pydantic models</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auth & dependency injection</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-ready Python code</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
    <!-- Config panel -->
    <div class="space-y-4">
      <!-- Method & path -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold mb-3">Endpoint</h2>
        <div class="flex gap-2 mb-3">
          <select id="method" class="bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono font-bold focus:outline-none focus:border-primary w-28">
            <option value="get" class="text-green-400">GET</option>
            <option value="post" selected class="text-blue-400">POST</option>
            <option value="put" class="text-yellow-400">PUT</option>
            <option value="patch" class="text-orange-400">PATCH</option>
            <option value="delete" class="text-red-400">DELETE</option>
          </select>
          <input id="path" type="text" value="/items/{item_id}"
            class="flex-1 bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>
        <input id="func-name" type="text" placeholder="Function name (e.g. create_item)" value="create_item"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
      </div>

      <!-- Request body -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold">Request Body (Pydantic)</h2>
          <label class="flex items-center gap-2 text-xs">
            <input type="checkbox" id="has-body" checked class="w-3.5 h-3.5" />
            Enabled
          </label>
        </div>
        <div id="body-section">
          <input id="body-model" type="text" placeholder="Model name (e.g. ItemCreate)" value="ItemCreate"
            class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono mb-2 focus:outline-none focus:border-primary" />
          <div id="body-fields" class="space-y-2">
            <div class="flex gap-2 body-field-row">
              <input type="text" placeholder="field name" value="name" class="flex-1 bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs font-mono focus:outline-none focus:border-primary field-name" />
              <select class="bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:border-primary field-type">
                <option>str</option><option>int</option><option>float</option><option>bool</option><option>list[str]</option><option>dict</option><option>Optional[str]</option>
              </select>
              <button class="text-red-400 hover:text-red-300 text-xs px-1 remove-field">✕</button>
            </div>
            <div class="flex gap-2 body-field-row">
              <input type="text" placeholder="field name" value="price" class="flex-1 bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs font-mono focus:outline-none focus:border-primary field-name" />
              <select class="bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:border-primary field-type">
                <option>str</option><option selected>float</option><option>int</option><option>bool</option><option>list[str]</option><option>dict</option><option>Optional[str]</option>
              </select>
              <button class="text-red-400 hover:text-red-300 text-xs px-1 remove-field">✕</button>
            </div>
          </div>
          <button id="add-field" class="mt-2 text-xs text-primary hover:underline">+ Add field</button>
        </div>
      </div>

      <!-- Response model -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold mb-3">Response</h2>
        <div class="flex gap-2 mb-2">
          <input id="resp-model" type="text" placeholder="Response model (e.g. Item)" value="Item"
            class="flex-1 bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
          <select id="status-code" class="bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
            <option value="200">200 OK</option>
            <option value="201" selected>201 Created</option>
            <option value="204">204 No Content</option>
            <option value="400">400 Bad Request</option>
            <option value="404">404 Not Found</option>
          </select>
        </div>
      </div>

      <!-- Auth -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold mb-3">Authentication</h2>
        <select id="auth-type" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="none">None</option>
          <option value="oauth2">OAuth2 / JWT Bearer</option>
          <option value="apikey">API Key Header</option>
          <option value="basic">HTTP Basic Auth</option>
        </select>
      </div>

      <!-- DB dependency -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between">
          <h2 class="text-sm font-semibold">Database Dependency (SQLAlchemy)</h2>
          <input type="checkbox" id="has-db" class="w-4 h-4" />
        </div>
      </div>

      <button id="generate-btn" class="w-full py-2.5 bg-primary text-white rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors">
        Generate Code
      </button>
    </div>

    <!-- Output -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-semibold">Generated Code</h2>
        <button id="copy-code" class="text-xs border border-border px-3 py-1 rounded-lg hover:bg-bg-page transition-colors">Copy</button>
      </div>
      <pre id="code-output" class="text-xs font-mono bg-bg-page border border-border rounded-lg p-4 overflow-x-auto whitespace-pre min-h-[400px] text-text-muted"></pre>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="FastAPI Route Builder" relatedTags={['python', 'fastapi', 'api', 'backend', 'pydantic']} />
</BaseLayout>

<script is:inline>
function generateCode() {
  const method = document.getElementById('method').value;
  const path = document.getElementById('path').value.trim() || '/items';
  const funcName = document.getElementById('func-name').value.trim() || 'my_route';
  const hasBody = document.getElementById('has-body').checked;
  const bodyModel = document.getElementById('body-model').value.trim() || 'ItemCreate';
  const respModel = document.getElementById('resp-model').value.trim() || 'Item';
  const statusCode = document.getElementById('status-code').value;
  const authType = document.getElementById('auth-type').value;
  const hasDb = document.getElementById('has-db').checked;

  const fieldRows = document.querySelectorAll('.body-field-row');
  const fields = [];
  fieldRows.forEach(row => {
    const name = row.querySelector('.field-name').value.trim();
    const type = row.querySelector('.field-type').value;
    if (name) fields.push({ name, type });
  });

  const lines = [];

  // Imports
  lines.push('from fastapi import FastAPI, Depends, HTTPException, status');
  if (authType === 'oauth2') lines.push('from fastapi.security import OAuth2PasswordBearer');
  if (authType === 'apikey') lines.push('from fastapi.security import APIKeyHeader');
  if (authType === 'basic') lines.push('from fastapi.security import HTTPBasic, HTTPBasicCredentials');
  if (hasDb) lines.push('from sqlalchemy.orm import Session');
  lines.push('from pydantic import BaseModel');
  const optionalFields = fields.filter(f => f.type.startsWith('Optional'));
  if (optionalFields.length > 0) lines.push('from typing import Optional');
  lines.push('');
  lines.push('app = FastAPI()');
  lines.push('');

  // Auth setup
  if (authType === 'oauth2') {
    lines.push('oauth2_scheme = OAuth2PasswordBearer(tokenUrl="token")');
    lines.push('');
    lines.push('def get_current_user(token: str = Depends(oauth2_scheme)):');
    lines.push('    # TODO: verify JWT token');
    lines.push('    if not token:');
    lines.push('        raise HTTPException(status_code=401, detail="Not authenticated")');
    lines.push('    return {"sub": "user@example.com"}');
    lines.push('');
  } else if (authType === 'apikey') {
    lines.push('api_key_header = APIKeyHeader(name="x-api-key")');
    lines.push('');
    lines.push('def verify_api_key(api_key: str = Depends(api_key_header)):');
    lines.push('    if api_key != "your-secret-key":');
    lines.push('        raise HTTPException(status_code=403, detail="Invalid API key")');
    lines.push('    return api_key');
    lines.push('');
  } else if (authType === 'basic') {
    lines.push('security = HTTPBasic()');
    lines.push('');
    lines.push('def verify_credentials(credentials: HTTPBasicCredentials = Depends(security)):');
    lines.push('    if credentials.username != "admin" or credentials.password != "secret":');
    lines.push('        raise HTTPException(status_code=401, detail="Invalid credentials")');
    lines.push('    return credentials.username');
    lines.push('');
  }

  // DB dependency
  if (hasDb) {
    lines.push('def get_db():');
    lines.push('    db = SessionLocal()  # configure your SessionLocal');
    lines.push('    try:');
    lines.push('        yield db');
    lines.push('    finally:');
    lines.push('        db.close()');
    lines.push('');
  }

  // Request body model
  if (hasBody && fields.length > 0) {
    lines.push(`class ${bodyModel}(BaseModel):`);
    fields.forEach(f => {
      lines.push(`    ${f.name}: ${f.type}`);
    });
    lines.push('');
  }

  // Response model
  lines.push(`class ${respModel}(BaseModel):`);
  lines.push('    id: int');
  if (hasBody && fields.length > 0) {
    fields.forEach(f => {
      lines.push(`    ${f.name}: ${f.type}`);
    });
  }
  lines.push('');
  lines.push('    class Config:');
  lines.push('        from_attributes = True  # Pydantic v2');
  lines.push('');

  // Route decorator
  const statusArg = statusCode !== '200' ? `, status_code=${statusCode}` : '';
  const respArg = respModel ? `, response_model=${respModel}` : '';
  lines.push(`@app.${method}("${path}"${respArg}${statusArg})`);

  // Function signature
  const params = [];

  // Extract path params
  const pathParams = [...path.matchAll(/\{(\w+)\}/g)].map(m => m[1]);
  pathParams.forEach(p => params.push(`${p}: int`));

  if (method === 'get' || method === 'delete') {
    params.push('skip: int = 0');
    params.push('limit: int = 100');
  }

  if (hasBody && (method === 'post' || method === 'put' || method === 'patch')) {
    params.push(`${bodyModel.toLowerCase()}: ${bodyModel}`);
  }

  if (hasDb) params.push('db: Session = Depends(get_db)');

  if (authType === 'oauth2') params.push('current_user: dict = Depends(get_current_user)');
  if (authType === 'apikey') params.push('api_key: str = Depends(verify_api_key)');
  if (authType === 'basic') params.push('username: str = Depends(verify_credentials)');

  const asyncKw = 'async ';
  lines.push(`${asyncKw}def ${funcName}(${params.join(', ')}):`);
  lines.push(`    # TODO: implement ${funcName}`);

  if (statusCode === '204') {
    lines.push('    return None');
  } else if (method === 'get') {
    lines.push(`    return ${respModel}(id=1${fields.map(f => `, ${f.name}=${f.type === 'str' ? '"example"' : f.type === 'float' ? '0.0' : f.type === 'bool' ? 'False' : '0'}`).join('')})`);
  } else if (method === 'post') {
    lines.push('    # Create in DB, then return created object');
    lines.push(`    return ${respModel}(id=1${fields.map(f => `, ${f.name}=${f.type === 'str' ? '"example"' : f.type === 'float' ? '0.0' : f.type === 'bool' ? 'False' : '0'}`).join('')})`);
  } else if (method === 'delete') {
    lines.push('    # Delete from DB');
    lines.push('    return {"deleted": True}');
  } else {
    lines.push('    # Update in DB, return updated object');
    lines.push(`    return ${respModel}(id=1${fields.map(f => `, ${f.name}=${f.type === 'str' ? '"example"' : f.type === 'float' ? '0.0' : f.type === 'bool' ? 'False' : '0'}`).join('')})`);
  }

  document.getElementById('code-output').textContent = lines.join('\n');
}

document.getElementById('generate-btn').addEventListener('click', generateCode);

document.getElementById('add-field').addEventListener('click', () => {
  const container = document.getElementById('body-fields');
  const row = document.createElement('div');
  row.className = 'flex gap-2 body-field-row';
  row.innerHTML = `
    <input type="text" placeholder="field name" class="flex-1 bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs font-mono focus:outline-none focus:border-primary field-name" />
    <select class="bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:border-primary field-type">
      <option>str</option><option>int</option><option>float</option><option>bool</option><option>list[str]</option><option>dict</option><option>Optional[str]</option>
    </select>
    <button class="text-red-400 hover:text-red-300 text-xs px-1 remove-field">✕</button>
  `;
  container.appendChild(row);
  row.querySelector('.remove-field').addEventListener('click', () => row.remove());
});

document.querySelectorAll('.remove-field').forEach(btn => {
  btn.addEventListener('click', () => btn.closest('.body-field-row').remove());
});

document.getElementById('copy-code').addEventListener('click', () => {
  const code = document.getElementById('code-output').textContent;
  navigator.clipboard.writeText(code).catch(() => {});
  const btn = document.getElementById('copy-code');
  btn.textContent = 'Copied!';
  setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
});

// Auto-generate on load
generateCode();

// Re-generate on any input change
['method', 'path', 'func-name', 'body-model', 'resp-model', 'status-code', 'auth-type', 'has-body', 'has-db'].forEach(id => {
  document.getElementById(id)?.addEventListener('change', generateCode);
});
</script>
