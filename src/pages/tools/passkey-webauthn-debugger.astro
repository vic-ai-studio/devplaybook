---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PasskeyWebauthnDebugger from '../../components/PasskeyWebauthnDebugger.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the difference between passkeys and passwords?",
    answer: "Passwords are shared secrets — you create one, the server stores a hash of it, and you prove you know it on login. This means password databases are breach targets and users reuse weak passwords. Passkeys use public-key cryptography: the device generates a key pair, keeps the private key in a secure enclave (never transmitted), and registers the public key with the server. Sign-in works by the device signing a server-issued challenge — there is no secret to steal from the server, and phishing is eliminated because the credential is scoped to the exact origin (domain)."
  },
  {
    question: "What is the difference between WebAuthn and FIDO2?",
    answer: "FIDO2 is the umbrella standard from the FIDO Alliance that defines passwordless authentication. It has two components: WebAuthn (Web Authentication) is the W3C browser API — the JavaScript navigator.credentials.create() and navigator.credentials.get() calls. CTAP (Client-to-Authenticator Protocol) is the protocol between the browser and external authenticators (USB security keys, NFC cards). When you implement WebAuthn in your web app, you are using FIDO2. The terms are often used interchangeably. Passkeys are the user-friendly brand name for synced FIDO2 credentials (backed up to iCloud Keychain, Google Password Manager, etc.)."
  },
  {
    question: "What are resident credentials (discoverable credentials)?",
    answer: "A resident credential (also called a discoverable credential or passkey) stores the user handle on the authenticator itself — alongside the private key. This enables usernameless authentication: the user visits your login page, taps 'Sign in with Passkey', and the authenticator presents matching credentials without the user typing a username first. Non-resident credentials require the server to know which credential IDs belong to the user (via allowCredentials) before the browser can proceed. Set residentKey: 'required' in authenticatorSelection to mandate discoverable credentials."
  },
  {
    question: "How do passkeys work across devices (cross-device authentication)?",
    answer: "Passkeys sync across a user's devices via cloud keychain providers: Apple syncs via iCloud Keychain across iPhone, iPad, Mac, and Safari on Windows. Google syncs via Google Password Manager across Android and Chrome. The private key is stored in the platform's secure enclave and only the encrypted key material is synced — the raw private key never leaves the device. For cross-device sign-in (e.g., signing into a laptop using a phone), WebAuthn uses Bluetooth proximity via CTAP 2.2 hybrid transport: the laptop shows a QR code, the phone scans it, and authentication completes over an encrypted BLE channel. This prevents remote phishing even in cross-device flows."
  },
];
---

<BaseLayout
  title="Passkey & WebAuthn Flow Debugger — Visualize Authentication Steps"
  description="Visualize WebAuthn registration and authentication flows step by step. Build PublicKeyCredentialCreationOptions JSON, understand credential structure, and debug passkey implementations."
  tool="WebAuthn Debugger, Passkey Flow, FIDO2 Visualizer, PublicKeyCredentialCreationOptions, WebAuthn Registration, WebAuthn Authentication, Passkey Implementation"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Passkey & WebAuthn Flow Debugger",
    "url": "https://devplaybook.cc/tools/passkey-webauthn-debugger",
    "description": "Visualize WebAuthn registration and authentication flows step by step. Build PublicKeyCredentialCreationOptions JSON, understand credential structure, and debug passkey implementations.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Passkey &amp; WebAuthn Flow Debugger</h1>
  <p class="text-text-muted mb-4">
    Step through WebAuthn registration and authentication flows — see exactly what the browser does,
    what the server expects, and example JSON at each step. Build a real
    <code class="font-mono bg-surface px-1 rounded text-sm">PublicKeyCredentialCreationOptions</code>
    payload with fresh challenge, RP settings, and authenticator selection options.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Registration flow (6 steps)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Authentication flow (6 steps)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Credential options builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <PasskeyWebauthnDebugger client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Passkey & WebAuthn Flow Debugger" relatedTags={['security', 'auth', 'webauthn', 'passkey', 'fido2', 'developer-tools']} />
</BaseLayout>
