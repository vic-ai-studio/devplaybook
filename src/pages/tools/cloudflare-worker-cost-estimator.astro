---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the Cloudflare Workers free tier?", answer: "The Free plan includes 100,000 requests per day and 10ms CPU time per request at no cost. There is no monthly fee. Once you exceed either limit, requests are failed (not billed). The Paid plan at $5/month gives you 10M included requests and 30M included CPU ms per month, with charges beyond that." },
  { question: "How does Cloudflare Workers CPU time billing work?", answer: "On the Paid plan, you get 30 million CPU milliseconds free per month. Beyond that, it's $0.02 per million CPU ms. CPU time is wall-clock time spent executing your Worker code — it excludes time waiting for external fetch calls or KV operations. A typical lightweight API call might use 1–5ms of CPU." },
  { question: "What are Cloudflare KV costs?", answer: "KV reads: first 10M free, then $0.50 per million. KV writes/deletes: first 1M free, then $5.00 per million. KV lists: first 1M free, then $5.00 per million. Storage: $0.50/GB stored per month (first 1 GB free). KV is eventually consistent — for strongly consistent data use Durable Objects instead." },
  { question: "How does Cloudflare Workers compare to AWS Lambda?", answer: "Workers runs at the edge (200+ PoPs globally) with sub-millisecond cold starts vs Lambda's 100ms+ cold start. Workers pricing is simpler — per request + CPU ms. Lambda bills per GB-second of memory allocation, which can be wasteful. For lightweight API workloads under 128MB/100ms, Workers is typically 5–10x cheaper than Lambda." },
  { question: "Should I use Workers Free or Workers Paid?", answer: "Free is ideal for personal projects, prototypes, or low-traffic internal tools under 100k req/day. Paid ($5/mo) makes sense once you exceed 100k req/day, need reliable SLAs, or use features like Workers KV at scale, Cron Triggers, or larger script sizes (10 MB vs 1 MB). The $5/month base covers up to 10M requests." },
];
---

<BaseLayout
  title="Cloudflare Workers Cost Estimator — Requests, CPU Time & KV Costs"
  description="Estimate Cloudflare Workers monthly costs including request charges, CPU time, and KV operations. Compare Free vs Paid plans and see how you stack up against AWS Lambda."
  tool="Cloudflare Workers cost calculator, Workers pricing estimator, KV cost calculator, Workers vs Lambda cost comparison"
  keywords={["cloudflare workers cost", "workers pricing calculator", "cloudflare kv cost", "workers vs lambda", "edge computing cost", "cloudflare paid plan"]}
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Cloudflare Workers Cost Estimator</h1>
  <p class="text-text-muted mb-4">Estimate your monthly Workers bill including requests, CPU time, and KV operations. Compare plans and see how it stacks up against AWS Lambda.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Free vs Paid plan comparison</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> KV operations included</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> AWS Lambda comparison</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <!-- Input Panel -->
    <div class="bg-bg-card border border-border rounded-xl p-5 space-y-4">
      <h2 class="text-base font-semibold">Worker Configuration</h2>

      <div>
        <label class="block text-sm font-medium mb-1.5">Daily Requests</label>
        <input id="daily-requests" type="number" min="0" value="500000"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        <div class="flex gap-2 mt-2 flex-wrap">
          <button class="req-preset text-xs px-2.5 py-1 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-v="50000">50K</button>
          <button class="req-preset text-xs px-2.5 py-1 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-v="500000">500K</button>
          <button class="req-preset text-xs px-2.5 py-1 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-v="2000000">2M</button>
          <button class="req-preset text-xs px-2.5 py-1 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-v="10000000">10M</button>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1.5">Avg CPU Time per Request (ms)</label>
        <input id="cpu-time" type="number" min="0.1" step="0.1" value="5"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        <div class="flex gap-2 mt-2 flex-wrap">
          <button class="cpu-preset text-xs px-2.5 py-1 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-v="1">1ms</button>
          <button class="cpu-preset text-xs px-2.5 py-1 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-v="5">5ms</button>
          <button class="cpu-preset text-xs px-2.5 py-1 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-v="10">10ms</button>
          <button class="cpu-preset text-xs px-2.5 py-1 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-v="50">50ms</button>
        </div>
        <p class="text-xs text-text-muted mt-1">Free plan limit: 10ms/request</p>
      </div>

      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-sm font-medium mb-1.5">KV Reads / Request</label>
          <input id="kv-reads" type="number" min="0" value="2"
            class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5">KV Writes / Request</label>
          <input id="kv-writes" type="number" min="0" value="0.1" step="0.01"
            class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium mb-2">Plan Type</label>
        <div class="flex gap-3">
          <label class="flex-1 flex items-center gap-2 bg-bg border border-border rounded-lg px-3 py-2.5 cursor-pointer hover:border-primary transition-all">
            <input type="radio" name="plan" id="plan-free" value="free" class="accent-primary" />
            <span class="text-sm">Free</span>
            <span class="text-xs text-text-muted ml-auto">$0/mo</span>
          </label>
          <label class="flex-1 flex items-center gap-2 bg-bg border border-primary rounded-lg px-3 py-2.5 cursor-pointer transition-all">
            <input type="radio" name="plan" id="plan-paid" value="paid" checked class="accent-primary" />
            <span class="text-sm">Paid</span>
            <span class="text-xs text-primary ml-auto font-medium">$5/mo</span>
          </label>
        </div>
      </div>
    </div>

    <!-- Results Panel -->
    <div class="space-y-4">
      <!-- Free plan warning -->
      <div id="free-warning" class="hidden bg-yellow-500/10 border border-yellow-500/30 rounded-xl p-4 text-sm text-yellow-400">
        <strong>Free plan limit exceeded.</strong> At this volume, requests will be throttled after 100K/day. Switch to the Paid plan for reliable service.
      </div>

      <!-- Cost Breakdown Table -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Monthly Cost Breakdown</h2>
        <div class="space-y-3">
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-sm text-text-muted">Base plan fee</span>
            <span id="base-cost" class="text-sm font-mono font-medium">$5.00</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-sm text-text-muted">Request charges (beyond 10M free)</span>
            <span id="req-cost" class="text-sm font-mono font-medium">$0.00</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-sm text-text-muted">CPU time charges (beyond 30M ms free)</span>
            <span id="cpu-cost" class="text-sm font-mono font-medium">$0.00</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-sm text-text-muted">KV reads</span>
            <span id="kv-read-cost" class="text-sm font-mono font-medium">$0.00</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-sm text-text-muted">KV writes</span>
            <span id="kv-write-cost" class="text-sm font-mono font-medium">$0.00</span>
          </div>
          <div class="flex justify-between items-center py-2">
            <span class="text-sm font-semibold">Total monthly estimate</span>
            <span id="total-cost" class="text-lg font-mono font-bold text-primary">$5.00</span>
          </div>
        </div>
      </div>

      <!-- Key Metrics -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">Key Metrics</h2>
        <div class="grid grid-cols-2 gap-3 text-sm">
          <div class="bg-bg border border-border rounded-lg p-3">
            <p class="text-text-muted text-xs mb-1">Monthly requests</p>
            <p id="monthly-requests" class="font-mono font-semibold">0</p>
          </div>
          <div class="bg-bg border border-border rounded-lg p-3">
            <p class="text-text-muted text-xs mb-1">Monthly CPU ms</p>
            <p id="monthly-cpu-ms" class="font-mono font-semibold">0</p>
          </div>
          <div class="bg-bg border border-border rounded-lg p-3">
            <p class="text-text-muted text-xs mb-1">Cost per 1M requests</p>
            <p id="per-million" class="font-mono font-semibold">$0.000</p>
          </div>
          <div class="bg-bg border border-border rounded-lg p-3">
            <p class="text-text-muted text-xs mb-1">Effective $/request</p>
            <p id="per-request" class="font-mono font-semibold">$0.0000000</p>
          </div>
        </div>
      </div>

      <!-- vs Lambda Comparison -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">vs AWS Lambda (128 MB)</h2>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between">
            <span class="text-text-muted">AWS Lambda estimate</span>
            <span id="lambda-cost" class="font-mono">$0.00/mo</span>
          </div>
          <div class="flex justify-between">
            <span class="text-text-muted">Cloudflare Workers estimate</span>
            <span id="workers-cost-vs" class="font-mono font-semibold">$0.00/mo</span>
          </div>
          <div id="vs-verdict" class="mt-3 p-3 rounded-lg text-xs bg-green-500/10 text-green-400">
            Workers is cheaper for this workload.
          </div>
        </div>
      </div>
    </div>
  </div>

  <ToolPageCta />
  <FaqSection faq={faq} />
</BaseLayout>

<script>
  const DAYS_PER_MONTH = 30;

  // Workers Paid pricing
  const PAID_BASE = 5.00;
  const FREE_REQUESTS_PAID = 10_000_000; // 10M included
  const REQ_RATE = 0.30 / 1_000_000; // $0.30 per 1M after free
  const FREE_CPU_MS = 30_000_000; // 30M ms included
  const CPU_MS_RATE = 0.02 / 1_000_000; // $0.02 per 1M CPU ms after free

  // KV pricing (Paid)
  const FREE_KV_READS = 10_000_000;
  const KV_READ_RATE = 0.50 / 1_000_000;
  const FREE_KV_WRITES = 1_000_000;
  const KV_WRITE_RATE = 5.00 / 1_000_000;

  // AWS Lambda 128MB, $0.20/1M requests + $0.0000000021 per ms (approx)
  const LAMBDA_REQ_RATE = 0.20 / 1_000_000;
  const LAMBDA_GB_S_RATE = 0.0000166667; // per GB-second
  const LAMBDA_FREE_REQ = 1_000_000;
  const LAMBDA_FREE_GBS = 400_000;

  function fmt(n: number) {
    if (n === 0) return '$0.00';
    if (n < 0.001) return '$' + n.toFixed(6);
    if (n < 0.01) return '$' + n.toFixed(4);
    return '$' + n.toFixed(2);
  }
  function fmtLarge(n: number) {
    if (n >= 1e9) return (n / 1e9).toFixed(2) + 'B';
    if (n >= 1e6) return (n / 1e6).toFixed(2) + 'M';
    if (n >= 1e3) return (n / 1e3).toFixed(1) + 'K';
    return n.toFixed(0);
  }

  function calculate() {
    const dailyRequests = parseFloat((document.getElementById('daily-requests') as HTMLInputElement).value) || 0;
    const cpuTimeMs = parseFloat((document.getElementById('cpu-time') as HTMLInputElement).value) || 0;
    const kvReadsPerReq = parseFloat((document.getElementById('kv-reads') as HTMLInputElement).value) || 0;
    const kvWritesPerReq = parseFloat((document.getElementById('kv-writes') as HTMLInputElement).value) || 0;
    const plan = (document.querySelector('input[name="plan"]:checked') as HTMLInputElement)?.value || 'paid';

    const monthlyRequests = dailyRequests * DAYS_PER_MONTH;
    const monthlyCpuMs = monthlyRequests * cpuTimeMs;
    const monthlyKvReads = monthlyRequests * kvReadsPerReq;
    const monthlyKvWrites = monthlyRequests * kvWritesPerReq;

    // Free plan check
    const freeWarning = document.getElementById('free-warning') as HTMLElement;
    if (plan === 'free' && dailyRequests > 100_000) {
      freeWarning.classList.remove('hidden');
    } else {
      freeWarning.classList.add('hidden');
    }

    let baseCost = 0;
    let reqCost = 0;
    let cpuCost = 0;
    let kvReadCost = 0;
    let kvWriteCost = 0;

    if (plan === 'paid') {
      baseCost = PAID_BASE;
      const billableRequests = Math.max(0, monthlyRequests - FREE_REQUESTS_PAID);
      reqCost = billableRequests * REQ_RATE;
      const billableCpuMs = Math.max(0, monthlyCpuMs - FREE_CPU_MS);
      cpuCost = billableCpuMs * CPU_MS_RATE;
      const billableKvReads = Math.max(0, monthlyKvReads - FREE_KV_READS);
      kvReadCost = billableKvReads * KV_READ_RATE;
      const billableKvWrites = Math.max(0, monthlyKvWrites - FREE_KV_WRITES);
      kvWriteCost = billableKvWrites * KV_WRITE_RATE;
    }
    // Free plan: $0, but throttled after 100K/day

    const total = baseCost + reqCost + cpuCost + kvReadCost + kvWriteCost;

    // AWS Lambda estimate for same workload (128MB, same CPU duration)
    // Lambda uses wall time not CPU time — assume CPU ≈ wall for fair comparison
    const lambdaGbS = (monthlyCpuMs / 1000) * (128 / 1024);
    const billableLambdaReq = Math.max(0, monthlyRequests - LAMBDA_FREE_REQ);
    const billableLambdaGbs = Math.max(0, lambdaGbS - LAMBDA_FREE_GBS);
    const lambdaCost = billableLambdaReq * LAMBDA_REQ_RATE + billableLambdaGbs * LAMBDA_GB_S_RATE;

    // Update DOM
    (document.getElementById('base-cost') as HTMLElement).textContent = plan === 'free' ? '$0.00' : '$5.00';
    (document.getElementById('req-cost') as HTMLElement).textContent = fmt(reqCost);
    (document.getElementById('cpu-cost') as HTMLElement).textContent = fmt(cpuCost);
    (document.getElementById('kv-read-cost') as HTMLElement).textContent = fmt(kvReadCost);
    (document.getElementById('kv-write-cost') as HTMLElement).textContent = fmt(kvWriteCost);
    (document.getElementById('total-cost') as HTMLElement).textContent = plan === 'free' ? '$0.00 (throttled)' : fmt(total);
    (document.getElementById('monthly-requests') as HTMLElement).textContent = fmtLarge(monthlyRequests);
    (document.getElementById('monthly-cpu-ms') as HTMLElement).textContent = fmtLarge(monthlyCpuMs) + ' ms';
    (document.getElementById('per-million') as HTMLElement).textContent = monthlyRequests > 0 ? fmt(total / monthlyRequests * 1_000_000) : '$0.00';
    (document.getElementById('per-request') as HTMLElement).textContent = monthlyRequests > 0 ? '$' + (total / monthlyRequests).toFixed(8) : '$0.00000000';
    (document.getElementById('lambda-cost') as HTMLElement).textContent = fmt(lambdaCost) + '/mo';
    (document.getElementById('workers-cost-vs') as HTMLElement).textContent = fmt(total) + '/mo';

    const verdict = document.getElementById('vs-verdict') as HTMLElement;
    if (total <= lambdaCost) {
      const saving = lambdaCost - total;
      verdict.className = 'mt-3 p-3 rounded-lg text-xs bg-green-500/10 text-green-400';
      verdict.textContent = saving > 0.01
        ? `Workers saves $${saving.toFixed(2)}/mo vs Lambda. Edge deployment also means faster global latency.`
        : 'Similar cost to Lambda. Workers adds edge latency benefits at no extra charge.';
    } else {
      const diff = total - lambdaCost;
      verdict.className = 'mt-3 p-3 rounded-lg text-xs bg-yellow-500/10 text-yellow-400';
      verdict.textContent = `Lambda is $${diff.toFixed(2)}/mo cheaper here. Workers still wins on cold start latency and global edge routing.`;
    }
  }

  document.querySelectorAll('.req-preset').forEach(btn => {
    btn.addEventListener('click', () => {
      (document.getElementById('daily-requests') as HTMLInputElement).value = btn.getAttribute('data-v') || '';
      calculate();
    });
  });
  document.querySelectorAll('.cpu-preset').forEach(btn => {
    btn.addEventListener('click', () => {
      (document.getElementById('cpu-time') as HTMLInputElement).value = btn.getAttribute('data-v') || '';
      calculate();
    });
  });

  ['daily-requests', 'cpu-time', 'kv-reads', 'kv-writes'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', calculate);
  });
  document.querySelectorAll('input[name="plan"]').forEach(radio => {
    radio.addEventListener('change', calculate);
  });

  calculate();
</script>
