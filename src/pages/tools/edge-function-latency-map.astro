---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What are edge functions?", answer: "Edge functions are serverless functions that run at CDN points of presence (PoPs) distributed globally, rather than in a single cloud region. They execute within milliseconds of the end user's location. Major providers include Cloudflare Workers (300+ PoPs), Vercel Edge Functions (based on Cloudflare), and Fastly Compute (100+ PoPs). Edge functions use the V8 isolates model rather than full Node.js, giving them near-zero cold starts." },
  { question: "What is the latency difference between edge functions and regional Lambda?", answer: "Edge functions typically add 5-50ms of latency to a user request because execution happens at the nearest CDN PoP. Regional Lambda (e.g., us-east-1) adds 80-250ms for users in that region, but 200-500ms+ for users on other continents. For global audiences requiring low latency, edge functions provide consistently fast response times regardless of user location." },
  { question: "Do edge functions have cold starts?", answer: "Edge functions using the V8 isolates model (Cloudflare Workers, Vercel Edge) have near-zero cold starts — typically under 5ms — because isolates are much lighter than full process/container environments. Fastly Compute using WebAssembly also achieves sub-millisecond cold starts. This is a significant advantage over regional Lambda which can have 100ms-4000ms cold starts depending on runtime." },
  { question: "What are the limitations of edge functions compared to regional serverless?", answer: "Edge functions have significant constraints: CPU time limits (1-50ms per request), memory limits (128MB), no persistent connections (no TCP database connections), limited Node.js APIs, and no file system access. They cannot run long computations, maintain WebSocket connections over time, or access VPC resources. For database-heavy logic, prefer regional Lambda or use edge-compatible databases like PlanetScale's HTTP driver." },
  { question: "When should I use edge functions vs regional Lambda?", answer: "Use edge functions for: JWT/cookie validation before hitting origin, geolocation-based redirects, A/B testing header injection, bot detection, rate limiting at CDN layer, and serving personalized cached responses. Use regional Lambda for: database queries, complex business logic, third-party API calls requiring persistent connections, operations exceeding 50ms CPU time, and anything requiring VPC access." },
  { question: "Which CDN provider has the most edge locations?", answer: "Cloudflare leads with 300+ PoPs across 100+ countries. Fastly has 100+ PoPs. Vercel Edge Functions run on Cloudflare's infrastructure. AWS CloudFront has 450+ distribution points but Lambda@Edge runs only in ~20 regional edge locations (not all PoPs). For maximum geographic coverage, Cloudflare Workers provides the widest distribution." },
];
---

<BaseLayout
  title="Edge Function Latency: CDN PoP Comparison & Optimization Guide"
  description="Compare edge function latency across Cloudflare Workers, Vercel Edge, and Fastly. Learn when to use edge vs regional serverless, P95 latency benchmarks, and optimization strategies."
  tool="Edge Functions, CDN Latency, Cloudflare Workers, Vercel Edge, Edge Computing, CDN PoP"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"Edge Function Latency: CDN PoP Comparison & Optimization Guide","url":"https://devplaybook.cc/tools/edge-function-latency-map","description":"Compare edge function latency across Cloudflare Workers, Vercel Edge, and Fastly. Benchmarks, use cases, and when to choose edge vs regional serverless."})} />

  <h1 class="text-3xl font-bold mb-2">Edge Function Latency: CDN PoP Comparison & Optimization Guide</h1>
  <p class="text-text-muted mb-6">Edge functions run your code at CDN points of presence globally, delivering sub-50ms latency to users worldwide. This guide compares providers, benchmarks real-world latency, and defines exactly when edge functions outperform regional serverless.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Cloudflare vs Vercel vs Fastly comparison</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> P95 latency benchmarks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Near-zero cold starts explained</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Edge vs regional decision guide</span>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-4">Edge Function Platform Comparison</h2>
  <div class="overflow-x-auto mb-8">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4">Provider</th>
          <th class="text-left py-2 pr-4">PoPs</th>
          <th class="text-left py-2 pr-4">P50 Latency</th>
          <th class="text-left py-2 pr-4">Cold Start</th>
          <th class="text-left py-2 pr-4">CPU Limit</th>
          <th class="text-left py-2">Runtime</th>
        </tr>
      </thead>
      <tbody class="text-text-muted">
        <tr class="border-b border-border"><td class="py-2 pr-4">Cloudflare Workers</td><td class="py-2 pr-4">300+</td><td class="py-2 pr-4">5-30ms</td><td class="py-2 pr-4">&lt;5ms</td><td class="py-2 pr-4">10ms / 50ms</td><td class="py-2">V8 Isolates</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Vercel Edge Functions</td><td class="py-2 pr-4">~300</td><td class="py-2 pr-4">5-35ms</td><td class="py-2 pr-4">&lt;5ms</td><td class="py-2 pr-4">~50ms</td><td class="py-2">V8 Isolates (CF)</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Fastly Compute</td><td class="py-2 pr-4">100+</td><td class="py-2 pr-4">10-50ms</td><td class="py-2 pr-4">&lt;1ms</td><td class="py-2 pr-4">50ms default</td><td class="py-2">WASM</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">AWS Lambda@Edge</td><td class="py-2 pr-4">~20 regional</td><td class="py-2 pr-4">50-150ms</td><td class="py-2 pr-4">100-500ms</td><td class="py-2 pr-4">5 seconds</td><td class="py-2">Node.js / Python</td></tr>
        <tr><td class="py-2 pr-4">Deno Deploy</td><td class="py-2 pr-4">35+</td><td class="py-2 pr-4">10-60ms</td><td class="py-2 pr-4">&lt;5ms</td><td class="py-2 pr-4">No hard limit</td><td class="py-2">V8 (Deno)</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-4">Use Case 1: Authentication at the Edge</h2>
  <p class="text-text-muted mb-4">Validate JWTs or session cookies before requests reach your origin, eliminating unauthorized traffic entirely:</p>
  <pre class="bg-surface border border-border rounded-lg p-4 mb-6 overflow-x-auto text-sm"><code>// Cloudflare Worker — JWT validation at edge
export default &#123;
  async fetch(request: Request): Promise&#60;Response&#62; &#123;
    const authHeader = request.headers.get('Authorization');

    if (!authHeader?.startsWith('Bearer ')) &#123;
      return new Response('Unauthorized', &#123; status: 401 &#125;);
    &#125;

    const token = authHeader.slice(7);

    try &#123;
      // Verify JWT using Web Crypto API (available at edge)
      const isValid = await verifyJWT(token, JWT_SECRET);
      if (!isValid) return new Response('Invalid token', &#123; status: 401 &#125;);
    &#125; catch &#123;
      return new Response('Auth error', &#123; status: 401 &#125;);
    &#125;

    // Token valid — forward to origin
    return fetch(request);
  &#125;
&#125;;
// Result: Auth check adds ~5ms, unauthorized requests never hit origin</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-4">Use Case 2: Geo-Redirect at Edge</h2>
  <pre class="bg-surface border border-border rounded-lg p-4 mb-6 overflow-x-auto text-sm"><code>// Vercel Edge Middleware — geo-based redirect
import &#123; NextResponse &#125; from 'next/server';
import type &#123; NextRequest &#125; from 'next/server';

export function middleware(request: NextRequest) &#123;
  const country = request.geo?.country ?? 'US';
  const url = request.nextUrl.clone();

  // Redirect EU users to GDPR-compliant domain
  if (['DE', 'FR', 'IT', 'ES', 'NL'].includes(country)) &#123;
    url.hostname = 'eu.example.com';
    return NextResponse.redirect(url, 302);
  &#125;

  // Add geo header for origin to use
  const response = NextResponse.next();
  response.headers.set('x-user-country', country);
  return response;
&#125;

export const config = &#123;
  matcher: ['/((?!api|_next/static|_next/image|favicon.ico).*)'],
&#125;;
// Geo data available from CF headers — no external API call needed</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-4">Edge vs Regional Serverless: Decision Guide</h2>
  <div class="overflow-x-auto mb-8">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4">Requirement</th>
          <th class="text-left py-2 pr-4">Edge Functions</th>
          <th class="text-left py-2">Regional Lambda</th>
        </tr>
      </thead>
      <tbody class="text-text-muted">
        <tr class="border-b border-border"><td class="py-2 pr-4">Database queries</td><td class="py-2 pr-4">HTTP-only (PlanetScale/Neon)</td><td class="py-2">Full support</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Global low latency</td><td class="py-2 pr-4">Excellent (&lt;50ms)</td><td class="py-2">Region-dependent</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Long computations</td><td class="py-2 pr-4">Not suitable (&gt;50ms)</td><td class="py-2">Up to 15 min</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">JWT/cookie auth</td><td class="py-2 pr-4">Ideal use case</td><td class="py-2">Works but slower</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">VPC resources</td><td class="py-2 pr-4">Not supported</td><td class="py-2">Full support</td></tr>
        <tr><td class="py-2 pr-4">A/B testing headers</td><td class="py-2 pr-4">Ideal use case</td><td class="py-2">Possible but adds origin RTT</td></tr>
      </tbody>
    </table>
  </div>

  <ToolPageCta currentTool="Edge Function Latency Map" relatedTags={['cloudflare', 'vercel', 'edge', 'cdn', 'serverless', 'performance']} />
  <FaqSection faq={faq} />
</BaseLayout>
