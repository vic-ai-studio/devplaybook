---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BorderRadiusGenerator from '../../components/BorderRadiusGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="CSS Border Radius Generator — Visual Corner Builder"
  description="Build CSS border-radius values visually. Control all four corners individually, use elliptical radii for organic shapes, or pick from 12 presets. Copy the CSS instantly."
  tool="Border Radius Generator, CSS border-radius, CSS rounded corners"
>
  <h1 class="text-3xl font-bold mb-2">CSS Border Radius Generator</h1>
  <p class="text-text-muted mb-8">Design rounded corners visually with live preview. Control each corner independently, switch between px and %, or use elliptical radii for pill and blob shapes. 12 quick presets included.</p>
  <BorderRadiusGenerator client:only="preact" />
  <ToolPageCta currentTool="CSS Border Radius Generator" relatedTags={['css', 'design', 'border-radius', 'generator']} />
</BaseLayout>
