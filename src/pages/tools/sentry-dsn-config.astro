---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SentryDsnConfig from '../../components/SentryDsnConfig.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a Sentry DSN and where do I find it?",
    answer: "DSN (Data Source Name) is a connection string that tells your Sentry SDK where to send error events. It contains your project ID and public key. Find it in: Sentry Dashboard → Settings → Projects → [your project] → SDK Setup → Client Keys (DSN). The DSN is safe to include in client-side code — it only allows event ingestion, not data reading."
  },
  {
    question: "What sample rates should I use in production?",
    answer: "Error sampleRate: keep at 1.0 (100%) for production — you want to capture all errors. tracesSampleRate: start at 0.1 (10%) to limit performance overhead; increase for more data. replaysSessionSampleRate: 0.1 (10%) is typical for session replay — recording all sessions is expensive. replaysOnErrorSampleRate: keep at 1.0 to always capture replays when errors occur."
  },
  {
    question: "How does Sentry integrate with Next.js App Router?",
    answer: "Use the Sentry Next.js wizard: npx @sentry/wizard@latest -i nextjs. This creates three config files: sentry.client.config.ts (browser), sentry.server.config.ts (Node server), and sentry.edge.config.ts (Edge Runtime). The wizard also sets up source map uploading for readable stack traces. For App Router, Sentry automatically instruments Server Components and API routes."
  },
  {
    question: "What is the difference between sampleRate and tracesSampleRate?",
    answer: "sampleRate controls what fraction of error events are captured and sent to Sentry (default 1.0 = all errors). tracesSampleRate controls performance tracing — how many requests get traced with spans and transaction data for performance monitoring. Setting tracesSampleRate too high can add latency overhead. These are independent: you can capture 100% of errors while tracing only 5% of transactions."
  },
  {
    question: "How do I set up Sentry source maps for readable stack traces?",
    answer: "Source maps are essential for production error debugging. For Vite/Next.js, use @sentry/vite-plugin or the Next.js wizard to auto-upload during build. Set SENTRY_AUTH_TOKEN as an environment variable (found in: User Settings → Auth Tokens). The auth token allows Sentry to associate uploaded source maps with releases. Never commit auth tokens to git — use environment variables or CI secrets."
  },
  {
    question: "How do I filter out irrelevant errors in Sentry?",
    answer: "Use beforeSend callback: Sentry.init({ beforeSend(event, hint) { if (event.exception?.values?.[0]?.type === 'ChunkLoadError') return null; return event; } }). Filter by URL with allowUrls/denyUrls to ignore CDN errors. Use ignoreErrors array for specific error messages or regex patterns. Set environment to filter by environment in the Sentry dashboard. Use issue filters and alerts to route important errors to the right team."
  },
];
---

<BaseLayout
  title="Sentry DSN Config Builder — Generate SDK Setup Code"
  description="Generate Sentry SDK initialization code for React, Next.js, Vue, Node.js, Python, and Astro. Configure DSN, sample rates, environment, and session replays. Free, runs in your browser."
  tool="sentry dsn config, sentry setup generator, sentry sdk configuration, sentry react setup, sentry nextjs config, error monitoring setup"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Sentry DSN Config Builder",
    "url": "https://devplaybook.cc/tools/sentry-dsn-config",
    "description": "Generate Sentry SDK initialization code for React, Next.js, Vue, Node.js, Python, and Astro with configurable sample rates and environment settings.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Sentry DSN Config Builder</h1>
  <p class="text-text-muted mb-4">
    Generate ready-to-use <strong>Sentry SDK initialization code</strong> for your framework. Paste your DSN, select React, Next.js, Vue, Node.js, Python, or Astro, configure sample rates and environment, and get copy-ready setup code instantly.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> React / Next.js / Vue</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Node.js / Python / Astro</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Sample rate config</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Session replay settings</span>
  </div>
  <SentryDsnConfig client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Sentry DSN Config Builder" relatedTags={['monitoring', 'error-tracking', 'react', 'nextjs', 'nodejs', 'developer-tools']} />
</BaseLayout>
