---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GrpcProtoValidator from '../../components/GrpcProtoValidator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What does this proto validator check?",
    answer: "It checks for: missing syntax declaration, missing package declaration, reserved field numbers (19000–19999 and 0), duplicate field numbers within a message, duplicate field names, field naming convention (snake_case), message naming convention (PascalCase), enum value naming (SCREAMING_SNAKE_CASE), enum first value must be 0 in proto3, missing language-specific options, and services without documentation comments."
  },
  {
    question: "Why must the first enum value be 0 in proto3?",
    answer: "In proto3, the default value for enum fields is always the first defined value with number 0. This is required so that unset fields have a predictable zero value. By convention, name this entry with a suffix like _UNSPECIFIED or _UNKNOWN (e.g. STATUS_UNSPECIFIED = 0) to make it clear that 0 means 'not set'."
  },
  {
    question: "Why are field numbers 19000–19999 reserved?",
    answer: "The Protobuf library itself uses field numbers 19000–19999 for internal purposes. If your message uses these numbers, it will conflict with the runtime and cause unpredictable behavior. Always use field numbers outside this range."
  },
  {
    question: "What is the Proto3 naming convention?",
    answer: "Field names: snake_case (e.g. user_id, created_at). Message names: PascalCase (e.g. UserRequest, CreateUserResponse). Service names: PascalCase (e.g. UserService). RPC names: PascalCase (e.g. GetUser, ListUsers). Enum type names: PascalCase. Enum value names: SCREAMING_SNAKE_CASE with the enum type prefix (e.g. STATUS_ACTIVE, STATUS_INACTIVE)."
  },
  {
    question: "What is the difference between proto2 and proto3?",
    answer: "Proto3 removes required/optional field modifiers (all fields are optional), uses simpler default values (zero/empty for all types), requires the first enum value to be 0, adds better JSON mapping support, and drops extensions in favor of 'Any'. Proto3 is recommended for new services. Proto2 is still supported but considered legacy."
  },
  {
    question: "Does this tool send my .proto file to a server?",
    answer: "No. All validation runs entirely in your browser using JavaScript. Your .proto file — which defines your API contract and data structures — never leaves your machine."
  },
];
---

<BaseLayout
  title="gRPC Proto Validator — Validate Protocol Buffer Files Online"
  description="Validate Protocol Buffer .proto files. Catch missing syntax, duplicate field numbers, naming violations, and proto3 best practices. Free, browser-side."
  tool="gRPC proto validator, protobuf linter, proto3 validator, Protocol Buffer checker, proto file validator online"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "gRPC Proto Validator",
    "url": "https://devplaybook.cc/tools/grpc-proto-validator",
    "description": "Validate Protocol Buffer .proto files online. Catches missing syntax declarations, duplicate field numbers, naming convention violations, and proto3 rules. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">gRPC Proto Validator</h1>
  <p class="text-text-muted mb-4">
    Paste your <code class="font-mono bg-surface px-1 rounded text-sm">.proto</code> file and catch mistakes before code generation.
    Validates syntax declarations, field numbering, naming conventions, enum rules, and proto3 compatibility.
    Nothing is sent to any server — runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Field number validation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Naming conventions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Proto3 rules</span>
  </div>
  <GrpcProtoValidator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="gRPC Proto Validator" relatedTags={['grpc', 'protobuf', 'api', 'validation', 'microservices', 'backend']} />
</BaseLayout>
