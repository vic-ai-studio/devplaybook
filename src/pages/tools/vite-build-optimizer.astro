---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "How do I analyze my Vite bundle size?", answer: "Install `rollup-plugin-visualizer`: `npm install --save-dev rollup-plugin-visualizer`. Add it to vite.config.ts plugins array: `visualizer({ open: true, gzipSize: true, brotliSize: true })`. Run `vite build` and a stats.html file opens in your browser showing a treemap of bundle composition by gzip and brotli size." },
  { question: "What is the difference between Vite's dev server and production build?", answer: "In dev mode, Vite serves files as native ES modules — no bundling, instant HMR. In production, Vite uses Rollup under the hood to bundle, tree-shake, and minify. Dev performance does not predict production bundle size. Always run `vite build` to check production output. Use `vite preview` to serve the production build locally and verify behavior." },
  { question: "How do I set up code splitting in Vite?", answer: "Vite handles code splitting automatically for dynamic imports. Use `() => import('./Component')` for lazy-loaded routes. Configure `manualChunks` in `build.rollupOptions` to force specific packages into their own chunks. For React apps, use `React.lazy()` + `<Suspense>` for component-level splitting. Vite also automatically splits CSS imported by JS into separate chunk files." },
  { question: "How do I configure Vite for maximum production performance?", answer: "Key optimizations: (1) `build.minify: 'esbuild'` (default, fastest) or `'terser'` for maximum compression. (2) `build.cssCodeSplit: true` (default) — separate CSS per chunk. (3) `build.rollupOptions.output.manualChunks` — vendor splitting. (4) Enable Brotli/gzip at the server level (Vite doesn't compress, your web server or CDN does). (5) Use `vite-plugin-compression` to pre-compress assets at build time." },
];
---

<BaseLayout
  title="Vite Build Optimizer Guide — Bundle Analysis, Code Splitting & Performance"
  description="Optimize your Vite production build: analyze bundle size with rollup-plugin-visualizer, configure code splitting, manual chunks, and pre-compression for maximum performance."
  tool="Vite, Vite build, Rollup, bundle optimization, code splitting, vite performance, frontend build"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Vite Build Optimizer Guide",
    "url": "https://devplaybook.cc/tools/vite-build-optimizer",
    "description": "Optimize Vite production builds with bundle analysis, code splitting, and pre-compression.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Vite Build Optimizer Guide</h1>
  <p class="text-text-muted mb-6">
    <strong>Vite</strong> uses Rollup for production builds — blazing fast in dev, highly optimizable in prod. Learn how to analyze bundle composition, configure code splitting, and squeeze maximum performance from your Vite output.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Bundle visualization</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Manual chunk config</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Pre-compression</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Build configuration</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Bundle Visualization with rollup-plugin-visualizer</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">npm install --save-dev rollup-plugin-visualizer</pre>

  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// vite.config.ts
import &#123; defineConfig &#125; from 'vite';
import &#123; visualizer &#125; from 'rollup-plugin-visualizer';

export default defineConfig(&#123;
  plugins: [
    visualizer(&#123;
      open: true,              // auto-open browser after build
      filename: 'dist/stats.html',
      gzipSize: true,          // show gzip sizes
      brotliSize: true,        // show brotli sizes (most accurate)
      template: 'treemap',     // 'treemap' | 'sunburst' | 'network'
    &#125;),
  ],
&#125;);</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Production Build Configuration</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// vite.config.ts
import &#123; defineConfig, splitVendorChunkPlugin &#125; from 'vite';

export default defineConfig(&#123;
  plugins: [splitVendorChunkPlugin()],  // auto vendor splitting
  build: &#123;
    target: 'es2020',          // modern browsers only
    minify: 'esbuild',         // fastest; use 'terser' for max compression
    cssCodeSplit: true,        // separate CSS per chunk
    sourcemap: false,          // disable in prod for smaller output
    chunkSizeWarningLimit: 500, // warn if chunk > 500KB

    rollupOptions: &#123;
      output: &#123;
        // Manual vendor chunk splitting
        manualChunks: &#123;
          'react-vendor': ['react', 'react-dom'],
          'router': ['react-router-dom'],
          'query': ['@tanstack/react-query'],
          'ui': ['@radix-ui/react-dialog', '@radix-ui/react-dropdown-menu'],
        &#125;,
        // Asset file naming
        chunkFileNames: 'assets/js/[name]-[hash].js',
        entryFileNames: 'assets/js/[name]-[hash].js',
        assetFileNames: 'assets/[ext]/[name]-[hash].[ext]',
      &#125;,
    &#125;,
  &#125;,
&#125;);</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Dynamic Imports for Code Splitting</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// React Router v6 with lazy loading
import &#123; lazy, Suspense &#125; from 'react';
import &#123; createBrowserRouter &#125; from 'react-router-dom';

const Dashboard = lazy(() => import('./pages/Dashboard'));
const Settings  = lazy(() => import('./pages/Settings'));
const Admin     = lazy(() => import('./pages/Admin'));

const router = createBrowserRouter([
  &#123;
    path: '/dashboard',
    element: (
      &lt;Suspense fallback=&#123;&lt;div&gt;Loading...&lt;/div&gt;&#125;&gt;
        &lt;Dashboard /&gt;
      &lt;/Suspense&gt;
    ),
  &#125;,
]);

// Vue Router lazy loading
const routes = [
  &#123;
    path: '/dashboard',
    component: () => import('./pages/Dashboard.vue'),
  &#125;,
];</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pre-Compression at Build Time</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">npm install --save-dev vite-plugin-compression</pre>

  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// vite.config.ts
import viteCompression from 'vite-plugin-compression';

export default defineConfig(&#123;
  plugins: [
    // Generate .gz files
    viteCompression(&#123; algorithm: 'gzip', ext: '.gz' &#125;),
    // Generate .br files (Brotli — 10–15% smaller than gzip)
    viteCompression(&#123; algorithm: 'brotliCompress', ext: '.br' &#125;),
  ],
&#125;);

// Configure nginx to serve pre-compressed files:
// gzip_static on;
// brotli_static on;  (requires ngx_brotli module)</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Build Performance Benchmarks</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Optimization</th>
          <th class="border border-border px-3 py-2 text-left">Impact</th>
          <th class="border border-border px-3 py-2 text-left">Effort</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2">Route-level code splitting</td><td class="border border-border px-3 py-2 text-green-400">High — 50–80% initial JS reduction</td><td class="border border-border px-3 py-2">Low</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Manual vendor chunks</td><td class="border border-border px-3 py-2 text-green-400">High — better caching</td><td class="border border-border px-3 py-2">Low</td></tr>
        <tr><td class="border border-border px-3 py-2">Brotli pre-compression</td><td class="border border-border px-3 py-2 text-yellow-400">Medium — 10–15% smaller</td><td class="border border-border px-3 py-2">Low</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Terser vs esbuild minify</td><td class="border border-border px-3 py-2 text-yellow-400">Low — 1–3% smaller</td><td class="border border-border px-3 py-2">Low</td></tr>
        <tr><td class="border border-border px-3 py-2">Tree-shake heavy deps</td><td class="border border-border px-3 py-2 text-green-400">High — depends on deps</td><td class="border border-border px-3 py-2">Medium</td></tr>
      </tbody>
    </table>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Vite Build Optimizer" relatedTags={['vite', 'performance', 'javascript', 'bundle-size', 'code-splitting', 'rollup']} />
</BaseLayout>
