---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is ETL schema mapping?", answer: "Schema mapping defines how fields from a source system translate to a target system. It specifies: which source column maps to which target column, any data type conversions needed (e.g. VARCHAR → INTEGER), and transformation rules (uppercase, trim whitespace, cast to date). Good schema mapping documentation is essential for debugging data discrepancies and onboarding new engineers to a pipeline." },
  { question: "What are common ETL transformation rules?", answer: "as-is: copy the value unchanged. uppercase/lowercase: standardize string casing. trim: remove leading/trailing whitespace. cast: convert data type (e.g. string '2024-01-15' to DATE). custom: apply a formula or expression (e.g. CONCAT(first_name, ' ', last_name)). null-replace: substitute NULL with a default value. format-date: reformat date strings (e.g. MM/DD/YYYY to YYYY-MM-DD)." },
  { question: "How do I handle data type mismatches in ETL?", answer: "Type mismatches are common between systems. Strategies: 1) CAST in SQL when loading into the warehouse. 2) Validate and reject at source with error logging. 3) Store everything as strings and cast at query time (flexible but slow). 4) Use explicit type converters in your ETL tool (dbt casts, Spark schema enforcement). Always test edge cases: empty strings cast to INT fail, trailing spaces in dates break CAST." },
  { question: "SQL SELECT vs pandas for ETL transformations?", answer: "SQL SELECT (via dbt, Spark SQL, or direct DB): better for large datasets, runs in-warehouse/distributed, SQL is readable by analysts. Python pandas: better for complex logic that's hard in SQL (ML transformations, API enrichment, custom string parsing), works well for small-medium datasets. Many modern stacks use SQL for heavy lifting (dbt) and Python for edge cases and data quality checks." },
  { question: "What should I document in a schema mapping?", answer: "For each field mapping document: source table/column, source data type, target table/column, target data type, transformation rule, example source value, example target value, nullable/not-null constraint, business logic notes (e.g. 'revenue is in cents, divide by 100'). This becomes your data dictionary and is critical for compliance, auditing, and troubleshooting data quality issues." },
];
---

<BaseLayout
  title="ETL Schema Mapper — SQL & Pandas Transformation Code Generator"
  description="Map source columns to target columns with type conversions and transformation rules. Generate SQL SELECT with CAST or Python pandas transformation code instantly."
  tool="ETL Schema Mapper, SQL CAST Generator, Data Type Mapping Tool, Pandas ETL Code Generator, Schema Transformation Builder"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "ETL Schema Mapper",
    "url": "https://devplaybook.cc/tools/etl-schema-mapper",
    "description": "Map ETL source to target schema with type conversions and generate SQL or pandas transformation code.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">ETL Schema Mapper</h1>
  <p class="text-text-muted mb-4">Define source-to-target column mappings with type conversions and transformation rules. Generate ready-to-use SQL SELECT with CAST statements or Python pandas transformation code.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Type conversion support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> SQL + pandas output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 6 transformation rules</span>
  </div>

  <div class="space-y-5">
    <!-- Table names -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="font-semibold mb-4">Table Configuration</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-text-muted mb-1" for="source-table">Source Table</label>
          <input id="source-table" type="text" value="raw.orders"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-1" for="target-table">Target Table</label>
          <input id="target-table" type="text" value="warehouse.fact_orders"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
        </div>
      </div>
    </div>

    <!-- Add mapping -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="font-semibold mb-4">Add Column Mapping</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-3">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="src-col">Source Column</label>
          <input id="src-col" type="text" placeholder="order_id"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="src-type">Source Type</label>
          <select id="src-type" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40">
            <option>VARCHAR</option><option>TEXT</option><option>INTEGER</option><option>BIGINT</option>
            <option>FLOAT</option><option>DECIMAL</option><option>BOOLEAN</option><option>DATE</option>
            <option>TIMESTAMP</option><option>JSON</option>
          </select>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="tgt-col">Target Column</label>
          <input id="tgt-col" type="text" placeholder="order_id"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="tgt-type">Target Type</label>
          <select id="tgt-type" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40">
            <option>VARCHAR</option><option>TEXT</option><option>INTEGER</option><option>BIGINT</option>
            <option>FLOAT</option><option>DECIMAL</option><option>BOOLEAN</option><option>DATE</option>
            <option>TIMESTAMP</option><option>JSON</option>
          </select>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="transform-rule">Transformation</label>
          <select id="transform-rule" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40">
            <option value="as-is">as-is</option>
            <option value="uppercase">uppercase</option>
            <option value="lowercase">lowercase</option>
            <option value="trim">trim</option>
            <option value="cast">cast</option>
            <option value="custom">custom</option>
          </select>
        </div>
        <div id="custom-expr-wrap" class="hidden">
          <label class="block text-xs text-text-muted mb-1" for="custom-expr">Custom Expression</label>
          <input id="custom-expr" type="text" placeholder="e.g. price / 100.0"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
        </div>
      </div>
      <button id="add-mapping-btn" class="bg-primary text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-primary/80 transition-colors">+ Add Mapping</button>
    </div>

    <!-- Mappings table -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="font-semibold mb-3">Column Mappings</h2>
      <div id="mappings-list">
        <p class="text-text-muted text-sm italic" id="no-mappings-msg">No mappings yet.</p>
      </div>
    </div>

    <!-- Output -->
    <div id="output-section" class="hidden space-y-4">
      <div class="flex gap-3">
        <button id="gen-sql-btn" class="bg-primary text-white px-5 py-2.5 rounded-lg font-semibold hover:bg-primary/80 transition-colors text-sm">Generate SQL</button>
        <button id="gen-pandas-btn" class="bg-bg border border-border px-5 py-2.5 rounded-lg font-semibold hover:bg-primary/10 hover:border-primary/40 transition-colors text-sm">Generate Pandas</button>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-semibold" id="output-title">Output</h2>
          <button id="copy-output" class="text-xs px-3 py-1 rounded-lg border border-border hover:bg-primary/10 hover:border-primary/40 transition-colors">Copy</button>
        </div>
        <pre id="code-output" class="bg-bg rounded-lg p-4 text-xs font-mono text-primary overflow-x-auto whitespace-pre-wrap max-h-96"></pre>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="ETL Schema Mapper" relatedTags={['etl', 'sql', 'data', 'pandas', 'schema', 'data-engineering']} />
</BaseLayout>

<script is:inline>
(function () {
  var mappings = [];

  document.getElementById('transform-rule').addEventListener('change', function () {
    var wrap = document.getElementById('custom-expr-wrap');
    if (this.value === 'custom') {
      wrap.classList.remove('hidden');
    } else {
      wrap.classList.add('hidden');
    }
  });

  function buildSqlExpr(m) {
    var col = m.srcCol;
    switch (m.rule) {
      case 'as-is': return (m.srcType !== m.tgtType) ? 'CAST(' + col + ' AS ' + m.tgtType + ')' : col;
      case 'uppercase': return 'UPPER(' + col + ')';
      case 'lowercase': return 'LOWER(' + col + ')';
      case 'trim': return 'TRIM(' + col + ')';
      case 'cast': return 'CAST(' + col + ' AS ' + m.tgtType + ')';
      case 'custom': return m.customExpr || col;
      default: return col;
    }
  }

  function buildPandasExpr(m) {
    var col = "df['" + m.srcCol + "']";
    switch (m.rule) {
      case 'as-is': return col;
      case 'uppercase': return col + '.str.upper()';
      case 'lowercase': return col + '.str.lower()';
      case 'trim': return col + '.str.strip()';
      case 'cast':
        var typeMap = { INTEGER: 'int', BIGINT: 'int64', FLOAT: 'float', DECIMAL: 'float', BOOLEAN: 'bool', DATE: 'datetime64[ns]', TIMESTAMP: 'datetime64[ns]', VARCHAR: 'str', TEXT: 'str' };
        return 'pd.to_datetime(' + col + ')' || col + '.astype(' + (typeMap[m.tgtType] || 'str') + ')';
      case 'custom': return m.customExpr ? m.customExpr.replace(new RegExp(m.srcCol, 'g'), "df['" + m.srcCol + "']") : col;
      default: return col;
    }
  }

  function renderMappings() {
    var list = document.getElementById('mappings-list');
    var noMsg = document.getElementById('no-mappings-msg');
    var outSection = document.getElementById('output-section');
    if (mappings.length === 0) {
      list.innerHTML = '';
      list.appendChild(noMsg);
      noMsg.classList.remove('hidden');
      outSection.classList.add('hidden');
      return;
    }
    noMsg.classList.add('hidden');
    outSection.classList.remove('hidden');
    list.innerHTML = '<div class="overflow-x-auto"><table class="w-full text-xs"><thead><tr class="text-text-muted border-b border-border"><th class="text-left py-2 pr-3">Source</th><th class="text-left py-2 pr-3">Src Type</th><th class="text-left py-2 pr-3">Target</th><th class="text-left py-2 pr-3">Tgt Type</th><th class="text-left py-2 pr-3">Rule</th><th class="py-2"></th></tr></thead><tbody id="map-tbody" class="divide-y divide-border"></tbody></table></div>';
    var tbody = document.getElementById('map-tbody');
    mappings.forEach(function (m, i) {
      var tr = document.createElement('tr');
      tr.innerHTML = '<td class="py-2 pr-3 font-mono">' + m.srcCol + '</td>'
        + '<td class="py-2 pr-3 text-text-muted">' + m.srcType + '</td>'
        + '<td class="py-2 pr-3 font-mono">' + m.tgtCol + '</td>'
        + '<td class="py-2 pr-3 text-text-muted">' + m.tgtType + '</td>'
        + '<td class="py-2 pr-3"><span class="px-2 py-0.5 rounded bg-primary/10 text-primary text-xs">' + m.rule + (m.customExpr ? ': ' + m.customExpr : '') + '</span></td>'
        + '<td class="py-2"><button class="text-red-400 hover:text-red-300 text-xs" data-idx="' + i + '">Remove</button></td>';
      tr.querySelector('button').addEventListener('click', function (e) {
        mappings.splice(parseInt(e.target.getAttribute('data-idx')), 1);
        renderMappings();
      });
      tbody.appendChild(tr);
    });
  }

  document.getElementById('add-mapping-btn').addEventListener('click', function () {
    var srcCol = document.getElementById('src-col').value.trim();
    var srcType = document.getElementById('src-type').value;
    var tgtCol = document.getElementById('tgt-col').value.trim() || srcCol;
    var tgtType = document.getElementById('tgt-type').value;
    var rule = document.getElementById('transform-rule').value;
    var customExpr = document.getElementById('custom-expr').value.trim();
    if (!srcCol) { alert('Please enter a source column name.'); return; }
    mappings.push({ srcCol: srcCol, srcType: srcType, tgtCol: tgtCol, tgtType: tgtType, rule: rule, customExpr: customExpr });
    document.getElementById('src-col').value = '';
    document.getElementById('tgt-col').value = '';
    document.getElementById('custom-expr').value = '';
    renderMappings();
  });

  function generateCode(mode) {
    var srcTable = document.getElementById('source-table').value.trim() || 'source_table';
    var tgtTable = document.getElementById('target-table').value.trim() || 'target_table';
    var code = '';
    if (mode === 'sql') {
      document.getElementById('output-title').textContent = 'SQL SELECT Statement';
      var selects = mappings.map(function (m) {
        var expr = buildSqlExpr(m);
        return '  ' + (expr !== m.tgtCol ? expr + ' AS ' + m.tgtCol : m.tgtCol);
      });
      code = 'INSERT INTO ' + tgtTable + ' (\n'
        + mappings.map(function (m) { return '  ' + m.tgtCol; }).join(',\n') + '\n)\n'
        + 'SELECT\n' + selects.join(',\n') + '\nFROM ' + srcTable + ';';
    } else {
      document.getElementById('output-title').textContent = 'Python Pandas Code';
      var lines = ["import pandas as pd\n", "# Read source", "df = pd.read_sql('SELECT * FROM " + srcTable + "', conn)\n", "# Apply transformations"];
      mappings.forEach(function (m) {
        var expr = buildPandasExpr(m);
        lines.push("df['" + m.tgtCol + "'] = " + expr);
      });
      lines.push("\n# Select target columns");
      lines.push("result = df[" + JSON.stringify(mappings.map(function (m) { return m.tgtCol; })) + "]");
      lines.push("\n# Load to target");
      lines.push("result.to_sql('" + tgtTable.split('.').pop() + "', con=engine, if_exists='append', index=False)");
      code = lines.join('\n');
    }
    document.getElementById('code-output').textContent = code;
    document.getElementById('copy-output').onclick = function () {
      navigator.clipboard.writeText(code).then(function () {
        var btn = document.getElementById('copy-output');
        btn.textContent = 'Copied!';
        setTimeout(function () { btn.textContent = 'Copy'; }, 2000);
      });
    };
  }

  document.getElementById('gen-sql-btn').addEventListener('click', function () { generateCode('sql'); });
  document.getElementById('gen-pandas-btn').addEventListener('click', function () { generateCode('pandas'); });

  // Seed example
  mappings = [
    { srcCol: 'order_id', srcType: 'VARCHAR', tgtCol: 'order_id', tgtType: 'BIGINT', rule: 'cast', customExpr: '' },
    { srcCol: 'customer_name', srcType: 'TEXT', tgtCol: 'customer_name', tgtType: 'VARCHAR', rule: 'trim', customExpr: '' },
    { srcCol: 'status', srcType: 'VARCHAR', tgtCol: 'status', tgtType: 'VARCHAR', rule: 'uppercase', customExpr: '' },
    { srcCol: 'amount_cents', srcType: 'INTEGER', tgtCol: 'amount_usd', tgtType: 'DECIMAL', rule: 'custom', customExpr: 'amount_cents / 100.0' },
    { srcCol: 'created_at', srcType: 'VARCHAR', tgtCol: 'created_at', tgtType: 'TIMESTAMP', rule: 'cast', customExpr: '' },
  ];
  renderMappings();
  generateCode('sql');
})();
</script>
