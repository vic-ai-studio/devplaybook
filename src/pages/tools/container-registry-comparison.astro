---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a container registry?", answer: "A container registry is a repository for storing, managing, and distributing container images. Images are pushed to a registry after building and pulled from the registry when deploying. Registries support versioning via tags (e.g., myapp:1.0.0, myapp:latest), access control so only authorized users or systems can pull images, and often vulnerability scanning to detect known CVEs in image layers before deployment." },
  { question: "What is the difference between ECR and Docker Hub?", answer: "ECR (Elastic Container Registry) is AWS's managed private registry deeply integrated with IAM, ECS, EKS, and CodeBuild — auth uses short-lived AWS tokens (12h TTL). Docker Hub is the public default registry for Docker, with free public images and tiered plans for private repos. ECR has no rate limits within AWS infrastructure, while Docker Hub enforces pull rate limits for anonymous and free-tier users (100/6h anonymous, 200/6h free accounts)." },
  { question: "What is GHCR and when should I use it?", answer: "GHCR (GitHub Container Registry, ghcr.io) is GitHub's built-in image registry. It integrates natively with GitHub Actions via GITHUB_TOKEN — no extra credentials needed for same-repo images. Free for public images, included in GitHub plans for private images. Best for teams already on GitHub who want a zero-friction CI/CD pipeline without managing additional registry credentials." },
  { question: "Does Google Artifact Registry replace GCR?", answer: "Yes. Google Container Registry (gcr.io) is deprecated in favor of Artifact Registry (pkg.dev). Artifact Registry supports multiple artifact formats (Docker, npm, Maven, PyPI), fine-grained IAM permissions at the repository level, multi-regional repositories, and CMEK encryption. Existing GCR images continue to work but new workloads on GCP should use Artifact Registry." },
  { question: "Which registries support vulnerability scanning?", answer: "ECR includes automated image scanning (Clair-based basic scan, or enhanced scanning via Amazon Inspector with $0.09/image). GCP Artifact Registry integrates Container Analysis for on-push scanning. Docker Hub includes vulnerability scanning on paid plans (Pro and Team). GHCR offers Dependabot alerts for images stored in packages. GitHub Advanced Security also scans Dockerfiles for misconfigurations." },
  { question: "How does geographic replication work for container registries?", answer: "ECR supports replication rules to copy images to other AWS regions and accounts automatically. GCP Artifact Registry supports multi-region repositories (us, europe, asia) that replicate globally. Docker Hub replicates public images via CDN globally. Azure ACR Premium tier supports geo-replication to multiple Azure regions. Geographic replication reduces latency for multi-region deployments and provides redundancy if one region has an outage." },
];
---

<BaseLayout
  title="Container Registry Comparison: ECR vs GCR vs Docker Hub vs GHCR"
  description="Compare container registries: AWS ECR, Google GCR/Artifact Registry, Docker Hub, GitHub GHCR, and Azure ACR. Pricing, access control, vulnerability scanning, and geographic replication guide."
  tool="container registry comparison, ECR vs Docker Hub, GCR vs GHCR, container image registry, ECR pricing"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"Container Registry Comparison: ECR vs GCR vs Docker Hub vs GHCR","url":"https://devplaybook.cc/tools/container-registry-comparison","description":"Compare AWS ECR, GCR, Docker Hub, GHCR, and Azure ACR on pricing, access control, vulnerability scanning, and replication."})} />

  <h1 class="text-3xl font-bold mb-2">Container Registry Comparison: ECR vs GCR vs Docker Hub vs GHCR</h1>
  <p class="text-text-muted mb-6">Choose the right container registry for your team. Compare AWS ECR, Google Artifact Registry (GCR), Docker Hub, GitHub Container Registry (GHCR), and Azure ACR on pricing, access control, vulnerability scanning, and geographic replication.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 registries compared</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Pricing breakdown</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Vulnerability scanning</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Access control models</span>
  </div>

  <ToolPageCta />

  <div class="space-y-8 mt-8">

    <section>
      <h2 class="text-2xl font-bold mb-4">What Is a Container Registry?</h2>
      <p class="text-text-muted mb-4">A container registry stores and distributes OCI-compliant container images. Your CI/CD pipeline builds an image, tags it (e.g., <code class="bg-surface px-1 rounded text-sm">myapp:v1.2.3</code>), and pushes it to the registry. When Kubernetes or ECS deploys the app, it pulls the image from the registry.</p>
      <p class="text-text-muted mb-4">Key capabilities to evaluate:</p>
      <ul class="list-disc list-inside space-y-1 text-text-muted mb-4">
        <li><strong>Authentication</strong> — How does your cluster authenticate to pull images?</li>
        <li><strong>Access control</strong> — Can you limit who can push vs pull, per repository?</li>
        <li><strong>Vulnerability scanning</strong> — Does it scan images on push?</li>
        <li><strong>Rate limits</strong> — Will pulls get throttled under load?</li>
        <li><strong>Geographic availability</strong> — Can images be replicated close to your clusters?</li>
        <li><strong>Pricing</strong> — Storage and egress costs at scale.</li>
      </ul>
    </section>

    <section>
      <h2 class="text-2xl font-bold mb-4">Feature Comparison Table</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-surface">
              <th class="border border-border px-3 py-2 text-left font-semibold">Feature</th>
              <th class="border border-border px-3 py-2 text-left font-semibold">ECR (AWS)</th>
              <th class="border border-border px-3 py-2 text-left font-semibold">Artifact Registry (GCP)</th>
              <th class="border border-border px-3 py-2 text-left font-semibold">Docker Hub</th>
              <th class="border border-border px-3 py-2 text-left font-semibold">GHCR</th>
              <th class="border border-border px-3 py-2 text-left font-semibold">ACR (Azure)</th>
            </tr>
          </thead>
          <tbody>
            <tr><td class="border border-border px-3 py-2 font-medium">Auth method</td><td class="border border-border px-3 py-2">IAM (token, 12h TTL)</td><td class="border border-border px-3 py-2">Service Account / WI</td><td class="border border-border px-3 py-2">Username + PAT</td><td class="border border-border px-3 py-2">GITHUB_TOKEN / PAT</td><td class="border border-border px-3 py-2">Service Principal / MI</td></tr>
            <tr class="bg-surface/30"><td class="border border-border px-3 py-2 font-medium">Free private repos</td><td class="border border-border px-3 py-2">Unlimited (storage cost)</td><td class="border border-border px-3 py-2">0.5 GB/month free</td><td class="border border-border px-3 py-2">1 (free tier)</td><td class="border border-border px-3 py-2">Included in GH plan</td><td class="border border-border px-3 py-2">Geo + tier dependent</td></tr>
            <tr><td class="border border-border px-3 py-2 font-medium">Pull rate limits</td><td class="border border-border px-3 py-2">None (within AWS)</td><td class="border border-border px-3 py-2">None</td><td class="border border-border px-3 py-2">200/6h (free)</td><td class="border border-border px-3 py-2">None</td><td class="border border-border px-3 py-2">None</td></tr>
            <tr class="bg-surface/30"><td class="border border-border px-3 py-2 font-medium">Vulnerability scanning</td><td class="border border-border px-3 py-2">Basic + Inspector</td><td class="border border-border px-3 py-2">Container Analysis</td><td class="border border-border px-3 py-2">Paid plans</td><td class="border border-border px-3 py-2">Dependabot alerts</td><td class="border border-border px-3 py-2">Defender for Containers</td></tr>
            <tr><td class="border border-border px-3 py-2 font-medium">Geo replication</td><td class="border border-border px-3 py-2">Cross-region rules</td><td class="border border-border px-3 py-2">Multi-region repos</td><td class="border border-border px-3 py-2">CDN (public images)</td><td class="border border-border px-3 py-2">Limited</td><td class="border border-border px-3 py-2">Premium tier</td></tr>
            <tr class="bg-surface/30"><td class="border border-border px-3 py-2 font-medium">OCI artifacts</td><td class="border border-border px-3 py-2">Yes</td><td class="border border-border px-3 py-2">Yes (multi-format)</td><td class="border border-border px-3 py-2">Limited</td><td class="border border-border px-3 py-2">Yes</td><td class="border border-border px-3 py-2">Yes</td></tr>
            <tr><td class="border border-border px-3 py-2 font-medium">Best for</td><td class="border border-border px-3 py-2">AWS workloads</td><td class="border border-border px-3 py-2">GCP / multi-format</td><td class="border border-border px-3 py-2">Public OSS images</td><td class="border border-border px-3 py-2">GitHub CI/CD teams</td><td class="border border-border px-3 py-2">Azure workloads</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-bold mb-4">Authenticating to Each Registry</h2>

      <h3 class="text-lg font-semibold mb-2">AWS ECR — IAM-Based Auth</h3>
      <p class="text-text-muted mb-3">ECR uses short-lived tokens generated via <code class="bg-surface px-1 rounded text-sm">aws ecr get-login-password</code>. Tokens expire after 12 hours, so static <code class="bg-surface px-1 rounded text-sm">imagePullSecrets</code> break overnight. For EKS, use the ECR credential provider plugin — it refreshes tokens automatically at the node level.</p>
      <pre class="bg-surface border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># Login to ECR
aws ecr get-login-password --region us-east-1 \
  | docker login --username AWS \
    --password-stdin 123456789.dkr.ecr.us-east-1.amazonaws.com

# Push image
docker tag myapp:latest 123456789.dkr.ecr.us-east-1.amazonaws.com/myapp:latest
docker push 123456789.dkr.ecr.us-east-1.amazonaws.com/myapp:latest</code></pre>

      <h3 class="text-lg font-semibold mb-2">GitHub GHCR — GITHUB_TOKEN</h3>
      <p class="text-text-muted mb-3">GHCR integrates with GitHub Actions natively. Use <code class="bg-surface px-1 rounded text-sm">GITHUB_TOKEN</code> for same-repository images — no PAT needed. For cross-repository pulls, create a PAT with <code class="bg-surface px-1 rounded text-sm">read:packages</code> scope.</p>
      <pre class="bg-surface border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># GitHub Actions workflow
- name: Log in to GHCR
  uses: docker/login-action@v3
  with:
    registry: ghcr.io
    username: &#123;&#123; github.actor &#125;&#125;
    password: &#123;&#123; secrets.GITHUB_TOKEN &#125;&#125;

- name: Build and push
  uses: docker/build-push-action@v5
  with:
    push: true
    tags: ghcr.io/&#123;&#123; github.repository &#125;&#125;:latest</code></pre>

      <h3 class="text-lg font-semibold mb-2">GCP Artifact Registry — Workload Identity</h3>
      <p class="text-text-muted mb-3">For GKE, use Workload Identity Federation to bind a Kubernetes Service Account to a GCP Service Account — no credentials in Kubernetes Secrets. For local dev, use <code class="bg-surface px-1 rounded text-sm">gcloud auth configure-docker</code>.</p>
      <pre class="bg-surface border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># Configure docker to use gcloud credentials
gcloud auth configure-docker us-central1-docker.pkg.dev

# Push to Artifact Registry
docker tag myapp:latest us-central1-docker.pkg.dev/my-project/my-repo/myapp:latest
docker push us-central1-docker.pkg.dev/my-project/my-repo/myapp:latest</code></pre>
    </section>

    <section>
      <h2 class="text-2xl font-bold mb-4">Pricing Comparison (2026)</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="bg-surface">
              <th class="border border-border px-3 py-2 text-left font-semibold">Registry</th>
              <th class="border border-border px-3 py-2 text-left font-semibold">Storage</th>
              <th class="border border-border px-3 py-2 text-left font-semibold">Egress (same region)</th>
              <th class="border border-border px-3 py-2 text-left font-semibold">Egress (cross-region)</th>
              <th class="border border-border px-3 py-2 text-left font-semibold">Free Tier</th>
            </tr>
          </thead>
          <tbody>
            <tr><td class="border border-border px-3 py-2">ECR</td><td class="border border-border px-3 py-2">$0.10/GB/month</td><td class="border border-border px-3 py-2">Free</td><td class="border border-border px-3 py-2">$0.09/GB</td><td class="border border-border px-3 py-2">500MB/month (12mo)</td></tr>
            <tr class="bg-surface/30"><td class="border border-border px-3 py-2">Artifact Registry</td><td class="border border-border px-3 py-2">$0.10/GB/month</td><td class="border border-border px-3 py-2">Free</td><td class="border border-border px-3 py-2">Varies by region</td><td class="border border-border px-3 py-2">0.5 GB storage</td></tr>
            <tr><td class="border border-border px-3 py-2">Docker Hub</td><td class="border border-border px-3 py-2">$0 (public) / plan-based</td><td class="border border-border px-3 py-2">Free</td><td class="border border-border px-3 py-2">Free</td><td class="border border-border px-3 py-2">1 private repo</td></tr>
            <tr class="bg-surface/30"><td class="border border-border px-3 py-2">GHCR</td><td class="border border-border px-3 py-2">$0 (public) / GH plan</td><td class="border border-border px-3 py-2">Free</td><td class="border border-border px-3 py-2">Free</td><td class="border border-border px-3 py-2">GH Free: 500MB/1GB egress</td></tr>
            <tr><td class="border border-border px-3 py-2">ACR Basic</td><td class="border border-border px-3 py-2">$0.003/GB/day</td><td class="border border-border px-3 py-2">Free (Azure VNet)</td><td class="border border-border px-3 py-2">Standard Azure egress</td><td class="border border-border px-3 py-2">$0.167/day (Basic tier)</td></tr>
          </tbody>
        </table>
      </div>
      <p class="text-text-muted mt-3 text-sm">Note: ECR egress is free when pulling from EC2/ECS/EKS in the same AWS region. Cross-region or internet egress costs apply.</p>
    </section>

    <section>
      <h2 class="text-2xl font-bold mb-4">Choosing the Right Registry</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="bg-surface border border-border rounded-lg p-4">
          <h3 class="font-semibold mb-2 text-primary">AWS-first teams → ECR</h3>
          <p class="text-text-muted text-sm">Zero egress costs within AWS, native IAM integration, no rate limits. Use the ECR credential provider for EKS to avoid token expiry issues.</p>
        </div>
        <div class="bg-surface border border-border rounded-lg p-4">
          <h3 class="font-semibold mb-2 text-primary">GitHub Actions CI/CD → GHCR</h3>
          <p class="text-text-muted text-sm">Native GITHUB_TOKEN auth, no extra accounts, free for public repos, private included in GitHub plans. Best DX for GitHub-centric teams.</p>
        </div>
        <div class="bg-surface border border-border rounded-lg p-4">
          <h3 class="font-semibold mb-2 text-primary">GCP teams → Artifact Registry</h3>
          <p class="text-text-muted text-sm">Multi-format (Docker, Helm, npm, Maven), Workload Identity for zero-credentials auth on GKE, Container Analysis for scanning.</p>
        </div>
        <div class="bg-surface border border-border rounded-lg p-4">
          <h3 class="font-semibold mb-2 text-primary">Public OSS projects → Docker Hub</h3>
          <p class="text-text-muted text-sm">Still the default for public images. Official images, automated builds, massive ecosystem. Rate limits only affect anonymous pulls.</p>
        </div>
      </div>
    </section>

  </div>

  <FaqSection faqs={faq} />
</BaseLayout>
