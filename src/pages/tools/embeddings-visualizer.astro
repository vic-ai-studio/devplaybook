---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmbeddingsVisualizer from '../../components/EmbeddingsVisualizer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What are text embeddings?",
    answer: "Text embeddings are dense numerical vectors that represent the semantic meaning of text. Similar sentences have vectors that point in similar directions in high-dimensional space. Unlike TF-IDF (which this tool uses), neural embeddings from models like OpenAI text-embedding-3 or Sentence Transformers capture deeper semantic relationships — 'king' and 'monarch' have high similarity even though they share no words."
  },
  {
    question: "What does cosine similarity measure?",
    answer: "Cosine similarity measures the angle between two vectors, ignoring their magnitude. A score of 1.0 means the vectors point in the same direction (identical content). A score of 0.0 means they are perpendicular (completely unrelated). A score of -1.0 means opposite directions (rare in text embeddings since most values are non-negative). In practice, scores above 0.7 indicate high semantic similarity."
  },
  {
    question: "How is this different from real embedding models?",
    answer: "This tool uses TF-IDF (Term Frequency-Inverse Document Frequency) vectors — a classic sparse representation. Real embedding models like OpenAI text-embedding-3-large produce dense 1536-dimensional vectors using neural networks trained on billions of documents. Neural embeddings understand synonyms, context, and language nuances that TF-IDF misses. TF-IDF only detects shared vocabulary, making it a good approximation for keyword-heavy text but poor for paraphrases."
  },
  {
    question: "What are embeddings used for in AI applications?",
    answer: "Embeddings enable: (1) Semantic search — find documents by meaning, not just keywords. (2) RAG (Retrieval Augmented Generation) — retrieve relevant context chunks for LLM prompts. (3) Clustering — group similar documents automatically. (4) Recommendation systems — suggest similar items. (5) Duplicate detection — find near-duplicate content. (6) Classification — train lightweight classifiers on top of embeddings."
  },
  {
    question: "Which embedding model should I use?",
    answer: "OpenAI text-embedding-3-small ($0.02/1M tokens) is excellent for most use cases. text-embedding-3-large offers higher accuracy at 3x cost. Cohere Embed v3 excels at multilingual text. Sentence Transformers (all-MiniLM-L6-v2) runs locally for free — good for private data. For RAG applications, the embedding model should match your retrieval use case — some are optimized for query-document pairs (asymmetric search) vs document-document similarity."
  },
  {
    question: "What is RAG and how do embeddings enable it?",
    answer: "RAG (Retrieval-Augmented Generation) augments LLM prompts with relevant context retrieved from a knowledge base. The process: (1) Embed all documents in your knowledge base and store vectors in a vector database (Pinecone, Qdrant, pgvector). (2) When a user asks a question, embed the query. (3) Find the most similar document chunks using cosine similarity. (4) Inject those chunks into the LLM prompt as context. This lets LLMs answer questions about private data without fine-tuning."
  },
];
---

<BaseLayout
  title="Embeddings Visualizer — Cosine Similarity Heatmap for Text Snippets"
  description="Visualize cosine similarity between 2–6 text snippets using TF-IDF vectors and a color heatmap. Understand semantic similarity, embeddings concepts, and RAG retrieval — all in your browser without an API key."
  tool="embeddings visualizer, cosine similarity, text similarity, TF-IDF similarity, semantic similarity heatmap, RAG tool"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Embeddings Visualizer",
    "url": "https://devplaybook.cc/tools/embeddings-visualizer",
    "description": "Visualize cosine similarity between text snippets using TF-IDF vectors and a color heatmap. No API key needed — runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Embeddings Visualizer</h1>
  <p class="text-text-muted mb-4">
    Compare 2–6 text snippets and visualize their semantic similarity as a color heatmap.
    Uses TF-IDF cosine similarity computed entirely in your browser — no API key or server needed.
    Great for understanding how embeddings and RAG retrieval work.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Up to 6 snippets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Color heatmap</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No API key needed</span>
  </div>
  <EmbeddingsVisualizer client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Embeddings Visualizer" relatedTags={['ai', 'llm', 'embeddings', 'rag', 'nlp', 'semantic-search', 'vector-db']} />
</BaseLayout>
