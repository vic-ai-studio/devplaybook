---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="SLO Error Budget Calculator — SLI/SLO/Error Budget Planner"
  description="Calculate SLO error budgets, remaining budget, burn rate, and time-to-exhaustion. Input your SLO target, window, and current error rate to plan incident response."
  tool="SLO calculator, error budget calculator, SLI SLO SLA, burn rate, reliability engineering, site reliability"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "SLO Error Budget Calculator",
    "url": "https://devplaybook.cc/tools/slo-error-budget-calculator",
    "description": "Calculate SLO error budgets, burn rates, and time-to-exhaustion for reliability engineering. Free, runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">SLO Error Budget Calculator</h1>
  <p class="text-text-muted mb-4">Enter your SLO target, time window, current error rate, and how far into the window you are. Get your total error budget, how much you have used, the burn rate, and a forecast of when the budget will be exhausted.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Budget used &amp; remaining</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Burn rate &amp; time-to-exhaustion</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> HEALTHY / WARNING / CRITICAL / EXHAUSTED status</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs entirely in your browser</span>
  </div>

  <!-- Preset buttons -->
  <div class="flex gap-2 mb-5 flex-wrap">
    <span class="text-sm text-text-muted self-center">Presets:</span>
    <button data-preset="999" class="preset-btn px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">99.9% SLO</button>
    <button data-preset="9995" class="preset-btn px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">99.95% SLO</button>
    <button data-preset="9999" class="preset-btn px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">99.99% SLO</button>
  </div>

  <!-- Inputs -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
    <div>
      <label class="block text-sm font-medium mb-2" for="slo-target">
        SLO Target (%)
        <span class="text-text-muted font-normal ml-1">e.g. 99.9</span>
      </label>
      <input
        id="slo-target"
        type="number"
        min="0"
        max="100"
        step="0.001"
        value="99.9"
        class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary"
        placeholder="99.9"
      />
    </div>
    <div>
      <label class="block text-sm font-medium mb-2" for="window-days">Window</label>
      <select id="window-days" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
        <option value="7">7 days (weekly)</option>
        <option value="30" selected>30 days (monthly)</option>
        <option value="90">90 days (quarterly)</option>
        <option value="365">365 days (annual)</option>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium mb-2" for="error-rate">
        Current Error Rate (%)
        <span class="text-text-muted font-normal ml-1">e.g. 0.15</span>
      </label>
      <input
        id="error-rate"
        type="number"
        min="0"
        max="100"
        step="0.001"
        value="0.15"
        class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary"
        placeholder="0.15"
      />
    </div>
    <div>
      <label class="block text-sm font-medium mb-2" for="elapsed-pct">
        Time Elapsed in Window (%)
        <span class="text-text-muted font-normal ml-1">e.g. 40</span>
      </label>
      <input
        id="elapsed-pct"
        type="number"
        min="0"
        max="100"
        step="0.1"
        value="40"
        class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary"
        placeholder="40"
      />
      <p class="text-xs text-text-muted mt-1">Percentage of the window that has already passed.</p>
    </div>
  </div>

  <!-- Calculate button -->
  <div class="flex gap-3 mb-8 flex-wrap">
    <button id="btn-calculate" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Calculate Error Budget</button>
    <button id="btn-reset" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Reset</button>
  </div>

  <!-- Results -->
  <div id="results-section" class="hidden">
    <!-- Status badge -->
    <div class="flex items-center gap-3 mb-6">
      <span id="status-badge" class="inline-flex items-center px-4 py-1.5 rounded-full text-sm font-bold"></span>
      <span id="status-msg" class="text-sm text-text-muted"></span>
    </div>

    <!-- Metric cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <p class="text-xs text-text-muted mb-1">Total Allowed Downtime</p>
        <p id="res-total-downtime" class="text-2xl font-bold font-mono"></p>
        <p class="text-xs text-text-muted mt-1">minutes in the window</p>
      </div>
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <p class="text-xs text-text-muted mb-1">Error Budget Used</p>
        <p id="res-used" class="text-2xl font-bold font-mono"></p>
        <p id="res-used-pct" class="text-xs text-text-muted mt-1"></p>
      </div>
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <p class="text-xs text-text-muted mb-1">Remaining Budget</p>
        <p id="res-remaining" class="text-2xl font-bold font-mono"></p>
        <p id="res-remaining-pct" class="text-xs text-text-muted mt-1"></p>
      </div>
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <p class="text-xs text-text-muted mb-1">Burn Rate</p>
        <p id="res-burn-rate" class="text-2xl font-bold font-mono"></p>
        <p class="text-xs text-text-muted mt-1">× normal consumption rate</p>
      </div>
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <p class="text-xs text-text-muted mb-1">Budget Exhausts In</p>
        <p id="res-exhaust" class="text-2xl font-bold font-mono"></p>
        <p class="text-xs text-text-muted mt-1">at current burn rate</p>
      </div>
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <p class="text-xs text-text-muted mb-1">Max Allowable Error Rate</p>
        <p id="res-max-rate" class="text-2xl font-bold font-mono"></p>
        <p class="text-xs text-text-muted mt-1">to stay on budget</p>
      </div>
    </div>

    <!-- Budget bar -->
    <div class="mb-6">
      <div class="flex justify-between text-xs text-text-muted mb-1">
        <span>Error budget consumed</span>
        <span id="bar-label"></span>
      </div>
      <div class="w-full bg-bg-card border border-border rounded-full h-4 overflow-hidden">
        <div id="budget-bar" class="h-full rounded-full transition-all duration-500" style="width:0%"></div>
      </div>
    </div>

    <!-- Summary pre -->
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <div class="flex justify-between items-center mb-3">
        <span class="text-sm font-medium text-text-muted">Summary</span>
        <button id="copy-summary-btn" class="px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">Copy</button>
      </div>
      <pre id="summary-output" class="font-mono text-sm whitespace-pre-wrap break-words overflow-x-auto max-h-[500px] overflow-y-auto text-foreground"></pre>
    </div>
  </div>

  <ToolPageCta />
</BaseLayout>

<script is:inline>
function v(id) {
  const el = document.getElementById(id);
  if (!el) return '';
  return (el.value || '').trim();
}

function fmt2(n) { return n.toFixed(2); }
function fmtMin(min) {
  if (min < 1) return `${(min * 60).toFixed(1)} sec`;
  if (min < 60) return `${fmt2(min)} min`;
  if (min < 1440) return `${fmt2(min / 60)} hr`;
  return `${fmt2(min / 1440)} days`;
}

const PRESETS = {
  '999':  { slo: '99.9',   window: '30', errRate: '0.15',  elapsed: '40' },
  '9995': { slo: '99.95',  window: '30', errRate: '0.05',  elapsed: '50' },
  '9999': { slo: '99.99',  window: '30', errRate: '0.005', elapsed: '30' },
};

document.querySelectorAll('.preset-btn').forEach(btn => {
  btn.addEventListener('click', function () {
    const p = PRESETS[this.dataset.preset];
    if (!p) return;
    document.getElementById('slo-target').value   = p.slo;
    document.getElementById('window-days').value  = p.window;
    document.getElementById('error-rate').value   = p.errRate;
    document.getElementById('elapsed-pct').value  = p.elapsed;
    calculate();
  });
});

function calculate() {
  const sloTarget  = parseFloat(v('slo-target'));
  const windowDays = parseInt(v('window-days'), 10);
  const errorRate  = parseFloat(v('error-rate'));
  const elapsedPct = parseFloat(v('elapsed-pct'));

  if (isNaN(sloTarget) || isNaN(windowDays) || isNaN(errorRate) || isNaN(elapsedPct)) return;
  if (sloTarget <= 0 || sloTarget >= 100) return;

  const errorBudgetPct   = 100 - sloTarget;           // e.g. 0.1 for 99.9%
  const windowMinutes    = windowDays * 24 * 60;
  const totalBudgetMin   = windowMinutes * (errorBudgetPct / 100);
  const elapsedMinutes   = windowMinutes * (elapsedPct / 100);
  const usedBudgetMin    = elapsedMinutes * (errorRate / 100);
  const remainingMin     = totalBudgetMin - usedBudgetMin;
  const usedPct          = (usedBudgetMin / totalBudgetMin) * 100;
  const remainingPct     = 100 - usedPct;

  // Burn rate: how fast we're consuming budget vs "ideal" (budget consumed / expected consumed)
  // Expected consumed at this point = elapsedPct% of total budget
  const expectedUsedPct  = elapsedPct;  // if on pace, used% == elapsed%
  const burnRate         = expectedUsedPct > 0 ? usedPct / expectedUsedPct : (usedPct > 0 ? Infinity : 1);

  // Time to exhaustion from now (at current burn rate, with remaining budget)
  // remaining budget in minutes, current consumption rate = usedBudgetMin / elapsedMinutes min/min
  const consumptionRatePerMin = elapsedMinutes > 0 ? usedBudgetMin / elapsedMinutes : 0;
  let exhaustDays;
  if (consumptionRatePerMin <= 0) {
    exhaustDays = Infinity;
  } else {
    const remainingDays = windowDays - (windowDays * elapsedPct / 100);
    const exhaustMinutes = remainingMin / consumptionRatePerMin;
    exhaustDays = exhaustMinutes / 1440;
  }

  // Max allowable error rate to stay on budget for the rest of the window
  const remainingWindowMin = windowMinutes * ((100 - elapsedPct) / 100);
  const maxErrRate = remainingWindowMin > 0
    ? (remainingMin / remainingWindowMin) * 100
    : 0;

  // Status
  let status, statusClass, statusMsg;
  if (remainingMin <= 0) {
    status = 'EXHAUSTED';
    statusClass = 'bg-red-900/40 text-red-300 border border-red-700';
    statusMsg = 'Error budget is fully exhausted. Every new error violates the SLO.';
  } else if (burnRate >= 2) {
    status = 'CRITICAL';
    statusClass = 'bg-orange-900/40 text-orange-300 border border-orange-700';
    statusMsg = `Burning budget ${fmt2(burnRate)}× faster than sustainable. Immediate action required.`;
  } else if (burnRate >= 1) {
    status = 'WARNING';
    statusClass = 'bg-yellow-900/40 text-yellow-300 border border-yellow-700';
    statusMsg = `Consuming budget ${fmt2(burnRate)}× normal rate. Monitor closely.`;
  } else {
    status = 'HEALTHY';
    statusClass = 'bg-green-900/40 text-green-300 border border-green-700';
    statusMsg = `Budget consumption is below normal rate (${fmt2(burnRate)}×). SLO is safe.`;
  }

  // Bar color
  const barPct = Math.min(usedPct, 100);
  let barColor = 'bg-green-500';
  if (barPct > 90) barColor = 'bg-red-500';
  else if (barPct > 70) barColor = 'bg-orange-500';
  else if (barPct > 50) barColor = 'bg-yellow-500';

  // Update DOM
  document.getElementById('status-badge').className = `inline-flex items-center px-4 py-1.5 rounded-full text-sm font-bold ${statusClass}`;
  document.getElementById('status-badge').textContent = status;
  document.getElementById('status-msg').textContent = statusMsg;

  document.getElementById('res-total-downtime').textContent = fmtMin(totalBudgetMin);
  document.getElementById('res-used').textContent = fmtMin(Math.max(0, usedBudgetMin));
  document.getElementById('res-used-pct').textContent = `${fmt2(Math.max(0, usedPct))}% of budget used`;
  document.getElementById('res-remaining').textContent = remainingMin > 0 ? fmtMin(remainingMin) : '0 min';
  document.getElementById('res-remaining-pct').textContent = `${fmt2(Math.max(0, remainingPct))}% of budget left`;
  document.getElementById('res-burn-rate').textContent = isFinite(burnRate) ? `${fmt2(burnRate)}×` : '∞';

  if (!isFinite(exhaustDays) || exhaustDays < 0) {
    document.getElementById('res-exhaust').textContent = remainingMin <= 0 ? 'Now' : '∞ (never)';
  } else if (exhaustDays < (1 / 24)) {
    document.getElementById('res-exhaust').textContent = `${(exhaustDays * 24 * 60).toFixed(0)} min`;
  } else if (exhaustDays < 1) {
    document.getElementById('res-exhaust').textContent = `${(exhaustDays * 24).toFixed(1)} hr`;
  } else {
    document.getElementById('res-exhaust').textContent = `${fmt2(exhaustDays)} days`;
  }

  document.getElementById('res-max-rate').textContent = maxErrRate > 0 ? `${maxErrRate.toFixed(4)}%` : '0%';

  document.getElementById('budget-bar').style.width = `${barPct.toFixed(1)}%`;
  document.getElementById('budget-bar').className = `h-full rounded-full transition-all duration-500 ${barColor}`;
  document.getElementById('bar-label').textContent = `${fmt2(barPct)}% used`;

  // Summary text
  const exhaustStr = !isFinite(exhaustDays) || exhaustDays < 0
    ? (remainingMin <= 0 ? 'Exhausted now' : 'Never at current rate')
    : exhaustDays < 1
      ? `~${(exhaustDays * 24).toFixed(1)} hours`
      : `~${fmt2(exhaustDays)} days`;

  const summary = [
    `SLO Target:            ${sloTarget}%`,
    `Window:                ${windowDays} days`,
    `Error Budget (total):  ${fmtMin(totalBudgetMin)} (${errorBudgetPct.toFixed(4)}% of window)`,
    ``,
    `Current Error Rate:    ${errorRate}%`,
    `Time Elapsed:          ${elapsedPct}% of window (${fmtMin(elapsedMinutes)})`,
    ``,
    `Budget Used:           ${fmtMin(Math.max(0, usedBudgetMin))} (${fmt2(Math.max(0, usedPct))}%)`,
    `Budget Remaining:      ${remainingMin > 0 ? fmtMin(remainingMin) : '0 min'} (${fmt2(Math.max(0, remainingPct))}%)`,
    ``,
    `Burn Rate:             ${isFinite(burnRate) ? fmt2(burnRate) + '×' : '∞'} normal`,
    `Budget Exhausts In:    ${exhaustStr}`,
    `Max Allowable Rate:    ${maxErrRate > 0 ? maxErrRate.toFixed(4) + '%' : '0%'} (to stay on budget)`,
    ``,
    `Status:                ${status}`,
  ].join('\n');

  document.getElementById('summary-output').textContent = summary;
  document.getElementById('results-section').classList.remove('hidden');
  setTimeout(() => document.getElementById('results-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
}

function resetForm() {
  document.getElementById('slo-target').value  = '99.9';
  document.getElementById('window-days').value = '30';
  document.getElementById('error-rate').value  = '0.15';
  document.getElementById('elapsed-pct').value = '40';
  document.getElementById('results-section').classList.add('hidden');
}

document.getElementById('btn-calculate')?.addEventListener('click', calculate);
document.getElementById('btn-reset')?.addEventListener('click', resetForm);

document.getElementById('copy-summary-btn')?.addEventListener('click', function () {
  const text = document.getElementById('summary-output').textContent;
  navigator.clipboard.writeText(text).then(() => {
    this.textContent = 'Copied!';
    setTimeout(() => { this.textContent = 'Copy'; }, 2000);
  });
});

// Live recalculate on input change
['slo-target', 'window-days', 'error-rate', 'elapsed-pct'].forEach(id => {
  document.getElementById(id)?.addEventListener('input', () => {
    if (!document.getElementById('results-section').classList.contains('hidden')) {
      calculate();
    }
  });
});

// Auto-calculate on load
calculate();
</script>
