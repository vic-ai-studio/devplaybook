---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is an SLO error budget?", answer: "An error budget is the maximum amount of downtime or errors you're allowed to have while still meeting your SLO. If your SLO is 99.9% availability, your error budget is 0.1% — which equals 43.8 minutes per 30-day month. Once consumed, you should stop risky deployments until the next window." },
  { question: "What is burn rate and why does it matter?", answer: "Burn rate tells you how fast you're consuming your error budget relative to the allowed rate. A burn rate of 1.0 means you're consuming budget exactly on pace to exhaust it by end of window. A burn rate of 2.0 means you'll exhaust budget in half the window. Google SRE recommends alerting at 2x burn (6h alert) and 5x burn (1h alert)." },
  { question: "What are the standard burn rate alert thresholds?", answer: "Google's Alerting on SLOs chapter defines three windows: 14.4x burn rate over 1 hour (fast burn — page immediately), 6x burn rate over 6 hours (medium burn — ticket urgently), and 3x burn rate over 72 hours (slow burn — create a task). These are starting points; tune based on your SLO window and risk tolerance." },
  { question: "How do I calculate minutes of error budget?", answer: "Error budget minutes = (1 - SLO%) × window days × 24h × 60min. For 99.9% over 30 days: (1 - 0.999) × 30 × 24 × 60 = 43.2 minutes. This is the total time your service can be unavailable or erroring before violating the SLO for that period." },
  { question: "What should I do when error budget is exhausted?", answer: "When budget hits 0%: freeze all non-critical deployments, halt experiments, focus engineering on reliability improvements. Resume normal velocity only when budget recovers (next window starts or current incident resolves). Some orgs enforce this automatically via deploy gates that check remaining budget." },
];
---

<BaseLayout
  title="SLO Error Budget Calculator — Burn Rate, Budget Minutes & Alert Thresholds"
  description="Calculate SLO error budgets from availability targets. Get error budget in minutes, burn rate, budget consumed %, and Google SRE-style alert thresholds for fast/slow burn scenarios."
  tool="SLO Error Budget Calculator, Burn Rate Calculator, SRE Error Budget, SLO Calculator, Availability Budget"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">SLO Error Budget Calculator</h1>
  <p class="text-text-muted mb-4">Calculate error budgets from SLO targets. Get burn rate, budget consumption, and Google SRE-style alert thresholds for fast/slow burn scenarios.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Error budget in minutes & seconds</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Burn rate with alert thresholds</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> HEALTHY / WARNING / CRITICAL / EXHAUSTED status</span>
  </div>

  <!-- Inputs -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">SLO Configuration</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">SLO Target (%)</label>
        <input id="slo-target" type="number" value="99.9" min="0" max="100" step="0.001"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        <p class="text-xs text-text-muted mt-1">e.g. 99.9 for three-nines, 99.95 for three-and-a-half nines</p>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Measurement Window</label>
        <select id="window-days" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="7">7 days (weekly)</option>
          <option value="30" selected>30 days (monthly)</option>
          <option value="90">90 days (quarterly)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Current Error Rate (%)</label>
        <input id="error-rate" type="number" value="0.05" min="0" max="100" step="0.001"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        <p class="text-xs text-text-muted mt-1">Percentage of requests that are errors/failures right now</p>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Total Requests in Window</label>
        <input id="total-requests" type="number" value="1000000" min="1"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        <p class="text-xs text-text-muted mt-1">Used to calculate absolute allowed/actual error counts</p>
      </div>
    </div>
  </div>

  <!-- Status Badge + Key Metrics -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-5">
    <div class="bg-bg-card border border-border rounded-lg p-3 text-center">
      <div id="status-badge" class="text-xl font-bold text-green-400 mb-1">—</div>
      <div class="text-xs text-text-muted">Status</div>
    </div>
    <div class="bg-bg-card border border-border rounded-lg p-3 text-center">
      <div id="budget-total" class="text-2xl font-bold text-primary mb-1">—</div>
      <div class="text-xs text-text-muted">Total Budget</div>
    </div>
    <div class="bg-bg-card border border-border rounded-lg p-3 text-center">
      <div id="budget-consumed-pct" class="text-2xl font-bold text-primary mb-1">—</div>
      <div class="text-xs text-text-muted">Budget Consumed</div>
    </div>
    <div class="bg-bg-card border border-border rounded-lg p-3 text-center">
      <div id="burn-rate-val" class="text-2xl font-bold text-primary mb-1">—</div>
      <div class="text-xs text-text-muted">Burn Rate</div>
    </div>
  </div>

  <!-- Budget Details + Alert Thresholds -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="text-base font-semibold mb-4">Budget Details</h2>
      <div class="space-y-3" id="budget-details"></div>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="text-base font-semibold mb-4">Alert Threshold Triggers</h2>
      <div class="space-y-3" id="alert-thresholds"></div>
    </div>
  </div>

  <!-- Burn Rate Table -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-3">Burn Rate Scenarios</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm min-w-[520px]">
        <thead>
          <tr class="text-text-muted text-xs uppercase border-b border-border">
            <th class="text-left pb-2 pr-4">Scenario</th>
            <th class="text-right pb-2 pr-4">Burn Rate</th>
            <th class="text-right pb-2 pr-4">Alert Window</th>
            <th class="text-right pb-2 pr-4">Error Rate Trigger</th>
            <th class="text-right pb-2">Budget Exhausted In</th>
          </tr>
        </thead>
        <tbody id="burn-rate-table" class="divide-y divide-border"></tbody>
      </table>
    </div>
  </div>

  <!-- Progress Bar -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-3">Budget Consumption Visual</h2>
    <div class="flex justify-between text-xs text-text-muted mb-1.5">
      <span>0% (full budget)</span>
      <span id="progress-label">—</span>
      <span>100% (exhausted)</span>
    </div>
    <div class="w-full bg-black/20 rounded-full h-4 overflow-hidden">
      <div id="budget-bar" class="h-4 rounded-full transition-all duration-300 bg-green-500" style="width:0%"></div>
    </div>
    <div class="flex justify-between text-xs text-text-muted mt-1.5">
      <span id="bar-consumed">Consumed: —</span>
      <span id="bar-remaining">Remaining: —</span>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SLO Error Budget Calculator" relatedTags={['sre', 'devops', 'monitoring', 'reliability', 'observability']} />
</BaseLayout>

<script is:inline>
  function fmtTime(minutes) {
    if (minutes <= 0) return '0s';
    if (minutes < 1) return (minutes * 60).toFixed(1) + 's';
    if (minutes < 60) return minutes.toFixed(1) + 'm';
    if (minutes < 1440) return (minutes / 60).toFixed(2) + 'h';
    return (minutes / 1440).toFixed(2) + 'd';
  }

  function calculate() {
    const slo = parseFloat((document.getElementById('slo-target')).value) || 99.9;
    const windowDays = parseInt((document.getElementById('window-days')).value) || 30;
    const errorRate = parseFloat((document.getElementById('error-rate')).value) || 0;
    const totalRequests = parseInt((document.getElementById('total-requests')).value) || 1000000;

    const errorBudgetPct = 100 - slo;          // 0.1 for 99.9%
    const windowMinutes = windowDays * 24 * 60;
    const budgetMinutes = (errorBudgetPct / 100) * windowMinutes;
    const budgetSeconds = budgetMinutes * 60;

    const burnRate = errorBudgetPct > 0 ? errorRate / errorBudgetPct : 0;
    const consumedFraction = Math.min(burnRate, 100);  // fraction relative to budget
    const consumedMinutes = consumedFraction * budgetMinutes;
    const remainingMinutes = Math.max(0, budgetMinutes - consumedMinutes);

    const allowedErrors = Math.round((errorBudgetPct / 100) * totalRequests);
    const actualErrors = Math.round((errorRate / 100) * totalRequests);

    // Status
    let status = 'HEALTHY', statusColor = 'text-green-400';
    if (burnRate >= 14.4 || consumedFraction >= 1.0) { status = 'EXHAUSTED'; statusColor = 'text-red-500'; }
    else if (burnRate >= 5  || consumedFraction >= 0.9) { status = 'CRITICAL';  statusColor = 'text-red-400'; }
    else if (burnRate >= 2  || consumedFraction >= 0.5) { status = 'WARNING';   statusColor = 'text-yellow-400'; }

    document.getElementById('status-badge').textContent = status;
    document.getElementById('status-badge').className = 'text-xl font-bold mb-1 ' + statusColor;
    document.getElementById('budget-total').textContent = fmtTime(budgetMinutes) + ' (' + budgetSeconds.toFixed(0) + 's)';
    document.getElementById('budget-consumed-pct').textContent = (Math.min(1, consumedFraction) * 100).toFixed(1) + '%';
    document.getElementById('burn-rate-val').textContent = burnRate.toFixed(2) + 'x';

    document.getElementById('budget-details').innerHTML = [
      ['Error budget (total)', fmtTime(budgetMinutes)],
      ['Budget consumed', fmtTime(consumedMinutes)],
      ['Budget remaining', remainingMinutes > 0 ? fmtTime(remainingMinutes) : '0s (exhausted)'],
      ['Allowed errors / window', allowedErrors.toLocaleString()],
      ['Actual errors / window', actualErrors.toLocaleString()],
      ['Remaining error allowance', Math.max(0, allowedErrors - actualErrors).toLocaleString()],
    ].map(([label, val], i) => `
      <div class="flex justify-between items-center p-2.5 bg-black/10 rounded-lg">
        <span class="text-sm text-text-muted">${label}</span>
        <span class="font-mono text-sm ${i === 2 && remainingMinutes <= 0 ? 'text-red-400' : ''}">${val}</span>
      </div>`).join('');

    const alertRows = [
      { label: 'Fast burn — page immediately', mult: 14.4, window: '1h', color: 'text-red-400' },
      { label: 'Medium burn — urgent ticket',  mult: 6,    window: '6h', color: 'text-orange-400' },
      { label: 'Slow burn — create task',      mult: 3,    window: '72h', color: 'text-yellow-400' },
      { label: 'Pace burn — watch closely',    mult: 2,    window: '24h', color: 'text-blue-400' },
    ];
    document.getElementById('alert-thresholds').innerHTML = alertRows.map(s => {
      const triggerErr = (errorBudgetPct * s.mult / 100).toFixed(4);
      const triggered = burnRate >= s.mult;
      return `<div class="flex items-center justify-between p-2.5 rounded-lg ${triggered ? 'bg-red-500/10 border border-red-500/30' : 'bg-black/10'}">
        <div>
          <div class="text-sm font-medium ${s.color}">${s.label}</div>
          <div class="text-xs text-text-muted">${s.mult}x burn · window ${s.window}</div>
        </div>
        <div class="text-right">
          <div class="font-mono text-xs">err &gt; ${triggerErr}%</div>
          <div class="text-xs font-semibold ${triggered ? 'text-red-400' : 'text-text-muted'}">${triggered ? '⚠ TRIGGERED' : '✓ OK'}</div>
        </div>
      </div>`;
    }).join('');

    const scenarios = [
      { name: 'Normal pace', mult: 1.0, color: 'text-text-muted' },
      { name: 'Slow burn',   mult: 3.0, color: 'text-yellow-400' },
      { name: 'Medium burn', mult: 6.0, color: 'text-orange-400' },
      { name: 'Fast burn',   mult: 14.4, color: 'text-red-400' },
      { name: '▶ Current',  mult: burnRate, color: statusColor, highlight: true },
    ];
    document.getElementById('burn-rate-table').innerHTML = scenarios.map(s => {
      const trigErr = ((errorBudgetPct * s.mult) / 100).toFixed(4);
      const exhaustIn = s.mult > 0 ? budgetMinutes / s.mult : Infinity;
      return `<tr class="${s.highlight ? 'bg-primary/5' : ''}">
        <td class="py-2.5 pr-4 text-sm ${s.highlight ? 'font-bold' : ''}">${s.name}</td>
        <td class="py-2.5 pr-4 text-right font-mono text-xs ${s.color}">${s.mult.toFixed(1)}x</td>
        <td class="py-2.5 pr-4 text-right text-xs text-text-muted">${s.mult >= 14.4 ? '1h' : s.mult >= 6 ? '6h' : s.mult >= 3 ? '72h' : s.mult >= 2 ? '24h' : '—'}</td>
        <td class="py-2.5 pr-4 text-right font-mono text-xs">${trigErr}%</td>
        <td class="py-2.5 text-right font-mono text-xs">${exhaustIn === Infinity ? '∞' : fmtTime(exhaustIn)}</td>
      </tr>`;
    }).join('');

    const barPct = Math.min(100, consumedFraction * 100);
    const barEl = document.getElementById('budget-bar');
    barEl.style.width = barPct + '%';
    barEl.className = 'h-4 rounded-full transition-all duration-300 ' + (barPct >= 100 ? 'bg-red-500' : barPct >= 90 ? 'bg-red-400' : barPct >= 50 ? 'bg-yellow-400' : 'bg-green-500');
    document.getElementById('progress-label').textContent = 'Consumed: ' + barPct.toFixed(1) + '%';
    document.getElementById('bar-consumed').textContent = 'Consumed: ' + fmtTime(consumedMinutes);
    document.getElementById('bar-remaining').textContent = 'Remaining: ' + (remainingMinutes > 0 ? fmtTime(remainingMinutes) : '0s (exhausted)');
  }

  document.querySelectorAll('input, select').forEach(function(el) { el.addEventListener('input', calculate); });
  calculate();
</script>
