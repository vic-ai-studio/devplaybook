---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RegexTesterPro from '../../components/RegexTesterPro.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "How does real-time match highlighting work?", answer: "As you type your regex pattern, the tool instantly highlights all matching substrings in your test text. Yellow highlights show exactly where your pattern matches — no need to scroll through match lists manually." },
  { question: "What regex flavors are supported?", answer: "Testing always runs in your browser's JavaScript engine (ES2020+), which supports lookahead, lookbehind, named capture groups, and Unicode property escapes. Python and Ruby mode display flavor-specific syntax notes while running tests with the JS engine as a close approximation." },
  { question: "How do capture groups work?", answer: "Add parentheses around parts of your pattern to create capture groups: ([a-z]+). The Match Details section shows each captured group value (g1, g2…) alongside the full match. Named groups (?<name>…) are also supported." },
  { question: "What do the flags mean?", answer: "g (global): find all matches, not just the first. i (ignore case): A matches a. m (multiline): ^ and $ match line beginnings and ends. s (dot-all): . matches newlines. u (unicode): enable full Unicode support for \\u{...} and \\p{...}." },
  { question: "Is my data safe when using this tool?", answer: "Yes. Everything runs 100% in your browser. Your regex patterns and test strings are never sent to any server. All processing is local to your machine." },
  { question: "Why does my regex match too many or too few results?", answer: "Check your flags — without g (global), only the first match is found. Without m (multiline), ^ and $ match the full string boundaries, not line boundaries. The i flag makes matching case-insensitive. Try the presets to see working examples." },
];
---

<BaseLayout
  title="Regex Tester Pro — Real-Time Highlight Regex Testing Online"
  description="Free Regex Tester Pro with real-time match highlighting. Test regular expressions with live visual feedback. Supports JS, Python, and Ruby flavors, all flags, capture groups, and 6 built-in presets. Runs 100% in your browser."
  tool="Regex Tester Pro, Regular Expression Tester, Real-Time Regex, Regex Highlighter, JavaScript Regex, Python Regex, Ruby Regex, Regex Capture Groups, Regex Online"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Regex Tester Pro</h1>
  <p class="text-text-muted mb-4">Test regular expressions with real-time match highlighting. Matches are visually marked as you type — no submit button needed. Supports all flags, capture group inspection, JavaScript/Python/Ruby flavor notes, and 6 built-in presets for email, URL, IPv4, phone, and more.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Real-time match highlighting</span>
  </div>
  <RegexTesterPro client:load />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Need batch assertion testing?</p>
    <a href="/tools/regex-tester" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Regex Tester (with pass/fail assertions) →</a>
  </div>
  <ToolPageCta currentTool="Regex Tester Pro" relatedTags={['regex', 'validation', 'testing', 'strings']} />
</BaseLayout>
