---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SslExpiryChecker from '../../components/SslExpiryChecker.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "How do I check an SSL certificate expiry date?",
    answer: "Use openssl: echo | openssl s_client -connect example.com:443 2>/dev/null | openssl x509 -noout -enddate. Or with curl: curl -vI https://example.com 2>&1 | grep expire. For browser-based simulation, this tool shows certificate status based on domain patterns and includes CLI command references for real checks."
  },
  {
    question: "Why do SSL certificates expire?",
    answer: "SSL/TLS certificates are time-limited for security reasons — shorter lifetimes reduce the window during which a compromised certificate can be misused. Since September 2020, CA/Browser Forum limits publicly trusted certificates to 398 days (approximately 13 months). Google Chrome has proposed reducing this to 90 days by 2026."
  },
  {
    question: "What happens when an SSL certificate expires?",
    answer: "Browsers show a security warning page blocking access to your site ('Your connection is not private'). HTTPS connections fail. Email clients may reject connections to mail servers. APIs using certificate pinning will stop working. SEO rankings can drop as Google treats HTTPS as a ranking signal."
  },
  {
    question: "How do I automate SSL certificate renewal?",
    answer: "Use Certbot with Let's Encrypt: certbot renew runs automatically as a cron job or systemd timer. Most cloud providers (AWS ACM, Cloudflare, Vercel) auto-renew certificates. For nginx, the certbot nginx plugin handles renewal and configuration updates. Set up monitoring alerts at 30, 14, and 7 days before expiry."
  },
  {
    question: "What is a Subject Alternative Name (SAN)?",
    answer: "A SAN is an extension in an SSL certificate that allows it to secure multiple domain names. A single certificate might cover example.com, www.example.com, api.example.com, and *.example.com. Modern certificates use SANs instead of the older Common Name (CN) field. Wildcard certificates (*.example.com) cover all immediate subdomains."
  },
  {
    question: "What does the certificate issuer field mean?",
    answer: "The issuer is the Certificate Authority (CA) that signed and vouches for your certificate. Common CAs include Let's Encrypt (free, automated), DigiCert, Sectigo, GlobalSign, and Comodo. Browsers maintain a trust store of recognized CAs. If your issuer is not in the browser's trust store, visitors will see a certificate error."
  },
];
---

<BaseLayout
  title="SSL Certificate Expiry Checker — Check SSL Expiry Date & Days Remaining"
  description="Check SSL certificate expiry dates for any domain. See days remaining, certificate issuer, Subject Alternative Names (SANs), and get CLI commands for real-time checks with openssl and curl. Free browser tool."
  tool="SSL expiry checker, SSL certificate expiry date, TLS certificate checker, HTTPS certificate expiry, SSL certificate monitoring, openssl check certificate"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "SSL Certificate Expiry Checker",
    "url": "https://devplaybook.cc/tools/ssl-expiry-checker",
    "description": "Check SSL/TLS certificate expiry dates. Simulate certificate status for any domain, see days remaining, issuer, and SANs. Includes CLI commands for live checks.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">SSL Certificate Expiry Checker</h1>
  <p class="text-text-muted mb-4">
    Check SSL/TLS certificate expiry dates for your domains. Simulate certificate status to understand
    expiry timelines, get plain-English explanations of certificate fields (issuer, SANs, validity period),
    and reference CLI commands for live checks with <code class="font-mono text-sm bg-surface px-1 rounded">openssl</code> and <code class="font-mono text-sm bg-surface px-1 rounded">curl</code>.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Expiry date & days remaining</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Issuer & SAN details</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CLI commands for live checks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Bulk domain checking (up to 10)</span>
  </div>

  <SslExpiryChecker client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SSL Certificate Expiry Checker" relatedTags={['security', 'ssl', 'tls', 'https', 'certificates', 'devops', 'monitoring']} />
</BaseLayout>
