---
import BaseLayout from '../../layouts/BaseLayout.astro';
import YamlDiffViewer from '../../components/YamlDiffViewer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is YAML Diff Viewer?", answer: "YAML Diff Viewer compares two YAML files side-by-side and highlights every difference — added lines (green), removed lines (red), and changed values (orange). It supports three views: side-by-side, unified diff, and semantic key-level diff. Everything runs in your browser." },
  { question: "What are the three diff views?", answer: "Side-by-side shows both files next to each other with colored highlights per line. Unified shows a classic git-style diff with + and − prefixes. Semantic parses both YAML files and shows key-level changes — which keys were added, removed, or changed — regardless of line position." },
  { question: "How does the semantic diff work?", answer: "The semantic view parses both YAML files into flat key-value maps (supporting nested keys like server.host) and compares the maps directly. This means it catches value changes even if surrounding lines moved, and ignores whitespace or comment-only differences. Useful for config file reviews." },
  { question: "Does it support anchors, aliases, and multi-document YAML?", answer: "The tool uses a lightweight browser-side YAML parser focused on common config file patterns (scalars, mappings, sequences). Complex YAML features like anchors (&alias), aliases (*alias), merge keys (<<), and multi-document (---) separators are not fully supported. For full YAML spec compliance, use a server-side tool." },
  { question: "Is my YAML data sent to any server?", answer: "No. All diffing runs entirely in your browser. Your YAML content — which may contain API URLs, credentials, or internal hostnames — never leaves your machine. Safe for sensitive config files." },
  { question: "When would I use YAML Diff Viewer?", answer: "Common use cases: comparing Kubernetes manifests before and after a change, reviewing docker-compose.yml updates, checking if a GitHub Actions workflow changed between versions, auditing Helm chart values.yaml differences, or comparing environment-specific configs (dev vs prod)." },
];
---

<BaseLayout
  title="YAML Diff Viewer — Side-by-Side YAML Comparison Tool"
  description="Compare two YAML files side-by-side with highlighted differences. Three views: side-by-side, unified diff, and semantic key-level diff. Free, runs 100% in your browser — no data sent to any server."
  tool="YAML diff, YAML compare, YAML diff viewer, compare YAML files, YAML file comparison, Kubernetes manifest diff, docker-compose diff"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "YAML Diff Viewer",
    "url": "https://devplaybook.cc/tools/yaml-diff-viewer",
    "description": "Compare two YAML files with highlighted differences in side-by-side, unified, or semantic view. Free, runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">YAML Diff Viewer</h1>
  <p class="text-text-muted mb-4">
    Paste two YAML files and instantly see <strong>highlighted differences</strong>. Three views: <strong>side-by-side</strong> with line-level highlights, <strong>unified</strong> git-style diff, and <strong>semantic</strong> key-level comparison. Perfect for Kubernetes manifests, docker-compose, GitHub Actions, and config files.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Side-by-side + unified + semantic views</span>
  </div>
  <YamlDiffViewer client:only="preact" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more free developer tools?</p>
    <a href="/tools" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Browse All Free Tools →</a>
  </div>
  <ToolPageCta currentTool="YAML Diff Viewer" relatedTags={['yaml', 'diff', 'devops', 'kubernetes', 'docker', 'config']} />
</BaseLayout>
