  // Scan button
  el('scan-btn')?.addEventListener('click', () => {
    const content = val('dockerfile-input');
    if (!content.trim()) return;
    const results = analyzeDockerfile(content);
    renderResults(results);
  });

  // Sample loaders
  el('load-node-sample')?.addEventListener('click', () => {
    (el('dockerfile-input') as HTMLTextAreaElement).value = SAMPLES.node;
    const results = analyzeDockerfile(SAMPLES.node);
    renderResults(results);
  });
  el('load-python-sample')?.addEventListener('click', () => {
    (el('dockerfile-input') as HTMLTextAreaElement).value = SAMPLES.python;
    const results = analyzeDockerfile(SAMPLES.python);
    renderResults(results);
  });
  el('load-go-sample')?.addEventListener('click', () => {
    (el('dockerfile-input') as HTMLTextAreaElement).value = SAMPLES.go;
    const results = analyzeDockerfile(SAMPLES.go);
    renderResults(results);
  });

  // Template generator
  function renderTemplate() {
    const stack = val('template-stack');
    const base = val('template-base');
    const out = el('template-output');
    if (out) out.textContent = generateTemplate(stack, base);
  }

  el('template-stack')?.addEventListener('change', renderTemplate);
  el('template-base')?.addEventListener('change', renderTemplate);

  el('copy-template-btn')?.addEventListener('click', () => {
    navigator.clipboard.writeText(el('template-output')?.textContent ?? '').then(() => {
      const btn = el('copy-template-btn') as HTMLButtonElement;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
    });
  });

  // Initial template render + auto-scan sample
  renderTemplate();
  (el('dockerfile-input') as HTMLTextAreaElement).value = SAMPLES.node;
  renderResults(analyzeDockerfile(SAMPLES.node));
</script>
