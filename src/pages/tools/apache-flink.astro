          <td class="border border-border px-3 py-2">Kafka, S3, JDBC, custom</td>
          <td class="border border-border px-3 py-2">Kafka, S3, Delta, custom</td>
          <td class="border border-border px-3 py-2">Kafka only</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">SQL support</td>
