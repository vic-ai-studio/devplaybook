          <td class="border border-border px-3 py-2">&lt;1ms–10ms</td>
          <td class="border border-border px-3 py-2">100ms–seconds</td>
          <td class="border border-border px-3 py-2">&lt;1ms–10ms</td>
        </tr>
        <tr>
