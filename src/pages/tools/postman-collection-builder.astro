---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Postman Collection Builder — JSON Collection Generator"
  description="Build Postman Collection v2.1 JSON files with multiple requests, folders, environment variables, and auth. Export ready-to-import Postman collections with one click."
  tool="Postman collection builder, Postman JSON generator, API collection, Postman import, REST API collection, Postman v2.1"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Postman Collection Builder",
    "url": "https://devplaybook.cc/tools/postman-collection-builder",
    "description": "Build Postman Collection v2.1 JSON files with multiple requests, folders, environment variables, and auth. Export ready-to-import collections with one click.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Postman Collection Builder</h1>
  <p class="text-text-muted mb-4">
    Build <strong>Postman Collection v2.1</strong> JSON files visually. Add requests, group them into folders, set collection-level auth, and define environment variables.
    Export a ready-to-import <code class="font-mono bg-surface px-1 rounded text-sm">.json</code> file — or a companion environment JSON — in one click.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Postman v2.1 format</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Bearer / Basic / API Key auth</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Folder grouping</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Environment variables export</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <!-- ── Main grid ──────────────────────────────────────────────────────────── -->
  <div class="grid grid-cols-1 xl:grid-cols-5 gap-6">

    <!-- LEFT PANEL: config form -->
    <div class="xl:col-span-2 space-y-4">

      <!-- Collection meta -->
      <div class="bg-bg-card border border-border rounded-lg p-4 space-y-3">
        <h2 class="text-sm font-semibold">Collection Info</h2>
        <div>
          <label class="block text-xs text-text-muted mb-1">Collection Name <span class="text-red-400">*</span></label>
          <input id="col-name" type="text" placeholder="My API Collection"
            class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">Description (optional)</label>
          <textarea id="col-desc" rows="2" placeholder="Describe what this collection does..."
            class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary resize-none"></textarea>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">Base URL</label>
          <input id="col-baseurl" type="text"
            class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary"
            placeholder="https://api.example.com" />
          <p class="text-xs text-text-muted mt-1">Stored as <code class="font-mono bg-surface px-1 rounded">baseUrl</code> variable in the collection.</p>
        </div>
      </div>

      <!-- Auth -->
      <div class="bg-bg-card border border-border rounded-lg p-4 space-y-3">
        <h2 class="text-sm font-semibold">Collection-Level Auth</h2>
        <select id="col-auth" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
          <option value="none">None</option>
          <option value="bearer">Bearer Token</option>
          <option value="basic">Basic Auth</option>
          <option value="apikey">API Key (Header)</option>
        </select>
        <div id="auth-bearer" class="hidden">
          <label class="block text-xs text-text-muted mb-1">Token variable name</label>
          <input id="auth-bearer-token" type="text" placeholder="authToken"
            class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" />
          <p class="text-xs text-text-muted mt-1">Will be referenced as a variable, e.g. <code class="font-mono bg-surface px-1 rounded">authToken</code></p>
        </div>
        <div id="auth-basic" class="hidden space-y-2">
          <div>
            <label class="block text-xs text-text-muted mb-1">Username variable</label>
            <input id="auth-basic-user" type="text" placeholder="basicUser"
              class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="block text-xs text-text-muted mb-1">Password variable</label>
            <input id="auth-basic-pass" type="text" placeholder="basicPass"
              class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" />
          </div>
        </div>
        <div id="auth-apikey" class="hidden space-y-2">
          <div>
            <label class="block text-xs text-text-muted mb-1">Header name</label>
            <input id="auth-apikey-header" type="text" placeholder="X-API-Key"
              class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="block text-xs text-text-muted mb-1">Value variable</label>
            <input id="auth-apikey-value" type="text" placeholder="apiKey"
              class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" />
          </div>
        </div>
      </div>

      <!-- Environment Variables -->
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <div class="flex items-center justify-between mb-2">
          <h2 class="text-sm font-semibold">Environment Variables</h2>
          <button id="btn-add-env" class="text-xs text-primary hover:underline">+ Add variable</button>
        </div>
        <p class="text-xs text-text-muted mb-3">Define variables to populate an environment JSON alongside the collection.</p>
        <div id="env-list" class="space-y-2"></div>
      </div>

      <!-- Load Examples -->
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <h2 class="text-sm font-semibold mb-3">Load Example</h2>
        <div class="flex gap-2 flex-wrap">
          <button id="btn-example-crud" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">REST API CRUD</button>
          <button id="btn-example-auth" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Auth Flow</button>
        </div>
      </div>
    </div>

    <!-- RIGHT PANEL: requests + output -->
    <div class="xl:col-span-3 space-y-4">

      <!-- Requests -->
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold">Requests</h2>
          <button id="btn-add-req" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90">+ Add Request</button>
        </div>
        <div id="req-list" class="space-y-3"></div>
        <p id="req-empty" class="text-xs text-text-muted text-center py-6">No requests yet. Click <strong>+ Add Request</strong> or load an example.</p>
      </div>

      <!-- Output -->
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
          <div class="flex gap-2" id="output-tabs">
            <button data-tab="collection" class="output-tab px-4 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold">Collection JSON</button>
            <button data-tab="environment" class="output-tab px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors" id="tab-env-btn">Environment JSON</button>
          </div>
          <div class="flex gap-2">
            <button id="btn-copy" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Copy JSON</button>
            <button id="btn-download" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90">Download</button>
          </div>
        </div>
        <p id="copy-msg" class="text-xs text-green-400 hidden mb-2">Copied to clipboard!</p>
        <pre id="output-json" class="bg-surface rounded-lg p-4 text-xs font-mono overflow-auto max-h-[480px] whitespace-pre text-text-muted leading-relaxed"></pre>
      </div>

    </div>
  </div>

  <ToolPageCta currentTool="Postman Collection Builder" relatedTags={['api', 'rest', 'http', 'postman', 'testing', 'json', 'developer-tools']} />
</BaseLayout>

<script is:inline>
(function () {
  // ── State ──────────────────────────────────────────────────────────────────
  var requests = [];   // array of request objects
  var envVars  = [];   // array of { key, value }
  var activeTab = 'collection';

  // ── Helpers ────────────────────────────────────────────────────────────────
  function g(id) { return document.getElementById(id); }
  function val(id) { var el = g(id); return el ? el.value.trim() : ''; }
  function esc(s) {
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function generateUUID() {
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function (c) {
      var r = (Math.random() * 16) | 0;
      var v = c === 'x' ? r : (r & 0x3) | 0x8;
      return v.toString(16);
    });
  }

  // ── Auth UI ────────────────────────────────────────────────────────────────
  g('col-auth').addEventListener('change', function () {
    ['auth-bearer', 'auth-basic', 'auth-apikey'].forEach(function (id) {
      g(id).classList.add('hidden');
    });
    var v = g('col-auth').value;
    if (v === 'bearer') g('auth-bearer').classList.remove('hidden');
    if (v === 'basic')  g('auth-basic').classList.remove('hidden');
    if (v === 'apikey') g('auth-apikey').classList.remove('hidden');
    render();
  });

  // Set default base URL via JS (avoids Astro parsing {{...}} in HTML)
  g('col-baseurl').value = 'https://api.example.com';

  // ── Env Vars ───────────────────────────────────────────────────────────────
  g('btn-add-env').addEventListener('click', function () {
    envVars.push({ key: '', value: '' });
    renderEnvList();
    render();
  });

  function renderEnvList() {
    g('env-list').innerHTML = envVars.map(function (v, i) {
      return '<div class="flex gap-2 items-center" data-env-idx="' + i + '">' +
        '<input type="text" placeholder="KEY" value="' + esc(v.key) + '" data-env-key="' + i + '"' +
        ' class="flex-1 bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" />' +
        '<input type="text" placeholder="value" value="' + esc(v.value) + '" data-env-val="' + i + '"' +
        ' class="flex-1 bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" />' +
        '<button data-env-remove="' + i + '" class="text-red-400 hover:text-red-300 text-lg leading-none flex-shrink-0" title="Remove">&times;</button>' +
        '</div>';
    }).join('');

    g('env-list').querySelectorAll('[data-env-key]').forEach(function (inp) {
      inp.addEventListener('input', function () {
        envVars[parseInt(inp.dataset.envKey)].key = inp.value;
        render();
      });
    });
    g('env-list').querySelectorAll('[data-env-val]').forEach(function (inp) {
      inp.addEventListener('input', function () {
        envVars[parseInt(inp.dataset.envVal)].value = inp.value;
        render();
      });
    });
    g('env-list').querySelectorAll('[data-env-remove]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        envVars.splice(parseInt(btn.dataset.envRemove), 1);
        renderEnvList();
        render();
      });
    });

    // Show/hide environment tab
    g('tab-env-btn').style.display = envVars.length > 0 ? '' : 'none';
    if (envVars.length === 0 && activeTab === 'environment') {
      setActiveTab('collection');
    }
  }

  // ── Requests ───────────────────────────────────────────────────────────────
  var METHODS = ['GET', 'POST', 'PUT', 'PATCH', 'DELETE'];
  var METHOD_COLORS = {
    GET:    'text-green-400',
    POST:   'text-blue-400',
    PUT:    'text-yellow-400',
    PATCH:  'text-orange-400',
    DELETE: 'text-red-400'
  };

  g('btn-add-req').addEventListener('click', function () {
    requests.push({ id: generateUUID(), method: 'GET', name: '', path: '', body: '', description: '', folder: '' });
    renderRequests();
    render();
  });

  function renderRequests() {
    var list = g('req-list');
    var empty = g('req-empty');

    if (requests.length === 0) {
      list.innerHTML = '';
      empty.style.display = '';
      return;
    }
    empty.style.display = 'none';

    list.innerHTML = requests.map(function (req, i) {
      var methodColor = METHOD_COLORS[req.method] || 'text-text-muted';
      return '<div class="border border-border rounded-lg overflow-hidden" data-req-idx="' + i + '">' +
        // Header row
        '<div class="flex items-center gap-2 px-3 py-2 bg-surface">' +
          '<select data-req-method="' + i + '" class="bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary font-mono font-semibold ' + methodColor + ' w-24">' +
            METHODS.map(function (m) {
              return '<option value="' + m + '"' + (req.method === m ? ' selected' : '') + '>' + m + '</option>';
            }).join('') +
          '</select>' +
          '<input type="text" placeholder="Request name (e.g. List Users)" value="' + esc(req.name) + '" data-req-name="' + i + '"' +
          ' class="flex-1 bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />' +
          '<button data-req-remove="' + i + '" class="text-red-400 hover:text-red-300 text-xl leading-none flex-shrink-0 px-1" title="Remove">&times;</button>' +
        '</div>' +
        // Path row
        '<div class="px-3 py-2 border-t border-border">' +
          '<div class="flex items-center gap-2">' +
            '<span class="text-xs text-text-muted font-mono flex-shrink-0">baseUrl +</span>' +
            '<input type="text" placeholder="/users/&#123;&#123;userId&#125;&#125;" value="' + esc(req.path) + '" data-req-path="' + i + '"' +
            ' class="flex-1 bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" />' +
          '</div>' +
        '</div>' +
        // Folder + Description row
        '<div class="px-3 py-2 border-t border-border grid grid-cols-2 gap-2">' +
          '<div>' +
            '<label class="block text-xs text-text-muted mb-1">Folder (optional)</label>' +
            '<input type="text" placeholder="e.g. Users" value="' + esc(req.folder) + '" data-req-folder="' + i + '"' +
            ' class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />' +
          '</div>' +
          '<div>' +
            '<label class="block text-xs text-text-muted mb-1">Description (optional)</label>' +
            '<input type="text" placeholder="What this request does" value="' + esc(req.description) + '" data-req-desc="' + i + '"' +
            ' class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />' +
          '</div>' +
        '</div>' +
        // Body (only POST/PUT/PATCH)
        (req.method === 'POST' || req.method === 'PUT' || req.method === 'PATCH' ?
          '<div class="px-3 py-2 border-t border-border">' +
            '<label class="block text-xs text-text-muted mb-1">Request Body (JSON)</label>' +
            '<textarea rows="4" placeholder=\'{\n  "name": "John"\n}\' data-req-body="' + i + '"' +
            ' class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary resize-y">' + esc(req.body) + '</textarea>' +
          '</div>'
        : '') +
      '</div>';
    }).join('');

    // Bind events
    list.querySelectorAll('[data-req-method]').forEach(function (sel) {
      sel.addEventListener('change', function () {
        var idx = parseInt(sel.dataset.reqMethod);
        requests[idx].method = sel.value;
        // Update color
        var methodColor = METHOD_COLORS[sel.value] || 'text-text-muted';
        Object.keys(METHOD_COLORS).forEach(function (m) { sel.classList.remove(METHOD_COLORS[m]); });
        sel.classList.add(methodColor);
        // Re-render to show/hide body field
        renderRequests();
        render();
      });
    });
    list.querySelectorAll('[data-req-name]').forEach(function (inp) {
      inp.addEventListener('input', function () {
        requests[parseInt(inp.dataset.reqName)].name = inp.value;
        render();
      });
    });
    list.querySelectorAll('[data-req-path]').forEach(function (inp) {
      inp.addEventListener('input', function () {
        requests[parseInt(inp.dataset.reqPath)].path = inp.value;
        render();
      });
    });
    list.querySelectorAll('[data-req-folder]').forEach(function (inp) {
      inp.addEventListener('input', function () {
        requests[parseInt(inp.dataset.reqFolder)].folder = inp.value;
        render();
      });
    });
    list.querySelectorAll('[data-req-desc]').forEach(function (inp) {
      inp.addEventListener('input', function () {
        requests[parseInt(inp.dataset.reqDesc)].description = inp.value;
        render();
      });
    });
    list.querySelectorAll('[data-req-body]').forEach(function (ta) {
      ta.addEventListener('input', function () {
        requests[parseInt(ta.dataset.reqBody)].body = ta.value;
        render();
      });
    });
    list.querySelectorAll('[data-req-remove]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        requests.splice(parseInt(btn.dataset.reqRemove), 1);
        renderRequests();
        render();
      });
    });
  }

  // ── Collection JSON builder ────────────────────────────────────────────────
  function buildUrl(baseUrlVar, path) {
    // path may start with / or not
    var cleanPath = (path || '').replace(/^\//, '');
    var segments = cleanPath ? cleanPath.split('/') : [];
    return {
      raw: '{{' + baseUrlVar + '}}' + (path ? (path.startsWith('/') ? path : '/' + path) : ''),
      host: ['{{' + baseUrlVar + '}}'],
      path: segments.length > 0 ? segments : ['']
    };
  }

  function buildAuth() {
    var type = g('col-auth').value;
    if (type === 'none') return { type: 'noauth' };

    if (type === 'bearer') {
      var tokenVar = val('auth-bearer-token') || 'authToken';
      return {
        type: 'bearer',
        bearer: [{ key: 'token', value: '{{' + tokenVar + '}}', type: 'string' }]
      };
    }
    if (type === 'basic') {
      var userVar = val('auth-basic-user') || 'basicUser';
      var passVar = val('auth-basic-pass') || 'basicPass';
      return {
        type: 'basic',
        basic: [
          { key: 'username', value: '{{' + userVar + '}}', type: 'string' },
          { key: 'password', value: '{{' + passVar + '}}', type: 'string' }
        ]
      };
    }
    if (type === 'apikey') {
      var headerName = val('auth-apikey-header') || 'X-API-Key';
      var valVar = val('auth-apikey-value') || 'apiKey';
      return {
        type: 'apikey',
        apikey: [
          { key: 'key',   value: headerName,          type: 'string' },
          { key: 'value', value: '{{' + valVar + '}}', type: 'string' },
          { key: 'in',    value: 'header',             type: 'string' }
        ]
      };
    }
    return { type: 'noauth' };
  }

  function buildRequestItem(req, baseUrlVar) {
    var urlObj = buildUrl(baseUrlVar, req.path);

    var requestObj = {
      method: req.method,
      header: [],
      url: urlObj
    };
    if (req.description) requestObj.description = req.description;

    // Body
    if ((req.method === 'POST' || req.method === 'PUT' || req.method === 'PATCH') && req.body) {
      requestObj.header.push({ key: 'Content-Type', value: 'application/json', type: 'text' });
      requestObj.body = {
        mode: 'raw',
        raw: req.body,
        options: { raw: { language: 'json' } }
      };
    }

    return {
      name: req.name || (req.method + ' ' + (req.path || '/')),
      request: requestObj,
      response: []
    };
  }

  function buildCollectionJSON() {
    var colName = val('col-name') || 'My API Collection';
    var baseUrl = val('col-baseurl') || 'https://api.example.com';
    var baseUrlVar = 'baseUrl';

    // Build items — group by folder
    var folders = {};   // folderName -> [items]
    var ungrouped = []; // items without folder

    requests.forEach(function (req) {
      var item = buildRequestItem(req, baseUrlVar);
      if (req.folder && req.folder.trim()) {
        var fn = req.folder.trim();
        if (!folders[fn]) folders[fn] = [];
        folders[fn].push(item);
      } else {
        ungrouped.push(item);
      }
    });

    var items = [];
    // Add folder items first
    Object.keys(folders).forEach(function (fn) {
      items.push({ name: fn, item: folders[fn] });
    });
    // Then ungrouped
    ungrouped.forEach(function (item) { items.push(item); });

    // Collection variables
    var variables = [{ key: baseUrlVar, value: baseUrl }];
    // Also add auth token vars if present
    var authType = g('col-auth').value;
    if (authType === 'bearer') {
      var tVar = val('auth-bearer-token') || 'authToken';
      variables.push({ key: tVar, value: '' });
    }
    if (authType === 'basic') {
      variables.push({ key: val('auth-basic-user') || 'basicUser', value: '' });
      variables.push({ key: val('auth-basic-pass') || 'basicPass', value: '' });
    }
    if (authType === 'apikey') {
      variables.push({ key: val('auth-apikey-value') || 'apiKey', value: '' });
    }

    var collection = {
      info: {
        _postman_id: generateUUID(),
        name: colName,
        schema: 'https://schema.getpostman.com/json/collection/v2.1.0/collection.json'
      },
      auth: buildAuth(),
      variable: variables,
      item: items
    };

    var colDesc = val('col-desc');
    if (colDesc) collection.info.description = colDesc;

    return collection;
  }

  function buildEnvironmentJSON() {
    var colName = val('col-name') || 'My API Collection';
    var baseUrl = val('col-baseurl') || 'https://api.example.com';

    var values = [{ key: 'baseUrl', value: baseUrl, type: 'default', enabled: true }];
    envVars.forEach(function (v) {
      if (v.key) {
        values.push({ key: v.key, value: v.value, type: 'default', enabled: true });
      }
    });

    return {
      id: generateUUID(),
      name: colName + ' — Environment',
      values: values,
      _postman_variable_scope: 'environment',
      _postman_exported_using: 'DevPlaybook Postman Builder'
    };
  }

  // ── Render output ──────────────────────────────────────────────────────────
  function render() {
    var json;
    if (activeTab === 'environment') {
      json = buildEnvironmentJSON();
    } else {
      json = buildCollectionJSON();
    }
    g('output-json').textContent = JSON.stringify(json, null, 2);
  }

  // ── Tabs ───────────────────────────────────────────────────────────────────
  function setActiveTab(tab) {
    activeTab = tab;
    document.querySelectorAll('.output-tab').forEach(function (btn) {
      var isActive = btn.dataset.tab === tab;
      btn.classList.toggle('bg-primary',     isActive);
      btn.classList.toggle('text-white',     isActive);
      btn.classList.toggle('font-semibold',  isActive);
      btn.classList.toggle('bg-bg-card',     !isActive);
      btn.classList.toggle('border',         !isActive);
      btn.classList.toggle('border-border',  !isActive);
      btn.classList.toggle('hover:border-primary', !isActive);
      btn.classList.toggle('transition-colors', !isActive);
    });
    render();
  }

  document.querySelectorAll('.output-tab').forEach(function (btn) {
    btn.addEventListener('click', function () { setActiveTab(btn.dataset.tab); });
  });

  // ── Copy + Download ────────────────────────────────────────────────────────
  g('btn-copy').addEventListener('click', function () {
    navigator.clipboard.writeText(g('output-json').textContent).then(function () {
      g('copy-msg').classList.remove('hidden');
      setTimeout(function () { g('copy-msg').classList.add('hidden'); }, 2000);
    });
  });

  g('btn-download').addEventListener('click', function () {
    var colName = (val('col-name') || 'collection').toLowerCase().replace(/\s+/g, '-');
    var filename, content;
    if (activeTab === 'environment') {
      filename = colName + '.environment.json';
      content  = JSON.stringify(buildEnvironmentJSON(), null, 2);
    } else {
      filename = colName + '.postman_collection.json';
      content  = JSON.stringify(buildCollectionJSON(), null, 2);
    }
    var blob = new Blob([content], { type: 'application/json' });
    var url  = URL.createObjectURL(blob);
    var a    = document.createElement('a');
    a.href     = url;
    a.download = filename;
    a.click();
    URL.revokeObjectURL(url);
  });

  // ── Live update on meta fields ────────────────────────────────────────────
  ['col-name', 'col-desc', 'col-baseurl',
   'auth-bearer-token', 'auth-basic-user', 'auth-basic-pass',
   'auth-apikey-header', 'auth-apikey-value'
  ].forEach(function (id) {
    var el = g(id);
    if (el) el.addEventListener('input', render);
  });

  // ── Load Examples ─────────────────────────────────────────────────────────
  g('btn-example-crud').addEventListener('click', function () {
    // Reset and populate REST CRUD example
    g('col-name').value = 'Users API';
    g('col-desc').value = 'CRUD operations for the Users resource.';
    g('col-baseurl').value = 'https://api.example.com';
    g('col-auth').value = 'bearer';
    g('col-auth').dispatchEvent(new Event('change'));
    g('auth-bearer-token').value = 'authToken';

    envVars = [
      { key: 'authToken', value: 'YOUR_BEARER_TOKEN_HERE' },
      { key: 'userId',    value: '1' }
    ];
    renderEnvList();

    requests = [
      { id: generateUUID(), method: 'GET',    name: 'List Users',   path: '/users',            body: '', description: 'Get all users',          folder: 'Users' },
      { id: generateUUID(), method: 'POST',   name: 'Create User',  path: '/users',            body: '{\n  "name": "Jane Doe",\n  "email": "jane@example.com"\n}', description: 'Create a new user', folder: 'Users' },
      { id: generateUUID(), method: 'GET',    name: 'Get User',     path: '/users/{{userId}}', body: '', description: 'Get a user by ID',        folder: 'Users' },
      { id: generateUUID(), method: 'PUT',    name: 'Update User',  path: '/users/{{userId}}', body: '{\n  "name": "Jane Smith"\n}',             description: 'Update a user', folder: 'Users' },
      { id: generateUUID(), method: 'DELETE', name: 'Delete User',  path: '/users/{{userId}}', body: '', description: 'Delete a user by ID',     folder: 'Users' }
    ];
    renderRequests();
    render();
  });

  g('btn-example-auth').addEventListener('click', function () {
    g('col-name').value = 'Auth Flow';
    g('col-desc').value = 'Authentication and token management endpoints.';
    g('col-baseurl').value = 'https://auth.example.com';
    g('col-auth').value = 'none';
    g('col-auth').dispatchEvent(new Event('change'));

    envVars = [
      { key: 'accessToken',  value: '' },
      { key: 'refreshToken', value: '' }
    ];
    renderEnvList();

    requests = [
      { id: generateUUID(), method: 'POST', name: 'Login',          path: '/auth/login',
        body: '{\n  "email": "user@example.com",\n  "password": "secret"\n}',
        description: 'Authenticate and receive tokens', folder: 'Auth' },
      { id: generateUUID(), method: 'POST', name: 'Refresh Token',  path: '/auth/refresh',
        body: '{\n  "refresh_token": "{{refreshToken}}"\n}',
        description: 'Exchange refresh token for a new access token', folder: 'Auth' },
      { id: generateUUID(), method: 'POST', name: 'Logout',         path: '/auth/logout',
        body: '{\n  "refresh_token": "{{refreshToken}}"\n}',
        description: 'Invalidate the refresh token', folder: 'Auth' },
      { id: generateUUID(), method: 'GET',  name: 'Get Current User', path: '/auth/me',
        body: '', description: 'Get the currently authenticated user', folder: 'Profile' },
      { id: generateUUID(), method: 'POST', name: 'Forgot Password', path: '/auth/forgot-password',
        body: '{\n  "email": "user@example.com"\n}',
        description: 'Send password reset email', folder: 'Password' }
    ];
    renderRequests();
    render();
  });

  // ── Init ──────────────────────────────────────────────────────────────────
  g('tab-env-btn').style.display = 'none'; // hidden until env vars are added
  renderEnvList();
  renderRequests();
  render();
})();
</script>
