</BaseLayout>

<script>
type DbType = 'postgresql' | 'mysql' | 'mongodb' | 'redis';

interface PoolResult {
  minPool: number;
  maxPool: number;
  totalConns: number;
  queueTimeout: number;
  formulaLines: string[];
  warnings: string[];
  pgBouncerNeeded: boolean;
  replicaSuggested: boolean;
}

// Default max_connections per DB type
const DB_MAX_CONNS: Record<DbType, number> = {
  postgresql: 100,
  mysql:      151,
  mongodb:    1000000, // effectively unlimited
  redis:      10000,
};

function calculatePool(
  dbType: DbType,
  cores: number,
  users: number,
  queryMs: number,
  rwRatio: number,
  instances: number
): PoolResult {
  const warnings: string[] = [];

  // HikariCP base formula: (cores × 2) + 1 (SSD effective spindle = 1)
  const basePool = cores * 2 + 1;

  // Concurrency demand: how many connections does the peak workload need?
  // Arrival rate (req/s) × avg service time (s) = Little's Law
  const arrivalRate = users;                        // requests per second at peak
  const serviceTime = queryMs / 1000;               // seconds
  const demandPool = Math.ceil(arrivalRate * serviceTime);

  // Take the larger of formula vs demand, cap at 2× formula to avoid over-provisioning
  let maxPool = Math.min(Math.max(basePool, Math.min(demandPool, basePool * 3)), basePool * 4);

  // Redis special case — small pool is fine
  if (dbType === 'redis') {
    maxPool = Math.max(5, Math.min(basePool, 20));
  }

  const minPool = Math.max(2, Math.floor(maxPool * 0.25));
  const totalConns = maxPool * instances;

  // Queue timeout heuristic: 2× avg query duration, min 5s
  const queueTimeout = Math.max(5000, queryMs * 2);

  const formulaLines: string[] = [
    `base_pool  = (${cores} cores × 2) + 1 (SSD)         = ${basePool}`,
    `demand     = ${users} users × ${serviceTime.toFixed(3)}s avg latency   = ${demandPool} connections`,
    `max_pool   = clamp(max(${basePool}, ${Math.min(demandPool, basePool * 3)}), ceil)        = ${maxPool}`,
    `min_pool   = max(2, floor(${maxPool} × 0.25))     = ${minPool}`,
    `total      = ${maxPool} × ${instances} instance${instances !== 1 ? 's' : ''}               = ${totalConns} connections`,
    `timeout    = max(5000, ${queryMs}ms × 2)              = ${queueTimeout}ms`,
  ];

  const dbMaxConns = DB_MAX_CONNS[dbType];
  let pgBouncerNeeded = false;

  if (totalConns > dbMaxConns * 0.8) {
    warnings.push(`Total connections (${totalConns}) exceeds 80% of ${dbType === 'postgresql' ? 'PostgreSQL default' : 'recommended'} max_connections (${dbMaxConns}). ${dbType === 'postgresql' ? 'Add PgBouncer in transaction mode.' : 'Consider connection proxying.'}`);
    pgBouncerNeeded = dbType === 'postgresql';
  }

  if (maxPool > 50 && dbType !== 'redis') {
    warnings.push(`Max pool size of ${maxPool} is unusually high. Verify query latency is accurate — long-running queries inflate pool requirements.`);
  }

  if (instances > 10 && maxPool > 10) {
    warnings.push(`With ${instances} instances × ${maxPool} connections = ${totalConns} total. Monitor your database's connection count closely.`);
  }

  const replicaSuggested = rwRatio >= 70 && dbType !== 'redis';

  return { minPool, maxPool, totalConns, queueTimeout, formulaLines, warnings, pgBouncerNeeded, replicaSuggested };
}

// ─── Config generators ────────────────────────────────────────────────────────
function genPrisma(dbType: DbType, min: number, max: number, timeout: number): string {
  const scheme = dbType === 'postgresql' ? 'postgresql' : dbType === 'mysql' ? 'mysql' : 'mongodb';
  if (dbType === 'redis') {
    return `// Redis: use ioredis with connection pool
import Redis from "ioredis";

const redis = new Redis({
  host: process.env.REDIS_HOST,
  port: 6379,
  maxRetriesPerRequest: 3,
  // ioredis manages a single connection by default.
  // For a pool use a Cluster or Redis Sentinel client.
  lazyConnect: true,
});`;
  }
  return `// schema.prisma
datasource db {
  provider = "${scheme}"
  url      = env("DATABASE_URL")
}

// .env — connection pool via URL params
// DATABASE_URL="${scheme}://user:pass@host:5432/db?connection_limit=${max}&pool_timeout=${Math.round(timeout / 1000)}"

// prisma/client.ts
import { PrismaClient } from "@prisma/client";

const globalForPrisma = global as unknown as { prisma: PrismaClient };

export const prisma =
  globalForPrisma.prisma ??
  new PrismaClient({
    datasources: {
      db: {
        url: process.env.DATABASE_URL,
      },
    },
    // Prisma uses connection_limit from the URL.
    // Recommended: connection_limit=${max}, pool_timeout=${Math.round(timeout / 1000)}
  });

if (process.env.NODE_ENV !== "production") globalForPrisma.prisma = prisma;

// ─── URL with pool params ───────────────────────────────────────────
// DATABASE_URL="${scheme}://user:pass@localhost:5432/mydb\\
//   ?connection_limit=${max}\\
//   &pool_timeout=${Math.round(timeout / 1000)}\\
//   &connect_timeout=10"`;
}

function genDrizzle(dbType: DbType, min: number, max: number, timeout: number): string {
  if (dbType === 'mongodb') {
    return `// Drizzle does not support MongoDB natively.
// Use the MongoDB Node.js driver directly:

import { MongoClient } from "mongodb";

const client = new MongoClient(process.env.MONGODB_URI!, {
  maxPoolSize: ${max},
  minPoolSize: ${min},
  maxIdleTimeMS: ${timeout},
  connectTimeoutMS: 10000,
  serverSelectionTimeoutMS: 5000,
});
await client.connect();`;
  }
  if (dbType === 'redis') {
    return `// Redis: use ioredis directly (Drizzle does not wrap Redis)
import Redis from "ioredis";

export const redis = new Redis(process.env.REDIS_URL!, {
  maxRetriesPerRequest: 3,
  enableReadyCheck: true,
  lazyConnect: false,
});`;
  }
  const driver = dbType === 'mysql' ? 'mysql2' : 'postgres';
  const importPkg = dbType === 'mysql'
    ? `import { drizzle } from "drizzle-orm/mysql2";\nimport mysql from "mysql2/promise";`
    : `import { drizzle } from "drizzle-orm/node-postgres";\nimport { Pool } from "pg";`;
  const poolSetup = dbType === 'mysql'
    ? `const pool = mysql.createPool({
  host: process.env.DB_HOST,
  user: process.env.DB_USER,
  password: process.env.DB_PASS,
  database: process.env.DB_NAME,
  connectionLimit: ${max},
  queueLimit: 0,
  acquireTimeout: ${timeout},
  waitForConnections: true,
});`
    : `const pool = new Pool({
  connectionString: process.env.DATABASE_URL,
  min: ${min},
  max: ${max},
  idleTimeoutMillis: 30000,
  connectionTimeoutMillis: ${timeout},
});`;
  const drizzleInit = dbType === 'mysql'
    ? `export const db = drizzle(pool);`
    : `export const db = drizzle(pool);`;

  return `// db.ts (Drizzle ORM + ${driver})
${importPkg}

${poolSetup}

${drizzleInit}

// Graceful shutdown
process.on("SIGINT", async () => {
  await pool.end();
  process.exit(0);
});`;
}

function genSQLAlchemy(dbType: DbType, min: number, max: number, timeout: number): string {
  if (dbType === 'mongodb') {
    return `# Use pymongo directly for MongoDB
from pymongo import MongoClient

client = MongoClient(
    host=os.environ["MONGODB_URI"],
    maxPoolSize=${max},
    minPoolSize=${min},
    maxIdleTimeMS=${timeout},
    connectTimeoutMS=10000,
    serverSelectionTimeoutMS=5000,
)
db = client["mydb"]`;
  }
  if (dbType === 'redis') {
    return `# Use redis-py with connection pool
import redis

pool = redis.ConnectionPool(
    host=os.environ.get("REDIS_HOST", "localhost"),
    port=6379,
    db=0,
    max_connections=${max},
    decode_responses=True,
)

r = redis.Redis(connection_pool=pool)`;
  }
  const dialect = dbType === 'mysql' ? 'mysql+mysqlconnector' : 'postgresql+psycopg2';
  return `# SQLAlchemy 2.0 (sync)
from sqlalchemy import create_engine
from sqlalchemy.orm import sessionmaker
import os

engine = create_engine(
    os.environ["DATABASE_URL"],
    pool_size=${min},          # min connections kept open
    max_overflow=${max - min},  # additional connections above pool_size (max total: ${max})
    pool_timeout=${timeout / 1000},         # seconds to wait for a connection
    pool_recycle=1800,          # recycle connections after 30 min
    pool_pre_ping=True,         # test connections before using
    echo=False,
)

SessionLocal = sessionmaker(autocommit=False, autoflush=False, bind=engine)

# FastAPI dependency
from contextlib import contextmanager

@contextmanager
def get_db():
    db = SessionLocal()
    try:
        yield db
        db.commit()
    except Exception:
        db.rollback()
        raise
    finally:
        db.close()

# ─── Async (SQLAlchemy 2.0 + asyncpg) ──────────────────────────────
from sqlalchemy.ext.asyncio import create_async_engine, async_sessionmaker

async_engine = create_async_engine(
    os.environ["DATABASE_URL"].replace("${dialect}", "${dbType === 'mysql' ? 'mysql+aiomysql' : 'postgresql+asyncpg'}"),
    pool_size=${min},
    max_overflow=${max - min},
    pool_timeout=${timeout / 1000},
    pool_recycle=1800,
    pool_pre_ping=True,
)
AsyncSession = async_sessionmaker(async_engine, expire_on_commit=False)`;
}

function genSequelize(dbType: DbType, min: number, max: number, timeout: number): string {
  if (dbType === 'mongodb') {
    return `// Sequelize does not support MongoDB.
// Use Mongoose instead:

import mongoose from "mongoose";

await mongoose.connect(process.env.MONGODB_URI!, {
  maxPoolSize: ${max},
  minPoolSize: ${min},
  serverSelectionTimeoutMS: 5000,
  socketTimeoutMS: 45000,
});`;
  }
  if (dbType === 'redis') {
    return `// Sequelize does not wrap Redis. Use ioredis:
import Redis from "ioredis";

export const redis = new Redis({
  host: process.env.REDIS_HOST ?? "localhost",
  port: 6379,
  maxRetriesPerRequest: 3,
  enableOfflineQueue: false,
});`;
  }
  const dialect = dbType === 'mysql' ? 'mysql' : 'postgres';
  return `// Sequelize 6 (TypeScript)
import { Sequelize } from "sequelize";

export const sequelize = new Sequelize(
  process.env.DB_NAME!,
  process.env.DB_USER!,
  process.env.DB_PASS!,
  {
    host: process.env.DB_HOST ?? "localhost",
    dialect: "${dialect}",
    pool: {
      min: ${min},
      max: ${max},
      acquire: ${timeout},   // ms to wait before throwing error
      idle: 10000,           // ms a connection can be idle before release
      evict: 1000,           // how often to run eviction checks (ms)
    },
    logging: process.env.NODE_ENV === "development" ? console.log : false,
  }
);

// Test connection on startup
await sequelize.authenticate();
console.log("Database connection pool established (max=${max})");

// Graceful shutdown
process.on("SIGTERM", async () => {
  await sequelize.close();
  process.exit(0);
});`;
}

// ─── Tab switching ────────────────────────────────────────────────────────────
let activeOrm = 'prisma';

function switchOrm(orm: string): void {
  activeOrm = orm;
  document.querySelectorAll<HTMLElement>('.orm-tab').forEach(t => {
    const active = t.dataset.orm === orm;
    t.classList.toggle('border-primary', active);
    t.classList.toggle('text-primary', active);
    t.classList.toggle('border-transparent', !active);
    t.classList.toggle('text-text-muted', !active);
  });
  document.querySelectorAll('.orm-panel').forEach(p => p.classList.add('hidden'));
  document.getElementById(`orm-tab-${orm}`)?.classList.remove('hidden');
}

document.querySelectorAll<HTMLElement>('.orm-tab').forEach(t => {
  t.addEventListener('click', () => switchOrm(t.dataset.orm!));
});

document.querySelectorAll<HTMLButtonElement>('.copy-orm-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const el = document.getElementById(btn.dataset.target!);
    if (!el) return;
    navigator.clipboard.writeText(el.textContent || '').then(() => {
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 2000);
    });
  });
});

// ─── Calculate ───────────────────────────────────────────────────────────────
function numVal(id: string): number {
  return Math.max(1, parseFloat((document.getElementById(id) as HTMLInputElement).value) || 1);
}

document.getElementById('btn-calculate')?.addEventListener('click', () => {
  const dbType = (document.getElementById('sel-db-type') as HTMLSelectElement).value as DbType;
  const cores     = numVal('inp-cores');
  const users     = numVal('inp-users');
  const queryMs   = numVal('inp-query-ms');
  const rwRatio   = numVal('inp-rw-ratio');
  const instances = numVal('inp-instances');

  const errorBox = document.getElementById('error-box')!;
  errorBox.classList.add('hidden');

  if (cores < 1 || cores > 256) {
    errorBox.textContent = 'CPU cores must be between 1 and 256.';
    errorBox.classList.remove('hidden');
    return;
  }

  const result = calculatePool(dbType, cores, users, queryMs, rwRatio, instances);

  document.getElementById('out-min-pool')!.textContent = String(result.minPool);
  document.getElementById('out-max-pool')!.textContent = String(result.maxPool);
  document.getElementById('out-total-conns')!.textContent = String(result.totalConns);
  document.getElementById('out-queue-timeout')!.textContent = String(result.queueTimeout);

  const formulaEl = document.getElementById('formula-breakdown')!;
  formulaEl.innerHTML = result.formulaLines.map(l => `<div>${l}</div>`).join('');

  const warningBox = document.getElementById('warning-box')!;
  if (result.warnings.length > 0) {
    document.getElementById('warning-text')!.textContent = result.warnings.join(' ');
    warningBox.classList.remove('hidden');
  } else {
    warningBox.classList.add('hidden');
  }

  const pgTip = document.getElementById('pgbouncer-tip')!;
  result.pgBouncerNeeded ? pgTip.classList.remove('hidden') : pgTip.classList.add('hidden');

  const replicaTip = document.getElementById('replica-tip')!;
  if (result.replicaSuggested) {
    document.getElementById('replica-read-pct')!.textContent = String(Math.round(rwRatio));
    replicaTip.classList.remove('hidden');
  } else {
    replicaTip.classList.add('hidden');
  }

  document.getElementById('code-prisma')!.textContent     = genPrisma(dbType, result.minPool, result.maxPool, result.queueTimeout);
  document.getElementById('code-drizzle')!.textContent    = genDrizzle(dbType, result.minPool, result.maxPool, result.queueTimeout);
  document.getElementById('code-sqlalchemy')!.textContent = genSQLAlchemy(dbType, result.minPool, result.maxPool, result.queueTimeout);
  document.getElementById('code-sequelize')!.textContent  = genSequelize(dbType, result.minPool, result.maxPool, result.queueTimeout);

  document.getElementById('output-section')!.classList.remove('hidden');
  switchOrm(activeOrm);
  setTimeout(() => document.getElementById('output-section')!.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
});

// Auto-calculate on load
document.getElementById('btn-calculate')?.dispatchEvent(new Event('click'));
</script>
