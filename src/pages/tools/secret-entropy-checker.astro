---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "How much entropy does an API key need?", answer: "For general API keys and secrets: at least 128 bits of entropy (roughly 22+ random Base64 characters, or 32 hex characters). For symmetric encryption keys (AES-256): exactly 256 bits. For HMAC secrets (JWT HS256): at least 256 bits per NIST SP 800-107 recommendation." },
  { question: "What is Shannon entropy?", answer: "Shannon entropy measures the unpredictability in a string. It's calculated per-character as H = -Σ p(c) × log₂(p(c)). For a string with total entropy bits = length × H, higher means harder to guess. A fully random Base64 string has ~6 bits/char; a string like 'aaaaaaa' has 0 bits/char." },
  { question: "Is high entropy enough for a secure secret?", answer: "High entropy is necessary but not sufficient. The secret must also be generated by a cryptographically secure random number generator (CSPRNG), not derived from a timestamp, username, or any predictable input. Use crypto.randomBytes() in Node.js, secrets.token_bytes() in Python, or /dev/urandom." },
  { question: "What is the difference between raw bits and effective bits?", answer: "Raw bits = length × log₂(charset_size) — assumes all characters drawn randomly. Effective (Shannon) entropy = actual observed randomness, penalizing repetition and patterns. A good secret should have effective entropy close to its raw bit estimate." },
  { question: "What format should I use for secrets?", answer: "Hex (0-9, a-f): 4 bits/char — easy to read but less dense. Base64 (a-z, A-Z, 0-9, +, /): ~6 bits/char — more compact, 43 chars = 256 bits. URL-safe Base64: same density, safe in headers/URLs. For most uses: generate 32 random bytes and encode as hex (64 chars) or Base64 (43 chars)." },
];
---

<BaseLayout
  title="Secret Entropy Checker — Validate API Keys, Tokens & Secrets Entropy"
  description="Check if your API keys, JWT secrets, tokens, and env variables have sufficient entropy. See bits, density rating, and recommendations for cryptographic strength. Browser-only, nothing sent."
  tool="Secret Entropy Checker, API Key Entropy, Token Entropy Validator, Secret Strength Checker, Cryptographic Entropy"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Secret Entropy Checker</h1>
  <p class="text-text-muted mb-4">Paste any API key, JWT secret, token, or env variable to check if it has enough entropy to be cryptographically secure. Everything runs in your browser — your secrets are never transmitted.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Shannon & raw entropy calculation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> NIST recommendations</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Secret never leaves browser</span>
  </div>

  <div class="space-y-5">
    <!-- Input -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-2">
        <label class="text-sm font-medium">Secret / Key / Token</label>
        <button id="generate-btn" class="text-xs bg-primary/10 text-primary border border-primary/30 rounded-lg px-3 py-1.5 hover:bg-primary/20 transition-colors">Generate Sample</button>
      </div>
      <div class="relative">
        <input id="secret-input" type="password" placeholder="Paste your API key, JWT secret, or any token..."
          class="w-full bg-bg border border-border rounded-lg px-4 py-3 text-sm font-mono focus:outline-none focus:border-primary pr-20" />
        <button id="toggle-vis" class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-text-muted hover:text-text px-2 py-1 border border-border rounded">Show</button>
      </div>
      <div class="flex gap-2 mt-3 flex-wrap">
        <span class="text-xs text-text-muted">Format:</span>
        <label class="flex items-center gap-1.5 text-xs cursor-pointer"><input type="radio" name="fmt" value="auto" checked /> Auto-detect</label>
        <label class="flex items-center gap-1.5 text-xs cursor-pointer"><input type="radio" name="fmt" value="hex" /> Hex</label>
        <label class="flex items-center gap-1.5 text-xs cursor-pointer"><input type="radio" name="fmt" value="base64" /> Base64</label>
        <label class="flex items-center gap-1.5 text-xs cursor-pointer"><input type="radio" name="fmt" value="ascii" /> ASCII</label>
      </div>
    </div>

    <div id="result-section" class="hidden space-y-4">
      <!-- Verdict Banner -->
      <div id="verdict-banner" class="rounded-xl p-4 border">
        <div class="flex items-center gap-3">
          <span id="verdict-icon" class="text-2xl"></span>
          <div>
            <div id="verdict-title" class="font-semibold"></div>
            <div id="verdict-desc" class="text-sm text-text-muted"></div>
          </div>
        </div>
      </div>

      <!-- Metrics -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
          <div id="m-raw" class="text-2xl font-bold text-primary">—</div>
          <div class="text-xs text-text-muted mt-1">Raw Bits</div>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
          <div id="m-shannon" class="text-2xl font-bold">—</div>
          <div class="text-xs text-text-muted mt-1">Shannon Bits</div>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
          <div id="m-len" class="text-2xl font-bold">—</div>
          <div class="text-xs text-text-muted mt-1">Length</div>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
          <div id="m-density" class="text-2xl font-bold">—</div>
          <div class="text-xs text-text-muted mt-1">Bits/Char</div>
        </div>
      </div>

      <!-- Use-case Thresholds -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold mb-3">Use-Case Thresholds</h2>
        <div id="thresholds" class="space-y-2"></div>
      </div>

      <!-- Character Distribution -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold mb-3">Character Analysis</h2>
        <div id="char-analysis" class="space-y-2"></div>
      </div>

      <!-- Generate Secure Alternative -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold mb-3">Generate Secure Alternative</h2>
        <div class="flex flex-wrap gap-2 mb-3">
          {[128, 192, 256].map(bits => (
            <button class="gen-bits-btn text-xs px-3 py-1.5 border border-border rounded-lg hover:bg-bg" data-bits={bits}>{bits}-bit</button>
          ))}
          <select id="gen-format" class="text-xs bg-bg border border-border rounded-lg px-2 py-1.5">
            <option value="hex">Hex</option>
            <option value="base64">Base64</option>
            <option value="base64url">Base64url</option>
          </select>
          <button id="gen-btn" class="text-xs bg-primary text-white px-3 py-1.5 rounded-lg hover:bg-primary/90">Generate</button>
        </div>
        <div class="relative">
          <input id="gen-output" type="text" readonly placeholder="Click Generate →"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-xs font-mono" />
          <button id="copy-gen" class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-text-muted hover:text-text border border-border px-2 py-0.5 rounded">Copy</button>
        </div>
      </div>
    </div>

    <div id="empty-msg" class="text-center text-text-muted text-sm py-8">Paste a secret above to analyze it.</div>
  </div>

  <AdUnit slot="in-content" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Secret Entropy Checker" relatedTags={['security', 'cryptography', 'api', 'auth', 'devops']} />
</BaseLayout>

<script>
let selectedBits = 256;

const input = document.getElementById('secret-input') as HTMLInputElement;
const toggle = document.getElementById('toggle-vis') as HTMLButtonElement;

toggle.addEventListener('click', () => {
  const vis = input.type === 'password';
  input.type = vis ? 'text' : 'password';
  toggle.textContent = vis ? 'Hide' : 'Show';
});

function detectFormat(s: string): { name: string; bitsPerChar: number } {
  const fmt = (document.querySelector('input[name="fmt"]:checked') as HTMLInputElement).value;
  if (fmt === 'hex') return { name: 'Hex', bitsPerChar: 4 };
  if (fmt === 'base64') return { name: 'Base64', bitsPerChar: 6 };
  if (fmt === 'ascii') return { name: 'ASCII', bitsPerChar: Math.log2(95) };

  // auto-detect
  if (/^[0-9a-fA-F]+$/.test(s)) return { name: 'Hex', bitsPerChar: 4 };
  if (/^[A-Za-z0-9+/]+=*$/.test(s)) return { name: 'Base64', bitsPerChar: 6 };
  if (/^[A-Za-z0-9\-_]+=*$/.test(s)) return { name: 'Base64url', bitsPerChar: 6 };
  return { name: 'ASCII/Other', bitsPerChar: Math.log2(94) };
}

function shannonEntropy(s: string): number {
  const freq: Record<string, number> = {};
  for (const c of s) freq[c] = (freq[c] || 0) + 1;
  const n = s.length;
  return Object.values(freq).reduce((sum, count) => {
    const p = count / n;
    return sum - p * Math.log2(p);
  }, 0);
}

function analyze() {
  const s = input.value;
  const result = document.getElementById('result-section')!;
  const empty = document.getElementById('empty-msg')!;

  if (!s) { result.classList.add('hidden'); empty.classList.remove('hidden'); return; }
  result.classList.remove('hidden');
  empty.classList.add('hidden');

  const { name: fmtName, bitsPerChar } = detectFormat(s);
  const rawBits = Math.round(s.length * bitsPerChar);
  const shannonPerChar = shannonEntropy(s);
  const shannonBits = Math.round(s.length * shannonPerChar * 10) / 10;
  const density = Math.round(shannonPerChar * 10) / 10;

  document.getElementById('m-raw')!.textContent = String(rawBits);
  document.getElementById('m-shannon')!.textContent = String(shannonBits);
  document.getElementById('m-len')!.textContent = String(s.length) + ' chars';
  document.getElementById('m-density')!.textContent = density + ' b/c';

  // Verdict
  const verdictBanner = document.getElementById('verdict-banner')!;
  let vIcon: string, vTitle: string, vDesc: string, vBg: string, vBorder: string;
  const effectiveBits = Math.min(rawBits, shannonBits);
  if (effectiveBits >= 128) {
    vIcon = '✓'; vTitle = 'Sufficient entropy for most uses'; vBg = 'bg-green-500/10'; vBorder = 'border-green-500/30';
    vDesc = `${effectiveBits} effective bits. Meets NIST minimum for general secrets (128-bit). Consider 256-bit for long-lived keys.`;
  } else if (effectiveBits >= 80) {
    vIcon = '⚠'; vTitle = 'Borderline — consider strengthening'; vBg = 'bg-amber-500/10'; vBorder = 'border-amber-500/30';
    vDesc = `${effectiveBits} effective bits. Below 128-bit minimum recommended by NIST. Acceptable only for short-lived tokens.`;
  } else {
    vIcon = '✗'; vTitle = 'Insufficient entropy'; vBg = 'bg-red-500/10'; vBorder = 'border-red-500/30';
    vDesc = `Only ${effectiveBits} effective bits. This secret is too weak for cryptographic use. Generate a secure random replacement.`;
  }
  verdictBanner.className = `rounded-xl p-4 border ${vBg} ${vBorder}`;
  document.getElementById('verdict-icon')!.textContent = vIcon;
  document.getElementById('verdict-title')!.textContent = vTitle;
  document.getElementById('verdict-desc')!.textContent = vDesc;

  // Thresholds
  const useCases = [
    { label: 'Session token / CSRF', min: 64, note: 'OWASP minimum' },
    { label: 'API key / general secret', min: 128, note: 'NIST SP 800-63B' },
    { label: 'JWT HMAC secret (HS256)', min: 256, note: 'RFC 7518 recommendation' },
    { label: 'AES-256 symmetric key', min: 256, note: 'FIPS 197' },
    { label: 'Long-lived infrastructure key', min: 192, note: 'Best practice' },
  ];
  document.getElementById('thresholds')!.innerHTML = useCases.map(uc => {
    const pass = effectiveBits >= uc.min;
    return `<div class="flex items-center gap-3 text-sm">
      <span class="${pass ? 'text-green-500' : 'text-red-400'}">${pass ? '✓' : '✗'}</span>
      <span class="flex-1">${uc.label}</span>
      <span class="text-xs text-text-muted">${uc.min}+ bits (${uc.note})</span>
    </div>`;
  }).join('');

  // Char analysis
  const freq: Record<string, number> = {};
  for (const c of s) freq[c] = (freq[c] || 0) + 1;
  const uniqueChars = Object.keys(freq).length;
  const maxFreq = Math.max(...Object.values(freq));
  const topChar = Object.entries(freq).sort((a,b) => b[1]-a[1])[0];
  const repetition = Math.round((1 - uniqueChars / s.length) * 100);

  document.getElementById('char-analysis')!.innerHTML = `
    <div class="grid grid-cols-3 gap-3 text-center text-sm">
      <div class="bg-bg border border-border rounded-lg p-2">
        <div class="font-bold text-lg">${uniqueChars}</div>
        <div class="text-xs text-text-muted">Unique chars</div>
      </div>
      <div class="bg-bg border border-border rounded-lg p-2">
        <div class="font-bold text-lg">${repetition}%</div>
        <div class="text-xs text-text-muted">Repetition</div>
      </div>
      <div class="bg-bg border border-border rounded-lg p-2">
        <div class="font-bold text-lg">${fmtName}</div>
        <div class="text-xs text-text-muted">Detected format</div>
      </div>
    </div>
    ${repetition > 30 ? `<div class="text-xs text-amber-400 mt-2">⚠ High repetition (${repetition}%) detected — '${topChar[0]}' appears ${topChar[1]} times. Suggests low randomness.</div>` : ''}
  `;
}

input.addEventListener('input', analyze);
document.querySelectorAll('input[name="fmt"]').forEach(r => r.addEventListener('change', analyze));

// Generate sample
document.getElementById('generate-btn')!.addEventListener('click', () => {
  const bytes = new Uint8Array(32);
  crypto.getRandomValues(bytes);
  input.value = Array.from(bytes).map(b => b.toString(16).padStart(2,'0')).join('');
  input.type = 'text';
  toggle.textContent = 'Hide';
  analyze();
});

// Generate secure alternative
document.querySelectorAll('.gen-bits-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    selectedBits = parseInt((btn as HTMLElement).dataset.bits || '256');
    document.querySelectorAll('.gen-bits-btn').forEach(b => {
      b.className = 'gen-bits-btn text-xs px-3 py-1.5 border border-border rounded-lg hover:bg-bg';
    });
    btn.className = 'gen-bits-btn text-xs px-3 py-1.5 border border-primary/50 rounded-lg bg-primary/10 text-primary';
  });
});

document.getElementById('gen-btn')!.addEventListener('click', () => {
  const byteCount = selectedBits / 8;
  const bytes = new Uint8Array(byteCount);
  crypto.getRandomValues(bytes);
  const fmt = (document.getElementById('gen-format') as HTMLSelectElement).value;
  let out = '';
  if (fmt === 'hex') {
    out = Array.from(bytes).map(b => b.toString(16).padStart(2,'0')).join('');
  } else if (fmt === 'base64') {
    out = btoa(String.fromCharCode(...bytes));
  } else {
    out = btoa(String.fromCharCode(...bytes)).replace(/\+/g,'-').replace(/\//g,'_').replace(/=/g,'');
  }
  (document.getElementById('gen-output') as HTMLInputElement).value = out;
});

document.getElementById('copy-gen')!.addEventListener('click', () => {
  const val = (document.getElementById('gen-output') as HTMLInputElement).value;
  if (val) navigator.clipboard.writeText(val);
});

// Init bit selection highlight
(document.querySelector('[data-bits="256"]') as HTMLElement)?.click();
</script>
