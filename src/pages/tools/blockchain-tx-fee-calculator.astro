---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "How are Ethereum gas fees calculated?", answer: "Since EIP-1559, Ethereum uses: Fee = gas_used × (base_fee + priority_fee). Base fee is burned by the protocol and adjusts automatically based on block fullness. Priority fee (tip) goes to validators. Max fee is the cap you're willing to pay. Actual fee = gas_used × min(max_fee, base_fee + priority_fee)." },
  { question: "What is gas limit vs gas used?", answer: "Gas limit is the maximum gas you allow for the transaction. Gas used is the actual amount consumed. You're only charged for gas used. ETH transfers use 21,000 gas. ERC-20 transfers use ~65,000. Complex DeFi interactions can use 200,000–500,000+." },
  { question: "Why are L2 fees so much cheaper?", answer: "Layer 2 networks (Arbitrum, Optimism, Base, Polygon) batch many transactions and post compressed data to Ethereum. Your transaction pays a small L2 execution cost plus a fractional share of the L1 data posting cost. This is typically 10-100x cheaper than mainnet." },
  { question: "What is MEV and how does it affect fees?", answer: "MEV (Maximal Extractable Value) is profit validators can make by reordering, including, or excluding transactions. During high activity, bots bid up priority fees to front-run profitable trades. If you're not doing time-sensitive DeFi, you can use a low priority fee and wait for inclusion." },
];

const chains = [
  { id: 'eth', name: 'Ethereum', symbol: 'ETH', usd: 3000, gasUnit: 'Gwei', defaultGas: 20, defaultPriority: 2 },
  { id: 'arb', name: 'Arbitrum One', symbol: 'ETH', usd: 3000, gasUnit: 'Gwei', defaultGas: 0.1, defaultPriority: 0.01 },
  { id: 'op', name: 'Optimism', symbol: 'ETH', usd: 3000, gasUnit: 'Gwei', defaultGas: 0.05, defaultPriority: 0.001 },
  { id: 'base', name: 'Base', symbol: 'ETH', usd: 3000, gasUnit: 'Gwei', defaultGas: 0.05, defaultPriority: 0.001 },
  { id: 'poly', name: 'Polygon PoS', symbol: 'MATIC', usd: 0.8, gasUnit: 'Gwei', defaultGas: 100, defaultPriority: 30 },
  { id: 'bsc', name: 'BNB Chain', symbol: 'BNB', usd: 400, gasUnit: 'Gwei', defaultGas: 3, defaultPriority: 1 },
  { id: 'avax', name: 'Avalanche C-Chain', symbol: 'AVAX', usd: 35, gasUnit: 'nAVAX', defaultGas: 25, defaultPriority: 2 },
  { id: 'sol', name: 'Solana', symbol: 'SOL', usd: 150, gasUnit: 'microlamports', defaultGas: 5000, defaultPriority: 0 },
];
---

<BaseLayout
  title="Blockchain Transaction Fee Calculator — ETH, L2, Polygon, BSC, Solana"
  description="Calculate transaction fees across Ethereum, Arbitrum, Optimism, Base, Polygon, BSC, Avalanche, and Solana. Input gas price, gas limit, and token price for exact cost in USD."
  tool="Blockchain Fee Calculator, Ethereum Gas Calculator, L2 Fee Estimator, Transaction Cost Calculator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Blockchain Transaction Fee Calculator</h1>
  <p class="text-text-muted mb-4">Estimate transaction fees across 8 chains. Compare costs for simple transfers, ERC-20 swaps, and complex DeFi interactions.</p>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
    <!-- Config -->
    <div class="space-y-4">
      <div class="bg-bg-card border border-border rounded-xl p-5 space-y-3">
        <h2 class="text-base font-semibold">Transaction Type</h2>
        <select id="tx-type" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="21000">ETH Transfer (21,000 gas)</option>
          <option value="65000">ERC-20 Transfer (~65,000 gas)</option>
          <option value="150000">Uniswap Swap (~150,000 gas)</option>
          <option value="250000">Complex DeFi (~250,000 gas)</option>
          <option value="500000">NFT Mint (~500,000 gas)</option>
          <option value="custom">Custom gas limit</option>
        </select>
        <div id="custom-gas-row" class="hidden">
          <label class="block text-xs font-medium mb-1">Custom Gas Limit</label>
          <input id="custom-gas" type="number" value="100000" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5 space-y-3">
        <h2 class="text-base font-semibold">Token Prices (USD)</h2>
        <div class="space-y-2 text-sm">
          <div class="flex items-center gap-2">
            <span class="w-16 text-text-muted">ETH</span>
            <span class="text-text-muted">$</span>
            <input id="price-eth" type="number" value="3000" class="flex-1 bg-bg border border-border rounded px-2 py-1 text-sm focus:outline-none focus:border-primary" />
          </div>
          <div class="flex items-center gap-2">
            <span class="w-16 text-text-muted">MATIC</span>
            <span class="text-text-muted">$</span>
            <input id="price-matic" type="number" value="0.80" step="0.01" class="flex-1 bg-bg border border-border rounded px-2 py-1 text-sm focus:outline-none focus:border-primary" />
          </div>
          <div class="flex items-center gap-2">
            <span class="w-16 text-text-muted">BNB</span>
            <span class="text-text-muted">$</span>
            <input id="price-bnb" type="number" value="400" class="flex-1 bg-bg border border-border rounded px-2 py-1 text-sm focus:outline-none focus:border-primary" />
          </div>
          <div class="flex items-center gap-2">
            <span class="w-16 text-text-muted">AVAX</span>
            <span class="text-text-muted">$</span>
            <input id="price-avax" type="number" value="35" class="flex-1 bg-bg border border-border rounded px-2 py-1 text-sm focus:outline-none focus:border-primary" />
          </div>
          <div class="flex items-center gap-2">
            <span class="w-16 text-text-muted">SOL</span>
            <span class="text-text-muted">$</span>
            <input id="price-sol" type="number" value="150" class="flex-1 bg-bg border border-border rounded px-2 py-1 text-sm focus:outline-none focus:border-primary" />
          </div>
        </div>
      </div>
    </div>

    <!-- Results table -->
    <div class="lg:col-span-2">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold mb-4">Fee Comparison</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-left text-xs text-text-muted border-b border-border">
                <th class="pb-2 font-medium">Chain</th>
                <th class="pb-2 font-medium text-right">Base Fee</th>
                <th class="pb-2 font-medium text-right">Priority</th>
                <th class="pb-2 font-medium text-right">Fee (native)</th>
                <th class="pb-2 font-medium text-right">Fee (USD)</th>
              </tr>
            </thead>
            <tbody id="fee-table" class="divide-y divide-border/50">
            </tbody>
          </table>
        </div>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5 mt-4">
        <h2 class="text-sm font-semibold mb-3">Customize Gas Prices (Gwei)</h2>
        <div id="gas-inputs" class="grid grid-cols-2 gap-3"></div>
      </div>
    </div>
  </div>

  <AdUnit slot="in-content" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Blockchain Transaction Fee Calculator" relatedTags={['blockchain', 'ethereum', 'web3', 'defi', 'smart-contracts']} />
</BaseLayout>

<script>
interface ChainConfig {
  id: string; name: string; symbol: string; priceKey: string;
  gasBase: number; gasPriority: number; gasUnit: string; solana: boolean;
}

const chains: ChainConfig[] = [
  { id: 'eth', name: 'Ethereum', symbol: 'ETH', priceKey: 'eth', gasBase: 20, gasPriority: 2, gasUnit: 'Gwei', solana: false },
  { id: 'arb', name: 'Arbitrum One', symbol: 'ETH', priceKey: 'eth', gasBase: 0.1, gasPriority: 0.01, gasUnit: 'Gwei', solana: false },
  { id: 'op', name: 'Optimism', symbol: 'ETH', priceKey: 'eth', gasBase: 0.05, gasPriority: 0.001, gasUnit: 'Gwei', solana: false },
  { id: 'base', name: 'Base', symbol: 'ETH', priceKey: 'eth', gasBase: 0.05, gasPriority: 0.001, gasUnit: 'Gwei', solana: false },
  { id: 'poly', name: 'Polygon PoS', symbol: 'MATIC', priceKey: 'matic', gasBase: 100, gasPriority: 30, gasUnit: 'Gwei', solana: false },
  { id: 'bsc', name: 'BNB Chain', symbol: 'BNB', priceKey: 'bnb', gasBase: 3, gasPriority: 1, gasUnit: 'Gwei', solana: false },
  { id: 'avax', name: 'Avalanche C-Chain', symbol: 'AVAX', priceKey: 'avax', gasBase: 25, gasPriority: 2, gasUnit: 'Gwei', solana: false },
  { id: 'sol', name: 'Solana', symbol: 'SOL', priceKey: 'sol', gasBase: 5000, gasPriority: 0, gasUnit: 'μlamports', solana: true },
];

const gasState: Record<string, { base: number; priority: number }> = {};
chains.forEach(c => { gasState[c.id] = { base: c.gasBase, priority: c.gasPriority }; });

function getGasLimit(): number {
  const sel = (document.getElementById('tx-type') as HTMLSelectElement).value;
  if (sel === 'custom') return parseInt((document.getElementById('custom-gas') as HTMLInputElement).value) || 100000;
  return parseInt(sel);
}

function getPrice(key: string): number {
  return parseFloat((document.getElementById('price-' + key) as HTMLInputElement)?.value) || 0;
}

function calcFee(chain: ChainConfig): { native: number; usd: number } {
  const g = gasState[chain.id];
  const gasLimit = getGasLimit();
  const price = getPrice(chain.priceKey);

  if (chain.solana) {
    // Solana: base fee = 5000 lamports per signature. priority = microlamports per CU * CU budget
    // Simplified: total lamports
    const lamports = g.base + g.priority;
    const sol = lamports / 1e9;
    return { native: sol, usd: sol * price };
  }

  const gweiFee = (g.base + g.priority) * gasLimit;
  const nativeFee = gweiFee / 1e9; // Gwei to ETH/MATIC/BNB/AVAX
  return { native: nativeFee, usd: nativeFee * price };
}

function renderTable() {
  const tbody = document.getElementById('fee-table')!;
  const rows = chains.map(c => {
    const g = gasState[c.id];
    const { native, usd } = calcFee(c);
    const nativeStr = native < 0.0001 ? native.toExponential(3) : native.toFixed(6);
    const usdStr = usd < 0.01 ? '$' + usd.toExponential(3) : '$' + usd.toFixed(4);
    const usdClass = usd < 0.05 ? 'text-green-400' : usd < 1 ? 'text-yellow-400' : 'text-red-400';
    return `<tr>
      <td class="py-2 font-medium">${c.name}</td>
      <td class="py-2 text-right font-mono text-text-muted text-xs">${g.base} ${c.gasUnit}</td>
      <td class="py-2 text-right font-mono text-text-muted text-xs">${g.priority} ${c.gasUnit}</td>
      <td class="py-2 text-right font-mono text-xs">${nativeStr} ${c.symbol}</td>
      <td class="py-2 text-right font-mono font-semibold ${usdClass}">${usdStr}</td>
    </tr>`;
  }).join('');
  tbody.innerHTML = rows;
}

function renderGasInputs() {
  const container = document.getElementById('gas-inputs')!;
  container.innerHTML = chains.map(c => `
    <div>
      <label class="block text-xs text-text-muted mb-1">${c.name} base (${c.gasUnit})</label>
      <input type="number" data-chain="${c.id}" data-field="base" value="${gasState[c.id].base}"
        class="gas-input w-full bg-bg border border-border rounded px-2 py-1 text-xs font-mono focus:outline-none focus:border-primary" />
    </div>
  `).join('');

  container.querySelectorAll('.gas-input').forEach(el => {
    el.addEventListener('input', (e) => {
      const t = e.target as HTMLInputElement;
      gasState[t.dataset.chain!][t.dataset.field as 'base'|'priority'] = parseFloat(t.value) || 0;
      renderTable();
    });
  });
}

document.getElementById('tx-type')!.addEventListener('change', (e) => {
  const sel = (e.target as HTMLSelectElement).value;
  document.getElementById('custom-gas-row')!.classList.toggle('hidden', sel !== 'custom');
  renderTable();
});
document.getElementById('custom-gas')?.addEventListener('input', renderTable);
['eth','matic','bnb','avax','sol'].forEach(id => {
  document.getElementById('price-' + id)?.addEventListener('input', renderTable);
});

renderGasInputs();
renderTable();
</script>
