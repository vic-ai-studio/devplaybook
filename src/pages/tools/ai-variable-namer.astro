---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AiVariableNamer from '../../components/AiVariableNamer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="AI Variable Namer — Naming Suggestions for Variables, Functions & Classes"
  description="Describe what your variable or function should represent and get naming suggestions in camelCase, snake_case, PascalCase, and more. Supports variables, functions, constants, classes, and CSS selectors."
  tool="AI Variable Namer, Variable Name Generator, Function Name Generator, Naming Conventions"
>
  <h1 class="text-3xl font-bold mb-2">AI Variable Namer</h1>
  <p class="text-text-muted mb-8">
    Describe what your identifier should represent in plain English and get naming suggestions across all common conventions —
    <code class="font-mono text-sm bg-bg-card px-1 rounded">camelCase</code>,
    <code class="font-mono text-sm bg-bg-card px-1 rounded">snake_case</code>,
    <code class="font-mono text-sm bg-bg-card px-1 rounded">PascalCase</code>,
    <code class="font-mono text-sm bg-bg-card px-1 rounded">SCREAMING_SNAKE</code>, and more.
    Runs entirely in your browser — no API needed.
  </p>
  <AiVariableNamer client:load />
  <ToolPageCta currentTool="AI Variable Namer" relatedTags={['ai', 'naming', 'developer-tools', 'productivity']} />
</BaseLayout>
