---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TailwindColorGenerator from '../../components/TailwindColorGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a Tailwind color scale?", answer: "Tailwind CSS uses a numbered scale from 50 (lightest) to 950 (darkest) for each color. For example, blue-100 is very light blue and blue-900 is very dark. This scale gives you 11 shades per color, providing enough range for backgrounds, borders, text, and hover states without naming individual colors." },
  { question: "How does this tool generate the color scale?", answer: "The generator converts your base color to HSL (Hue, Saturation, Lightness), then creates 11 shades by adjusting the Lightness value while keeping the Hue constant. This approach matches how Tailwind's built-in palettes are designed, ensuring harmonious transitions between shades." },
  { question: "What shade should I use as my primary brand color?", answer: "Use shade 500 or 600 as your primary action color (buttons, links) — it's typically the most saturated and visually distinctive. Use 50–200 for light backgrounds and hover states, 700–900 for dark text or pressed states. Your input base color maps closest to shade 500." },
  { question: "How do I add a custom color to my tailwind.config.js?", answer: "Copy the generated tailwind.config.js snippet and paste it into your tailwind.config.js under theme.extend.colors. This preserves all built-in Tailwind colors and adds your custom palette alongside them. You can then use classes like bg-primary-500, text-primary-900, etc." },
  { question: "What are CSS Custom Properties and when should I use them?", answer: "CSS Custom Properties (variables) like --color-primary-500 let you use your color scale without Tailwind's build step. Useful for non-Tailwind projects, email templates, or when you need to change themes dynamically at runtime with JavaScript. Reference them in CSS as var(--color-primary-500)." },
  { question: "Can I use this with Tailwind v4?", answer: "Yes. Tailwind v4 uses CSS-first configuration with @theme directive. Copy the CSS variables output, then reference them in your @theme block: --color-primary-500: #3b82f6; This approach also works with Tailwind v3 by pasting into the extend.colors config." },
];
---

<BaseLayout
  title="Tailwind Color Generator — Free Online Tool | Custom Color Scale"
  description="Pick any base color and generate a full Tailwind-compatible color scale (50–950). Preview all 11 shades, copy as tailwind.config.js snippet or CSS custom properties. Runs 100% in your browser."
  tool="Tailwind Color Generator, Tailwind Color Palette, Custom Tailwind Colors, Tailwind Config Generator, Color Scale Generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Tailwind Color Generator",
    "url": "https://devplaybook.cc/tools/tailwind-color-generator",
    "description": "Generate full Tailwind CSS color scales (50–950) from any base color. Preview swatches, copy tailwind.config.js or CSS variables. Runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Tailwind Color Generator</h1>
  <p class="text-text-muted mb-4">Pick a base color and instantly generate a full Tailwind-compatible color scale (50–950). Preview all 11 shades, then copy the <code class="font-mono bg-surface px-1 rounded text-sm">tailwind.config.js</code> snippet or CSS custom properties. Works with Tailwind v3 and v4. Everything runs in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <TailwindColorGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Tailwind Color Generator" relatedTags={['css', 'tailwind', 'design', 'colors', 'frontend']} />
</BaseLayout>
