---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CronValidator from '../../components/CronValidator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "How do I read a cron expression?",
    answer: "A standard cron expression has 5 fields separated by spaces: minute (0–59), hour (0–23), day of month (1–31), month (1–12), day of week (0–6, where 0 is Sunday). For example, '0 9 * * 1-5' means 'at 9:00 AM, every weekday (Monday through Friday)'."
  },
  {
    question: "What do the special characters *, /, -, and , mean in cron?",
    answer: "* means 'every value' (wildcard). / is a step value — */5 in the minute field means every 5 minutes. - defines a range — 1-5 in day-of-week means Monday through Friday. , is a list separator — 1,15 in the day-of-month field means the 1st and 15th of every month."
  },
  {
    question: "What is the difference between cron's day-of-month and day-of-week?",
    answer: "If you specify a value in both day-of-month and day-of-week (not using *), most cron implementations treat them as a union — the job runs if either condition matches. If only one is specified (the other is *), only that condition is used. Use ? in one field when you intend to restrict by only the other."
  },
  {
    question: "How do I schedule a job every 15 minutes?",
    answer: "Use */15 * * * * — the */15 step in the minute field means the job runs at minute 0, 15, 30, and 45 of every hour. This pattern works in standard cron, GitHub Actions (on.schedule), Kubernetes CronJobs, and AWS EventBridge."
  },
  {
    question: "What is the difference between cron and POSIX cron format?",
    answer: "Standard 5-field cron is POSIX-compatible. Some tools like Quartz Scheduler (Java), AWS CloudWatch Events, and some node schedulers add a 6th field for seconds (0–59) at the start, or a 7th field for year. This validator uses the standard 5-field format compatible with Unix cron, crontab, GitHub Actions, and Kubernetes."
  },
  {
    question: "Why does my cron job run at the wrong time?",
    answer: "The most common causes are timezone mismatches (cron runs in the server's local timezone, not yours), off-by-one in day-of-week (0=Sunday vs 1=Sunday depending on the system), and DST transitions that skip or repeat an hour. Always confirm the timezone of your cron daemon and consider using UTC for reliability."
  },
];
---

<BaseLayout
  title="Cron Expression Validator — Build, Validate & Preview Next 10 Run Times"
  description="Validate cron expressions with field-by-field breakdown, human-readable description, and next 10 scheduled run times. Includes preset schedule builder for common patterns. Free, runs in your browser."
  tool="Cron Expression Validator, Cron schedule builder, Cron checker, Cron next run times, Cron expression tester, Crontab validator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Cron Expression Validator",
    "url": "https://devplaybook.cc/tools/cron-expression-validator",
    "description": "Validate cron expressions with field-by-field breakdown, human-readable description, and preview of the next 10 scheduled run times. Includes preset schedule builder.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Cron Expression Validator</h1>
  <p class="text-text-muted mb-4">
    Enter a cron expression to validate it instantly. See a plain-English description, field-by-field breakdown (minute / hour / day / month / weekday), and preview the next 10 scheduled run times.
    Includes preset builder for the most common schedules — hourly, daily, weekdays, monthly, and more.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Next 10 run times preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Human-readable description</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Field-by-field breakdown</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Common schedule presets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <CronValidator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Cron Expression Validator" relatedTags={['automation', 'devops', 'ci-cd', 'bash', 'scheduling', 'kubernetes']} />
</BaseLayout>
