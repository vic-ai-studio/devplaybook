---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArgoCDAppConfigGenerator from '../../components/ArgoCDAppConfigGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is an ArgoCD Application CRD?",
    answer: "An ArgoCD Application is a Custom Resource Definition (CRD) that tells ArgoCD where to find your Kubernetes manifests (a Git repo or Helm chart) and where to deploy them (a cluster + namespace). It's the core unit of GitOps in ArgoCD — each Application tracks one source and one destination, reconciling continuously so the cluster always matches your Git state."
  },
  {
    question: "What is the difference between automated sync and manual sync?",
    answer: "With manual sync, ArgoCD detects drift between your Git source and cluster state but does nothing until you click 'Sync' in the UI or run 'argocd app sync'. With automated sync, ArgoCD automatically applies changes whenever it detects a new commit or config drift. Automated sync is ideal for CD pipelines, while manual sync is preferred when you want human approval before applying changes to production."
  },
  {
    question: "What does self-heal do and when should I enable it?",
    answer: "Self-heal makes ArgoCD automatically revert manual changes made directly to the cluster (e.g., someone ran 'kubectl edit deployment' in prod). Without self-heal, automated sync only triggers on new Git commits — drift from manual edits goes uncorrected. Enable self-heal in production environments where you want Git to be the absolute source of truth and prevent configuration drift caused by ad-hoc changes."
  },
  {
    question: "What is the risk of enabling prune in automated sync?",
    answer: "Prune tells ArgoCD to delete Kubernetes resources that exist in the cluster but are no longer in the Git repository. This is powerful but dangerous — if you accidentally delete a manifest from Git, ArgoCD will delete the live resource immediately. It's recommended to enable prune only after thorough testing, and consider pairing it with the 'PrunePropagationPolicy=foreground' sync option so dependent resources are deleted in the correct order."
  },
  {
    question: "What are sync waves and how do they control deployment order?",
    answer: "Sync waves let you control the order in which resources are applied during a sync. Add the annotation 'argocd.argoproj.io/sync-wave: \"N\"' to your Kubernetes manifests. Resources with lower wave numbers are applied first. ArgoCD waits for all resources in one wave to become healthy before moving to the next. Use waves to ensure CRDs are applied before custom resources, or databases before applications."
  },
  {
    question: "What is the App of Apps pattern in ArgoCD?",
    answer: "App of Apps is a pattern where a single ArgoCD Application points to a Git directory containing other ArgoCD Application manifests. The root app bootstraps all child apps, giving you a single entry point to manage your entire cluster's GitOps state. It's the recommended approach for multi-service environments — commit a new Application YAML to Git and ArgoCD automatically discovers and deploys it without any manual argocd CLI commands."
  },
];
---

<BaseLayout
  title="ArgoCD App Config Generator — Application CRD YAML Builder"
  description="Generate ArgoCD Application configuration YAML visually. Configure source repo, destination cluster, sync policy, automated sync, self-heal, and retry logic. Free, runs in your browser."
  tool="argocd app generator, ArgoCD Application YAML, argocd config builder, GitOps application config, argocd sync policy"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "ArgoCD App Config Generator",
    "description": "Generate ArgoCD Application CRD YAML visually. Configure source repo, destination cluster, sync policy, automated sync, self-heal, and retry logic.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "url": "https://devplaybook.cc/tools/argocd-app-config-generator"
  })} />

  <h1 class="text-3xl font-bold mb-2">ArgoCD App Config Generator</h1>
  <p class="text-text-muted mb-6">
    Build a production-ready <code class="bg-surface px-1 rounded text-sm">Application</code> CRD for ArgoCD without memorizing the YAML spec.
    Configure your Git or Helm source, destination cluster, sync policy, and retry logic — then copy the manifest or the equivalent CLI command.
  </p>

  <div class="flex flex-wrap gap-2 mb-8">
    <span class="text-xs bg-surface border border-border rounded-full px-3 py-1 text-text-muted">Application CRD v1alpha1</span>
    <span class="text-xs bg-surface border border-border rounded-full px-3 py-1 text-text-muted">Git + Helm sources</span>
    <span class="text-xs bg-surface border border-border rounded-full px-3 py-1 text-text-muted">Automated sync + self-heal</span>
    <span class="text-xs bg-surface border border-border rounded-full px-3 py-1 text-text-muted">argocd CLI output</span>
  </div>

  <ArgoCDAppConfigGenerator client:only="preact" />

  <FaqSection faq={faq} />

  <ToolPageCta
    currentTool="ArgoCD App Config Generator"
    relatedTags={['argocd', 'gitops', 'kubernetes', 'devops', 'cd', 'infrastructure']}
  />
</BaseLayout>
