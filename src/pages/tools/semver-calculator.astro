---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SemverChecker from '../../components/SemverChecker.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is semantic versioning (semver)?", answer: "Semantic versioning (semver) is a version numbering convention using the MAJOR.MINOR.PATCH format. Increment MAJOR for breaking changes, MINOR for new backwards-compatible features, and PATCH for backwards-compatible bug fixes. For example, going from 1.2.3 to 2.0.0 signals a breaking change." },
  { question: "What does ^ mean in a semver range?", answer: "The caret (^) means 'compatible with' — it allows changes that do not modify the left-most non-zero version component. ^1.2.3 allows >=1.2.3 <2.0.0, so any 1.x.x version works. ^0.2.3 allows >=0.2.3 <0.3.0 because 0.x is the left-most non-zero digit." },
  { question: "What does ~ mean in a semver range?", answer: "The tilde (~) means 'approximately equivalent' — it allows patch-level changes if a minor version is specified. ~1.2.3 allows >=1.2.3 <1.3.0 (same minor, any patch). ~1.2 allows >=1.2.0 <1.3.0. This is more restrictive than ^ because it locks the minor version." },
  { question: "When should I bump major vs minor vs patch?", answer: "Bump MAJOR when you make incompatible API changes (removing a function, changing method signatures). Bump MINOR when you add backwards-compatible functionality (new methods, new optional parameters). Bump PATCH for backwards-compatible bug fixes only. Pre-release versions (1.0.0-alpha.1) and build metadata (1.0.0+build.1) are also part of the semver spec." },
  { question: "How do I check if a version satisfies a npm package range?", answer: "Use the Range Check tab. Enter the installed version (e.g. 1.5.3) and the constraint from package.json (e.g. ^1.0.0 or ~1.2.0 or >=1.0.0 <2.0.0). The calculator shows whether the version satisfies the range and explains why or why not." },
];
---

<BaseLayout
  title="Semver Calculator — Compare Versions & Check Range Compatibility"
  description="Calculate and compare semantic versions (semver). Check if a version satisfies a range constraint (^, ~, >=), bump major/minor/patch, and parse version components. Free, browser-based."
  tool="Semver Calculator, Semantic Version Calculator, NPM Version Range Checker, Version Bump Calculator, Semver Range Validator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Semver Calculator",
    "url": "https://devplaybook.cc/tools/semver-calculator",
    "description": "Calculate semantic version comparisons, check range constraints, and compute version bumps. Supports ^, ~, >=, <=, >, < range operators.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Semver Calculator</h1>
  <p class="text-text-muted mb-4">
    Parse, compare, and calculate semantic versions. Check if a version satisfies a range constraint
    (<code class="font-mono text-sm">^</code>, <code class="font-mono text-sm">~</code>, <code class="font-mono text-sm">>=</code>),
    bump major/minor/patch, and break down version components. Follows the semver 2.0.0 spec.
  </p>
  <div class="flex items-center gap-3 mb-8 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Compare two versions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Range constraint checker</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Major/minor/patch bumper</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <SemverChecker client:only="preact" />

  <AffiliateSection />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Semver Calculator" relatedTags={['semver', 'npm', 'versioning', 'devops', 'package']} />
</BaseLayout>
