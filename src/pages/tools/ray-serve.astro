            <th class="text-left pb-2 pr-4">BentoML</th>
            <th class="text-left pb-2 pr-4">Triton</th>
            <th class="text-left pb-2">TorchServe</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border text-text-muted">
          <tr><td class="py-2 pr-4 font-medium text-text">Distributed cluster</td><td class="py-2 pr-4 text-green-500">Native (Ray)</td><td class="py-2 pr-4">K8s-based</td><td class="py-2 pr-4">K8s-based</td><td class="py-2">K8s-based</td></tr>
          <tr><td class="py-2 pr-4 font-medium text-text">Pipeline DAG</td><td class="py-2 pr-4 text-green-500">Deployment graph</td><td class="py-2 pr-4">Runner composition</td><td class="py-2 pr-4">Ensemble models</td><td class="py-2">No</td></tr>
          <tr><td class="py-2 pr-4 font-medium text-text">Autoscaling</td><td class="py-2 pr-4 text-green-500">Request-queue based</td><td class="py-2 pr-4">KEDA-based</td><td class="py-2 pr-4">Manual replicas</td><td class="py-2">Manual replicas</td></tr>
          <tr><td class="py-2 pr-4 font-medium text-text">LLM streaming</td><td class="py-2 pr-4 text-green-500">Generator streaming</td><td class="py-2 pr-4 text-green-500">SSE streaming</td><td class="py-2 pr-4">gRPC streaming</td><td class="py-2">Limited</td></tr>
          <tr><td class="py-2 pr-4 font-medium text-text">GPU fractional alloc</td><td class="py-2 pr-4 text-green-500">Yes (0.25, 0.5)</td><td class="py-2 pr-4">No</td><td class="py-2 pr-4">No</td><td class="py-2">No</td></tr>
          <tr><td class="py-2 pr-4 font-medium text-text">Raw GPU throughput</td><td class="py-2 pr-4">Good</td><td class="py-2 pr-4">Good</td><td class="py-2 pr-4 text-green-500">Best</td><td class="py-2">Good</td></tr>
          <tr><td class="py-2 pr-4 font-medium text-text">Best for</td><td class="py-2 pr-4">Distributed, Ray users</td><td class="py-2 pr-4">Packaging &amp; deploy</td><td class="py-2 pr-4">Max throughput</td><td class="py-2">PyTorch simple serving</td></tr>
        </tbody>
      </table>
    </div>
