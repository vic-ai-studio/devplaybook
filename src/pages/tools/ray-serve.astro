>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"Ray Serve: Scalable ML Model Serving & Online Inference","url":"https://devplaybook.cc/tools/ray-serve","description":"Complete guide to Ray Serve for scalable ML model serving, deployment graphs, GPU allocation, and production online inference."})} />

  <h1 class="text-3xl font-bold mb-2">Ray Serve: Scalable ML Model Serving &amp; Online Inference</h1>
  <p class="text-text-muted mb-6">Ray Serve is a scalable model serving library built on Ray. Deploy ML models as HTTP endpoints with automatic autoscaling, GPU-aware scheduling, and composable multi-model pipelines — on a single machine or a distributed cluster.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Automatic replica autoscaling</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multi-model pipeline DAG</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Fractional GPU allocation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> LLM streaming support</span>
  </div>

  <ToolPageCta />

  <!-- Basic deployment -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-xl font-semibold mb-3">Basic Deployment with @serve.deployment</h2>
    <p class="text-sm text-text-muted mb-3">Install with <code class="bg-bg border border-border rounded px-1 text-xs">pip install "ray[serve]"</code>. A Deployment is a class bound to an HTTP route:</p>
    <pre class="bg-bg border border-border rounded-lg p-4 text-xs overflow-x-auto mb-3"><code>import ray
from ray import serve
from starlette.requests import Request
import torch

ray.init()
serve.start()

@serve.deployment(
    num_replicas=2,
    ray_actor_options=&#123;"num_cpus": 1, "num_gpus": 0.5&#125;,
    autoscaling_config=&#123;
        "min_replicas": 1,
        "max_replicas": 8,
        "target_num_ongoing_requests_per_replica": 5,
    &#125;,
)
@serve.ingress(app)  # FastAPI app as HTTP ingress
class SentimentClassifier:
    def __init__(self):
        from transformers import pipeline
        self.pipe = pipeline(
            "sentiment-analysis",
            model="distilbert-base-uncased-finetuned-sst-2-english",
            device=0,  # GPU 0
        )

    async def classify(self, request: Request) -> dict:
        body = await request.json()
        result = self.pipe(body["text"])[0]
        return &#123;"label": result["label"], "score": result["score"]&#125;

# Deploy and get a handle
handle = serve.run(SentimentClassifier.bind())
result = ray.get(handle.classify.remote("Ray Serve is amazing!"))
print(result)  # &#123;"label": "POSITIVE", "score": 0.9998&#125;</code></pre>
  </div>

  <!-- Pipeline DAG -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-xl font-semibold mb-3">Model Composition: Pipeline DAG</h2>
    <p class="text-sm text-text-muted mb-3">Chain deployments into a pipeline where each stage processes the output of the previous:</p>
    <pre class="bg-bg border border-border rounded-lg p-4 text-xs overflow-x-auto mb-3"><code>from ray import serve
import numpy as np

@serve.deployment(ray_actor_options=&#123;"num_cpus": 1&#125;)
class TextPreprocessor:
    def preprocess(self, text: str) -> list:
        # Tokenize, clean, normalize
        return text.lower().split()

@serve.deployment(ray_actor_options=&#123;"num_gpus": 1&#125;)
class EmbeddingModel:
    def __init__(self):
        from sentence_transformers import SentenceTransformer
        self.model = SentenceTransformer("all-MiniLM-L6-v2")

    def embed(self, tokens: list) -> list:
        return self.model.encode([" ".join(tokens)]).tolist()

@serve.deployment
class PipelineOrchestrator:
    def __init__(self, preprocessor, embedder):
        self.preprocessor = preprocessor
        self.embedder = embedder

    async def predict(self, text: str) -> dict:
        # Chained async calls across deployments
        tokens = await self.preprocessor.preprocess.remote(text)
        embedding = await self.embedder.embed.remote(tokens)
        return &#123;"embedding": embedding, "dims": len(embedding)&#125;

# Bind deployments into a graph
preprocessor = TextPreprocessor.bind()
embedder = EmbeddingModel.bind()
pipeline = PipelineOrchestrator.bind(preprocessor, embedder)
serve.run(pipeline)</code></pre>
  </div>

  <!-- Autoscaling config -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-xl font-semibold mb-3">Production Autoscaling Configuration</h2>
    <p class="text-sm text-text-muted mb-3">Configure autoscaling via YAML for production deployments:</p>
    <pre class="bg-bg border border-border rounded-lg p-4 text-xs overflow-x-auto mb-3"><code># serve_config.yaml
applications:
  - name: llm-inference
    route_prefix: /v1
    import_path: app:LLMService
    deployments:
      - name: LLMService
        num_replicas: "auto"           # enable autoscaling
        max_ongoing_requests: 10
        ray_actor_options:
          num_cpus: 2
          num_gpus: 1
          memory: 8000000000           # 8 GB RAM reservation
        autoscaling_config:
          min_replicas: 1
          max_replicas: 4
          target_num_ongoing_requests_per_replica: 3
          upscale_delay_s: 5           # fast scale-up
          downscale_delay_s: 60        # slow scale-down

# Deploy with:
# serve deploy serve_config.yaml
# Monitor with:
# serve status</code></pre>
  </div>

