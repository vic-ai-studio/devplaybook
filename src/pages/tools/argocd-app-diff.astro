---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArgoCdAppDiff from '../../components/ArgoCdAppDiff.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is an ArgoCD App Diff?",
    answer: "An ArgoCD App Diff compares the desired state (defined in Git) against the live state (currently running in the Kubernetes cluster). When these states differ, ArgoCD reports the application as 'OutOfSync'. Understanding the diff helps you identify what changed, whether it was an intentional update or unexpected drift, and what ArgoCD will do on the next sync."
  },
  {
    question: "How do I get the live ArgoCD Application YAML?",
    answer: "Run: kubectl get application <app-name> -n argocd -o yaml. This outputs the full Application resource including its current status, syncPolicy, and source configuration. You can also use the ArgoCD CLI: argocd app get <app-name> -o yaml."
  },
  {
    question: "What is the difference between OutOfSync and configuration drift?",
    answer: "OutOfSync means the cluster state doesn't match what Git defines. Configuration drift specifically refers to manual changes made directly to Kubernetes resources (kubectl edit, kubectl patch) that bypass Git. ArgoCD with selfHeal: true automatically reverts drift. Without selfHeal, drift persists until a manual sync. Use this diff tool to identify both types of discrepancies."
  },
  {
    question: "What does targetRevision control?",
    answer: "targetRevision tells ArgoCD which Git ref (branch, tag, or commit SHA) to use as the source of truth. 'HEAD' tracks the tip of the default branch and syncs with every commit. A pinned tag like 'v1.2.0' ensures only explicit releases are deployed. For production environments, always pin to a specific tag or SHA — never use HEAD, which can cause unexpected automatic deployments."
  },
  {
    question: "What is the difference between prune: true and selfHeal: true?",
    answer: "prune: true tells ArgoCD to delete Kubernetes resources that exist in the cluster but are no longer defined in Git (orphaned resources). selfHeal: true tells ArgoCD to revert any manual changes made directly to the cluster that differ from Git. Both are components of automated sync — without prune, deleted Git resources remain running; without selfHeal, direct kubectl changes persist."
  },
  {
    question: "Should I use automated sync in production?",
    answer: "It depends on your team's release process. Automated sync with prune and selfHeal provides the strongest GitOps guarantees — Git is always the single source of truth. However, it can cause unexpected changes if a bad commit is pushed. Many teams use automated sync for dev/staging and manual sync for production, combined with branch protection and required reviews before merging to the production branch."
  },
];
---

<BaseLayout
  title="ArgoCD App Diff — Compare Desired vs Live Application State"
  description="Compare ArgoCD Application manifests to find differences between desired Git state and live cluster state. Identify config drift, sync policy changes, and version mismatches. Runs in your browser."
  tool="argocd diff, gitops diff, kubernetes manifest diff, argocd compare, argocd app diff online"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "ArgoCD App Diff",
    "url": "https://devplaybook.cc/tools/argocd-app-diff",
    "description": "Compare ArgoCD Application manifests between desired Git state and live cluster state. Find configuration drift, version mismatches, and sync policy differences. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">ArgoCD App Diff</h1>
  <p class="text-text-muted mb-4">
    Compare ArgoCD Application manifests between your Git (desired) state and live cluster state.
    Identify configuration drift, version mismatches, sync policy differences, and GitOps inconsistencies
    without needing access to ArgoCD UI or CLI.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Field-level diff view</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Raw line diff</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Drift explanation</span>
  </div>
  <ArgoCdAppDiff client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="ArgoCD App Diff" relatedTags={['devops', 'kubernetes', 'cloud', 'infrastructure', 'gitops', 'argocd', 'yaml']} />
</BaseLayout>
