---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';
import ToolsDiscovery from '../../components/ToolsDiscovery';

const categories = [
  {
    name: 'API & Network',
    icon: '🌐',
    tools: [
      { name: 'HTTP API Tester', desc: 'Send REST API requests directly in your browser. Custom headers, JSON body, response inspection, and request history. No install needed.', href: '/tools/api-tester', icon: '🚀' },
      { name: 'API Request Builder', desc: 'Build and test HTTP requests visually. Generate cURL commands.', href: '/tools/api-request-builder', icon: '🔗' },
      { name: 'API Response Mock Generator', desc: 'Generate realistic mock API responses with custom status codes, headers, and JSON body. Quick templates for 200, 401, 404, 429, 500 and more.', href: '/tools/api-response-mock', icon: '📨' },
      { name: 'HTTP Mock Response Builder', desc: 'Build mock HTTP responses for testing. Set status code, headers, and body — export as curl command, Jest fetch mock, or MSW v2 handler.', href: '/tools/http-mock-builder', icon: '🧪' },
      { name: 'API Response Formatter & Analyzer', desc: 'Paste any raw HTTP response to format JSON body, inspect headers, and analyze status codes, CORS, caching, and rate-limit signals instantly.', href: '/tools/api-response-formatter', icon: '🔬' },
      { name: 'API Rate Limit Calculator', desc: 'Convert rate limits across req/s, req/min, req/hr. Calculate delay per worker, burst refill time, and get a Node.js throttle snippet.', href: '/tools/api-rate-limit-calculator', icon: '⏱️' },
      { name: 'Rate Limit Calculator', desc: 'Enter RPM limit and burst size to get token bucket config, per-worker request delay, refill time, and code snippets for Express.js, Nginx, and Cloudflare Workers.', href: '/tools/rate-limit-calculator', icon: '🪣' },
      { name: 'HTTP Status Codes', desc: 'Complete reference for all HTTP status codes with descriptions, use cases, and searchable index.', href: '/tools/http-status-codes', icon: '📡' },
      { name: 'HTTP Status Code Explorer', desc: 'Browse all HTTP status codes with descriptions, use cases, and common response headers. Filter by 1xx–5xx category, search by code or keyword, and copy ready-to-use examples.', href: '/tools/http-status-explorer', icon: '🔎' },
      { name: 'HTTP Status Code Lookup', desc: 'Search and filter all HTTP status codes (1xx–5xx). Shows category, description, common causes, usage guidance, and curl examples. Click any code for instant details.', href: '/tools/http-status-code-lookup', icon: '🔍' },
      { name: 'HTTP Methods Reference', desc: 'Complete reference for GET, POST, PUT, PATCH, DELETE, HEAD, OPTIONS and more. Includes safe/idempotent/cacheable properties and real-world examples.', href: '/tools/http-methods', icon: '🌐' },
      { name: 'HTTP Headers Inspector', desc: 'Inspect HTTP response headers for any URL. See security headers, cache directives, CORS settings, and more — with plain-English explanations for every header.', href: '/tools/http-headers-inspector', icon: '📡' },
      { name: 'CORS Tester', desc: 'Test CORS headers for any URL. Analyze preflight responses and diagnose cross-origin errors.', href: '/tools/cors-tester', icon: '🌐' },
      { name: 'DNS Lookup Tool', desc: 'Look up A, AAAA, CNAME, MX, TXT, NS, SOA, and PTR records for any domain using the Cloudflare DNS-over-HTTPS API. Fully client-side.', href: '/tools/dns-lookup', icon: '🌍' },
      { name: 'SSL Certificate Checker', desc: 'Check SSL/TLS certificate validity, expiry date, issuer, and Subject Alternative Names for any domain. Queries Certificate Transparency logs via crt.sh.', href: '/tools/ssl-checker', icon: '🔒' },
      { name: 'IP Geolocation Lookup', desc: 'Look up the geographic location of any IPv4 or IPv6 address — city, country, timezone, ISP, and coordinates. Or detect your own IP.', href: '/tools/ip-geolocation', icon: '🌍' },
      { name: 'Leaflet Map Config Builder', desc: 'Generate Leaflet.js map initialization code. Choose tile provider (OpenStreetMap, CartoDB, Mapbox), set center/zoom, add marker/circle/polygon layers. CDN and npm ES module output. React cleanup included.', href: '/tools/leaflet-map-config-builder', icon: '🗺️' },
      { name: 'Timezone Converter', desc: 'Convert a time across multiple timezones at once. Live world clock, pick source timezone, add destinations, and copy results. No signup needed.', href: '/tools/timezone-converter', icon: '🕐' },
      { name: 'HTTP Code Snippet Generator', desc: 'Generate HTTP request snippets for cURL, fetch, Axios, Python requests, Go, and PHP. Configure method, URL, headers, and body. One-click copy.', href: '/tools/http-snippet-generator', icon: '📡' },
      { name: 'curl Command Builder', desc: 'Build curl commands visually. Set HTTP method, URL, query params, headers, auth (Bearer, Basic, API key), request body, and options. Copy the ready-to-run command instantly.', href: '/tools/curl-builder', icon: '⌨️' },
      { name: 'WebSocket Tester', desc: 'Connect to any WebSocket server, send and receive messages in real time, and inspect the message log with timestamps and byte sizes. No install needed.', href: '/tools/websocket-tester', icon: '🔌' },
      { name: 'API Latency Heatmap', desc: 'Visualize API endpoint response times as a color-coded heatmap. Green <100ms, yellow 100–300ms, orange 300–500ms, red >500ms. Shows avg, P95, and max latency. Runs in browser.', href: '/tools/api-latency-heatmap', icon: '🌡️' },
      { name: 'GraphQL Playground', desc: 'Execute GraphQL queries and mutations against any public API. Split editor with Query/Variables tabs, syntax-highlighted JSON response, and response time tracking. No install needed.', href: '/tools/graphql-playground', icon: '⬡' },
      { name: 'GraphQL Query Builder', desc: 'Build GraphQL queries visually from your schema SDL. Select root fields, pick sub-fields, add arguments, and generate query/mutation/subscription strings instantly. Supports nested types.', href: '/tools/graphql-query-builder', icon: '⬡' },
      { name: 'HAR File Analyzer', desc: 'Upload or paste a HAR file to analyze HTTP request performance. See slowest requests, largest responses, error count, and timing waterfall. Filter by status code or content type.', href: '/tools/har-file-analyzer', icon: '📊' },
      { name: 'OpenAPI Validator', desc: 'Paste your OpenAPI 3.x spec (YAML or JSON) to validate structure, find missing required fields, detect duplicate paths, check operationIds, and get errors/warnings with path references.', href: '/tools/openapi-validator', icon: '✅' },
      { name: 'OpenAPI Code Generator', desc: 'Build an OpenAPI 3.0 YAML spec visually. Define API info, add endpoints with methods and parameters, export YAML or JSON — ready for Swagger UI, Redoc, and code generation tools.', href: '/tools/openapi-code-generator', icon: '📝' },
      { name: 'GraphQL Schema Generator', desc: 'Build a GraphQL SDL schema visually. Add types, fields, scalars, enums — auto-generates Query/Mutation stubs. Copy-ready for Apollo Server, GraphQL Yoga, and more.', href: '/tools/graphql-schema-generator', icon: '⬡' },
      { name: 'Webhook Request Inspector', desc: 'Paste a raw HTTP request or JSON webhook payload to inspect headers, body, method, and generate a curl command. Interactive JSON tree view and auth header detection.', href: '/tools/webhook-request-inspector', icon: '🔗' },
      { name: 'SMTP Server Tester', desc: 'Validate your SMTP server configuration — host, port (25/465/587), TLS/STARTTLS, and credentials. Detects common issues like blocked ports and missing auth. Client-side simulation.', href: '/tools/smtp-tester', icon: '📧' },
    ],
  },
  {
    name: 'JSON & Data',
    icon: '📋',
    tools: [
      { name: 'YAML Validator & Formatter', desc: 'Validate YAML syntax and see errors by line number. Format with consistent indentation or convert YAML to JSON. Supports mappings, sequences, and nested structures.', href: '/tools/yaml-validator', icon: '📄' },
      { name: 'YAML Diff Viewer', desc: 'Compare two YAML files side-by-side with highlighted differences. Three views: side-by-side, unified git-style diff, and semantic key-level comparison. Perfect for Kubernetes manifests and config files.', href: '/tools/yaml-diff-viewer', icon: '🔀' },
      { name: 'JSON Schema Generator', desc: 'Paste JSON and auto-generate a JSON Schema. Supports Draft-07 and 2020-12. Detects formats like date-time, email, uuid, and uri. Runs in your browser.', href: '/tools/json-schema-generator', icon: '📐' },
      { name: 'JSON Formatter & Validator', desc: 'Format, beautify, and validate JSON instantly. Choose indent size, minify to one line, or copy the result. Syntax errors highlighted live.', href: '/tools/json-formatter', icon: '📋' },
      { name: 'JSON Formatter Pro', desc: 'Advanced JSON formatter with JSONPath querying, minify/beautify, schema validation, and diff comparison. Handle complex JSON structures with ease.', href: '/tools/json-formatter-pro', icon: '🔍' },
      { name: 'JSON Path Finder', desc: 'Paste JSON and click any value to instantly get its JSONPath and jq path. Visual tree explorer with copy-to-clipboard. Great for debugging API responses.', href: '/tools/json-path-finder', icon: '🎯' },
      { name: 'JSON Diff', desc: 'Compare two JSON objects side-by-side. Highlight added, removed, and unchanged lines instantly. Perfect for debugging API responses.', href: '/tools/json-diff-viewer', icon: '📊' },
      { name: 'JSON to CSV Converter', desc: 'Convert a JSON array to CSV format. Choose comma, tab, semicolon, or pipe delimiter. Download as .csv file. All processing client-side.', href: '/tools/json-to-csv', icon: '📋' },
      { name: 'CSV to JSON Converter', desc: 'Convert CSV data to JSON. Supports comma, tab, semicolon, and pipe delimiters. Output array of objects (with headers) or array of arrays. Download as .json.', href: '/tools/csv-json-transformer', icon: '🔄' },
      { name: 'CSV Editor', desc: 'Edit CSV files directly in your browser. Inline cell editing, sort columns, filter rows, add/delete rows and columns, and export to CSV, TSV, or JSON.', href: '/tools/csv-editor', icon: '✏️' },
      { name: 'CSV Viewer', desc: 'Paste CSV data and instantly preview it as a formatted table. Supports multiple delimiters, quoted fields, and toggleable header rows.', href: '/tools/csv-viewer', icon: '📊' },
      { name: 'XML Formatter & Validator', desc: 'Format messy XML with clean indentation or minify it to reduce size. Invalid XML is caught instantly with a clear error message.', href: '/tools/xml-formatter', icon: '📄' },
      { name: 'XML to JSON Converter', desc: 'Paste XML and get clean JSON output. Attributes become @-prefixed keys, repeated elements become arrays, and booleans/numbers are auto-cast. Free, runs in your browser.', href: '/tools/xml-to-json-converter', icon: '🔄' },
      { name: 'JSON ↔ YAML Converter', desc: 'Convert between JSON and YAML formats. Handles nested objects, arrays, and all scalar types. Useful for config file migration.', href: '/tools/json-to-yaml', icon: '🔁' },
      { name: 'TOML Validator', desc: 'Validate TOML syntax and see the parsed result as JSON. Useful for Cargo.toml, pyproject.toml, and other TOML config files.', href: '/tools/toml-validator', icon: '✅' },
      { name: 'Avro Schema Generator', desc: 'Generate Apache Avro schema definitions from JSON sample data. Detects nested records, arrays, nullable fields, and logical types (timestamp-millis, date). Useful for Kafka + Schema Registry.', href: '/tools/avro-schema-generator', icon: '📊' },
      { name: 'gRPC Proto Validator', desc: 'Validate Protocol Buffer .proto files for syntax and compatibility. Catches missing syntax declarations, duplicate field numbers, naming convention violations, and proto3 rules. Runs in browser.', href: '/tools/grpc-proto-validator', icon: '⚙️' },
      { name: 'JSON to TypeScript Interface', desc: 'Paste JSON and get TypeScript interfaces instantly. Handles nested objects, arrays, optional fields, and custom root names. Runs entirely in your browser.', href: '/tools/json-to-typescript', icon: '🔷' },
      { name: 'SQL Formatter & Beautifier', desc: 'Format and indent SQL queries automatically. Uppercase keywords, align clauses, and minify SQL to one line. Supports SELECT, JOIN, CTEs, and more.', href: '/tools/sql-formatter', icon: '🗄️' },
      { name: 'Kysely Query Builder', desc: 'Build type-safe SQL queries with Kysely TypeScript query builder. Select columns with aggregates, add WHERE/JOIN/ORDER BY, configure pagination, and get Kysely code + TypeScript Database interface. Runs in browser.', href: '/tools/kysely-query-builder', icon: '🔷' },
      { name: 'JSON Schema to Zod', desc: 'Convert JSON Schema (Draft-07, 2020-12) to Zod TypeScript validation code. Supports objects, arrays, enums, required/optional fields, min/max constraints, and inferred TypeScript types.', href: '/tools/json-schema-to-zod', icon: '🛡️' },
      { name: 'Prisma Schema Builder', desc: 'Build schema.prisma files visually. Add models and fields, configure types, @id, @default, @unique, @updatedAt. Generates copy-ready Prisma ORM schema for PostgreSQL, MySQL, SQLite, and more.', href: '/tools/prisma-schema-builder', icon: '🗄️' },
      { name: 'Neon DB Connection String Builder', desc: 'Build Neon serverless PostgreSQL connection strings for pooled and direct modes. Generates .env values, Prisma datasource, @neondatabase/serverless, and Drizzle ORM setup code.', href: '/tools/neon-db-connection-builder', icon: '🐘' },
      { name: 'MySQL Query Explainer', desc: 'Paste any MySQL query and get a plain-English explanation of each execution step plus optimization hints. Covers SELECT, JOIN, GROUP BY, UPDATE, DELETE, and CREATE TABLE.', href: '/tools/mysql-query-explainer', icon: '🔍' },
      { name: 'PostgreSQL EXPLAIN Analyzer', desc: 'Paste EXPLAIN or EXPLAIN ANALYZE output and get a visual cost breakdown per node, optimization suggestions, and actual vs estimated row counts.', href: '/tools/postgres-explain-analyzer', icon: '🐘' },
      { name: 'TOML to JSON Converter', desc: 'Convert TOML to JSON or JSON to TOML instantly. Supports sections, key-value pairs, arrays, booleans, and all scalar types. Bidirectional. Runs in your browser.', href: '/tools/toml-to-json', icon: '🔄' },
      { name: 'HTML Formatter & Minifier', desc: 'Format messy HTML with proper indentation or minify to reduce file size. Handles void elements, pre/script blocks, and nested tags. Runs in your browser.', href: '/tools/html-formatter', icon: '🌐' },
      { name: 'CSS Formatter & Minifier', desc: 'Beautify CSS with consistent indentation or minify to strip whitespace. Supports @media, @keyframes, nested rules. Shows compression savings.', href: '/tools/css-formatter', icon: '🎨' },
      { name: 'CSS Minifier', desc: 'Strip comments, whitespace, and redundant characters from CSS. Shows original size, minified size, and exact % saved. Runs entirely in your browser.', href: '/tools/css-minifier', icon: '⚡' },
      { name: 'JavaScript Formatter & Minifier', desc: 'Format JS for readability or minify to reduce bundle size. Preserves strings and template literals. Works with JS, TS, and JSX.', href: '/tools/js-formatter', icon: '💛' },
      { name: 'TypeScript to JavaScript', desc: 'Strip TypeScript type annotations, interfaces, generics, enums, access modifiers, and decorators to get clean JavaScript. Runs in your browser.', href: '/tools/typescript-to-js', icon: '🔷' },
    ],
  },
  {
    name: 'Security & Auth',
    icon: '🔒',
    tools: [
      { name: 'JWT Decoder', desc: 'Decode JWT tokens — inspect header, payload, and claims. Check expiry and iat/sub/iss fields instantly.', href: '/tools/jwt-decoder', icon: '🔐' },
      { name: 'JWT Builder', desc: 'Create HS256 JWT tokens with custom header, payload claims, and secret key. Color-coded output. Great for testing auth flows.', href: '/tools/jwt-builder', icon: '🔑' },
      { name: 'RSA Key Generator', desc: 'Generate RSA-OAEP key pairs (2048 or 4096-bit) in your browser. Export public and private keys in PEM format. Uses Web Crypto API.', href: '/tools/rsa-key-generator', icon: '🔐' },
      { name: 'HTTP Security Headers Generator', desc: 'Toggle and configure HTTP security headers (HSTS, CSP, X-Frame-Options). Generates ready-to-use nginx and Apache configuration snippets.', href: '/tools/http-security-headers', icon: '🛡️' },
      { name: 'Hash Generator', desc: 'Generate MD5, SHA-1, SHA-256, and SHA-512 hashes instantly. All hashing runs in your browser — nothing sent to any server.', href: '/tools/hash-generator', icon: '🔒' },
      { name: 'Password Generator', desc: 'Generate cryptographically secure random passwords with custom length and character sets. No data sent to any server.', href: '/tools/password-generator', icon: '🔑' },
      { name: 'Password Strength Checker', desc: 'Test any password instantly — strength score, entropy estimate, criteria checklist, and improvement tips. Nothing is stored or sent anywhere.', href: '/tools/password-strength-checker', icon: '🛡️' },
      { name: 'htpasswd Generator', desc: 'Generate .htpasswd entries for Apache and Nginx Basic Auth. Supports bcrypt (apr1), SHA-1, and plain formats. All hashing runs in your browser — no data sent to servers.', href: '/tools/htpasswd-generator', icon: '🔐' },
      { name: 'Passphrase Generator', desc: 'Generate diceware-style passphrases with crypto.getRandomValues(). Configure word count (3–8), separator, capitalization, and number suffix. Shows entropy strength. Fully client-side.', href: '/tools/passphrase-generator', icon: '🔑' },
      { name: 'HMAC Generator', desc: 'Generate HMAC-SHA256, HMAC-SHA512, and HMAC-SHA1 hashes. Enter message and secret key, choose hex or base64 output. Uses Web Crypto API — runs entirely in your browser. For JWT signing, webhook verification.', href: '/tools/hmac-generator', icon: '🔐' },
      { name: 'CSP Header Builder', desc: 'Build Content Security Policy headers visually. Toggle directives (default-src, script-src, img-src, etc.), set allowed sources, and get nginx/Apache config snippets. Defends against XSS attacks.', href: '/tools/csp-header-builder', icon: '🛡️' },
      { name: 'Bcrypt Hash Generator', desc: 'Generate bcrypt password hashes with a configurable cost factor (4–14) and verify passwords against existing hashes. Shows full hash breakdown (version, cost, salt). Runs in your browser using bcryptjs.', href: '/tools/bcrypt-hash-generator', icon: '🔒' },
      { name: 'Clerk Auth Config Generator', desc: 'Generate Clerk authentication configuration for Next.js, Remix, and Astro. Configure protected routes, social OAuth providers (Google, GitHub, Discord), middleware.ts, and .env variables. Copy-ready output.', href: '/tools/clerk-auth-config-generator', icon: '🔑' },
      { name: 'AES Encryptor / Decryptor', desc: 'Encrypt and decrypt text using AES-256-GCM in your browser. Key derived via PBKDF2-SHA256 with 100,000 iterations. No data sent to any server — fully client-side using Web Crypto API.', href: '/tools/aes-encryptor', icon: '🔐' },
      { name: 'Certificate Decoder', desc: 'Decode X.509 / SSL / TLS certificates from PEM format. View subject, issuer, SANs, expiry (color-coded), key usage, and SHA-256 fingerprint. Runs entirely in your browser — no uploads.', href: '/tools/certificate-decoder', icon: '📜' },
      { name: 'TOTP Generator', desc: 'Generate TOTP one-time codes from a Base32 secret. Compatible with Google Authenticator, Authy, and all RFC 6238 apps. Live countdown timer and next-code preview. Secret stays in your browser.', href: '/tools/totp-generator', icon: '🔐' },
    ],
  },
  {
    name: 'Code & DevOps',
    icon: '💻',
    tools: [
      { name: 'TypeScript Playground', desc: 'Write TypeScript and instantly see compiled JavaScript output. Strip interfaces, generics, enums, and decorators. Share code via URL. No install needed.', href: '/tools/typescript-playground', icon: '🛝' },
      { name: 'Regex Playground', desc: 'Write and test regular expressions in real-time with match highlighting, flag toggles (g, i, m, s), and group display. Instant feedback as you type. No install needed.', href: '/tools/regex-playground', icon: '🔍' },
      { name: 'Regex Tester', desc: 'Test your regular expressions against multiple strings at once. Batch validate with pass/fail assertions and match highlights. Free, no signup.', href: '/tools/regex-tester', icon: '✅' },
      { name: 'Regex Tester Pro', desc: 'Advanced regex tester with real-time match highlighting, multiple language flavors (JS/Python/Ruby), 6 presets, and capture group display. Visual regex debugging.', href: '/tools/regex-tester-pro', icon: '⚡' },
      { name: 'Cron Expression Builder', desc: 'Build cron expressions visually with common presets. See next run times in plain English. Copy for GitHub Actions, Linux crontab, AWS EventBridge. Free, no signup.', href: '/tools/cron-builder', icon: '🔧' },
      { name: 'Cron Expression Generator', desc: 'Build and validate cron expressions visually. See next 5 run times in plain English with common presets for hourly, daily, and weekly jobs.', href: '/tools/cron-generator', icon: '⏰' },
      { name: 'Cron Expression Validator', desc: 'Validate cron expressions and see a human-readable schedule with the next 5 run times. Field-by-field breakdown and common presets included.', href: '/tools/cron-validator', icon: '✅' },
      { name: 'Cron Expression Parser', desc: 'Parse and decode cron expressions instantly. Plain-English description, field-by-field breakdown, and next 5 scheduled run times. Works with Linux, GitHub Actions, and AWS EventBridge.', href: '/tools/cron-expression-parser', icon: '🔍' },
      { name: 'Cron Expression Visualizer', desc: 'Visualize cron expressions with a plain-English description, field-by-field breakdown, and next 5 scheduled run times preview. Common presets included. Free, runs in your browser.', href: '/tools/cron-expression-visualizer', icon: '👁️' },
      { name: 'Cron Expression Tester', desc: 'Test any cron expression and see the next 10 scheduled run times with a plain-English explanation of each field. Works with Linux cron, GitHub Actions, and POSIX schedules.', href: '/tools/cron-expression-tester', icon: '🧪' },
      { name: 'Git Command Builder', desc: 'Build Git commands step by step: clone, branch, merge, rebase, reset, stash, and more. Shows all relevant flags with descriptions. Copy the final command instantly.', href: '/tools/git-command-builder', icon: '🌿' },
      { name: 'Git Commit Message Generator', desc: 'Generate clean commit messages following the Conventional Commits spec. Pick type, scope, description, body, and issue references. Copy in one click.', href: '/tools/git-commit-generator', icon: '💬' },
      { name: 'AI Commit Message Generator', desc: 'Describe your change in plain English and get commit message suggestions — Conventional Commits, imperative, and bracket-style. Auto-detects type and scope.', href: '/tools/ai-commit-generator', icon: '✨' },
      { name: 'Dockerfile Generator', desc: 'Interactive wizard to generate production-ready Dockerfiles for Node.js, Python, Go, Java, and Rust. Multi-stage builds, port config, custom layers.', href: '/tools/dockerfile-generator', icon: '🐋' },
      { name: 'Docker Compose Generator', desc: 'Generate docker-compose.yml visually. Add services, configure ports, volumes, environment variables, and depends_on. Templates for web + db, full-stack, and microservices setups.', href: '/tools/docker-compose-generator', icon: '🐳' },
      { name: 'Docker Compose Validator', desc: 'Paste your docker-compose.yml and validate it instantly. Catches missing image/build, broken depends_on, hardcoded secrets, :latest tags, and YAML errors.', href: '/tools/docker-compose-validator', icon: '🔍' },
      { name: 'Docker ENV File Parser', desc: 'Parse .env and docker-compose env_file format. See key-value table, detect duplicate keys and missing values, export as docker run --env flags or shell export statements.', href: '/tools/docker-env-parser', icon: '🔧' },
      { name: 'Semver Checker', desc: 'Parse, compare, and check semantic version ranges. Verify ^, ~, >= constraints, compare two versions, or calculate the next major/minor/patch bump.', href: '/tools/semver-checker', icon: '🔢' },
      { name: 'Semantic Version Bumper', desc: 'Enter a semver and click major, minor, patch, or pre-release to get the next version. Live preview of all bump types, bump history, configurable pre-release tags, and one-click copy.', href: '/tools/semantic-version-bumper', icon: '🔖' },
      { name: '.env File Parser', desc: 'Parse and validate .env files. Detect syntax errors, browse variables, generate a keys-only template, and export shell export commands. Fully client-side.', href: '/tools/env-parser', icon: '⚙️' },
      { name: '.gitignore Generator', desc: 'Generate .gitignore files for Node.js, Python, React, Java, Go, Rust, .NET, and Docker. Select extras like VS Code, macOS, Windows. Download instantly.', href: '/tools/gitignore-generator', icon: '🚫' },
      { name: 'package.json Validator & Audit', desc: 'Paste your package.json to validate syntax and get an audit score. Detects wildcard versions, missing fields, misplaced dependencies, and more.', href: '/tools/packagejson-validator', icon: '📦' },
      { name: 'Code Snippet Share', desc: 'Paste code and get a shareable URL instantly. Encoded in the URL — no server, no sign-up, no expiry. Share on Slack, Discord, or email.', href: '/tools/code-snippet-share', icon: '🔗' },
      { name: 'GitHub Actions Generator', desc: 'Generate GitHub Actions YAML workflows instantly. Choose triggers, runtime (Node.js, Python, Go, Rust), and jobs (test, lint, build, Docker). Copy-ready CI/CD YAML with best practices.', href: '/tools/github-actions-generator', icon: '🔄' },
      { name: 'Kubernetes Resource Calculator', desc: 'Calculate CPU/memory requests and limits for Kubernetes pods. Configure millicores, Mi/Gi memory, HPA replicas, and get ready-to-paste Pod spec YAML with resource quotas.', href: '/tools/kubernetes-resource-calculator', icon: '☸️' },
      { name: 'Terraform Variable Generator', desc: 'Generate Terraform variable declarations and tfvars files. Define variable name, type, default, and description — get complete variables.tf and terraform.tfvars output.', href: '/tools/terraform-variable-generator', icon: '🏗️' },
      { name: 'AWS IAM Policy Builder', desc: 'Build AWS IAM policies visually. Pick Effect, select Actions from S3/EC2/Lambda/DynamoDB service groups, enter Resource ARNs, and get a complete JSON policy document.', href: '/tools/aws-iam-policy-builder', icon: '🔐' },
      { name: 'CI Pipeline Linter', desc: 'Validate GitHub Actions and GitLab CI YAML pipelines. Detects hardcoded secrets, mutable :latest image tags, deprecated syntax, and security best practices. Free, runs in browser.', href: '/tools/ci-pipeline-linter', icon: '🔎' },
      { name: 'GitHub Actions Workflow Validator', desc: 'Validate your GitHub Actions workflow YAML. Checks structure, trigger events, job dependencies, action version pins, hardcoded secrets, and cron expressions. Runs in browser.', href: '/tools/github-actions-workflow-validator', icon: '✅' },
      { name: 'Ansible Playbook Linter', desc: 'Validate Ansible YAML playbooks for syntax and best practice issues. Catches hardcoded secrets, non-idempotent modules, missing task names, ignore_errors usage, and more. Runs in browser.', href: '/tools/ansible-playbook-linter', icon: '📋' },
      { name: 'RabbitMQ Config Generator', desc: 'Generate RabbitMQ exchange, queue, and binding configurations in JSON or YAML. Configure exchange types (direct/topic/fanout/headers), TTL, max-length, dead letter exchanges, and routing keys.', href: '/tools/rabbitmq-config-generator', icon: '🐇' },
      { name: 'Vault Policy Generator', desc: 'Generate HashiCorp Vault HCL policy files visually. Configure paths, capabilities (create/read/update/delete/list/sudo/deny), with presets for read-only, app service accounts, PKI, and DB credentials.', href: '/tools/vault-policy-generator', icon: '🔐' },
