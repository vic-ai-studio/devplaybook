---
import BaseLayout from '../../layouts/BaseLayout.astro';

const categories = [
  {
    name: 'API & Network',
    icon: '🌐',
    tools: [
      { name: 'HTTP API Tester', desc: 'Send REST API requests directly in your browser. Custom headers, JSON body, response inspection, and request history. No install needed.', href: '/tools/api-tester', icon: '🚀' },
      { name: 'API Request Builder', desc: 'Build and test HTTP requests visually. Generate cURL commands.', href: '/tools/api-request-builder', icon: '🔗' },
      { name: 'API Response Mock Generator', desc: 'Generate realistic mock API responses with custom status codes, headers, and JSON body. Quick templates for 200, 401, 404, 429, 500 and more.', href: '/tools/api-response-mock', icon: '📨' },
      { name: 'API Response Formatter & Analyzer', desc: 'Paste any raw HTTP response to format JSON body, inspect headers, and analyze status codes, CORS, caching, and rate-limit signals instantly.', href: '/tools/api-response-formatter', icon: '🔬' },
      { name: 'API Rate Limit Calculator', desc: 'Convert rate limits across req/s, req/min, req/hr. Calculate delay per worker, burst refill time, and get a Node.js throttle snippet.', href: '/tools/api-rate-limit-calculator', icon: '⏱️' },
      { name: 'HTTP Status Codes', desc: 'Complete reference for all HTTP status codes with descriptions, use cases, and searchable index.', href: '/tools/http-status-codes', icon: '📡' },
      { name: 'HTTP Methods Reference', desc: 'Complete reference for GET, POST, PUT, PATCH, DELETE, HEAD, OPTIONS and more. Includes safe/idempotent/cacheable properties and real-world examples.', href: '/tools/http-methods', icon: '🌐' },
      { name: 'HTTP Headers Inspector', desc: 'Inspect HTTP response headers for any URL. See security headers, cache directives, CORS settings, and more — with plain-English explanations for every header.', href: '/tools/http-headers-inspector', icon: '📡' },
      { name: 'CORS Tester', desc: 'Test CORS headers for any URL. Analyze preflight responses and diagnose cross-origin errors.', href: '/tools/cors-tester', icon: '🌐' },
      { name: 'DNS Lookup Tool', desc: 'Look up A, AAAA, CNAME, MX, TXT, NS, SOA, and PTR records for any domain using the Cloudflare DNS-over-HTTPS API. Fully client-side.', href: '/tools/dns-lookup', icon: '🌍' },
      { name: 'IP Geolocation Lookup', desc: 'Look up the geographic location of any IPv4 or IPv6 address — city, country, timezone, ISP, and coordinates. Or detect your own IP.', href: '/tools/ip-geolocation', icon: '🌍' },
      { name: 'Timezone Converter', desc: 'Convert a time across multiple timezones at once. Live world clock, pick source timezone, add destinations, and copy results. No signup needed.', href: '/tools/timezone-converter', icon: '🕐' },
      { name: 'HTTP Code Snippet Generator', desc: 'Generate HTTP request snippets for cURL, fetch, Axios, Python requests, Go, and PHP. Configure method, URL, headers, and body. One-click copy.', href: '/tools/http-snippet-generator', icon: '📡' },
    ],
  },
  {
    name: 'JSON & Data',
    icon: '📋',
    tools: [
      { name: 'JSON Schema Generator', desc: 'Paste JSON and auto-generate a JSON Schema. Supports Draft-07 and 2020-12. Detects formats like date-time, email, uuid, and uri. Runs in your browser.', href: '/tools/json-schema-generator', icon: '📐' },
      { name: 'JSON Formatter & Validator', desc: 'Format, beautify, and validate JSON instantly. Choose indent size, minify to one line, or copy the result. Syntax errors highlighted live.', href: '/tools/json-formatter', icon: '📋' },
      { name: 'JSON Diff Viewer', desc: 'Compare two JSON objects side-by-side. Highlight added, removed, and unchanged lines instantly.', href: '/tools/json-diff-viewer', icon: '📊' },
      { name: 'JSON to CSV Converter', desc: 'Convert a JSON array to CSV format. Choose comma, tab, semicolon, or pipe delimiter. Download as .csv file. All processing client-side.', href: '/tools/json-to-csv', icon: '📋' },
      { name: 'JSON to TypeScript Interface', desc: 'Paste JSON and get TypeScript interfaces instantly. Handles nested objects, arrays, optional fields, and custom root names. Runs entirely in your browser.', href: '/tools/json-to-typescript', icon: '🔷' },
      { name: 'SQL Formatter & Beautifier', desc: 'Format and indent SQL queries automatically. Uppercase keywords, align clauses, and minify SQL to one line. Supports SELECT, JOIN, CTEs, and more.', href: '/tools/sql-formatter', icon: '🗄️' },
      { name: 'HTML Formatter & Minifier', desc: 'Format messy HTML with proper indentation or minify to reduce file size. Handles void elements, pre/script blocks, and nested tags. Runs in your browser.', href: '/tools/html-formatter', icon: '🌐' },
      { name: 'CSS Formatter & Minifier', desc: 'Beautify CSS with consistent indentation or minify to strip whitespace. Supports @media, @keyframes, nested rules. Shows compression savings.', href: '/tools/css-formatter', icon: '🎨' },
      { name: 'JavaScript Formatter & Minifier', desc: 'Format JS for readability or minify to reduce bundle size. Preserves strings and template literals. Works with JS, TS, and JSX.', href: '/tools/js-formatter', icon: '💛' },
      { name: 'TypeScript to JavaScript', desc: 'Strip TypeScript type annotations, interfaces, generics, enums, access modifiers, and decorators to get clean JavaScript. Runs in your browser.', href: '/tools/typescript-to-js', icon: '🔷' },
    ],
  },
  {
    name: 'Security & Auth',
    icon: '🔒',
    tools: [
      { name: 'JWT Decoder', desc: 'Decode JWT tokens — inspect header, payload, and claims. Check expiry and iat/sub/iss fields instantly.', href: '/tools/jwt-decoder', icon: '🔐' },
      { name: 'Hash Generator', desc: 'Generate MD5, SHA-1, SHA-256, and SHA-512 hashes instantly. All hashing runs in your browser — nothing sent to any server.', href: '/tools/hash-generator', icon: '🔒' },
      { name: 'Password Generator', desc: 'Generate cryptographically secure random passwords with custom length and character sets. No data sent to any server.', href: '/tools/password-generator', icon: '🔑' },
      { name: 'UUID Generator', desc: 'Generate UUID v1, v4, and v5 in bulk. Multiple formats: standard, uppercase, no-hyphens, braces. One-click copy.', href: '/tools/uuid-generator', icon: '🔑' },
    ],
  },
  {
    name: 'Code & DevOps',
    icon: '💻',
    tools: [
      { name: 'Regex Playground', desc: 'Write, test, and debug regular expressions in real-time with match highlighting.', href: '/tools/regex-playground', icon: '🔍' },
      { name: 'Regex Tester', desc: 'Test your regular expressions against multiple strings at once. Batch validate with pass/fail assertions and match highlights. Free, no signup.', href: '/tools/regex-tester', icon: '✅' },
      { name: 'Cron Expression Generator', desc: 'Build and validate cron expressions visually. See next 5 run times in plain English with common presets for hourly, daily, and weekly jobs.', href: '/tools/cron-generator', icon: '⏰' },
      { name: 'Cron Expression Validator', desc: 'Validate cron expressions and see a human-readable schedule with the next 5 run times. Field-by-field breakdown and common presets included.', href: '/tools/cron-validator', icon: '✅' },
      { name: 'Git Command Builder', desc: 'Build complex Git commands step by step with all common options.', href: '/tools/git-command-builder', icon: '🌿' },
      { name: 'Git Commit Message Generator', desc: 'Generate clean commit messages following the Conventional Commits spec. Pick type, scope, description, body, and issue references. Copy in one click.', href: '/tools/git-commit-generator', icon: '💬' },
      { name: 'Docker Compose Generator', desc: 'Generate docker-compose.yml configurations visually with templates.', href: '/tools/docker-compose-generator', icon: '🐳' },
      { name: 'Semver Checker', desc: 'Parse, compare, and check semantic version ranges. Verify ^, ~, >= constraints, compare two versions, or calculate the next major/minor/patch bump.', href: '/tools/semver-checker', icon: '🔢' },
      { name: '.env File Parser', desc: 'Parse and validate .env files. Detect syntax errors, browse variables, generate a keys-only template, and export shell export commands. Fully client-side.', href: '/tools/env-parser', icon: '⚙️' },
    ],
  },
  {
    name: 'AI & Productivity',
    icon: '🤖',
    tools: [
      { name: 'AI Token Cost Calculator', desc: 'Estimate API costs for GPT-4o, Claude 3.5, Gemini 1.5, and more. Enter token counts, character count, or word count and get instant per-call and monthly projections.', href: '/tools/ai-token-calculator', icon: '🤖' },
      { name: 'Prompt Template Builder', desc: 'Build reusable AI prompt templates with {slot} variables. Fill values, preview the finished prompt, and export as JSON. Works with ChatGPT, Claude, and Gemini.', href: '/tools/prompt-template-builder', icon: '📋' },
      { name: 'Pomodoro Timer', desc: 'Focus timer using the Pomodoro Technique. 25/5/15-minute intervals, sound notifications, session counter. Works offline, no signup needed.', href: '/tools/pomodoro-timer', icon: '🍅' },
      { name: 'Countdown Timer', desc: 'Countdown by duration (5 min, 30 min, custom) or to a specific date and time. Great for meetings, deadlines, and sprints. Works offline.', href: '/tools/countdown-timer', icon: '⏳' },
    ],
  },
  {
    name: 'CSS & Design',
    icon: '🎨',
    tools: [
      { name: 'CSS Box Shadow Generator', desc: 'Build multi-layer CSS box-shadow values visually with live preview. Presets, inset, blur, spread, opacity, and one-click copy.', href: '/tools/box-shadow-generator', icon: '🎨' },
      { name: 'CSS Gradient Generator', desc: 'Build linear, radial, and conic CSS gradients visually. Add color stops, adjust angles, and copy the ready-to-use CSS instantly.', href: '/tools/css-gradient-generator', icon: '🌈' },
      { name: 'CSS Flexbox Visualizer', desc: 'Interactive flexbox playground. Configure container and item properties with a live preview and generated CSS.', href: '/tools/css-flexbox', icon: '🎨' },
      { name: 'CSS Grid Generator', desc: 'Build CSS Grid layouts visually. Set columns, rows, gaps, and alignment — click items to control placement. Copy generated CSS in one click.', href: '/tools/css-grid-generator', icon: '▦' },
      { name: 'CSS Unit Converter', desc: 'Convert between px, rem, em, vw, vh, pt, and % instantly. Configure base font size, viewport, and parent size for accurate relative unit calculations.', href: '/tools/css-unit-converter', icon: '📐' },
      { name: 'CSS Animation Generator', desc: 'Build CSS keyframe animations with live preview. 10 presets (fade, bounce, shake, spin), configure timing, easing, delay. Copy ready-to-use CSS.', href: '/tools/css-animation-generator', icon: '✨' },
      { name: 'Color Picker & Palette', desc: 'Pick a color and instantly get HEX, RGB, HSL values. WCAG contrast checker and 5-shade palette generator.', href: '/tools/color-picker', icon: '🎨' },
      { name: 'Color Palette Generator', desc: 'Generate full palettes from any hex color — Tailwind-style shades, complementary, triadic, analogous, and tetradic. Export as CSS custom properties.', href: '/tools/color-palette-generator', icon: '🌈' },
      { name: 'Color Contrast Checker', desc: 'Check foreground/background color contrast ratios against WCAG 2.1 AA and AAA standards. Instant pass/fail results with suggested fixes.', href: '/tools/color-contrast-checker', icon: '♿' },
      { name: 'Aspect Ratio Calculator', desc: 'Calculate simplified aspect ratios, scale dimensions proportionally, and find common screen sizes for any width/height pair. Includes CSS padding-top value.', href: '/tools/aspect-ratio', icon: '🖥️' },
      { name: 'CSS Specificity Calculator', desc: 'Calculate CSS selector specificity in (inline, ID, class, element) notation. Compare two selectors to see which wins the cascade. All logic runs in your browser.', href: '/tools/css-specificity', icon: '🎯' },
    ],
  },
  {
    name: 'Text & Encoding',
    icon: '🔤',
    tools: [
      { name: 'Base64 Encoder / Decoder', desc: 'Encode and decode Base64 strings online. Supports UTF-8 text, URL-safe encoding, and binary data. Runs in your browser.', href: '/tools/base64', icon: '🔤' },
      { name: 'URL Encoder / Decoder', desc: 'Encode text to percent-encoded URL format or decode %20 / %3D / %2F sequences back to readable text. Full URL mode supported.', href: '/tools/url-encoder', icon: '🔗' },
      { name: 'HTML Entity Encoder / Decoder', desc: 'Encode special characters to HTML entities (&lt; &gt; &amp;) or decode entities back to plain text. Supports 50+ named entities.', href: '/tools/html-entity-encoder', icon: '🏷️' },
      { name: 'String Case Converter', desc: 'Convert text between camelCase, PascalCase, snake_case, kebab-case, SCREAMING_SNAKE, Title Case, dot.case, and 5 more formats.', href: '/tools/string-case-converter', icon: '🔤' },
      { name: 'Markdown Previewer', desc: 'Write and preview Markdown in real-time. Supports GFM tables, task lists, and code blocks with syntax hints.', href: '/tools/markdown-preview', icon: '📝' },
      { name: 'Code Diff Viewer', desc: 'Compare two code snippets with unified or split side-by-side view. Highlights added/removed lines, shows change counts. Runs in your browser.', href: '/tools/code-diff', icon: '🔀' },
      { name: 'Text Diff Checker', desc: 'Compare two text blocks side-by-side with line-level diff highlighting. Lines added, removed, and unchanged at a glance.', href: '/tools/text-diff', icon: '📄' },
      { name: 'Word Counter', desc: 'Count words, characters, sentences, paragraphs, and lines. Get reading time estimate and top word frequency. Works on any text instantly.', href: '/tools/word-counter', icon: '📊' },
      { name: 'Line Sorter & Deduplicator', desc: 'Sort lines A–Z, by length, reverse, or shuffle. Remove duplicates, trim whitespace, and delete empty lines. Perfect for cleaning lists and configs.', href: '/tools/line-sorter', icon: '📑' },
      { name: 'Unicode Character Lookup', desc: 'Look up any Unicode character by typing it, U+XXXX code point, decimal, or HTML entity. Get UTF-8 bytes, UTF-16, HTML entities, CSS and JS escape sequences instantly.', href: '/tools/unicode-lookup', icon: '🔡' },
    ],
  },
  {
    name: 'Converters & Generators',
    icon: '⚙️',
    tools: [
      { name: 'Unix Timestamp Converter', desc: 'Convert between Unix timestamps and human-readable dates. Live clock, timezone support, and instant copy.', href: '/tools/unix-timestamp', icon: '⏱️' },
      { name: 'Number Base Converter', desc: 'Convert between binary, octal, decimal, and hexadecimal instantly. Enter any value in any base — all others update automatically.', href: '/tools/number-base-converter', icon: '🔢' },
      { name: 'UUID Generator', desc: 'Generate UUID v1, v4, and v5 in bulk. Multiple formats: standard, uppercase, no-hyphens, braces. One-click copy.', href: '/tools/uuid-generator', icon: '🔑' },
      { name: 'URL Slug Generator', desc: 'Convert any title or text into a clean URL-safe slug. Handles accented characters, camelCase, and special characters. Choose hyphen, underscore, or no separator.', href: '/tools/slug-generator', icon: '🔗' },
      { name: 'Lorem Ipsum Generator', desc: 'Generate Lorem Ipsum placeholder text — paragraphs, sentences, or words. Start with the classic opening line. Instant copy for mockups and wireframes.', href: '/tools/lorem-ipsum', icon: '📝' },
      { name: 'QR Code Generator', desc: 'Generate QR codes for URLs, WiFi, email, phone, and more. Custom colors, error correction levels, PNG download. No signup, no watermark.', href: '/tools/qr-code-generator', icon: '📱' },
      { name: 'Image to Base64', desc: 'Convert PNG, JPG, SVG, WebP images to Base64. Get the data URL or CSS background-image value. Drag-and-drop, runs entirely in your browser.', href: '/tools/image-to-base64', icon: '🖼️' },
    ],
  },
];

const totalTools = categories.reduce((sum, c) => sum + c.tools.length, 0);
---

<BaseLayout title={`Free Developer Tools — ${totalTools} Tools`} description={`${totalTools} free interactive developer tools: API mock generator, JWT decoder, JSON formatter, regex tester, UUID generator, AI token calculator, and much more. No signup required.`}>
  <div class="text-center mb-12">
    <h1 class="text-4xl font-bold mb-4">Free Developer <span class="text-primary">Tools</span></h1>
    <p class="text-text-muted text-lg max-w-2xl mx-auto">{totalTools} fast, privacy-first interactive tools for developers. No signup, no tracking. Just tools that work.</p>
  </div>

  <!-- Browse by category -->
  <div class="flex flex-wrap gap-2 justify-center mb-6">
    <a href="/tools/text" class="text-sm bg-primary/10 border border-primary/30 hover:border-primary text-primary px-4 py-1.5 rounded-full transition-colors font-medium">📝 Text Tools</a>
    <a href="/tools/code" class="text-sm bg-primary/10 border border-primary/30 hover:border-primary text-primary px-4 py-1.5 rounded-full transition-colors font-medium">💻 Code Tools</a>
    <a href="/tools/utilities" class="text-sm bg-primary/10 border border-primary/30 hover:border-primary text-primary px-4 py-1.5 rounded-full transition-colors font-medium">⚙️ Utilities</a>
  </div>

  <!-- Category nav -->
  <div class="flex flex-wrap gap-2 justify-center mb-10">
    {categories.map(cat => (
      <a href={`#${cat.name.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}
        class="text-sm bg-bg-card border border-border hover:border-primary px-3 py-1.5 rounded-full transition-colors">
        {cat.icon} {cat.name}
      </a>
    ))}
  </div>

  <!-- Category sections -->
  {categories.map(cat => (
    <section id={cat.name.toLowerCase().replace(/[^a-z0-9]+/g, '-')} class="mb-12">
      <div class="flex items-center gap-3 mb-5">
        <span class="text-2xl">{cat.icon}</span>
        <h2 class="text-2xl font-bold">{cat.name}</h2>
        <span class="text-sm text-text-muted bg-bg-card border border-border px-2 py-0.5 rounded-full">{cat.tools.length} tools</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {cat.tools.map(tool => (
          <a href={tool.href} class="block bg-bg-card rounded-xl p-6 border border-border hover:border-primary transition-colors group">
            <div class="text-3xl mb-3">{tool.icon}</div>
            <h3 class="text-lg font-semibold mb-2 group-hover:text-primary transition-colors">{tool.name}</h3>
            <p class="text-text-muted text-sm">{tool.desc}</p>
          </a>
        ))}
      </div>
    </section>
  ))}

  <div class="text-center mt-4">
    <p class="text-text-muted mb-4">Need more? Check out our premium products.</p>
    <a href="/products" class="inline-block bg-primary hover:bg-primary-dark text-white font-semibold px-6 py-3 rounded-lg transition-colors">
      Browse Products &rarr;
    </a>
  </div>
</BaseLayout>
