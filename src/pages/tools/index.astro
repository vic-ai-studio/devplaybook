---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tools = [
  { name: 'JWT Decoder', desc: 'Decode JWT tokens — inspect header, payload, and claims. Check expiry and iat/sub/iss fields instantly.', href: '/tools/jwt-decoder', icon: '🔐' },
  { name: 'Base64 Encoder / Decoder', desc: 'Encode and decode Base64 strings online. Supports UTF-8 text, URL-safe encoding, and binary data. Runs in your browser.', href: '/tools/base64', icon: '🔤' },
  { name: 'Password Generator', desc: 'Generate cryptographically secure random passwords with custom length and character sets. No data sent to any server.', href: '/tools/password-generator', icon: '🔑' },
  { name: 'Markdown Previewer', desc: 'Write and preview Markdown in real-time. Supports GFM tables, task lists, and code blocks with syntax hints.', href: '/tools/markdown-preview', icon: '📝' },
  { name: 'CSS Box Shadow Generator', desc: 'Build multi-layer CSS box-shadow values visually with live preview. Presets, inset, blur, spread, opacity, and one-click copy.', href: '/tools/box-shadow-generator', icon: '🎨' },
  { name: 'HTTP Status Codes', desc: 'Complete reference for all HTTP status codes with descriptions, use cases, and searchable index.', href: '/tools/http-status-codes', icon: '📡' },
  { name: 'CORS Tester', desc: 'Test CORS headers for any URL. Analyze preflight responses and diagnose cross-origin errors.', href: '/tools/cors-tester', icon: '🌐' },
  { name: 'UUID Generator', desc: 'Generate UUID v4 in bulk. Multiple formats: standard, uppercase, no-hyphens, braces.', href: '/tools/uuid-generator', icon: '🔑' },
  { name: 'API Request Builder', desc: 'Build and test HTTP requests visually. Generate cURL commands.', href: '/tools/api-request-builder', icon: '🔗' },
  { name: 'JSON Diff Viewer', desc: 'Compare two JSON objects side-by-side. Highlight added, removed, and unchanged lines instantly.', href: '/tools/json-diff-viewer', icon: '📊' },
  { name: 'Regex Tester', desc: 'Test your regex against multiple strings with pass/fail assertions. Batch validate patterns.', href: '/tools/regex-tester', icon: '✅' },
  { name: 'Regex Playground', desc: 'Write, test, and debug regular expressions in real-time with match highlighting.', href: '/tools/regex-playground', icon: '🔍' },
  { name: 'Cron Expression Generator', desc: 'Generate and validate cron expressions with a visual interface.', href: '/tools/cron-generator', icon: '⏰' },
  { name: 'Git Command Builder', desc: 'Build complex Git commands step by step with all common options.', href: '/tools/git-command-builder', icon: '🌿' },
  { name: 'Docker Compose Generator', desc: 'Generate docker-compose.yml configurations visually with templates.', href: '/tools/docker-compose-generator', icon: '🐳' },
  { name: 'CSS Flexbox Visualizer', desc: 'Interactive flexbox playground. Configure container and item properties with a live preview and generated CSS.', href: '/tools/css-flexbox', icon: '🎨' },
  { name: 'Unix Timestamp Converter', desc: 'Convert between Unix timestamps and human-readable dates. Live clock, timezone support, and instant copy.', href: '/tools/unix-timestamp', icon: '⏱️' },
  { name: 'Color Picker & Palette', desc: 'Pick a color and instantly get HEX, RGB, HSL values. WCAG contrast checker and 5-shade palette generator.', href: '/tools/color-picker', icon: '🎨' },
  { name: 'Text Diff Checker', desc: 'Compare two text blocks side-by-side with line-level diff highlighting. Lines added, removed, and unchanged at a glance.', href: '/tools/text-diff', icon: '🔀' },
  { name: 'JSON Formatter & Validator', desc: 'Format, beautify, and validate JSON instantly. Choose indent size, minify to one line, or copy the result. Syntax errors highlighted live.', href: '/tools/json-formatter', icon: '📋' },
  { name: 'URL Encoder / Decoder', desc: 'Encode text to percent-encoded URL format or decode %20 / %3D / %2F sequences back to readable text. Full URL mode supported.', href: '/tools/url-encoder', icon: '🔗' },
  { name: 'Hash Generator', desc: 'Generate MD5, SHA-1, SHA-256, and SHA-512 hashes instantly. All hashing runs in your browser — nothing sent to any server.', href: '/tools/hash-generator', icon: '🔒' },
  { name: 'HTML Entity Encoder / Decoder', desc: 'Encode special characters to HTML entities (&amp;lt; &amp;gt; &amp;amp;) or decode entities back to plain text. Supports 50+ named entities.', href: '/tools/html-entity-encoder', icon: '🏷️' },
  { name: 'SQL Formatter & Beautifier', desc: 'Format and indent SQL queries automatically. Uppercase keywords, align clauses, and minify SQL to one line. Supports SELECT, JOIN, CTEs, and more.', href: '/tools/sql-formatter', icon: '🗄️' },
];
---

<BaseLayout title="Free Developer Tools" description="24 free interactive developer tools: JSON formatter, SQL formatter, hash generator, HTML entity encoder, URL encoder, regex tester, UUID generator, and more. No signup required.">
  <div class="text-center mb-12">
    <h1 class="text-4xl font-bold mb-4">Free Developer <span class="text-primary">Tools</span></h1>
    <p class="text-text-muted text-lg max-w-2xl mx-auto">Fast, privacy-first interactive tools for developers. No signup, no tracking. Just tools that work.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {tools.map(tool => (
      <a href={tool.href} class="block bg-bg-card rounded-xl p-6 border border-border hover:border-primary transition-colors group">
        <div class="text-3xl mb-3">{tool.icon}</div>
        <h2 class="text-xl font-semibold mb-2 group-hover:text-primary transition-colors">{tool.name}</h2>
        <p class="text-text-muted text-sm">{tool.desc}</p>
      </a>
    ))}
  </div>

  <div class="text-center mt-12">
    <p class="text-text-muted mb-4">Need more? Check out our premium products.</p>
    <a href="/products" class="inline-block bg-primary hover:bg-primary-dark text-white font-semibold px-6 py-3 rounded-lg transition-colors">
      Browse Products &rarr;
    </a>
  </div>
</BaseLayout>
