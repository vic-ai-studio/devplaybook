      { name: 'Service Worker Generator', desc: 'Generate a ready-to-use service worker (sw.js). Choose cache strategy — Cache First, Network First, or Stale While Revalidate. Configure URLs to cache and download.', href: '/tools/service-worker-generator', icon: '⚙️' },
      { name: 'Web Vitals Scorer', desc: 'Enter LCP, INP, and CLS values to get instant Pass/Fail ratings against Google Core Web Vitals thresholds with optimization tips for each metric.', href: '/tools/web-vitals-scorer', icon: '⚡' },
      { name: 'Core Web Vitals Guide', desc: 'Learn LCP, INP, and CLS with interactive explanations and a score simulator. Enter your metric values to get Pass/Fail ratings and targeted optimization tips.', href: '/tools/core-web-vitals', icon: '📊' },
      { name: 'Core Web Vitals Calculator', desc: 'Enter your LCP, INP, and CLS scores to get instant pass/fail grades with color-coded results and improvement recommendations. Also supports FCP and TTFB.', href: '/tools/cwv-calculator', icon: '⚡' },
      { name: 'Image Optimizer Checklist', desc: 'Enter image dimensions and file size to get format recommendations, compression targets, srcset breakpoints, lazy loading guidance, and CDN tips.', href: '/tools/image-optimizer-checklist', icon: '🖼️' },
      { name: 'Image Compression Estimator', desc: 'Estimate how much file size you\'ll save by converting images to WebP or AVIF. Get bandwidth savings and LCP improvement estimates based on industry compression ratios.', href: '/tools/image-compression-estimator', icon: '📦' },
    ],
  },
  {
    name: 'HTTP Headers',
    icon: '📡',
    tools: [
      { name: 'HTTP Headers Analyzer', desc: 'Paste HTTP response headers to get plain-English explanations. Identifies security headers, cache directives, CORS policies, and flags missing critical headers.', href: '/tools/http-headers-analyzer', icon: '🔍' },
    ],
  },
  {
    name: 'SEO & Meta',
    icon: '🔍',
    tools: [
      { name: 'Meta Tags Preview', desc: 'Preview how your page appears when shared on Twitter/X, Facebook, and LinkedIn. Configure og:title, og:description, og:image, and twitter:card with live social previews.', href: '/tools/meta-tags-preview', icon: '🏷️' },
      { name: 'Sitemap.xml Validator', desc: 'Validate your sitemap.xml structure, namespace, URL count, and required fields. Flags common SEO mistakes that prevent Google from reading your sitemap.', href: '/tools/sitemap-validator', icon: '🗺️' },
    ],
  },
];

const featuredTools = [
  { name: 'JSON Formatter & Validator', desc: 'Format, beautify, and validate JSON instantly. Syntax errors highlighted live.', href: '/tools/json-formatter', icon: '📋' },
  { name: 'JWT Decoder', desc: 'Decode JWT tokens — inspect header, payload, and claims. Check expiry instantly.', href: '/tools/jwt-decoder', icon: '🔐' },
  { name: 'Regex Tester Pro', desc: 'Advanced regex tester with real-time highlighting, multiple language flavors, and capture groups.', href: '/tools/regex-tester-pro', icon: '⚡' },
  { name: 'Cron Expression Builder', desc: 'Build cron expressions visually. See next run times in plain English. Works for GitHub Actions, AWS EventBridge, and more.', href: '/tools/cron-builder', icon: '🔧' },
  { name: 'Base64 Encoder / Decoder', desc: 'Encode and decode Base64 strings. Supports UTF-8 text, URL-safe encoding, and binary data.', href: '/tools/base64', icon: '🔤' },
  { name: 'UUID Generator', desc: 'Generate UUID v1, v4, and v5 in bulk. Multiple formats, one-click copy.', href: '/tools/uuid-generator', icon: '🔑' },
];

const totalTools = categories.reduce((sum, c) => sum + c.tools.length, 0);
const totalCategories = categories.length;

const faqItems = [
  {
    q: "Are all these developer tools really free?",
    a: "Yes — every tool on DevPlaybook is 100% free with no usage limits. No signup, no credit card, no paywalls. We make money through optional premium products and newsletter sponsorships, not by locking tools behind accounts."
  },
  {
    q: "Do these tools send my data to a server?",
    a: "No. All tools run entirely in your browser using client-side JavaScript. Your JWT tokens, regex patterns, passwords, code snippets, and any other data you paste never leave your device. There are no API calls made for processing your input."
  },
  {
    q: "What is a JWT Decoder and when should I use it?",
    a: "A JWT (JSON Web Token) Decoder lets you inspect the header, payload, and signature of any JWT token — useful when debugging auth flows, checking expiry claims (exp, iat, nbf), or understanding what your backend is issuing. Our JWT Decoder runs in your browser with zero data sent anywhere."
  },
  {
    q: "How do I build a cron expression for my job scheduler?",
    a: "Use our Cron Expression Generator to build schedules visually: pick fields for minute, hour, day-of-month, month, and day-of-week, then see the next 5 run times in plain English. Common presets include every minute (* * * * *), hourly (0 * * * *), daily at midnight (0 0 * * *), and weekly (0 0 * * 0)."
  },
  {
    q: "Can I test my regex against multiple strings at once?",
    a: "Yes. The Regex Tester lets you write a pattern and test it against a list of strings simultaneously, showing pass/fail assertions and match highlights for each line. The Regex Playground is better for real-time iterative development with a single input."
  },
  {
    q: "What UUID versions does your UUID Generator support?",
    a: "Our UUID Generator supports v1 (time-based), v4 (random), and v5 (namespace-based SHA-1). You can generate up to 100 UUIDs in bulk and copy them in standard, uppercase, no-hyphens, or braces format — all client-side."
  },
  {
    q: "Do the tools work offline?",
    a: "Most tools work fully offline once the page is loaded, since they use no external APIs for processing. Tools that require network requests (like DNS Lookup, HTTP Headers Inspector, or IP Geolocation) need connectivity by design, but everything else — formatters, generators, converters — works without internet."
  },
  {
    q: "Can I use these tools on mobile?",
    a: "Yes. All tools are responsive and designed to work on mobile browsers. Some complex tools (like the CSS Grid Generator or code formatters) are more comfortable on a wider screen, but they're all functional on phones and tablets."
  }
];

// Build ItemList JSON-LD (top 20 tools across categories)
const itemListSeed = categories.flatMap(c => c.tools.slice(0, 3)).slice(0, 20);
const itemListJsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Free Developer Tools — ${totalTools} Tools`,
  "description": `${totalTools} free interactive developer tools for web developers. No signup required.`,
  "url": "https://devplaybook.cc/tools",
  "numberOfItems": totalTools,
  "itemListElement": itemListSeed.map((tool, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": tool.name,
    "description": tool.desc,
    "url": `https://devplaybook.cc${tool.href}`
  }))
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a
    }
  }))
};
---

<BaseLayout
  title={`Free Developer Tools — ${totalTools}+ Tools`}
  description={`${totalTools}+ free interactive developer tools: API tester, JWT decoder, JSON formatter, regex tester, UUID generator, cron builder, color picker, and more. No signup required. Runs in your browser.`}
  noDefaultJsonLd={true}
>
  <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div class="text-center mb-8">
    <h1 class="text-4xl font-bold mb-4">Free Developer <span class="text-primary">Tools</span></h1>
    <p class="text-text-muted text-lg max-w-2xl mx-auto">Fast, privacy-first interactive tools for developers. No signup, no tracking. Just tools that work.</p>
  </div>

  <!-- Stats bar -->
  <div class="flex flex-wrap justify-center gap-6 mb-10 py-4 px-6 bg-bg-card border border-border rounded-2xl">
    <div class="text-center">
      <div class="text-2xl font-bold text-primary">{totalTools}+</div>
      <div class="text-xs text-text-muted uppercase tracking-wide">Free Tools</div>
    </div>
    <div class="text-center">
      <div class="text-2xl font-bold text-primary">{totalCategories}</div>
      <div class="text-xs text-text-muted uppercase tracking-wide">Categories</div>
    </div>
    <div class="text-center">
      <div class="text-2xl font-bold text-primary">0</div>
      <div class="text-xs text-text-muted uppercase tracking-wide">Signups Needed</div>
    </div>
    <div class="text-center">
      <div class="text-2xl font-bold text-primary">100%</div>
      <div class="text-xs text-text-muted uppercase tracking-wide">Client-Side</div>
    </div>
    <div class="text-center">
      <div class="text-2xl font-bold text-primary">∞</div>
      <div class="text-xs text-text-muted uppercase tracking-wide">Usage Limit</div>
    </div>
  </div>

  <!-- Tools discovery: search + featured + categories (Preact) -->
  <ToolsDiscovery
    categories={categories}
    featuredTools={featuredTools}
    client:load
  />

  <!-- Newsletter CTA section -->
  <section class="mb-14">
    <div class="bg-gradient-to-br from-primary/10 via-bg-card to-primary/5 border border-primary/30 rounded-2xl p-8 text-center">
      <div class="text-4xl mb-4">📬</div>
      <h2 class="text-2xl font-bold mb-2">Get New Tools in Your Inbox</h2>
      <p class="text-text-muted mb-6 max-w-lg mx-auto">
        Join thousands of developers who get weekly tool drops, dev tips, and exclusive resources. Free forever — unsubscribe anytime.
      </p>
      <div class="max-w-md mx-auto">
        <NewsletterForm source="tools-page" />
      </div>
      <p class="text-xs text-text-muted mt-3">Used by developers at Google, Meta, Stripe, and 12,000+ more</p>
    </div>
  </section>

  <!-- CTA section -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-14">
    <div class="bg-bg-card border border-border rounded-xl p-6 text-center">
      <div class="text-3xl mb-3">📦</div>
      <h3 class="font-semibold mb-2">Premium Products</h3>
      <p class="text-text-muted text-sm mb-4">Cheat sheets, templates, and guides for developers who want to go deeper.</p>
      <a href="/products" class="inline-block bg-primary hover:bg-primary-dark text-white text-sm font-semibold px-5 py-2 rounded-lg transition-colors">
        Browse Products &rarr;
      </a>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-6 text-center">
      <div class="text-3xl mb-3">⚡</div>
      <h3 class="font-semibold mb-2">DevPlaybook Pro</h3>
      <p class="text-text-muted text-sm mb-4">AI Code Review, Doc Generator, SQL Builder, and all future premium tools.</p>
      <a href="/pro" class="inline-block bg-primary hover:bg-primary-dark text-white text-sm font-semibold px-5 py-2 rounded-lg transition-colors">
        Start 7-Day Free Trial &rarr;
      </a>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-6 text-center">
      <div class="text-3xl mb-3">✍️</div>
      <h3 class="font-semibold mb-2">Dev Blog</h3>
      <p class="text-text-muted text-sm mb-4">Tutorials, API guides, tool comparisons, and practical how-tos for working developers.</p>
      <a href="/blog" class="inline-block border border-border hover:border-primary text-text-muted hover:text-primary text-sm font-semibold px-5 py-2 rounded-lg transition-colors">
        Read the Blog &rarr;
      </a>
    </div>
  </div>

  <!-- FAQ section -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold mb-6 text-center">Frequently Asked Questions</h2>
    <div class="space-y-4 max-w-3xl mx-auto">
      {faqItems.map(item => (
        <details class="bg-bg-card border border-border rounded-xl group">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer font-medium hover:text-primary transition-colors list-none">
            <span>{item.q}</span>
            <span class="text-text-muted group-open:rotate-180 transition-transform text-lg ml-4 shrink-0">▾</span>
          </summary>
          <div class="px-5 pb-4 text-text-muted text-sm leading-relaxed">
            {item.a}
          </div>
        </details>
      ))}
    </div>
  </section>
</BaseLayout>
