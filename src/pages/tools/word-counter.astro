---
import BaseLayout from "../../layouts/BaseLayout.astro";
import WordCounter from "../../components/WordCounter.tsx";
import ToolPageCta from "../../components/ToolPageCta.astro";
import FaqSection from "../../components/FaqSection.astro";

const faq = [
  { question: "How is reading time calculated?", answer: "Reading time is estimated at 200 words per minute — the average adult reading speed for online content. Technical or code-heavy content is typically read slower (150 wpm). The estimate is shown as a range to account for variation." },
  { question: "What is the difference between characters with and without spaces?", answer: "Character count with spaces counts every character including spaces. Without spaces counts only visible characters. Twitter/X uses characters with spaces for its 280-character limit. Some CMS platforms use the without-spaces count for SEO meta description limits (~155 characters recommended)." },
  { question: "How are sentences counted?", answer: "Sentences are detected by periods, exclamation marks, and question marks followed by whitespace or end of text. Abbreviations (e.g., Dr., U.S.A.) may cause slight over-counting. For precise sentence analysis, use a grammar-focused tool." },
  { question: "How is top word frequency useful?", answer: "The word frequency list shows which words appear most often in your text. This is useful for checking keyword density in SEO content, spotting repetitive writing, or verifying that important terms appear the expected number of times in your copy." },
  { question: "Can I use this tool offline?", answer: "Yes. Once the page is loaded, word counting runs entirely in your browser with no network requests. You can paste text and get instant stats even without an internet connection." },
];
---

<BaseLayout
  title="Word Counter — Free Online Word & Character Count Tool"
  description="Count words, characters, sentences, paragraphs, and lines instantly. Get reading time estimate and top word frequency. Free, runs in your browser, no signup needed."
  tool="Word Counter, Character Counter, Text Statistics, Reading Time Calculator, Word Frequency, Sentence Counter"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Word Counter & Text Statistics</h1>
  <p class="text-text-muted mb-4">Paste or type any text to instantly count words, characters (with and without spaces), sentences, paragraphs, and lines. Also shows estimated reading time and top word frequency.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <WordCounter client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Word Counter & Text Statistics" relatedTags={["text", "writing", "productivity", "analysis"]} />
</BaseLayout>
