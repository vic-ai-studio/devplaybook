---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HelmValuesGenerator from '../../components/HelmValuesGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a Helm chart values.yaml?", answer: "values.yaml is the default configuration file for a Helm chart. It provides default values for all chart parameters — container image, replica count, resource limits, ingress settings, and more. You override these values at deploy time with 'helm install -f my-values.yaml'." },
  { question: "What is Helm?", answer: "Helm is the package manager for Kubernetes. Charts are packages of pre-configured Kubernetes resources. Helm lets you install, upgrade, rollback, and uninstall applications on Kubernetes with a single command, using versioned and reusable chart packages." },
  { question: "How do I use this generated values.yaml?", answer: "Save the output as values.yaml in your chart directory or as a standalone override file. Deploy with: helm install my-release ./my-chart -f values.yaml. For upgrading: helm upgrade my-release ./my-chart -f values.yaml. Always run 'helm lint' before deploying to production." },
  { question: "What are Kubernetes resource requests and limits?", answer: "Requests are the minimum resources Kubernetes reserves for a pod (used for scheduling). Limits are the maximum a pod can consume. If a container exceeds its memory limit it's OOMKilled; if it exceeds CPU limit it's throttled. Set requests based on typical usage and limits conservatively higher." },
  { question: "What is a HPA (Horizontal Pod Autoscaler)?", answer: "HPA automatically scales the number of pod replicas based on observed CPU utilization (or custom metrics). When CPU exceeds your target percentage, HPA adds pods; when it drops, it scales down. Requires the Kubernetes Metrics Server to be installed in your cluster." },
  { question: "When should I use ClusterIP vs LoadBalancer service type?", answer: "ClusterIP (default) makes the service reachable only within the cluster — use for internal microservices. NodePort exposes on a static port on each node. LoadBalancer provisions a cloud load balancer (AWS ELB, GCP LB) — use for public-facing apps. For HTTP traffic, Ingress + ClusterIP is the recommended pattern." },
];
---

<BaseLayout
  title="Helm Values Generator — Kubernetes Helm Chart values.yaml Builder"
  description="Free Helm values.yaml generator for Kubernetes charts. Configure image, replicas, resources, HPA, ingress, probes, env vars, and persistence. Copy production-ready YAML in seconds."
  tool="Helm values generator, values.yaml generator, Helm chart configuration, Kubernetes Helm, Helm values.yaml template, Helm chart builder, K8s Helm"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Helm Values Generator</h1>
  <p class="text-text-muted mb-4">Generate Helm chart <code class="bg-surface-elevated px-1.5 py-0.5 rounded text-sm">values.yaml</code> templates visually. Choose a preset (nginx, postgres, redis, custom), configure image, resources, ingress, probes, env vars, and persistence — copy production-ready YAML instantly.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> nginx · postgres · redis presets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> HPA, Ingress, Probes, PVC</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <HelmValuesGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Helm Values Generator" relatedTags={['kubernetes', 'helm', 'k8s', 'devops', 'cloud', 'docker', 'infrastructure']} />
</BaseLayout>
