---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is an Axios interceptor?", answer: "An Axios interceptor is a function that runs before every request or after every response. Request interceptors let you modify config (add auth headers, log requests). Response interceptors let you handle errors globally, refresh tokens, transform data, or retry failed requests — without repeating the logic in every API call." },
  { question: "How does token refresh with interceptors work?", answer: "When a 401 response arrives, the response interceptor catches it, calls the refresh token endpoint to get a new access token, stores it, then retries the original failed request with the new token. To prevent multiple simultaneous refreshes, you queue pending requests while the refresh is in-flight, then replay them all after success." },
  { question: "What is the difference between request and response interceptors?", answer: "Request interceptors run before the request leaves the browser — perfect for injecting auth tokens, adding correlation IDs, or logging outbound requests. Response interceptors run after the response arrives — perfect for global error handling, token refresh, response transformation, or retry logic." },
  { question: "How do I remove an interceptor?", answer: "axios.interceptors.request.use() and .response.use() return an interceptor ID. Store it and call axios.interceptors.request.eject(id) to remove it. This is important in React to clean up interceptors on component unmount to avoid memory leaks or duplicate interceptors." },
  { question: "What is exponential backoff in retry logic?", answer: "Exponential backoff increases the wait time between retries geometrically: attempt 1 waits 1s, attempt 2 waits 2s, attempt 3 waits 4s. Adding random jitter (±20%) prevents thundering herd — when many clients retry simultaneously, random delays spread the load. Only retry idempotent requests (GET, PUT) and specific status codes (429, 503)." },
  { question: "How should I handle Axios errors in TypeScript?", answer: "Use axios.isAxiosError(error) to type-narrow. This gives you access to error.response (server response), error.request (request that was made), and error.config (request config). Create a typed API error class to wrap these for consistent error handling: catch (err) { if (axios.isAxiosError(err)) { const status = err.response?.status; ... } }" },
];
---

<BaseLayout
  title="Axios Interceptor Builder — Axios Interceptor Code Generator with Retry Logic"
  description="Generate Axios interceptor code visually. Build auth token injection, token refresh, retry with exponential backoff, error handling, and request logging. TypeScript ready."
  tool="Axios Interceptor Builder, Axios Code Generator, Axios Token Refresh Interceptor, Axios Retry Logic Builder, Axios TypeScript Setup"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Axios Interceptor Builder</h1>
  <p class="text-text-muted mb-4">Build Axios interceptor configurations visually. Add auth injection, token refresh, retry logic, and error handling — generate production-ready TypeScript code for your HTTP client.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auth token injection</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Automatic token refresh</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Exponential backoff retry</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-5">
    <!-- Config Panel -->
    <div class="space-y-4">
      <!-- Instance -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Axios Instance</h2>
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium mb-1">Base URL</label>
            <input id="base-url" type="text" value="https://api.example.com"
              class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Timeout (ms)</label>
            <input id="timeout" type="number" value="10000" min="0"
              class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Default Content-Type</label>
            <select id="content-type" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="application/json" selected>application/json</option>
              <option value="multipart/form-data">multipart/form-data</option>
              <option value="application/x-www-form-urlencoded">application/x-www-form-urlencoded</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Request Interceptors -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Request Interceptors</h2>
        <div class="space-y-3">
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="req-auth" checked class="rounded" />
            <div>
              <span class="font-medium">Auth Token Injection</span>
              <div class="text-xs text-text-muted">Add Bearer token from localStorage</div>
            </div>
          </label>
          <div id="auth-options" class="pl-5 space-y-2">
            <div>
              <label class="block text-xs text-text-muted mb-1">Token storage key</label>
              <input id="token-key" type="text" value="access_token"
                class="w-full bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs font-mono focus:outline-none focus:border-primary" />
            </div>
          </div>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="req-log" class="rounded" />
            <div>
              <span class="font-medium">Request Logger</span>
              <div class="text-xs text-text-muted">Log method, URL, and duration</div>
            </div>
          </label>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="req-correlation" class="rounded" />
            <div>
              <span class="font-medium">Correlation ID</span>
              <div class="text-xs text-text-muted">Add X-Request-ID header</div>
            </div>
          </label>
        </div>
      </div>

      <!-- Response Interceptors -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Response Interceptors</h2>
        <div class="space-y-3">
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="res-refresh" class="rounded" />
            <div>
              <span class="font-medium">Token Refresh (401 handling)</span>
              <div class="text-xs text-text-muted">Auto-refresh and retry on 401</div>
            </div>
          </label>
          <div id="refresh-options" class="pl-5 space-y-2 hidden">
            <input id="refresh-endpoint" type="text" value="/auth/refresh" placeholder="/auth/refresh"
              class="w-full bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs font-mono focus:outline-none focus:border-primary" />
          </div>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="res-retry" checked class="rounded" />
            <div>
              <span class="font-medium">Retry with Exponential Backoff</span>
              <div class="text-xs text-text-muted">Retry 429/503 with jitter</div>
            </div>
          </label>
          <div id="retry-options" class="pl-5 space-y-2">
            <div class="flex gap-2">
              <div class="flex-1">
                <label class="block text-xs text-text-muted mb-1">Max retries</label>
                <input id="max-retries" type="number" value="3" min="1" max="10"
                  class="w-full bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:border-primary" />
              </div>
              <div class="flex-1">
                <label class="block text-xs text-text-muted mb-1">Base delay (ms)</label>
                <input id="base-delay" type="number" value="1000" min="100"
                  class="w-full bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:border-primary" />
              </div>
            </div>
          </div>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="res-error" checked class="rounded" />
            <div>
              <span class="font-medium">Global Error Handler</span>
              <div class="text-xs text-text-muted">Normalize and log all API errors</div>
            </div>
          </label>
        </div>
      </div>
    </div>

    <!-- Code Output -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-base font-semibold">Generated Code</h2>
        <button id="copy-btn" class="text-xs bg-primary/10 text-primary border border-primary/30 rounded-lg px-3 py-1.5 hover:bg-primary/20 transition-colors">Copy</button>
      </div>
      <pre id="code-output" class="text-xs font-mono bg-bg-card border border-border rounded-lg p-4 overflow-auto max-h-[600px] whitespace-pre-wrap text-text-muted"></pre>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Axios Interceptor Builder" relatedTags={['axios', 'http', 'api', 'typescript', 'frontend']} />
</BaseLayout>

<script>
  function getVal(id: string): string { return (document.getElementById(id) as HTMLInputElement | HTMLSelectElement).value; }
  function getBool(id: string): boolean { return (document.getElementById(id) as HTMLInputElement).checked; }

  function generateCode(): string {
    const baseUrl = getVal('base-url');
    const timeout = getVal('timeout');
    const contentType = getVal('content-type');
    const reqAuth = getBool('req-auth');
    const tokenKey = getVal('token-key') || 'access_token';
    const reqLog = getBool('req-log');
    const reqCorrelation = getBool('req-correlation');
    const resRefresh = getBool('res-refresh');
    const refreshEndpoint = getVal('refresh-endpoint') || '/auth/refresh';
    const resRetry = getBool('res-retry');
    const maxRetries = parseInt(getVal('max-retries') || '3');
    const baseDelay = parseInt(getVal('base-delay') || '1000');
    const resError = getBool('res-error');

    const parts: string[] = [];

    parts.push(`import axios, { AxiosError, InternalAxiosRequestConfig } from 'axios';

// ── Axios Instance ──────────────────────────────────────────────
export const api = axios.create({
  baseURL: '${baseUrl}',
  timeout: ${timeout},
  headers: { 'Content-Type': '${contentType}' },
});`);

    if (resRefresh) {
      parts.push(`
// ── Token Refresh State ─────────────────────────────────────────
let isRefreshing = false;
let failedQueue: Array<{ resolve: (v: string) => void; reject: (e: unknown) => void }> = [];

function processQueue(error: unknown, token: string | null = null) {
  failedQueue.forEach(({ resolve, reject }) => error ? reject(error) : resolve(token!));
  failedQueue = [];
}`);
    }

    const requestInterceptors: string[] = [];
    if (reqAuth) {
      requestInterceptors.push(`  // Inject auth token
  const token = localStorage.getItem('${tokenKey}');
  if (token) config.headers['Authorization'] = \`Bearer \${token}\`;`);
    }
    if (reqCorrelation) {
      requestInterceptors.push(`  // Add correlation ID for distributed tracing
  config.headers['X-Request-ID'] = crypto.randomUUID();`);
    }
    if (reqLog) {
      requestInterceptors.push(`  // Log request
  config.metadata = { startTime: Date.now() };
  console.debug(\`[API] \${config.method?.toUpperCase()} \${config.url}\`);`);
    }

    if (requestInterceptors.length) {
      parts.push(`
// ── Request Interceptors ────────────────────────────────────────
api.interceptors.request.use(
  (config) => {
${requestInterceptors.join('\n')}
    return config;
  },
  (error) => Promise.reject(error)
);`);
    }

    const responseSuccessLines: string[] = [];
    if (reqLog) {
      responseSuccessLines.push(`  const duration = Date.now() - ((response.config as any).metadata?.startTime ?? 0);
  console.debug(\`[API] \${response.status} \${response.config.url} (\${duration}ms)\`);`);
    }

    const responseErrorParts: string[] = [];
    if (resRefresh) {
      responseErrorParts.push(`  // Token refresh on 401
  if (error.response?.status === 401 && !originalRequest._retry) {
    if (isRefreshing) {
      return new Promise((resolve, reject) => {
        failedQueue.push({ resolve, reject });
      }).then(token => {
        originalRequest.headers['Authorization'] = \`Bearer \${token}\`;
        return api(originalRequest);
      });
    }
    originalRequest._retry = true;
    isRefreshing = true;
    try {
      const { data } = await api.post('${refreshEndpoint}');
      const newToken = data.accessToken;
      localStorage.setItem('${tokenKey}', newToken);
      api.defaults.headers.common['Authorization'] = \`Bearer \${newToken}\`;
      processQueue(null, newToken);
      originalRequest.headers['Authorization'] = \`Bearer \${newToken}\`;
      return api(originalRequest);
    } catch (refreshError) {
      processQueue(refreshError, null);
      localStorage.removeItem('${tokenKey}');
      window.location.href = '/login';
      return Promise.reject(refreshError);
    } finally {
      isRefreshing = false;
    }
  }`);
    }

    if (resRetry) {
      responseErrorParts.push(`  // Exponential backoff retry
  const RETRY_STATUS = [429, 503, 504];
  const retryCount = (originalRequest as any)._retryCount ?? 0;
  if (RETRY_STATUS.includes(error.response?.status ?? 0) && retryCount < ${maxRetries}) {
    (originalRequest as any)._retryCount = retryCount + 1;
    const jitter = Math.random() * 0.4 - 0.2; // ±20% jitter
    const delay = ${baseDelay} * Math.pow(2, retryCount) * (1 + jitter);
    await new Promise(r => setTimeout(r, delay));
    return api(originalRequest);
  }`);
    }

    if (resError) {
      responseErrorParts.push(`  // Normalize error
  if (error.response) {
    const { status, data } = error.response;
    console.error(\`[API Error] \${status}: \${data?.message ?? error.message}\`);
    // Re-throw with consistent shape
    throw Object.assign(error, { message: data?.message ?? error.message });
  } else if (error.request) {
    console.error('[API Error] No response received:', error.message);
  }`);
    }

    if (responseSuccessLines.length || responseErrorParts.length) {
      parts.push(`
// ── Response Interceptors ───────────────────────────────────────
api.interceptors.response.use(
  (response) => {
${responseSuccessLines.join('\n') || '    // Pass through successful responses'}
    return response;
  },
  async (error: AxiosError) => {
    const originalRequest = error.config as InternalAxiosRequestConfig & {
      _retry?: boolean; _retryCount?: number; metadata?: { startTime: number };
    };

${responseErrorParts.join('\n\n') || '    // No response interceptors configured'}
    return Promise.reject(error);
  }
);`);
    }

    parts.push(`
// ── Usage Examples ──────────────────────────────────────────────
// GET
const { data: todos } = await api.get<Todo[]>('/todos');

// POST
const { data: newTodo } = await api.post<Todo>('/todos', { title: 'New task' });

// Type-safe wrapper
export async function fetchUser(id: string): Promise<User> {
  const { data } = await api.get<User>(\`/users/\${id}\`);
  return data;
}

export default api;`);

    return parts.join('');
  }

  function update() {
    document.getElementById('code-output')!.textContent = generateCode();

    // Toggle refresh options visibility
    const refreshOpts = document.getElementById('refresh-options')!;
    refreshOpts.classList.toggle('hidden', !getBool('res-refresh'));

    // Toggle retry options
    const retryOpts = document.getElementById('retry-options')!;
    retryOpts.style.display = getBool('res-retry') ? '' : 'none';

    // Toggle auth options
    const authOpts = document.getElementById('auth-options')!;
    authOpts.style.display = getBool('req-auth') ? '' : 'none';
  }

  document.querySelectorAll('input, select').forEach(el => {
    el.addEventListener('input', update);
    el.addEventListener('change', update);
  });

  document.getElementById('copy-btn')!.addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('code-output')!.textContent || '');
    const btn = document.getElementById('copy-btn')!;
    btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = 'Copy', 1500);
  });

  update();
</script>
