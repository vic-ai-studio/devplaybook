---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How does AWS Lambda pricing work?", answer: "Lambda charges for two things: the number of requests ($0.20 per 1M requests) and compute duration ($0.0000166667 per GB-second, billed in 1ms increments). The free tier includes 1M requests and 400,000 GB-seconds per month. Duration is calculated as ceil(duration/1ms) × memory_GB × $0.0000166667." },
  { question: "What is a GB-second?", answer: "A GB-second is 1 GB of memory running for 1 second. If your function uses 512 MB and runs for 2 seconds, that's 0.5 GB × 2s = 1 GB-second. With 128 MB and 100ms runtime, it's 0.128 GB × 0.1s = 0.0128 GB-seconds. Lambda bills per millisecond so you pay for exact usage." },
  { question: "When does Lambda beat EC2 t3.micro?", answer: "A t3.micro on-demand costs ~$8.47/month. Lambda becomes more expensive than a 24/7 t3.micro when you exceed roughly 400M invocations at 100ms/128MB or 50M invocations at 500ms/512MB. Lambda wins for spiky or low-volume workloads; EC2 wins for sustained high-throughput." },
  { question: "What about data transfer costs?", answer: "Lambda charges $0.09/GB for data transferred out to the internet. Transfers within the same AWS region (to S3, DynamoDB, etc.) are free. Transfers to other AWS regions cost $0.02/GB. Our calculator includes outbound internet transfer costs." },
  { question: "Does Lambda have a free tier?", answer: "Yes — the Lambda free tier is perpetual (not just 12 months): 1M free requests per month and 400,000 GB-seconds per month. For a 128 MB function, that's about 3.2 million seconds of compute time per month for free." },
];
---

<BaseLayout
  title="AWS Lambda Cost Calculator — Estimate Serverless Function Pricing"
  description="Estimate AWS Lambda monthly costs. Input invocations, duration, memory, and data transfer to get compute cost, request cost, and total with EC2 comparison."
  tool="AWS Lambda cost calculator, serverless pricing estimator, Lambda GB-second calculator, AWS Lambda vs EC2 cost, Lambda monthly cost"
  keywords={["aws lambda cost", "serverless pricing", "lambda calculator", "gb-second", "aws lambda pricing", "lambda vs ec2"]}
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">AWS Lambda Cost Calculator</h1>
  <p class="text-text-muted mb-4">Estimate your monthly Lambda bill. Enter invocations, duration, memory, and data transfer — get a full cost breakdown with EC2 comparison.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Per-invocation + monthly estimate</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> EC2 t3.micro comparison</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs in your browser</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <!-- Input Panel -->
    <div class="bg-bg-card border border-border rounded-xl p-5 space-y-4">
      <h2 class="text-base font-semibold">Lambda Configuration</h2>

      <div>
        <label class="block text-sm font-medium mb-1.5">Monthly Invocations</label>
        <input id="invocations" type="number" min="0" value="1000000"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        <div class="flex gap-2 mt-2 flex-wrap">
          <button class="inv-preset text-xs px-2.5 py-1 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-v="100000">100K</button>
          <button class="inv-preset text-xs px-2.5 py-1 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-v="1000000">1M</button>
          <button class="inv-preset text-xs px-2.5 py-1 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-v="10000000">10M</button>
          <button class="inv-preset text-xs px-2.5 py-1 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-v="100000000">100M</button>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1.5">Average Duration (ms)</label>
        <input id="duration" type="number" min="1" max="900000" value="200"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        <div class="flex gap-2 mt-2 flex-wrap">
          <button class="dur-preset text-xs px-2.5 py-1 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-v="50">50ms</button>
          <button class="dur-preset text-xs px-2.5 py-1 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-v="200">200ms</button>
          <button class="dur-preset text-xs px-2.5 py-1 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-v="1000">1s</button>
          <button class="dur-preset text-xs px-2.5 py-1 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-v="5000">5s</button>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1.5">Memory Allocation</label>
        <select id="memory" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="128">128 MB</option>
          <option value="256">256 MB</option>
          <option value="512" selected>512 MB</option>
          <option value="1024">1 GB</option>
          <option value="2048">2 GB</option>
          <option value="3008">3 GB</option>
          <option value="10240">10 GB</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1.5">Outbound Data Transfer (GB/month)</label>
        <input id="datatransfer" type="number" min="0" value="10"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>

      <div class="flex items-center gap-2">
        <input id="freetier" type="checkbox" checked class="w-4 h-4 accent-primary" />
        <label for="freetier" class="text-sm">Apply free tier (1M req + 400K GB-s/month)</label>
      </div>
    </div>

    <!-- Results Panel -->
    <div class="space-y-4">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Monthly Cost Breakdown</h2>
        <div class="space-y-3">
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-sm text-text-muted">Request charges</span>
            <span id="req-cost" class="text-sm font-mono font-medium">$0.00</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-sm text-text-muted">Compute charges</span>
            <span id="compute-cost" class="text-sm font-mono font-medium">$0.00</span>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-border">
            <span class="text-sm text-text-muted">Data transfer</span>
            <span id="transfer-cost" class="text-sm font-mono font-medium">$0.00</span>
          </div>
          <div class="flex justify-between items-center py-2">
            <span class="text-sm font-semibold">Total monthly</span>
            <span id="total-cost" class="text-lg font-mono font-bold text-primary">$0.00</span>
          </div>
        </div>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">vs EC2 t3.micro (always-on)</h2>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between">
            <span class="text-text-muted">EC2 t3.micro on-demand</span>
            <span class="font-mono">$8.47/mo</span>
          </div>
          <div class="flex justify-between">
            <span class="text-text-muted">Your Lambda estimate</span>
            <span id="lambda-vs" class="font-mono font-semibold">$0.00/mo</span>
          </div>
          <div id="verdict" class="mt-3 p-3 rounded-lg text-xs bg-green-500/10 text-green-400">
            Lambda is cheaper for this workload.
          </div>
        </div>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">Key Metrics</h2>
        <div class="grid grid-cols-2 gap-3 text-sm">
          <div class="bg-bg border border-border rounded-lg p-3">
            <p class="text-text-muted text-xs mb-1">GB-seconds/month</p>
            <p id="gb-seconds" class="font-mono font-semibold">0</p>
          </div>
          <div class="bg-bg border border-border rounded-lg p-3">
            <p class="text-text-muted text-xs mb-1">Cost per 1K invocations</p>
            <p id="per-1k" class="font-mono font-semibold">$0.000</p>
          </div>
          <div class="bg-bg border border-border rounded-lg p-3">
            <p class="text-text-muted text-xs mb-1">Free tier applied</p>
            <p id="free-savings" class="font-mono font-semibold text-green-400">$0.00 saved</p>
          </div>
          <div class="bg-bg border border-border rounded-lg p-3">
            <p class="text-text-muted text-xs mb-1">Effective $/request</p>
            <p id="per-req" class="font-mono font-semibold">$0.00000</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <ToolPageCta />
  <FaqSection faq={faq} />
</BaseLayout>

<script>
  const PRICE_PER_1M_REQUESTS = 0.20;
  const PRICE_PER_GB_SECOND = 0.0000166667;
  const PRICE_DATA_TRANSFER_GB = 0.09;
  const FREE_REQUESTS = 1_000_000;
  const FREE_GB_SECONDS = 400_000;
  const EC2_MICRO_MONTHLY = 8.47;

  function fmt(n: number, digits = 4) {
    if (n < 0.01) return '$' + n.toFixed(digits);
    return '$' + n.toFixed(2);
  }
  function fmtLarge(n: number) {
    if (n >= 1e9) return (n / 1e9).toFixed(2) + 'B';
    if (n >= 1e6) return (n / 1e6).toFixed(2) + 'M';
    if (n >= 1e3) return (n / 1e3).toFixed(1) + 'K';
    return n.toFixed(0);
  }

  function calculate() {
    const invocations = parseFloat((document.getElementById('invocations') as HTMLInputElement).value) || 0;
    const duration = parseFloat((document.getElementById('duration') as HTMLInputElement).value) || 0;
    const memory = parseFloat((document.getElementById('memory') as HTMLSelectElement).value) || 512;
    const dataTransfer = parseFloat((document.getElementById('datatransfer') as HTMLInputElement).value) || 0;
    const useFree = (document.getElementById('freetier') as HTMLInputElement).checked;

    const memoryGB = memory / 1024;
    const gbSeconds = invocations * (duration / 1000) * memoryGB;

    let billableRequests = invocations;
    let billableGbSeconds = gbSeconds;
    let freeSavings = 0;

    if (useFree) {
      const savedReq = Math.min(billableRequests, FREE_REQUESTS);
      const savedGs = Math.min(billableGbSeconds, FREE_GB_SECONDS);
      freeSavings = (savedReq / 1e6) * PRICE_PER_1M_REQUESTS + savedGs * PRICE_PER_GB_SECOND;
      billableRequests = Math.max(0, billableRequests - FREE_REQUESTS);
      billableGbSeconds = Math.max(0, billableGbSeconds - FREE_GB_SECONDS);
    }

    const reqCost = (billableRequests / 1e6) * PRICE_PER_1M_REQUESTS;
    const computeCost = billableGbSeconds * PRICE_PER_GB_SECOND;
    const transferCost = Math.max(0, dataTransfer - 1) * PRICE_DATA_TRANSFER_GB; // 1 GB free
    const total = reqCost + computeCost + transferCost;

    (document.getElementById('req-cost') as HTMLElement).textContent = fmt(reqCost);
    (document.getElementById('compute-cost') as HTMLElement).textContent = fmt(computeCost);
    (document.getElementById('transfer-cost') as HTMLElement).textContent = fmt(transferCost);
    (document.getElementById('total-cost') as HTMLElement).textContent = fmt(total);
    (document.getElementById('lambda-vs') as HTMLElement).textContent = fmt(total) + '/mo';
    (document.getElementById('gb-seconds') as HTMLElement).textContent = fmtLarge(gbSeconds);
    (document.getElementById('per-1k') as HTMLElement).textContent = invocations > 0 ? fmt(total / invocations * 1000, 4) : '$0.0000';
    (document.getElementById('free-savings') as HTMLElement).textContent = fmt(freeSavings, 2) + ' saved';
    (document.getElementById('per-req') as HTMLElement).textContent = invocations > 0 ? '$' + (total / invocations).toFixed(7) : '$0.0000000';

    const verdict = document.getElementById('verdict') as HTMLElement;
    if (total < EC2_MICRO_MONTHLY) {
      verdict.className = 'mt-3 p-3 rounded-lg text-xs bg-green-500/10 text-green-400';
      verdict.textContent = `Lambda is cheaper by $${(EC2_MICRO_MONTHLY - total).toFixed(2)}/mo vs EC2 t3.micro.`;
    } else {
      verdict.className = 'mt-3 p-3 rounded-lg text-xs bg-yellow-500/10 text-yellow-400';
      verdict.textContent = `EC2 t3.micro is cheaper by $${(total - EC2_MICRO_MONTHLY).toFixed(2)}/mo. Consider EC2 for sustained load.`;
    }
  }

  document.querySelectorAll('.inv-preset').forEach(btn => {
    btn.addEventListener('click', () => {
      (document.getElementById('invocations') as HTMLInputElement).value = btn.getAttribute('data-v') || '';
      calculate();
    });
  });
  document.querySelectorAll('.dur-preset').forEach(btn => {
    btn.addEventListener('click', () => {
      (document.getElementById('duration') as HTMLInputElement).value = btn.getAttribute('data-v') || '';
      calculate();
    });
  });

  ['invocations', 'duration', 'memory', 'datatransfer', 'freetier'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', calculate);
  });

  calculate();
</script>
