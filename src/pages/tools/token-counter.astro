---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How accurate is the token estimate?", answer: "This tool uses a 4 characters ≈ 1 token heuristic, which closely matches tiktoken for typical English text. Code, JSON, and non-English text may vary. For production accuracy use the official tokenizer libraries (tiktoken for OpenAI, claude-tokenizer for Anthropic)." },
  { question: "Why do different models have different token counts for the same text?", answer: "Each model uses its own tokenizer vocabulary. GPT models use cl100k_base, Claude uses its own BPE tokenizer, Gemini uses SentencePiece. Token counts can differ by 10–20% for the same text." },
  { question: "What is a token exactly?", answer: "A token is a chunk of text — roughly a word or sub-word. 'hamburger' might be 2 tokens: 'ham' and 'burger'. Numbers, punctuation, and whitespace are also tokens. 100 tokens ≈ 75 words in English." },
  { question: "How is the API cost calculated?", answer: "Cost = (token count ÷ 1,000,000) × price per million tokens. Each model has separate input and output rates. This tool shows the input cost for the pasted text." },
];
---

<BaseLayout
  title="LLM Token Counter — Count Tokens & Estimate API Cost"
  description="Paste any text and instantly count tokens for GPT-4o, Claude, and Gemini. Uses tiktoken-style 4-char-per-token estimation. See token count, word count, and estimated API cost. Free browser tool."
  tool="Token Counter, LLM Token Estimator, GPT Token Count, Claude Token Calculator, API Cost Estimator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">LLM Token Counter</h1>
  <p class="text-text-muted mb-6">Paste your text to estimate token count for GPT-4o, Claude, and Gemini. Uses the 4-chars-per-token heuristic — close to tiktoken for English text.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 3 major models</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Input + cost estimate</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs in your browser</span>
  </div>

  <div id="token-counter-app" class="space-y-5">
    <!-- Text input -->
    <div>
      <label for="text-input" class="block text-sm font-medium mb-2">Text to Tokenize</label>
      <textarea
        id="text-input"
        rows="8"
        placeholder="Paste your prompt, message, or document here…"
        class="w-full bg-bg-card border border-border rounded-lg px-4 py-3 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary resize-y"
      ></textarea>
      <div class="flex justify-between mt-1">
        <p class="text-xs text-text-muted">Estimation: 4 characters ≈ 1 token</p>
        <button id="clear-btn" class="text-xs text-text-muted hover:text-primary transition-colors">Clear</button>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
        <p class="text-xs text-text-muted uppercase tracking-wide mb-1">Characters</p>
        <p class="text-2xl font-bold tabular-nums text-primary" id="stat-chars">0</p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
        <p class="text-xs text-text-muted uppercase tracking-wide mb-1">Words</p>
        <p class="text-2xl font-bold tabular-nums" id="stat-words">0</p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
        <p class="text-xs text-text-muted uppercase tracking-wide mb-1">Lines</p>
        <p class="text-2xl font-bold tabular-nums" id="stat-lines">0</p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
        <p class="text-xs text-text-muted uppercase tracking-wide mb-1">Est. Tokens</p>
        <p class="text-2xl font-bold tabular-nums text-primary" id="stat-tokens">0</p>
      </div>
    </div>

    <!-- Model selector -->
    <div>
      <label for="model-select" class="block text-sm font-medium mb-2">Estimate Cost For</label>
      <select id="model-select" class="w-full bg-bg-card border border-border rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary">
        <optgroup label="OpenAI">
          <option value="gpt4o">GPT-4o — $5.00/1M input</option>
          <option value="gpt4o-mini">GPT-4o Mini — $0.15/1M input</option>
          <option value="o1">o1 — $15.00/1M input</option>
        </optgroup>
        <optgroup label="Anthropic">
          <option value="claude-sonnet">Claude 3.5 Sonnet — $3.00/1M input</option>
          <option value="claude-haiku">Claude 3.5 Haiku — $0.80/1M input</option>
          <option value="claude-opus">Claude 3 Opus — $15.00/1M input</option>
        </optgroup>
        <optgroup label="Google">
          <option value="gemini-pro">Gemini 1.5 Pro — $3.50/1M input</option>
          <option value="gemini-flash">Gemini 1.5 Flash — $0.075/1M input</option>
        </optgroup>
        <optgroup label="Meta / Open Source">
          <option value="llama3-70b">Llama 3.3 70B* — $0.59/1M input</option>
          <option value="llama3-8b">Llama 3.1 8B* — $0.10/1M input</option>
        </optgroup>
      </select>
    </div>

    <!-- Cost result -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <p class="text-sm font-semibold mb-4">Estimated Input Cost</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-center">
        <div>
          <p class="text-xs text-text-muted uppercase tracking-wide mb-1">This Text (1x)</p>
          <p class="text-xl font-bold tabular-nums text-primary" id="cost-once">$0.000000</p>
        </div>
        <div>
          <p class="text-xs text-text-muted uppercase tracking-wide mb-1">1,000 Requests</p>
          <p class="text-xl font-bold tabular-nums" id="cost-1k">$0.00</p>
        </div>
        <div>
          <p class="text-xs text-text-muted uppercase tracking-wide mb-1">100,000 Requests</p>
          <p class="text-xl font-bold tabular-nums" id="cost-100k">$0.00</p>
        </div>
      </div>
      <p class="text-xs text-text-muted mt-4">Input token cost only. Output tokens billed separately at a different rate.</p>
    </div>

    <!-- Context window usage -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <p class="text-sm font-semibold mb-3">Context Window Usage</p>
      <div id="context-bars" class="space-y-3">
      </div>
      <p class="text-xs text-text-muted mt-3">* Llama prices via cloud inference (Together AI, Groq)</p>
    </div>

    <!-- Sample prompts -->
    <div>
      <p class="text-sm font-semibold mb-3">Try a Sample</p>
      <div class="flex flex-wrap gap-2">
        <button class="sample-btn text-xs px-3 py-1.5 bg-bg-card border border-border rounded-full hover:border-primary transition-colors" data-text="Write a Python function that checks if a string is a palindrome, with unit tests.">Python task</button>
        <button class="sample-btn text-xs px-3 py-1.5 bg-bg-card border border-border rounded-full hover:border-primary transition-colors" data-text="You are a helpful assistant. Answer questions accurately and concisely. If you are unsure, say so.">System prompt</button>
        <button class="sample-btn text-xs px-3 py-1.5 bg-bg-card border border-border rounded-full hover:border-primary transition-colors" data-text="Explain the difference between REST and GraphQL APIs. When should I use each? Provide real-world examples.">API question</button>
        <button class="sample-btn text-xs px-3 py-1.5 bg-bg-card border border-border rounded-full hover:border-primary transition-colors" data-text="Translate the following text to Spanish, French, and Japanese: 'The quick brown fox jumps over the lazy dog.'">Translation</button>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="LLM Token Counter" relatedTags={['ai', 'llm', 'openai', 'claude', 'gemini', 'tokens', 'cost']} />
</BaseLayout>

<script>
  type ModelDef = { name: string; inputPricePerM: number; contextK: number };
  const MODELS: Record<string, ModelDef> = {
    'gpt4o':          { name: 'GPT-4o',            inputPricePerM: 5.00,   contextK: 128  },
    'gpt4o-mini':     { name: 'GPT-4o Mini',        inputPricePerM: 0.15,   contextK: 128  },
    'o1':             { name: 'o1',                 inputPricePerM: 15.00,  contextK: 200  },
    'claude-sonnet':  { name: 'Claude 3.5 Sonnet',  inputPricePerM: 3.00,   contextK: 200  },
    'claude-haiku':   { name: 'Claude 3.5 Haiku',   inputPricePerM: 0.80,   contextK: 200  },
    'claude-opus':    { name: 'Claude 3 Opus',       inputPricePerM: 15.00,  contextK: 200  },
    'gemini-pro':     { name: 'Gemini 1.5 Pro',      inputPricePerM: 3.50,   contextK: 1000 },
    'gemini-flash':   { name: 'Gemini 1.5 Flash',    inputPricePerM: 0.075,  contextK: 1000 },
    'llama3-70b':     { name: 'Llama 3.3 70B*',      inputPricePerM: 0.59,   contextK: 128  },
    'llama3-8b':      { name: 'Llama 3.1 8B*',       inputPricePerM: 0.10,   contextK: 128  },
  };

  const CONTEXT_MODELS = ['gpt4o', 'claude-sonnet', 'gemini-pro', 'gemini-flash'];

  function estimateTokens(text: string): number {
    return Math.ceil(text.length / 4);
  }

  function countWords(text: string): number {
    return text.trim() ? text.trim().split(/\s+/).length : 0;
  }

  function fmt(n: number): string {
    if (n < 0.000001) return `$${n.toFixed(10)}`;
    if (n < 0.001) return `$${n.toFixed(6)}`;
    if (n < 1) return `$${n.toFixed(4)}`;
    if (n >= 1000) return `$${n.toLocaleString('en-US', { maximumFractionDigits: 2 })}`;
    return `$${n.toFixed(2)}`;
  }

  function pct(tokens: number, contextK: number): number {
    return Math.min(100, (tokens / (contextK * 1000)) * 100);
  }

  function update() {
    const text = (document.getElementById('text-input') as HTMLTextAreaElement).value;
    const chars = text.length;
    const words = countWords(text);
    const lines = text ? text.split('\n').length : 0;
    const tokens = estimateTokens(text);

    (document.getElementById('stat-chars') as HTMLElement).textContent = chars.toLocaleString();
    (document.getElementById('stat-words') as HTMLElement).textContent = words.toLocaleString();
    (document.getElementById('stat-lines') as HTMLElement).textContent = lines.toLocaleString();
    (document.getElementById('stat-tokens') as HTMLElement).textContent = tokens.toLocaleString();

    const modelKey = (document.getElementById('model-select') as HTMLSelectElement).value;
    const model = MODELS[modelKey];
    const costOnce = (tokens / 1_000_000) * model.inputPricePerM;
    const cost1k = costOnce * 1000;
    const cost100k = costOnce * 100_000;

    (document.getElementById('cost-once') as HTMLElement).textContent = fmt(costOnce);
    (document.getElementById('cost-1k') as HTMLElement).textContent = fmt(cost1k);
    (document.getElementById('cost-100k') as HTMLElement).textContent = fmt(cost100k);

    // Context window bars
    const barsEl = document.getElementById('context-bars') as HTMLElement;
    barsEl.innerHTML = CONTEXT_MODELS.map(key => {
      const m = MODELS[key];
      const p = pct(tokens, m.contextK);
      const color = p > 80 ? 'bg-red-500' : p > 50 ? 'bg-yellow-500' : 'bg-green-500';
      return `
        <div>
          <div class="flex justify-between text-xs text-text-muted mb-1">
            <span>${m.name}</span>
            <span>${p.toFixed(1)}% of ${m.contextK}K tokens</span>
          </div>
          <div class="w-full bg-border rounded-full h-2">
            <div class="${color} h-2 rounded-full transition-all" style="width:${p}%"></div>
          </div>
        </div>`;
    }).join('');
  }

  document.getElementById('text-input')?.addEventListener('input', update);
  document.getElementById('model-select')?.addEventListener('change', update);
  document.getElementById('clear-btn')?.addEventListener('click', () => {
    (document.getElementById('text-input') as HTMLTextAreaElement).value = '';
    update();
  });

  document.querySelectorAll('.sample-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      (document.getElementById('text-input') as HTMLTextAreaElement).value = btn.getAttribute('data-text') || '';
      update();
    });
  });

  update();
</script>
