---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProtobufFieldNumberTracker from '../../components/ProtobufFieldNumberTracker.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "Why do Protobuf field numbers matter?",
    answer: "Field numbers in Protocol Buffers are used for binary encoding — they identify fields in the serialized wire format, not names. Changing a field number is a breaking change: old clients and new clients will misread each other's data. Numbers 1-15 use one byte encoding, 16-2047 use two bytes — so frequently used fields should get low numbers."
  },
  {
    question: "What field numbers are reserved by Google?",
    answer: "Field numbers 19000 through 19999 are reserved by the Protocol Buffers implementation for internal use. Using them will produce a compile-time error in protoc. Numbers must also be positive integers between 1 and 536870911 (2^29 - 1)."
  },
  {
    question: "What does 'reserved' mean in proto files?",
    answer: "The 'reserved' keyword prevents reuse of field numbers or names that were previously used by removed fields. This avoids accidental reuse which would cause data corruption when old serialized data is parsed by new code. Example: reserved 2, 15, 9 to 11; or reserved \"foo\", \"bar\";"
  },
  {
    question: "How do I handle field number conflicts?",
    answer: "Each field in a message must have a unique field number. If you rename a field, the number stays the same (that's fine). If you remove a field, mark its number as reserved. Never reuse field numbers in the same message — the binary wire format uses the number as the field identifier."
  },
  {
    question: "What is the difference between proto2 and proto3 field rules?",
    answer: "In proto2, fields have explicit rules: required, optional, or repeated. In proto3, all singular fields are implicitly optional and the 'optional' keyword was only re-added in proto3 optional syntax. This tool handles both syntaxes and parses fields correctly regardless of label style."
  },
  {
    question: "Which fields should get numbers 1-15?",
    answer: "Fields you expect to be present in most messages — typically IDs, status flags, timestamps, and primary data payloads. Fields 1-15 encode in 1 byte vs 2 bytes for 16-2047, which can matter at scale. Map fields, repeated nested messages, and rarely-set optional fields can safely use higher numbers."
  },
];
---

<BaseLayout
  title="Protobuf Field Number Tracker — Validate & Audit .proto Files"
  description="Parse and validate Protobuf field numbers in your .proto files. Detect conflicts, reserved number violations, Google reserved range usage, and get encoding efficiency tips. Free browser tool."
  tool="Protobuf Field Number Tracker, Proto Validator, Protocol Buffers Lint, Proto Field Audit"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Protobuf Field Number Tracker",
    "url": "https://devplaybook.cc/tools/protobuf-field-number-tracker",
    "description": "Validate Protobuf field numbers — detect duplicates, reserved range violations, and encoding efficiency issues. Runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Protobuf Field Number Tracker</h1>
  <p class="text-text-muted mb-4">
    Paste your <code class="font-mono bg-surface px-1 rounded text-sm">.proto</code> file and instantly audit field numbers.
    Detects duplicates, reserved range violations, Google reserved numbers (19000-19999), and encoding efficiency.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Conflict detection</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Reserved range validation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 1-byte vs 2-byte encoding hints</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <ProtobufFieldNumberTracker client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Protobuf Field Number Tracker" relatedTags={['protobuf', 'grpc', 'serialization', 'api', 'developer-tools']} />
</BaseLayout>
