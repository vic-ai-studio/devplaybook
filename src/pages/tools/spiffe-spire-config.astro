---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="SPIFFE/SPIRE Config Generator — Generate SPIRE Server & Agent Configs"
  description="Generate SPIFFE/SPIRE server and agent configuration files for zero-trust workload identity. Configure trust domains, node attestors, key managers, and data stores. Free, runs in browser."
  tool="SPIFFE SPIRE config generator, workload identity, zero trust, SVID, trust domain, node attestor, SPIRE server config"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "SPIFFE/SPIRE Config Generator",
    "url": "https://devplaybook.cc/tools/spiffe-spire-config",
    "description": "Generate SPIRE server and agent HCL configuration files for SPIFFE workload identity in zero-trust environments.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">SPIFFE / SPIRE Config Generator</h1>
  <p class="text-text-muted mb-4">
    Generate <a href="https://spiffe.io" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">SPIFFE/SPIRE</a> server and agent HCL configuration files for zero-trust workload identity.
    Configure trust domains, node attestors, upstream authorities, and data stores. Runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Server + Agent configs</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multiple attestors (K8s, AWS, GCP, TPM)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Disk / SQLite / PostgreSQL data stores</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-ready HCL output</span>
  </div>

  <!-- Mode toggle -->
  <div class="flex gap-2 mb-6">
    <button id="tab-server" class="tab-btn px-4 py-2 rounded-lg text-sm font-semibold bg-primary text-white transition-colors">Server Config</button>
    <button id="tab-agent" class="tab-btn px-4 py-2 rounded-lg text-sm font-semibold bg-bg-card border border-border hover:border-primary transition-colors">Agent Config</button>
  </div>

  <!-- Server Config Section -->
  <div id="section-server">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium mb-2">Trust Domain</label>
        <input id="srv-trust-domain" type="text" value="example.org" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="example.org" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Bind Address</label>
        <input id="srv-bind-addr" type="text" value="0.0.0.0" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Bind Port</label>
        <input id="srv-bind-port" type="number" value="8081" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Data Directory</label>
        <input id="srv-data-dir" type="text" value="/opt/spire/data/server" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Log Level</label>
        <select id="srv-log-level" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
          <option value="INFO" selected>INFO</option>
          <option value="DEBUG">DEBUG</option>
          <option value="WARN">WARN</option>
          <option value="ERROR">ERROR</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Data Store</label>
        <select id="srv-datastore" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
          <option value="sqlite3" selected>SQLite3 (dev)</option>
          <option value="postgres">PostgreSQL</option>
          <option value="mysql">MySQL</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Node Attestor</label>
        <select id="srv-attestor" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
          <option value="k8s_sat" selected>Kubernetes SAT</option>
          <option value="aws_iid">AWS IID</option>
          <option value="gcp_iit">GCP IIT</option>
          <option value="azure_msi">Azure MSI</option>
          <option value="join_token">Join Token</option>
          <option value="tpm_devid">TPM DevID</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Key Manager</label>
        <select id="srv-key-manager" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
          <option value="disk" selected>Disk</option>
          <option value="memory">Memory</option>
          <option value="aws_kms">AWS KMS</option>
          <option value="gcp_kms">GCP KMS</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">SVID TTL</label>
        <input id="srv-svid-ttl" type="text" value="1h" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="1h" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">CA TTL</label>
        <input id="srv-ca-ttl" type="text" value="24h" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="24h" />
      </div>
    </div>
    <div id="srv-k8s-extra" class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium mb-2">K8s API Server URL</label>
        <input id="srv-k8s-api" type="text" value="https://kubernetes.default.svc" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
      </div>
    </div>
  </div>

  <!-- Agent Config Section -->
  <div id="section-agent" class="hidden">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium mb-2">Trust Domain</label>
        <input id="agt-trust-domain" type="text" value="example.org" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="example.org" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Server Address</label>
        <input id="agt-server-addr" type="text" value="spire-server" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Server Port</label>
        <input id="agt-server-port" type="number" value="8081" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Agent Socket Path</label>
        <input id="agt-socket" type="text" value="/run/spire/sockets/agent.sock" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Data Directory</label>
        <input id="agt-data-dir" type="text" value="/opt/spire/data/agent" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Node Attestor</label>
        <select id="agt-attestor" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
          <option value="k8s_sat" selected>Kubernetes SAT</option>
          <option value="aws_iid">AWS IID</option>
          <option value="gcp_iit">GCP IIT</option>
          <option value="azure_msi">Azure MSI</option>
          <option value="join_token">Join Token</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Log Level</label>
        <select id="agt-log-level" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
          <option value="INFO" selected>INFO</option>
          <option value="DEBUG">DEBUG</option>
          <option value="WARN">WARN</option>
        </select>
      </div>
    </div>
  </div>

  <div class="flex gap-3 mb-8">
    <button id="btn-generate" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Generate Config</button>
    <button id="btn-copy" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors hidden">Copy</button>
  </div>

  <div id="output-section" class="hidden">
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <div class="flex justify-between items-center mb-3">
        <span id="output-title" class="text-sm font-medium text-text-muted">spire-server.conf</span>
        <button id="copy-btn" class="px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">Copy</button>
      </div>
      <pre id="config-output" class="font-mono text-sm whitespace-pre-wrap break-words overflow-x-auto max-h-[600px] overflow-y-auto text-foreground"></pre>
    </div>
  </div>

  <ToolPageCta currentTool="SPIFFE/SPIRE Config Generator" relatedTags={['security', 'zero-trust', 'kubernetes', 'infrastructure', 'devops', 'identity']} />
</BaseLayout>

<script is:inline>
  let mode = 'server';

  function v(id) {
    const el = document.getElementById(id);
    return el ? el.value.trim() : '';
  }

  document.getElementById('tab-server').addEventListener('click', () => {
    mode = 'server';
    document.getElementById('section-server').classList.remove('hidden');
    document.getElementById('section-agent').classList.add('hidden');
    document.getElementById('tab-server').className = 'tab-btn px-4 py-2 rounded-lg text-sm font-semibold bg-primary text-white transition-colors';
    document.getElementById('tab-agent').className = 'tab-btn px-4 py-2 rounded-lg text-sm font-semibold bg-bg-card border border-border hover:border-primary transition-colors';
    document.getElementById('output-section').classList.add('hidden');
  });

  document.getElementById('tab-agent').addEventListener('click', () => {
    mode = 'agent';
    document.getElementById('section-agent').classList.remove('hidden');
    document.getElementById('section-server').classList.add('hidden');
    document.getElementById('tab-agent').className = 'tab-btn px-4 py-2 rounded-lg text-sm font-semibold bg-primary text-white transition-colors';
    document.getElementById('tab-server').className = 'tab-btn px-4 py-2 rounded-lg text-sm font-semibold bg-bg-card border border-border hover:border-primary transition-colors';
    document.getElementById('output-section').classList.add('hidden');
  });

  document.getElementById('btn-generate').addEventListener('click', () => {
    let cfg = '';
    if (mode === 'server') {
      cfg = generateServer();
      document.getElementById('output-title').textContent = 'spire-server.conf';
    } else {
      cfg = generateAgent();
      document.getElementById('output-title').textContent = 'spire-agent.conf';
    }
    document.getElementById('config-output').textContent = cfg;
    document.getElementById('output-section').classList.remove('hidden');
    document.getElementById('output-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  document.getElementById('copy-btn').addEventListener('click', function () {
    navigator.clipboard.writeText(document.getElementById('config-output').textContent).then(() => {
      this.textContent = 'Copied!';
      setTimeout(() => { this.textContent = 'Copy'; }, 2000);
    });
  });

  function generateServer() {
    const td = v('srv-trust-domain');
    const addr = v('srv-bind-addr');
    const port = v('srv-bind-port');
    const dataDir = v('srv-data-dir');
    const logLevel = v('srv-log-level');
    const datastore = v('srv-datastore');
    const attestor = v('srv-attestor');
    const keyMgr = v('srv-key-manager');
    const svidTTL = v('srv-svid-ttl');
    const caTTL = v('srv-ca-ttl');

    let dsConfig = '';
    if (datastore === 'sqlite3') {
      dsConfig = `    connection_string = "${dataDir}/datastore.sqlite3"`;
    } else if (datastore === 'postgres') {
      dsConfig = `    connection_string = "dbname=spire user=spire password=secret host=localhost sslmode=disable"`;
    } else {
      dsConfig = `    connection_string = "spire:secret@tcp(localhost:3306)/spire?parseTime=true"`;
    }

    let attestorBlock = '';
    if (attestor === 'k8s_sat') {
      const k8sApi = v('srv-k8s-api');
      attestorBlock = `
  NodeAttestor "k8s_sat" {
    plugin_data {
      clusters = {
        "default" = {
          service_account_allow_list = ["spire:spire-agent"]
          kube_config_file = ""
        }
      }
    }
  }`;
    } else if (attestor === 'aws_iid') {
      attestorBlock = `
  NodeAttestor "aws_iid" {
    plugin_data {
      skip_block_device = true
    }
  }`;
    } else if (attestor === 'gcp_iit') {
      attestorBlock = `
  NodeAttestor "gcp_iit" {
    plugin_data {}
  }`;
    } else if (attestor === 'azure_msi') {
      attestorBlock = `
  NodeAttestor "azure_msi" {
    plugin_data {
      tenants = {
        "your-tenant-id" = {}
      }
    }
  }`;
    } else if (attestor === 'join_token') {
      attestorBlock = `
  NodeAttestor "join_token" {
    plugin_data {}
  }`;
    } else if (attestor === 'tpm_devid') {
      attestorBlock = `
  NodeAttestor "tpm_devid" {
    plugin_data {
      devid_cert_path = "/etc/spire/certs/devid.crt"
      devid_priv_path = "/etc/spire/keys/devid.key"
    }
  }`;
    }

    let keyMgrBlock = '';
    if (keyMgr === 'disk') {
      keyMgrBlock = `
  KeyManager "disk" {
    plugin_data {
      keys_path = "${dataDir}/keys.json"
    }
  }`;
    } else if (keyMgr === 'memory') {
      keyMgrBlock = `
  KeyManager "memory" {
    plugin_data {}
  }`;
    } else if (keyMgr === 'aws_kms') {
      keyMgrBlock = `
  KeyManager "aws_kms" {
    plugin_data {
      region = "us-east-1"
      key_policy_file = ""
    }
  }`;
    } else {
      keyMgrBlock = `
  KeyManager "gcp_kms" {
    plugin_data {
      project_id = "your-project"
      location   = "global"
      key_ring   = "spire"
    }
  }`;
    }

    return `server {
  bind_address = "${addr}"
  bind_port    = "${port}"
  trust_domain = "${td}"
  data_dir     = "${dataDir}"
  log_level    = "${logLevel}"

  ca_ttl   = "${caTTL}"
  svid_ttl = "${svidTTL}"

  ca_subject {
    country      = ["US"]
    organization = ["SPIFFE"]
    common_name  = ""
  }
}

plugins {
  DataStore "sql" {
    plugin_data {
      database_type = "${datastore}"
${dsConfig}
    }
  }
${attestorBlock}
${keyMgrBlock}

  BundlePublisher "local" {
    plugin_data {
      local_dir = "${dataDir}/bundle"
    }
  }
}

health_checks {
  listener_enabled = true
  bind_address     = "0.0.0.0"
  bind_port        = "8080"
  live_path        = "/live"
  ready_path       = "/ready"
}
`;
  }

  function generateAgent() {
    const td = v('agt-trust-domain');
    const serverAddr = v('agt-server-addr');
    const serverPort = v('agt-server-port');
    const socket = v('agt-socket');
    const dataDir = v('agt-data-dir');
    const attestor = v('agt-attestor');
    const logLevel = v('agt-log-level');

    let attestorBlock = '';
    if (attestor === 'k8s_sat') {
      attestorBlock = `
  NodeAttestor "k8s_sat" {
    plugin_data {
      cluster = "default"
      token_path = "/var/run/secrets/kubernetes.io/serviceaccount/token"
    }
  }`;
    } else if (attestor === 'aws_iid') {
      attestorBlock = `
  NodeAttestor "aws_iid" {
    plugin_data {}
  }`;
    } else if (attestor === 'gcp_iit') {
      attestorBlock = `
  NodeAttestor "gcp_iit" {
    plugin_data {}
  }`;
    } else if (attestor === 'azure_msi') {
      attestorBlock = `
  NodeAttestor "azure_msi" {
    plugin_data {
      resource_id = "https://management.azure.com/"
    }
  }`;
    } else if (attestor === 'join_token') {
      attestorBlock = `
  NodeAttestor "join_token" {
    plugin_data {}
  }`;
    }

    return `agent {
  data_dir             = "${dataDir}"
  log_level            = "${logLevel}"
  trust_domain         = "${td}"
  server_address       = "${serverAddr}"
  server_port          = ${serverPort}
  socket_path          = "${socket}"
  trust_bundle_path    = "${dataDir}/bundle.crt"

  # Reload interval for workload API
  workload_x509_svid_key_type = "EC"
}

plugins {
${attestorBlock}

  KeyManager "memory" {
    plugin_data {}
  }

  WorkloadAttestor "k8s" {
    plugin_data {
      skip_kubelet_verification = true
    }
  }

  WorkloadAttestor "unix" {
    plugin_data {}
  }
}

health_checks {
  listener_enabled = true
  bind_address     = "0.0.0.0"
  bind_port        = "8080"
  live_path        = "/live"
  ready_path       = "/ready"
}
`;
  }
</script>
