---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const installExample = `# Run oxlint without installing (one-shot check)
npx oxlint@latest .

# Add oxlint as a dev dependency
npm add -D oxlint

# Lint the current directory
npx oxlint .

# Lint and auto-fix fixable issues
npx oxlint --fix .

# Lint a specific file or glob
npx oxlint src/

# Lint with a specific rule category enabled
npx oxlint --deny correctness .`;

const configExample = `// package.json — add a lint script
{
  "scripts": {
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix ."
  },
  "devDependencies": {
    "oxlint": "^0.4.0"
  }
}`;

const ciExample = `# .github/workflows/lint.yml
name: Lint

on: [push, pull_request]

jobs:
  oxlint:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: 20
      - run: npm ci
      - run: npx oxlint .`;

const eslintMigrationExample = `# Step 1 — run oxlint alongside ESLint (zero risk)
# oxlint catches issues ESLint misses at 50-100x the speed

# Step 2 — disable rules in ESLint that oxlint now covers
# oxlint outputs a list of covered rules:
npx oxlint --rules

# Step 3 — once confident, remove ESLint entirely
npm remove eslint eslint-config-* eslint-plugin-*
npm add -D oxlint`;

const faq = [
  {
    question: "What is oxlint?",
    answer: "oxlint is a JavaScript and TypeScript linter written in Rust, developed as part of the Oxc (JavaScript Oxidation Compiler) toolchain. It is designed to be 50–100x faster than ESLint by leveraging Rust's performance characteristics and parallel processing. It supports JSX, TSX, and a growing set of lint rules compatible with the ESLint rule API."
  },
  {
    question: "How does oxlint compare to ESLint?",
    answer: "oxlint is dramatically faster than ESLint — benchmarks show 50–100x speed improvements on large codebases. ESLint has a much larger ecosystem with thousands of community plugins and rules. oxlint covers the most commonly used correctness and style rules out of the box. For projects that primarily use the ESLint core rules and popular plugins, oxlint can serve as a drop-in speed upgrade."
  },
  {
    question: "Can oxlint fully replace ESLint?",
    answer: "Not yet for every project. oxlint covers a large and growing set of rules, but ESLint has thousands of community plugins (eslint-plugin-react, eslint-plugin-import, etc.) that have no oxlint equivalent yet. The recommended migration path is to run oxlint alongside ESLint first, then disable the ESLint rules that oxlint already covers, and gradually reduce ESLint's scope. The oxlint team maintains an ESLint compatibility list."
  },
  {
    question: "What rules does oxlint support?",
    answer: "oxlint ships with rules across several categories: correctness (logic errors, no-unused-vars), pedantic (stylistic consistency), suspicious (likely bugs), restriction (opinionated constraints), and nursery (new, experimental rules). Run npx oxlint --rules to see the full list of currently supported rules. Coverage of ESLint's built-in rules is extensive and growing rapidly with each release."
  },
  {
    question: "Is oxlint stable enough for production CI?",
    answer: "Yes. oxlint has been adopted by large projects and is actively maintained by the Oxc team. It follows semantic versioning and the API is stable. The recommended approach is to start with the default rule set and incrementally enable stricter categories. Running it in CI as a fast pre-check alongside a slower ESLint pass is a common production pattern."
  },
  {
    question: "How do I integrate oxlint with CI/CD?",
    answer: "oxlint is a single binary with no configuration required to start. Add it as a dev dependency (npm add -D oxlint), add a lint script in package.json, and call it in your CI workflow. It exits with a non-zero code when lint errors are found, making it compatible with any CI system (GitHub Actions, GitLab CI, CircleCI, etc.). A minimal GitHub Actions step is just: run: npx oxlint ."
  },
];
---

<BaseLayout
  title="oxlint — Rust-Based JavaScript and TypeScript Linter (50–100x Faster Than ESLint)"
  description="oxlint is a blazing-fast JavaScript and TypeScript linter written in Rust. Part of the Oxc toolchain, it is 50–100x faster than ESLint with zero config to start, built-in fix support, and ESLint-compatible rules."
  tool="oxlint, javascript linter, typescript linter, rust linter, eslint alternative, oxc toolchain, fast linter"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "oxlint — Rust-Based JavaScript and TypeScript Linter",
    "url": "https://devplaybook.cc/tools/oxlint",
    "description": "oxlint is a Rust-based JavaScript and TypeScript linter that is 50–100x faster than ESLint, with zero config to start, ESLint-compatible rules, and built-in fix support.",
  })} />

  <h1 class="text-3xl font-bold mb-2">oxlint</h1>
  <p class="text-text-muted mb-6">
    A Rust-based JavaScript and TypeScript linter from the Oxc toolchain.
    50–100x faster than ESLint, zero configuration required to start,
    built-in auto-fix, and a growing set of ESLint-compatible rules.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 50–100x faster than ESLint</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Zero config to start</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Built-in --fix support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> JSX and TSX support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> ESLint-compatible rules</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Part of the Oxc toolchain</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is oxlint?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    oxlint is a JavaScript and TypeScript linter written in Rust, developed as part of the <strong>Oxc (JavaScript Oxidation Compiler)</strong> project. It was designed from the ground up to be extremely fast by leveraging Rust's memory safety and parallel processing capabilities. On large codebases oxlint consistently benchmarks 50–100x faster than ESLint, often completing in milliseconds rather than seconds.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    oxlint requires zero configuration to start — just point it at a directory and it immediately catches common correctness errors, suspicious patterns, and style issues. It supports JSX and TSX, has a built-in <code class="bg-bg-card px-1 rounded text-xs">--fix</code> flag, and is designed to be run alongside or as a replacement for ESLint as its rule coverage grows. The official documentation is at <a href="https://oxc.rs/docs/guide/usage/linter.html" class="underline hover:text-text" target="_blank" rel="noopener">oxc.rs</a>.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Written in Rust</strong> — delivers 50–100x speed improvements over ESLint; large monorepos lint in milliseconds</li>
    <li><strong>Zero config to start</strong> — run <code class="bg-bg-card px-1 rounded text-xs">npx oxlint .</code> with no config file required; sensible defaults out of the box</li>
    <li><strong>ESLint-compatible rules</strong> — covers a growing subset of ESLint core rules with the same names and semantics</li>
    <li><strong>Built-in fix support</strong> — <code class="bg-bg-card px-1 rounded text-xs">--fix</code> flag auto-corrects fixable issues without extra plugins</li>
    <li><strong>JSX and TSX support</strong> — understands React syntax and TypeScript generics natively</li>
    <li><strong>Rule categories</strong> — correctness, pedantic, suspicious, restriction, and nursery categories for granular control</li>
    <li><strong>Part of Oxc toolchain</strong> — integrates with oxc-parser, oxc-resolver, and other Oxc tools for a unified fast pipeline</li>
    <li><strong>Run alongside ESLint</strong> — no forced migration; use oxlint as a fast first pass and ESLint for plugin-specific rules</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Installation</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={installExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Adding to package.json Scripts</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    The simplest integration is to add lint scripts to your <code class="bg-bg-card px-1 rounded text-xs">package.json</code>. oxlint exits with a non-zero code on errors, making it immediately usable in CI.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={configExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">GitHub Actions CI Integration</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    oxlint fits naturally into any CI workflow. Below is a minimal GitHub Actions example that lints on every push and pull request.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={ciExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Migrating from ESLint</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    The recommended migration strategy is incremental: run oxlint alongside ESLint first, identify overlapping rules, then progressively reduce ESLint's scope. This is zero-risk and immediately speeds up your CI feedback loop.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={eslintMigrationExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">oxlint vs ESLint</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">oxlint</th>
          <th class="border border-border px-3 py-2 text-left">ESLint</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2">Speed</td><td class="border border-border px-3 py-2 text-green-400">50–100x faster (Rust)</td><td class="border border-border px-3 py-2">Slower (Node.js)</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Configuration required</td><td class="border border-border px-3 py-2 text-green-400">None to start</td><td class="border border-border px-3 py-2">Flat config or .eslintrc required</td></tr>
        <tr><td class="border border-border px-3 py-2">Plugin ecosystem</td><td class="border border-border px-3 py-2">Limited (growing)</td><td class="border border-border px-3 py-2 text-green-400">Thousands of plugins</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Rule coverage</td><td class="border border-border px-3 py-2">Core + growing</td><td class="border border-border px-3 py-2 text-green-400">Comprehensive</td></tr>
        <tr><td class="border border-border px-3 py-2">Built-in fix</td><td class="border border-border px-3 py-2 text-green-400">Yes (--fix)</td><td class="border border-border px-3 py-2 text-green-400">Yes (--fix)</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">JSX / TSX support</td><td class="border border-border px-3 py-2 text-green-400">Yes (native)</td><td class="border border-border px-3 py-2">Requires plugins</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pros and Cons</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-green-400 mb-2">Pros</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✓ Dramatically faster than ESLint — near-instant feedback on large codebases</li>
        <li>✓ Zero configuration required to start linting immediately</li>
        <li>✓ Native JSX and TypeScript support without extra plugins</li>
        <li>✓ Can run alongside ESLint — no forced migration required</li>
        <li>✓ Actively developed with rapid rule coverage expansion</li>
      </ul>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-red-400 mb-2">Cons</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✗ Plugin ecosystem is much smaller than ESLint's</li>
        <li>✗ Cannot yet replace ESLint for projects using many community plugins</li>
        <li>✗ Rule coverage, while growing, is not yet 100% ESLint-compatible</li>
        <li>✗ Fewer IDE extensions compared to ESLint's mature tooling</li>
        <li>✗ Still maturing — some APIs and config options may change</li>
      </ul>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="oxlint" relatedTags={['linting', 'rust', 'javascript', 'typescript', 'performance', 'ci-cd']} />
</BaseLayout>
