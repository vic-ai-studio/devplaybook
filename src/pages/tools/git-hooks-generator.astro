---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GitHooksGenerator from '../../components/GitHooksGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is Husky and why use it?",
    answer: "Husky is a Git hooks manager for Node.js projects. Git hooks are scripts that run automatically at specific points in the Git workflow (pre-commit, pre-push, commit-msg). Husky makes it easy to configure and share these hooks via package.json so every team member runs the same checks — no manual chmod or .git/ editing required."
  },
  {
    question: "What is lint-staged and how does it work with Husky?",
    answer: "lint-staged runs linters and formatters only on files staged for commit (git add). This is much faster than linting your entire project — if you have 1000 files but only changed 3, lint-staged only processes those 3. The typical setup: Husky pre-commit hook calls lint-staged, which runs ESLint and Prettier on staged .ts/.tsx files."
  },
  {
    question: "What's new in Husky v9 vs v8?",
    answer: "Husky v9 simplifies setup significantly. Instead of running 'husky install' in prepare, you just add 'prepare': 'husky' to package.json. Hook scripts are plain shell scripts (no special format required). The .husky/ folder structure is the same, but hooks no longer need to source /_/husky.sh in v9's simplified form. v9 also removes the need for HUSKY=0 to skip hooks temporarily."
  },
  {
    question: "How do I skip Husky hooks temporarily?",
    answer: "Use HUSKY=0 git commit -m 'message' to skip all hooks for one commit. For lint-staged specifically, use --no-verify: git commit --no-verify -m 'message'. Use this sparingly — the reason to have hooks is to catch issues early. A common legitimate use: emergency hotfixes where you need to push immediately and will clean up after."
  },
  {
    question: "How do I enforce Conventional Commits?",
    answer: "Install commitlint: npm install -D @commitlint/cli @commitlint/config-conventional. Create .commitlintrc.json: { \"extends\": [\"@commitlint/config-conventional\"] }. Add a commit-msg hook that runs: npx --no -- commitlint --edit $1. Conventional format: type(scope): description — types are feat, fix, docs, style, refactor, test, chore, perf, ci, build, revert."
  },
  {
    question: "Should I run tests in pre-commit or pre-push?",
    answer: "Run fast checks (linting, formatting, type-checking) in pre-commit — these complete in seconds and catch issues before you even commit. Run full test suites in pre-push — tests can take minutes and you don't want that delay on every commit. This gives you a good balance: frequent fast feedback on commit, comprehensive validation before sharing with the team."
  },
];
---

<BaseLayout
  title="Git Hooks Generator — Husky + lint-staged Config Builder"
  description="Generate Husky git hooks and lint-staged configuration visually. Configure pre-commit, pre-push, and commit-msg hooks with ESLint, Prettier, and tsc checks. Free, browser-based."
  tool="Husky Config Generator, lint-staged config, Git Hooks Generator, pre-commit hooks, husky v9 setup, commitlint"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Git Hooks Generator (Husky + lint-staged)",
    "url": "https://devplaybook.cc/tools/git-hooks-generator",
    "description": "Generate Husky git hooks and lint-staged config visually. Configure pre-commit, pre-push, commit-msg hooks with ESLint, Prettier, TypeScript checks. Supports Husky v8 and v9.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Git Hooks Generator</h1>
  <p class="text-text-muted mb-4">
    Generate <strong>Husky</strong> git hook scripts and <strong>lint-staged</strong> configuration visually.
    Configure pre-commit linting, pre-push tests, and commit message validation.
    Copy the output files and drop them into your project.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Husky v8 + v9 support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> lint-staged patterns</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> npm / yarn / pnpm / bun</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Conventional Commits setup</span>
  </div>
  <GitHooksGenerator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Git Hooks Generator" relatedTags={['git', 'linting', 'typescript', 'javascript', 'devops', 'development']} />
</BaseLayout>
