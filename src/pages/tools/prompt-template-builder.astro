---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PromptTemplateBuilder from '../../components/PromptTemplateBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Prompt Template Builder — Create Reusable AI Prompts"
  description="Build reusable prompt templates with {slot} variables. Fill in values, preview the final prompt, copy to clipboard, or export as JSON. Perfect for ChatGPT, Claude, and Gemini workflows."
  tool="Prompt Template Builder, AI Prompt Generator, Reusable Prompt Creator, ChatGPT Template"
>
  <h1 class="text-3xl font-bold mb-2">Prompt Template Builder</h1>
  <p class="text-text-muted mb-8">Create reusable AI prompt templates with <code class="text-primary bg-bg-card px-1 rounded text-sm">&#123;slot&#125;</code> variables. Fill in values, preview, and copy the finished prompt in one click.</p>
  <PromptTemplateBuilder client:load />
  <ToolPageCta currentTool="Prompt Template Builder" relatedTags={['ai', 'llm', 'openai', 'claude', 'prompts', 'templates']} />
</BaseLayout>
