---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FeatureEngineeringCalculator from '../../components/FeatureEngineeringCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a ColumnTransformer and why use it?",
    answer: "ColumnTransformer applies different preprocessing steps to different columns in a single, sklearn-compatible object. For example: StandardScaler on numeric columns, OneHotEncoder on categorical columns, and TfidfVectorizer on text columns — all in one pipeline step. This is the canonical sklearn approach because it prevents data leakage (fit only on training data, transform both train and test), integrates with cross-validation and GridSearchCV, and makes the full pipeline serializable with joblib.dump()."
  },
  {
    question: "When should I use StandardScaler vs MinMaxScaler vs RobustScaler?",
    answer: "StandardScaler (z-score normalization) works best for algorithms that assume Gaussian distributions like linear regression, logistic regression, and SVM. It's sensitive to outliers. MinMaxScaler scales to [0, 1] — good for neural networks and when you need bounded values, but extremely sensitive to outliers. RobustScaler uses median and IQR instead of mean/std — the best choice when your data has significant outliers (income, price, usage data). Tree-based models (Random Forest, XGBoost) don't require scaling at all."
  },
  {
    question: "What encoding should I use for categorical features?",
    answer: "OneHotEncoder creates a binary column per category — best for nominal categories (country, color) and linear models, but creates high-dimensional output for high-cardinality columns. OrdinalEncoder assigns integers 0,1,2... — works for ordered categories (education level, size: S/M/L/XL) and tree-based models. TargetEncoder replaces categories with the mean target value — powerful for high-cardinality features but requires careful cross-validation to avoid leakage. For very high cardinality (>100 categories), consider embedding or frequency encoding."
  },
  {
    question: "How do I handle datetime features in sklearn pipelines?",
    answer: "Datetime columns must be decomposed into numeric features before sklearn can use them. Extract components like year, month, day, dayofweek (0=Monday), hour, and quarter using .dt accessor. Cyclical features (month, hour, dayofweek) are better represented as sin/cos pairs to capture their circular nature: sin(2π × month/12), cos(2π × month/12). The FunctionTransformer in sklearn allows wrapping any pandas datetime extraction into a pipeline step. Always parse dates before splitting train/test to avoid type errors."
  },
];
---

<BaseLayout
  title="Feature Engineering Calculator — Generate sklearn ColumnTransformer Pipeline Code"
  description="Generate sklearn feature engineering pipeline code. Configure transformations for numeric, categorical, text, and datetime features. Get ColumnTransformer and Pipeline code instantly."
  tool="feature engineering calculator, sklearn pipeline, columntransformer, feature preprocessing, scikit-learn pipeline generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Feature Engineering Calculator",
    "url": "https://devplaybook.cc/tools/feature-engineering-calculator",
    "description": "Generate sklearn ColumnTransformer and Pipeline code for numeric, categorical, text, and datetime features. Configure scalers, encoders, and vectorizers visually.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Feature Engineering Calculator</h1>
  <p class="text-text-muted mb-4">
    Generate a complete <strong>sklearn ColumnTransformer + Pipeline</strong> for your features. Configure scalers, encoders, and vectorizers for numeric, categorical, text, and datetime columns — get production-ready code instantly.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 4 feature types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> ColumnTransformer code</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Full Pipeline output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-ready Python</span>
  </div>
  <FeatureEngineeringCalculator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Feature Engineering Calculator" relatedTags={['python', 'scikit-learn', 'machine-learning', 'feature-engineering', 'developer-tools']} />
</BaseLayout>
