---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PulumiStackConfigGenerator from '../../components/PulumiStackConfigGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a Pulumi stack and how does it differ from a project?",
    answer: "A Pulumi project defines your infrastructure program (the code). A stack is a separate deployment of that project — for example, dev, staging, and prod are three stacks of the same project. Each stack has its own state, resources, and configuration. This lets you reuse the same infrastructure code across environments while keeping config and secrets isolated per stack."
  },
  {
    question: "What is Pulumi.dev.yaml and where does it go?",
    answer: "Pulumi.&lt;stack&gt;.yaml (e.g. Pulumi.dev.yaml, Pulumi.prod.yaml) is the per-stack configuration file. It lives in your project root alongside Pulumi.yaml. It stores non-secret config values in plain text and secret values as encrypted ciphertext under a 'secure' key. You commit this file to source control — the encrypted secrets are safe to check in since only your stack's encryption key can decrypt them."
  },
  {
    question: "How does Pulumi encrypt secrets?",
    answer: "By default, Pulumi uses its managed backend (app.pulumi.com) to encrypt secrets using per-stack encryption keys with AES-256-GCM. The encrypted value is stored as 'secure: enc:v1:...' in your stack YAML. Alternatively, you can use a self-managed backend with a passphrase, AWS KMS, Azure Key Vault, or GCP KMS for encryption. The plaintext value never appears in source control."
  },
  {
    question: "What is the namespace:key config format?",
    answer: "Pulumi uses namespaced keys like 'aws:region' or 'myapp:instanceType' to avoid collisions between your app config and provider config. The part before ':' is the namespace — built-in providers use their name (aws, azure, gcp, kubernetes). For your own app config, use your project name or a short prefix. In code, you access it with: const config = new pulumi.Config('myapp'); config.require('instanceType')."
  },
  {
    question: "What is the difference between config.require() and config.requireSecret()?",
    answer: "config.require('key') retrieves a plain config value as a string and throws if the key is missing. config.requireSecret('key') retrieves a secret value and returns a pulumi.Output&lt;string&gt; — an encrypted output that Pulumi tracks through your program. You must use requireSecret for sensitive values so Pulumi knows to redact them from logs and diffs. Using require() on a secret-marked key will work but loses the encryption tracking."
  },
  {
    question: "Can I share config values across stacks?",
    answer: "Not directly via the config file — each Pulumi.&lt;stack&gt;.yaml is stack-specific. For shared values, use Pulumi ESC (Environments, Secrets, and Configuration), which lets you define config in reusable environment definitions and compose them into stacks. Alternatively, you can define defaults in your Pulumi program using config.get() with a fallback value, so stacks that don't override the config use the default."
  },
];
---

<BaseLayout
  title="Pulumi Stack Config Generator — Pulumi.stack.yaml Builder"
  description="Generate Pulumi stack configuration files (Pulumi.dev.yaml, Pulumi.prod.yaml) visually. Add config values, mark secrets, configure cloud providers. Get ready-to-use YAML and CLI commands. Free, runs in your browser."
  tool="pulumi stack config generator, Pulumi.yaml builder, pulumi config set, pulumi secrets, IaC config builder"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Pulumi Stack Config Generator",
    "description": "Generate Pulumi stack configuration files (Pulumi.dev.yaml, Pulumi.prod.yaml) with config values, secrets, and cloud provider settings. Free browser tool.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "url": "https://devplaybook.cc/tools/pulumi-stack-config-generator"
  })} />

  <h1 class="text-3xl font-bold mb-2">Pulumi Stack Config Generator</h1>
  <p class="text-text-muted mb-6">
    Build <code class="font-mono bg-surface px-1 rounded text-sm">Pulumi.&lt;stack&gt;.yaml</code> configuration files visually.
    Configure cloud providers, add key-value pairs, and mark secrets for encryption.
    Get both the ready-to-commit YAML and the equivalent <code class="font-mono bg-surface px-1 rounded text-sm">pulumi config set</code> CLI commands.
  </p>

  <div class="flex flex-wrap gap-2 mb-8">
    <span class="inline-flex items-center gap-1.5 bg-surface border border-border text-text-muted text-xs px-3 py-1 rounded-full">
      <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>
      AWS / Azure / GCP
    </span>
    <span class="inline-flex items-center gap-1.5 bg-surface border border-border text-text-muted text-xs px-3 py-1 rounded-full">
      <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
      Secret encryption
    </span>
    <span class="inline-flex items-center gap-1.5 bg-surface border border-border text-text-muted text-xs px-3 py-1 rounded-full">
      <span class="w-1.5 h-1.5 rounded-full bg-blue-400"></span>
      dev / staging / prod stacks
    </span>
    <span class="inline-flex items-center gap-1.5 bg-surface border border-border text-text-muted text-xs px-3 py-1 rounded-full">
      <span class="w-1.5 h-1.5 rounded-full bg-purple-400"></span>
      CLI commands included
    </span>
  </div>

  <PulumiStackConfigGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Pulumi Stack Config Generator" relatedTags={['pulumi', 'iac', 'devops', 'infrastructure', 'cloud', 'developer-tools']} />
</BaseLayout>
