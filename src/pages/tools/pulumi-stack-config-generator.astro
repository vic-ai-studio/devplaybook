---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Pulumi?", answer: "Pulumi is an Infrastructure as Code (IaC) tool that lets you define cloud infrastructure using real programming languages (TypeScript, Python, Go, C#). Unlike Terraform's HCL DSL, Pulumi code runs in a real runtime — you can use loops, functions, and packages. It supports AWS, Azure, GCP, Kubernetes, and 100+ providers." },
  { question: "What is a Pulumi stack?", answer: "A stack is an isolated, independently deployable instance of your Pulumi program. Typically you have dev, staging, and prod stacks. Each stack has its own configuration values and state. `pulumi stack` manages stack selection; `pulumi config set` manages per-stack configuration. Stack configs are stored in Pulumi.<stack>.yaml files." },
  { question: "How does Pulumi config work?", answer: "Configuration values are set per-stack and accessed via `const config = new pulumi.Config()`. Values can be plain strings, secrets (encrypted), or structured JSON. Secrets are encrypted using the stack's encryption provider (Pulumi Cloud, AWS KMS, GCP KMS, or passphrase). Never store secrets in plaintext config — use `pulumi config set --secret`." },
  { question: "What is the difference between Pulumi and Terraform?", answer: "Key differences: Pulumi uses real languages (TypeScript/Python/Go) vs Terraform's HCL. Pulumi supports all language features (loops, functions, abstractions) natively. Terraform has a larger community and more provider examples. Both use a state file for drift detection. Pulumi has better type safety and IDE support. Terraform is more portable for teams with non-developers." },
  { question: "How do I migrate from Terraform to Pulumi?", answer: "Use `pulumi convert --from terraform` to convert .tf files to Pulumi TypeScript/Python automatically. The converter handles most resources but may need manual fixes for complex configurations. Pulumi can also import existing Terraform state with `pulumi import`. Run both in parallel during migration for safety." },
];
---

<BaseLayout
  title="Pulumi Stack Config Generator — IaC TypeScript & Python Config Builder"
  description="Generate Pulumi stack configuration files and TypeScript/Python code. Create Pulumi.yaml, stack config files, resource definitions, and config access patterns for AWS, Azure, and GCP."
  tool="Pulumi Stack Config Generator, Pulumi TypeScript IaC Builder, Pulumi Python Config Generator, Pulumi Stack YAML, Infrastructure as Code Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Pulumi Stack Config Generator</h1>
  <p class="text-text-muted mb-4">Generate Pulumi stack configuration files and infrastructure code. Build Pulumi.yaml, stack configs, and TypeScript/Python resource definitions from form inputs.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Pulumi.yaml generator</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Stack config files</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript + Python output</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <!-- Left: Config inputs -->
    <div class="space-y-4">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Project Configuration</h2>
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium mb-1">Project Name</label>
            <input id="proj-name" type="text" value="my-infra"
              class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Description</label>
            <input id="proj-desc" type="text" value="Cloud infrastructure stack"
              class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium mb-1">Language</label>
              <select id="proj-lang" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
                <option value="typescript">TypeScript</option>
                <option value="python">Python</option>
                <option value="go">Go</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Cloud Provider</label>
              <select id="proj-provider" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
                <option value="aws">AWS</option>
                <option value="azure">Azure</option>
                <option value="gcp">GCP</option>
                <option value="kubernetes">Kubernetes</option>
              </select>
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Stack Name</label>
            <input id="stack-name" type="text" value="dev"
              class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
          </div>
        </div>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-base font-semibold">Config Values</h2>
          <button id="add-config" class="text-xs px-3 py-1.5 border border-border text-text-muted rounded-lg hover:border-primary hover:text-primary transition-all">+ Add</button>
        </div>
        <div id="config-list" class="space-y-2"></div>
      </div>
    </div>

    <!-- Right: Generated code -->
    <div class="space-y-4">
      <div class="flex gap-2">
        <button class="pulumi-tab active text-xs px-3 py-1.5 bg-primary text-white rounded-lg" data-tab="yaml">Pulumi.yaml</button>
        <button class="pulumi-tab text-xs px-3 py-1.5 border border-border text-text-muted rounded-lg hover:border-primary" data-tab="stack">Stack Config</button>
        <button class="pulumi-tab text-xs px-3 py-1.5 border border-border text-text-muted rounded-lg hover:border-primary" data-tab="code">Program Code</button>
      </div>
      <div class="relative">
        <button id="copy-pulumi" class="absolute top-3 right-3 text-xs px-2 py-1 bg-bg-card border border-border rounded hover:border-primary text-text-muted z-10">Copy</button>
        <pre id="pulumi-output" class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre-wrap min-h-[400px] max-h-[600px] overflow-y-auto"></pre>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Pulumi Stack Config Generator" relatedTags={['pulumi', 'iac', 'devops', 'aws', 'infrastructure', 'typescript']} />
</BaseLayout>

<script>
  interface ConfigVal { id: string; key: string; value: string; secret: boolean }

  let configVals: ConfigVal[] = [
    { id: '1', key: 'aws:region', value: 'us-east-1', secret: false },
    { id: '2', key: 'instanceType', value: 't3.micro', secret: false },
    { id: '3', key: 'dbPassword', value: 'changeme123', secret: true },
  ];
  let activeTab = 'yaml';

  function getVal(id: string): string {
    return (document.getElementById(id) as HTMLInputElement | HTMLSelectElement)?.value || '';
  }

  function renderConfigList() {
    const list = document.getElementById('config-list')!;
    list.innerHTML = configVals.map(c => `
      <div class="config-row flex items-center gap-2" data-id="${c.id}">
        <input type="text" value="${c.key}" class="conf-key flex-1 bg-bg-card border border-border rounded px-2 py-1.5 text-xs focus:outline-none focus:border-primary font-mono" />
        <input type="text" value="${c.value}" class="conf-val flex-1 bg-bg-card border border-border rounded px-2 py-1.5 text-xs focus:outline-none focus:border-primary ${c.secret ? 'text-yellow-500' : ''}" />
        <label class="flex items-center gap-1 text-xs cursor-pointer flex-shrink-0">
          <input type="checkbox" class="conf-secret" ${c.secret ? 'checked' : ''} /> <span class="text-text-muted">Secret</span>
        </label>
        <button class="remove-conf text-xs text-red-400">✕</button>
      </div>
    `).join('');

    list.querySelectorAll('.config-row').forEach(row => {
      const id = row.getAttribute('data-id')!;
      const conf = configVals.find(c => c.id === id)!;
      row.querySelector('.conf-key')!.addEventListener('input', (e) => { conf.key = (e.target as HTMLInputElement).value; updateOutput(); });
      row.querySelector('.conf-val')!.addEventListener('input', (e) => { conf.value = (e.target as HTMLInputElement).value; updateOutput(); });
      row.querySelector('.conf-secret')!.addEventListener('change', (e) => { conf.secret = (e.target as HTMLInputElement).checked; renderConfigList(); updateOutput(); });
      row.querySelector('.remove-conf')!.addEventListener('click', () => { configVals = configVals.filter(c => c.id !== id); renderConfigList(); updateOutput(); });
    });
  }

  function updateOutput() {
    const projName = getVal('proj-name');
    const projDesc = getVal('proj-desc');
    const lang = getVal('proj-lang');
    const provider = getVal('proj-provider');
    const stackName = getVal('stack-name');
    let output = '';

    if (activeTab === 'yaml') {
      const runtimeMap: Record<string, string> = { typescript: 'nodejs', python: 'python', go: 'go' };
      output = `name: ${projName}
runtime: ${runtimeMap[lang]}
description: ${projDesc}
config:
  pulumi:tags:
    value:
      project: ${projName}
      managedBy: pulumi
`;
    } else if (activeTab === 'stack') {
      const configLines = configVals.map(c =>
        c.secret
          ? `  ${projName}:${c.key}:\n    secure: [encrypted]  # set with: pulumi config set --secret ${c.key}`
          : `  ${projName}:${c.key}: ${c.value}`
      ).join('\n');
      output = `# Pulumi.${stackName}.yaml
config:
${configLines || '  # No config values'}

# Apply with:
# pulumi stack select ${stackName}
${configVals.map(c => `# pulumi config set${c.secret ? ' --secret' : ''} ${c.key} "${c.value}"`).join('\n')}
# pulumi up`;
    } else {
      if (lang === 'typescript') {
        const importLine = provider === 'aws' ? `import * as aws from "@pulumi/aws";`
          : provider === 'gcp' ? `import * as gcp from "@pulumi/gcp";`
          : provider === 'azure' ? `import * as azure from "@pulumi/azure-native";`
          : `import * as k8s from "@pulumi/kubernetes";`;

        const configAccess = configVals.map(c => {
          const varName = (c.key.includes(':') ? c.key.split(':')[1] : c.key).replace(/-/g, '_');
          return `const ${varName} = config.${c.secret ? 'requireSecret' : 'require'}("${c.key.includes(':') ? c.key.split(':')[1] : c.key}");`;
        }).join('\n');

        output = `import * as pulumi from "@pulumi/pulumi";
${importLine}

const config = new pulumi.Config();
${configAccess ? '\n// Config values\n' + configAccess : ''}

// Stack: ${stackName}
// Project: ${projName}
${provider === 'aws' ? `\nconst bucket = new aws.s3.BucketV2("${projName}-bucket", {
  tags: {
    Environment: pulumi.getStack(),
    Project: pulumi.getProject(),
  },
});

export const bucketName = bucket.id;
export const bucketArn = bucket.arn;` : `\n// Add ${provider} resources here`}`;
      } else if (lang === 'python') {
        const configAccess = configVals.map(c => {
          const varName = (c.key.includes(':') ? c.key.split(':')[1] : c.key).toLowerCase().replace(/-/g, '_');
          return `${varName} = config.${c.secret ? 'require_secret' : 'require'}("${c.key.includes(':') ? c.key.split(':')[1] : c.key}")`;
        }).join('\n');

        output = `import pulumi
${provider === 'aws' ? 'import pulumi_aws as aws' : provider === 'gcp' ? 'import pulumi_gcp as gcp' : ''}

config = pulumi.Config()
${configAccess ? '\n# Config values\n' + configAccess : ''}

# Stack: ${stackName}
${provider === 'aws' ? `\nbucket = aws.s3.BucketV2("${projName}-bucket",
    tags={"Environment": pulumi.get_stack(), "Project": pulumi.get_project()}
)

pulumi.export("bucket_name", bucket.id)` : `\n# Add ${provider} resources here`}`;
      } else {
        output = `// Go Pulumi — ${projName} (${stackName})
// pulumi new go && pulumi up`;
      }
    }

    document.getElementById('pulumi-output')!.textContent = output;
  }

  document.getElementById('add-config')!.addEventListener('click', () => {
    configVals.push({ id: Date.now().toString(), key: 'newKey', value: 'value', secret: false });
    renderConfigList(); updateOutput();
  });

  document.querySelectorAll('.pulumi-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      activeTab = btn.getAttribute('data-tab')!;
      document.querySelectorAll('.pulumi-tab').forEach(b => {
        b.classList.remove('bg-primary','text-white'); b.classList.add('border','border-border','text-text-muted');
      });
      btn.classList.add('bg-primary','text-white'); btn.classList.remove('border','border-border','text-text-muted');
      updateOutput();
    });
  });

  document.getElementById('copy-pulumi')!.addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('pulumi-output')!.textContent || '');
    const btn = document.getElementById('copy-pulumi')!; btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = 'Copy', 2000);
  });

  ['proj-name','proj-desc','proj-lang','proj-provider','stack-name'].forEach(id => {
    const el = document.getElementById(id)!;
    el.addEventListener('input', updateOutput); el.addEventListener('change', updateOutput);
  });

  renderConfigList(); updateOutput();
</script>
