---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PackageJsonValidator from '../../components/PackageJsonValidator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="package.json Validator & Audit — Free Online Tool"
  description="Paste your package.json to validate syntax, detect issues, and get an audit score. Checks required fields, bad version ranges, misplaced dependencies, and missing best practices."
  tool="package.json validator, npm audit, package.json checker, node package validator"
>
  <h1 class="text-3xl font-bold mb-2">package.json Validator & Audit</h1>
  <p class="text-text-muted mb-8">Paste your <code>package.json</code> to validate its structure and get an audit score. Detects wildcard versions, missing required fields, misplaced dependencies, and more — all in your browser.</p>
  <PackageJsonValidator client:only="preact" />
  <ToolPageCta currentTool="package.json Validator" relatedTags={['npm', 'node', 'package', 'json', 'devops']} />
</BaseLayout>
