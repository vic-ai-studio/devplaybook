---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonPathTester from '../../components/JsonPathTester.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is JSONPath and when should I use it?",
    answer: "JSONPath is a query language for JSON, similar to XPath for XML. You use it to extract specific values from nested JSON structures — for example, pulling all order IDs from an array of orders, or grabbing every email address nested under customer objects. It is widely used in REST API testing tools like Postman, AWS Step Functions, Kubernetes manifests, and monitoring configurations."
  },
  {
    question: "How does the $ symbol work in JSONPath?",
    answer: "The $ symbol always refers to the root of your JSON document. Every JSONPath expression should start with $. From there you use dot notation ($.store.name) to navigate object keys, bracket notation ($.orders[0]) to access array elements, and wildcards ($.orders[*]) to match all items in an array or all values in an object."
  },
  {
    question: "What is the difference between $.key and $..key?",
    answer: "$.key navigates directly to a property at one specific level of the JSON tree. $..key uses recursive descent, meaning it searches at every depth — it will find 'name' whether it is at the top level, inside an array, or nested five levels deep. Use .. when you want to extract a field without knowing exactly how deeply it is nested."
  },
  {
    question: "How do I select all items in a JSON array?",
    answer: "Use the wildcard operator: $.orders[*] selects every element in the orders array. You can chain this with further selectors — for example $.orders[*].id returns the id property from every order object in the array. To select a specific index use $.orders[0] for the first, $.orders[-1] for the last."
  },
  {
    question: "Can I filter JSONPath results by a condition?",
    answer: "Yes, using filter expressions: $.orders[?(@.price > 100)] selects all orders where price is greater than 100. The @ symbol refers to the current element being tested. You can use comparison operators (>, <, ==, !=), logical operators (&&, ||), and string matching to build precise filters."
  },
  {
    question: "Is this tool safe to use with sensitive data?",
    answer: "Yes. The JSONPath Tester runs entirely in your browser using JavaScript. No data is transmitted to any server. Your JSON payload — including API responses, config files, and any sensitive values — never leaves your machine. It is safe to paste production API responses for debugging."
  },
];
---

<BaseLayout
  title="JSONPath Tester — Test JSONPath Expressions Online Free"
  description="Test JSONPath expressions against JSON data in real time. Paste JSON and a JSONPath expression to see matched values, paths, and types instantly. Supports $, ., .., [*], filter expressions, and recursive descent. Free, runs 100% in your browser."
  tool="JSONPath Tester, JSON Path Query, JSONPath Evaluator, JSONPath Expression Tester, JSON Query Online"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">JSONPath Tester</h1>
  <p class="text-text-muted mb-4">
    Paste any JSON and write a JSONPath expression to see matching values in real time. Supports dot notation (<code class="font-mono text-sm">$.store.name</code>), array indexing (<code class="font-mono text-sm">$.orders[0]</code>), wildcards (<code class="font-mono text-sm">$.items[*]</code>), recursive descent (<code class="font-mono text-sm">$..price</code>), and filter expressions. Runs entirely in your browser — no data sent anywhere.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <JsonPathTester client:only="preact" />
  <!-- Ad slot below tool output — highest CTR position (user pauses after using the tool) -->
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="JSONPath Tester" relatedTags={['json', 'api', 'development', 'testing', 'jsonpath']} />
</BaseLayout>
