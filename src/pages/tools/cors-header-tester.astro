---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CorsTester from '../../components/CorsTester.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is CORS and why does it matter?",
    answer: "CORS (Cross-Origin Resource Sharing) is a browser security mechanism that restricts JavaScript from making requests to a different origin (domain, protocol, or port) than the page it loaded from. Servers must explicitly opt in by returning Access-Control-Allow-Origin and related headers. If they don't, the browser blocks the response — even if the server processed the request successfully."
  },
  {
    question: "What is a preflight request?",
    answer: "Before sending certain cross-origin requests (non-simple methods like PUT/DELETE, or custom headers), the browser sends an OPTIONS preflight request to ask the server if the actual request is allowed. The server must respond with appropriate Access-Control headers. If the preflight fails or returns wrong headers, the browser blocks the real request. GET and POST with standard content types are usually simple requests that don't trigger preflights."
  },
  {
    question: "Why do I get CORS errors even when the server returns 200?",
    answer: "CORS errors happen on the browser side — the server may have processed the request and returned 200, but if the response is missing Access-Control-Allow-Origin (or it doesn't match your origin), the browser blocks JavaScript from reading the response. The network tab shows 200, but your code gets a CORS error. The fix is always on the server side: add the correct CORS headers."
  },
  {
    question: "What's the difference between Access-Control-Allow-Origin: * and a specific origin?",
    answer: "Wildcard (*) allows any origin to read the response — fine for public APIs with no authentication. A specific origin (e.g. https://yourapp.com) restricts access to that domain. You cannot use * with Access-Control-Allow-Credentials: true — if you need cookies or auth headers in cross-origin requests, you must specify the exact origin and set Vary: Origin in the response."
  },
  {
    question: "How do I fix CORS in a Node.js / Express API?",
    answer: "Install the 'cors' npm package and add it as middleware: `app.use(cors({ origin: 'https://yourapp.com', credentials: true }))`. For development, you can use `origin: true` to mirror the request origin. Never use `origin: '*'` with credentials. Always whitelist specific origins in production."
  },
  {
    question: "Can I fix CORS from the frontend?",
    answer: "No — CORS headers must be set by the server. Frontend workarounds include: using a proxy (Nginx, Next.js rewrites, or a CORS proxy service) that forwards requests and adds headers, or configuring your dev server to proxy requests. In production, the correct fix is always to configure the target server or API to return the right Access-Control headers."
  },
];
---

<BaseLayout
  title="CORS Header Tester — Test Cross-Origin Request Headers Instantly"
  description="Test CORS headers for any URL. Send real cross-origin requests from your browser, analyze Access-Control headers, simulate preflight OPTIONS requests, and diagnose why requests are blocked."
  tool="CORS Header Tester, CORS Checker, Cross-Origin Request Debugger, Access-Control Headers"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "CORS Header Tester",
    "url": "https://devplaybook.cc/tools/cors-header-tester",
    "description": "Test CORS headers for any URL. Analyze Access-Control response headers, simulate preflight requests, and diagnose cross-origin request issues instantly.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">CORS Header Tester</h1>
  <p class="text-text-muted mb-4">
    Send real cross-origin requests from your browser, inspect <code class="font-mono bg-surface px-1 rounded text-sm">Access-Control</code> response headers,
    and diagnose preflight failures. Find out exactly why a request is blocked — and what headers to add to fix it.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Real browser requests</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Preflight simulation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Header analysis & issues</span>
  </div>
  <CorsTester client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <AffiliateSection category="deployment" />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Need to inspect HTTP response headers in detail?</p>
    <a href="/tools/http-headers-inspector" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">HTTP Headers Inspector →</a>
  </div>
  <ToolPageCta currentTool="CORS Header Tester" relatedTags={['cors', 'api', 'http', 'security', 'web', 'headers']} />
</BaseLayout>
