---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const installExample = `# Install globally
npm install -g autocannon

# Or add to a project as a dev dependency
npm install --save-dev autocannon

# Verify installation
autocannon --version`;

const cliExample = `# Benchmark a GET endpoint for 10 seconds with 10 connections
autocannon -c 10 -d 10 http://localhost:3000/api/users

# POST with JSON body and custom header
autocannon -c 20 -d 30 \\
  -m POST \\
  -H "Content-Type: application/json" \\
  -b '{"name":"test","email":"test@example.com"}' \\
  http://localhost:3000/api/users

# 100 connections, 1000 total requests (instead of duration)
autocannon -c 100 -a 1000 http://localhost:3000/

# Enable HTTP pipelining (4 requests per connection)
autocannon -c 10 -p 4 -d 10 http://localhost:3000/

# Output results as JSON (useful for CI pipelines)
autocannon -c 10 -d 5 --json http://localhost:3000/ > results.json

# Benchmark with a custom Authorization header
autocannon -c 50 -d 20 \\
  -H "Authorization: Bearer <token>" \\
  https://api.example.com/protected`;

const programmaticExample = `// benchmark.js — programmatic API
const autocannon = require('autocannon');

async function run() {
  const result = await autocannon({
    url: 'http://localhost:3000/api/items',
    connections: 20,       // concurrent connections
    pipelining: 1,         // HTTP pipelining factor
    duration: 10,          // seconds
    method: 'GET',
    headers: {
      'accept': 'application/json',
    },
  });

  // result contains full latency/throughput statistics
  console.log('Requests/sec:', result.requests.average);
  console.log('Throughput:  ', result.throughput.average, 'bytes/sec');
  console.log('Latency p50: ', result.latency.p50, 'ms');
  console.log('Latency p99: ', result.latency.p99, 'ms');
  console.log('Errors:      ', result.errors);
}

run();`;

const ciExample = `// ci-benchmark.js — fail the build if p99 latency exceeds threshold
const autocannon = require('autocannon');

async function benchmark() {
  const result = await autocannon({
    url: process.env.TARGET_URL || 'http://localhost:3000/',
    connections: 10,
    duration: 10,
  });

  const p99 = result.latency.p99;
  const rps  = result.requests.average;

  console.log(\`p99 latency: \${p99}ms | RPS: \${rps}\`);

  if (p99 > 200) {
    console.error(\`FAIL: p99 \${p99}ms exceeds 200ms threshold\`);
    process.exit(1);
  }

  console.log('PASS: performance within acceptable thresholds');
}

benchmark();`;

const faq = [
  {
    question: "What is autocannon?",
    answer: "autocannon is a fast HTTP/1.1 benchmarking tool written in Node.js by Matteo Collina, one of the Node.js core contributors. It uses uWebSockets under the hood to generate high-throughput load against HTTP and HTTPS endpoints. It reports latency percentiles (p50, p90, p99, p99.9), requests per second, throughput in bytes per second, and error counts. It works both as a CLI tool and as a Node.js programmatic API, making it easy to embed in scripts and CI pipelines."
  },
  {
    question: "How does autocannon compare to wrk and ab (ApacheBench)?",
    answer: "wrk is a C-based tool that produces very low overhead and high request rates, making it ideal for raw maximum throughput tests. ab (ApacheBench) is the oldest of the three and the simplest but lacks modern features like percentile histograms. autocannon sits between them: it runs on Node.js (so it is easy to install anywhere Node is available), supports a programmatic API for embedding in test suites, and outputs detailed latency percentiles. For pure raw numbers wrk may edge out autocannon, but autocannon is far easier to integrate into JavaScript/Node.js projects and CI workflows."
  },
  {
    question: "How do I benchmark a POST endpoint with a JSON body?",
    answer: "Use the -m POST flag to set the HTTP method, -H to add a Content-Type header, and -b to supply the request body. For example: autocannon -c 10 -d 10 -m POST -H \"Content-Type: application/json\" -b '{\"key\":\"value\"}' http://localhost:3000/api. In the programmatic API, pass method, headers, and body fields to the options object passed to autocannon()."
  },
  {
    question: "What metrics does autocannon report?",
    answer: "autocannon reports: latency statistics (mean, standard deviation, min, max, and percentiles p2.5, p50, p75, p90, p97.5, p99, p99.9, p99.99), requests per second (mean, standard deviation, min, max, total), throughput in bytes per second (mean, standard deviation, min, max, total), total requests sent, total bytes received, connection errors, timeout errors, and non-2xx response counts. All percentile data comes from HDR histograms for accuracy at high sample counts."
  },
  {
    question: "Can autocannon be used programmatically in Node.js tests?",
    answer: "Yes — that is one of autocannon's key strengths over CLI-only tools. Install it as a dev dependency and require or import it in your test or benchmark script. The autocannon() function accepts a configuration object and returns a Promise that resolves with the full results object. You can then assert on result.latency.p99 or result.requests.average to fail a CI build if performance regresses. This makes it straightforward to add automated performance gates alongside your unit and integration tests."
  },
  {
    question: "What is HTTP pipelining and how does autocannon support it?",
    answer: "HTTP pipelining allows multiple requests to be sent on the same TCP connection without waiting for each response before sending the next. This can increase throughput significantly for servers that support it. autocannon enables pipelining via the -p flag on the CLI (e.g., -p 4 sends 4 requests per connection without waiting) or the pipelining option in the programmatic API. Note that HTTP/1.1 pipelining is not universally supported or beneficial — most modern servers and proxies disable it in favor of HTTP/2 multiplexing, so test with and without to compare results."
  },
];
---

<BaseLayout
  title="autocannon — Fast HTTP Benchmarking Tool for Node.js"
  description="autocannon is a fast HTTP/1.1 benchmarking tool written in Node.js. Measure latency percentiles, requests per second, and throughput with a CLI or programmatic Node.js API."
  tool="autocannon, http benchmarking, load testing, nodejs performance, latency, requests per second, throughput, cli"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "autocannon — Fast HTTP Benchmarking Tool for Node.js",
    "url": "https://devplaybook.cc/tools/autocannon",
    "description": "autocannon is a fast HTTP/1.1 benchmarking tool written in Node.js. Measure latency percentiles, requests per second, and throughput via CLI or programmatic API.",
  })} />

  <h1 class="text-3xl font-bold mb-2">autocannon</h1>
  <p class="text-text-muted mb-6">
    Ultra-fast HTTP/1.1 benchmarking tool built for Node.js. Powered by uWebSockets, it measures
    latency percentiles (p50, p90, p99), requests per second, and throughput — from the CLI or
    embedded directly in your Node.js scripts and CI pipelines.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> HTTP &amp; HTTPS</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Latency percentiles</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Programmatic API</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> HTTP pipelining</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> JSON output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CI-friendly</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is autocannon?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    autocannon is an open-source HTTP benchmarking tool written entirely in Node.js by Matteo Collina, a Node.js core contributor. It uses <a href="https://github.com/uNetworking/uWebSockets" class="text-blue-400 hover:underline" target="_blank" rel="noopener noreferrer">uWebSockets</a> to generate high-throughput load against HTTP/1.1 and HTTPS endpoints, making it significantly faster than tools implemented in pure JavaScript.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    Unlike heavier load-testing platforms, autocannon focuses on raw HTTP performance measurement: how fast does your server respond, what are the tail latencies, how many requests per second can it sustain? It works as a command-line tool for quick benchmarks and as a Node.js module for embedding performance gates in automated test suites and CI pipelines.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Ultra-fast engine</strong> — built on uWebSockets for maximum request throughput from a single Node.js process</li>
    <li><strong>Configurable load</strong> — set concurrent connections, pipelining factor, duration, or total request count</li>
    <li><strong>Latency percentiles</strong> — reports p50, p75, p90, p97.5, p99, p99.9, p99.99 via HDR histograms</li>
    <li><strong>HTTP &amp; HTTPS</strong> — benchmarks both plain HTTP and TLS-secured HTTPS endpoints</li>
    <li><strong>Programmatic API</strong> — use <code class="bg-bg-card px-1 rounded text-xs">autocannon()</code> in Node.js scripts, tests, and CI jobs</li>
    <li><strong>POST / custom methods</strong> — set method, headers, and body for any HTTP verb</li>
    <li><strong>HTTP pipelining</strong> — send multiple requests per connection without waiting for responses</li>
    <li><strong>JSON output</strong> — machine-readable results for dashboards and performance regression tracking</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Installation</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={installExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">CLI Usage</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    The CLI covers most benchmarking scenarios: set <code class="bg-bg-card px-1 rounded text-xs">-c</code> for connections,
    <code class="bg-bg-card px-1 rounded text-xs">-d</code> for duration in seconds, <code class="bg-bg-card px-1 rounded text-xs">-m</code> for HTTP method,
    <code class="bg-bg-card px-1 rounded text-xs">-H</code> for headers, and <code class="bg-bg-card px-1 rounded text-xs">-b</code> for a request body.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={cliExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Programmatic API</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Import autocannon as a Node.js module to run benchmarks from scripts, Mocha/Jest test files, or custom tooling. The returned Promise resolves with a structured results object containing all latency, throughput, and error statistics.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={programmaticExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">CI Performance Gates</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Combine the programmatic API with <code class="bg-bg-card px-1 rounded text-xs">process.exit(1)</code> to fail a CI build when latency or throughput regresses past defined thresholds. Run this script after deploying to a staging environment to catch performance regressions before they reach production.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={ciExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">autocannon vs wrk vs ab</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">autocannon</th>
          <th class="border border-border px-3 py-2 text-left">wrk</th>
          <th class="border border-border px-3 py-2 text-left">ab (ApacheBench)</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2">Language</td><td class="border border-border px-3 py-2 text-green-400">Node.js</td><td class="border border-border px-3 py-2">C</td><td class="border border-border px-3 py-2">C</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Programmatic API</td><td class="border border-border px-3 py-2 text-green-400">Yes (Node.js)</td><td class="border border-border px-3 py-2">Lua scripts only</td><td class="border border-border px-3 py-2">No</td></tr>
        <tr><td class="border border-border px-3 py-2">Latency percentiles</td><td class="border border-border px-3 py-2 text-green-400">Yes (HDR histogram)</td><td class="border border-border px-3 py-2">Yes</td><td class="border border-border px-3 py-2">Limited</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">HTTP pipelining</td><td class="border border-border px-3 py-2 text-green-400">Yes</td><td class="border border-border px-3 py-2">No</td><td class="border border-border px-3 py-2">No</td></tr>
        <tr><td class="border border-border px-3 py-2">JSON output</td><td class="border border-border px-3 py-2 text-green-400">Yes</td><td class="border border-border px-3 py-2">No</td><td class="border border-border px-3 py-2">Partial</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Install (Node environment)</td><td class="border border-border px-3 py-2 text-green-400">npm install -g autocannon</td><td class="border border-border px-3 py-2">Compile from source</td><td class="border border-border px-3 py-2">System package manager</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pros and Cons</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-green-400 mb-2">Pros</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✓ npm install — zero native dependencies, works anywhere Node runs</li>
        <li>✓ Programmatic API fits naturally into Node.js CI scripts</li>
        <li>✓ Accurate HDR histogram latency percentiles up to p99.99</li>
        <li>✓ HTTP pipelining support for testing pipeline-capable servers</li>
        <li>✓ JSON output for storing and comparing benchmark history</li>
      </ul>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-red-400 mb-2">Cons</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✗ HTTP/1.1 only — no HTTP/2 or HTTP/3 support</li>
        <li>✗ Node.js runtime adds slight overhead vs pure C tools like wrk</li>
        <li>✗ No built-in scenario scripting (multiple URLs, ramp-up phases)</li>
        <li>✗ Single-machine load generation; no distributed test coordination</li>
        <li>✗ Not designed for long-soak or multi-step user journey tests</li>
      </ul>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="autocannon" relatedTags={['benchmarking', 'http', 'performance', 'nodejs', 'cli']} />
</BaseLayout>
