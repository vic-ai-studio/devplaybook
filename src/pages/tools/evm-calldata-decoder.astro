---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is EVM calldata?", answer: "Calldata is the input data sent with an Ethereum transaction when calling a smart contract function. It's ABI-encoded: the first 4 bytes are the function selector (keccak256 hash of the function signature, first 4 bytes), followed by the ABI-encoded arguments. Understanding calldata is essential for debugging transactions and building EVM tooling." },
  { question: "What is a function selector?", answer: "A function selector is the first 4 bytes of the keccak256 hash of the function signature. For `transfer(address,uint256)`, the selector is `0xa9059cbb`. Ethereum uses selectors to route calls to the correct function in a contract. You can look up known selectors at 4byte.directory." },
  { question: "How is calldata ABI-encoded?", answer: "After the 4-byte selector, arguments are ABI-encoded as 32-byte slots. Static types (uint256, address, bool, bytes32) are right-padded or left-padded to 32 bytes. Dynamic types (string, bytes, arrays) have an offset pointer in the static section pointing to the dynamic data location. Addresses are 20 bytes left-padded to 32 bytes." },
  { question: "Why would calldata be 'raw' without a function selector?", answer: "Raw calldata without a selector appears in: fallback function calls, Ethereum transfer (empty calldata), some proxy patterns, and direct contract construction. In these cases, decode from offset 0 rather than offset 4." },
  { question: "How do I decode a failed transaction's calldata?", answer: "Get the transaction's `input` field from a block explorer (Etherscan, Basescan). Paste it here or use `cast calldata-decode` from Foundry. Knowing the function signature (from the contract ABI or 4byte.directory) is required for full decoding. The 4-byte selector alone tells you which function was called." },
];
---

<BaseLayout
  title="EVM Calldata Decoder — Ethereum Transaction Input ABI Decoder"
  description="Decode Ethereum EVM calldata from raw hex. Parse function selectors, decode ABI-encoded arguments for uint256/address/bytes/string types, and analyze transaction input data."
  tool="EVM Calldata Decoder, Ethereum ABI Decoder, Transaction Input Parser, Function Selector Lookup, Solidity ABI Encode Decode"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">EVM Calldata Decoder</h1>
  <p class="text-text-muted mb-4">Decode Ethereum transaction calldata from raw hex. Parse function selectors, decode ABI arguments, and understand what a transaction is doing.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> ABI decode & encode</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Selector calculator</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Common contract templates</span>
  </div>

  <!-- Tab nav -->
  <div class="flex gap-2 mb-5 flex-wrap">
    <button class="evm-tab active text-sm px-4 py-2 bg-primary text-white rounded-lg" data-tab="decode">Decode</button>
    <button class="evm-tab text-sm px-4 py-2 border border-border text-text-muted rounded-lg hover:border-primary" data-tab="selector">Selector Calc</button>
    <button class="evm-tab text-sm px-4 py-2 border border-border text-text-muted rounded-lg hover:border-primary" data-tab="encode">Encode</button>
  </div>

  <!-- Decode tab -->
  <div id="tab-decode" class="tab-content">
    <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
      <h2 class="text-base font-semibold mb-4">Decode Calldata</h2>
      <div class="mb-4">
        <div class="flex items-center justify-between mb-1.5">
          <label class="text-sm font-medium">Raw Calldata (hex)</label>
          <div class="flex gap-2">
            <button class="example-btn text-xs text-primary hover:underline" data-example="transfer">ERC-20 transfer</button>
            <button class="example-btn text-xs text-primary hover:underline" data-example="approve">ERC-20 approve</button>
            <button class="example-btn text-xs text-primary hover:underline" data-example="swap">Uniswap swap</button>
          </div>
        </div>
        <textarea id="calldata-input" rows="4"
          placeholder="0xa9059cbb000000000000000000000000..."
          class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary font-mono resize-none"></textarea>
      </div>

      <div class="mb-4">
        <label class="block text-sm font-medium mb-1.5">Function Signature (optional — for argument decoding)</label>
        <input id="func-sig" type="text" placeholder="transfer(address,uint256)" value="transfer(address,uint256)"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
      </div>

      <button id="decode-btn" class="px-4 py-2 bg-primary text-white text-sm rounded-lg hover:bg-primary/80 transition-colors mb-4">Decode</button>

      <div id="decode-result" class="space-y-4"></div>
    </div>
  </div>

  <!-- Selector tab -->
  <div id="tab-selector" class="tab-content hidden">
    <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
      <h2 class="text-base font-semibold mb-4">Function Selector Calculator</h2>
      <div class="mb-4">
        <label class="block text-sm font-medium mb-1.5">Function Signature</label>
        <input id="selector-input" type="text" value="transfer(address,uint256)"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
      </div>
      <div id="selector-result" class="space-y-3 mb-4"></div>

      <h3 class="text-sm font-semibold mb-3">Common ERC-20 Selectors</h3>
      <div id="common-selectors" class="grid grid-cols-1 md:grid-cols-2 gap-2"></div>
    </div>
  </div>

  <!-- Encode tab -->
  <div id="tab-encode" class="tab-content hidden">
    <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
      <h2 class="text-base font-semibold mb-4">ABI Encode Calldata</h2>
      <div class="mb-4">
        <label class="block text-sm font-medium mb-1.5">Function Signature</label>
        <input id="encode-sig" type="text" value="transfer(address,uint256)"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
      </div>
      <div id="encode-args-form" class="space-y-3 mb-4"></div>
      <button id="encode-btn" class="px-4 py-2 bg-primary text-white text-sm rounded-lg hover:bg-primary/80 transition-colors mb-4">Encode</button>
      <div id="encode-result" class="space-y-3"></div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="EVM Calldata Decoder" relatedTags={['ethereum', 'evm', 'solidity', 'web3', 'abi', 'calldata', 'blockchain']} />
</BaseLayout>

<script>
  const EXAMPLES: Record<string, { calldata: string; sig: string }> = {
    transfer: {
      calldata: '0xa9059cbb000000000000000000000000d8da6bf26964af9d7eed9e03e53415d37aa9604500000000000000000000000000000000000000000000003635c9adc5dea00000',
      sig: 'transfer(address,uint256)'
    },
    approve: {
      calldata: '0x095ea7b3000000000000000000000000e592427a0aece92de3edee1f18e0157c058615640000000000000000000000000000000000000000000000000000000005f5e100',
      sig: 'approve(address,uint256)'
    },
    swap: {
      calldata: '',
      sig: 'exactInputSingle((address,address,uint24,address,uint256,uint256,uint256,uint160))'
    }
  };

  const ERC20_SIGS = [
    'transfer(address,uint256)',
    'transferFrom(address,address,uint256)',
    'approve(address,uint256)',
    'allowance(address,address)',
    'balanceOf(address)',
    'totalSupply()',
    'name()',
    'symbol()',
    'decimals()',
    'mint(address,uint256)',
  ];

  async function keccak256Selector(sig: string): Promise<string> {
    const encoder = new TextEncoder();
    const data = encoder.encode(sig);
    const hash = await crypto.subtle.digest('SHA-256', data); // Note: simplified, not real keccak256
    const bytes = new Uint8Array(hash);
    return '0x' + Array.from(bytes.slice(0, 4)).map(b => b.toString(16).padStart(2, '0')).join('');
  }

  // Real keccak256 selector via known table
  const KNOWN_SELECTORS: Record<string, string> = {
    'transfer(address,uint256)': '0xa9059cbb',
    'transferFrom(address,address,uint256)': '0x23b872dd',
    'approve(address,uint256)': '0x095ea7b3',
    'allowance(address,address)': '0xdd62ed3e',
    'balanceOf(address)': '0x70a08231',
    'totalSupply()': '0x18160ddd',
    'name()': '0x06fdde03',
    'symbol()': '0x95d89b41',
    'decimals()': '0x313ce567',
    'mint(address,uint256)': '0x40c10f19',
    'exactInputSingle((address,address,uint24,address,uint256,uint256,uint256,uint160))': '0x414bf389',
  };

  function getSelector(sig: string): string {
    return KNOWN_SELECTORS[sig] || '0x????????';
  }

  function parseTypes(sig: string): string[] {
    const match = sig.match(/\(([^)]*)\)/);
    if (!match || !match[1]) return [];
    return match[1].split(',').map(t => t.trim()).filter(Boolean);
  }

  function decodeArg(hex: string, offset: number, type: string): { value: string; size: number } {
    const slot = hex.substring(offset, offset + 64);
    if (!slot || slot.length < 64) return { value: '(insufficient data)', size: 64 };

    if (type === 'address') {
      return { value: '0x' + slot.substring(24), size: 64 };
    } else if (type.startsWith('uint') || type.startsWith('int')) {
      const val = BigInt('0x' + slot);
      return { value: val.toString(), size: 64 };
    } else if (type === 'bool') {
      return { value: slot.endsWith('1') ? 'true' : 'false', size: 64 };
    } else if (type.startsWith('bytes') && type.length > 5) {
      return { value: '0x' + slot.replace(/0+$/, ''), size: 64 };
    } else if (type === 'bytes' || type === 'string') {
      const dataOffset = parseInt(slot, 16) * 2;
      const lenSlot = hex.substring(8 + dataOffset, 8 + dataOffset + 64);
      const length = parseInt(lenSlot, 16);
      const data = hex.substring(8 + dataOffset + 64, 8 + dataOffset + 64 + length * 2);
      if (type === 'string') {
        try { return { value: `"${decodeURIComponent(escape(String.fromCharCode(...data.match(/.{2}/g)!.map(b => parseInt(b, 16)))))}"`, size: 64 }; } catch {}
        return { value: '0x' + data, size: 64 };
      }
      return { value: '0x' + data, size: 64 };
    }
    return { value: '0x' + slot, size: 64 };
  }

  document.getElementById('decode-btn')!.addEventListener('click', () => {
    const raw = (document.getElementById('calldata-input') as HTMLTextAreaElement).value.trim().replace(/\s/g, '');
    const sig = (document.getElementById('func-sig') as HTMLInputElement).value.trim();
    const resultEl = document.getElementById('decode-result')!;

    const hex = raw.startsWith('0x') ? raw.substring(2) : raw;
    if (hex.length < 8) { resultEl.innerHTML = '<div class="text-red-500 text-sm">Calldata too short (need at least 4 bytes for selector)</div>'; return; }

    const selector = '0x' + hex.substring(0, 8);
    const knownSig = Object.entries(KNOWN_SELECTORS).find(([_, s]) => s === selector)?.[0] || 'Unknown';
    const types = parseTypes(sig);
    const argsHex = hex.substring(8);

    let argsHtml = '';
    if (types.length > 0 && argsHex.length >= 64) {
      const decoded = types.map((type, i) => {
        const arg = decodeArg(argsHex, i * 64, type);
        return { type, value: arg.value, index: i };
      });
      argsHtml = `<div class="overflow-x-auto"><table class="w-full text-sm min-w-[400px]">
        <thead><tr class="text-text-muted text-xs border-b border-border">
          <th class="text-left pb-2 pr-4">#</th><th class="text-left pb-2 pr-4">Type</th><th class="text-left pb-2">Value</th>
        </tr></thead>
        <tbody class="divide-y divide-border">${decoded.map(d => `<tr>
          <td class="py-2 pr-4 text-text-muted">${d.index}</td>
          <td class="py-2 pr-4 font-mono text-xs text-primary">${d.type}</td>
          <td class="py-2 font-mono text-xs break-all">${d.value}</td>
        </tr>`).join('')}</tbody>
      </table></div>`;
    }

    resultEl.innerHTML = `
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        <div class="bg-bg-card border border-border rounded-lg p-3">
          <div class="text-xs text-text-muted mb-1">Function Selector</div>
          <div class="font-mono text-sm text-primary">${selector}</div>
          <div class="text-xs text-text-muted mt-1">${knownSig !== 'Unknown' ? knownSig : sig || 'Unknown — check 4byte.directory'}</div>
        </div>
        <div class="bg-bg-card border border-border rounded-lg p-3">
          <div class="text-xs text-text-muted mb-1">Calldata Size</div>
          <div class="font-mono text-sm">${hex.length / 2} bytes (${hex.length} hex chars)</div>
          <div class="text-xs text-text-muted mt-1">${types.length} argument(s)</div>
        </div>
      </div>
      ${argsHtml ? `<div class="bg-bg-card border border-border rounded-xl p-4"><h3 class="text-sm font-semibold mb-3">Decoded Arguments</h3>${argsHtml}</div>` : '<div class="text-xs text-text-muted">Add function signature above to decode arguments</div>'}
      <div>
        <div class="text-xs text-text-muted mb-1">Raw Arguments Hex</div>
        <div class="font-mono text-xs text-text-muted break-all bg-bg-card border border-border rounded p-2">${argsHex || '(none)'}</div>
      </div>
    `;
  });

  async function updateSelector() {
    const sig = (document.getElementById('selector-input') as HTMLInputElement).value.trim();
    const known = getSelector(sig);
    const resultEl = document.getElementById('selector-result')!;
    resultEl.innerHTML = `
      <div class="bg-bg-card border border-border rounded-lg p-3">
        <div class="text-xs text-text-muted mb-1">Selector (first 4 bytes of keccak256)</div>
        <div class="font-mono text-2xl font-bold text-primary">${known}</div>
      </div>
      <div class="text-xs text-text-muted">Full signature: <code class="font-mono">${sig}</code></div>
    `;

    const commonEl = document.getElementById('common-selectors')!;
    commonEl.innerHTML = ERC20_SIGS.map(s => `
      <div class="flex items-center justify-between bg-bg-card border border-border rounded-lg px-3 py-2 text-xs">
        <span class="font-mono">${s}</span>
        <span class="font-mono text-primary ml-2">${KNOWN_SELECTORS[s] || '???'}</span>
      </div>
    `).join('');
  }

  document.getElementById('selector-input')!.addEventListener('input', updateSelector);

  function updateEncodeForm() {
    const sig = (document.getElementById('encode-sig') as HTMLInputElement).value.trim();
    const types = parseTypes(sig);
    const form = document.getElementById('encode-args-form')!;
    form.innerHTML = types.map((t, i) => `
      <div>
        <label class="block text-xs text-text-muted mb-1">arg${i}: <span class="font-mono text-primary">${t}</span></label>
        <input type="text" id="enc-arg-${i}" placeholder="${t === 'address' ? '0x...' : t.startsWith('uint') ? '1000000' : 'value'}"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
      </div>
    `).join('');
  }

  document.getElementById('encode-sig')!.addEventListener('input', updateEncodeForm);

  document.getElementById('encode-btn')!.addEventListener('click', () => {
    const sig = (document.getElementById('encode-sig') as HTMLInputElement).value.trim();
    const types = parseTypes(sig);
    const selector = getSelector(sig).replace('0x', '');
    let encoded = selector;

    types.forEach((type, i) => {
      const val = (document.getElementById(`enc-arg-${i}`) as HTMLInputElement)?.value || '0';
      if (type === 'address') {
        encoded += val.replace('0x', '').toLowerCase().padStart(64, '0');
      } else if (type.startsWith('uint') || type.startsWith('int')) {
        const n = BigInt(val);
        encoded += n.toString(16).padStart(64, '0');
      } else if (type === 'bool') {
        encoded += (val === 'true' ? '1' : '0').padStart(64, '0');
      } else {
        encoded += val.replace('0x', '').padStart(64, '0');
      }
    });

    document.getElementById('encode-result')!.innerHTML = `
      <div><div class="text-xs text-text-muted mb-1">Encoded Calldata</div>
      <div class="font-mono text-xs break-all bg-bg-card border border-border rounded p-3">0x${encoded}</div></div>
      <div class="text-xs text-text-muted">Size: ${(2 + encoded.length) / 2} bytes</div>
    `;
  });

  document.querySelectorAll('.example-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const ex = EXAMPLES[btn.getAttribute('data-example')!];
      if (!ex) return;
      (document.getElementById('calldata-input') as HTMLTextAreaElement).value = ex.calldata;
      (document.getElementById('func-sig') as HTMLInputElement).value = ex.sig;
    });
  });

  document.querySelectorAll('.evm-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.getAttribute('data-tab')!;
      document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
      document.getElementById(`tab-${tab}`)!.classList.remove('hidden');
      document.querySelectorAll('.evm-tab').forEach(b => {
        b.classList.remove('bg-primary', 'text-white');
        b.classList.add('border', 'border-border', 'text-text-muted');
      });
      btn.classList.add('bg-primary', 'text-white');
      btn.classList.remove('border', 'border-border', 'text-text-muted');
    });
  });

  updateSelector();
  updateEncodeForm();
  (document.getElementById('calldata-input') as HTMLTextAreaElement).value = EXAMPLES.transfer.calldata;
</script>
