---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GithubActionsWorkflowValidator from '../../components/GithubActionsWorkflowValidator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What does this GitHub Actions validator check?",
    answer: "It validates workflow structure (required name/on/jobs keys), trigger event names, job fields (runs-on, steps), needs: dependency references (catching undefined jobs), action version pinning, hardcoded secrets, schedule cron expressions, and security issues like pull_request_target with untrusted head SHA."
  },
  {
    question: "What is the difference between this validator and a linter?",
    answer: "This tool focuses on structural correctness — does your workflow have the required fields, are job dependencies valid, are event names spelled correctly? A linter additionally checks style and best practices. Both are complementary: validate structure first, then lint for best practices."
  },
  {
    question: "Why should I pin actions to version tags instead of branch names?",
    answer: "Pinning to @main or @master uses whatever code is on that branch at run time — including potentially malicious changes (supply chain attacks). Pinning to @v4 or a commit SHA (e.g., @abc1234) makes your workflow reproducible and immune to upstream branch changes."
  },
  {
    question: "What are valid GitHub Actions trigger events?",
    answer: "Common triggers: push, pull_request, pull_request_target, schedule (cron), workflow_dispatch (manual trigger), workflow_call (reusable workflows), release, issues, issue_comment, create, delete, fork, label, milestone, repository_dispatch, discussion, merge_group, and more. Invalid event names silently fail to trigger."
  },
  {
    question: "What is needs: used for and what breaks it?",
    answer: "The needs: field creates job dependencies — a job with needs: [test, build] only runs after both succeed. If you reference a job name that doesn't exist in the workflow, GitHub will refuse to run it. This validator catches those broken references before you push."
  },
  {
    question: "Is my workflow YAML sent to any server?",
    answer: "No. All validation runs entirely in your browser using JavaScript. Your workflow YAML never leaves your machine — safe even when your workflows contain secret names, internal endpoint URLs, or repository structure details."
  },
];
---

<BaseLayout
  title="GitHub Actions Workflow Validator — Validate .github/workflows YAML"
  description="Validate your GitHub Actions workflow YAML online. Checks structure, trigger events, job dependencies, runs-on, action version pins, hardcoded secrets, and cron expressions. Free, runs 100% in your browser."
  tool="GitHub Actions validator, workflow YAML validator, .github/workflows checker, GitHub Actions structure validator, CI/CD workflow validator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "GitHub Actions Workflow Validator",
    "url": "https://devplaybook.cc/tools/github-actions-workflow-validator",
    "description": "Validate GitHub Actions workflow YAML. Checks structure, job dependencies, trigger events, action pins, and security issues. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">GitHub Actions Workflow Validator</h1>
  <p class="text-text-muted mb-4">
    Paste your <code class="font-mono bg-surface px-1 rounded text-sm">.github/workflows/*.yml</code> and validate it before pushing.
    Checks required structure, trigger events, job dependencies, action version pins, secrets handling, and cron expressions.
    Nothing is sent to any server — runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Structure & schema validation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Security checks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Job dependency graph validation</span>
  </div>
  <GithubActionsWorkflowValidator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="GitHub Actions Workflow Validator" relatedTags={['github', 'ci-cd', 'devops', 'yaml', 'validation', 'automation']} />
</BaseLayout>
