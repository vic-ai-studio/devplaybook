---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Turborepo?", answer: "Turborepo is a high-performance build system for JavaScript and TypeScript monorepos, built by Vercel. It understands task dependencies across packages, caches build outputs locally and in the cloud, and runs tasks in parallel — dramatically speeding up build, test, and lint pipelines in large monorepos." },
  { question: "What does the pipeline configuration do?", answer: "The pipeline (now called 'tasks' in Turbo v2+) in turbo.json defines how tasks relate to each other. Each entry specifies a task name, which tasks it depends on, what files it outputs, and whether results should be cached. Turborepo uses this graph to schedule tasks optimally across packages." },
  { question: "What does 'dependsOn' mean in Turborepo?", answer: "dependsOn tells Turborepo which tasks must complete before this task can start. Use '^build' (with caret) to mean 'the build task of all packages this package depends on'. Use 'test' (without caret) to mean 'the test task in the same package'. Plain task names (no caret) refer to tasks in the same workspace." },
  { question: "How does Turborepo caching work?", answer: "Turborepo hashes your source files, dependencies, and environment variables to create a unique fingerprint for each task. If the fingerprint matches a previous run, Turborepo replays the cached output instantly instead of re-running the task. With Remote Caching (Vercel), the cache is shared across your entire team and CI." },
  { question: "What are persistent tasks in Turborepo?", answer: "Persistent tasks are long-running tasks that never exit, like dev servers (next dev, vite dev). Mark them with 'persistent: true' so Turborepo knows they will not complete — it will not wait for them to finish before starting other tasks, and it will not cache their output." },
  { question: "What is the difference between Turborepo and Nx?", answer: "Both are monorepo build orchestrators with caching. Turborepo is simpler and designed specifically for npm/pnpm/yarn workspaces — great for most web projects. Nx is more feature-rich with generators, a plugin ecosystem, and deeper IDE integration — better for very large enterprise monorepos or when you need code generation. Turborepo is easier to adopt; Nx scales further." },
];
---

<BaseLayout
  title="Turborepo Pipeline Visualizer — Build and Visualize turbo.json Tasks"
  description="Free Turborepo pipeline builder. Add tasks with dependsOn, outputs, cache and persistent settings. Get a valid turbo.json pipeline config and visualize the dependency graph instantly."
  tool="Turborepo pipeline builder, turbo.json generator, Turborepo task config, monorepo build tool, Turborepo dependsOn visualizer"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Turborepo Pipeline Visualizer",
    "url": "https://devplaybook.cc/tools/turborepo-pipeline-visualizer",
    "description": "Build and visualize Turborepo pipeline task configs. Add tasks, set dependencies, and get a valid turbo.json config with dependency graph.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Turborepo Pipeline Visualizer</h1>
  <p class="text-text-muted mb-4">Build your Turborepo task pipeline visually. Add tasks, configure <code class="bg-surface px-1 rounded text-sm">dependsOn</code>, outputs, caching, and persistent flags — then get a valid <code class="bg-surface px-1 rounded text-sm">turbo.json</code> and a text-based dependency graph.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> turbo.json v1 &amp; v2 format</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Dependency graph preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Left: Task builder -->
    <div class="space-y-4">
      <div class="bg-surface border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold mb-3 text-text-muted uppercase tracking-wide">Add Task</h2>
        <div class="space-y-3">
          <div>
            <label for="tp-task-name" class="block text-xs font-medium mb-1">Task Name</label>
            <input id="tp-task-name" type="text" placeholder="build"
              class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-accent" />
          </div>
          <div>
            <label for="tp-depends-on" class="block text-xs font-medium mb-1">dependsOn <span class="text-text-muted font-normal">(comma-separated, use ^ prefix for upstream)</span></label>
            <input id="tp-depends-on" type="text" placeholder="^build, lint"
              class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-accent" />
          </div>
          <div>
            <label for="tp-outputs" class="block text-xs font-medium mb-1">Outputs <span class="text-text-muted font-normal">(comma-separated glob patterns)</span></label>
            <input id="tp-outputs" type="text" placeholder="dist/**, .next/**"
              class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-accent" />
          </div>
          <div class="flex gap-6">
            <label class="flex items-center gap-2 text-sm cursor-pointer">
              <input type="checkbox" id="tp-cache" checked class="accent-accent" /> Cache
            </label>
            <label class="flex items-center gap-2 text-sm cursor-pointer">
              <input type="checkbox" id="tp-persistent" class="accent-accent" /> Persistent
            </label>
          </div>
          <button id="tp-add-task" class="bg-accent hover:bg-accent/80 text-white font-medium px-4 py-2 rounded-lg text-sm transition-colors w-full">
            Add Task
          </button>
        </div>
      </div>

      <div class="bg-surface border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold text-text-muted uppercase tracking-wide">Tasks</h2>
          <button id="tp-clear" class="text-xs text-red-400 border border-red-400/30 px-2 py-1 rounded hover:bg-red-400/10 transition-colors">Clear All</button>
        </div>
        <div id="tp-task-list" class="space-y-2 min-h-[60px]">
          <p class="text-xs text-text-muted" id="tp-empty-msg">No tasks yet. Add a task above.</p>
        </div>
      </div>
    </div>

    <!-- Right: Output -->
    <div class="space-y-4">
      <div class="bg-surface border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <label class="text-sm font-medium">turbo.json</label>
          <button id="tp-copy-config" class="text-xs bg-background border border-border hover:bg-accent/20 px-3 py-1 rounded-lg transition-colors">Copy</button>
        </div>
        <pre id="tp-config-output" class="bg-background border border-border rounded-lg px-4 py-3 text-xs font-mono overflow-x-auto whitespace-pre leading-relaxed min-h-[160px]"></pre>
      </div>

      <div class="bg-surface border border-border rounded-xl p-5">
        <h2 class="text-sm font-medium mb-3">Dependency Graph</h2>
        <pre id="tp-graph-output" class="bg-background border border-border rounded-lg px-4 py-3 text-xs font-mono overflow-x-auto whitespace-pre leading-relaxed min-h-[100px] text-green-400"></pre>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Turborepo Pipeline Visualizer" relatedTags={['monorepo', 'build-tools', 'devops', 'javascript', 'typescript']} />
</BaseLayout>

<script>
(function() {
  var tasks = [];

  function el(id) { return document.getElementById(id); }

  var DEFAULT_TASKS = [
    { name: 'build', dependsOn: ['^build'], outputs: ['dist/**', '.next/**'], cache: true, persistent: false },
    { name: 'test', dependsOn: ['^build'], outputs: [], cache: true, persistent: false },
    { name: 'lint', dependsOn: [], outputs: [], cache: true, persistent: false },
    { name: 'dev', dependsOn: ['^build'], outputs: [], cache: false, persistent: true },
  ];

  function addTask(task) {
    tasks.push(task);
    renderTaskList();
    renderOutputs();
  }

  function removeTask(idx) {
    tasks.splice(idx, 1);
    renderTaskList();
    renderOutputs();
  }

  function renderTaskList() {
    var list = el('tp-task-list');
    var emptyMsg = el('tp-empty-msg');
    if (tasks.length === 0) {
      list.innerHTML = '';
      list.appendChild(emptyMsg);
      emptyMsg.style.display = '';
      return;
    }
    list.innerHTML = '';
    tasks.forEach(function(t, i) {
      var div = document.createElement('div');
      div.className = 'flex items-center justify-between bg-background border border-border rounded-lg px-3 py-2 text-xs font-mono';
      var badges = '';
      if (!t.cache) badges += ' <span class="text-yellow-400">[no-cache]</span>';
      if (t.persistent) badges += ' <span class="text-blue-400">[persistent]</span>';
      var deps = t.dependsOn.length > 0 ? ' <span class="text-text-muted">depends: ' + t.dependsOn.join(', ') + '</span>' : '';
      div.innerHTML = '<span><span class="text-accent font-semibold">' + t.name + '</span>' + badges + deps + '</span>'
        + '<button class="text-red-400 hover:text-red-300 ml-2 text-xs">Remove</button>';
      div.querySelector('button').addEventListener('click', function() { removeTask(i); });
      list.appendChild(div);
    });
  }

  function renderOutputs() {
    renderConfig();
    renderGraph();
  }

  function renderConfig() {
    if (tasks.length === 0) {
      el('tp-config-output').textContent = '// Add tasks to generate turbo.json';
      return;
    }
    var pipeline = {};
    tasks.forEach(function(t) {
      var taskConfig = {};
      if (t.dependsOn.length > 0) taskConfig.dependsOn = t.dependsOn;
      if (t.outputs.length > 0) taskConfig.outputs = t.outputs;
      if (!t.cache) taskConfig.cache = false;
      if (t.persistent) taskConfig.persistent = true;
      pipeline[t.name] = taskConfig;
    });
    var config = { '$schema': 'https://turbo.build/schema.json', pipeline: pipeline };
    el('tp-config-output').textContent = JSON.stringify(config, null, 2);
  }

  function renderGraph() {
    if (tasks.length === 0) {
      el('tp-graph-output').textContent = '// Dependency graph will appear here';
      return;
    }
    var lines = ['Dependency Graph', '================', ''];
    tasks.forEach(function(t) {
      if (t.dependsOn.length === 0) {
        lines.push(t.name + ' (no deps)');
      } else {
        t.dependsOn.forEach(function(dep) {
          lines.push(dep + ' ---> ' + t.name);
        });
      }
    });
    lines.push('');
    lines.push('Execution order (approximate):');
    var roots = tasks.filter(function(t) { return t.dependsOn.length === 0; });
    var deps = tasks.filter(function(t) { return t.dependsOn.length > 0; });
    if (roots.length > 0) {
      lines.push('  1. Parallel: ' + roots.map(function(t) { return t.name; }).join(', '));
    }
    if (deps.length > 0) {
      lines.push('  2. After deps: ' + deps.map(function(t) { return t.name; }).join(', '));
    }
    el('tp-graph-output').textContent = lines.join('\n');
  }

  el('tp-add-task').addEventListener('click', function() {
    var nameEl = el('tp-task-name') as HTMLInputElement;
    var name = nameEl.value.trim();
    if (!name) { nameEl.focus(); return; }
    var depsRaw = (el('tp-depends-on') as HTMLInputElement).value.trim();
    var outputsRaw = (el('tp-outputs') as HTMLInputElement).value.trim();
    var deps = depsRaw ? depsRaw.split(',').map(function(s) { return s.trim(); }).filter(Boolean) : [];
    var outputs = outputsRaw ? outputsRaw.split(',').map(function(s) { return s.trim(); }).filter(Boolean) : [];
    var cache = (el('tp-cache') as HTMLInputElement).checked;
    var persistent = (el('tp-persistent') as HTMLInputElement).checked;
    addTask({ name: name, dependsOn: deps, outputs: outputs, cache: cache, persistent: persistent });
    nameEl.value = '';
    (el('tp-depends-on') as HTMLInputElement).value = '';
    (el('tp-outputs') as HTMLInputElement).value = '';
    (el('tp-cache') as HTMLInputElement).checked = true;
    (el('tp-persistent') as HTMLInputElement).checked = false;
  });

  el('tp-clear').addEventListener('click', function() {
    tasks = [];
    renderTaskList();
    renderOutputs();
  });

  el('tp-copy-config').addEventListener('click', function() {
    var text = el('tp-config-output').textContent;
    navigator.clipboard.writeText(text).then(function() {
      var btn = el('tp-copy-config');
      btn.textContent = 'Copied!';
      setTimeout(function() { btn.textContent = 'Copy'; }, 1500);
    });
  });

  // Load defaults
  DEFAULT_TASKS.forEach(function(t) { addTask(t); });
})();
</script>
