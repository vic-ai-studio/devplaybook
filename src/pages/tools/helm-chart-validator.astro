---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HelmChartValidator from '../../components/HelmChartValidator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the difference between Helm chart validation and linting?",
    answer: "Helm linting (helm lint) checks Chart.yaml structure and basic YAML syntax. Validation goes deeper: it checks template logic, parameterization best practices, brace balance in Go templates, and values.yaml structural correctness. This tool helps you catch issues before running helm template or helm install, without needing the Helm CLI installed."
  },
  {
    question: "What are Helm template directives?",
    answer: "Helm templates use Go's text/template syntax with double curly braces: {{ .Values.myValue }}, {{ include \"chart.name\" . }}, {{- if .Values.enabled -}}. The leading dash {{- removes preceding whitespace, and the trailing dash -}} removes following whitespace. Proper use of dashes prevents unexpected blank lines in rendered manifests."
  },
  {
    question: "What does 'nindent' do in Helm templates?",
    answer: "nindent N prepends a newline and then indents each line by N spaces. It's used when including a multi-line helper (like a labels block) inside an existing indented block. For example: {{- include \"mychart.labels\" . | nindent 4 }} ensures the labels are properly indented within the metadata section, preventing invalid YAML indentation in the rendered output."
  },
  {
    question: "Should image tags be hardcoded in templates?",
    answer: "No. Image tags should always come from values.yaml via {{ .Values.image.tag }}. Hardcoding image tags in templates makes it impossible to override them at deploy time with helm install --set or -f custom-values.yaml. The best practice is to use {{ .Values.image.tag | default .Chart.AppVersion }} so the chart falls back to the app version if no tag is specified."
  },
  {
    question: "Why should I set resource requests and limits in Kubernetes?",
    answer: "Resource requests tell the Kubernetes scheduler how much CPU/memory a Pod needs to be placed on a node. Resource limits cap the maximum usage. Without requests, the scheduler may place Pods on overloaded nodes. Without limits, a runaway container can consume all node resources and evict other Pods (OOM kill). Always set both requests and limits for production workloads."
  },
  {
    question: "Does this tool run helm template or connect to a cluster?",
    answer: "No. All validation runs entirely in your browser using JavaScript. Your template YAML never leaves your machine. For full rendering validation, run 'helm template my-release ./chart' locally with the Helm CLI."
  },
];
---

<BaseLayout
  title="Helm Chart Validator — Validate Helm Templates and values.yaml Online"
  description="Validate Helm chart templates and values.yaml online. Checks template brace balance, parameterization, resource limits, hardcoded values, and values.yaml best practices. No Helm CLI required."
  tool="helm chart validator, helm template validator, values.yaml checker, helm syntax check, kubernetes helm validator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Helm Chart Validator",
    "url": "https://devplaybook.cc/tools/helm-chart-validator",
    "description": "Validate Helm chart templates and values.yaml online. Checks Go template syntax, parameterization, resource limits, and best practices. Runs 100% in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Helm Chart Validator</h1>
  <p class="text-text-muted mb-4">
    Validate Helm chart templates and <code class="font-mono text-sm bg-surface px-1 rounded">values.yaml</code> without the Helm CLI.
    Checks Go template syntax, brace balance, parameterization, resource constraints, and Kubernetes best practices.
    Nothing is sent to any server — runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Template brace balance</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Parameterization checks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> values.yaml best practices</span>
  </div>
  <HelmChartValidator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Helm Chart Validator" relatedTags={['devops', 'kubernetes', 'cloud', 'infrastructure', 'helm', 'yaml', 'validation']} />
</BaseLayout>
