---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GithubActionsWorkflowGenerator from '../../components/GithubActionsWorkflowGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is GitHub Actions and how does it work?",
    answer: "GitHub Actions is GitHub's built-in CI/CD platform. Workflows are defined as YAML files in .github/workflows/ and triggered by events like push, pull_request, or schedule. Each workflow runs on a runner (ubuntu-latest, windows-latest, macos-latest) and consists of jobs, which contain steps — individual commands or reusable actions from the GitHub Marketplace. Workflows run on GitHub's servers at no cost for public repositories (private repos get 2,000 free minutes/month on the free plan)."
  },
  {
    question: "What is the difference between actions/cache and built-in caching in setup actions?",
    answer: "Modern setup actions like actions/setup-node@v4, actions/setup-python@v5, and actions/setup-go@v5 have a built-in cache parameter that automatically caches the relevant package manager's dependencies (node_modules, pip, Go module cache). This is the preferred approach — it handles cache key generation automatically based on lock files. The standalone actions/cache@v4 action gives you more control for custom caching scenarios but requires manual key configuration. For standard setups, always prefer the built-in cache option."
  },
  {
    question: "How do I store secrets like API keys in GitHub Actions?",
    answer: "Never put secrets in YAML files. Use GitHub repository secrets: go to Settings → Secrets and variables → Actions → New repository secret. Reference them in workflows as $\\{\\{ secrets.MY_SECRET \\}\\}. For Docker Hub, create DOCKERHUB_USERNAME and DOCKERHUB_TOKEN secrets. For Vercel, add VERCEL_TOKEN, VERCEL_ORG_ID, and VERCEL_PROJECT_ID. For Fly.io, add FLY_API_TOKEN. The GITHUB_TOKEN secret is automatically available for GitHub Container Registry — no setup needed."
  },
  {
    question: "How do I run a workflow only on the main branch (not on PRs)?",
    answer: "Use an if condition on the job or step: if: github.ref == 'refs/heads/main'. This is essential for deployment steps — you want tests to run on every PR, but deployments should only happen when code merges to main. For Docker pushes, use push: $\\{\\{ github.ref == 'refs/heads/main' \\}\\} in the build-push-action to build on all branches but only push the image when on main. Alternatively, put deploy logic in a separate job that depends on the build job and has the if condition."
  },
];
---

<BaseLayout
  title="GitHub Actions Workflow Generator — CI/CD YAML for Node.js, Python, Go, Docker"
  description="Generate GitHub Actions CI/CD workflow YAML for Node.js, Python, Go, Rust, and Docker projects. Configure triggers, test, build, and deploy steps. Get ready-to-use .github/workflows/ci.yml."
  tool="github actions workflow generator, ci cd yaml generator, github actions ci, github actions node python go, workflow yaml"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "GitHub Actions Workflow Generator",
    "url": "https://devplaybook.cc/tools/github-actions-workflow-generator",
    "description": "Generate GitHub Actions CI/CD workflow YAML for Node.js, Python, Go, Rust, and Docker projects. Configure triggers, test, build, and deploy steps.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">GitHub Actions Workflow Generator</h1>
  <p class="text-text-muted mb-4">
    Generate complete <strong>GitHub Actions CI/CD workflows</strong> for Node.js, Python, Go, Rust, and Docker projects. Configure triggers, steps, and deploy targets — get a ready-to-use <strong>.github/workflows/ci.yml</strong> file instantly.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 project types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Lint, test, build, Docker</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Vercel / Netlify / Fly.io deploy</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Dependency caching included</span>
  </div>
  <GithubActionsWorkflowGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="GitHub Actions Workflow Generator" relatedTags={['github-actions', 'ci-cd', 'devops', 'yaml', 'developer-tools']} />
</BaseLayout>
