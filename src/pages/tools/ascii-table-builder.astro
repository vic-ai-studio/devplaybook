---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AsciiTableBuilder from '../../components/AsciiTableBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is an ASCII table?", answer: "An ASCII table uses printable ASCII characters (like +, -, |, or box-drawing characters like ┌, ─, │) to render tabular data in plain text. They're used in CLI tool output, terminal UIs, README files, code comments, API documentation, and any context where rich text formatting isn't available." },
  { question: "What is the difference between ASCII and Unicode box-drawing characters?", answer: "Traditional ASCII tables use + - | characters (code points 43, 45, 124) — universally supported but visually basic. Unicode box-drawing characters (U+2500 to U+257F) like ┌ ─ │ └ ┤ produce cleaner-looking tables but require UTF-8 encoding support. Most modern terminals, browsers, and editors support Unicode box-drawing." },
  { question: "How do I use this in a README?", answer: "Use the Markdown style — it generates GitHub Flavored Markdown table syntax with | separators and dashes in the header row. GitHub, GitLab, and most documentation platforms render this natively. For terminal output or documentation that must be plain ASCII, use the Simple or Grid styles." },
  { question: "What is the Rounded style?", answer: "The Rounded style uses Unicode box-drawing characters with curved corners: ╭, ╮, ╰, ╯. It produces modern-looking terminal output popular in CLI tools like rich (Python) and ink (Node.js). Supported in most modern terminal emulators." },
];
---

<BaseLayout
  title="ASCII Table Builder — Generate Text Tables Online — Free Tool"
  description="Build ASCII and Unicode tables from editable grid data. Choose from Simple (+--+), Grid (box-drawing), Rounded (curved corners), or Markdown styles. Copy-ready text table output."
  tool="ASCII table generator, text table maker, CLI table builder, Unicode box drawing table, Markdown table generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">ASCII Table Builder</h1>
  <p class="text-text-muted mb-4">
    Enter data in the editable grid and generate a formatted ASCII or Unicode text table.
    Choose from Simple (+--+), Grid (box-drawing characters), Rounded (curved corners), or Markdown styles.
    Runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 4 table styles</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Add/remove rows & columns</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Markdown format for READMEs</span>
  </div>
  <AsciiTableBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="ASCII Table Builder" relatedTags={['cli', 'terminal', 'markdown', 'documentation', 'text']} />
</BaseLayout>
