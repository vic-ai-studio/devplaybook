---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a Golden Path in platform engineering?",
    answer: "A Golden Path (or Paved Road) is an opinionated, pre-approved set of tools, templates, and workflows that platform teams provide to product engineers. Instead of each team reinventing the wheel for CI/CD, containerization, observability, and secret management, they pick a Golden Path that gives them a production-ready starting point in minutes. The term was popularized by Spotify's platform team alongside Backstage."
  },
  {
    question: "What should a Golden Path template include?",
    answer: "A complete Golden Path template should include: (1) A Dockerfile or container build configuration. (2) A CI/CD pipeline definition (GitHub Actions workflow, GitLab CI YAML, etc.). (3) Infrastructure manifests (Kubernetes Deployment/Service, ECS task definition, or Lambda SAM template). (4) Observability bootstrap (metrics endpoint, log format, tracing SDK initialization). (5) Secret injection pattern (Vault agent sidecar, AWS SSM parameter paths, etc.). (6) A catalog descriptor (catalog-info.yaml for Backstage, Port blueprint, etc.)."
  },
  {
    question: "How do I manage Golden Path template versions?",
    answer: "Store templates in a dedicated Git repository (e.g., platform-templates) with semantic versioning. Use a template registry (Backstage Software Templates, Cookiecutter, or Copier) to publish versions. When a template is updated, notify teams using older versions via their IDP scorecard or automated PRs. Avoid breaking changes in patch versions; use major versions for structural changes. Always keep at least one previous major version supported for 3–6 months."
  },
  {
    question: "How does this generator work?",
    answer: "Select your service type, language, infrastructure target, CI/CD system, observability platform, and secret manager. The generator produces a YAML configuration block showing the key template paths and config snippets for that combination. This gives you a starting scaffold you can copy into your platform template repository or Backstage Software Template. All logic runs in your browser — nothing is sent to a server."
  },
  {
    question: "Can I use multiple languages or infrastructure targets?",
    answer: "The generator produces a single opinionated configuration per selection, which mirrors how Golden Paths work in practice — one path per combination. If your organization supports multiple stacks, generate a configuration for each and store them as separate named templates in your registry (e.g., go-k8s-github, python-lambda-github). Avoid creating too many paths: the goal is to reduce choice paralysis, not multiply it."
  }
];
---

<BaseLayout
  title="Golden Path Template Generator — Platform Engineering Scaffold Config"
  description="Generate a Golden Path scaffolding configuration for your platform engineering setup. Select service type, language, infrastructure, CI/CD, observability, and secret manager to get a ready-to-use YAML template."
  tool="golden path template, platform engineering, Backstage software template, Kubernetes scaffold, GitHub Actions template, golden road, paved road, IDP template"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Golden Path Template Generator",
    "url": "https://devplaybook.cc/tools/golden-path-template-generator",
    "description": "Generate Golden Path scaffolding YAML for platform engineering. Pick your stack and get a ready-to-use config. Free, runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Golden Path Template Generator</h1>
  <p class="text-text-muted mb-4">Select your stack and generate a Golden Path scaffolding configuration. Copy the YAML into your platform template repository or Backstage Software Template.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 6 stack dimensions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Dockerfile, CI/CD, K8s/infra, observability, secrets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Backstage catalog descriptor included</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> One-click copy</span>
  </div>

  <!-- Inputs -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">

    <div>
      <label class="block text-sm font-medium mb-2" for="svc-type">Service Type</label>
      <select id="svc-type" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
        <option value="rest">REST API</option>
        <option value="grpc">gRPC Service</option>
        <option value="worker">Worker / Queue Consumer</option>
        <option value="frontend">Frontend App</option>
      </select>
    </div>

    <div>
      <label class="block text-sm font-medium mb-2" for="lang">Language</label>
      <select id="lang" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
        <option value="go">Go</option>
        <option value="python">Python</option>
        <option value="node">Node.js</option>
        <option value="java">Java</option>
      </select>
    </div>

    <div>
      <label class="block text-sm font-medium mb-2" for="infra">Infrastructure</label>
      <select id="infra" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
        <option value="k8s">Kubernetes</option>
        <option value="ecs">AWS ECS</option>
        <option value="lambda">AWS Lambda</option>
      </select>
    </div>

    <div>
      <label class="block text-sm font-medium mb-2" for="cicd">CI/CD</label>
      <select id="cicd" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
        <option value="gha">GitHub Actions</option>
        <option value="gitlab">GitLab CI</option>
        <option value="jenkins">Jenkins</option>
      </select>
    </div>

    <div>
      <label class="block text-sm font-medium mb-2" for="obs">Observability</label>
      <select id="obs" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
        <option value="datadog">Datadog</option>
        <option value="grafana">Grafana / Prometheus</option>
        <option value="dynatrace">Dynatrace</option>
      </select>
    </div>

    <div>
      <label class="block text-sm font-medium mb-2" for="secrets">Secret Manager</label>
      <select id="secrets" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
        <option value="vault">HashiCorp Vault</option>
        <option value="ssm">AWS SSM Parameter Store</option>
        <option value="azure">Azure Key Vault</option>
      </select>
    </div>

  </div>

  <!-- Generate button -->
  <div class="flex gap-3 mb-8 flex-wrap">
    <button id="btn-generate" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Generate Golden Path Config</button>
    <button id="btn-reset" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Reset</button>
  </div>

  <!-- Output -->
  <div id="output-section" class="hidden">
    <div class="bg-bg-card border border-border rounded-lg p-5">
      <div class="flex justify-between items-center mb-3">
        <span class="text-sm font-medium">Generated Golden Path Config</span>
        <button id="btn-copy" class="px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">Copy</button>
      </div>
      <div id="stack-summary" class="flex flex-wrap gap-2 mb-4"></div>
      <pre id="config-output" class="font-mono text-xs whitespace-pre overflow-x-auto max-h-[600px] overflow-y-auto text-foreground leading-relaxed bg-black/20 rounded p-4"></pre>
    </div>
  </div>

  <ToolPageCta />
  <FaqSection faq={faq} />
</BaseLayout>

<script is:inline>
function v(id) { return document.getElementById(id)?.value || ''; }

const LABELS = {
  svcType: { rest: 'REST API', grpc: 'gRPC Service', worker: 'Worker/Queue', frontend: 'Frontend App' },
  lang:    { go: 'Go', python: 'Python', node: 'Node.js', java: 'Java' },
  infra:   { k8s: 'Kubernetes', ecs: 'AWS ECS', lambda: 'AWS Lambda' },
  cicd:    { gha: 'GitHub Actions', gitlab: 'GitLab CI', jenkins: 'Jenkins' },
  obs:     { datadog: 'Datadog', grafana: 'Grafana/Prometheus', dynatrace: 'Dynatrace' },
  secrets: { vault: 'HashiCorp Vault', ssm: 'AWS SSM', azure: 'Azure Key Vault' },
};

function dockerfileTemplate(lang, svcType) {
  const bases = { go: 'golang:1.22-alpine AS builder', python: 'python:3.12-slim', node: 'node:22-alpine', java: 'eclipse-temurin:21-jdk-alpine AS builder' };
  const runCmds = {
    go: 'RUN go build -o /app/server ./cmd/server',
    python: 'RUN pip install --no-cache-dir -r requirements.txt',
    node: 'RUN npm ci --omit=dev',
    java: 'RUN ./gradlew bootJar --no-daemon',
  };
  const ports = { rest: '8080', grpc: '50051', worker: '', frontend: '3000' };
  const port = ports[svcType];
  return `# Multi-stage Dockerfile — ${LABELS.lang[lang]}
FROM ${bases[lang]}
WORKDIR /app
COPY . .
${runCmds[lang]}
${port ? `EXPOSE ${port}` : '# No port needed for worker'}
USER nonroot:nonroot
ENTRYPOINT ["/app/server"]`;
}

function cicdTemplate(cicd, lang, infra) {
  const langCmds = { go: 'go test ./...', python: 'pytest', node: 'npm test', java: './gradlew test' };
  const infraStep = {
    k8s:    'kubectl apply -f k8s/deploy/',
    ecs:    'aws ecs update-service --cluster prod --service $SERVICE_NAME --force-new-deployment',
    lambda: 'sam deploy --no-confirm-changeset',
  };
  if (cicd === 'gha') return `# .github/workflows/ci.yml
name: CI/CD Pipeline
on:
  push:
    branches: [main]
  pull_request:
jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Run tests
        run: ${langCmds[lang]}
  build-and-deploy:
    needs: test
    runs-on: ubuntu-latest
    if: github.ref == 'refs/heads/main'
    steps:
      - uses: actions/checkout@v4
      - name: Build & push image
        run: |
          docker build -t \$IMAGE_TAG .
          docker push \$IMAGE_TAG
      - name: Deploy
        run: ${infraStep[infra]}`;

  if (cicd === 'gitlab') return `# .gitlab-ci.yml
stages: [test, build, deploy]
test:
  stage: test
  script: ${langCmds[lang]}
build:
  stage: build
  script:
    - docker build -t $IMAGE_TAG .
    - docker push $IMAGE_TAG
  only: [main]
deploy:
  stage: deploy
  script: ${infraStep[infra]}
  only: [main]
  environment: production`;

  return `// Jenkinsfile (Declarative)
pipeline {
  agent any
  stages {
    stage('Test') { steps { sh '${langCmds[lang]}' } }
    stage('Build') {
      steps {
        sh 'docker build -t $IMAGE_TAG .'
        sh 'docker push $IMAGE_TAG'
      }
    }
    stage('Deploy') {
      when { branch 'main' }
      steps { sh '${infraStep[infra]}' }
    }
  }
}`;
}

function infraTemplate(infra, svcType) {
  const ports = { rest: 8080, grpc: 50051, worker: null, frontend: 3000 };
  const port = ports[svcType];
  if (infra === 'k8s') return `# k8s/deploy/deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: \${SERVICE_NAME}
  labels:
    app: \${SERVICE_NAME}
    version: \${IMAGE_TAG}
spec:
  replicas: 2
  selector:
    matchLabels:
      app: \${SERVICE_NAME}
  template:
    metadata:
      labels:
        app: \${SERVICE_NAME}
      annotations:
        prometheus.io/scrape: "true"
        prometheus.io/port: "${port || 9090}"
    spec:
      containers:
        - name: \${SERVICE_NAME}
          image: \${IMAGE_TAG}
          ${port ? `ports:\n            - containerPort: ${port}` : '# No port for worker'}
          resources:
            requests: { cpu: 100m, memory: 128Mi }
            limits:   { cpu: 500m, memory: 512Mi }
          readinessProbe:
            httpGet:
              path: /healthz
              port: ${port || 8080}
            initialDelaySeconds: 5`;

  if (infra === 'ecs') return `# ecs/task-definition.json (excerpt)
{
  "family": "\${SERVICE_NAME}",
  "containerDefinitions": [{
    "name": "\${SERVICE_NAME}",
    "image": "\${IMAGE_TAG}",
    ${port ? `"portMappings": [{"containerPort": ${port}, "protocol": "tcp"}],` : ''}
    "cpu": 256,
    "memory": 512,
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-group": "/ecs/\${SERVICE_NAME}",
        "awslogs-region": "\${AWS_REGION}",
        "awslogs-stream-prefix": "ecs"
      }
    }
  }]
}`;

  return `# template.yaml (AWS SAM)
AWSTemplateFormatVersion: '2010-09-09'
Transform: AWS::Serverless-2016-10-31
Resources:
  \${ServiceName}Function:
    Type: AWS::Serverless::Function
    Properties:
      Handler: handler.main
      Runtime: \${RUNTIME}
      MemorySize: 256
      Timeout: 30
      Events:
        Api:
          Type: Api
          Properties:
            Path: /{proxy+}
            Method: ANY
      Environment:
        Variables:
          ENV: production`;
}

function obsTemplate(obs, svcType) {
  if (obs === 'datadog') return `# observability/datadog.yaml
# DD Agent sidecar (K8s) or DD_API_KEY env var (ECS/Lambda)
DD_SERVICE: \${SERVICE_NAME}
DD_ENV: production
DD_VERSION: \${IMAGE_TAG}
DD_TRACE_ENABLED: "true"
DD_LOGS_INJECTION: "true"
DD_RUNTIME_METRICS_ENABLED: "true"
# Add to Dockerfile: RUN pip install ddtrace  (Python)
#                    go get gopkg.in/DataDog/dd-trace-go.v1  (Go)`;

  if (obs === 'grafana') return `# observability/prometheus-annotations.yaml
# K8s pod annotations (add to deployment template)
annotations:
  prometheus.io/scrape: "true"
  prometheus.io/port: "9090"
  prometheus.io/path: "/metrics"
# Grafana dashboard auto-discovery label:
  grafana.app/dashboard: "golden-path-service"
# OpenTelemetry collector endpoint:
OTEL_EXPORTER_OTLP_ENDPOINT: http://otel-collector:4317
OTEL_SERVICE_NAME: \${SERVICE_NAME}`;

  return `# observability/dynatrace.yaml
# Dynatrace OneAgent injection (K8s operator or env var)
DT_RELEASE_PRODUCT: \${SERVICE_NAME}
DT_RELEASE_VERSION: \${IMAGE_TAG}
DT_RELEASE_STAGE: production
# OneAgent K8s operator label:
instrumentationLibraries:
  - name: \${SERVICE_NAME}
    technology: auto`;
}

function secretsTemplate(secrets) {
  if (secrets === 'vault') return `# secrets/vault-config.yaml
# Vault Agent Injector annotations (K8s)
annotations:
  vault.hashicorp.com/agent-inject: "true"
  vault.hashicorp.com/role: "\${SERVICE_NAME}-role"
  vault.hashicorp.com/agent-inject-secret-config: "secret/\${SERVICE_NAME}/config"
  vault.hashicorp.com/agent-inject-template-config: |
    {{ with secret "secret/\${SERVICE_NAME}/config" -}}
    DB_PASSWORD={{ .Data.data.db_password }}
    API_KEY={{ .Data.data.api_key }}
    {{- end }}`;

  if (secrets === 'ssm') return `# secrets/ssm-policy.json
# IAM policy — attach to ECS task role or Lambda execution role
{
  "Effect": "Allow",
  "Action": ["ssm:GetParameter", "ssm:GetParametersByPath"],
  "Resource": "arn:aws:ssm:\${AWS_REGION}:\${ACCOUNT_ID}:parameter/\${SERVICE_NAME}/*"
}
# Parameter naming convention:
# /\${SERVICE_NAME}/production/DB_PASSWORD
# /\${SERVICE_NAME}/production/API_KEY`;

  return `# secrets/azure-keyvault.yaml
# Azure Key Vault CSI Driver (K8s) or SDK (app-level)
apiVersion: secrets-store.csi.x-k8s.io/v1
kind: SecretProviderClass
metadata:
  name: \${SERVICE_NAME}-secrets
spec:
  provider: azure
  parameters:
    keyvaultName: "\${KEYVAULT_NAME}"
    objects: |
      array:
        - objectName: db-password
          objectType: secret
        - objectName: api-key
          objectType: secret`;
}

function catalogTemplate(svcType, lang, infra) {
  return `# catalog-info.yaml (Backstage)
apiVersion: backstage.io/v1alpha1
kind: Component
metadata:
  name: \${SERVICE_NAME}
  description: "\${SERVICE_DESCRIPTION}"
  tags:
    - ${lang}
    - ${svcType}
    - ${infra}
  annotations:
    github.com/project-slug: "\${ORG}/\${SERVICE_NAME}"
    backstage.io/techdocs-ref: dir:.
spec:
  type: service
  lifecycle: production
  owner: \${TEAM_NAME}
  system: \${SYSTEM_NAME}`;
}

function generate() {
  const svcType = v('svc-type');
  const lang    = v('lang');
  const infra   = v('infra');
  const cicd    = v('cicd');
  const obs     = v('obs');
  const secrets = v('secrets');

  const sections = [
    { title: 'DOCKERFILE TEMPLATE', body: dockerfileTemplate(lang, svcType) },
    { title: `CI/CD — ${LABELS.cicd[cicd].toUpperCase()}`, body: cicdTemplate(cicd, lang, infra) },
    { title: `INFRASTRUCTURE — ${LABELS.infra[infra].toUpperCase()}`, body: infraTemplate(infra, svcType) },
    { title: `OBSERVABILITY — ${LABELS.obs[obs].toUpperCase()}`, body: obsTemplate(obs, svcType) },
    { title: `SECRET MANAGER — ${LABELS.secrets[secrets].toUpperCase()}`, body: secretsTemplate(secrets) },
    { title: 'CATALOG DESCRIPTOR (Backstage)', body: catalogTemplate(svcType, lang, infra) },
  ];

  const sep = '# ' + '─'.repeat(60);
  const output = sections.map(s => `${sep}\n# ${s.title}\n${sep}\n${s.body}`).join('\n\n');

  document.getElementById('config-output').textContent = output;

  // Stack summary badges
  const summary = document.getElementById('stack-summary');
  summary.innerHTML = '';
  [
    LABELS.svcType[svcType], LABELS.lang[lang], LABELS.infra[infra],
    LABELS.cicd[cicd], LABELS.obs[obs], LABELS.secrets[secrets]
  ].forEach(label => {
    const span = document.createElement('span');
    span.className = 'px-2 py-0.5 bg-primary/10 text-primary text-xs rounded font-mono';
    span.textContent = label;
    summary.appendChild(span);
  });

  document.getElementById('output-section').classList.remove('hidden');
  setTimeout(() => document.getElementById('output-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
}

document.getElementById('btn-generate')?.addEventListener('click', generate);

document.getElementById('btn-reset')?.addEventListener('click', () => {
  ['svc-type','lang','infra','cicd','obs','secrets'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.selectedIndex = 0;
  });
  document.getElementById('output-section').classList.add('hidden');
});

document.getElementById('btn-copy')?.addEventListener('click', function() {
  const text = document.getElementById('config-output').textContent;
  navigator.clipboard.writeText(text).then(() => {
    this.textContent = 'Copied!';
    setTimeout(() => { this.textContent = 'Copy'; }, 2000);
  });
});

// Auto-generate on load
generate();
</script>
