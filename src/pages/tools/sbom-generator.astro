---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SbomGenerator from '../../components/SbomGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is an SBOM and why do I need one?",
    answer: "A Software Bill of Materials (SBOM) is a machine-readable inventory of every component, library, and dependency in your software. It is used for supply chain security audits, vulnerability scanning (knowing what you ship), open-source license compliance, and regulatory requirements like the US Executive Order 14028 and the EU Cyber Resilience Act."
  },
  {
    question: "What is CycloneDX and how does it compare to SPDX?",
    answer: "CycloneDX is an OWASP-backed SBOM standard optimised for security use cases — vulnerability tracking, VEX (Vulnerability Exploitability eXchange), and integration with tools like Dependency-Track. SPDX is a Linux Foundation standard focused on licence compliance. CycloneDX 1.5 (generated by this tool) is widely supported by GitHub, Grype, Trivy, and most CI/CD pipelines."
  },
  {
    question: "Which package file formats does this tool support?",
    answer: "Four ecosystems are supported: npm (package.json — reads dependencies, devDependencies, peerDependencies, and optionalDependencies), pip (requirements.txt — standard ==, >=, ~= version specifiers), Cargo (Cargo.toml — [dependencies] and [dev-dependencies] sections), and Go modules (go.mod — require blocks and inline require statements). The ecosystem is auto-detected from the file content."
  },
  {
    question: "What is a PURL (Package URL)?",
    answer: "A Package URL (PURL) is a standardised string that uniquely identifies a software package across ecosystems. The format is pkg:type/namespace/name@version. For example, pkg:npm/lodash@4.17.21 or pkg:pypi/requests@2.31.0. PURLs are used in SBOMs, vulnerability databases (OSV, NVD), and tools like OWASP Dependency-Track to unambiguously match packages against known CVEs."
  },
  {
    question: "Is this tool secure to use with internal package files?",
    answer: "Yes. All parsing and SBOM generation runs entirely in your browser using client-side JavaScript — no file content is ever sent to a server. The CycloneDX JSON is built locally and downloaded directly to your machine. It is safe to use with proprietary or internal dependency manifests."
  },
];
---

<BaseLayout
  title="SBOM Generator — Generate CycloneDX SBOMs Online | DevPlaybook"
  description="Generate CycloneDX 1.5 Software Bill of Materials (SBOM) from package.json, requirements.txt, Cargo.toml, or go.mod. Auto-detects ecosystem, lists all dependencies with PURLs, and exports JSON. Runs entirely in your browser."
  tool="SBOM Generator, CycloneDX Generator, Software Bill of Materials, Supply Chain Security"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "SBOM Generator",
    "url": "https://devplaybook.cc/tools/sbom-generator",
    "description": "Generate CycloneDX 1.5 Software Bill of Materials (SBOM) from package.json, requirements.txt, Cargo.toml, or go.mod. Runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">SBOM Generator</h1>
  <p class="text-text-muted mb-4">
    Paste a package file and instantly generate a <strong class="text-text">CycloneDX 1.5</strong> Software Bill of Materials.
    Supports <code class="font-mono bg-surface px-1 rounded text-sm">package.json</code>,
    <code class="font-mono bg-surface px-1 rounded text-sm">requirements.txt</code>,
    <code class="font-mono bg-surface px-1 rounded text-sm">Cargo.toml</code>, and
    <code class="font-mono bg-surface px-1 rounded text-sm">go.mod</code> — ecosystem detected automatically.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CycloneDX 1.5 format</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> npm / pip / cargo / go</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> PURL for every component</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <SbomGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SBOM Generator" relatedTags={['security', 'dependencies', 'supply-chain', 'devops', 'compliance']} />
</BaseLayout>
