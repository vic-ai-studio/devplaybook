---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is MCP (Model Context Protocol)?", answer: "MCP is an open standard by Anthropic that defines how AI models connect to external tools, data sources, and services. An MCP server exposes capabilities (tools, resources, prompts) through a standardized JSON interface. Hosts like Claude Desktop, Cursor, and other AI tools act as MCP clients that connect to these servers." },
  { question: "What are the valid MCP transport types?", answer: "MCP supports two transport types: 'stdio' (Standard I/O — the MCP server runs as a subprocess and communicates via stdin/stdout, most common for local tools) and 'sse' (Server-Sent Events — connects to a running HTTP server at a URL, used for remote/cloud MCP servers). The 'command' field is required for stdio; 'url' is required for sse." },
  { question: "Why does my MCP server show as 'disabled' in Claude Desktop?", answer: "Common reasons: (1) The 'command' or 'args' path is wrong — use absolute paths in production, (2) Missing required fields in the config, (3) JSON syntax errors, (4) The server process crashes on startup — check Claude Desktop logs at ~/Library/Logs/Claude/ (macOS). Use this validator to catch schema issues before troubleshooting runtime errors." },
  { question: "Where does Claude Desktop store its MCP config?", answer: "macOS: ~/Library/Application Support/Claude/claude_desktop_config.json. Windows: %APPDATA%\\Claude\\claude_desktop_config.json. The top-level key is 'mcpServers' and each value is an MCP server config object. After editing, restart Claude Desktop to apply changes." },
  { question: "What does 'env' do in MCP config?", answer: "The 'env' object passes environment variables to the MCP server subprocess. Use it for API keys and secrets instead of hardcoding them in 'args'. For example: { \"env\": { \"GITHUB_TOKEN\": \"ghp_xxxx\" } }. Never commit configs with real tokens — use shell variable substitution or a secrets manager in CI/CD." },
];
---

<BaseLayout
  title="MCP Config Validator — Model Context Protocol JSON Schema Checker"
  description="Validate your MCP server configuration JSON. Check required fields, transport types, command format, and get actionable error messages for Claude Desktop, Cursor, and other MCP hosts."
  tool="MCP Config Validator, Model Context Protocol Validator, Claude Desktop MCP Config, MCP Server Config Checker"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">MCP Config Validator</h1>
  <p class="text-text-muted mb-4">Paste your MCP server config JSON to validate schema, required fields, transport type, and command format. Instant in-browser validation.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> stdio + SSE transport support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Schema validation with error lines</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Works with Claude Desktop format</span>
  </div>

  <!-- Example buttons -->
  <div class="flex gap-2 mb-4 flex-wrap">
    <button id="example-stdio" class="text-xs px-3 py-1.5 border border-border rounded-lg hover:border-primary transition-colors">Load stdio Example</button>
    <button id="example-sse" class="text-xs px-3 py-1.5 border border-border rounded-lg hover:border-primary transition-colors">Load SSE Example</button>
    <button id="example-desktop" class="text-xs px-3 py-1.5 border border-border rounded-lg hover:border-primary transition-colors">Load Claude Desktop Format</button>
    <button id="example-invalid" class="text-xs px-3 py-1.5 border border-red-400/50 text-red-400 rounded-lg hover:border-red-400 transition-colors">Load Invalid Example</button>
  </div>

  <!-- JSON input -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-base font-semibold">MCP Config JSON</h2>
      <button id="clear-btn" class="text-xs px-3 py-1.5 border border-border rounded-lg hover:border-red-400 transition-colors">Clear</button>
    </div>
    <textarea id="json-input" rows="14" placeholder='Paste your MCP server config here...\n\nExample:\n{\n  "command": "npx",\n  "args": ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"]\n}'
      class="w-full bg-bg-card border border-border rounded-lg px-3 py-2.5 text-sm font-mono focus:outline-none focus:border-primary resize-y"></textarea>
    <div class="flex items-center justify-between mt-3">
      <div id="parse-status" class="text-xs text-text-muted"></div>
      <button id="validate-btn" class="px-5 py-2 bg-primary text-white text-sm font-medium rounded-lg hover:bg-primary/80 transition-colors">Validate →</button>
    </div>
  </div>

  <!-- Validation results -->
  <div id="results" class="hidden space-y-4 mb-6">
    <div id="verdict-banner" class="rounded-xl p-4 flex items-center gap-3">
      <span id="verdict-icon" class="text-2xl"></span>
      <div>
        <div id="verdict-title" class="font-semibold"></div>
        <div id="verdict-desc" class="text-sm text-text-muted"></div>
      </div>
    </div>

    <!-- Errors & Warnings -->
    <div id="errors-section" class="hidden bg-bg-card border border-red-500/30 rounded-xl p-5">
      <h2 class="text-base font-semibold text-red-400 mb-3">Errors</h2>
      <div id="errors-list" class="space-y-2"></div>
    </div>
    <div id="warnings-section" class="hidden bg-bg-card border border-yellow-500/30 rounded-xl p-5">
      <h2 class="text-base font-semibold text-yellow-400 mb-3">Warnings</h2>
      <div id="warnings-list" class="space-y-2"></div>
    </div>

    <!-- Parsed fields -->
    <div id="parsed-section" class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="text-base font-semibold mb-3">Parsed Fields</h2>
      <div id="parsed-fields" class="space-y-2 text-sm"></div>
    </div>

    <!-- Tips -->
    <div id="tips-section" class="hidden bg-bg-card border border-blue-500/20 rounded-xl p-5">
      <h2 class="text-base font-semibold text-blue-400 mb-3">Suggestions</h2>
      <div id="tips-list" class="space-y-2 text-sm text-text-muted"></div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="MCP Config Validator" relatedTags={['mcp', 'ai', 'claude', 'llm', 'tools', 'config', 'validation']} />
</BaseLayout>

<script>
  interface ValidationResult {
    errors: string[];
    warnings: string[];
    tips: string[];
    fields: Record<string, string>;
    valid: boolean;
  }

  const EXAMPLES = {
    stdio: `{
  "command": "npx",
  "args": ["-y", "@modelcontextprotocol/server-filesystem", "/Users/me/projects"],
  "env": {
    "NODE_ENV": "production"
  }
}`,
    sse: `{
  "type": "sse",
  "url": "https://my-mcp-server.example.com/sse",
  "headers": {
    "Authorization": "Bearer my-token"
  }
}`,
    desktop: `{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_your_token_here"
      }
    }
  }
}`,
    invalid: `{
  "type": "websocket",
  "command": 42,
  "args": "should-be-array",
  "env": "should-be-object"
}`,
  };

  function validateMcpConfig(raw: string): ValidationResult {
    const result: ValidationResult = { errors: [], warnings: [], tips: [], fields: {}, valid: false };

    let parsed: unknown;
    try {
      parsed = JSON.parse(raw);
    } catch (e: unknown) {
      result.errors.push(`JSON syntax error: ${e instanceof Error ? e.message : String(e)}`);
      return result;
    }

    if (typeof parsed !== 'object' || parsed === null || Array.isArray(parsed)) {
      result.errors.push('Config must be a JSON object, not an array or primitive.');
      return result;
    }

    const obj = parsed as Record<string, unknown>;

    // Claude Desktop wrapper format
    if ('mcpServers' in obj) {
      const servers = obj.mcpServers;
      if (typeof servers !== 'object' || servers === null || Array.isArray(servers)) {
        result.errors.push('"mcpServers" must be an object mapping server names to configs.');
        return result;
      }
      const srvMap = servers as Record<string, unknown>;
      const names = Object.keys(srvMap);
      result.fields['Format'] = 'Claude Desktop (mcpServers wrapper)';
      result.fields['Server count'] = String(names.length);

      let allOk = true;
      for (const name of names) {
        const srv = srvMap[name];
        if (typeof srv !== 'object' || srv === null) {
          result.errors.push(`Server "${name}": config must be an object.`);
          allOk = false;
          continue;
        }
        const sub = validateSingleServer(srv as Record<string, unknown>, name);
        result.errors.push(...sub.errors);
        result.warnings.push(...sub.warnings);
        result.tips.push(...sub.tips);
        Object.assign(result.fields, Object.fromEntries(
          Object.entries(sub.fields).map(([k, v]) => [`${name}.${k}`, v])
        ));
        if (!sub.valid) allOk = false;
      }
      result.valid = allOk && result.errors.length === 0;
      return result;
    }

    // Single server format
    const sub = validateSingleServer(obj, 'server');
    result.errors.push(...sub.errors);
    result.warnings.push(...sub.warnings);
    result.tips.push(...sub.tips);
    result.fields = sub.fields;
    result.valid = sub.valid;
    return result;
  }

  function validateSingleServer(obj: Record<string, unknown>, name: string): ValidationResult {
    const result: ValidationResult = { errors: [], warnings: [], tips: [], fields: {}, valid: false };
    const prefix = name !== 'server' ? `[${name}] ` : '';

    const transport = (obj.type as string) || 'stdio';
    result.fields['Transport'] = transport;

    if (obj.type && !['stdio', 'sse'].includes(transport)) {
      result.errors.push(`${prefix}Invalid transport type "${transport}". Must be "stdio" or "sse".`);
    }

    if (transport === 'sse') {
      if (!obj.url) {
        result.errors.push(`${prefix}SSE transport requires a "url" field.`);
      } else if (typeof obj.url !== 'string') {
        result.errors.push(`${prefix}"url" must be a string.`);
      } else {
        result.fields['URL'] = obj.url as string;
        if (!String(obj.url).startsWith('http')) {
          result.warnings.push(`${prefix}"url" should start with http:// or https://.`);
        }
        if (String(obj.url).includes('localhost') || String(obj.url).includes('127.0.0.1')) {
          result.tips.push(`${prefix}Local SSE URL detected. Ensure the server is running before connecting.`);
        }
      }
      if (obj.command) {
        result.warnings.push(`${prefix}"command" is ignored for SSE transport — it only applies to stdio.`);
      }
    } else {
      // stdio
      if (!obj.command) {
        result.errors.push(`${prefix}stdio transport requires a "command" field (e.g. "npx", "node", "python").`);
      } else if (typeof obj.command !== 'string') {
        result.errors.push(`${prefix}"command" must be a string.`);
      } else {
        result.fields['Command'] = obj.command as string;
      }

      if (obj.args !== undefined) {
        if (!Array.isArray(obj.args)) {
          result.errors.push(`${prefix}"args" must be an array of strings.`);
        } else {
          const badArgs = (obj.args as unknown[]).filter(a => typeof a !== 'string');
          if (badArgs.length > 0) {
            result.errors.push(`${prefix}"args" array must contain only strings. Found non-string values.`);
          } else {
            result.fields['Args'] = (obj.args as string[]).join(' ');
          }
        }
      }
    }

    if (obj.env !== undefined) {
      if (typeof obj.env !== 'object' || Array.isArray(obj.env) || obj.env === null) {
        result.errors.push(`${prefix}"env" must be an object (key-value pairs).`);
      } else {
        const envMap = obj.env as Record<string, unknown>;
        const envKeys = Object.keys(envMap);
        result.fields['Env vars'] = envKeys.length > 0 ? envKeys.join(', ') : '(empty)';
        const nonStringVals = envKeys.filter(k => typeof envMap[k] !== 'string');
        if (nonStringVals.length > 0) {
          result.warnings.push(`${prefix}env values should be strings. Non-string: ${nonStringVals.join(', ')}`);
        }
        const secretKeys = envKeys.filter(k => /token|key|secret|password|auth/i.test(k));
        if (secretKeys.length > 0) {
          result.tips.push(`${prefix}Secret-looking env vars detected (${secretKeys.join(', ')}). Ensure you're not committing real values to version control.`);
        }
      }
    }

    const knownKeys = new Set(['type', 'command', 'args', 'env', 'url', 'headers', 'disabled', 'alwaysAllow']);
    const unknown = Object.keys(obj).filter(k => !knownKeys.has(k));
    if (unknown.length > 0) {
      result.warnings.push(`${prefix}Unknown fields: ${unknown.join(', ')}. These will be ignored by most MCP hosts.`);
    }

    if (obj.disabled === true) {
      result.tips.push(`${prefix}"disabled": true — this server will be skipped by MCP hosts.`);
    }

    result.valid = result.errors.length === 0;
    return result;
  }

  function renderResults(res: ValidationResult) {
    const container = document.getElementById('results')!;
    container.classList.remove('hidden');

    const banner = document.getElementById('verdict-banner')!;
    const icon = document.getElementById('verdict-icon')!;
    const title = document.getElementById('verdict-title')!;
    const desc = document.getElementById('verdict-desc')!;

    if (res.valid) {
      banner.className = 'rounded-xl p-4 flex items-center gap-3 bg-green-500/10 border border-green-500/30';
      icon.textContent = '✅';
      title.textContent = 'Valid MCP Config';
      desc.textContent = `No errors found. ${res.warnings.length > 0 ? res.warnings.length + ' warning(s) to review.' : 'Ready to use.'}`;
    } else {
      banner.className = 'rounded-xl p-4 flex items-center gap-3 bg-red-500/10 border border-red-500/30';
      icon.textContent = '❌';
      title.textContent = `Invalid Config — ${res.errors.length} error${res.errors.length > 1 ? 's' : ''}`;
      desc.textContent = 'Fix the errors below before using this config.';
    }

    const errSec = document.getElementById('errors-section')!;
    const warnSec = document.getElementById('warnings-section')!;
    const tipsSec = document.getElementById('tips-section')!;

    if (res.errors.length > 0) {
      errSec.classList.remove('hidden');
      document.getElementById('errors-list')!.innerHTML = res.errors.map(e =>
        `<div class="flex gap-2 text-sm"><span class="text-red-400 shrink-0">✕</span><span>${e}</span></div>`
      ).join('');
    } else {
      errSec.classList.add('hidden');
    }

    if (res.warnings.length > 0) {
      warnSec.classList.remove('hidden');
      document.getElementById('warnings-list')!.innerHTML = res.warnings.map(w =>
        `<div class="flex gap-2 text-sm"><span class="text-yellow-400 shrink-0">⚠</span><span>${w}</span></div>`
      ).join('');
    } else {
      warnSec.classList.add('hidden');
    }

    if (res.tips.length > 0) {
      tipsSec.classList.remove('hidden');
      document.getElementById('tips-list')!.innerHTML = res.tips.map(t =>
        `<div class="flex gap-2"><span class="text-blue-400 shrink-0">ℹ</span><span>${t}</span></div>`
      ).join('');
    } else {
      tipsSec.classList.add('hidden');
    }

    const fields = res.fields;
    document.getElementById('parsed-fields')!.innerHTML = Object.keys(fields).length > 0
      ? Object.entries(fields).map(([k, v]) =>
          `<div class="flex justify-between gap-4 border-b border-border py-1.5 last:border-0">
            <span class="text-text-muted shrink-0">${k}</span>
            <span class="font-mono text-right truncate max-w-xs" title="${v}">${v}</span>
          </div>`
        ).join('')
      : '<p class="text-text-muted text-sm">No valid fields parsed.</p>';
  }

  const input = document.getElementById('json-input') as HTMLTextAreaElement;

  input.addEventListener('input', () => {
    const raw = input.value.trim();
    if (!raw) {
      document.getElementById('parse-status')!.textContent = '';
      return;
    }
    try {
      JSON.parse(raw);
      document.getElementById('parse-status')!.textContent = '✓ Valid JSON syntax';
      document.getElementById('parse-status')!.className = 'text-xs text-green-400';
    } catch (e: unknown) {
      document.getElementById('parse-status')!.textContent = `✕ ${e instanceof Error ? e.message : 'Invalid JSON'}`;
      document.getElementById('parse-status')!.className = 'text-xs text-red-400';
    }
  });

  document.getElementById('validate-btn')!.addEventListener('click', () => {
    const raw = input.value.trim();
    if (!raw) return;
    const res = validateMcpConfig(raw);
    renderResults(res);
  });

  document.getElementById('clear-btn')!.addEventListener('click', () => {
    input.value = '';
    document.getElementById('parse-status')!.textContent = '';
    document.getElementById('results')!.classList.add('hidden');
  });

  document.getElementById('example-stdio')!.addEventListener('click', () => {
    input.value = EXAMPLES.stdio;
    input.dispatchEvent(new Event('input'));
  });
  document.getElementById('example-sse')!.addEventListener('click', () => {
    input.value = EXAMPLES.sse;
    input.dispatchEvent(new Event('input'));
  });
  document.getElementById('example-desktop')!.addEventListener('click', () => {
    input.value = EXAMPLES.desktop;
    input.dispatchEvent(new Event('input'));
  });
  document.getElementById('example-invalid')!.addEventListener('click', () => {
    input.value = EXAMPLES.invalid;
    input.dispatchEvent(new Event('input'));
  });
</script>
