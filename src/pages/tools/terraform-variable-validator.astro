---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TerraformVariableValidator from '../../components/TerraformVariableValidator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What does this tool validate?",
    answer: "It parses your variables.tf file and checks for missing descriptions, missing type constraints, secrets that should be marked sensitive, type/default value mismatches (e.g. a number type with a string default), required variables without defaults, and tab characters that aren't valid HCL."
  },
  {
    question: "What is a Terraform variable type constraint?",
    answer: "Type constraints tell Terraform what kind of value a variable expects: string, number, bool, list(string), map(string), set(string), object({...}), or tuple([...]). Without a type, Terraform infers any type, which can lead to unexpected behavior when a caller passes the wrong value type."
  },
  {
    question: "Why should secrets be marked sensitive = true?",
    answer: "Marking a variable sensitive = true tells Terraform to redact its value from plan output, apply output, and state display. Without it, passwords, tokens, and API keys may appear in CI/CD logs or terraform show output in plain text."
  },
  {
    question: "What is the difference between required and optional variables?",
    answer: "A Terraform variable without a default value is required — callers must supply it via tfvars, environment variables (TF_VAR_name), or -var flags. A variable with a default is optional. Required variables are not necessarily secrets; they're just configuration that must be explicitly set per environment."
  },
  {
    question: "Should I add a validation block to every variable?",
    answer: "Not necessarily. Validation blocks are most useful for variables with a constrained set of valid values (e.g. environment = 'prod' | 'staging' | 'dev') or numeric ranges (e.g. instance_count between 1 and 10). For simple strings or flags, type constraints are usually sufficient."
  },
  {
    question: "Does this tool send my Terraform code to a server?",
    answer: "No. All validation runs entirely in your browser using JavaScript. Your variables.tf content never leaves your machine."
  },
];
---

<BaseLayout
  title="Terraform Variable Validator — Check variables.tf Online"
  description="Paste your Terraform variables.tf and validate it instantly. Checks for missing descriptions, missing type constraints, secret variables without sensitive=true, type/default mismatches, and HCL syntax issues. Runs in your browser."
  tool="Terraform variable validator, variables.tf checker, Terraform type validator, HCL variable linter, Terraform secrets validator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Terraform Variable Validator",
    "url": "https://devplaybook.cc/tools/terraform-variable-validator",
    "description": "Validate Terraform variables.tf files online. Catches missing type constraints, undocumented variables, unmasked secrets, and type/default mismatches. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Terraform Variable Validator</h1>
  <p class="text-text-muted mb-4">
    Paste your <code class="font-mono bg-surface px-1 rounded text-sm">variables.tf</code> and catch common mistakes instantly.
    Validates type constraints, missing descriptions, secret handling, and type/default mismatches.
    Nothing is sent to any server — runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 7 validation checks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Secrets & sensitive detection</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No data leaves your browser</span>
  </div>
  <TerraformVariableValidator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Terraform Variable Validator" relatedTags={['terraform', 'iac', 'devops', 'infrastructure', 'cloud', 'validation', 'aws', 'gcp', 'azure']} />
</BaseLayout>
