---
import BaseLayout from '../../layouts/BaseLayout.astro';
import VercelConfigGenerator from '../../components/VercelConfigGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is vercel.json and when do I need it?",
    answer: "vercel.json is Vercel's project configuration file. You need it when you want to customize build behavior beyond Vercel's auto-detection — for example, adding URL rewrites (to proxy API requests), custom response headers (for security or caching), function timeouts, or region configuration. For simple projects, Vercel auto-detects your framework and you may not need it at all."
  },
  {
    question: "What's the difference between rewrites and redirects in Vercel?",
    answer: "Rewrites forward requests to a new destination transparently — the user's browser URL doesn't change. Redirects send the browser to a new URL (301/302 responses). Use rewrites to proxy API calls to a backend (e.g. /api/:path* → https://api.example.com/:path*) to avoid CORS issues. Use redirects for SEO-friendly URL restructuring where the URL should visibly change."
  },
  {
    question: "How do I choose between Vercel deployment regions?",
    answer: "Choose regions closest to your users or backend services. iad1 (US East, Virginia) is Vercel's default and primary region. sfo1 (US West) is good for West Coast or Asia-Pacific traffic. lhr1 (London) and cdg1 (Paris) serve European users. sin1 (Singapore) and hnd1 (Tokyo) serve Southeast Asia and Japan. For global apps, deploying to multiple regions reduces latency but increases cost."
  },
  {
    question: "What does maxDuration do for Vercel Functions?",
    answer: "maxDuration sets the maximum execution time (in seconds) for a serverless function before Vercel terminates it. The Hobby plan allows up to 10s, Pro up to 300s. For API routes that call slow external services or run heavy computations (like AI inference), increasing maxDuration prevents timeout errors. Default is 10s on Hobby and 15s on Pro."
  },
  {
    question: "How do I add security headers with vercel.json?",
    answer: "Use the headers field to add HTTP response headers to all or specific routes. Common security headers: X-Content-Type-Options: nosniff (prevents MIME sniffing), X-Frame-Options: DENY (prevents clickjacking), Strict-Transport-Security (forces HTTPS), Content-Security-Policy (prevents XSS). Apply them to /(.*)  to cover all routes. These headers are injected at the CDN edge, so there's no performance cost."
  },
  {
    question: "Can I use vercel.json with Next.js rewrites configured in next.config.js?",
    answer: "Yes, but they work at different layers. next.config.js rewrites run inside the Next.js server and can access middleware/auth context. vercel.json rewrites run at the CDN/edge before hitting Next.js — useful for routing to external services. If both are set, vercel.json takes precedence for requests it matches. Avoid duplicating the same rules in both files to prevent confusion."
  },
];
---

<BaseLayout
  title="Vercel Config Generator — Generate vercel.json Visually"
  description="Generate a complete vercel.json configuration file visually. Configure build settings, URL rewrites, response headers, deployment regions, and function timeouts. Free, runs in your browser."
  tool="Vercel Config Generator, vercel.json, Vercel Deployment, Vercel Rewrites, Vercel Headers, Serverless Functions"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Vercel Config Generator",
    "url": "https://devplaybook.cc/tools/vercel-config-generator",
    "description": "Generate a complete vercel.json configuration file visually. Configure build settings, URL rewrites, response headers, deployment regions, and serverless function options.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Vercel Config Generator</h1>
  <p class="text-text-muted mb-4">
    Build a complete <code class="text-accent font-mono">vercel.json</code> visually.
    Select your framework, configure URL rewrites and custom headers, pick deployment regions,
    and tune function timeouts — then copy the ready-to-use JSON.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Next.js / Astro / Vite / SvelteKit / Remix</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> URL rewrites & response headers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multi-region deployment</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Function maxDuration & memory</span>
  </div>
  <VercelConfigGenerator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Vercel Config Generator" relatedTags={['vercel', 'deployment', 'nextjs', 'devops', 'developer-tools']} />
</BaseLayout>
