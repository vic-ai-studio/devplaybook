---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CronExpressionExplainer from '../../components/CronExpressionExplainer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a cron expression?",
    answer: "A cron expression is a 5-field string that defines a schedule for recurring tasks. The fields, left to right, represent: Minute (0-59), Hour (0-23), Day of Month (1-31), Month (1-12), and Day of Week (0-7, where both 0 and 7 represent Sunday). Use * for 'every', */n for 'every n units', and ranges like 1-5 or lists like 1,3,5."
  },
  {
    question: "What does the asterisk (*) mean in cron?",
    answer: "An asterisk means 'any value' or 'every possible value' for that field. So '* * * * *' runs every minute of every hour of every day. '0 * * * *' runs at minute 0 of every hour (i.e. once per hour). '0 9 * * *' runs at 9:00 AM every day."
  },
  {
    question: "What is the difference between */15 and 0,15,30,45?",
    answer: "Both produce the same result: they run at minutes 0, 15, 30, and 45 of every hour. The step syntax (*/15) is more concise and readable for evenly-spaced intervals. The list syntax (0,15,30,45) is more explicit and useful for irregular intervals like 0,20,50."
  },
  {
    question: "Does cron use my local timezone?",
    answer: "By default, cron on Linux runs in the server's local timezone (set by /etc/timezone or TZ env var). GitHub Actions cron runs in UTC. AWS EventBridge uses UTC by default but supports timezone scheduling. Always check your scheduler's timezone setting, especially for daylight saving time transitions."
  },
  {
    question: "Can I run a cron job more than once a minute?",
    answer: "Standard cron cannot schedule sub-minute intervals — the minimum is 1 minute (* * * * *). For more frequent execution, use a sleep loop inside your script (e.g., while true; do task; sleep 10; done), systemd timers with sub-second precision, or dedicated task schedulers that support finer granularity."
  },
];
---

<BaseLayout
  title="Cron Expression Explainer — Plain-English Cron Schedule Decoder"
  description="Enter any cron expression and get a plain-English explanation plus the next 5 scheduled run times. Choose from common presets. Free, runs 100% in your browser."
  tool="cron expression explainer, cron decoder, cron schedule explainer, cron to plain English, cron next run time, cron expression guide"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Cron Expression Explainer",
    "url": "https://devplaybook.cc/tools/cron-expression-explainer",
    "description": "Enter any cron expression and get a plain-English explanation plus the next 5 scheduled run times. Includes common presets.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Cron Expression Explainer</h1>
  <p class="text-text-muted mb-4">
    Enter any cron expression to get an instant plain-English breakdown of each field plus the next 5 scheduled run times. Use the preset chips for the most common schedules.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Plain-English per-field explanation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Next 5 run times</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Common presets</span>
  </div>
  <CronExpressionExplainer client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Cron Expression Explainer" relatedTags={['cron', 'scheduler', 'devops', 'linux', 'automation']} />
</BaseLayout>
