---
import BaseLayout from '../../layouts/BaseLayout.astro';
import IcalEventGenerator from '../../components/IcalEventGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is an .ics file?", answer: "An .ics file is a calendar file in the iCalendar format (RFC 5545). It contains event data — title, start/end time, location, description, organizer, and recurrence rules — in a standardized plain-text format. Every major calendar app (Google Calendar, Apple Calendar, Outlook, Thunderbird) can import .ics files." },
  { question: "How do I add the .ics event to my calendar?", answer: "Download the .ics file and double-click it — your default calendar app will offer to import it. On mobile, email the file to yourself or AirDrop it and tap it to open. In Google Calendar, go to Settings → Import and upload the .ics file. In Outlook, go to File → Open & Export → Import/Export." },
  { question: "What repeat rules does this generator support?", answer: "This generator supports four repeat patterns: None (single event), Daily (every day), Weekly (every 7 days), and Monthly (same date each month). You can set the number of occurrences to limit how many times the event repeats, or set it to 0 for infinite recurrence." },
  { question: "Can I share the .ics event with other people?", answer: "Yes — you can email the .ics file to anyone and they can import it into their calendar. The ORGANIZER field is included for attribution. Note that .ics files are static snapshots; they don't sync live with a shared calendar service like Google Calendar's sharing feature." },
  { question: "What is the iCalendar standard?", answer: "iCalendar (RFC 5545) is an open internet standard for sharing calendar and scheduling information. Published in 1998 and widely supported, it defines the format for events, tasks, and free/busy information. The .ics file extension stands for iCalendar." },
];
---

<BaseLayout
  title="iCal Event Generator — Create .ics Calendar Files Online"
  description="Free iCal event generator. Create .ics calendar files with title, start/end time, location, description, organizer email, and repeat rules (daily/weekly/monthly). Download or copy — compatible with Google Calendar, Outlook, Apple Calendar."
  tool="iCal Generator, ics File Generator, Calendar Event Creator, iCalendar Generator, .ics Event File, Google Calendar Import, Outlook Calendar Event"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">iCal Event Generator</h1>
  <p class="text-text-muted mb-4">Create .ics calendar event files that work with Google Calendar, Apple Calendar, Outlook, and Thunderbird. Fill in event details, set repeat rules, then download or copy the iCalendar content. Runs entirely in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> RFC 5545 compliant</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Works with all major calendar apps</span>
  </div>
  <IcalEventGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="iCal Event Generator" relatedTags={['utilities', 'calendar', 'scheduling', 'productivity']} />
</BaseLayout>
