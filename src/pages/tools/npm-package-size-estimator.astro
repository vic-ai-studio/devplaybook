---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NpmPackageSizeEstimator from '../../components/NpmPackageSizeEstimator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is minified + gzipped size and why does it matter?",
    answer: "Minified + gzipped size is the closest approximation to what your users actually download. Minification removes whitespace, comments, and shortens variable names. Gzip compression further reduces the size by 60-80% on average. Most CDNs and web servers serve gzipped responses automatically. When evaluating package size, always use the min+gz number — the raw minified size is misleading because gzip handles repetition very efficiently."
  },
  {
    question: "What is a good JavaScript bundle size budget?",
    answer: "A common rule of thumb: keep your total JavaScript bundle (excluding React/framework) under 50 KB min+gz for fast loading on mobile. For the full initial load including framework, aim for under 100 KB min+gz. Google's Performance Budget recommends total transfer size under 200 KB on a 3G connection for Time to Interactive under 5 seconds. For critical path JS (blocking render), target under 14 KB — the TCP slow-start window. Libraries like moment (72 KB) or MUI (93 KB) alone can blow your budget."
  },
  {
    question: "Are these package sizes accurate?",
    answer: "Sizes in this tool are approximate based on common bundle sizes reported by bundlephobia.com and bundle.js.org. Actual sizes depend on which parts of the package you import (tree-shaking), your bundler configuration, and whether you're using the ESM or CJS build. For exact sizes, use bundlephobia.com or run your actual bundle through webpack-bundle-analyzer or vite-bundle-visualizer."
  },
  {
    question: "What is tree-shaking and how does it reduce bundle size?",
    answer: "Tree-shaking is a bundler optimization that removes unused exports from your bundle. If you import `import { format } from 'date-fns'`, only the format function is included — not the entire library. For tree-shaking to work, the package must be written as ES modules (ESM with import/export statements, not CommonJS require). Libraries like date-fns, lodash-es, and @radix-ui/* are fully tree-shakeable. Lodash (non-es) is not tree-shakeable — use `lodash-es` or individual imports like `lodash/debounce`."
  },
  {
    question: "What are the best lighter alternatives to popular heavy packages?",
    answer: "moment → dayjs (2.6 KB vs 72 KB). lodash → lodash-es with named imports or radash (4 KB). axios → ky (4 KB) or native fetch. @mui/material → headless UI + Tailwind or shadcn/ui. framer-motion → CSS transitions or motion/react (subset). redux + react-redux → zustand (1.2 KB) or jotai (3.1 KB). yup → zod (12 KB) or valibot (1.2 KB). formik → react-hook-form (8.6 KB). These alternatives often have better TypeScript support too."
  },
  {
    question: "How can I analyze my actual project's bundle?",
    answer: "For Vite projects: install `rollup-plugin-visualizer` and add it to vite.config.ts. For webpack: use `webpack-bundle-analyzer`. For Next.js: use `@next/bundle-analyzer`. For a quick check without building: use `bundlephobia.com` to check individual packages, or `bundlesize` CLI for CI budget enforcement. The Chrome DevTools Coverage tab shows unused JavaScript on an actual page load. For per-route analysis in Next.js, check the build output — it shows each route's JS size."
  },
];
---

<BaseLayout
  title="npm Package Size Estimator — Bundle Size Checker for 60+ Packages"
  description="Estimate your JavaScript bundle size from npm packages. Built-in database of 60+ popular packages with minified+gzipped sizes. See lighter alternatives, budget indicators, and category breakdowns."
  tool="npm package size, bundle size estimator, javascript bundle analyzer, package size checker, npm bundle size"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "npm Package Size Estimator",
    "url": "https://devplaybook.cc/tools/npm-package-size-estimator",
    "description": "Check the bundle size of npm packages before adding them to your project. Built-in database of 60+ popular packages with min+gz sizes, lighter alternatives, and budget indicators.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">npm Package Size Estimator</h1>
  <p class="text-text-muted mb-4">
    Check the <strong>bundle size</strong> of npm packages before adding them to your project. Enter package names to see individual sizes, total bundle weight, a budget indicator, and suggestions for lighter alternatives. Built-in database of <strong>60+ popular packages</strong> with minified+gzipped sizes.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60+ packages in database</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Budget indicator</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Lighter alternatives</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Category breakdown</span>
  </div>
  <NpmPackageSizeEstimator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="npm Package Size Estimator" relatedTags={['javascript', 'performance', 'npm', 'bundle', 'webpack', 'vite']} />
</BaseLayout>
