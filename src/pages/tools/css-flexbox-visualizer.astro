---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CssFlexboxVisualizer from '../../components/CssFlexboxVisualizer.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is CSS Flexbox?", answer: "Flexbox (Flexible Box Layout) is a CSS layout model that lets you arrange items in a row or column, distribute space, and align elements — even when their sizes are unknown. It's the foundation of most modern responsive UIs." },
  { question: "What does flex-direction do?", answer: "'row' places items left-to-right (default). 'row-reverse' places them right-to-left. 'column' stacks items top-to-bottom. 'column-reverse' stacks them bottom-to-top. The direction also changes the meaning of the main axis and cross axis." },
  { question: "What is the difference between justify-content and align-items?", answer: "justify-content aligns items along the main axis (the direction flex-direction points). align-items aligns items along the cross axis (perpendicular to main axis). For row direction: justify-content = horizontal, align-items = vertical." },
  { question: "When should I use flex-grow vs flex-basis?", answer: "flex-basis sets the initial size of an item before free space is distributed. flex-grow determines how much of the remaining free space an item absorbs. Use flex-basis to set a starting size and flex-grow to allow expansion. A common pattern: flex: 1 (shorthand for flex-grow:1, flex-shrink:1, flex-basis:0%) makes all items share space equally." },
  { question: "How do I copy the generated CSS?", answer: "Click the 'Copy CSS' button at the bottom. The code includes the container styles and any per-item overrides you've configured. Paste it directly into your stylesheet." },
];
---

<BaseLayout
  title="CSS Flexbox Visualizer — Interactive Flexbox Layout Builder"
  description="Build CSS Flexbox layouts visually. Adjust flex-direction, justify-content, align-items, flex-wrap, and per-item properties. See live preview and copy the generated CSS instantly."
  tool="CSS Flexbox Visualizer, Flexbox Generator, CSS Flex Layout, Flexbox Tutorial"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">CSS Flexbox Visualizer</h1>
  <p class="text-text-muted mb-4">Build Flexbox layouts interactively. Adjust container and item properties, see the live preview update instantly, then copy the generated CSS.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <CssFlexboxVisualizer client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <AffiliateSection category="frontend" />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Need a grid layout instead?</p>
    <a href="/tools/css-grid-generator" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">CSS Grid Generator →</a>
  </div>
  <ToolPageCta currentTool="CSS Flexbox Visualizer" relatedTags={['css', 'flexbox', 'layout', 'frontend', 'design']} />
</BaseLayout>
