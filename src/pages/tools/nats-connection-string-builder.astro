---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NatsConnectionStringBuilder from '../../components/NatsConnectionStringBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is NATS?",
    answer: "NATS is a lightweight, high-performance open-source messaging system for cloud-native applications. It supports publish-subscribe, request-reply, and queue subscriber patterns. NATS is known for its simplicity — a minimal server with no dependencies — and extremely low latency (sub-millisecond in LAN environments)."
  },
  {
    question: "What is the difference between nats:// and tls:// URLs?",
    answer: "nats:// connects to a NATS server over plain TCP (default port 4222). tls:// (or nats:// with TLS options) connects over TLS/SSL. For production deployments, always use TLS to encrypt messages in transit. NATS Leafnode and Gateway connections typically also use TLS."
  },
  {
    question: "How do I use token authentication?",
    answer: "NATS supports token authentication as an alternative to username/password. The server is configured with auth_token (or multiple tokens). Clients connect with a single token string. Token auth is simpler than user/pass for machine-to-machine connections but offers less granular access control than NKeys or JWT-based auth."
  },
  {
    question: "What is NATS cluster mode?",
    answer: "In cluster mode, multiple NATS servers form a cluster and route messages between each other. Clients can provide a list of server URLs — if one server is unavailable, the client automatically reconnects to another. Use cluster mode for high availability and horizontal scaling."
  },
  {
    question: "How does NATS reconnection work?",
    answer: "NATS client libraries support automatic reconnection with configurable max attempts and backoff intervals. When a connection drops, the client will try to reconnect to any of the configured servers. Subscriptions and pending messages are handled automatically based on QoS settings. Set max reconnect attempts to -1 for infinite retries."
  },
  {
    question: "What port does NATS use?",
    answer: "Default NATS client port is 4222. The monitoring HTTP endpoint is on 8222. Cluster routing uses 6222 by default. For TLS, you can use the same 4222 port with TLS configured on the server side, or a dedicated TLS port (common: 4443)."
  },
];
---

<BaseLayout
  title="NATS Connection String Builder — Go, Node.js & Python Snippets"
  description="Build NATS connection strings and generate Go, Node.js, and Python connection code snippets. Configure TLS, authentication, cluster mode, and reconnection options. Free browser tool."
  tool="NATS Connection String Builder, NATS URL Generator, NATS Go Client, NATS Node.js Python"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "NATS Connection String Builder",
    "url": "https://devplaybook.cc/tools/nats-connection-string-builder",
    "description": "Build NATS connection strings and generate ready-to-use Go, Node.js, and Python code snippets with authentication, TLS, cluster, and reconnection options.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">NATS Connection String Builder</h1>
  <p class="text-text-muted mb-4">
    Configure your NATS server connection and get ready-to-use code snippets for Go, Node.js, and Python —
    with TLS, authentication, cluster, and reconnect options.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Go, Node.js & Python snippets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TLS & auth options</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Cluster mode support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <NatsConnectionStringBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="NATS Connection String Builder" relatedTags={['nats', 'messaging', 'microservices', 'go', 'nodejs', 'developer-tools']} />
</BaseLayout>
