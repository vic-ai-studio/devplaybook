---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AzureArmTemplateValidator from '../../components/AzureArmTemplateValidator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is an Azure ARM template?",
    answer: "An Azure Resource Manager (ARM) template is a JSON file that declaratively defines the Azure resources you want to deploy. The template describes the desired end state, and ARM handles the deployment order, parallel operations, and idempotency. ARM templates support parameters (for reusability), variables (for internal calculations), resources (the infrastructure to deploy), and outputs (values returned after deployment). They're the foundation of Infrastructure as Code on Azure."
  },
  {
    question: "What is the $schema field in an ARM template?",
    answer: "The $schema field points to the JSON Schema definition for the template, which enables IDE validation and IntelliSense. Different schemas apply to different deployment scopes: 2019-04-01/deploymentTemplate.json# for resource group deployments (most common), 2018-05-01/subscriptionDeploymentTemplate.json# for subscription-level deployments (policy, RBAC), 2019-08-01/managementGroupDeploymentTemplate.json# for management group deployments, and 2019-08-01/tenantDeploymentTemplate.json# for tenant-level deployments."
  },
  {
    question: "What is the difference between ARM templates and Bicep?",
    answer: "Bicep is a domain-specific language (DSL) that compiles to ARM JSON. It offers cleaner syntax (no JSON boilerplate), better type safety, modules for reusability, and a simpler parameter file format. Bicep is now the recommended way to write Azure IaC — the Azure docs increasingly show Bicep first. ARM JSON is still valid and supported but verbose. You can convert existing ARM templates to Bicep with 'az bicep decompile'. Terraform is another popular alternative that supports Azure alongside other clouds."
  },
  {
    question: "Why should sensitive parameters use securestring?",
    answer: "Parameters with type 'string' are logged in deployment history, Azure Monitor logs, and visible in the Azure Portal. Using 'securestring' tells Azure to never log or display the value — it's treated as a secret throughout the deployment pipeline. Always use securestring for passwords, API keys, connection strings, and certificates. Combine with Azure Key Vault parameter references to avoid passing secrets on the command line at all: ARM can retrieve values directly from Key Vault at deploy time."
  },
  {
    question: "How should I avoid hardcoding locations in ARM templates?",
    answer: "Hardcoding a location like 'eastus' makes the template non-portable — it fails if deployed to a subscription with restrictions or a different preferred region. Instead, use '[resourceGroup().location]' to automatically use the resource group's region (most common), or add a 'location' parameter with a default of '[resourceGroup().location]' to allow overrides. This makes the same template deployable to any region without modification."
  },
  {
    question: "What are ARM template outputs and when should I use them?",
    answer: "Outputs return values from a deployment, such as resource IDs, connection strings, storage account keys, or public IP addresses. They're essential for chained deployments (where one template consumes outputs from another), CI/CD pipelines (capturing connection strings for configuration), and cross-resource-group deployments. Common outputs: storage account connection string, Key Vault URI, App Service default hostname. Access outputs with 'az deployment group show --query properties.outputs'."
  },
];
---

<BaseLayout
  title="Azure ARM Template Validator — Check ARM JSON Online"
  description="Free online Azure ARM template validator. Checks $schema, contentVersion, required resource fields, securestring parameters, hardcoded locations, and structural issues. Runs in your browser."
  tool="Azure ARM template validator, ARM template checker, Azure deployment template linter, ARM JSON validator, Azure infrastructure validator, ARM template best practices"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Azure ARM Template Validator</h1>
  <p class="text-text-muted mb-4">Validate your Azure ARM template JSON for structural errors and best-practice violations — without running <code class="font-mono text-sm bg-surface px-1 rounded">az deployment</code>. Catch missing required fields, insecure parameter types, hardcoded locations, and more before deployment.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 9 validation checks</span>
  </div>
  <AzureArmTemplateValidator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Azure ARM Template Validator" relatedTags={['azure', 'cloud', 'devops', 'security', 'infrastructure']} />
</BaseLayout>
