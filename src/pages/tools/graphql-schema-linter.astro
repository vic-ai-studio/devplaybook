---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What does this GraphQL schema linter check?",
    answer: "It validates SDL syntax structure and checks for: missing Query type, fields without descriptions, deprecated fields and types, naming convention violations (types PascalCase, fields camelCase, enum values SCREAMING_SNAKE_CASE), ID field type consistency, missing pagination on list fields, and custom scalar declarations."
  },
  {
    question: "What is GraphQL SDL?",
    answer: "SDL stands for Schema Definition Language. It is the official way to define a GraphQL schema in a human-readable text format. You define types with type TypeName { fieldName: FieldType }, input types, enums, interfaces, unions, and the root Query/Mutation/Subscription types. SDL is used in schema-first development and by tools like Apollo Studio, GraphQL Inspector, and graphql-codegen."
  },
  {
    question: "Why should every field have a description?",
    answer: "Descriptions appear in GraphQL Playground, Apollo Studio, and any introspection-based documentation tool. Without descriptions, API consumers have no context for what a field means, what values are valid, or what side effects it has. Descriptions are added with triple quotes: \"\"\"User's email address, used for login.\"\"\" before the field."
  },
  {
    question: "What is the @deprecated directive?",
    answer: "The @deprecated directive marks a field, argument, or enum value as deprecated. It takes an optional reason parameter: fieldName: String @deprecated(reason: \"Use newField instead\"). Introspection and GraphQL clients can detect deprecated fields and show warnings to developers. This is the correct way to sunset API fields without breaking clients."
  },
  {
    question: "What naming conventions does GraphQL use?",
    answer: "Types: PascalCase (User, CreateUserInput, UserRole). Fields and arguments: camelCase (firstName, createdAt, userId). Enum values: SCREAMING_SNAKE_CASE (ACTIVE, PENDING_REVIEW, DELETED). Directives: camelCase (@deprecated, @skip, @include). Query/Mutation root type names are conventionally Query and Mutation."
  },
  {
    question: "Does this tool send my schema to a server?",
    answer: "No. All parsing and linting runs entirely in your browser using JavaScript. Your GraphQL schema — which may describe your data model and API surface — never leaves your machine."
  },
];
---

<BaseLayout
  title="GraphQL Schema Linter — Validate GraphQL SDL Online"
  description="Paste your GraphQL SDL schema and lint it for syntax errors, naming conventions, missing descriptions, deprecated patterns, and best practices. Runs 100% in your browser."
  tool="GraphQL schema linter, GraphQL SDL validator, GraphQL lint online, GraphQL schema checker, GraphQL naming conventions, GraphQL best practices"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "GraphQL Schema Linter",
    "url": "https://devplaybook.cc/tools/graphql-schema-linter",
    "description": "Validate and lint GraphQL SDL schemas for syntax errors, naming conventions, missing descriptions, and best practices. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">GraphQL Schema Linter</h1>
  <p class="text-text-muted mb-4">
    Paste your GraphQL SDL schema and detect syntax errors, naming convention violations,
    missing descriptions, deprecated patterns, and best-practice issues.
    Nothing is sent to any server — runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Syntax validation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Naming conventions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Best practice checks</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Input -->
    <div class="flex flex-col gap-3">
      <div class="flex items-center justify-between">
        <label class="text-sm font-medium" for="schema-input">GraphQL SDL Schema</label>
        <button id="load-example-btn" class="text-xs text-accent hover:underline">Load example</button>
      </div>
      <textarea
        id="schema-input"
        rows="24"
        placeholder="Paste your GraphQL SDL schema here...&#10;&#10;type Query {&#10;  user(id: ID!): User&#10;}&#10;&#10;type User {&#10;  id: ID!&#10;  name: String!&#10;}"
        class="w-full px-4 py-3 rounded-xl bg-bg border border-border text-text placeholder:text-text-muted focus:outline-none focus:border-accent transition-colors font-mono text-xs resize-y"
        spellcheck="false"
      ></textarea>
      <button
        id="lint-btn"
        class="w-full py-3 px-6 rounded-xl bg-accent hover:bg-accent/80 text-white font-bold transition-colors duration-200"
      >
        Lint Schema
      </button>
    </div>

    <!-- Output -->
    <div class="flex flex-col gap-3">
      <div class="flex items-center justify-between">
        <label class="text-sm font-medium">Lint Results</label>
        <span id="score-badge" class="hidden text-xs font-semibold px-3 py-1 rounded-full border"></span>
      </div>
      <div id="output-placeholder" class="flex-1 min-h-[520px] rounded-xl bg-bg border border-border flex items-center justify-center text-text-muted text-sm">
        Lint results will appear here
      </div>
      <div id="output-container" class="hidden flex-1 min-h-[520px] rounded-xl bg-bg border border-border overflow-y-auto p-4 space-y-2"></div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="GraphQL Schema Linter" relatedTags={['graphql', 'api', 'backend', 'schema', 'rest', 'typescript']} />
</BaseLayout>

<script is:inline>
  const EXAMPLE = `"""
The root query type.
"""
type Query {
  "Fetch a user by ID."
  user(id: ID!): User
  users: [User!]!
  searchUsers(query: String!): [User]
}

type Mutation {
  createUser(input: CreateUserInput!): User!
  updateUser(id: ID!, input: UpdateUserInput!): User
  deleteUser(id: ID!): Boolean
}

"""
Represents a registered user.
"""
type User {
  id: ID!
  name: String!
  email: String!
  createdAt: String!
  profile: UserProfile
  posts: [Post!]!
  oldField: String @deprecated(reason: "Use profile.bio instead")
}

type userProfile {
  bio: String
  AvatarUrl: String
}

type Post {
  id: ID!
  Title: String!
  body: String!
  author: User!
}

input CreateUserInput {
  name: String!
  email: String!
  password: String!
}

input UpdateUserInput {
  name: String
  email: String
}

enum UserStatus {
  active
  inactive
  pending_review
}

enum PostStatus {
  PUBLISHED
  DRAFT
  ARCHIVED
}
`;

  // ── Simple GraphQL SDL tokenizer/parser ─────────────────────────────────────
  function parseSchema(sdl) {
    const types = [];
    const lines = sdl.split('\n');
    let i = 0;

    while (i < lines.length) {
      const line = lines[i].trim();

      // Skip comments and blanks
      if (!line || line.startsWith('#')) { i++; continue; }

      // Triple-quote description
      let description = '';
      if (line.startsWith('"""')) {
        let descLines = [];
        i++;
        while (i < lines.length && !lines[i].trim().startsWith('"""')) {
          descLines.push(lines[i]);
          i++;
        }
        i++; // closing """
        description = descLines.join('\n').trim();
        continue;
      }
      if (line.startsWith('"') && !line.startsWith('"""')) {
        description = line.slice(1, line.lastIndexOf('"'));
        i++;
        continue;
      }

      // Type definitions
      const typeMatch = line.match(/^(type|input|enum|interface|union|scalar)\s+(\w+)(\s+implements\s+\w+)?(\s+@\w+[^{]*)?\s*\{?/);
      if (typeMatch) {
        const kind = typeMatch[1];
        const name = typeMatch[2];
        const fields = [];
        const isEnum = kind === 'enum';
        const isScalar = kind === 'scalar';

        if (!line.includes('{') && !isScalar) { i++; continue; }
        if (isScalar) { types.push({ kind, name, description, fields: [] }); i++; continue; }

        i++;
        while (i < lines.length) {
          const fline = lines[i].trim();
          if (fline === '}') { i++; break; }
          if (!fline || fline.startsWith('#') || fline.startsWith('"""') || fline.startsWith('"')) { i++; continue; }

          if (isEnum) {
            const evMatch = fline.match(/^(\w+)(\s+@\w+.*)?$/);
            if (evMatch) fields.push({ name: evMatch[1], type: null, isDeprecated: !!(evMatch[2] && evMatch[2].includes('@deprecated')), directives: evMatch[2] || '' });
          } else {
            const fieldMatch = fline.match(/^(\w+)(\([^)]*\))?\s*:\s*([![\]\w]+)(\s+@\w+.*)?$/);
            if (fieldMatch) fields.push({ name: fieldMatch[1], type: fieldMatch[3], isDeprecated: !!(fieldMatch[4] && fieldMatch[4].includes('@deprecated')), directives: fieldMatch[4] || '' });
          }
          i++;
        }
        types.push({ kind, name, description, fields });
        continue;
      }

      i++;
    }
    return types;
  }

  // ── Lint rules ────────────────────────────────────────────────────────────────
  function lintSchema(types) {
    const issues = [];

    function err(ctx, msg, fix) { issues.push({ level: 'error', ctx, msg, fix }); }
    function warn(ctx, msg, fix) { issues.push({ level: 'warn', ctx, msg, fix }); }
    function info(ctx, msg) { issues.push({ level: 'info', ctx, msg }); }

    const typeNames = new Set(types.map(t => t.name));

    // Global checks
    const hasQuery = types.some(t => t.name === 'Query' && t.kind === 'type');
    if (!hasQuery) warn('Schema', 'No Query type defined', 'Add "type Query { }" as the root query entry point');

    types.forEach(type => {
      const ctx = `${type.kind} ${type.name}`;

      // Naming conventions
      if (type.kind === 'type' || type.kind === 'input' || type.kind === 'interface' || type.kind === 'enum') {
        if (!/^[A-Z][A-Za-z0-9]*$/.test(type.name)) {
          err(ctx, `Type name "${type.name}" violates PascalCase convention`, `Rename to "${toPascalCase(type.name)}"`);
        }
      }

      // Missing description on non-trivial types
      if (['type', 'input', 'interface'].includes(type.kind) && !['Query','Mutation','Subscription'].includes(type.name)) {
        if (!type.description) {
          warn(ctx, `Type has no description`, 'Add a description with """ ... """ above the type definition');
        }
      }

      // Field checks
      if (['type', 'input', 'interface'].includes(type.kind)) {
        type.fields.forEach(f => {
          const fctx = `${ctx}.${f.name}`;

          // Field naming: camelCase
          if (!/^[a-z][a-zA-Z0-9]*$/.test(f.name)) {
            err(fctx, `Field "${f.name}" violates camelCase convention`, `Rename to "${toCamelCase(f.name)}"`);
          }

          // Deprecated without reason is ok, just info
          if (f.isDeprecated) {
            info(fctx, `Field is @deprecated — ensure clients have migrated`);
          }

          // List fields without pagination args (warn on Query)
          if (type.name === 'Query' && f.type && f.type.includes('[') && !f.name.includes('(')) {
            warn(fctx, `List field "${f.name}" on Query has no pagination arguments`, 'Add first/last/after/before cursor args or limit/offset for pagination');
          }
        });
      }

      // Enum value naming: SCREAMING_SNAKE_CASE
      if (type.kind === 'enum') {
        type.fields.forEach(f => {
          if (!/^[A-Z][A-Z0-9_]*$/.test(f.name)) {
            err(`${ctx}.${f.name}`, `Enum value "${f.name}" violates SCREAMING_SNAKE_CASE convention`, `Rename to "${toScreamingSnake(f.name)}"`);
          }
        });
      }
    });

    if (issues.length === 0) info('Schema', 'No issues found. Schema looks great!');
    return issues;
  }

  function toPascalCase(s) {
    return s.replace(/(^|_|-)([a-z])/g, (_, __, c) => c.toUpperCase()).replace(/[_-]/g, '');
  }
  function toCamelCase(s) {
    const p = toPascalCase(s);
    return p.charAt(0).toLowerCase() + p.slice(1);
  }
  function toScreamingSnake(s) {
    return s.replace(/([a-z])([A-Z])/g, '$1_$2').replace(/[-\s]/g, '_').toUpperCase();
  }

  // ── UI ───────────────────────────────────────────────────────────────────────
  document.getElementById('load-example-btn').addEventListener('click', () => {
    document.getElementById('schema-input').value = EXAMPLE;
  });

  document.getElementById('lint-btn').addEventListener('click', () => {
    const input = document.getElementById('schema-input').value.trim();
    const placeholder = document.getElementById('output-placeholder');
    const container = document.getElementById('output-container');
    const scoreBadge = document.getElementById('score-badge');

    if (!input) {
      alert('Paste a GraphQL SDL schema first.');
      return;
    }

    let types;
    try {
      types = parseSchema(input);
    } catch (e) {
      placeholder.innerHTML = `<span class="text-red-400 text-sm">Parse error: ${escHtml(e.message)}</span>`;
      placeholder.classList.remove('hidden');
      container.classList.add('hidden');
      return;
    }

    if (!types.length) {
      placeholder.innerHTML = `<span class="text-red-400 text-sm">No type definitions found. Is this valid GraphQL SDL?</span>`;
      return;
    }

    const issues = lintSchema(types);
    const errors = issues.filter(i => i.level === 'error').length;
    const warns = issues.filter(i => i.level === 'warn').length;

    const score = Math.max(0, 100 - errors * 15 - warns * 5);
    const scoreColor = score >= 90 ? 'border-green-500/40 text-green-400' : score >= 70 ? 'border-yellow-500/40 text-yellow-400' : 'border-red-500/40 text-red-400';
    scoreBadge.className = `text-xs font-semibold px-3 py-1 rounded-full border ${scoreColor}`;
    scoreBadge.textContent = `Health: ${score}/100`;
    scoreBadge.classList.remove('hidden');

    // Summary card
    let html = `<div class="rounded-xl border border-border bg-surface/30 p-3 mb-3 flex flex-wrap gap-4">
      <div class="text-center"><div class="text-xl font-bold text-text">${types.length}</div><div class="text-xs text-text-muted">types found</div></div>
      <div class="text-center"><div class="text-xl font-bold ${errors ? 'text-red-400' : 'text-green-400'}">${errors}</div><div class="text-xs text-text-muted">errors</div></div>
      <div class="text-center"><div class="text-xl font-bold ${warns ? 'text-yellow-400' : 'text-green-400'}">${warns}</div><div class="text-xs text-text-muted">warnings</div></div>
    </div>`;

    const colors = { error: 'border-red-500/40 bg-red-500/5', warn: 'border-yellow-500/40 bg-yellow-500/5', info: 'border-green-500/40 bg-green-500/5' };
    const icons = { error: '✗', warn: '⚠', info: '✓' };
    const textColors = { error: 'text-red-400', warn: 'text-yellow-400', info: 'text-green-400' };

    issues.forEach(issue => {
      html += `<div class="rounded-lg border ${colors[issue.level]} px-3 py-2">
        <div class="flex items-start gap-2">
          <span class="font-bold ${textColors[issue.level]} text-sm mt-0.5 shrink-0">${icons[issue.level]}</span>
          <div class="min-w-0">
            <div class="text-xs font-mono text-text-muted mb-0.5">${escHtml(issue.ctx)}</div>
            <div class="text-sm text-text">${escHtml(issue.msg)}</div>
            ${issue.fix ? `<div class="text-xs text-text-muted mt-1">Fix: ${escHtml(issue.fix)}</div>` : ''}
          </div>
        </div>
      </div>`;
    });

    container.innerHTML = html;
    placeholder.classList.add('hidden');
    container.classList.remove('hidden');
  });

  function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
</script>
