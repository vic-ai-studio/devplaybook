---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is the best debugger for React Native in 2024?",
    answer: "Flipper is the officially recommended debugger for React Native and provides the most comprehensive toolset, including network inspection, layout inspection, and plugin support. For a lighter alternative, the Hermes debugger integrated with Chrome DevTools works well for JavaScript debugging. VS Code's React Native extension is the best choice if you prefer IDE-integrated debugging with full breakpoint and variable inspection support."
  },
  {
    question: "How do I enable debugging in a React Native app?",
    answer: "On a physical device or simulator, shake the device (or press Cmd+D on iOS simulator / Cmd+M on Android emulator) to open the Developer Menu, then tap 'Debug'. For Flipper, simply open the Flipper desktop app and run your app — it connects automatically. For VS Code debugging, install the React Native Tools extension and use the provided launch configurations in .vscode/launch.json."
  },
  {
    question: "Why is my React Native debugger slow or laggy?",
    answer: "Running JavaScript in Chrome DevTools introduces a remote JS bridge that can significantly slow down your app. Switch to Hermes engine and use the direct Hermes debugger (chrome://inspect) instead of the legacy Remote JS Debugger. Also ensure you're not running too many background processes, and consider using Flipper's standalone inspector rather than Chrome for layout inspection."
  },
  {
    question: "How do I inspect network requests in React Native?",
    answer: "The easiest way is through Flipper's Network plugin, which captures all fetch and XMLHttpRequest calls automatically. Alternatively, install the react-native-network-logger package for an in-app overlay. For more advanced needs, you can route your app traffic through a proxy like Charles Proxy or mitmproxy by configuring your device/simulator to use your machine's IP as the HTTP proxy."
  },
  {
    question: "Can I use Redux DevTools with React Native?",
    answer: "Yes. Install the redux-devtools-extension package and connect it in your store configuration. With Flipper, install the Redux Debugger plugin to view Redux state and actions directly in the Flipper UI. Alternatively, use the Reactotron desktop app which provides Redux integration alongside API logging and custom command support — it works well even without Flipper."
  },
  {
    question: "How do I debug on a physical Android device?",
    answer: "Enable Developer Options on your Android device (tap Build Number 7 times in Settings > About Phone), then enable USB Debugging. Connect via USB and run 'adb devices' to verify the connection. For Flipper, it connects automatically over USB. For network-based debugging, ensure your device and development machine are on the same Wi-Fi network, then run 'adb reverse tcp:8081 tcp:8081' to forward the Metro bundler port."
  }
];
---
<BaseLayout
  title="React Native Debugger Setup — Configure Debugging Environment"
  description="Complete guide to setting up React Native debugging with Flipper, Chrome DevTools, React DevTools, and VS Code debugger. Covers Metro bundler, breakpoints, network inspection, and Redux DevTools."
  tool="react-native-debugger-setup"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">React Native Debugger Setup</h1>
  <p class="text-text-muted mb-6">Configure a powerful React Native debugging environment with Flipper, Chrome DevTools, VS Code, and Metro bundler. Step-by-step setup for iOS and Android.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span>✅ Flipper Integration</span>
    <span>✅ Chrome DevTools & Hermes</span>
    <span>✅ VS Code Breakpoints</span>
    <span>✅ Network & Redux Inspection</span>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Why a Proper Debug Setup Matters</h2>
  <p class="mb-4">React Native apps run JavaScript in a separate thread from the UI, communicate over a bridge (or JSI in new arch), and target two very different native platforms simultaneously. Without the right tooling, tracking down a crash on an Android device while your iOS simulator shows nothing is a frustrating experience. A well-configured debugging environment catches issues at the source, whether that's a failed network request, a broken Redux action, or a layout constraint that only breaks on a small screen.</p>
  <p class="mb-4">This guide walks through every layer of the React Native debugging stack — from Metro bundler configuration up to Redux state inspection — so you can diagnose any issue quickly.</p>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Metro Bundler Configuration</h2>
  <p class="mb-4">Metro is the JavaScript bundler that powers React Native. Before any debugger can attach, Metro needs to be running and configured correctly. The default port is 8081. If that port is taken, start Metro on a custom port:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm"># Start Metro on a custom port
npx react-native start --port 8082

# In your app entry, update the connection
# For Android emulator, forward the custom port:
adb reverse tcp:8082 tcp:8082</code></pre>
  <p class="mb-4">The metro.config.js file controls bundler behavior. For debugging, enable source maps and set the resolver to handle any custom extensions:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm">// metro.config.js
const { getDefaultConfig, mergeConfig } = require('@react-native/metro-config');

const config = {
  resolver: {
    sourceExts: ['js', 'jsx', 'ts', 'tsx', 'json'],
  },
  transformer: {
    minifierConfig: {
      keep_fnames: true, // preserve function names in stack traces
    },
  },
};

module.exports = mergeConfig(getDefaultConfig(__dirname), config);</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Setting Up Flipper</h2>
  <p class="mb-4">Flipper is a desktop debugging platform for React Native (and native iOS/Android apps). It offers a plugin ecosystem covering layout inspection, network monitoring, crash reporting, and more.</p>
  <p class="mb-4"><strong>Installation:</strong> Download Flipper from <code>fbflipper.com</code>. On macOS, iOS simulator support works out of the box. For Android, ensure you have the Android SDK and a running emulator or USB-connected device.</p>
  <p class="mb-4">React Native 0.62+ includes Flipper by default. Verify your android/app/src/debug/java/.../ReactNativeFlipper.java exists. For iOS, confirm the Podfile includes:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm"># ios/Podfile (debug configuration)
use_flipper!({ 'Flipper' => '0.182.0' })

# After adding, run:
cd ios && pod install</code></pre>
  <p class="mb-4">Key Flipper plugins to install via Flipper's Plugin Manager:</p>
  <ul class="list-disc list-inside mb-4 space-y-1">
    <li><strong>React DevTools</strong> — Component tree, props, state inspection</li>
    <li><strong>Network</strong> — All HTTP/HTTPS requests with headers and body</li>
    <li><strong>Redux Debugger</strong> — Actions, state diff, time-travel</li>
    <li><strong>Crash Reporter</strong> — Native and JS crash logs</li>
    <li><strong>Databases</strong> — SQLite and Realm browser</li>
    <li><strong>AsyncStorage</strong> — View and edit stored key-value pairs</li>
  </ul>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Chrome DevTools and Hermes Debugger</h2>
  <p class="mb-4">If you use the Hermes JavaScript engine (enabled by default in React Native 0.64+), you can debug directly via Chrome DevTools without the performance overhead of the legacy remote debugger.</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm">// Verify Hermes is enabled in android/app/build.gradle:
project.ext.react = [
    enableHermes: true,
]

// For iOS, in Podfile:
use_react_native!(
  :path => config[:reactNativePath],
  :hermes_enabled => true
)</code></pre>
  <p class="mb-4">With Hermes enabled, open Chrome and navigate to <code>chrome://inspect</code>. Under "Remote Target" you should see your React Native app. Click "inspect" to open a full Chrome DevTools session with Sources, Console, Memory, and Profiler tabs — all with native Hermes performance.</p>

  <h2 class="text-2xl font-semibold mt-8 mb-3">VS Code Debugger with Breakpoints</h2>
  <p class="mb-4">The React Native Tools extension for VS Code (by Microsoft) provides full breakpoint debugging, variable watches, and call stack navigation directly in your editor.</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm">// .vscode/launch.json
{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Android",
      "type": "reactnative",
      "request": "launch",
      "platform": "android",
      "sourceMaps": true,
      "outDir": "${workspaceFolder}/.vscode/.react"
    },
    {
      "name": "Debug iOS",
      "type": "reactnative",
      "request": "launch",
      "platform": "ios",
      "sourceMaps": true,
      "outDir": "${workspaceFolder}/.vscode/.react"
    },
    {
      "name": "Attach to packager",
      "type": "reactnative",
      "request": "attach",
      "sourceMaps": true
    }
  ]
}</code></pre>
  <p class="mb-4">Set breakpoints by clicking the gutter in any .js, .jsx, .ts, or .tsx file. When the code executes on device, VS Code will pause at your breakpoint and display the current scope variables, the call stack, and allow step-over/step-into navigation.</p>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Network Inspection</h2>
  <p class="mb-4">Network debugging is critical for API-driven apps. Beyond Flipper's Network plugin, you can configure a proxy for more advanced traffic inspection:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm"># Configure Android emulator to use Charles Proxy
# In emulator: Settings > Wi-Fi > Long press network > Modify > Proxy Manual
# Host: 10.0.2.2 (loopback alias for host machine)
# Port: 8888 (Charles default)

# For iOS simulator, Charles automatically captures traffic
# Enable SSL proxying for HTTPS:
# Charles > Proxy > SSL Proxying Settings > Add *.yourdomain.com</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Redux DevTools Integration</h2>
  <p class="mb-4">Connect Redux DevTools to your store for time-travel debugging and action logging:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm">// store.ts
import { configureStore } from '@reduxjs/toolkit';
import { composeWithDevTools } from '@redux-devtools/extension';

export const store = configureStore({
  reducer: rootReducer,
  enhancers: (getDefaultEnhancers) =>
    getDefaultEnhancers().concat(
      // Flipper Redux plugin picks this up automatically
    ),
  devTools: __DEV__, // only enable in development
});</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Console Logging Best Practices</h2>
  <p class="mb-4">While console.log is the simplest tool, structure your logging to make debugging faster in production incidents. Use a logger library like react-native-logs to control log levels and filter output:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm">import { logger } from 'react-native-logs';

const log = logger.createLogger({
  severity: __DEV__ ? 'debug' : 'error',
  transport: __DEV__ ? consoleTransport : sentryTransport,
  transportOptions: {
    colors: { debug: 'cyan', info: 'blue', warn: 'yellow', error: 'red' },
  },
});

log.debug('Component mounted', { screen: 'HomeScreen', userId: user.id });
log.error('API call failed', { endpoint: '/api/users', status: 500 });</code></pre>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="react-native-debugger-setup" relatedTags={['react-native', 'mobile', 'debugging', 'javascript', 'ios', 'android']} />
</BaseLayout>
