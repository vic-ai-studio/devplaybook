---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PromptChainBuilder from '../../components/PromptChainBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is prompt chaining?",
    answer: "Prompt chaining is a technique where the output of one LLM call is used as input to the next. Instead of trying to do everything in a single prompt, you break complex tasks into sequential steps — each step focused on a specific sub-task. This mirrors how humans solve complex problems: research first, then analyze, then synthesize. Chains are easier to debug, test, and optimize than monolithic prompts because each step has clear inputs and expected outputs."
  },
  {
    question: "When should I use chain-of-thought vs. a simple prompt?",
    answer: "Use a single prompt for simple, well-scoped tasks: classification, summarization of short text, translation, code completion. Use prompt chaining (chain-of-thought) when: the task requires multiple distinct reasoning steps, when you need intermediate results for validation, when different steps may benefit from different models or system instructions, or when the output of one step needs to be used by a parallel branch. Rule of thumb: if you can describe the task in one sentence with one expected output format, a single prompt is fine. If you need a paragraph with multiple stages, chain it."
  },
  {
    question: "How does variable passing work between chain steps?",
    answer: "In most production implementations, you maintain an in-memory context object. After each LLM call completes, you store the output under a key (e.g., step1_output) and inject it into the next prompt by string interpolation. In this builder, the {{step1_output}} placeholder syntax shows where to inject the value. In code: const step2Prompt = template.replace('{{step1_output}}', step1Result). Frameworks like LangChain, LlamaIndex, and custom orchestrators all handle this pattern, but the underlying mechanism is simple string substitution."
  },
  {
    question: "What is the advantage of a chain over one long prompt?",
    answer: "Long, complex prompts tend to degrade quality — models struggle to track all requirements simultaneously. Chains improve quality by letting each step focus on one thing. They also enable: (1) validation gates between steps — check if step 1 output is correct before proceeding; (2) branching — send different steps to different models optimized for that task (e.g., GPT-4o for reasoning, Claude Haiku for summarization); (3) parallelism — run independent steps concurrently; (4) observability — log and debug each step independently. The main tradeoff is increased latency and API cost proportional to the number of steps."
  },
];
---

<BaseLayout
  title="Prompt Chain Builder — Visual Multi-Step AI Prompt Chain Designer"
  description="Build multi-step AI prompt chains visually. Design chain-of-thought workflows, reference outputs between steps, and export as OpenAI messages JSON. Free, browser-based prompt engineering tool."
  tool="Prompt Chain Builder, AI Prompt Chaining, Chain-of-Thought Builder, LangChain Alternative, OpenAI Messages Format, Prompt Engineering Tools"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Prompt Chain Builder",
    "url": "https://devplaybook.cc/tools/prompt-chain-builder",
    "description": "Build multi-step AI prompt chains visually. Design chain-of-thought workflows, reference outputs between steps, and export as OpenAI messages JSON.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Prompt Chain Builder</h1>
  <p class="text-text-muted mb-4">
    Design multi-step AI prompt chains visually. Add steps, set roles
    (<code class="font-mono bg-surface px-1 rounded text-sm">system</code> /
    <code class="font-mono bg-surface px-1 rounded text-sm">user</code> /
    <code class="font-mono bg-surface px-1 rounded text-sm">assistant</code>),
    reference previous step outputs via
    <code class="font-mono bg-surface px-1 rounded text-sm">&#123;&#123;step1_output&#125;&#125;</code>,
    and export the finished chain as OpenAI messages JSON or a readable template.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Add / remove / reorder steps</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> system / user / assistant roles</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Export as OpenAI JSON</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <PromptChainBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Prompt Chain Builder" relatedTags={['prompt-engineering', 'ai', 'llm', 'chain-of-thought', 'developer-tools']} />
</BaseLayout>
