---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WasmBinaryInspector from '../../components/WasmBinaryInspector.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What are the WASM magic bytes?",
    answer: "Every valid WebAssembly binary starts with the 4-byte magic sequence 0x00 0x61 0x73 0x6D, which spells '\\0asm' in ASCII. Following the magic bytes are 4 version bytes (0x01 0x00 0x00 0x00 = version 1, the MVP). If these 8 bytes are incorrect, the runtime will reject the file immediately before parsing any sections."
  },
  {
    question: "What sections does a WASM binary contain?",
    answer: "A WASM binary is divided into sections identified by a 1-byte section ID: Type (1) defines function signatures, Import (2) lists imported functions/memories/tables/globals, Function (3) maps functions to type signatures, Table (4) defines function reference tables, Memory (5) defines linear memory, Global (6) declares global variables, Export (7) lists exported symbols, Start (8) specifies an entry point, Element (9) and Data (11) initialize tables and memory, Code (10) contains function bodies, and Custom (0) holds arbitrary metadata like debug info or DWARF."
  },
  {
    question: "What is LEB128 encoding in WASM?",
    answer: "LEB128 (Little Endian Base 128) is a variable-length integer encoding used throughout WASM binaries. Each byte uses 7 bits for data and 1 bit (the MSB) as a continuation flag. If the MSB is 1, another byte follows. This allows small integers to occupy just 1 byte while supporting arbitrarily large values. WASM uses unsigned LEB128 for sizes and indices, and signed LEB128 for integer constants."
  },
  {
    question: "How do I generate a WASM binary?",
    answer: "You can produce WASM from multiple sources: (1) Compile Rust with 'cargo build --target wasm32-unknown-unknown', (2) Compile C/C++ with Emscripten ('emcc main.c -o out.wasm'), (3) Compile WAT text format with 'wat2wasm module.wat -o module.wasm' from the wabt toolkit, (4) Use AssemblyScript which compiles TypeScript to WASM. The wabt toolkit also includes wasm-objdump and wasm-validate for inspection."
  },
  {
    question: "What is the difference between WASM imports and exports?",
    answer: "Imports are symbols a WASM module needs from the host environment — your JavaScript must provide these when instantiating the module via the imports object: WebAssembly.instantiate(bytes, { 'env': { 'memory': mem, 'log': console.log } }). Exports are symbols the WASM module exposes to the host — after instantiation, these appear as instance.exports.functionName(). A module can import/export functions, tables, memories, and globals."
  },
];
---

<BaseLayout
  title="WASM Binary Inspector — WebAssembly Binary Parser & Section Analyzer"
  description="Inspect WebAssembly binary files in your browser. Paste hex bytes or Base64-encoded WASM to validate magic bytes, parse sections, and list imports and exports. No upload needed."
  tool="WASM inspector, WebAssembly binary parser, wasm hex viewer, wasm section analyzer, wasm imports exports"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">WASM Binary Inspector</h1>
  <p class="text-text-muted mb-4">Parse WebAssembly binaries in your browser. Validates magic bytes, decodes section structure, and lists imports and exports — no server needed.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Magic bytes validation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Section breakdown table</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Imports & exports list</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Hex or Base64 input</span>
  </div>

  <WasmBinaryInspector client:only="preact" />

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="WASM Binary Inspector" relatedTags={['webassembly', 'wasm', 'binary', 'parser', 'compiler', 'systems']} />
</BaseLayout>

