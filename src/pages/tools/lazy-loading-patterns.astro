---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is the difference between lazy loading images and lazy loading components?", answer: "Image lazy loading defers downloading the image file until the <img> element is near the viewport. It uses the native `loading='lazy'` attribute or Intersection Observer API. Component lazy loading (code splitting) defers downloading and parsing the JavaScript code for a component until it's needed. Both reduce initial page load, but component lazy loading is more impactful for JavaScript-heavy apps since it reduces parse/execute time, while image lazy loading primarily saves bandwidth." },
  { question: "Should I lazy load the LCP (Largest Contentful Paint) image?", answer: "Never lazy load the LCP image. Lazy loading delays image download, which directly increases LCP. The LCP element should have `loading='eager'` (the default) and `fetchpriority='high'` to prioritize it. Only lazy-load images that start below the fold — images visible on initial load should always load eagerly. A common mistake is bulk-applying `loading='lazy'` to all images, which breaks the hero/banner LCP." },
  { question: "What is the Intersection Observer API and how does it work for lazy loading?", answer: "IntersectionObserver is a browser API that fires a callback when a target element enters or exits the viewport. For lazy loading, you set `data-src` on images instead of `src`, observe all such images, and swap `data-src` to `src` when the image enters the viewport. Unlike scroll event listeners, IntersectionObserver is asynchronous, doesn't block the main thread, and fires off the main thread. The native `loading='lazy'` attribute uses a similar mechanism internally and is preferred for simple cases." },
  { question: "How do I implement lazy loading in React without third-party libraries?", answer: "React 18+ supports lazy loading with `React.lazy(() => import('./Component'))` for component code splitting, wrapped in `<Suspense fallback={<Loading />}>`. For images, use a custom hook with IntersectionObserver or the native `loading='lazy'` HTML attribute. For virtualized long lists (thousands of items), use `@tanstack/react-virtual` or `react-window` to only render visible rows — this is more effective than lazy loading for list performance." },
];
---

<BaseLayout
  title="Lazy Loading Patterns Guide — Images, Components & Virtual Lists"
  description="Master lazy loading techniques: native image lazy loading, React.lazy component splitting, Intersection Observer, virtual lists, and avoiding LCP pitfalls."
  tool="lazy loading, React.lazy, Intersection Observer, code splitting, virtual scrolling, image optimization, performance"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Lazy Loading Patterns Guide",
    "url": "https://devplaybook.cc/tools/lazy-loading-patterns",
    "description": "Implement lazy loading for images, components, and lists to improve initial page load performance.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Lazy Loading Patterns Guide</h1>
  <p class="text-text-muted mb-6">
    <strong>Lazy loading</strong> defers loading of non-critical resources until they're needed, reducing initial page weight and improving LCP. Use native browser APIs for images and dynamic imports for JavaScript components.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Native image lazy loading</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> React.lazy + Suspense</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Intersection Observer</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Virtual scrolling</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Native Image Lazy Loading</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">&lt;!-- ✅ Lazy load below-fold images --&gt;
&lt;img
  src="product-gallery-2.webp"
  width="800"
  height="600"
  loading="lazy"
  alt="Product gallery image"
&gt;

&lt;!-- ❌ NEVER lazy-load the LCP/hero image --&gt;
&lt;!-- This INCREASES LCP --&gt;
&lt;img src="hero.webp" loading="lazy" alt="Hero"&gt;

&lt;!-- ✅ Hero image: eager + high priority --&gt;
&lt;img
  src="hero.webp"
  width="1200"
  height="600"
  loading="eager"
  fetchpriority="high"
  alt="Hero"
&gt;

&lt;!-- Also lazy-load iframes --&gt;
&lt;iframe
  src="https://www.youtube.com/embed/VIDEO_ID"
  loading="lazy"
  width="560"
  height="315"
&gt;&lt;/iframe&gt;</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">React Component Lazy Loading</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">import &#123; lazy, Suspense &#125; from 'react';

// Lazy load heavy components
const HeavyChart     = lazy(() => import('./components/HeavyChart'));
const MapComponent   = lazy(() => import('./components/MapComponent'));
const VideoPlayer    = lazy(() => import('./components/VideoPlayer'));
const PdfViewer      = lazy(() => import('./components/PdfViewer'));

// Loading skeleton component
function ChartSkeleton() &#123;
  return &lt;div class="h-64 bg-gray-200 animate-pulse rounded" /&gt;;
&#125;

// Usage with Suspense
function Dashboard() &#123;
  const [showChart, setShowChart] = useState(false);

  return (
    &lt;div&gt;
      &lt;button onClick=&#123;() => setShowChart(true)&#125;&gt;Show Chart&lt;/button&gt;
      &#123;showChart &amp;&amp; (
        &lt;Suspense fallback=&#123;&lt;ChartSkeleton /&gt;&#125;&gt;
          &lt;HeavyChart data=&#123;data&#125; /&gt;
        &lt;/Suspense&gt;
      )&#125;
    &lt;/div&gt;
  );
&#125;</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Custom Intersection Observer Hook</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// useIntersectionObserver.ts
import &#123; useEffect, useRef, useState &#125; from 'react';

export function useIntersectionObserver(options = &#123;&#125;) &#123;
  const ref = useRef&lt;HTMLElement&gt;(null);
  const [isVisible, setIsVisible] = useState(false);

  useEffect(() => &#123;
    const el = ref.current;
    if (!el) return;

    const observer = new IntersectionObserver(([entry]) => &#123;
      if (entry.isIntersecting) &#123;
        setIsVisible(true);
        observer.unobserve(el); // Only trigger once
      &#125;
    &#125;, &#123; rootMargin: '200px', ...options &#125;);

    observer.observe(el);
    return () => observer.disconnect();
  &#125;, []);

  return &#123; ref, isVisible &#125;;
&#125;

// Usage: lazy-load a component on scroll into view
function LazySection() &#123;
  const &#123; ref, isVisible &#125; = useIntersectionObserver();

  return (
    &lt;div ref=&#123;ref&#125;&gt;
      &#123;isVisible ? (
        &lt;Suspense fallback=&#123;&lt;Skeleton /&gt;&#125;&gt;
          &lt;HeavyComponent /&gt;
        &lt;/Suspense&gt;
      ) : (
        &lt;div style=&#123;&#123; height: 400 &#125;&#125; /&gt;  &#123;/* Placeholder to prevent CLS */&#125;
      )&#125;
    &lt;/div&gt;
  );
&#125;</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Virtual Scrolling for Long Lists</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">npm install @tanstack/react-virtual</pre>

  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">import &#123; useVirtualizer &#125; from '@tanstack/react-virtual';

function VirtualList(&#123; items &#125;) &#123;
  const parentRef = useRef(null);

  const virtualizer = useVirtualizer(&#123;
    count: items.length,
    getScrollElement: () => parentRef.current,
    estimateSize: () => 50,  // estimated row height in px
    overscan: 10,            // render 10 extra rows above/below
  &#125;);

  return (
    &lt;div ref=&#123;parentRef&#125; style=&#123;&#123; height: '600px', overflow: 'auto' &#125;&#125;&gt;
      &lt;div style=&#123;&#123; height: virtualizer.getTotalSize() &#125;&#125;&gt;
        &#123;virtualizer.getVirtualItems().map(virtualRow => (
          &lt;div
            key=&#123;virtualRow.key&#125;
            style=&#123;&#123;
              position: 'absolute',
              top: virtualRow.start,
              height: virtualRow.size,
            &#125;&#125;
          &gt;
            &#123;items[virtualRow.index].name&#125;
          &lt;/div&gt;
        ))&#125;
      &lt;/div&gt;
    &lt;/div&gt;
  );
&#125;</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">When to Use Each Pattern</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Pattern</th>
          <th class="border border-border px-3 py-2 text-left">Best For</th>
          <th class="border border-border px-3 py-2 text-left">Savings</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2">Native <code class="font-mono text-xs">loading="lazy"</code></td><td class="border border-border px-3 py-2">Below-fold images, iframes</td><td class="border border-border px-3 py-2 text-green-400">Bandwidth</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">React.lazy + Suspense</td><td class="border border-border px-3 py-2">Heavy route pages, modals, charts</td><td class="border border-border px-3 py-2 text-green-400">JS parse/exec</td></tr>
        <tr><td class="border border-border px-3 py-2">Intersection Observer</td><td class="border border-border px-3 py-2">Scroll-triggered content, analytics</td><td class="border border-border px-3 py-2 text-yellow-400">API calls</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Virtual scrolling</td><td class="border border-border px-3 py-2">Lists with 1000+ items</td><td class="border border-border px-3 py-2 text-green-400">DOM nodes, memory</td></tr>
      </tbody>
    </table>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Lazy Loading Patterns" relatedTags={['performance', 'react', 'images', 'code-splitting', 'core-web-vitals']} />
</BaseLayout>
