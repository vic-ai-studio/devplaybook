---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "Why do mobile A/B tests need larger sample sizes than web tests?",
    answer: "Mobile apps have lower session frequencies than websites — users may open an app once a day or less, versus web users who might visit multiple times per day. This means it takes longer to accumulate the same number of sessions. Additionally, mobile conversion funnels are often longer and conversion rates lower (especially for in-app purchases), which requires more samples to detect meaningful differences. A typical mobile A/B test needs 2–4 weeks to reach significance, versus hours or days for high-traffic web pages."
  },
  {
    question: "What is statistical significance and what confidence level should I use?",
    answer: "Statistical significance means the observed difference is unlikely to be due to random chance. At 95% confidence (the industry standard), there's only a 5% probability the result is a false positive. For low-stakes UI tests (button color, copy changes), 90% confidence is acceptable. For major feature rollouts or monetization changes, use 95% or even 99%. Higher confidence requires larger sample sizes."
  },
  {
    question: "How do I calculate the required sample size before starting a test?",
    answer: "You need three inputs: baseline conversion rate (current CR%), minimum detectable effect (the smallest lift worth detecting — e.g., 10% relative improvement), and your desired confidence level (usually 95%). A common formula for equal groups: n = (z_alpha/2 + z_beta)^2 * (p1*(1-p1) + p2*(1-p2)) / (p1-p2)^2. Use a sample size calculator or Firebase A/B Testing's built-in sample size planner rather than computing this manually."
  },
  {
    question: "What is Minimum Detectable Effect (MDE)?",
    answer: "MDE is the smallest relative improvement you care about detecting reliably. If your baseline conversion is 5% and you set MDE to 20%, you're looking for a lift from 5% to 6%. Setting a smaller MDE (e.g., 5%) means you need a much larger sample to detect it reliably. Be realistic — chasing 2% lifts requires enormous traffic and long test durations. For mobile apps, an MDE of 10–20% is typically the practical minimum."
  },
  {
    question: "What is Firebase A/B Testing and how does it work?",
    answer: "Firebase A/B Testing (part of Firebase Remote Config) lets you run experiments that control app behavior through remote configuration values. Define variants with different Remote Config parameter values, specify your target audience (all users, specific segments), and set a goal metric (retention, revenue, in-app events). Firebase assigns users to variants client-side, collects event data via Google Analytics for Firebase, and shows results with statistical significance indicators."
  },
  {
    question: "Should I test multiple variants simultaneously?",
    answer: "Testing more than 2 variants (A/B/C/D tests) requires adjusting for multiple comparisons (the Bonferroni correction or similar). Each additional variant increases the chance of at least one false positive. For mobile apps where sample sizes are already constrained, limit tests to 2–3 variants maximum. Running too many variants dilutes the traffic per variant, extending test duration significantly."
  }
];
---
<BaseLayout
  title="Mobile A/B Test Calculator: Sample Size & Statistical Significance"
  description="Calculate sample sizes and statistical significance for mobile A/B tests. Understand why mobile tests need more traffic, set correct confidence levels, choose MDE, and configure Firebase A/B Testing and Optimizely."
  tool="mobile-ab-test-calculator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"Mobile A/B Test Calculator: Sample Size & Statistical Significance","url":"https://devplaybook.cc/tools/mobile-ab-test-calculator","description":"Calculate sample sizes and statistical significance for mobile A/B tests. Configure Firebase A/B Testing for React Native apps."})} />

  <h1 class="text-3xl font-bold mb-2">Mobile A/B Test Calculator: Sample Size & Statistical Significance</h1>
  <p class="text-text-muted mb-6">Plan mobile A/B tests correctly: calculate required sample sizes, understand statistical significance at 95% confidence, set realistic MDE targets, and integrate Firebase A/B Testing or Optimizely with your React Native app.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Sample size calculation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Statistical significance explained</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Firebase A/B Testing setup</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Minimum Detectable Effect guide</span>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Sample Size Reference Table</h2>
  <p class="mb-4">Required sample size per variant (95% confidence, 80% power) at different baseline conversion rates and MDE values:</p>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 font-semibold">Baseline CR</th>
          <th class="text-left py-2 pr-4 font-semibold">MDE 5%</th>
          <th class="text-left py-2 pr-4 font-semibold">MDE 10%</th>
          <th class="text-left py-2 pr-4 font-semibold">MDE 20%</th>
          <th class="text-left py-2 font-semibold">MDE 30%</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <tr>
          <td class="py-2 pr-4">1%</td>
          <td class="py-2 pr-4">312,000</td>
          <td class="py-2 pr-4">79,000</td>
          <td class="py-2 pr-4">20,000</td>
          <td class="py-2">9,000</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">3%</td>
          <td class="py-2 pr-4">104,000</td>
          <td class="py-2 pr-4">26,000</td>
          <td class="py-2 pr-4">6,500</td>
          <td class="py-2">2,900</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">5%</td>
          <td class="py-2 pr-4">62,000</td>
          <td class="py-2 pr-4">15,600</td>
          <td class="py-2 pr-4">3,900</td>
          <td class="py-2">1,740</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">10%</td>
          <td class="py-2 pr-4">30,000</td>
          <td class="py-2 pr-4">7,500</td>
          <td class="py-2 pr-4">1,880</td>
          <td class="py-2">840</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">20%</td>
          <td class="py-2 pr-4">13,000</td>
          <td class="py-2 pr-4">3,300</td>
          <td class="py-2 pr-4">830</td>
          <td class="py-2">370</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Firebase A/B Testing Setup for React Native</h2>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm">npm install @react-native-firebase/app @react-native-firebase/remote-config @react-native-firebase/analytics</code></pre>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm">// hooks/useExperiment.ts
import remoteConfig from '@react-native-firebase/remote-config';
import analytics from '@react-native-firebase/analytics';

export function useExperiment(experimentKey: string, defaultValue: string) &#123;
  const [variant, setVariant] = useState(defaultValue);

  useEffect(() => &#123;
    // Fetch remote config values (Firebase assigns user to variant)
    remoteConfig()
      .setConfigSettings(&#123; minimumFetchIntervalMillis: 300000 &#125;)
      .then(() => remoteConfig().fetchAndActivate())
      .then(() => &#123;
        const value = remoteConfig().getString(experimentKey);
        setVariant(value || defaultValue);

        // Log exposure event so Firebase knows this user saw the experiment
        analytics().logEvent('experiment_exposure', &#123;
          experiment_key: experimentKey,
          variant: value,
        &#125;);
      &#125;);
  &#125;, [experimentKey]);

  return variant;
&#125;

// Usage in a component
const CheckoutScreen = () => &#123;
  const ctaVariant = useExperiment('checkout_cta_text', 'Buy Now');

  const handlePurchase = async () => &#123;
    // Log the goal event — Firebase A/B Testing tracks this
    await analytics().logEvent('purchase', &#123; value: 29.99, currency: 'USD' &#125;);
  &#125;;

  return (
    &lt;Button title=&#123;ctaVariant&#125; onPress=&#123;handlePurchase&#125; /&gt;
  );
&#125;;</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Lift Calculation Formula</h2>
  <p class="mb-4">Calculate relative lift and whether your result is practically significant:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm">// Calculate statistical significance manually
function calculateSignificance(
  controlUsers: number,
  controlConversions: number,
  variantUsers: number,
  variantConversions: number
) &#123;
  const controlRate = controlConversions / controlUsers;
  const variantRate = variantConversions / variantUsers;

  const relativeLift = ((variantRate - controlRate) / controlRate) * 100;

  const pooledRate = (controlConversions + variantConversions) / (controlUsers + variantUsers);
  const standardError = Math.sqrt(
    pooledRate * (1 - pooledRate) * (1 / controlUsers + 1 / variantUsers)
  );

  const zScore = (variantRate - controlRate) / standardError;
  const pValue = 2 * (1 - normalCDF(Math.abs(zScore)));

  return &#123;
    controlRate: (controlRate * 100).toFixed(2) + '%',
    variantRate: (variantRate * 100).toFixed(2) + '%',
    relativeLift: relativeLift.toFixed(1) + '%',
    zScore: zScore.toFixed(2),
    pValue: pValue.toFixed(4),
    significant: pValue < 0.05,
  &#125;;
&#125;</code></pre>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="mobile-ab-test-calculator" relatedTags={['mobile', 'analytics', 'firebase', 'testing', 'statistics', 'react-native']} />
</BaseLayout>
