---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AvroSchemaGenerator from '../../components/AvroSchemaGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Apache Avro and why use it?",
    answer: "Apache Avro is a data serialization system used heavily in the Hadoop/Kafka ecosystem. It stores schema with data (or in a schema registry), provides compact binary serialization, and supports schema evolution with backward/forward compatibility. It's the standard format for Kafka messages via the Confluent Schema Registry and for Hadoop/Spark data pipelines."
  },
  {
    question: "How does the JSON-to-Avro type mapping work?",
    answer: "JSON booleans → Avro boolean. JSON integers → Avro long. JSON floats/decimals → Avro double. JSON strings → Avro string (with datetime/date detection). ISO 8601 datetime strings → Avro timestamp-millis (logical type). Date-only strings (YYYY-MM-DD) → Avro date (logical type). JSON arrays → Avro array with inferred item type. JSON objects → nested Avro record. JSON null values → union ['null', 'string'] with null default."
  },
  {
    question: "What are Avro logical types?",
    answer: "Logical types annotate a base Avro type with semantic meaning. Common ones: date (stored as int, days since epoch), time-millis (stored as int, ms since midnight), timestamp-millis (stored as long, ms since Unix epoch), decimal (stored as bytes, with precision/scale), uuid (stored as string). The generator detects ISO 8601 datetime and date strings and emits the appropriate logical type."
  },
  {
    question: "How does Avro handle nullable fields?",
    answer: "In Avro, nullable fields are represented as a union: ['null', 'actualType']. When the JSON sample contains null, the generator outputs this union type with a null default. In practice, you can use the Avro union pattern to make any field optional by adding 'null' to its type array."
  },
  {
    question: "How does Avro schema evolution work?",
    answer: "Avro supports schema evolution with backward/forward compatibility. You can add fields with defaults (backward compatible), add union types, or rename fields with aliases. The key rule: never delete fields without providing a default, and never change field types without using a union. This is why using a Schema Registry (like Confluent) is recommended to track schema versions."
  },
  {
    question: "Does this tool send my JSON data to a server?",
    answer: "No. All schema generation runs entirely in your browser using JavaScript. Your JSON data — which may contain sensitive field names or data structures — never leaves your machine."
  },
];
---

<BaseLayout
  title="Avro Schema Generator — Generate Apache Avro Schema from JSON"
  description="Paste JSON sample data and instantly generate an Apache Avro schema. Detects nested records, arrays, nullable fields, and logical types (timestamp, date). Free, runs in your browser."
  tool="Avro schema generator, JSON to Avro, Apache Avro schema, Avro schema from JSON, Kafka Avro schema"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Avro Schema Generator",
    "url": "https://devplaybook.cc/tools/avro-schema-generator",
    "description": "Generate Apache Avro schema definitions from JSON sample data. Detects nested records, arrays, nullable fields, and logical types. Free, runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Avro Schema Generator</h1>
  <p class="text-text-muted mb-4">
    Paste a JSON object or array and generate an Apache Avro schema instantly.
    Detects nested records, arrays, nullable fields, and logical types like <code class="font-mono bg-surface px-1 rounded text-sm">timestamp-millis</code> and <code class="font-mono bg-surface px-1 rounded text-sm">date</code>.
    Useful for Kafka + Confluent Schema Registry workflows. Runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Nested record support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Logical type detection</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Nullable field unions</span>
  </div>
  <AvroSchemaGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Avro Schema Generator" relatedTags={['kafka', 'avro', 'data', 'json', 'schema', 'backend', 'streaming']} />
</BaseLayout>
