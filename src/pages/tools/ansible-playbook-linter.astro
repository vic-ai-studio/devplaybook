---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnsiblePlaybookLinter from '../../components/AnsiblePlaybookLinter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What does this Ansible linter check?",
    answer: "It checks for: hardcoded secrets/passwords in vars, missing required 'hosts:' and 'tasks:' fields, use of non-idempotent 'command:' and 'shell:' modules, missing task names, 'become: yes' without 'become_user:', 'ignore_errors: yes' usage, package modules without 'state:', tab characters, undefined variable checks, and 'notify:' without 'handlers:'."
  },
  {
    question: "Why should I avoid 'command:' and 'shell:' modules?",
    answer: "Ansible's power comes from idempotency — running a playbook multiple times should produce the same result. Built-in modules like 'apt', 'service', 'copy', and 'template' are designed to check current state and only make changes when needed. The 'command:' and 'shell:' modules run blindly every time, breaking idempotency unless you add 'changed_when:', 'creates:', or 'removes:' conditions."
  },
  {
    question: "How should I store secrets in Ansible?",
    answer: "Use Ansible Vault to encrypt sensitive values. You can encrypt entire variable files with 'ansible-vault encrypt vars/secrets.yml' or encrypt individual string values with 'ansible-vault encrypt_string'. Never put plaintext passwords, API keys, or tokens directly in playbooks or unencrypted var files."
  },
  {
    question: "What is idempotency in Ansible?",
    answer: "Idempotency means running a task multiple times produces the same result as running it once. For example, 'apt: name=nginx state=present' is idempotent — if nginx is already installed, Ansible reports 'ok' and makes no change. This is critical for safe playbook re-runs and configuration drift correction."
  },
  {
    question: "Why do task names matter?",
    answer: "Named tasks make playbook output readable and help diagnose failures. When a task fails, Ansible shows the task name in the error output. Anonymous tasks show the module name and arguments, which can be cryptic. Names also serve as documentation for what each step does."
  },
  {
    question: "Does this tool send my playbook to a server?",
    answer: "No. All linting runs entirely in your browser using JavaScript. Your playbook YAML — which may contain hostnames, usernames, or structural information about your infrastructure — never leaves your machine."
  },
];
---

<BaseLayout
  title="Ansible Playbook Linter — Validate Ansible YAML Online"
  description="Paste your Ansible playbook YAML and lint it instantly. Catches hardcoded secrets, non-idempotent modules, missing required fields, and best practice violations. Runs 100% in your browser."
  tool="Ansible linter, Ansible playbook validator, Ansible YAML checker, ansible-lint online, Ansible best practices"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Ansible Playbook Linter",
    "url": "https://devplaybook.cc/tools/ansible-playbook-linter",
    "description": "Validate Ansible playbook YAML online. Catches hardcoded secrets, non-idempotent modules, missing required fields, and best practice violations. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Ansible Playbook Linter</h1>
  <p class="text-text-muted mb-4">
    Paste your Ansible playbook YAML and catch mistakes before you run it.
    Validates hosts, tasks, idempotency issues, secret handling, and Ansible best practices.
    Nothing is sent to any server — runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Secret detection</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Idempotency checks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Best practice hints</span>
  </div>
  <AnsiblePlaybookLinter client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Ansible Playbook Linter" relatedTags={['devops', 'ansible', 'yaml', 'validation', 'automation', 'infrastructure', 'ci-cd']} />
</BaseLayout>
