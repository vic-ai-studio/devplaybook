---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is HashiCorp Vault and what problems does it solve?", answer: "Vault is a secrets management platform that centralizes storage, access control, and auditing of sensitive data: API keys, database credentials, TLS certificates, encryption keys, and passwords. The core problem it solves is 'secret sprawl' — credentials hardcoded in config files, environment variables scattered across servers, and no audit trail of who accessed what. Vault provides a single source of truth for secrets with fine-grained policies, time-limited leases, automatic rotation, and comprehensive audit logging of every secret access." },
  { question: "What are dynamic secrets and why are they safer than static ones?", answer: "Dynamic secrets are generated on-demand and automatically expire after a configurable lease period. For example, when an application requests database credentials from Vault's database secrets engine, Vault creates a new PostgreSQL user with a random password and a 1-hour TTL. After the TTL expires, Vault automatically revokes that credential. This means leaked credentials expire on their own, you always know which application used which credentials (each request gets unique creds), and you never have long-lived passwords that accumulate over time." },
  { question: "What authentication methods does Vault support?", answer: "Vault supports many auth methods: AppRole (machine-to-machine, CI/CD pipelines), Kubernetes (pods authenticate using ServiceAccount JWTs), AWS IAM (EC2 instances or Lambda functions authenticate using AWS credentials), LDAP, GitHub, JWT/OIDC (for cloud platforms), TLS certificates, and userpass (for humans). In production, AppRole and Kubernetes are the most common for service authentication. Each auth method issues a Vault token with policies attached. The principle of least privilege applies: each service gets only the policies it needs." },
  { question: "What is the Transit secrets engine?", answer: "The Transit engine turns Vault into an 'encryption-as-a-service' API. Instead of managing encryption keys in your application code, you send plaintext to Vault's /transit/encrypt endpoint and receive ciphertext back. The encryption key never leaves Vault. To decrypt, send the ciphertext to /transit/decrypt. This pattern is ideal for encrypting PII or PCI data before storing it in a database — your application never handles raw keys, key rotation is centralized in Vault, and you get audit logs of every encrypt/decrypt operation." },
  { question: "How does Vault handle high availability and disaster recovery?", answer: "Vault supports multiple storage backends for HA: Integrated Storage (Raft consensus, built-in, recommended for new deployments), Consul, etcd, and cloud storage (DynamoDB, Azure Blob, GCS). In Raft mode, you run 3 or 5 Vault nodes — one is the leader and the others are standbys that automatically promote if the leader fails. For DR, Vault Enterprise supports Performance Replication (read-only replica clusters in other regions) and DR Replication. OSS Vault requires you to manage backups via vault operator raft snapshot and test restore procedures." },
  { question: "What is Vault Agent and when should I use it?", answer: "Vault Agent is a client-side daemon that handles authentication and secret retrieval on behalf of your application. It runs alongside your application (as a sidecar or systemd service), authenticates to Vault automatically, renews tokens, fetches secrets, renders them into template files, and restarts your application when secrets change. This means your application doesn't need the Vault SDK — it just reads a file or environment variable that Vault Agent keeps fresh. Use Vault Agent for legacy applications, simple services, or any scenario where you want to decouple Vault integration from the application code." },
];

const vaultCliBasics = `# Start dev server (in-memory, DO NOT use in production)
vault server -dev

export VAULT_ADDR='http://127.0.0.1:8200'
export VAULT_TOKEN='root'   # shown after vault server -dev starts

# Check status
vault status

# Enable KV v2 secrets engine at path 'secret/'
vault secrets enable -path=secret kv-v2

# Write and read secrets
vault kv put secret/myapp/config db_host=postgres db_port=5432
vault kv get secret/myapp/config
vault kv get -format=json secret/myapp/config | jq '.data.data'

# See all versions
vault kv metadata get secret/myapp/config

# Delete a specific version
vault kv delete -versions=1 secret/myapp/config`;

const vaultDynamicCreds = `# Enable the database secrets engine
vault secrets enable database

# Configure a PostgreSQL connection
vault write database/config/my-postgres \\
  plugin_name=postgresql-database-plugin \\
  connection_url="postgresql://{{username}}:{{password}}@postgres:5432/mydb" \\
  allowed_roles="my-app-role" \\
  username="vault_admin" \\
  password="vault_admin_password"

# Create a role that generates 1-hour database credentials
vault write database/roles/my-app-role \\
  db_name=my-postgres \\
  creation_statements="CREATE ROLE \\"{{name}}\\" WITH LOGIN PASSWORD '{{password}}' VALID UNTIL '{{expiration}}'; GRANT SELECT, INSERT, UPDATE ON ALL TABLES IN SCHEMA public TO \\"{{name}}\\";" \\
  default_ttl="1h" \\
  max_ttl="24h"

# Request credentials (new unique user each time)
vault read database/creds/my-app-role
# Key                Value
# ---                -----
# username           v-token-my-app-rol-AbC123xyz
# password           A1B2C3D4E5F6G7H8
# lease_duration     1h`;

const vaultAppRole = `# Enable AppRole auth
vault auth enable approle

# Write a policy for the application
vault policy write my-app-policy - <<EOF
path "secret/data/myapp/*" {
  capabilities = ["read", "list"]
}
path "database/creds/my-app-role" {
  capabilities = ["read"]
}
EOF

# Create an AppRole with the policy
vault write auth/approle/role/my-app \\
  policies="my-app-policy" \\
  token_ttl=1h \\
  token_max_ttl=4h \\
  secret_id_ttl=720h

# Fetch Role ID (public, embed in app config)
vault read auth/approle/role/my-app/role-id

# Generate a Secret ID (private, inject at deploy time)
vault write -f auth/approle/role/my-app/secret-id

# Application authenticates with both to get a token
vault write auth/approle/login \\
  role_id="<ROLE_ID>" \\
  secret_id="<SECRET_ID>"`;
---

<BaseLayout
  title="HashiCorp Vault Secrets Management Guide — Dynamic Secrets, PKI, and Encryption"
  description="Complete Vault guide: KV secrets engine, dynamic database credentials, AppRole auth, PKI, transit encryption, policies, and comparison with AWS Secrets Manager, Azure Key Vault, and Doppler."
  tool="HashiCorp Vault, secrets management, dynamic secrets, Vault AppRole, Vault KV, Vault PKI, transit encryption"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "HashiCorp Vault Secrets Management Guide — Dynamic Secrets, PKI, and Encryption",
    "url": "https://devplaybook.cc/tools/vault-secrets",
    "description": "Complete Vault guide: KV secrets engine, dynamic database credentials, AppRole auth, PKI, transit encryption, policies, and comparison with AWS Secrets Manager, Azure Key Vault, and Doppler.",
  })} />

  <h1 class="text-3xl font-bold mb-2">HashiCorp Vault — Secrets Management Guide</h1>
  <p class="text-text-muted mb-6">
    Centralize secrets storage, enforce access policies, generate <strong>dynamic credentials</strong>,
    and encrypt data at rest — all with full audit logging of every access.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Dynamic secrets (auto-expiring)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> PKI / TLS certificate authority</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Transit encryption-as-a-service</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> AppRole / Kubernetes / AWS IAM auth</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is HashiCorp Vault?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    HashiCorp Vault is an identity-based secrets management platform designed to solve the hardest security problems in modern infrastructure: how do you store secrets securely, who should have access, how do you rotate credentials, and how do you know who accessed what? Released in 2015, Vault has become the de facto standard for secrets management in cloud-native environments, used by thousands of organizations from startups to Fortune 500 enterprises.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    Vault organizes its capabilities into <strong>secrets engines</strong> (plugins that store or generate secrets — KV, database, AWS, PKI, transit) and <strong>auth methods</strong> (plugins that authenticate callers — AppRole, Kubernetes, AWS IAM, LDAP, JWT). Every request to Vault is authenticated and authorization is checked against <strong>policies</strong> written in HCL. Every access is recorded in an <strong>audit log</strong>. Secrets have <strong>leases</strong> that limit how long they are valid, and Vault can automatically renew or revoke them.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>KV Secrets Engine</strong> — versioned key-value store for static secrets with full history</li>
    <li><strong>Dynamic Secrets</strong> — on-demand database users, AWS credentials, SSH OTPs that auto-expire</li>
    <li><strong>PKI Secrets Engine</strong> — internal certificate authority: issue and revoke TLS certificates via API</li>
    <li><strong>Transit Encryption</strong> — encryption-as-a-service: encrypt/decrypt/sign without managing keys in app code</li>
    <li><strong>Leases &amp; Renewal</strong> — every secret has a TTL; Vault automatically revokes expired secrets</li>
    <li><strong>Policies</strong> — fine-grained HCL policies: allow/deny paths with specific capabilities (read, write, list)</li>
    <li><strong>Audit Logging</strong> — every request and response logged (file, syslog, socket backends)</li>
    <li><strong>Vault Agent</strong> — client daemon that authenticates and renders secrets to files or env vars</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Getting Started: CLI Basics</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={vaultCliBasics}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Dynamic Database Credentials</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={vaultDynamicCreds}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">AppRole Authentication</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={vaultAppRole}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Vault vs Secrets Management Alternatives</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse mb-6">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">HashiCorp Vault</th>
          <th class="border border-border px-3 py-2 text-left">AWS Secrets Manager</th>
          <th class="border border-border px-3 py-2 text-left">Azure Key Vault</th>
          <th class="border border-border px-3 py-2 text-left">Doppler</th>
          <th class="border border-border px-3 py-2 text-left">1Password Secrets</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-border px-3 py-2">Dynamic secrets</td>
          <td class="border border-border px-3 py-2">Yes (core feature)</td>
          <td class="border border-border px-3 py-2">Limited (RDS rotation)</td>
          <td class="border border-border px-3 py-2">No</td>
          <td class="border border-border px-3 py-2">No</td>
          <td class="border border-border px-3 py-2">No</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Multi-cloud</td>
          <td class="border border-border px-3 py-2">Yes</td>
          <td class="border border-border px-3 py-2">AWS only</td>
          <td class="border border-border px-3 py-2">Azure only</td>
          <td class="border border-border px-3 py-2">Yes</td>
          <td class="border border-border px-3 py-2">Yes</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">PKI / TLS CA</td>
          <td class="border border-border px-3 py-2">Yes</td>
          <td class="border border-border px-3 py-2">ACM (separate)</td>
          <td class="border border-border px-3 py-2">Yes (Managed HSM)</td>
          <td class="border border-border px-3 py-2">No</td>
          <td class="border border-border px-3 py-2">No</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Self-hosted</td>
          <td class="border border-border px-3 py-2">Yes (OSS)</td>
          <td class="border border-border px-3 py-2">No (managed)</td>
          <td class="border border-border px-3 py-2">No (managed)</td>
          <td class="border border-border px-3 py-2">No (SaaS)</td>
          <td class="border border-border px-3 py-2">No (SaaS)</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">Audit logging</td>
          <td class="border border-border px-3 py-2">Comprehensive</td>
          <td class="border border-border px-3 py-2">CloudTrail</td>
          <td class="border border-border px-3 py-2">Azure Monitor</td>
          <td class="border border-border px-3 py-2">Activity log</td>
          <td class="border border-border px-3 py-2">Activity log</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Complexity</td>
          <td class="border border-border px-3 py-2">High (self-managed)</td>
          <td class="border border-border px-3 py-2">Low (fully managed)</td>
          <td class="border border-border px-3 py-2">Low (fully managed)</td>
          <td class="border border-border px-3 py-2">Low (SaaS)</td>
          <td class="border border-border px-3 py-2">Low (SaaS)</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Use Cases</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li>Eliminating hardcoded database passwords — dynamic credentials rotate automatically every hour</li>
    <li>Internal certificate authority — issue short-lived TLS certs to microservices via the PKI engine</li>
    <li>Encryption-as-a-service — encrypt PII before storing in databases using the Transit engine</li>
    <li>CI/CD pipeline secrets — Jenkins, GitHub Actions, and GitLab CI authenticate via AppRole or JWT</li>
    <li>Kubernetes secrets injection — Vault Agent sidecar or CSI driver injects secrets into pods</li>
    <li>Compliance and auditing — every secret access logged with timestamp, caller identity, and path</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pros and Cons</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-green-400 mb-2">Pros</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✓ Dynamic secrets are a game-changer for security posture</li>
        <li>✓ Multi-cloud, multi-platform — works everywhere</li>
        <li>✓ Full-featured PKI engine for internal TLS</li>
        <li>✓ Transit engine for application-layer encryption</li>
        <li>✓ Open source, self-hosted, no vendor lock-in</li>
        <li>✓ Comprehensive audit logging for compliance</li>
      </ul>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-red-400 mb-2">Cons</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✗ Complex to operate — unsealing, HA setup, backup procedures</li>
        <li>✗ Requires dedicated infrastructure and operational expertise</li>
        <li>✗ Vault Enterprise needed for performance replication (expensive)</li>
        <li>✗ Policy language (HCL paths) has a learning curve</li>
        <li>✗ Application integration requires SDK or Vault Agent setup</li>
        <li>✗ Overkill for small teams who just need static secret storage</li>
      </ul>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="HashiCorp Vault Secrets Guide" relatedTags={['vault', 'secrets', 'security', 'hashicorp', 'devops']} />
</BaseLayout>
