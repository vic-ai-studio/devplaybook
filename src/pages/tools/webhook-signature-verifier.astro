---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How does webhook signature verification work?", answer: "The sending service computes an HMAC (keyed hash) over the raw request body using a shared secret key. The result is sent as a header (e.g. X-Hub-Signature-256: sha256=abc123). Your server independently computes the same HMAC with the same secret and compares the two values. If they match, the payload is authentic and hasn't been tampered with." },
  { question: "Why should I use constant-time comparison?", answer: "Timing attacks can reveal the correct signature one character at a time by measuring how long a comparison takes. Standard string equality short-circuits on the first mismatch. Use `crypto.timingSafeEqual()` (Node.js) or `hmac.compare_digest()` (Python) which always compare all bytes in the same amount of time." },
  { question: "Which algorithm should I use — SHA-256 or SHA-1?", answer: "Always prefer HMAC-SHA256. SHA-1 is considered cryptographically weak and deprecated for new systems. It's still used by some older providers (GitHub's legacy X-Hub-Signature header uses SHA-1) but SHA-256 provides stronger collision resistance." },
  { question: "What is the signature prefix (e.g. sha256=)?", answer: "Many providers prefix the hex signature with the algorithm name: GitHub sends `sha256=<hex>`, Stripe sends `v1=<hex>`. This prefix is part of the header value, not the computed HMAC. When verifying, strip the prefix before comparing, or include it in your expected value calculation." },
  { question: "Should I verify webhooks in production?", answer: "Yes — always verify webhook signatures in production. Skipping verification means any attacker who discovers your endpoint URL can send arbitrary fake events. The verification process is inexpensive and prevents spoofed events from triggering critical business logic." },
];
---

<BaseLayout
  title="Webhook Signature Verifier — HMAC-SHA256 / SHA1 Verification Tool"
  description="Verify webhook signatures client-side. Compute HMAC-SHA256 or SHA1 signatures and check against received headers. Includes Node.js and Python verification code."
  tool="Webhook Signature Verifier, HMAC SHA256 Verifier, Webhook Security, Node.js Webhook, Python Webhook"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Webhook Signature Verifier</h1>
  <p class="text-text-muted mb-4">Verify HMAC webhook signatures client-side using SubtleCrypto. Paste your payload, secret, and received signature to instantly check authenticity.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> HMAC-SHA256 &amp; SHA1</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Client-side SubtleCrypto</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Node.js &amp; Python code</span>
  </div>

  <!-- Inputs -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Verification Inputs</h2>
    <div class="mb-4">
      <label class="block text-sm font-medium mb-1.5">Payload Body (raw request body)</label>
      <textarea id="wh-payload" rows="5"
        class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono resize-y"
></textarea>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Secret Key</label>
        <input id="wh-secret" type="text" value="whsec_my_super_secret_key_here"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Received Signature (from header)</label>
        <input id="wh-received" type="text" placeholder="sha256=abc123def456..."
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Algorithm</label>
        <select id="wh-algo" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="SHA-256">HMAC-SHA256</option>
          <option value="SHA-1">HMAC-SHA1</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Signature Prefix (optional, e.g. sha256=)</label>
        <input id="wh-prefix" type="text" placeholder="sha256="
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
      </div>
    </div>
    <button id="wh-verify" class="bg-primary text-white rounded-lg px-5 py-2 text-sm font-semibold hover:opacity-90 transition-opacity">
      Verify Signature
    </button>
  </div>

  <!-- Result -->
  <div id="wh-result-box" class="bg-bg-card border border-border rounded-xl p-5 mb-5 hidden">
    <h2 class="text-base font-semibold mb-4">Verification Result</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
      <div>
        <div class="flex justify-between items-center mb-1">
          <label class="text-sm font-medium">Computed Signature</label>
          <button class="wh-copy text-xs text-primary hover:underline" data-target="out-computed">Copy</button>
        </div>
        <div id="out-computed" class="bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono break-all text-text-muted"></div>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Match Result</label>
        <div id="out-match" class="rounded-lg px-3 py-2 text-sm font-semibold"></div>
      </div>
    </div>
  </div>

  <!-- Code Output Tabs -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-4">Verification Code</h2>
    <div class="flex gap-1 mb-4 border-b border-border">
      <button class="wh-tab px-4 py-2 text-sm font-medium rounded-t-lg border-b-2 border-primary text-primary" data-tab="nodejs">Node.js</button>
      <button class="wh-tab px-4 py-2 text-sm font-medium rounded-t-lg border-b-2 border-transparent text-text-muted hover:text-primary" data-tab="python">Python</button>
    </div>
    <div id="wh-tab-nodejs" class="wh-tab-panel">
      <div class="flex justify-between items-center mb-2">
        <span class="text-xs text-text-muted font-mono">javascript</span>
        <button class="wh-copy text-xs text-primary hover:underline" data-target="out-nodejs">Copy</button>
      </div>
      <pre id="out-nodejs" class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto whitespace-pre-wrap text-text-muted"></pre>
    </div>
    <div id="wh-tab-python" class="wh-tab-panel hidden">
      <div class="flex justify-between items-center mb-2">
        <span class="text-xs text-text-muted font-mono">python</span>
        <button class="wh-copy text-xs text-primary hover:underline" data-target="out-python">Copy</button>
      </div>
      <pre id="out-python" class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto whitespace-pre-wrap text-text-muted"></pre>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Webhook Signature Verifier" relatedTags={['webhook', 'hmac', 'security', 'api', 'nodejs', 'python']} />
</BaseLayout>

<script>
  // Set default textarea value (avoids Astro parsing {} as expressions)
  (document.getElementById('wh-payload') as HTMLTextAreaElement).value = '{"event":"payment.completed","amount":9900,"currency":"usd","customer_id":"cus_abc123"}';

  function getV(id: string): string {
    return (document.getElementById(id) as HTMLInputElement).value;
  }

  function toHex(buffer: ArrayBuffer): string {
    return Array.from(new Uint8Array(buffer)).map(b => b.toString(16).padStart(2, '0')).join('');
  }

  function buildNodeCode(algo: string, secret: string, prefix: string): string {
    const algoName = algo === 'SHA-256' ? 'sha256' : 'sha1';
    const headerName = algo === 'SHA-256' ? 'x-signature-256' : 'x-signature';
    return `const crypto = require('crypto');

function verifyWebhookSignature(req, secret) {
  const payload = req.body; // raw Buffer — do NOT parse JSON first
  const received = req.headers['${headerName}'] || '';
  const prefix = '${prefix || ''}';

  const computed = crypto
    .createHmac('${algoName}', secret)
    .update(payload)
    .digest('hex');

  const expectedFull = prefix + computed;
  const receivedBuf = Buffer.from(received, 'utf8');
  const expectedBuf = Buffer.from(expectedFull, 'utf8');

  // Constant-time comparison to prevent timing attacks
  if (receivedBuf.length !== expectedBuf.length) {
    return false;
  }
  return crypto.timingSafeEqual(receivedBuf, expectedBuf);
}

// Express middleware usage
app.post('/webhook', express.raw({ type: 'application/json' }), (req, res) => {
  const isValid = verifyWebhookSignature(req, '${secret_placeholder}');
  if (!isValid) return res.status(401).json({ error: 'Invalid signature' });
  const event = JSON.parse(req.body);
  // process event...
  res.json({ received: true });
});`;
  }

  function buildPythonCode(algo: string, secret: string, prefix: string): string {
    const algoName = algo === 'SHA-256' ? 'sha256' : 'sha1';
    const headerName = algo === 'SHA-256' ? 'X-Signature-256' : 'X-Signature';
    return `import hmac
import hashlib
from flask import Flask, request, abort

app = Flask(__name__)
WEBHOOK_SECRET = b'${secret_placeholder}'

def verify_webhook_signature(payload: bytes, received_sig: str) -> bool:
    """Verify HMAC-${algoName.toUpperCase()} webhook signature using constant-time compare."""
    computed = hmac.new(
        WEBHOOK_SECRET,
        msg=payload,
        digestmod=hashlib.${algoName}
    ).hexdigest()

    prefix = '${prefix || ''}'
    expected = prefix + computed

    # hmac.compare_digest is constant-time — prevents timing attacks
    return hmac.compare_digest(expected, received_sig)

@app.route('/webhook', methods=['POST'])
def webhook():
    payload = request.get_data()  # raw bytes
    received = request.headers.get('${headerName}', '')

    if not verify_webhook_signature(payload, received):
        abort(401, description='Invalid signature')

    event = request.get_json(force=True)
    # process event...
    return {'received': True}, 200`;
  }

  const secret_placeholder = 'YOUR_WEBHOOK_SECRET';

  async function verify() {
    const payload = getV('wh-payload');
    const secret = getV('wh-secret');
    const received = getV('wh-received').trim();
    const algo = getV('wh-algo') as 'SHA-256' | 'SHA-1';
    const prefix = getV('wh-prefix');

    // Compute HMAC
    const encoder = new TextEncoder();
    const keyData = encoder.encode(secret);
    const msgData = encoder.encode(payload);

    const cryptoKey = await crypto.subtle.importKey(
      'raw', keyData,
      { name: 'HMAC', hash: algo },
      false, ['sign']
    );

    const sig = await crypto.subtle.sign('HMAC', cryptoKey, msgData);
    const computed = toHex(sig);
    const computedFull = prefix + computed;

    // Show result
    document.getElementById('wh-result-box')!.classList.remove('hidden');
    const computedEl = document.getElementById('out-computed')!;
    computedEl.textContent = computedFull;

    const matchEl = document.getElementById('out-match')!;
    const isMatch = received ? (received === computedFull || received === computed) : false;
    if (!received) {
      matchEl.textContent = '— No received signature to compare';
      matchEl.className = 'rounded-lg px-3 py-2 text-sm font-semibold bg-bg-card border border-border text-text-muted';
    } else if (isMatch) {
      matchEl.textContent = '✓ Signatures match — payload is authentic';
      matchEl.className = 'rounded-lg px-3 py-2 text-sm font-semibold bg-green-500/10 border border-green-500/30 text-green-500';
    } else {
      matchEl.textContent = '✗ Signatures do NOT match — payload may be tampered or wrong secret';
      matchEl.className = 'rounded-lg px-3 py-2 text-sm font-semibold bg-red-500/10 border border-red-500/30 text-red-500';
    }

    // Update code snippets
    (document.getElementById('out-nodejs') as HTMLElement).textContent = buildNodeCode(algo, secret, prefix);
    (document.getElementById('out-python') as HTMLElement).textContent = buildPythonCode(algo, secret, prefix);
  }

  // Tab switching
  document.querySelectorAll('.wh-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = (btn as HTMLElement).dataset.tab!;
      document.querySelectorAll('.wh-tab').forEach(b => {
        b.classList.remove('border-primary', 'text-primary');
        b.classList.add('border-transparent', 'text-text-muted');
      });
      btn.classList.add('border-primary', 'text-primary');
      btn.classList.remove('border-transparent', 'text-text-muted');
      document.querySelectorAll('.wh-tab-panel').forEach(p => p.classList.add('hidden'));
      document.getElementById('wh-tab-' + tab)!.classList.remove('hidden');
    });
  });

  // Copy buttons
  document.querySelectorAll('.wh-copy').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = (btn as HTMLElement).dataset.target!;
      const text = (document.getElementById(target) as HTMLElement).textContent || '';
      navigator.clipboard.writeText(text).then(() => {
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
      });
    });
  });

  document.getElementById('wh-verify')!.addEventListener('click', verify);

  // Initialize code snippets
  (document.getElementById('out-nodejs') as HTMLElement).textContent = buildNodeCode('SHA-256', secret_placeholder, 'sha256=');
  (document.getElementById('out-python') as HTMLElement).textContent = buildPythonCode('SHA-256', secret_placeholder, 'sha256=');

  // Auto-verify when inputs change
  ['wh-payload', 'wh-secret', 'wh-received', 'wh-algo', 'wh-prefix'].forEach(id => {
    document.getElementById(id)!.addEventListener('input', verify);
  });
</script>
