---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UrlParser from '../../components/UrlParser.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What does the URL parser show?", answer: "The parser breaks a URL into its components: protocol (https:), hostname (domain), port, pathname (/path/to/page), query string (?key=value), query parameters as a table, and hash fragment (#section)." },
  { question: "What is a query string?", answer: "A query string is the part of the URL after the ? character. It contains key=value pairs separated by & that pass data to the server or page. For example: ?page=1&sort=name&limit=20." },
  { question: "What is the URL fragment (#hash)?", answer: "The fragment (hash) is the part of the URL after #. It identifies a section on the page and is not sent to the server. It's used for navigation within a page and for single-page app routing." },
  { question: "Can I build a URL from parts?", answer: "Yes — switch to 'Build URL' mode to enter protocol, hostname, port, path, query parameters, and hash separately. The tool assembles them into a valid, encoded URL." },
];
---

<BaseLayout
  title="URL Parser & Builder — Parse URL Components Online"
  description="Parse any URL into its components: protocol, hostname, path, query parameters, and hash. Or build a URL from parts. Free online URL parser tool."
  tool="URL parser, URL components, URL decoder, parse URL online, URL builder, query string parser"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">URL Parser & Builder</h1>
  <p class="text-text-muted mb-4">Paste any URL to break it down into protocol, hostname, port, pathname, query parameters (as a table), and hash fragment. Or switch to Build mode to construct a URL from individual parts.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Parse & build modes</span>
  </div>
  <UrlParser client:only="preact" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more free developer tools?</p>
    <a href="/tools" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Browse All Free Tools →</a>
  </div>
  <ToolPageCta currentTool="URL Parser" relatedTags={['url', 'http', 'api', 'encoding']} />
</BaseLayout>
