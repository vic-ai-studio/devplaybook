---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is Jest and why is it the most popular JS testing framework?", answer: "Jest is a JavaScript testing framework developed by Meta (Facebook) and maintained by the open-source community. It became the dominant choice because it works with zero configuration for most projects, bundles mocking, assertion, and coverage tooling together, and integrates seamlessly with Babel, TypeScript, and React. Its snapshot testing feature and watch mode transformed developer workflow by making TDD fast and ergonomic." },
  { question: "What is the difference between describe, it, and test in Jest?", answer: "describe() groups related tests into a suite — it is optional but improves readability. it() and test() are aliases; both define a single test case. The convention is to use it() with a behaviour-description ('it should return 0 for empty input') and test() for more imperative descriptions ('test calculateTotal'). Nesting describe blocks lets you organize tests by feature, component, and scenario." },
  { question: "How does Jest snapshot testing work?", answer: "When you call expect(value).toMatchSnapshot(), Jest serializes the value and saves it to a __snapshots__ directory on the first run. On subsequent runs it compares the serialized output against the saved snapshot and fails if they differ. Snapshots are powerful for UI component output (React) and large JSON structures. Run jest --updateSnapshot (or jest -u) to regenerate snapshots after intentional changes." },
  { question: "What is the difference between jest.fn(), jest.spyOn(), and jest.mock()?", answer: "jest.fn() creates a standalone mock function with no implementation. jest.spyOn(object, 'method') wraps an existing method so you can track calls without fully replacing it — the original implementation still runs unless you chain .mockImplementation(). jest.mock('module') replaces an entire module with an auto-mocked version at the module system level, affecting all imports in the test file. Each serves a different granularity of isolation." },
  { question: "How do I test asynchronous code in Jest?", answer: "Jest supports three async patterns: (1) return a Promise from the test function and Jest waits for it to resolve; (2) use async/await which is the modern preferred style; (3) use the done callback for callback-style APIs. For promises, use expect(promise).resolves.toBe(value) or expect(promise).rejects.toThrow(). Always use expect.assertions(n) in async tests to ensure assertions actually ran if you are testing rejection paths." },
  { question: "How do I configure Jest for TypeScript?", answer: "Install ts-jest and @types/jest, then set transform: { '^.+\\.tsx?$': 'ts-jest' } in jest.config.ts. Alternatively, use Babel with @babel/preset-typescript for faster (but type-unsafe) transforms. ts-jest runs the TypeScript compiler so type errors surface in tests; the Babel approach is faster but skips type-checking. For modern projects, Vitest is often preferred over Jest+TypeScript due to simpler config." },
];
---

<BaseLayout
  title="Jest Testing Guide — JavaScript Unit Testing Framework Reference"
  description="Complete Jest guide covering describe/it/expect, mocks, snapshots, async testing, coverage, and configuration. Compare Jest vs Vitest vs Mocha. Free reference for JavaScript developers."
  tool="Jest testing guide, Jest mocks, Jest snapshot testing, Jest async, Jest TypeScript, JavaScript unit testing"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Jest Testing Guide",
    "url": "https://devplaybook.cc/tools/jest-testing",
    "description": "Complete guide to Jest — the dominant JavaScript unit testing framework. Covers setup, matchers, mocks, snapshots, async patterns, coverage, and TypeScript configuration.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Jest Testing Guide</h1>
  <p class="text-text-muted mb-6">
    The definitive reference for <strong>Jest</strong> — JavaScript's most-used testing framework. Covers matchers, mocking, snapshots, async patterns, coverage configuration, and TypeScript integration.
  </p>

  <div class="flex items-center gap-3 mb-8 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Zero-config setup</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Built-in mocking</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Snapshot testing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Code coverage</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript support</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Jest?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Jest is a delightful JavaScript testing framework created by Meta and open-sourced to the community. Unlike older frameworks that required assembling a separate test runner (Mocha), assertion library (Chai), and mocking library (Sinon), Jest ships all three in a single, coherent package. This zero-configuration philosophy — combined with excellent watch mode, parallel test execution, and built-in code coverage — made Jest the dominant choice for React, Node.js, and TypeScript projects alike.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    Jest uses jsdom as a simulated browser environment by default, making it ideal for testing React components without a real browser. For Node.js-only code, you can set <code class="bg-bg-card px-1 rounded text-sm">testEnvironment: 'node'</code> for better performance. With over 40 million weekly npm downloads, Jest has shaped how an entire generation of JavaScript developers thinks about testing.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Installation &amp; Basic Setup</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Install Jest
npm install --save-dev jest

# With TypeScript support
npm install --save-dev jest ts-jest @types/jest typescript

# jest.config.ts
export default {
  preset: 'ts-jest',
  testEnvironment: 'node',
  coverageDirectory: 'coverage',
  collectCoverageFrom: ['src/**/*.ts'],
};</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Core Test Structure: describe / it / expect</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Jest tests are organised into suites (describe blocks) and individual test cases (it or test). The <code class="bg-bg-card px-1 rounded text-sm">expect()</code> function chains to matchers like <code class="bg-bg-card px-1 rounded text-sm">toBe</code>, <code class="bg-bg-card px-1 rounded text-sm">toEqual</code>, <code class="bg-bg-card px-1 rounded text-sm">toThrow</code>, and many more.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// math.test.ts
import { add, divide } from './math';

describe('add()', () => {
  it('returns the sum of two positive numbers', () => {
    expect(add(2, 3)).toBe(5);
  });

  it('handles negative numbers', () => {
    expect(add(-1, 1)).toBe(0);
  });
});

describe('divide()', () => {
  it('divides correctly', () => {
    expect(divide(10, 2)).toBeCloseTo(5);
  });

  it('throws on division by zero', () => {
    expect(() => divide(10, 0)).toThrow('Cannot divide by zero');
  });
});</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Lifecycle Hooks: beforeEach / afterEach / beforeAll / afterAll</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">describe('DatabaseService', () => {
  let db: DatabaseService;

  beforeAll(async () => {
    // Runs once before all tests in this describe block
    await setupTestDatabase();
  });

  beforeEach(() => {
    // Runs before each individual test
    db = new DatabaseService({ url: 'sqlite::memory:' });
  });

  afterEach(async () => {
    // Clean up state between tests
    await db.clearAll();
    jest.clearAllMocks();
  });

  afterAll(async () => {
    // Runs once after all tests complete
    await teardownTestDatabase();
  });

  it('inserts a record', async () => {
    const id = await db.insert({ name: 'Alice' });
    expect(id).toBeDefined();
  });
});</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Mocking: jest.fn(), jest.spyOn(), jest.mock()</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// 1. Standalone mock function
const mockFetch = jest.fn().mockResolvedValue({ json: () => ({ id: 1 }) });

// 2. Spy on an existing method (original still runs)
const consoleSpy = jest.spyOn(console, 'error').mockImplementation(() => {});

// 3. Mock an entire module
jest.mock('./emailService', () => ({
  sendEmail: jest.fn().mockResolvedValue({ messageId: 'abc123' }),
}));

import { sendEmail } from './emailService';

it('calls sendEmail with correct args', async () => {
  await notifyUser('user@example.com', 'Hello');
  expect(sendEmail).toHaveBeenCalledWith('user@example.com', expect.stringContaining('Hello'));
  expect(sendEmail).toHaveBeenCalledTimes(1);
});</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Async Testing</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// Async/await (preferred)
it('fetches user data', async () => {
  const user = await fetchUser(42);
  expect(user).toMatchObject({ id: 42, name: expect.any(String) });
});

// Testing rejection
it('throws on 404', async () => {
  await expect(fetchUser(9999)).rejects.toThrow('User not found');
});

// Using resolves/rejects matchers
it('resolves to a valid token', () => {
  return expect(generateToken()).resolves.toMatch(/^[A-Za-z0-9._-]+$/);
});</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Snapshot Testing</strong> — serialise component output and detect regressions automatically</li>
    <li><strong>Coverage Reports</strong> — built-in Istanbul coverage with HTML, LCOV, and text outputs</li>
    <li><strong>Watch Mode</strong> — re-run only changed tests on every file save for rapid feedback</li>
    <li><strong>Parallel Workers</strong> — tests run in isolated worker processes for speed and isolation</li>
    <li><strong>Timer Mocking</strong> — jest.useFakeTimers() controls setTimeout, setInterval, and Date</li>
    <li><strong>Global Setup/Teardown</strong> — globalSetup and globalTeardown for database migrations before the full suite</li>
    <li><strong>Custom Matchers</strong> — extend expect with project-specific assertions via expect.extend()</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Use Cases</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>React component testing</strong> — with React Testing Library for user-centric assertions</li>
    <li><strong>Node.js API unit tests</strong> — mock dependencies, test route handlers and service layers</li>
    <li><strong>Utility library testing</strong> — pure function suites with high coverage targets</li>
    <li><strong>Regression prevention</strong> — snapshot tests catch unintended UI or JSON output changes</li>
    <li><strong>TDD workflows</strong> — watch mode makes red-green-refactor cycles instant</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Comparison: Jest vs Alternatives</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse mb-6">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">Jest</th>
          <th class="border border-border px-3 py-2 text-left">Vitest</th>
          <th class="border border-border px-3 py-2 text-left">Jasmine</th>
          <th class="border border-border px-3 py-2 text-left">Mocha</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-border px-3 py-2">Zero config</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes (Vite)</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes</td>
          <td class="border border-border px-3 py-2 text-yellow-400">No</td>
        </tr>
        <tr class="bg-bg-card/50">
          <td class="border border-border px-3 py-2">Built-in mocking</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Spies only</td>
          <td class="border border-border px-3 py-2 text-red-400">No (needs Sinon)</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">Snapshot testing</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
        </tr>
        <tr class="bg-bg-card/50">
          <td class="border border-border px-3 py-2">Native ESM</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Partial</td>
          <td class="border border-border px-3 py-2 text-green-400">Full</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Partial</td>
          <td class="border border-border px-3 py-2 text-green-400">Full</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">Speed (large suites)</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Moderate</td>
          <td class="border border-border px-3 py-2 text-green-400">Fast</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Moderate</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Moderate</td>
        </tr>
        <tr class="bg-bg-card/50">
          <td class="border border-border px-3 py-2">React ecosystem fit</td>
          <td class="border border-border px-3 py-2 text-green-400">Excellent</td>
          <td class="border border-border px-3 py-2 text-green-400">Excellent</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Good</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Good</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pros &amp; Cons</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-green-400 mb-2">Pros</h3>
      <ul class="list-disc list-inside text-text-muted space-y-1 text-sm">
        <li>All-in-one: runner + assertions + mocks + coverage</li>
        <li>Massive ecosystem and community documentation</li>
        <li>Excellent React Testing Library integration</li>
        <li>Snapshot testing catches regressions automatically</li>
        <li>Parallel worker isolation prevents test bleed</li>
        <li>Great watch mode with interactive filter UI</li>
      </ul>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-red-400 mb-2">Cons</h3>
      <ul class="list-disc list-inside text-text-muted space-y-1 text-sm">
        <li>Slow startup for large TypeScript projects</li>
        <li>Native ESM support is incomplete and tricky</li>
        <li>Heavy memory footprint with many workers</li>
        <li>jsdom doesn't perfectly replicate real browsers</li>
        <li>Config can become complex in monorepos</li>
        <li>Vitest is faster for Vite-based projects</li>
      </ul>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Jest Testing Guide" relatedTags={['jest', 'testing', 'javascript', 'unit-testing', 'developer-tools']} />
</BaseLayout>
