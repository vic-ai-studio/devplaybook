---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BinaryToDecimal from '../../components/BinaryToDecimal.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How do you convert binary to decimal?", answer: "Multiply each binary digit by 2 raised to its position power, then sum the results. For example, 1010 = 1×2³ + 0×2² + 1×2¹ + 0×2⁰ = 8 + 0 + 2 + 0 = 10. This tool shows every step of the calculation." },
  { question: "What is the difference between binary, octal, decimal, and hexadecimal?", answer: "They are different number bases: binary (base 2) uses only 0 and 1, octal (base 8) uses 0–7, decimal (base 10) uses 0–9 (our everyday system), and hexadecimal (base 16) uses 0–9 and A–F. Computers work natively in binary; hex is a compact shorthand for binary (4 bits = 1 hex digit)." },
  { question: "How do you convert decimal to binary?", answer: "Repeatedly divide the number by 2 and record each remainder. Read the remainders from bottom to top. For example: 172 ÷ 2 = 86 r0, 86 ÷ 2 = 43 r0, 43 ÷ 2 = 21 r1, 21 ÷ 2 = 10 r1, 10 ÷ 2 = 5 r0, 5 ÷ 2 = 2 r1, 2 ÷ 2 = 1 r0, 1 ÷ 2 = 0 r1 → read up: 10101100." },
  { question: "Why is hex used instead of binary in programming?", answer: "Binary strings get very long quickly — a 32-bit number needs 32 digits in binary but only 8 in hex. Each hex digit represents exactly 4 binary bits (a nibble), making conversion simple and the representation compact. Memory addresses, color codes (#FF6600), and byte values are all expressed in hex." },
  { question: "What is a nibble and a byte in binary?", answer: "A nibble is 4 binary bits (one hex digit), representing values 0–15. A byte is 8 binary bits (two hex digits), representing values 0–255. A byte is the fundamental unit of digital data storage." },
];
---

<BaseLayout
  title="Binary to Decimal Converter — Binary, Decimal, Hex, Octal"
  description="Convert between binary, decimal, hexadecimal, and octal with step-by-step explanations. See the full conversion math for any number. Runs 100% in your browser."
  tool="binary to decimal, decimal to binary, hex converter, octal converter, number base converter, binary calculator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Binary ↔ Decimal ↔ Hex ↔ Octal Converter</h1>
  <p class="text-text-muted mb-4">Convert numbers between binary (base 2), octal (base 8), decimal (base 10), and hexadecimal (base 16) — with step-by-step conversion math so you understand exactly how it works. Everything runs in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Step-by-step breakdown</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All 4 bases at once</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <BinaryToDecimal client:only="preact" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more free developer tools?</p>
    <a href="/tools" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Browse All Free Tools →</a>
  </div>
  <ToolPageCta currentTool="Binary to Decimal Converter" relatedTags={['binary', 'hex', 'math', 'encoding', 'low-level']} />
</BaseLayout>
