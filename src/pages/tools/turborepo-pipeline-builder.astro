---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TurborepoBuilder from '../../components/TurborepoBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a Turborepo pipeline and how does it work?",
    answer: "A Turborepo pipeline defines tasks and their relationships in turbo.json. When you run `turbo run build`, Turborepo reads the pipeline to determine the order to execute tasks across all packages in your monorepo. Tasks with `dependsOn: [\"^build\"]` wait for the upstream package's build to finish first. Tasks without dependencies run in parallel. Turborepo caches task outputs and replays them on cache hits, dramatically speeding up CI and local development."
  },
  {
    question: "What does the ^ (caret) prefix mean in dependsOn?",
    answer: "The ^ prefix in dependsOn means 'wait for all upstream packages in the dependency graph to complete this task first'. For example, `dependsOn: [\"^build\"]` means: before building package A, build all packages that A depends on. Without the caret, `dependsOn: [\"test\"]` means the task must run after the `test` task in the same package completes. Use ^ for cross-package dependencies and plain names for same-package ordering."
  },
  {
    question: "How does Turborepo caching work?",
    answer: "Turborepo computes a hash of the task's inputs (source files, env vars, turbo.json config) and checks a local or remote cache. On a cache hit, it replays the cached outputs and logs without re-running the task. Configure what files to hash with `inputs[]` and what to cache with `outputs[]`. Set `cache: false` for tasks like `dev` that should always run. Remote caching (Vercel Remote Cache or self-hosted) shares the cache across CI runs and team members."
  },
  {
    question: "When should I use persistent: true?",
    answer: "Set `persistent: true` for long-running tasks that don't exit, like `dev`, `start`, or `storybook`. This tells Turborepo not to wait for the task to finish before starting downstream tasks. Without persistent, Turborepo would block waiting for a server process that never exits. Persistent tasks are excluded from remote caching since they produce continuous output, not discrete artifacts."
  },
  {
    question: "What should I put in inputs[] vs outputs[]?",
    answer: "inputs[] are the files that affect the task's output — changes to these files invalidate the cache. Typical inputs: source files (`src/**`), config files (`tsconfig.json`, `.eslintrc.js`), and env var names. outputs[] are the files produced by the task that should be cached. Typical outputs: `dist/**`, `.next/**`, `coverage/**`. If outputs[] is empty, the task result is still cached (exit code + logs) but no files are restored on cache hit."
  },
  {
    question: "How do I run only affected packages?",
    answer: "Use `--filter` flag: `turbo run build --filter=[HEAD^1]` runs build only for packages changed since the last commit. `turbo run build --filter=./apps/web...` runs build for the web app and all its local dependencies. You can combine filters: `turbo run test --filter=./packages/... --filter=[origin/main...HEAD]`. In CI, combine with `--affected` (Turborepo v2+) or git diff to run only what changed."
  },
];
---

<BaseLayout
  title="Turborepo Pipeline Builder — Visual turbo.json Generator"
  description="Build Turborepo pipelines visually. Configure tasks, dependencies, cache settings, outputs, inputs, and env vars. Generates a valid turbo.json for your monorepo. Free, runs in browser."
  tool="turborepo pipeline builder, turbo.json generator, turborepo config, monorepo build pipeline, turborepo tasks"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Turborepo Pipeline Builder",
    "url": "https://devplaybook.cc/tools/turborepo-pipeline-builder",
    "description": "Visually build Turborepo pipeline configs. Add tasks, configure dependsOn, outputs, inputs, env vars, and cache settings. Get a valid turbo.json instantly.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Turborepo Pipeline Builder</h1>
  <p class="text-text-muted mb-4">
    Build <strong>Turborepo pipeline configs</strong> visually. Add tasks (build, test, lint, typecheck), configure <code class="font-mono text-sm">dependsOn</code>, cache settings, <code class="font-mono text-sm">outputs[]</code>, <code class="font-mono text-sm">inputs[]</code>, and <code class="font-mono text-sm">env[]</code>. Get a valid <strong>turbo.json</strong> ready to drop into your monorepo.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Visual task editor</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Dependency graph view</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Cache & persistent flags</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-ready turbo.json</span>
  </div>
  <TurborepoBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Turborepo Pipeline Builder" relatedTags={['monorepo', 'turborepo', 'build', 'devops', 'cicd', 'javascript']} />
</BaseLayout>
