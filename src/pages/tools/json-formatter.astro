---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonFormatter from '../../components/JsonFormatter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "How do I format JSON online?", answer: "Paste your raw JSON into the input field. The tool instantly formats it with proper indentation. Choose 2-space, 4-space, or tab indentation. Click 'Copy' to grab the formatted result." },
  { question: "How do I validate JSON?", answer: "Paste your JSON and the tool automatically checks for syntax errors. If there's a problem — missing comma, extra bracket, unquoted key — the error location is highlighted with a clear message." },
  { question: "What is the difference between JSON format and minify?", answer: "Formatting (or beautifying) adds indentation and line breaks to make JSON human-readable. Minifying removes all whitespace to create the smallest possible string — ideal for API payloads and configuration files." },
  { question: "Is it safe to paste sensitive JSON data?", answer: "Yes. This tool runs entirely in your browser. No data is sent to any server. Your JSON never leaves your machine, making it safe for API keys, tokens, and other sensitive payloads." },
];
---

<BaseLayout
  title="JSON Formatter & Validator — Free Online Tool"
  description="Format, beautify, and validate JSON online. Paste your JSON to instantly pretty-print it with 2-space, 4-space, or tab indentation. Minify JSON too. Free, runs in your browser."
  tool="JSON Formatter, JSON Beautifier, JSON Validator, JSON Pretty Print"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">JSON Formatter & Validator</h1>
  <p class="text-text-muted mb-4">Paste raw JSON to instantly format and validate it. Choose your indent style, minify to one line, or copy the result. Syntax errors are highlighted immediately.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <JsonFormatter client:load />
  <!-- Ad slot below tool output — highest CTR position (user pauses after using the tool) -->
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more free developer tools?</p>
    <a href="/tools" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Browse All 57 Free Tools →</a>
  </div>
  <ToolPageCta currentTool="JSON Formatter" relatedTags={['json', 'api', 'debugging', 'development']} />
</BaseLayout>
