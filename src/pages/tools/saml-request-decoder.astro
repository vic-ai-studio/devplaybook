---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SamlRequestDecoder from '../../components/SamlRequestDecoder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is SAML and when is it used?",
    answer: "SAML (Security Assertion Markup Language) is an XML-based SSO standard used primarily in enterprise environments. It allows an Identity Provider (IdP like Okta, Azure AD, ADFS) to authenticate a user and pass their identity to a Service Provider (SP — your app). SAML is widely used for enterprise SSO. For new apps, consider OIDC/OAuth2 instead — it's simpler and more developer-friendly. SAML is still required for integration with legacy enterprise systems."
  },
  {
    question: "What is the difference between SAMLRequest and SAMLResponse?",
    answer: "SAMLRequest is sent from the Service Provider (your app) to the Identity Provider to initiate authentication — it's an AuthnRequest XML document. SAMLResponse is sent from the Identity Provider back to the Service Provider after the user authenticates — it contains assertions (user identity, attributes, session info). Both are Base64-encoded XML, usually URL-encoded in the query string (redirect binding) or sent as form fields (POST binding)."
  },
  {
    question: "What does it mean when SAML validation fails with 'InResponseTo mismatch'?",
    answer: "When your app generates a SAMLRequest, it embeds an ID. The IdP's SAMLResponse includes InResponseTo with that ID to prevent replay attacks. If they don't match, it means either: (1) the response is for a different request (clock skew or session mismatch), (2) someone is replaying an old response, or (3) your SP lost track of the original request ID. Fix: ensure your app correctly stores and retrieves the request ID, and check NTP time sync between SP and IdP (allow ±5 minutes tolerance)."
  },
  {
    question: "How do I extract SAML data from browser network traffic?",
    answer: "Open Chrome DevTools → Network tab → filter by 'saml'. Look for POST requests to your app's ACS (Assertion Consumer Service) URL. In the request payload, find SAMLResponse form field. Copy the value. In GET requests (redirect binding), the SAMLRequest appears in the URL query string. Alternatively, use the SAML Chrome extension or Firefox SAML DevTools extension which automatically decode SAML messages as you browse."
  },
  {
    question: "What are SAML NameID and Attributes used for?",
    answer: "NameID is the primary identifier for the authenticated user — often an email address, username, or persistent opaque ID. Attributes are additional claims about the user sent in the assertion: email, displayName, groups, department, etc. The exact attribute names vary by IdP. In Okta they might be 'email' and 'firstName'; in Azure AD they use URN format like 'http://schemas.xmlsoap.org/ws/2005/05/identity/claims/emailaddress'. Map these attributes in your SP configuration to standardize them."
  },
  {
    question: "Why is my SAML response returning 'Signature verification failed'?",
    answer: "SAML responses are signed with the IdP's private key and verified using their public certificate. Verification fails when: (1) you're using the wrong IdP certificate — download the current certificate from your IdP's metadata URL, (2) the certificate has expired — IdPs rotate certificates periodically, (3) the XML was modified after signing — some proxies or middleware corrupt the response. Check your SP's stored IdP certificate matches what the IdP is currently using."
  },
];
---

<BaseLayout
  title="SAML Request Decoder — Decode & Inspect SAML XML"
  description="Decode and inspect SAML authentication requests and responses. Base64 decode, parse XML attributes, extract NameID, and view metadata. Works with SAMLRequest and SAMLResponse. Free, runs in your browser."
  tool="saml request decoder, saml response decoder, saml xml parser, saml debugger, decode saml base64, saml inspector"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "SAML Request Decoder",
    "url": "https://devplaybook.cc/tools/saml-request-decoder",
    "description": "Decode and inspect SAML authentication requests and responses. Base64 decode, parse XML, extract NameID and attributes, view metadata including issuer, status, and validity dates.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">SAML Request Decoder</h1>
  <p class="text-text-muted mb-4">
    Decode and inspect <strong>SAML authentication requests and responses</strong>. Paste Base64-encoded SAML data to decode the XML, extract NameID and attribute claims, view issuer, status, and validity metadata — all client-side, nothing sent to any server.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Base64 decode</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> XML attribute extraction</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Expiry check</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Nothing sent to server</span>
  </div>
  <SamlRequestDecoder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SAML Request Decoder" relatedTags={['authentication', 'saml', 'security', 'sso', 'enterprise', 'developer-tools']} />
</BaseLayout>
