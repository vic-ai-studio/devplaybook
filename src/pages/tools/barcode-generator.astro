---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BarcodeGenerator from '../../components/BarcodeGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "Which barcode formats are supported?", answer: "The generator supports Code 128 (general purpose, full ASCII), EAN-13 (European retail products, 13 digits), UPC-A (US retail products, 12 digits), and Code 39 (alphanumeric, used in industrial and automotive). Code 128 works for most general use cases." },
  { question: "What is the difference between EAN-13 and UPC-A?", answer: "UPC-A is a 12-digit barcode used primarily in the United States and Canada. EAN-13 is a 13-digit superset used internationally. Most modern barcode scanners read both. If you're creating barcodes for European products, use EAN-13; for US products, use UPC-A." },
  { question: "Can I download the barcode as a file?", answer: "Yes. After generating a barcode, click '↓ SVG' for a vector file (scalable to any size, ideal for print) or '↓ PNG' for a raster image at 2× resolution. SVG is recommended for professional use." },
  { question: "How do I generate a valid EAN-13 or UPC-A barcode?", answer: "EAN-13 requires exactly 13 digits where the last digit is a checksum calculated from the first 12. UPC-A requires 12 digits with the last as checksum. The tool validates automatically — use the 'Use Example' button to see a valid format." },
  { question: "Is this tool free and does it send data to a server?", answer: "Completely free. All barcode generation uses JsBarcode running entirely in your browser — no data is sent to any server. Safe to use for internal product codes, inventory labels, and sensitive identifiers." },
];
---

<BaseLayout
  title="Barcode Generator — Code 128, EAN-13, UPC-A, Code 39 | Free Online"
  description="Generate barcodes online for free. Supports Code 128, EAN-13, UPC-A, and Code 39 formats. Customize colors, download as SVG or PNG. Runs entirely in your browser — no data sent to servers."
  tool="barcode generator, Code 128 barcode, EAN-13 barcode, UPC-A barcode, Code 39, barcode maker online, generate barcode free"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Barcode Generator</h1>
  <p class="text-text-muted mb-4">Generate barcodes for Code 128, EAN-13, UPC-A, and Code 39 formats. Customize bar color and background, toggle the human-readable text, and download as SVG or PNG. Everything runs client-side — nothing sent to any server.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> SVG & PNG download</span>
  </div>
  <BarcodeGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more free developer tools?</p>
    <a href="/tools" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Browse All Free Tools →</a>
  </div>
  <ToolPageCta currentTool="Barcode Generator" relatedTags={['barcode', 'generator', 'image', 'qr-code', 'encoding']} />
</BaseLayout>
