---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GithubActionsLinter from '../../components/GithubActionsLinter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What does this linter check?",
    answer: "It checks for: missing on: trigger block, invalid event names, missing jobs: block, broken needs: job references, circular job dependencies, hardcoded tokens/secrets, actions pinned to branch refs instead of version tags, unusual runs-on runner values, secrets printed in echo commands, and tab characters in YAML."
  },
  {
    question: "Why should I pin actions to version tags instead of branches?",
    answer: "Pinning to @main or @master means your workflow will use whatever code is on that branch at the time it runs — including potentially malicious commits in a supply chain attack. Pinning to a version tag like @v4 or better yet a commit SHA (e.g. @abc1234) ensures your workflow is reproducible and not vulnerable to upstream changes."
  },
  {
    question: "What does needs: do in GitHub Actions?",
    answer: "The needs: field creates a dependency between jobs. A job with needs: [test, build] will only run after both test and build jobs complete successfully. If a referenced job name doesn't exist, the workflow will fail to parse. This linter catches undefined needs references before you push."
  },
  {
    question: "How should I handle secrets in GitHub Actions?",
    answer: "Store secrets in GitHub Settings → Secrets and variables → Actions, then reference them with ${{ secrets.MY_SECRET }}. Never hardcode token values in the workflow YAML. Use GITHUB_TOKEN for operations within the same repository — it's automatically provided and scoped to each workflow run."
  },
  {
    question: "What are valid GitHub Actions trigger events?",
    answer: "Common triggers include push, pull_request, pull_request_target, schedule (cron), workflow_dispatch (manual), workflow_call (reusable), release, issues, issue_comment, create, delete, deployment, and more. Invalid event names will cause the workflow to silently fail to trigger."
  },
  {
    question: "Does this tool send my workflow YAML to a server?",
    answer: "No. All linting runs entirely in your browser using JavaScript. Your workflow YAML never leaves your machine — important since workflows often reference sensitive secret names and repository structure."
  },
];
---

<BaseLayout
  title="GitHub Actions YAML Linter — Validate Workflow Files Online"
  description="Paste your GitHub Actions workflow YAML and lint it instantly. Catches missing triggers, broken needs references, hardcoded secrets, unversioned actions, and YAML syntax issues. Runs 100% in your browser."
  tool="GitHub Actions linter, workflow YAML validator, GitHub Actions checker, CI/CD linter, GitHub workflow validator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "GitHub Actions YAML Linter",
    "url": "https://devplaybook.cc/tools/github-actions-linter",
    "description": "Lint GitHub Actions workflow YAML files online. Catches broken needs references, hardcoded tokens, unversioned actions, invalid event names, and more. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">GitHub Actions YAML Linter</h1>
  <p class="text-text-muted mb-4">
    Paste your <code class="font-mono bg-surface px-1 rounded text-sm">.github/workflows/*.yml</code> and catch mistakes before you push.
    Validates trigger events, job dependencies, secret handling, and action version pins.
    Nothing is sent to any server — runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 10 validation checks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Security & secrets checks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Fix suggestions included</span>
  </div>
  <GithubActionsLinter client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="GitHub Actions YAML Linter" relatedTags={['ci-cd', 'github', 'devops', 'yaml', 'validation', 'automation', 'security']} />
</BaseLayout>
