---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a runbook?", answer: "A runbook is a documented set of procedures for operating and troubleshooting a system or service. It provides step-by-step instructions for common tasks and incident scenarios, enabling on-call engineers to respond quickly without relying on memory or tribal knowledge." },
  { question: "What should every runbook include?", answer: "A good runbook includes: service overview, how the alert/incident is detected, immediate triage steps, investigation commands, escalation contacts, resolution steps, rollback procedure, and post-incident follow-up actions. The goal is that any on-call engineer — even unfamiliar with the service — can follow it." },
  { question: "What is the difference between a runbook and a playbook?", answer: "These terms are often used interchangeably, but runbooks typically describe reactive procedures for specific operational tasks or alerts. Playbooks are broader operational guides covering multiple scenarios and decision trees. In practice, most teams call any operational procedure doc a runbook." },
  { question: "How should runbooks be maintained?", answer: "Runbooks should be updated after every incident as part of the post-incident review. Link runbooks from your alerting rules so on-call engineers find them instantly. Track runbook age — if a runbook hasn't been reviewed in 6 months, schedule a review. Consider runbook health as part of your reliability scorecard." },
  { question: "What are P0/P1/P2/P3 severity levels?", answer: "P0 (Critical): full outage or data loss — all hands, immediate response. P1 (High): major feature broken, significant revenue/customer impact — on-call engaged within 15 minutes. P2 (Medium): degraded performance or partial outage affecting some users — respond within 1-2 hours. P3 (Low): minor issue, workaround available — respond within 24-48 hours." },
];
---

<BaseLayout
  title="Runbook Generator — Create Structured Incident Runbooks Instantly"
  description="Generate complete structured runbooks for incidents. Fill in service name, incident type, and severity to get a ready-to-use runbook with investigation steps, escalation matrix, and resolution checklist."
  tool="Runbook Generator, Incident Runbook, On-call Playbook Generator, SRE Runbook Template"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Runbook Generator</h1>
  <p class="text-text-muted mb-4">Fill in the details below to generate a complete, structured runbook for your incident. Includes investigation commands, escalation matrix, resolution steps, and post-incident checklist.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Complete runbook with 8 sections</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Sample investigation commands</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Escalation matrix</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy to clipboard</span>
  </div>

  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Runbook Configuration</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Service / Component Name</label>
        <input id="service-name" type="text" value="order-service"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Incident Type</label>
        <select id="incident-type" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="service_down">Service Down / Unavailable</option>
          <option value="high_latency">High Latency / Slow Responses</option>
          <option value="high_error_rate">High Error Rate</option>
          <option value="disk_full">Disk Full / Storage Issue</option>
          <option value="oom">Out of Memory (OOM)</option>
          <option value="custom">Custom / Other</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Severity</label>
        <select id="severity" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="P0">P0 — Critical (full outage)</option>
          <option value="P1" selected>P1 — High (major impact)</option>
          <option value="P2">P2 — Medium (partial impact)</option>
          <option value="P3">P3 — Low (minor issue)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Responsible Team</label>
        <input id="team-name" type="text" value="Platform Engineering"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div class="md:col-span-2">
        <label class="block text-sm font-medium mb-1.5">Monitoring / Dashboard Link</label>
        <input id="monitoring-link" type="text" value="https://grafana.internal/d/order-service"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
    </div>
    <button id="btn-generate" class="mt-4 bg-primary text-white text-sm px-5 py-2 rounded-lg hover:opacity-90">Generate Runbook</button>
  </div>

  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-base font-semibold">Generated Runbook</h2>
      <button id="copy-btn" class="text-xs bg-primary text-white px-3 py-1.5 rounded-lg hover:opacity-90">Copy Runbook</button>
    </div>
    <pre id="runbook-output" class="bg-black/20 rounded-lg p-4 text-xs font-mono overflow-x-auto whitespace-pre text-green-300 max-h-[600px] overflow-y-auto"></pre>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Runbook Generator" relatedTags={['sre', 'devops', 'incident', 'runbook', 'on-call', 'reliability']} />
</BaseLayout>

<script is:inline>
  var INCIDENT_LABELS = {
    service_down:    "Service Down / Unavailable",
    high_latency:    "High Latency / Slow Responses",
    high_error_rate: "High Error Rate",
    disk_full:       "Disk Full / Storage Issue",
    oom:             "Out of Memory (OOM)",
    custom:          "Custom Incident"
  };

  var SEV_DEFS = {
    P0: { label: "Critical", response: "Immediate — all hands on deck", escalate: "5 minutes" },
    P1: { label: "High",     response: "Within 15 minutes",             escalate: "30 minutes" },
    P2: { label: "Medium",   response: "Within 1–2 hours",              escalate: "2 hours" },
    P3: { label: "Low",      response: "Within 24–48 hours",            escalate: "Next business day" },
  };

  function getDetectionSection(type, svc) {
    var detections = {
      service_down:    "- Alertmanager fires: `" + svc + "_up == 0` for > 2 minutes\n- Synthetic health check returns non-2xx\n- Error budget burn rate > 14.4x\n- Users reporting 503 Service Unavailable",
      high_latency:    "- Alertmanager fires: `p95_latency > 500ms` for > 5 minutes\n- Grafana SLO dashboard shows SLI below threshold\n- Error budget burn rate > 5x\n- Users reporting slow responses",
      high_error_rate: "- Alertmanager fires: `error_rate > 5%` for > 5 minutes\n- Grafana shows spike in 5xx responses\n- Error budget burn rate > 2x\n- Users/monitoring reporting errors",
      disk_full:       "- Alertmanager fires: `disk_usage > 85%`\n- Application logs contain `No space left on device`\n- Write operations failing",
      oom:             "- Pod/container OOMKilled in Kubernetes events\n- Alertmanager fires: `memory_usage > 90%`\n- Application crash with OutOfMemoryError",
      custom:          "- Alertmanager alert fires\n- User report or anomaly detected in monitoring\n- Automated health check failure",
    };
    return detections[type] || detections.custom;
  }

  function getImmediateActions(type, svc, sev) {
    var common = "- [ ] Acknowledge the alert in PagerDuty / OpsGenie\n- [ ] Join incident bridge: #incident-response channel\n- [ ] Open monitoring dashboard: see link below\n- [ ] Assess customer impact and notify stakeholders";
    var specific = {
      service_down:    "- [ ] Check pod/process status: `kubectl get pods -l app=" + svc + " -n production`\n- [ ] Check recent deployments: `kubectl rollout history deployment/" + svc + "`\n- [ ] If last deploy < 30 min ago, consider rollback immediately",
      high_latency:    "- [ ] Check current p95/p99 latency in Grafana\n- [ ] Identify if latency is upstream (dependency) or local\n- [ ] Check resource utilization (CPU/memory) — look for saturation",
      high_error_rate: "- [ ] Check error logs for error type and stack trace\n- [ ] Identify if error started after a recent deploy\n- [ ] Check downstream dependencies for failures",
      disk_full:       "- [ ] Run `df -h` to identify full mount\n- [ ] Check log directory size: `du -sh /var/log/*`\n- [ ] If > 95% full, rotate/archive logs immediately to free space",
      oom:             "- [ ] Check recent memory metrics in Grafana\n- [ ] Look for memory leak pattern (steadily increasing usage)\n- [ ] Restart pod as immediate relief if OOMKilled: `kubectl rollout restart deployment/" + svc + "`",
      custom:          "- [ ] Gather initial symptoms from alert\n- [ ] Check service health endpoints\n- [ ] Review recent changes (deploys, config, infrastructure)",
    };
    return common + "\n" + (specific[type] || specific.custom);
  }

  function getInvestigationSteps(type, svc) {
    var steps = {
      service_down: [
        "1. Check pod status and recent events:\n   ```\n   kubectl get pods -l app=" + svc + " -n production\n   kubectl describe pod -l app=" + svc + " -n production\n   kubectl events --field-selector reason=Failed -n production\n   ```",
        "2. Check application logs:\n   ```\n   kubectl logs -l app=" + svc + " -n production --tail=100\n   kubectl logs -l app=" + svc + " -n production --previous --tail=50\n   ```",
        "3. Check recent deployments and diff:\n   ```\n   kubectl rollout history deployment/" + svc + " -n production\n   kubectl diff -f deploy/" + svc + ".yaml\n   ```",
        "4. Check downstream service health:\n   ```\n   kubectl get endpoints -n production\n   curl -sv http://" + svc + "/healthz\n   ```",
      ],
      high_latency: [
        "1. Check p95/p99 latency in Grafana — identify when it started and correlate with deploys.",
        "2. Check CPU / memory saturation:\n   ```\n   kubectl top pods -l app=" + svc + " -n production\n   kubectl top nodes\n   ```",
        "3. Check database slow query log if " + svc + " is DB-backed:\n   ```\n   # PostgreSQL\n   SELECT query, mean_exec_time, calls FROM pg_stat_statements ORDER BY mean_exec_time DESC LIMIT 10;\n   ```",
        "4. Check upstream dependencies for added latency:\n   ```\n   curl -w '@/tmp/curl_format.txt' -o /dev/null -s http://dependency-service/health\n   ```",
      ],
      high_error_rate: [
        "1. Find error type from logs:\n   ```\n   kubectl logs -l app=" + svc + " -n production --tail=200 | grep -i error\n   ```",
        "2. Check error rate by endpoint in Grafana — identify if error is isolated to one route.",
        "3. Check dependency health (DB, cache, external APIs):\n   ```\n   kubectl exec -it deploy/" + svc + " -n production -- curl http://postgres-service:5432\n   kubectl exec -it deploy/" + svc + " -n production -- redis-cli ping\n   ```",
        "4. Compare with last known-good deployment logs for differences.",
      ],
      disk_full: [
        "1. Identify full volume:\n   ```\n   df -h\n   mount | grep ' / '\n   ```",
        "2. Find largest consumers:\n   ```\n   du -sh /* 2>/dev/null | sort -rh | head -20\n   du -sh /var/log/* | sort -rh | head -10\n   ```",
        "3. Check log rotation config:\n   ```\n   cat /etc/logrotate.conf\n   ls /etc/logrotate.d/\n   ```",
        "4. Clear old logs if safe:\n   ```\n   find /var/log -name '*.gz' -mtime +7 -delete\n   journalctl --vacuum-time=7d\n   ```",
      ],
      oom: [
        "1. Check OOM events in Kubernetes:\n   ```\n   kubectl get events -n production | grep OOM\n   kubectl describe pod -l app=" + svc + " -n production | grep -A5 OOM\n   ```",
        "2. Check memory trend in Grafana — gradual increase = leak, sudden spike = burst usage.",
        "3. Check JVM heap / Go memory if applicable:\n   ```\n   # JVM\n   kubectl exec -it deploy/" + svc + " -- jmap -heap 1\n   # Go pprof\n   curl http://localhost:6060/debug/pprof/heap > heap.prof\n   go tool pprof heap.prof\n   ```",
        "4. Review and adjust resource limits:\n   ```\n   kubectl get deployment " + svc + " -n production -o yaml | grep -A5 resources\n   ```",
      ],
      custom: [
        "1. Collect relevant logs:\n   ```\n   kubectl logs -l app=" + svc + " -n production --tail=200\n   ```",
        "2. Check service metrics in Grafana for anomalies.",
        "3. Review recent changes (git log, deployment history).",
        "4. Check dependency health.",
      ],
    };
    return (steps[type] || steps.custom).join("\n\n");
  }

  function generateRunbook() {
    var svc    = document.getElementById("service-name").value    || "my-service";
    var type   = document.getElementById("incident-type").value;
    var sev    = document.getElementById("severity").value;
    var team   = document.getElementById("team-name").value       || "Platform Engineering";
    var link   = document.getElementById("monitoring-link").value || "https://grafana.internal";
    var now    = new Date().toISOString().split("T")[0];
    var sevDef = SEV_DEFS[sev];

    var rb = "";
    rb += "# Runbook: " + INCIDENT_LABELS[type] + " — " + svc + "\n";
    rb += "\n";
    rb += "**Service:** " + svc + "  \n";
    rb += "**Severity:** " + sev + " — " + sevDef.label + "  \n";
    rb += "**Team:** " + team + "  \n";
    rb += "**Monitoring:** " + link + "  \n";
    rb += "**Last Updated:** " + now + "  \n";
    rb += "\n---\n\n";

    rb += "## 1. Overview\n\n";
    rb += "This runbook covers the procedure for handling a **" + INCIDENT_LABELS[type] + "** incident\n";
    rb += "affecting **" + svc + "**. Severity is **" + sev + " (" + sevDef.label + ")**.\n\n";
    rb += "Expected initial response time: **" + sevDef.response + "**\n\n";

    rb += "## 2. Detection\n\n";
    rb += "This incident is typically detected via:\n\n";
    rb += getDetectionSection(type, svc) + "\n\n";

    rb += "## 3. Immediate Actions (Triage Checklist)\n\n";
    rb += getImmediateActions(type, svc, sev) + "\n\n";

    rb += "## 4. Investigation Steps\n\n";
    rb += getInvestigationSteps(type, svc) + "\n\n";

    rb += "## 5. Escalation Matrix\n\n";
    rb += "| Condition | Escalate To | Timeframe |\n";
    rb += "|-----------|-------------|----------|\n";
    rb += "| Incident not resolved in " + sevDef.escalate + " | " + team + " lead | " + sevDef.escalate + " |\n";
    rb += "| Customer data at risk | Security team + VP Engineering | Immediately |\n";
    rb += "| Full production outage | CTO / executive on-call | Immediately |\n";
    rb += "| Third-party vendor issue | Vendor support + account manager | 15 minutes |\n\n";

    rb += "## 6. Resolution Steps\n\n";
    if (type === "service_down") {
      rb += "1. Identify root cause (bad deploy, config change, dependency failure, or hardware issue).\n";
      rb += "2. **If recent deploy:** `kubectl rollout undo deployment/" + svc + " -n production`\n";
      rb += "3. **If config issue:** revert ConfigMap and redeploy.\n";
      rb += "4. **If dependency failure:** implement circuit breaker or failover.\n";
      rb += "5. Verify service health: `kubectl get pods -l app=" + svc + " -n production`\n";
      rb += "6. Confirm in Grafana that error rate returns to baseline.\n";
      rb += "7. Run smoke tests: `curl -f http://" + svc + "/healthz`\n";
    } else if (type === "high_latency") {
      rb += "1. If resource saturation: scale up `kubectl scale deployment/" + svc + " --replicas=N -n production`\n";
      rb += "2. If slow queries: add query hints, indexes, or cache layer.\n";
      rb += "3. If upstream latency: enable circuit breaker / timeout reduction.\n";
      rb += "4. If bad deploy: rollback with `kubectl rollout undo deployment/" + svc + "`\n";
      rb += "5. Verify p95 latency returns to SLO threshold in Grafana.\n";
    } else if (type === "high_error_rate") {
      rb += "1. If caused by deploy: `kubectl rollout undo deployment/" + svc + " -n production`\n";
      rb += "2. If dependency failure: check circuit breaker status, enable fallback.\n";
      rb += "3. If bug: deploy hotfix through fast-track pipeline.\n";
      rb += "4. Verify error rate returns below SLO threshold.\n";
      rb += "5. Clear error queues if applicable.\n";
    } else if (type === "disk_full") {
      rb += "1. Immediately free space: archive/rotate old logs.\n";
      rb += "2. If database: run VACUUM or archive old data.\n";
      rb += "3. Expand volume if on cloud: resize EBS/PD volume.\n";
      rb += "4. Update log rotation policy to prevent recurrence.\n";
      rb += "5. Set disk usage alert at 70% to warn earlier next time.\n";
    } else if (type === "oom") {
      rb += "1. Immediate relief: restart affected pod(s).\n";
      rb += "2. Increase memory limits: update deployment resource spec.\n";
      rb += "3. If leak: deploy fix, use profiling data to identify root cause.\n";
      rb += "4. Set HPA min replicas to distribute memory load.\n";
      rb += "5. Add memory usage alert at 80% for earlier warning.\n";
    } else {
      rb += "1. Identify and confirm root cause.\n";
      rb += "2. Apply targeted fix or rollback as appropriate.\n";
      rb += "3. Verify service returns to healthy state.\n";
      rb += "4. Confirm in monitoring that all SLIs are within SLO.\n";
    }
    rb += "\n";

    rb += "## 7. Post-Incident Checklist\n\n";
    rb += "- [ ] Incident resolved and monitoring confirms recovery\n";
    rb += "- [ ] Stakeholders notified of resolution\n";
    rb += "- [ ] Incident timeline documented in incident tracker\n";
    rb += "- [ ] Post-incident review (PIR) scheduled within 24–48 hours\n";
    rb += "- [ ] Action items created for root cause fix\n";
    rb += "- [ ] This runbook updated with any new findings\n\n";

    rb += "## 8. Prevention\n\n";
    rb += "- Add/update automated tests that would have caught this issue\n";
    rb += "- Review alerting thresholds — were we notified early enough?\n";
    rb += "- Consider adding chaos engineering test for this scenario\n";
    rb += "- Update deployment checklist if process gaps contributed\n";
    rb += "- Share learning in team retrospective\n";

    return rb;
  }

  function updateOutput() {
    document.getElementById("runbook-output").textContent = generateRunbook();
  }

  document.getElementById("btn-generate").addEventListener("click", updateOutput);

  document.getElementById("copy-btn").addEventListener("click", function() {
    var text = document.getElementById("runbook-output").textContent;
    if (!text) { updateOutput(); text = document.getElementById("runbook-output").textContent; }
    navigator.clipboard.writeText(text).then(function() {
      var btn = document.getElementById("copy-btn");
      btn.textContent = "Copied!";
      setTimeout(function(){ btn.textContent = "Copy Runbook"; }, 2000);
    }).catch(function() {
      var ta = document.createElement("textarea");
      ta.value = text; document.body.appendChild(ta); ta.select(); document.execCommand("copy"); document.body.removeChild(ta);
      var btn = document.getElementById("copy-btn");
      btn.textContent = "Copied!"; setTimeout(function(){ btn.textContent = "Copy Runbook"; }, 2000);
    });
  });

  // Auto-generate on load
  updateOutput();
</script>
