---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WebSocketTester from '../../components/WebSocketTester.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a WebSocket and how is it different from HTTP?",
    answer: "WebSocket is a protocol that provides a persistent, full-duplex communication channel over a single TCP connection. Unlike HTTP, which is request-response (client initiates every exchange), WebSocket allows both client and server to send messages at any time after the connection is established. This makes it ideal for real-time features like chat, live dashboards, multiplayer games, and collaborative editing.",
  },
  {
    question: "What is the difference between ws:// and wss://?",
    answer: "ws:// is unencrypted WebSocket — equivalent to http://. wss:// is WebSocket over TLS — equivalent to https://. Always use wss:// in production to protect data in transit. Modern browsers may block ws:// connections from secure (https://) pages due to mixed content restrictions. For local development, ws://localhost is fine.",
  },
  {
    question: "How do I test my WebSocket server?",
    answer: "Enter your server URL (e.g. wss://myapp.com/ws) in the URL field and click Connect. Once connected, type a message and press Send or Ctrl+Enter. The message log shows both sent and received messages with timestamps and byte sizes. If you don't have a server ready, use the pre-filled echo server (wss://echo.websocket.events) — it reflects back everything you send.",
  },
  {
    question: "Why does my WebSocket connection fail?",
    answer: "Common causes: (1) Wrong URL or port — double-check the endpoint. (2) TLS mismatch — use wss:// for HTTPS pages, ws:// for HTTP. (3) Server not running — make sure the server process is live. (4) Firewall or proxy blocking WebSocket upgrades — corporate networks often block WebSocket. (5) Missing CORS headers on the WebSocket handshake — check your server's allowed origins.",
  },
  {
    question: "How do I send JSON over WebSocket?",
    answer: "WebSocket transmits raw strings or binary data — it has no built-in JSON framing. The convention is to JSON.stringify() your message before sending and JSON.parse() on receipt. This tester formats JSON messages automatically in the log. To send JSON, type a valid JSON object in the message input and the server will receive it as a string.",
  },
  {
    question: "What are WebSocket subprotocols?",
    answer: "Subprotocols (Sec-WebSocket-Protocol header) let client and server agree on a message format or application-level protocol on top of WebSocket. Examples: STOMP (messaging), MQTT (IoT), graphql-ws (GraphQL subscriptions), or custom application protocols. If your server requires a specific subprotocol, you'd need to specify it in the connection headers — not all testing tools support this out of the box.",
  },
];
---

<BaseLayout
  title="WebSocket Tester — Test WebSocket Connections Online"
  description="Connect to any WebSocket server, send and receive messages in real time, and inspect the message log with timestamps and byte sizes. Free online WebSocket client — no install needed."
  tool="WebSocket Tester, WebSocket Client, WebSocket Debugger, Test WebSocket Online"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "WebSocket Tester",
    "url": "https://devplaybook.cc/tools/websocket-tester",
    "description": "Online WebSocket client for testing WebSocket servers. Connect, send messages, and inspect the message log with timestamps.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">WebSocket Tester</h1>
  <p class="text-text-muted mb-8">
    Connect to any <code class="font-mono bg-surface px-1 rounded">ws://</code> or <code class="font-mono bg-surface px-1 rounded">wss://</code> server directly from your browser.
    Send JSON or raw text messages, see responses highlighted in real time with timestamps and byte sizes.
    Use <code class="font-mono bg-surface px-1 rounded">Ctrl+Enter</code> to send quickly.
    The free echo server at <code class="font-mono bg-surface px-1 rounded">wss://echo.websocket.events</code> is pre-filled to test with instantly.
  </p>
  <WebSocketTester client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="WebSocket Tester" relatedTags={['websocket', 'api', 'http', 'realtime', 'networking']} />
</BaseLayout>
