---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WebSocketTester from '../../components/WebSocketTester.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="WebSocket Tester — Test WebSocket Connections Online"
  description="Connect to any WebSocket server, send and receive messages in real time, and inspect the message log with timestamps and byte sizes. Free online WebSocket client — no install needed."
  tool="WebSocket Tester, WebSocket Client, WebSocket Debugger, Test WebSocket Online"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "WebSocket Tester",
    "url": "https://devplaybook.cc/tools/websocket-tester",
    "description": "Online WebSocket client for testing WebSocket servers. Connect, send messages, and inspect the message log with timestamps.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">WebSocket Tester</h1>
  <p class="text-text-muted mb-8">
    Connect to any <code class="font-mono bg-surface px-1 rounded">ws://</code> or <code class="font-mono bg-surface px-1 rounded">wss://</code> server directly from your browser.
    Send JSON or raw text messages, see responses highlighted in real time with timestamps and byte sizes.
    Use <code class="font-mono bg-surface px-1 rounded">Ctrl+Enter</code> to send quickly.
    The free echo server at <code class="font-mono bg-surface px-1 rounded">wss://echo.websocket.events</code> is pre-filled to test with instantly.
  </p>
  <WebSocketTester client:only="preact" />
  <ToolPageCta currentTool="WebSocket Tester" relatedTags={['websocket', 'api', 'http', 'realtime', 'networking']} />
</BaseLayout>
