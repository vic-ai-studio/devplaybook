---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const installExample = `# Add Biome as a dev dependency
npm add -D @biomejs/biome

# Initialize a biome.json config file
npx @biomejs/biome init

# Format all files in the project
npx @biomejs/biome format --write .

# Lint all files
npx @biomejs/biome lint .

# Check (lint + format check) and auto-fix everything
npx @biomejs/biome check --write .

# Check a specific file
npx @biomejs/biome check --write src/index.ts`;

const configExample = `// biome.json — generated by "biome init", customise as needed
{
  "$schema": "https://biomejs.dev/schemas/1.6.0/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "es5"
    }
  }
}`;

const ciExample = `# .github/workflows/biome.yml
name: Biome Check

on: [push, pull_request]

jobs:
  biome:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: 20
      - run: npm ci
      - run: npx @biomejs/biome ci .`;

const migrationExample = `# Remove Prettier and ESLint
npm remove prettier eslint eslint-config-* eslint-plugin-* @typescript-eslint/*

# Remove config files
rm .eslintrc.* .eslintignore .prettierrc .prettierignore

# Install Biome
npm add -D @biomejs/biome
npx @biomejs/biome init

# Migrate your ESLint rules — Biome has a migration command
npx @biomejs/biome migrate eslint --write

# Run the formatter to match Biome's style
npx @biomejs/biome format --write .`;

const vscodeExample = `// .vscode/settings.json — configure Biome as default formatter
{
  "editor.defaultFormatter": "biomejs.biome",
  "editor.formatOnSave": true,
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  }
}`;

const faq = [
  {
    question: "What is Biome?",
    answer: "Biome is a unified toolchain for JavaScript and TypeScript that combines a linter, formatter, and import organizer in a single fast tool. It is written in Rust, requires zero dependencies, and replaces both Prettier (for formatting) and ESLint (for linting) with a single binary and a single config file (biome.json). It is the direct successor to the Rome project, which was forked and rebranded as Biome in 2023."
  },
  {
    question: "How does Biome differ from using Prettier and ESLint together?",
    answer: "Prettier and ESLint are two separate tools with separate config files, separate dependencies, and separate CI steps. They can conflict with each other (especially around formatting rules) and require eslint-config-prettier to disable ESLint rules that overlap. Biome replaces both with a single tool, single config file, zero npm dependencies, and dramatically faster execution thanks to Rust. The tradeoff is that Biome does not support ESLint plugins (only its own 200+ built-in rules)."
  },
  {
    question: "Is Biome compatible with ESLint rules?",
    answer: "Biome ships its own implementation of over 200 lint rules, many of which correspond to popular ESLint rules (including some from eslint-plugin-react, eslint-plugin-typescript, and others). It is not plugin-compatible with ESLint — you cannot install an eslint-plugin-* and have it work in Biome. However, Biome provides a migration command (biome migrate eslint) that reads your ESLint config and enables the equivalent Biome rules automatically."
  },
  {
    question: "How do I migrate from Prettier to Biome?",
    answer: "Run npx @biomejs/biome init to create a biome.json, then run npx @biomejs/biome format --write . to reformat all files with Biome's formatter. Biome's formatting is designed to be highly compatible with Prettier's output (same line width defaults, similar quote handling) so the diff should be small. After verifying the output, remove Prettier and its config files. Update your VS Code settings to use the Biome extension as the default formatter."
  },
  {
    question: "What is biome.json?",
    answer: "biome.json is Biome's single configuration file. It controls the formatter (indent style, line width, quote style, trailing commas), linter (which rule categories and specific rules to enable), import organizer, and language-specific overrides. Unlike ESLint's config which can be complex and hierarchical, biome.json is flat and JSON-typed with a published JSON schema for IDE auto-completion."
  },
  {
    question: "Is Biome production-ready?",
    answer: "Yes. Biome reached v1.0 in 2023 and is in active production use at large companies. It is maintained by a team of contributors and follows semantic versioning. The formatter is considered stable and Prettier-compatible. The linter is stable with 200+ rules. The import organizer is stable. Biome is a safe choice for new projects and a well-supported migration target for projects currently using Prettier and ESLint."
  },
];
---

<BaseLayout
  title="Biome — Unified Linter and Formatter for JavaScript and TypeScript"
  description="Biome is a Rust-based unified toolchain that replaces both Prettier and ESLint. One tool, one config file, zero dependencies, 200+ lint rules, and Prettier-compatible formatting at blazing speed."
  tool="biome, javascript linter, typescript linter, formatter, prettier alternative, eslint alternative, rome successor, rust toolchain, biomejs"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Biome — Unified Linter and Formatter for JavaScript and TypeScript",
    "url": "https://devplaybook.cc/tools/biome",
    "description": "Biome is a Rust-based unified toolchain replacing Prettier and ESLint with one tool, one config file, 200+ lint rules, and blazing-fast formatting.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Biome</h1>
  <p class="text-text-muted mb-6">
    A unified linter and formatter for JavaScript and TypeScript — written in Rust.
    Replaces both Prettier and ESLint with a single tool, a single config file,
    zero npm dependencies, and over 200 built-in lint rules.
    The direct successor to the Rome project.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Linter + Formatter in one</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Rust-based (blazing fast)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 200+ lint rules</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Prettier-compatible output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Single biome.json config</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Zero dependencies</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Biome?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Biome is an open-source, Rust-based toolchain for JavaScript, TypeScript, JSX, and JSON. It combines a <strong>formatter</strong> (replacing Prettier), a <strong>linter</strong> (replacing ESLint), and an <strong>import organizer</strong> into a single binary with zero npm dependencies. One <code class="bg-bg-card px-1 rounded text-xs">biome.json</code> file replaces <code class="bg-bg-card px-1 rounded text-xs">.eslintrc</code>, <code class="bg-bg-card px-1 rounded text-xs">.prettierrc</code>, and all the associated config overhead.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    Biome is the direct continuation of the <strong>Rome project</strong>, which was forked and rebranded as Biome in late 2023 after the original Rome organization went inactive. It reached v1.0 in 2023 and is in active production use. The official website is <a href="https://biomejs.dev/" class="underline hover:text-text" target="_blank" rel="noopener">biomejs.dev</a>.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Unified tool</strong> — linting, formatting, and import organizing in one binary; no more Prettier vs ESLint conflicts</li>
    <li><strong>Rust performance</strong> — formats and lints large codebases in milliseconds; much faster than Node.js-based tools</li>
    <li><strong>200+ lint rules</strong> — covers correctness, style, performance, accessibility, and security categories out of the box</li>
    <li><strong>Prettier-compatible formatting</strong> — same default line width (80), similar quote handling; migration diff is minimal</li>
    <li><strong>Single config file</strong> — <code class="bg-bg-card px-1 rounded text-xs">biome.json</code> with a published JSON schema for IDE auto-completion</li>
    <li><strong>Zero dependencies</strong> — no transitive npm package risks; one dependency entry in package.json</li>
    <li><strong>LSP support</strong> — full Language Server Protocol implementation for VS Code, Neovim, and other editors</li>
    <li><strong>ESLint migration command</strong> — <code class="bg-bg-card px-1 rounded text-xs">biome migrate eslint</code> reads your ESLint config and enables equivalent Biome rules</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Installation</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={installExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Configuration (biome.json)</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Running <code class="bg-bg-card px-1 rounded text-xs">biome init</code> generates a <code class="bg-bg-card px-1 rounded text-xs">biome.json</code> with sensible defaults. Customize indent style, line width, quote style, and which lint rule categories to enable.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={configExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Migrating from Prettier and ESLint</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Migration is straightforward. Biome provides a built-in <code class="bg-bg-card px-1 rounded text-xs">migrate</code> command that reads your existing ESLint config and maps rules to Biome equivalents automatically.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={migrationExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">VS Code Integration</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Install the <strong>Biome VS Code extension</strong> (<code class="bg-bg-card px-1 rounded text-xs">biomejs.biome</code>) and configure it as the default formatter. Disable the Prettier extension for the workspace to avoid conflicts.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={vscodeExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">GitHub Actions CI Integration</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Use <code class="bg-bg-card px-1 rounded text-xs">biome ci</code> (not <code class="bg-bg-card px-1 rounded text-xs">biome check</code>) in CI — it is identical to check but never writes files and exits with a non-zero code on any issue.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={ciExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Biome vs Prettier + ESLint</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">Biome</th>
          <th class="border border-border px-3 py-2 text-left">Prettier + ESLint</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2">Number of tools</td><td class="border border-border px-3 py-2 text-green-400">1 (unified)</td><td class="border border-border px-3 py-2">2+ (separate)</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Config files</td><td class="border border-border px-3 py-2 text-green-400">1 (biome.json)</td><td class="border border-border px-3 py-2">.eslintrc + .prettierrc + ignore files</td></tr>
        <tr><td class="border border-border px-3 py-2">npm dependencies</td><td class="border border-border px-3 py-2 text-green-400">1 (@biomejs/biome)</td><td class="border border-border px-3 py-2">10–50+ (plugins, configs, compat)</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Performance</td><td class="border border-border px-3 py-2 text-green-400">Rust — extremely fast</td><td class="border border-border px-3 py-2">Node.js — slower</td></tr>
        <tr><td class="border border-border px-3 py-2">Plugin ecosystem</td><td class="border border-border px-3 py-2">Limited (built-in rules only)</td><td class="border border-border px-3 py-2 text-green-400">Thousands of plugins</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Rule–format conflicts</td><td class="border border-border px-3 py-2 text-green-400">None (single tool)</td><td class="border border-border px-3 py-2">Common (requires eslint-config-prettier)</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pros and Cons</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-green-400 mb-2">Pros</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✓ One tool replaces both Prettier and ESLint completely</li>
        <li>✓ Zero npm dependencies — no plugin supply chain risks</li>
        <li>✓ Rust speed makes it near-instant even on large codebases</li>
        <li>✓ No formatting vs linting rule conflicts by design</li>
        <li>✓ Built-in ESLint migration command simplifies adoption</li>
        <li>✓ 200+ rules covering correctness, accessibility, and performance</li>
      </ul>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-red-400 mb-2">Cons</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✗ No support for ESLint plugins (no eslint-plugin-* packages)</li>
        <li>✗ Opinionated formatting — less configurable than Prettier</li>
        <li>✗ Smaller community than ESLint/Prettier's established ecosystems</li>
        <li>✗ Some niche ESLint rules have no Biome equivalent yet</li>
        <li>✗ TypeScript type-aware lint rules (requiring type info) are limited</li>
      </ul>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="biome" relatedTags={['linting', 'formatting', 'javascript', 'typescript', 'rust', 'ci-cd']} />
</BaseLayout>
