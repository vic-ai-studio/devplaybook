---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is TOML and how is it different from YAML?", answer: "TOML (Tom's Obvious Minimal Language) is a config file format designed to be easy to read and map unambiguously to a hash table. Unlike YAML, TOML has explicit types, no indentation-sensitive syntax, and avoids YAML's notorious edge cases (like the Norway problem where 'NO' parses as false). TOML is popular in Rust (Cargo.toml), Python (pyproject.toml), and Hugo configurations." },
  { question: "When should I use TOML instead of YAML?", answer: "Use TOML when you want a config format that's explicit and hard to misread. TOML's type system is strict — strings are always quoted, booleans are always true/false, dates have a dedicated type. YAML is more flexible and supports complex structures like anchors/aliases, but its indentation-based syntax can cause subtle bugs. TOML is preferred for package configs (Cargo.toml, pyproject.toml) while YAML dominates CI/CD (GitHub Actions, Kubernetes)." },
  { question: "Does TOML support nested objects like YAML mappings?", answer: "Yes. YAML mappings become TOML tables (sections in square brackets). Nested YAML mappings become TOML dotted keys or nested tables ([section.subsection]). YAML sequences of objects become TOML arrays of tables ([[array]])." },
  { question: "What YAML features are not supported in TOML?", answer: "TOML does not support YAML anchors (&anchor, *alias), custom tags (!!type), multi-document streams (---), or block scalars (| and >). Complex YAML merge keys (<<: *base) also have no TOML equivalent. This converter handles common single-document YAML configs but may not cover advanced YAML features." },
  { question: "How does this YAML to TOML converter work?", answer: "This tool parses YAML entirely in your browser using a built-in parser — no server calls are made. It converts scalars (strings, numbers, booleans, nulls), nested mappings to TOML tables, and sequences to TOML arrays. The output follows TOML v1.0 spec syntax." },
];
---

<BaseLayout
  title="YAML to TOML Converter — Convert YAML Config to TOML Online Free"
  description="Convert YAML to TOML online. Handles nested objects, arrays, strings, numbers, booleans. Free, runs in your browser, no signup required. Supports Cargo.toml, pyproject.toml formats."
  tool="YAML to TOML converter, YAML TOML online, convert YAML config to TOML, pyproject.toml converter, Cargo.toml converter"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "YAML to TOML Converter",
    "url": "https://devplaybook.cc/tools/yaml-to-toml",
    "description": "Convert YAML configuration files to TOML format online. Handles nested objects, arrays, and all common YAML scalar types.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">YAML to TOML Converter</h1>
  <p class="text-text-muted mb-4">
    Paste YAML and get clean TOML output. Handles nested objects, arrays, strings, numbers, and booleans.
    Useful for migrating configs to Rust (Cargo.toml) or Python (pyproject.toml) projects.
    Runs entirely in your browser — nothing is sent to a server.
  </p>
  <div class="flex items-center gap-3 mb-8 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Nested objects → TOML tables</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Arrays of objects → [[arrays]]</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Type-safe scalar conversion</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <!-- Converter -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
    <!-- Input -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <label class="font-semibold text-sm" for="yaml-input">YAML Input</label>
        <button id="yaml-example" class="text-xs text-primary hover:underline">Load example</button>
      </div>
      <textarea id="yaml-input" rows="18"
        placeholder="name: my-project&#10;version: 1.0.0&#10;dependencies:&#10;  - tokio&#10;  - serde&#10;build:&#10;  release: true&#10;  target: x86_64"
        class="w-full bg-bg border border-border rounded-lg px-3 py-3 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40 resize-y"></textarea>
    </div>
    <!-- Output -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <span class="font-semibold text-sm">TOML Output</span>
        <button id="yaml-copy" class="text-xs text-primary hover:underline hidden">Copy</button>
      </div>
      <div id="yaml-error" class="hidden mb-3 p-3 bg-red-500/10 border border-red-500/20 rounded-lg text-sm text-red-400"></div>
      <textarea id="toml-output" rows="18" readonly
        placeholder="TOML output will appear here..."
        class="w-full bg-bg border border-border rounded-lg px-3 py-3 text-sm font-mono resize-y text-text-muted focus:outline-none"></textarea>
    </div>
  </div>

  <div class="flex gap-3 mb-8">
    <button id="yaml-convert" class="bg-primary text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-primary/80 transition-colors">
      Convert to TOML
    </button>
    <button id="yaml-clear" class="text-sm text-text-muted hover:text-red-400 transition-colors">Clear</button>
  </div>

  <!-- Comparison table -->
  <div class="bg-bg-card border border-border rounded-xl p-6 mb-8">
    <h2 class="font-bold text-sm uppercase tracking-wide text-text-muted mb-4">YAML vs TOML Quick Reference</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border">
            <th class="text-left py-2 pr-4 text-text-muted font-medium">Concept</th>
            <th class="text-left py-2 pr-4 text-text-muted font-medium">YAML</th>
            <th class="text-left py-2 text-text-muted font-medium">TOML</th>
          </tr>
        </thead>
        <tbody class="font-mono text-xs text-text-muted">
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-sans text-text">String</td><td class="pr-4">name: hello</td><td>name = "hello"</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-sans text-text">Integer</td><td class="pr-4">count: 42</td><td>count = 42</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-sans text-text">Boolean</td><td class="pr-4">debug: true</td><td>debug = true</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-sans text-text">Array</td><td class="pr-4">tags: [a, b]</td><td>tags = ["a", "b"]</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-sans text-text">Nested object</td><td class="pr-4">db:<br>&nbsp;&nbsp;host: localhost</td><td>[db]<br>host = "localhost"</td></tr>
          <tr><td class="py-2 pr-4 font-sans text-text">Array of objects</td><td class="pr-4">- name: a<br>&nbsp;&nbsp;val: 1</td><td>[[section]]<br>name = "a"<br>val = 1</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <AffiliateSection />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="YAML to TOML Converter" relatedTags={['yaml', 'toml', 'config', 'converter', 'devops']} />
</BaseLayout>

<script is:inline>
(function () {
  // ── Minimal YAML parser ──────────────────────────────────────────────────────
  function parseYamlValue(raw) {
    var s = raw.trim();
    if (s === '' || s === 'null' || s === '~') return null;
    if (s === 'true' || s === 'yes' || s === 'on') return true;
    if (s === 'false' || s === 'no' || s === 'off') return false;
    if (/^-?\d+$/.test(s) && !s.startsWith('0')) return parseInt(s, 10);
    if (/^-?\d+\.\d+$/.test(s)) return parseFloat(s);
    if ((s.startsWith('"') && s.endsWith('"')) || (s.startsWith("'") && s.endsWith("'")))
      return s.slice(1, -1).replace(/\\n/g, '\n').replace(/\\t/g, '\t');
    return s.replace(/ #.*$/, '').trim();
  }

  function tokenize(raw) {
    var lines = raw.split('\n');
    var tokens = [];
    for (var i = 0; i < lines.length; i++) {
      var line = lines[i];
      if (/^\s*#/.test(line) || line.trim() === '' || line.trim() === '---') continue;
      var indent = line.length - line.trimStart().length;
      var content = line.trimStart().replace(/ #.*$/, '').trim();
      var listItem = content.startsWith('- ') || content === '-';
      if (listItem) content = content.slice(2).trim();
      var colonIdx = content.indexOf(':');
      var key = null, value = null;
      if (colonIdx !== -1) {
        key = content.substring(0, colonIdx).trim();
        value = content.substring(colonIdx + 1).trim() || null;
      } else if (!listItem) {
        value = content;
      }
      tokens.push({ indent: indent, key: key, value: value, listItem: listItem });
    }
    return tokens;
  }

  function buildTree(tokens, startIdx, baseIndent) {
    var result = null;
    var i = startIdx;
    // detect if this level is an array or object
    if (i < tokens.length && tokens[i].listItem) {
      result = [];
      while (i < tokens.length && tokens[i].indent >= baseIndent && tokens[i].listItem) {
        var t = tokens[i];
        if (t.value !== null) {
          result.push(parseYamlValue(t.value));
          i++;
        } else {
          // nested object for this list item
          var child = {};
          i++;
          while (i < tokens.length && tokens[i].indent > baseIndent && !tokens[i].listItem) {
            if (tokens[i].key) {
              if (tokens[i].value !== null) {
                child[tokens[i].key] = parseYamlValue(tokens[i].value);
                i++;
              } else {
                var sub = buildTree(tokens, i + 1, tokens[i].indent + 2);
                child[tokens[i].key] = sub.tree;
                i = sub.nextIdx;
              }
            } else { i++; }
          }
          result.push(child);
        }
      }
      return { tree: result, nextIdx: i };
    }
    // object
    result = {};
    while (i < tokens.length && tokens[i].indent >= baseIndent && !tokens[i].listItem) {
      var tk = tokens[i];
      if (!tk.key) { i++; continue; }
      if (i + 1 < tokens.length && tokens[i + 1].indent > baseIndent && tokens[i + 1].listItem) {
        var arrRes = buildTree(tokens, i + 1, tokens[i + 1].indent);
        result[tk.key] = arrRes.tree;
        i = arrRes.nextIdx;
      } else if (tk.value !== null) {
        result[tk.key] = parseYamlValue(tk.value);
        i++;
      } else if (i + 1 < tokens.length && tokens[i + 1].indent > baseIndent) {
        var objRes = buildTree(tokens, i + 1, tokens[i + 1].indent);
        result[tk.key] = objRes.tree;
        i = objRes.nextIdx;
      } else {
        result[tk.key] = null;
        i++;
      }
    }
    return { tree: result, nextIdx: i };
  }

  function parseYaml(raw) {
    var tokens = tokenize(raw);
    if (!tokens.length) return {};
    var res = buildTree(tokens, 0, 0);
    return res.tree;
  }

  // ── TOML serializer ──────────────────────────────────────────────────────────
  function toTomlValue(v) {
    if (v === null) return '"null"';
    if (typeof v === 'boolean') return v ? 'true' : 'false';
    if (typeof v === 'number') return String(v);
    if (typeof v === 'string') return '"' + v.replace(/\\/g, '\\\\').replace(/"/g, '\\"').replace(/\n/g, '\\n').replace(/\t/g, '\\t') + '"';
    if (Array.isArray(v)) {
      var allScalar = v.every(function(x) { return typeof x !== 'object' || x === null; });
      if (allScalar) return '[' + v.map(toTomlValue).join(', ') + ']';
      return null; // handled as [[table-array]]
    }
    return null; // handled as [table]
  }

  function serializeToml(obj, prefix) {
    var lines = [];
    var tables = [];

    Object.keys(obj).forEach(function(key) {
      var v = obj[key];
      var fullKey = prefix ? prefix + '.' + key : key;

      if (v === null || typeof v !== 'object') {
        lines.push(key + ' = ' + toTomlValue(v));
      } else if (Array.isArray(v)) {
        var allScalar = v.every(function(x) { return typeof x !== 'object' || x === null; });
        if (allScalar) {
          lines.push(key + ' = ' + toTomlValue(v));
        } else {
          // array of tables
          v.forEach(function(item) {
            tables.push('');
            tables.push('[[' + fullKey + ']]');
            if (item && typeof item === 'object' && !Array.isArray(item)) {
              var inner = serializeToml(item, '');
              inner.split('\n').forEach(function(l) { if (l) tables.push(l); });
            }
          });
        }
      } else {
        // nested object
        tables.push('');
        tables.push('[' + fullKey + ']');
        var inner = serializeToml(v, fullKey);
        inner.split('\n').forEach(function(l) { if (l) tables.push(l); });
      }
    });

    return lines.concat(tables).join('\n');
  }

  // ── Example YAML ─────────────────────────────────────────────────────────────
  var EXAMPLE = [
    'name: my-app',
    'version: "0.1.0"',
    'edition: "2021"',
    '',
    'build:',
    '  release: true',
    '  target: x86_64-unknown-linux-gnu',
    '',
    'features:',
    '  - logging',
    '  - metrics',
    '  - tracing',
    '',
    'database:',
    '  host: localhost',
    '  port: 5432',
    '  name: mydb',
    '  pool_size: 10',
    '',
    'dependencies:',
    '  - name: tokio',
    '    version: "1.0"',
    '  - name: serde',
    '    version: "1.0"',
  ].join('\n');

  document.getElementById('yaml-example').addEventListener('click', function() {
    document.getElementById('yaml-input').value = EXAMPLE;
  });

  document.getElementById('yaml-clear').addEventListener('click', function() {
    document.getElementById('yaml-input').value = '';
    document.getElementById('toml-output').value = '';
    document.getElementById('yaml-error').classList.add('hidden');
    document.getElementById('yaml-copy').classList.add('hidden');
  });

  document.getElementById('yaml-convert').addEventListener('click', function() {
    var raw = document.getElementById('yaml-input').value.trim();
    var errEl = document.getElementById('yaml-error');
    var outEl = document.getElementById('toml-output');
    var copyBtn = document.getElementById('yaml-copy');

    errEl.classList.add('hidden');
    outEl.value = '';
    copyBtn.classList.add('hidden');

    if (!raw) { errEl.textContent = 'Please paste some YAML input first.'; errEl.classList.remove('hidden'); return; }

    try {
      var parsed = parseYaml(raw);
      if (!parsed || typeof parsed !== 'object') throw new Error('YAML must be a mapping at the top level.');
      var toml = serializeToml(parsed, '');
      outEl.value = toml.trim();
      copyBtn.classList.remove('hidden');
    } catch (e) {
      errEl.textContent = 'Parse error: ' + (e.message || String(e));
      errEl.classList.remove('hidden');
    }
  });

  document.getElementById('yaml-copy').addEventListener('click', function() {
    var val = document.getElementById('toml-output').value;
    if (val) navigator.clipboard && navigator.clipboard.writeText(val);
    this.textContent = 'Copied!';
    var btn = this;
    setTimeout(function() { btn.textContent = 'Copy'; }, 2000);
  });
})();
</script>
