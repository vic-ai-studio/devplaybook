---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OAuthTokenInspector from '../../components/OAuthTokenInspector.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the difference between OAuth and JWT?", answer: "OAuth 2.0 is an authorization framework — a protocol for granting access. JWT (JSON Web Token) is a token format. OAuth tokens can be JWTs, but don't have to be. OIDC (OpenID Connect) extends OAuth 2.0 with identity and mandates JWT for ID tokens." },
  { question: "Is it safe to paste tokens into this tool?", answer: "Yes. This tool runs entirely in your browser — no token data is sent to any server. However, avoid pasting production tokens that grant real access to sensitive resources, as a general best practice." },
  { question: "What does 'exp' mean in a JWT?", answer: "exp (expiration time) is a Unix timestamp (seconds since 1970-01-01). The token must be rejected after this time. iat (issued at) is when the token was created. nbf (not before) is a timestamp before which the token must not be accepted." },
  { question: "What is the 'scope' claim?", answer: "The scope claim lists the permissions granted to the token. Common OIDC scopes include openid (required for OIDC), profile (name, picture), email, and application-specific scopes like read:users or write:orders." },
  { question: "Why does this tool show the signature as 'present' but not verify it?", answer: "Verifying a JWT signature requires the secret key (HMAC) or public key (RSA/EC). This client-side tool can decode the header and payload but cannot verify the cryptographic signature without the key. For production verification, use your backend or a library like jsonwebtoken (Node.js)." },
  { question: "What is the iss (issuer) claim?", answer: "The iss claim identifies who issued the token. For example, https://accounts.google.com for Google OAuth or https://your-auth0-domain.auth0.com for Auth0. Clients should validate that the issuer matches the expected value to prevent token substitution attacks." },
];
---

<BaseLayout
  title="OAuth Token Inspector — Decode JWT & OIDC Tokens"
  description="Free OAuth and JWT token inspector. Paste any OAuth 2.0, OIDC, or JWT token to decode header, payload, and claims — see expiry, issuer, scopes, and audience. Runs in your browser."
  tool="OAuth token inspector, JWT decoder, OIDC token inspector, JWT claims viewer, token expiry checker, JWT payload decoder"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">OAuth Token Inspector</h1>
  <p class="text-text-muted mb-4">Paste any OAuth 2.0, OIDC, or JWT token to instantly decode header and payload, inspect all claims, check expiry status, and view granted scopes — all locally in your browser, nothing sent to any server.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Highlights expired tokens</span>
  </div>
  <OAuthTokenInspector client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="OAuth Token Inspector" relatedTags={['auth', 'jwt', 'oauth', 'security', 'api', 'tokens']} />
</BaseLayout>
