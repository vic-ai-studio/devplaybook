---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "How do I check which React Native version my Expo SDK includes?",
    answer: "Each Expo SDK bundles a specific React Native version. Check the official compatibility table at docs.expo.dev/versions/latest/. Key mappings: Expo SDK 50 = React Native 0.73, SDK 51 = RN 0.74, SDK 52 = RN 0.76. You can also run 'npx expo install --check' in your project to verify all installed packages match the current SDK's compatible versions."
  },
  {
    question: "How do I check if a package is compatible with my Expo SDK?",
    answer: "Run 'npx expo-doctor' in your project — it checks all installed packages against the current Expo SDK's compatibility list and flags any mismatches. Alternatively, use 'npx expo install <package-name>' instead of 'npm install' — Expo's installer automatically resolves the compatible version for your SDK. The expo.fyi/package-incompatibility page lists known incompatible packages."
  },
  {
    question: "What is the difference between Expo managed workflow and bare workflow?",
    answer: "Managed workflow: Expo manages your native code entirely. You write JavaScript only, Expo handles iOS and Android builds, and you cannot add custom native modules outside of Expo's SDK. Bare workflow: You have full access to android/ and ios/ directories. You can add any native module, but you're responsible for native builds and Xcode/Android Studio configuration. Most teams start managed and eject to bare only when needed."
  },
  {
    question: "How do I upgrade Expo SDK?",
    answer: "Run 'npx expo install expo@latest' to update the Expo package, then 'npx expo install --fix' to update all Expo packages to compatible versions. Review the Expo SDK changelog at expo.dev/changelog for breaking changes. After upgrading, run 'npx expo-doctor' to verify all dependencies are compatible. If using EAS Build, trigger a new build to pick up the SDK update."
  },
  {
    question: "What is EAS Build and how does it relate to Expo SDK?",
    answer: "EAS (Expo Application Services) Build is Expo's cloud build service. It compiles your app's native code on Expo's servers, so you can build iOS apps without a Mac. EAS Build uses build profiles in eas.json to configure the build environment. The Expo SDK version in your project determines which React Native version EAS Build uses. EAS Build supports both managed and bare workflow projects."
  },
  {
    question: "Can I use packages not in the Expo SDK?",
    answer: "Yes. In managed workflow, you can use any JavaScript-only package freely. For packages with native code, the package must have an Expo config plugin or be included in Expo's pre-built native modules. In bare workflow, you can use any package with native code — you'll need to run 'pod install' for iOS and rebuild. The expo.dev/packages directory lists packages with known Expo compatibility status."
  }
];
---
<BaseLayout
  title="Expo SDK Compatibility Checker: Package & React Native Version Guide"
  description="Check Expo SDK compatibility with React Native versions and packages. Use expo-doctor to find mismatches, understand managed vs bare workflow, upgrade SDK safely, and configure EAS Build."
  tool="expo-sdk-compatibility-checker"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"Expo SDK Compatibility Checker: Package & React Native Version Guide","url":"https://devplaybook.cc/tools/expo-sdk-compatibility-checker","description":"Check Expo SDK compatibility, use expo-doctor to find package mismatches, and upgrade safely."})} />

  <h1 class="text-3xl font-bold mb-2">Expo SDK Compatibility Checker: Package & React Native Version Guide</h1>
  <p class="text-text-muted mb-6">Verify your Expo SDK version, check package compatibility with expo-doctor, understand managed vs bare workflow, and upgrade your Expo SDK safely with EAS Build.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> SDK version reference table</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> expo-doctor usage</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Managed vs bare workflow</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> EAS Build setup</span>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Expo SDK to React Native Version Map</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 font-semibold">Expo SDK</th>
          <th class="text-left py-2 pr-4 font-semibold">React Native</th>
          <th class="text-left py-2 pr-4 font-semibold">React</th>
          <th class="text-left py-2 font-semibold">Status</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <tr>
          <td class="py-2 pr-4">SDK 52</td>
          <td class="py-2 pr-4">0.76</td>
          <td class="py-2 pr-4">18.3</td>
          <td class="py-2 text-green-500">Latest</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">SDK 51</td>
          <td class="py-2 pr-4">0.74</td>
          <td class="py-2 pr-4">18.2</td>
          <td class="py-2 text-yellow-500">Supported</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">SDK 50</td>
          <td class="py-2 pr-4">0.73</td>
          <td class="py-2 pr-4">18.2</td>
          <td class="py-2 text-yellow-500">Supported</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">SDK 49</td>
          <td class="py-2 pr-4">0.72</td>
          <td class="py-2 pr-4">18.2</td>
          <td class="py-2 text-red-500">End of life</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">SDK 48</td>
          <td class="py-2 pr-4">0.71</td>
          <td class="py-2 pr-4">18.2</td>
          <td class="py-2 text-red-500">End of life</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Check Compatibility with expo-doctor</h2>
  <p class="mb-4">expo-doctor is the quickest way to find package version mismatches in your Expo project:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm"># Check your project for compatibility issues
npx expo-doctor

# Example output:
# ✓ Expo config is valid
# ✓ No issues found in package.json
# ✗ react-native-reanimated@3.3.0 is not compatible with SDK 52
#   Expected: ~3.16.2
#   Run: npx expo install react-native-reanimated to fix

# Fix all detected issues automatically
npx expo install --fix

# Check a specific package's compatible version
npx expo install react-native-reanimated --check</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Installing Packages with expo install</h2>
  <p class="mb-4">Always use <code>npx expo install</code> instead of <code>npm install</code> for packages that may have Expo SDK-specific versions:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm"># expo install resolves the compatible version automatically
npx expo install react-native-reanimated
npx expo install expo-camera expo-location

# For packages outside Expo's registry, npm install works fine
npm install lodash date-fns zod

# After installing native packages in bare workflow:
cd ios && pod install && cd ..
# Then rebuild:
npx expo run:ios
npx expo run:android</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Upgrading Expo SDK</h2>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm"># Step 1: Upgrade the Expo package
npx expo install expo@^52.0.0

# Step 2: Update all Expo packages to compatible versions
npx expo install --fix

# Step 3: Verify no remaining issues
npx expo-doctor

# Step 4: For bare workflow — update native files
# Check the Expo SDK changelog for required native changes:
# https://expo.dev/changelog

# Step 5: Rebuild
npx expo run:ios  # or use EAS Build
npx expo run:android</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">EAS Build Configuration</h2>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm">// eas.json — build profiles
&#123;
  "cli": &#123;
    "version": "&gt;=12.0.0"
  &#125;,
  "build": &#123;
    "development": &#123;
      "developmentClient": true,
      "distribution": "internal",
      "ios": &#123; "simulator": true &#125;
    &#125;,
    "preview": &#123;
      "distribution": "internal",
      "android": &#123; "buildType": "apk" &#125;
    &#125;,
    "production": &#123;
      "autoIncrement": true
    &#125;
  &#125;,
  "submit": &#123;
    "production": &#123;
      "ios": &#123; "appleId": "you@example.com" &#125;,
      "android": &#123; "serviceAccountKeyPath": "./service-account.json" &#125;
    &#125;
  &#125;
&#125;</code></pre>

  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm"># Build for production
eas build --platform all --profile production

# Build iOS only (no Mac required)
eas build --platform ios --profile production

# Submit to App Store and Play Store
eas submit --platform all</code></pre>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="expo-sdk-compatibility-checker" relatedTags={['expo', 'react-native', 'mobile', 'ios', 'android', 'eas']} />
</BaseLayout>
