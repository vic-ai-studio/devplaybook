---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is a CSS viewport unit (vw, vh)?",
    answer: "vw (viewport width) and vh (viewport height) are relative CSS units. 1vw = 1% of the viewport width, 1vh = 1% of the viewport height. On a 375px wide phone, 100vw = 375px and 50vw = 187.5px. These units are useful for full-screen layouts but have quirks — on mobile, 100vh includes the browser toolbar height, which iOS Safari addresses with svh/lvh/dvh units."
  },
  {
    question: "What are svh, lvh, and dvh?",
    answer: "These are new viewport units that account for mobile browser toolbars: svh (small viewport height) = height when all browser UI is visible (most conservative). lvh (large viewport height) = height when all browser UI is hidden. dvh (dynamic viewport height) = adjusts dynamically as the browser toolbar shows/hides. Use dvh for most mobile full-height layouts, svh for the safest minimum."
  },
  {
    question: "What is the CSS device-pixel-ratio?",
    answer: "Device pixel ratio (DPR) is the ratio of physical pixels to CSS pixels. iPhone 15: DPR 3 (460×1000 physical, ~390×844 CSS). Most Android flagships: DPR 2-3. Standard desktop: DPR 1. In CSS, use @media (-webkit-device-pixel-ratio: 2) or @media (resolution: 2dppx) to target high-DPI screens. In JS, use window.devicePixelRatio."
  },
  {
    question: "What is the safe area inset for iOS?",
    answer: "iOS devices with notches/dynamic islands have safe area insets that your content should avoid. Use env(safe-area-inset-top/right/bottom/left) in CSS to add appropriate padding. Set the viewport meta tag to: content='width=device-width, initial-scale=1, viewport-fit=cover' to enable safe area support."
  },
  {
    question: "What viewport meta tag should I use?",
    answer: "The recommended viewport meta tag is: <meta name='viewport' content='width=device-width, initial-scale=1'>. This sets the viewport width to the device width and prevents the browser from zooming in on load. For PWAs that should not be user-scalable: add 'user-scalable=no', though this hurts accessibility. Never omit the viewport meta tag on mobile-targeted sites."
  }
];
---

<BaseLayout
  title="Mobile Viewport Simulator — Device Dimensions & CSS Viewport Calculator"
  description="Simulate mobile viewport dimensions and breakpoints. Calculate CSS viewport units, device pixel ratios, and safe area insets for iOS and Android devices. Free browser tool."
  tool="mobile viewport simulator, viewport calculator, CSS viewport units, device pixel ratio, mobile breakpoints, vw vh calculator, svh dvh units"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Mobile Viewport Simulator",
    "url": "https://devplaybook.cc/tools/mobile-viewport-simulator",
    "description": "Simulate mobile viewport dimensions and breakpoints. Calculate CSS viewport units, device pixel ratios, and safe area insets.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Mobile Viewport Simulator</h1>
  <p class="text-text-muted mb-4">Explore device viewport dimensions, CSS unit calculations, and breakpoints for iOS and Android devices.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 20+ real devices</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CSS unit calculator</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> vw/vh/svh/dvh/rem</span>
  </div>

  <!-- Device picker -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-semibold mb-3">Select Device</h2>
    <div class="flex gap-2 mb-3 flex-wrap">
      <button data-category="all" class="cat-btn px-3 py-1.5 rounded-lg text-xs font-medium bg-primary text-white transition-colors">All</button>
      <button data-category="iphone" class="cat-btn px-3 py-1.5 rounded-lg text-xs font-medium bg-surface border border-border hover:bg-bg-card transition-colors">iPhone</button>
      <button data-category="ipad" class="cat-btn px-3 py-1.5 rounded-lg text-xs font-medium bg-surface border border-border hover:bg-bg-card transition-colors">iPad</button>
      <button data-category="android" class="cat-btn px-3 py-1.5 rounded-lg text-xs font-medium bg-surface border border-border hover:bg-bg-card transition-colors">Android</button>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2" id="device-grid"></div>
  </div>

  <!-- Device info + calculator -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <h2 class="text-sm font-semibold mb-3" id="device-name">iPhone 15 Pro</h2>
      <div class="space-y-2" id="device-stats"></div>

      <!-- Orientation toggle -->
      <div class="flex gap-2 mt-4">
        <button id="btn-portrait" class="flex-1 py-1.5 bg-primary text-white rounded-lg text-xs font-medium transition-colors">Portrait</button>
        <button id="btn-landscape" class="flex-1 py-1.5 bg-surface border border-border rounded-lg text-xs font-medium hover:bg-bg-card transition-colors">Landscape</button>
      </div>
    </div>

    <!-- Unit calculator -->
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <h2 class="text-sm font-semibold mb-3">CSS Unit Calculator</h2>
      <div class="space-y-2 mb-3">
        <div>
          <label class="block text-xs text-text-muted mb-1">Value</label>
          <div class="flex gap-2">
            <input id="calc-value" type="number" value="50" class="flex-1 bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
            <select id="calc-unit" class="bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="vw">vw</option>
              <option value="vh">vh</option>
              <option value="px">px</option>
              <option value="rem">rem</option>
              <option value="em">em</option>
            </select>
          </div>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">Base Font Size (rem)</label>
          <input id="calc-rem" type="number" value="16" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
      </div>
      <div class="space-y-1.5" id="calc-results"></div>
    </div>
  </div>

  <!-- Breakpoints -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-semibold mb-3">Common Breakpoints</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-xs">
        <thead>
          <tr class="text-left text-text-muted border-b border-border">
            <th class="py-2 pr-4 font-medium">Framework</th>
            <th class="py-2 pr-4 font-medium">xs</th>
            <th class="py-2 pr-4 font-medium">sm</th>
            <th class="py-2 pr-4 font-medium">md</th>
            <th class="py-2 pr-4 font-medium">lg</th>
            <th class="py-2 pr-4 font-medium">xl</th>
            <th class="py-2 font-medium">2xl</th>
          </tr>
        </thead>
        <tbody id="bp-table"></tbody>
      </table>
    </div>
    <div class="mt-3 text-xs font-medium">
      Current device width fits: <span id="bp-match" class="text-accent font-mono"></span>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Mobile Viewport Simulator" relatedTags={['mobile', 'css', 'responsive', 'ios', 'android']} />
</BaseLayout>

<script is:inline>
(function() {
  var DEVICES = [
    { name: 'iPhone 15 Pro', category: 'iphone', w: 393, h: 852, dpr: 3, safeTop: 59, safeBottom: 34 },
    { name: 'iPhone 15', category: 'iphone', w: 390, h: 844, dpr: 3, safeTop: 47, safeBottom: 34 },
    { name: 'iPhone 14', category: 'iphone', w: 390, h: 844, dpr: 3, safeTop: 47, safeBottom: 34 },
    { name: 'iPhone SE 3rd', category: 'iphone', w: 375, h: 667, dpr: 2, safeTop: 20, safeBottom: 0 },
    { name: 'iPhone 12 mini', category: 'iphone', w: 375, h: 812, dpr: 3, safeTop: 50, safeBottom: 34 },
    { name: 'iPad Pro 12.9"', category: 'ipad', w: 1024, h: 1366, dpr: 2, safeTop: 24, safeBottom: 20 },
    { name: 'iPad Pro 11"', category: 'ipad', w: 834, h: 1194, dpr: 2, safeTop: 24, safeBottom: 20 },
    { name: 'iPad Air', category: 'ipad', w: 820, h: 1180, dpr: 2, safeTop: 24, safeBottom: 20 },
    { name: 'iPad mini', category: 'ipad', w: 768, h: 1024, dpr: 2, safeTop: 20, safeBottom: 0 },
    { name: 'Samsung S24 Ultra', category: 'android', w: 412, h: 915, dpr: 3.5, safeTop: 0, safeBottom: 0 },
    { name: 'Samsung S24', category: 'android', w: 360, h: 780, dpr: 3, safeTop: 0, safeBottom: 0 },
    { name: 'Pixel 8 Pro', category: 'android', w: 412, h: 915, dpr: 3.5, safeTop: 0, safeBottom: 0 },
    { name: 'Pixel 8', category: 'android', w: 393, h: 851, dpr: 3, safeTop: 0, safeBottom: 0 },
    { name: 'OnePlus 12', category: 'android', w: 412, h: 919, dpr: 3, safeTop: 0, safeBottom: 0 },
    { name: 'Generic Mobile', category: 'android', w: 375, h: 667, dpr: 2, safeTop: 0, safeBottom: 0 },
    { name: 'Generic Tablet', category: 'android', w: 768, h: 1024, dpr: 2, safeTop: 0, safeBottom: 0 }
  ];

  var BREAKPOINTS = [
    { name: 'Tailwind', xs: '-', sm: '640', md: '768', lg: '1024', xl: '1280', xxl: '1536' },
    { name: 'Bootstrap', xs: '0', sm: '576', md: '768', lg: '992', xl: '1200', xxl: '1400' },
    { name: 'MUI', xs: '0', sm: '600', md: '900', lg: '1200', xl: '1536', xxl: '-' },
    { name: 'Chakra UI', xs: '0', sm: '480', md: '768', lg: '992', xl: '1280', xxl: '1536' }
  ];

  var current = DEVICES[0];
  var portrait = true;
  var currentCat = 'all';

  function vw() { return portrait ? current.w : current.h; }
  function vh() { return portrait ? current.h : current.w; }

  function renderDevice() {
    var w = vw(), h = vh();
    var stats = [
      { label: 'CSS Width', val: w + 'px' },
      { label: 'CSS Height', val: h + 'px' },
      { label: 'Physical Width', val: Math.round(w * current.dpr) + 'px' },
      { label: 'Physical Height', val: Math.round(h * current.dpr) + 'px' },
      { label: 'Device Pixel Ratio', val: current.dpr + 'x' },
      { label: 'Aspect Ratio', val: gcd_ratio(w, h) },
      { label: 'Safe Area Top', val: current.safeTop + 'px' },
      { label: 'Safe Area Bottom', val: current.safeBottom + 'px' }
    ];
    document.getElementById('device-name').textContent = current.name + (portrait ? '' : ' (Landscape)');
    document.getElementById('device-stats').innerHTML = stats.map(function(s) {
      return '<div class="flex justify-between items-center py-1 border-b border-border/50">' +
        '<span class="text-xs text-text-muted">' + s.label + '</span>' +
        '<span class="text-xs font-mono font-semibold">' + s.val + '</span>' +
        '</div>';
    }).join('');
    calcResults();
    renderBP();
  }

  function gcd_ratio(w, h) {
    function gcd(a, b) { return b === 0 ? a : gcd(b, a % b); }
    var g = gcd(w, h);
    return (w/g) + ':' + (h/g);
  }

  function calcResults() {
    var v = parseFloat(document.getElementById('calc-value').value) || 0;
    var unit = document.getElementById('calc-unit').value;
    var base = parseFloat(document.getElementById('calc-rem').value) || 16;
    var w = vw(), h = vh();

    var results = [];
    if (unit === 'vw') {
      results = [
        { label: 'in pixels (width)', val: (v/100*w).toFixed(2) + 'px' },
        { label: 'as % of height', val: (v/100*w/h*100).toFixed(2) + 'vh' },
        { label: 'in rem', val: (v/100*w/base).toFixed(2) + 'rem' }
      ];
    } else if (unit === 'vh') {
      results = [
        { label: 'in pixels (height)', val: (v/100*h).toFixed(2) + 'px' },
        { label: 'as % of width', val: (v/100*h/w*100).toFixed(2) + 'vw' },
        { label: 'in rem', val: (v/100*h/base).toFixed(2) + 'rem' }
      ];
    } else if (unit === 'px') {
      results = [
        { label: 'as vw', val: (v/w*100).toFixed(2) + 'vw' },
        { label: 'as vh', val: (v/h*100).toFixed(2) + 'vh' },
        { label: 'in rem', val: (v/base).toFixed(2) + 'rem' },
        { label: 'physical px', val: Math.round(v * current.dpr) + 'px (@' + current.dpr + 'x)' }
      ];
    } else if (unit === 'rem') {
      results = [
        { label: 'in pixels', val: (v*base).toFixed(2) + 'px' },
        { label: 'as vw', val: (v*base/w*100).toFixed(2) + 'vw' },
        { label: 'as vh', val: (v*base/h*100).toFixed(2) + 'vh' }
      ];
    } else if (unit === 'em') {
      results = [
        { label: 'in pixels (base ' + base + 'px)', val: (v*base).toFixed(2) + 'px' },
        { label: 'as rem', val: v + 'rem (if base same)' }
      ];
    }

    document.getElementById('calc-results').innerHTML = results.map(function(r) {
      return '<div class="flex justify-between items-center py-1 border-b border-border/50">' +
        '<span class="text-xs text-text-muted">' + r.label + '</span>' +
        '<span class="text-xs font-mono font-semibold text-accent">' + r.val + '</span>' +
        '</div>';
    }).join('');
  }

  function renderBP() {
    var w = vw();
    document.getElementById('bp-table').innerHTML = BREAKPOINTS.map(function(bp) {
      return '<tr class="border-b border-border/50">' +
        '<td class="py-1.5 pr-4 font-medium text-text-muted">' + bp.name + '</td>' +
        ['xs','sm','md','lg','xl','xxl'].map(function(k) {
          return '<td class="py-1.5 pr-4 font-mono">' + bp[k] + '</td>';
        }).join('') +
        '</tr>';
    }).join('');

    // determine match
    var twBps = { sm: 640, md: 768, lg: 1024, xl: 1280, '2xl': 1536 };
    var match = 'xs (< 640px)';
    if (w >= 1536) match = '2xl (>= 1536px)';
    else if (w >= 1280) match = 'xl (>= 1280px)';
    else if (w >= 1024) match = 'lg (>= 1024px)';
    else if (w >= 768) match = 'md (>= 768px)';
    else if (w >= 640) match = 'sm (>= 640px)';
    document.getElementById('bp-match').textContent = match + ' [Tailwind]';
  }

  function renderGrid() {
    var filtered = currentCat === 'all' ? DEVICES : DEVICES.filter(function(d) { return d.category === currentCat; });
    document.getElementById('device-grid').innerHTML = filtered.map(function(d, i) {
      var idx = DEVICES.indexOf(d);
      var active = d === current;
      return '<button data-device="' + idx + '" class="device-btn text-left p-2 rounded-lg text-xs border transition-colors ' +
        (active ? 'border-primary bg-primary/10 text-primary' : 'border-border bg-surface hover:bg-bg-card text-text-muted') + '">' +
        '<div class="font-medium">' + d.name + '</div>' +
        '<div class="font-mono mt-0.5 opacity-70">' + d.w + 'x' + d.h + '</div>' +
        '</button>';
    }).join('');

    document.querySelectorAll('.device-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        current = DEVICES[parseInt(btn.dataset.device)];
        renderGrid();
        renderDevice();
      });
    });
  }

  document.querySelectorAll('.cat-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      currentCat = btn.dataset.category;
      document.querySelectorAll('.cat-btn').forEach(function(b) {
        b.classList.remove('bg-primary', 'text-white');
        b.classList.add('bg-surface', 'border', 'border-border');
      });
      btn.classList.add('bg-primary', 'text-white');
      btn.classList.remove('bg-surface', 'border', 'border-border');
      renderGrid();
    });
  });

  document.getElementById('btn-portrait').addEventListener('click', function() {
    portrait = true;
    this.classList.add('bg-primary', 'text-white'); this.classList.remove('bg-surface', 'border', 'border-border');
    document.getElementById('btn-landscape').classList.remove('bg-primary', 'text-white');
    document.getElementById('btn-landscape').classList.add('bg-surface', 'border', 'border-border');
    renderDevice();
  });
  document.getElementById('btn-landscape').addEventListener('click', function() {
    portrait = false;
    this.classList.add('bg-primary', 'text-white'); this.classList.remove('bg-surface', 'border', 'border-border');
    document.getElementById('btn-portrait').classList.remove('bg-primary', 'text-white');
    document.getElementById('btn-portrait').classList.add('bg-surface', 'border', 'border-border');
    renderDevice();
  });

  ['calc-value','calc-unit','calc-rem'].forEach(function(id) {
    document.getElementById(id).addEventListener('input', calcResults);
    document.getElementById(id).addEventListener('change', calcResults);
  });

  renderGrid();
  renderDevice();
})();
</script>
