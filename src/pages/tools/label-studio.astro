---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Label Studio and what data types does it support?", answer: "Label Studio is an open-source data labeling platform that supports a wide range of data types: text (NER, classification, span labeling), images (bounding boxes, polygons, semantic segmentation, keypoints), audio (transcription, classification, speaker diarization), video (object tracking, temporal classification), time series, and HTML/conversational data. A single instance can label all these types with different labeling interfaces configured per project." },
  { question: "How does ML-assisted labeling work in Label Studio?", answer: "Label Studio's ML backend integration lets a trained model pre-annotate incoming data. You connect a prediction server (your own FastAPI endpoint or a Label Studio ML backend template) that receives task data and returns pre-filled annotations. Annotators then review and correct the predictions instead of labeling from scratch, reducing labeling time by 60-80% for tasks where your model has reasonable accuracy. The corrected labels feed back to retrain the model (active learning loop)." },
  { question: "What export formats does Label Studio support?", answer: "Label Studio exports to: JSON (native), COCO (object detection), YOLO (darknet format), Pascal VOC XML, CSV, TSV, CoNLL (NER), and custom templates via Python SDK exporters. For HuggingFace datasets, use the label-studio-sdk to export directly to the datasets format. For custom formats, write a converter using the label-studio-converter library." },
  { question: "Can Label Studio be self-hosted?", answer: "Yes, Label Studio is fully open-source (Apache 2.0) and runs as a Docker container or Python package. Self-host with docker run -it -p 8080:8080 heartexlabs/label-studio:latest. Data stays on your infrastructure — critical for medical, legal, or PII data. Label Studio Enterprise adds SSO, RBAC, advanced QA workflows, and cloud storage auto-sync, but the open-source version is fully functional for most teams." },
  { question: "How do I set up an NER (Named Entity Recognition) labeling project?", answer: "In Label Studio, create a project and select the NER template. The labeling config is XML-based: define Labels (entity types like PERSON, ORG, DATE) and bind them to a Text view. Annotators highlight text spans and tag them. Export as CoNLL or JSON for training spaCy, HuggingFace NER models, or custom models. Use pre-annotations from an existing NER model to speed up the process." },
  { question: "How does Label Studio handle annotation quality control?", answer: "Label Studio supports inter-annotator agreement (IAA) scoring, annotation review workflows (submit → review → accept/reject), and task overlap (assign the same task to multiple annotators and compute agreement). In Label Studio Enterprise, automated QA rules can flag low-confidence annotations. For open-source, use the Python SDK to compute Cohen's kappa or Krippendorff's alpha on exported annotations." },
];
---

<BaseLayout
  title="Label Studio: Data Labeling, Annotation & ML Integration Guide"
  description="Complete Label Studio guide: supported data types, labeling interfaces for NER/bounding box/classification, ML-assisted labeling with active learning, export formats (COCO/YOLO/JSON), and Label Studio vs Scale AI vs V7."
  tool="Label Studio, data labeling, annotation tool, ML training data, NER, bounding box, image annotation, active learning"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"Label Studio: Data Labeling, Annotation & ML Integration Guide","url":"https://devplaybook.cc/tools/label-studio","description":"Complete guide to Label Studio for open-source data labeling, ML-assisted annotation, and training data pipeline integration."})} />

  <h1 class="text-3xl font-bold mb-2">Label Studio: Data Labeling, Annotation &amp; ML Integration</h1>
  <p class="text-text-muted mb-6">Label Studio is the open-source data labeling platform that handles text, images, audio, and video in one tool. Build training datasets with ML-assisted pre-annotation, export to COCO/YOLO/CoNLL, and close the active learning loop — all self-hosted.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Text / image / audio / video</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> ML-assisted pre-annotation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> COCO / YOLO / CoNLL export</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Fully self-hostable (Apache 2.0)</span>
  </div>

  <ToolPageCta />

  <!-- Setup and project config -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-xl font-semibold mb-3">Setup &amp; Project Configuration</h2>
    <p class="text-sm text-text-muted mb-3">Run Label Studio locally or via Docker, then configure labeling projects with XML templates:</p>
    <pre class="bg-bg border border-border rounded-lg p-4 text-xs overflow-x-auto mb-3"><code># Install and run (local)
pip install label-studio
label-studio start         # opens http://localhost:8080

# Or Docker
docker run -it -p 8080:8080 \
  -v $(pwd)/mydata:/label-studio/data \
  -e LABEL_STUDIO_LOCAL_FILES_SERVING_ENABLED=true \
  heartexlabs/label-studio:latest

# Create a project via Python SDK
from label_studio_sdk import Client

ls = Client(url="http://localhost:8080", api_key="your-api-key")
project = ls.create_project(
    title="Product Image Classification",
    label_config="""
&lt;View&gt;
  &lt;Image name="image" value="$image"/&gt;
  &lt;Choices name="category" toName="image" choice="single"&gt;
    &lt;Choice value="Electronics"/&gt;
    &lt;Choice value="Clothing"/&gt;
    &lt;Choice value="Furniture"/&gt;
    &lt;Choice value="Food"/&gt;
  &lt;/Choices&gt;
&lt;/View&gt;
    """
)

# Import tasks (URLs or local files)
project.import_tasks([
    &#123;"image": "https://example.com/img1.jpg"&#125;,
    &#123;"image": "https://example.com/img2.jpg"&#125;,
])</code></pre>
  </div>

  <!-- NER config -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-xl font-semibold mb-3">NER &amp; Bounding Box Labeling Configs</h2>
    <p class="text-sm text-text-muted mb-3">Label Studio uses XML-based configs to define labeling interfaces for any task type:</p>
    <pre class="bg-bg border border-border rounded-lg p-4 text-xs overflow-x-auto mb-3"><code>&lt;!-- Named Entity Recognition (NER) config --&gt;
&lt;View&gt;
  &lt;Labels name="label" toName="text"&gt;
    &lt;Label value="PERSON" background="blue"/&gt;
    &lt;Label value="ORGANIZATION" background="green"/&gt;
    &lt;Label value="LOCATION" background="orange"/&gt;
    &lt;Label value="DATE" background="purple"/&gt;
    &lt;Label value="MONEY" background="red"/&gt;
  &lt;/Labels&gt;
  &lt;Text name="text" value="$text"/&gt;
&lt;/View&gt;

&lt;!-- Object Detection (bounding box) config --&gt;
&lt;View&gt;
  &lt;RectangleLabels name="label" toName="image"&gt;
    &lt;Label value="Car" background="#FF0000"/&gt;
    &lt;Label value="Person" background="#00FF00"/&gt;
    &lt;Label value="Bicycle" background="#0000FF"/&gt;
  &lt;/RectangleLabels&gt;
  &lt;Image name="image" value="$image" zoom="true" zoomControl="true"/&gt;
&lt;/View&gt;

&lt;!-- Polygon segmentation config --&gt;
&lt;View&gt;
  &lt;PolygonLabels name="label" toName="image" strokeWidth="3"&gt;
    &lt;Label value="Road" background="#808080"/&gt;
    &lt;Label value="Building" background="#A0522D"/&gt;
    &lt;Label value="Vegetation" background="#228B22"/&gt;
  &lt;/PolygonLabels&gt;
  &lt;Image name="image" value="$image"/&gt;
&lt;/View&gt;</code></pre>
  </div>

  <!-- ML backend -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-xl font-semibold mb-3">ML-Assisted Labeling with Active Learning</h2>
    <p class="text-sm text-text-muted mb-3">Connect a prediction server to pre-annotate tasks and close the active learning loop:</p>
    <pre class="bg-bg border border-border rounded-lg p-4 text-xs overflow-x-auto mb-3"><code"># label_studio_ml backend (FastAPI-based prediction server)
from label_studio_ml.model import LabelStudioMLBase

class NERPredictor(LabelStudioMLBase):
    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        import spacy
        self.nlp = spacy.load("en_core_web_lg")

    def predict(self, tasks, **kwargs):
        predictions = []
        for task in tasks:
            text = task["data"]["text"]
            doc = self.nlp(text)
            results = []
            for ent in doc.ents:
                results.append(&#123;
                    "from_name": "label",
                    "to_name": "text",
                    "type": "labels",
                    "value": &#123;
                        "start": ent.start_char,
                        "end": ent.end_char,
                        "text": ent.text,
                        "labels": [ent.label_],
                    &#125;,
                    "score": 0.9,
                &#125;)
            predictions.append(&#123;"result": results, "score": 0.9&#125;)
        return predictions

# Run: label-studio-ml start . --port 9090
# Connect in Label Studio: Settings → ML → Add ML Backend → http://localhost:9090</code></pre>
  </div>

  <!-- Comparison table -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-xl font-semibold mb-4">Label Studio vs Scale AI vs V7 vs CVAT</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm min-w-[620px]">
        <thead>
          <tr class="text-text-muted text-xs uppercase border-b border-border">
            <th class="text-left pb-2 pr-4">Feature</th>
            <th class="text-left pb-2 pr-4">Label Studio</th>
            <th class="text-left pb-2 pr-4">Scale AI</th>
            <th class="text-left pb-2 pr-4">V7 Darwin</th>
            <th class="text-left pb-2">CVAT</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border text-text-muted">
          <tr><td class="py-2 pr-4 font-medium text-text">Open-source</td><td class="py-2 pr-4 text-green-500">Yes (Apache 2.0)</td><td class="py-2 pr-4">No (SaaS)</td><td class="py-2 pr-4">No (SaaS)</td><td class="py-2 text-green-500">Yes (MIT)</td></tr>
          <tr><td class="py-2 pr-4 font-medium text-text">Data types</td><td class="py-2 pr-4 text-green-500">All (text/img/audio/video)</td><td class="py-2 pr-4">All + 3D LiDAR</td><td class="py-2 pr-4">Images/video</td><td class="py-2">Images/video</td></tr>
          <tr><td class="py-2 pr-4 font-medium text-text">ML-assisted labeling</td><td class="py-2 pr-4 text-green-500">ML backend API</td><td class="py-2 pr-4 text-green-500">Auto-annotation</td><td class="py-2 pr-4 text-green-500">Auto-annotate</td><td class="py-2">Semi-auto</td></tr>
          <tr><td class="py-2 pr-4 font-medium text-text">Human workforce</td><td class="py-2 pr-4">No (your team)</td><td class="py-2 pr-4 text-green-500">Scale workforce</td><td class="py-2 pr-4">Limited</td><td class="py-2">No</td></tr>
          <tr><td class="py-2 pr-4 font-medium text-text">Self-hostable</td><td class="py-2 pr-4 text-green-500">Yes (Docker)</td><td class="py-2 pr-4">No</td><td class="py-2 pr-4">Enterprise only</td><td class="py-2 text-green-500">Yes (Docker)</td></tr>
          <tr><td class="py-2 pr-4 font-medium text-text">Export formats</td><td class="py-2 pr-4 text-green-500">COCO/YOLO/CoNLL/VOC/JSON</td><td class="py-2 pr-4">JSON/CSV</td><td class="py-2 pr-4">COCO/Pascal VOC</td><td class="py-2">COCO/VOC/YOLO</td></tr>
          <tr><td class="py-2 pr-4 font-medium text-text">Best for</td><td class="py-2 pr-4">Self-hosted, multi-modal</td><td class="py-2 pr-4">Enterprise, large scale</td><td class="py-2 pr-4">CV teams, SaaS</td><td class="py-2">CV tasks, free</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <FaqSection faq={faq} />
</BaseLayout>
