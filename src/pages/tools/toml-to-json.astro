---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TomlToJsonConverter from '../../components/TomlToJsonConverter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is TOML and why convert it to JSON?", answer: "TOML (Tom's Obvious, Minimal Language) is a config file format used by Rust (Cargo.toml), Python (pyproject.toml), and Hugo. JSON is the standard for APIs and web services. Converting between them is a common task when bridging tooling ecosystems or reading config data programmatically." },
  { question: "Can I convert JSON back to TOML?", answer: "Yes. Click 'JSON → TOML' to switch direction. Paste your JSON object and get clean TOML output with proper sections for nested objects and correct value types." },
  { question: "What TOML features are supported?", answer: "The converter supports [section] headers (mapped to nested JSON objects), key = value pairs, strings (double and single quoted), integers, floats, booleans (true/false), and inline arrays. Multi-line strings and inline tables are not yet supported." },
  { question: "Is my data sent to any server?", answer: "No. All conversion runs entirely in your browser using JavaScript. Your TOML or JSON data never leaves your machine — safe for sensitive config files, API keys, and secrets." },
  { question: "What projects use TOML?", answer: "TOML is the standard config format for Rust (Cargo.toml), Python packaging (pyproject.toml), the Hugo static site generator, Gitea, and many modern CLI tools. If you work in Rust or Python, you likely encounter TOML daily." },
];
---

<BaseLayout
  title="TOML to JSON Converter — Free Online Tool | JSON to TOML"
  description="Convert TOML to JSON or JSON to TOML instantly. Supports sections, key-value pairs, arrays, booleans, and all scalar types. Free, runs 100% in your browser — no data sent to any server."
  tool="TOML to JSON, JSON to TOML converter, TOML parser online, Cargo.toml to JSON, pyproject.toml converter, convert TOML JSON"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">TOML ↔ JSON Converter</h1>
  <p class="text-text-muted mb-4">Convert TOML to JSON or JSON to TOML instantly. Supports <code class="bg-bg-secondary px-1 rounded text-sm">[sections]</code>, key-value pairs, strings, integers, floats, booleans, and arrays. Useful for Cargo.toml, pyproject.toml, and any TOML config file. Everything runs in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Bidirectional conversion</span>
  </div>
  <TomlToJsonConverter client:only="preact" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more free developer tools?</p>
    <a href="/tools" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Browse All Free Tools →</a>
  </div>
  <ToolPageCta currentTool="TOML to JSON Converter" relatedTags={['toml', 'json', 'converter', 'config', 'rust', 'python']} />
</BaseLayout>
