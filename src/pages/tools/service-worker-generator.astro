---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceWorkerGenerator from '../../components/ServiceWorkerGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a Service Worker?",
    answer: "A Service Worker is a JavaScript file that runs in the background, separate from the main browser thread. It acts as a proxy between your web app and the network, enabling offline support, background sync, push notifications, and fine-grained caching strategies. It's a core building block of Progressive Web Apps (PWAs)."
  },
  {
    question: "What is Cache First strategy?",
    answer: "Cache First checks the cache before going to the network. If the resource is cached, it serves it immediately without a network request. If not cached, it fetches from the network and caches the response. Best for static assets (JS, CSS, images) that rarely change — delivers fastest performance."
  },
  {
    question: "What is Network First strategy?",
    answer: "Network First always tries the network first and falls back to the cache if the network fails. Best for dynamic content like API responses, HTML pages, or anything that changes frequently. Ensures users always get the freshest content when online, with offline support as a fallback."
  },
  {
    question: "What is Stale While Revalidate?",
    answer: "Stale While Revalidate returns cached content immediately (fast) while simultaneously fetching a fresh version in the background to update the cache for the next request. The user gets an instant response and the content stays fresh. Best for resources that can tolerate being slightly out of date, like news feeds or user avatars."
  },
  {
    question: "Where should I place sw.js?",
    answer: "Place sw.js at the root of your site (e.g., /sw.js or /public/sw.js). The scope of a service worker is limited to its directory and all subdirectories — so a service worker at /sw.js can intercept requests for the whole site, but one at /app/sw.js can only intercept /app/* requests."
  },
  {
    question: "How do I update a deployed Service Worker?",
    answer: "Increment the CACHE_NAME version (e.g., v1 → v2). The browser detects the changed file, installs the new service worker in the background, and activates it when all old tabs are closed. The activate handler deletes old caches by comparing against the new CACHE_NAME. Use skipWaiting() + clients.claim() to force immediate takeover."
  },
];
---

<BaseLayout
  title="Service Worker Generator — Cache First, Network First, SWR"
  description="Generate a ready-to-use Service Worker (sw.js) for your PWA. Choose cache strategy — Cache First, Network First, or Stale While Revalidate. Configure URLs to cache and download sw.js."
  tool="Service Worker Generator, sw.js generator, PWA service worker, cache strategy, offline web app"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Service Worker Generator",
    "url": "https://devplaybook.cc/tools/service-worker-generator",
    "description": "Generate a ready-to-use service worker (sw.js) for your PWA. Choose from Cache First, Network First, or Stale While Revalidate strategies. Configure URLs to cache and download.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Service Worker Generator</h1>
  <p class="text-text-muted mb-4">
    Generate a production-ready <code class="font-mono bg-surface px-1 rounded text-sm">sw.js</code> for your Progressive Web App.
    Pick a caching strategy, configure URLs to pre-cache, and enable an optional offline fallback page.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 3 cache strategies</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Offline fallback support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auto cache versioning</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Download sw.js</span>
  </div>
  <ServiceWorkerGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Service Worker Generator" relatedTags={['pwa', 'frontend', 'performance', 'offline', 'web']} />
</BaseLayout>
