---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WebGLShaderPlayground from '../../components/WebGLShaderPlayground.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is GLSL and WebGL?",
    answer: "WebGL is a JavaScript API that renders interactive 2D and 3D graphics in the browser using the GPU, with no plugins. GLSL (OpenGL Shading Language) is the C-like language used to write shaders — programs that run directly on the GPU for every pixel. Fragment shaders run for each pixel and output a color (gl_FragColor). They're used for procedural graphics, post-processing effects, generative art, and game rendering."
  },
  {
    question: "What uniforms are available in this playground?",
    answer: "Three uniforms are automatically provided: u_time (float) is the seconds elapsed since the page loaded — use it to animate values over time. u_resolution (vec2) is the canvas width and height in pixels — divide gl_FragCoord.xy by u_resolution to get normalized UV coordinates (0 to 1). u_mouse (vec2) is the mouse position in pixels with (0,0) at the bottom-left — move your mouse over the canvas to interact."
  },
  {
    question: "How do I get UV coordinates (0 to 1) in a fragment shader?",
    answer: "gl_FragCoord.xy gives the current pixel position in pixels. Divide by u_resolution to normalize: vec2 uv = gl_FragCoord.xy / u_resolution; — this gives (0,0) at bottom-left and (1,1) at top-right. To center the origin ((-0.5 to 0.5) or similar for non-square canvases): vec2 uv = (gl_FragCoord.xy - u_resolution * 0.5) / u_resolution.y; This is the pattern used by Shadertoy and most shader examples."
  },
  {
    question: "Why does my shader look different from Shadertoy?",
    answer: "Shadertoy uses a slightly different coordinate system: iResolution, iTime, and iMouse instead of u_resolution, u_time, and u_mouse. Shadertoy's origin (0,0) is at the bottom-left matching WebGL's default. To port a Shadertoy shader: replace iResolution with u_resolution, iTime with u_time, iMouse.xy with u_mouse. Shadertoy also uses mainImage(out vec4 fragColor, in vec2 fragCoord) — replace this with void main() { ... gl_FragColor = ...; }."
  },
  {
    question: "What is 'precision mediump float' for?",
    answer: "This sets the floating-point precision for the fragment shader. mediump (medium precision) is required on mobile GPUs and some embedded systems where highp (high precision) isn't always available. For most visual effects, mediump is sufficient. If you need very precise calculations (e.g. large coordinate values, deep zoom), use highp. Always declare precision at the top of your fragment shader — it's required by the GLSL ES spec."
  },
  {
    question: "How do I add a texture to a WebGL shader?",
    answer: "To use an image texture, upload it as a WebGL texture: const texture = gl.createTexture(); gl.bindTexture(gl.TEXTURE_2D, texture); gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, gl.RGBA, gl.UNSIGNED_BYTE, image); gl.generateMipmap(gl.TEXTURE_2D); In your fragment shader, add: uniform sampler2D u_texture; then sample it with: vec4 color = texture2D(u_texture, uv); WebGL requires images to be served from the same origin (CORS) or loaded via a blob URL."
  },
];
---

<BaseLayout
  title="WebGL Shader Playground — Live GLSL Fragment Shader Editor"
  description="Live WebGL fragment shader editor with real-time canvas preview. Write GLSL shaders with u_time, u_resolution, and u_mouse uniforms. 4 starter templates: gradient, wave, noise, interactive circle. Runs in your browser."
  tool="webgl shader playground, glsl online editor, fragment shader editor, webgl glsl examples"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "WebGL Shader Playground",
    "url": "https://devplaybook.cc/tools/webgl-shader-playground",
    "description": "Live GLSL WebGL fragment shader editor with real-time preview. Write shaders with u_time, u_resolution, and u_mouse uniforms.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">WebGL Shader Playground</h1>
  <p class="text-text-muted mb-4">
    Write and preview <strong>GLSL fragment shaders</strong> live in your browser using WebGL.
    Access built-in uniforms for animation (<code class="font-mono bg-surface px-1 rounded text-sm">u_time</code>),
    canvas size (<code class="font-mono bg-surface px-1 rounded text-sm">u_resolution</code>),
    and mouse position (<code class="font-mono bg-surface px-1 rounded text-sm">u_mouse</code>).
    Includes 4 starter templates — gradient, wave, noise, and interactive circle.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Real-time WebGL preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> u_time + u_mouse + u_resolution</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 4 starter templates</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GLSL error highlighting</span>
  </div>
  <WebGLShaderPlayground client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="WebGL Shader Playground" relatedTags={['webgl', 'glsl', 'graphics', 'javascript', 'canvas', 'developer-tools']} />
</BaseLayout>
