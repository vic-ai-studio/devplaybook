---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CssFlexbox from '../../components/CssFlexbox.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is CSS Flexbox?", answer: "Flexbox (Flexible Box Layout) is a CSS layout model that makes it easy to align and distribute space among items in a container — even when their sizes are unknown. It's one-dimensional, meaning it works along a single axis (row or column) at a time. For two-dimensional layouts, consider CSS Grid." },
  { question: "What is the difference between justify-content and align-items?", answer: "justify-content controls alignment along the main axis (horizontal in row, vertical in column). align-items controls alignment along the cross axis (perpendicular to the main axis). For example, in a row layout: justify-content centers items left-to-right, while align-items centers items top-to-bottom." },
  { question: "When should I use flex-grow?", answer: "flex-grow controls how much a flex item expands to fill available space relative to siblings. A value of 1 means 'take equal share of remaining space'. A value of 2 means 'take twice as much as items with flex-grow: 1'. Items with flex-grow: 0 (default) won't expand beyond their natural size." },
  { question: "What does flex-wrap do?", answer: "By default (flex-wrap: nowrap), flex items are forced onto a single line, which can cause overflow. Setting flex-wrap: wrap allows items to flow onto multiple lines when they don't fit. wrap-reverse does the same but lines wrap in reverse order. Use wrap with responsive designs to prevent content overflow on small screens." },
  { question: "What is the shorthand for flex-grow, flex-shrink, and flex-basis?", answer: "The flex shorthand combines all three: flex: <grow> <shrink> <basis>. Common values: flex: 1 (equivalent to flex: 1 1 0%, takes equal share); flex: auto (equivalent to flex: 1 1 auto, grows/shrinks based on natural size); flex: none (equivalent to flex: 0 0 auto, inflexible)." },
  { question: "How do I center an element with Flexbox?", answer: "To center a child both horizontally and vertically in its parent: set display: flex; justify-content: center; align-items: center; on the parent container. This is one of the most common Flexbox patterns and works regardless of the child's size. No need to know the child's dimensions." },
];
---

<BaseLayout
  title="CSS Flexbox Playground — Visualize & Generate Flexbox CSS"
  description="Interactively build and preview CSS Flexbox layouts. Configure flex-direction, justify-content, align-items, and per-item properties. Copy the generated CSS instantly. Free, runs in your browser."
  tool="CSS Flexbox, Flexbox Generator, CSS Layout Tool, Flexbox Playground"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">CSS Flexbox Playground</h1>
  <p class="text-text-muted mb-4">Build Flexbox layouts visually. Tweak container and per-item properties, see the result live, then copy the generated CSS — no guesswork required.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live preview as you type</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <CssFlexbox client:only="preact" />
  <!-- Ad slot below tool output — highest CTR position (user pauses after using the tool) -->
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <AffiliateSection category="hosting" />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Need to build CSS Grid layouts too?</p>
    <a href="/tools/css-grid-generator" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">CSS Grid Generator →</a>
  </div>
  <ToolPageCta currentTool="CSS Flexbox Playground" relatedTags={['css', 'flexbox', 'layout', 'frontend', 'web']} />
</BaseLayout>
