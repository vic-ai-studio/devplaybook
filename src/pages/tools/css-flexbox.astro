---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CssFlexbox from '../../components/CssFlexbox.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---
<BaseLayout
  title="CSS Flexbox Visualizer"
  description="Interactively build and preview CSS Flexbox layouts. Configure container properties like flex-direction, justify-content, and align-items, then fine-tune individual item properties. Copy the generated CSS instantly."
  tool="CSS Flexbox, Flexbox Generator, CSS Layout Tool"
>
  <h1 class="text-3xl font-bold mb-2">CSS Flexbox Visualizer</h1>
  <p class="text-text-muted mb-8">Build Flexbox layouts visually. Tweak container and per-item properties, see the result live, then copy the generated CSS — no guesswork required.</p>
  <CssFlexbox client:only="preact" />
  <ToolPageCta currentTool="CSS Flexbox Visualizer" relatedTags={['css', 'flexbox', 'layout', 'frontend']} />
</BaseLayout>
