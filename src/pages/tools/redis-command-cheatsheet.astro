---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Redis and what is it used for?", answer: "Redis (Remote Dictionary Server) is an in-memory data structure store used as a database, cache, and message broker. Its key strengths are sub-millisecond read/write performance and rich data types: strings, lists, hashes, sets, sorted sets, streams, and more. Common use cases include session storage, rate limiting, pub/sub messaging, leaderboards (sorted sets), job queues (lists), and full-page caching." },
  { question: "What is the difference between KEYS and SCAN?", answer: "KEYS pattern returns all matching keys in one blocking call. In production with millions of keys, KEYS can block the Redis server for seconds, causing timeouts. SCAN is the safe alternative — it iterates the keyspace in small batches (cursor-based) without blocking. Always use SCAN in production. SCAN returns a cursor and a batch of keys; repeat until cursor returns 0." },
  { question: "What does O(1) vs O(N) mean for Redis commands?", answer: "O(1) means the command takes constant time regardless of data size — it is always fast. O(N) means the time scales linearly with N (number of elements). For example, LRANGE with a list of 1 million items is O(N) and can be slow. In Redis, O(N) commands on large data structures are a common source of latency spikes. Always check complexity before using commands like KEYS, SMEMBERS, or HGETALL on large data." },
  { question: "What is the difference between EXPIRE and TTL?", answer: "EXPIRE key seconds sets a timeout on a key — Redis will automatically delete it after that many seconds. TTL key returns the remaining time-to-live in seconds (-1 means no expiry, -2 means the key does not exist). PEXPIRE and PTTL are the millisecond equivalents. Use PERSIST to remove an expiry and make a key permanent again." },
];
---

<BaseLayout
  title="Redis Command Cheatsheet — Interactive Redis Commands Reference"
  description="Interactive Redis command reference with syntax, examples, and time complexity. Browse and search all Redis commands across Strings, Lists, Hashes, Sets, Sorted Sets, and Keys categories."
  tool="Redis command cheatsheet, Redis commands reference, Redis GET SET HSET ZADD, Redis time complexity, Redis tutorial"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Redis Command Cheatsheet",
    "url": "https://devplaybook.cc/tools/redis-command-cheatsheet",
    "description": "Interactive Redis command reference. Browse Strings, Lists, Hashes, Sets, Sorted Sets, and Keys commands with syntax, examples, and O() complexity.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Redis Command Cheatsheet</h1>
  <p class="text-text-muted mb-4">
    Interactive reference for Redis commands across all major data types.
    Each command shows syntax, description, a practical example, and time complexity.
    Search or filter by category to find the right command fast.
  </p>
  <div class="flex items-center gap-3 mb-8 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Strings, Lists, Hashes, Sets, Sorted Sets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Keys &amp; expiry commands</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> O() time complexity for each command</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Searchable &amp; filterable</span>
  </div>

  <!-- Search + Filter -->
  <div class="flex flex-wrap gap-3 mb-6">
    <input id="search-input" type="text" placeholder="Search commands..."
      class="flex-1 min-w-[200px] bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40" />
    <div id="category-filters" class="flex flex-wrap gap-2">
      <!-- Rendered by JS -->
    </div>
  </div>

  <div id="results-count" class="text-xs text-text-muted mb-4"></div>

  <!-- Commands grid -->
  <div id="commands-grid" class="flex flex-col gap-3 mb-8">
    <!-- Rendered by JS -->
  </div>

  <AffiliateSection />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Redis Command Cheatsheet" relatedTags={['redis', 'database', 'cache', 'backend', 'performance', 'devops']} />
</BaseLayout>

<script is:inline>
(function () {
  var COMMANDS = [
    // Strings
    { cat: 'Strings', name: 'SET', syntax: 'SET key value [EX seconds] [NX]', desc: 'Set the string value of a key. Use EX for TTL, NX to set only if not exists.', example: 'SET session:abc "user:42" EX 3600', complexity: 'O(1)' },
    { cat: 'Strings', name: 'GET', syntax: 'GET key', desc: 'Get the string value of a key. Returns nil if the key does not exist.', example: 'GET session:abc', complexity: 'O(1)' },
    { cat: 'Strings', name: 'MGET', syntax: 'MGET key [key ...]', desc: 'Get the values of multiple keys in one round trip. Returns nil for missing keys.', example: 'MGET user:1 user:2 user:3', complexity: 'O(N)' },
    { cat: 'Strings', name: 'MSET', syntax: 'MSET key value [key value ...]', desc: 'Set multiple key-value pairs atomically in one command.', example: 'MSET name "Alice" age "30" city "Taipei"', complexity: 'O(N)' },
    { cat: 'Strings', name: 'INCR', syntax: 'INCR key', desc: 'Increment the integer value of a key by 1. Creates the key at 0 if it does not exist.', example: 'INCR page:views', complexity: 'O(1)' },
    { cat: 'Strings', name: 'INCRBY', syntax: 'INCRBY key increment', desc: 'Increment the integer value of a key by a given amount.', example: 'INCRBY user:42:credits 100', complexity: 'O(1)' },
    { cat: 'Strings', name: 'EXPIRE', syntax: 'EXPIRE key seconds', desc: 'Set a timeout on a key. The key will be deleted after the specified seconds.', example: 'EXPIRE session:abc 1800', complexity: 'O(1)' },
    { cat: 'Strings', name: 'TTL', syntax: 'TTL key', desc: 'Get the remaining TTL of a key in seconds. Returns -1 (no expiry) or -2 (key missing).', example: 'TTL session:abc', complexity: 'O(1)' },
    { cat: 'Strings', name: 'SETNX', syntax: 'SETNX key value', desc: 'Set key only if it does NOT exist. Used as a simple mutex/lock primitive.', example: 'SETNX lock:resource "1"', complexity: 'O(1)' },
    { cat: 'Strings', name: 'GETSET', syntax: 'GETSET key value', desc: 'Atomically set a new value and return the old value. Useful for read-modify cycles.', example: 'GETSET last_run "2024-01-01T00:00:00Z"', complexity: 'O(1)' },
    // Lists
    { cat: 'Lists', name: 'LPUSH', syntax: 'LPUSH key value [value ...]', desc: 'Prepend one or more values to a list (left push). Creates the list if it does not exist.', example: 'LPUSH jobs "task:1" "task:2"', complexity: 'O(1)' },
    { cat: 'Lists', name: 'RPUSH', syntax: 'RPUSH key value [value ...]', desc: 'Append one or more values to a list (right push). Used for queue patterns.', example: 'RPUSH queue:email "msg:42"', complexity: 'O(1)' },
    { cat: 'Lists', name: 'LPOP', syntax: 'LPOP key [count]', desc: 'Remove and return the first element(s) from a list. Used in consumer queue patterns.', example: 'LPOP jobs', complexity: 'O(N) count' },
    { cat: 'Lists', name: 'RPOP', syntax: 'RPOP key [count]', desc: 'Remove and return the last element(s) from a list. Pairs with LPUSH for stack.', example: 'RPOP queue:email', complexity: 'O(N) count' },
    { cat: 'Lists', name: 'LRANGE', syntax: 'LRANGE key start stop', desc: 'Get a range of elements. Indices are 0-based; -1 means last element.', example: 'LRANGE jobs 0 -1', complexity: 'O(S+N)' },
    { cat: 'Lists', name: 'LLEN', syntax: 'LLEN key', desc: 'Get the length of a list.', example: 'LLEN queue:email', complexity: 'O(1)' },
    { cat: 'Lists', name: 'BLPOP', syntax: 'BLPOP key [key ...] timeout', desc: 'Blocking left pop. Waits up to timeout seconds for a value to be pushed.', example: 'BLPOP jobs 30', complexity: 'O(N) keys' },
    { cat: 'Lists', name: 'LINDEX', syntax: 'LINDEX key index', desc: 'Get the element at a specific index in the list.', example: 'LINDEX jobs 0', complexity: 'O(N)' },
    // Hashes
    { cat: 'Hashes', name: 'HSET', syntax: 'HSET key field value [field value ...]', desc: 'Set one or more fields on a hash. Overwrites existing fields.', example: 'HSET user:42 name "Alice" email "alice@example.com"', complexity: 'O(N) fields' },
    { cat: 'Hashes', name: 'HGET', syntax: 'HGET key field', desc: 'Get the value of a single hash field.', example: 'HGET user:42 email', complexity: 'O(1)' },
    { cat: 'Hashes', name: 'HMGET', syntax: 'HMGET key field [field ...]', desc: 'Get the values of multiple hash fields in one round trip.', example: 'HMGET user:42 name email age', complexity: 'O(N) fields' },
    { cat: 'Hashes', name: 'HGETALL', syntax: 'HGETALL key', desc: 'Get all fields and values of a hash. Avoid on large hashes — use HSCAN instead.', example: 'HGETALL user:42', complexity: 'O(N)' },
    { cat: 'Hashes', name: 'HDEL', syntax: 'HDEL key field [field ...]', desc: 'Delete one or more hash fields.', example: 'HDEL user:42 temp_token', complexity: 'O(N) fields' },
    { cat: 'Hashes', name: 'HEXISTS', syntax: 'HEXISTS key field', desc: 'Check if a field exists in a hash. Returns 1 if yes, 0 if no.', example: 'HEXISTS user:42 email', complexity: 'O(1)' },
    { cat: 'Hashes', name: 'HINCRBY', syntax: 'HINCRBY key field increment', desc: 'Increment a hash field by an integer. Creates the field at 0 if missing.', example: 'HINCRBY user:42 login_count 1', complexity: 'O(1)' },
    { cat: 'Hashes', name: 'HKEYS', syntax: 'HKEYS key', desc: 'Get all field names of a hash.', example: 'HKEYS user:42', complexity: 'O(N)' },
    // Sets
    { cat: 'Sets', name: 'SADD', syntax: 'SADD key member [member ...]', desc: 'Add one or more members to a set. Duplicate members are ignored.', example: 'SADD tags:post:1 "redis" "database" "cache"', complexity: 'O(N) members' },
    { cat: 'Sets', name: 'SMEMBERS', syntax: 'SMEMBERS key', desc: 'Get all members of a set. Avoid on very large sets — use SSCAN instead.', example: 'SMEMBERS tags:post:1', complexity: 'O(N)' },
    { cat: 'Sets', name: 'SREM', syntax: 'SREM key member [member ...]', desc: 'Remove one or more members from a set.', example: 'SREM tags:post:1 "cache"', complexity: 'O(N) members' },
    { cat: 'Sets', name: 'SISMEMBER', syntax: 'SISMEMBER key member', desc: 'Check if a member is in a set. Returns 1 or 0. O(1) — ideal for membership checks.', example: 'SISMEMBER blocked_ips "1.2.3.4"', complexity: 'O(1)' },
    { cat: 'Sets', name: 'SUNION', syntax: 'SUNION key [key ...]', desc: 'Return the union of multiple sets — all unique members across all sets.', example: 'SUNION tags:post:1 tags:post:2', complexity: 'O(N)' },
    { cat: 'Sets', name: 'SINTER', syntax: 'SINTER key [key ...]', desc: 'Return the intersection of multiple sets — members present in all sets.', example: 'SINTER user:1:friends user:2:friends', complexity: 'O(N*M)' },
    { cat: 'Sets', name: 'SCARD', syntax: 'SCARD key', desc: 'Get the number of members in a set.', example: 'SCARD online_users', complexity: 'O(1)' },
    // Sorted Sets
    { cat: 'Sorted Sets', name: 'ZADD', syntax: 'ZADD key score member [score member ...]', desc: 'Add members with scores to a sorted set. Members are auto-sorted by score ascending.', example: 'ZADD leaderboard 1500 "player:alice" 2300 "player:bob"', complexity: 'O(log N)' },
    { cat: 'Sorted Sets', name: 'ZRANGE', syntax: 'ZRANGE key start stop [WITHSCORES]', desc: 'Get members by rank range (ascending). Use WITHSCORES to include scores.', example: 'ZRANGE leaderboard 0 9 WITHSCORES', complexity: 'O(log N + M)' },
    { cat: 'Sorted Sets', name: 'ZREVRANGE', syntax: 'ZREVRANGE key start stop [WITHSCORES]', desc: 'Get members by rank range in descending score order. Great for top-N leaderboards.', example: 'ZREVRANGE leaderboard 0 9 WITHSCORES', complexity: 'O(log N + M)' },
    { cat: 'Sorted Sets', name: 'ZRANK', syntax: 'ZRANK key member', desc: 'Get the rank (0-based index, ascending) of a member. Returns nil if not found.', example: 'ZRANK leaderboard "player:alice"', complexity: 'O(log N)' },
    { cat: 'Sorted Sets', name: 'ZSCORE', syntax: 'ZSCORE key member', desc: 'Get the score of a member in a sorted set.', example: 'ZSCORE leaderboard "player:alice"', complexity: 'O(1)' },
    { cat: 'Sorted Sets', name: 'ZINCRBY', syntax: 'ZINCRBY key increment member', desc: 'Increment the score of a member. Creates member with score=increment if missing.', example: 'ZINCRBY leaderboard 50 "player:alice"', complexity: 'O(log N)' },
    { cat: 'Sorted Sets', name: 'ZRANGEBYSCORE', syntax: 'ZRANGEBYSCORE key min max [WITHSCORES] [LIMIT offset count]', desc: 'Get members with scores between min and max. Use -inf and +inf for unbounded range.', example: 'ZRANGEBYSCORE leaderboard 1000 2000 WITHSCORES', complexity: 'O(log N + M)' },
    { cat: 'Sorted Sets', name: 'ZCARD', syntax: 'ZCARD key', desc: 'Get the number of members in a sorted set.', example: 'ZCARD leaderboard', complexity: 'O(1)' },
    // Keys
    { cat: 'Keys', name: 'DEL', syntax: 'DEL key [key ...]', desc: 'Delete one or more keys. Returns the number of keys actually deleted.', example: 'DEL session:abc user:42:cache', complexity: 'O(N)' },
    { cat: 'Keys', name: 'EXISTS', syntax: 'EXISTS key [key ...]', desc: 'Check if one or more keys exist. Returns count of existing keys.', example: 'EXISTS user:42', complexity: 'O(N)' },
    { cat: 'Keys', name: 'KEYS', syntax: 'KEYS pattern', desc: 'Find all keys matching a pattern. WARNING: blocks server. Use SCAN in production.', example: 'KEYS user:*', complexity: 'O(N) — DANGEROUS' },
    { cat: 'Keys', name: 'SCAN', syntax: 'SCAN cursor [MATCH pattern] [COUNT count]', desc: 'Incrementally iterate keyspace without blocking. Repeat until cursor returns 0.', example: 'SCAN 0 MATCH user:* COUNT 100', complexity: 'O(1) per call' },
    { cat: 'Keys', name: 'TYPE', syntax: 'TYPE key', desc: 'Returns the data type stored at key: string, list, set, zset, hash, stream.', example: 'TYPE leaderboard', complexity: 'O(1)' },
    { cat: 'Keys', name: 'RENAME', syntax: 'RENAME key newkey', desc: 'Rename a key. Overwrites newkey if it exists. Atomic.', example: 'RENAME temp:job job:123', complexity: 'O(1)' },
    { cat: 'Keys', name: 'PERSIST', syntax: 'PERSIST key', desc: 'Remove the expiry from a key, making it permanent.', example: 'PERSIST user:42:session', complexity: 'O(1)' },
    { cat: 'Keys', name: 'PEXPIRE', syntax: 'PEXPIRE key milliseconds', desc: 'Set a key timeout in milliseconds (ms precision).', example: 'PEXPIRE rate:ip:1.2.3.4 500', complexity: 'O(1)' },
    { cat: 'Keys', name: 'OBJECT ENCODING', syntax: 'OBJECT ENCODING key', desc: 'Inspect the internal encoding used by Redis for a key (e.g. ziplist, listpack, skiplist).', example: 'OBJECT ENCODING leaderboard', complexity: 'O(1)' },
  ];

  var ALL_CATS = ['All', 'Strings', 'Lists', 'Hashes', 'Sets', 'Sorted Sets', 'Keys'];
  var CAT_COLORS = {
    'Strings': 'bg-blue-500/10 text-blue-400 border-blue-500/20',
    'Lists': 'bg-purple-500/10 text-purple-400 border-purple-500/20',
    'Hashes': 'bg-green-500/10 text-green-400 border-green-500/20',
    'Sets': 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20',
    'Sorted Sets': 'bg-orange-500/10 text-orange-400 border-orange-500/20',
    'Keys': 'bg-cyan-500/10 text-cyan-400 border-cyan-500/20',
  };

  var activeCat = 'All';
  var searchTerm = '';

  function renderFilters() {
    var container = document.getElementById('category-filters');
    container.innerHTML = ALL_CATS.map(function (cat) {
      var active = activeCat === cat;
      return '<button data-cat="' + cat + '" class="cat-btn text-xs px-3 py-1.5 rounded-lg border transition-colors ' +
        (active ? 'bg-primary text-white border-primary' : 'bg-bg-card border-border text-text-muted hover:border-primary/50') +
        '">' + cat + '</button>';
    }).join('');

    container.querySelectorAll('.cat-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        activeCat = this.getAttribute('data-cat');
        renderFilters();
        renderCommands();
      });
    });
  }

  function filteredCommands() {
    return COMMANDS.filter(function (cmd) {
      var catMatch = activeCat === 'All' || cmd.cat === activeCat;
      var term = searchTerm.toLowerCase();
      var searchMatch = !term ||
        cmd.name.toLowerCase().includes(term) ||
        cmd.syntax.toLowerCase().includes(term) ||
        cmd.desc.toLowerCase().includes(term) ||
        cmd.example.toLowerCase().includes(term) ||
        cmd.cat.toLowerCase().includes(term);
      return catMatch && searchMatch;
    });
  }

  function renderCommands() {
    var cmds = filteredCommands();
    var grid = document.getElementById('commands-grid');
    var countEl = document.getElementById('results-count');
    countEl.textContent = cmds.length + ' command' + (cmds.length !== 1 ? 's' : '') + ' shown';

    if (!cmds.length) {
      grid.innerHTML = '<p class="text-sm text-text-muted text-center py-8">No commands match your search.</p>';
      return;
    }

    grid.innerHTML = cmds.map(function (cmd) {
      var catCls = CAT_COLORS[cmd.cat] || 'bg-bg-card text-text-muted border-border';
      var isDangerous = cmd.complexity.toUpperCase().includes('DANGEROUS');
      var complexityCls = isDangerous ? 'text-red-400' : 'text-green-400';
      return '<div class="bg-bg-card border border-border rounded-xl p-5">' +
        '<div class="flex flex-wrap items-center gap-2 mb-2">' +
        '  <span class="font-bold font-mono text-primary text-sm">' + cmd.name + '</span>' +
        '  <span class="text-xs px-2 py-0.5 rounded border ' + catCls + '">' + cmd.cat + '</span>' +
        '  <span class="ml-auto text-xs font-mono ' + complexityCls + '">' + cmd.complexity + '</span>' +
        '</div>' +
        '<p class="text-xs text-text-muted mb-3">' + cmd.desc + '</p>' +
        '<div class="grid grid-cols-1 md:grid-cols-2 gap-2">' +
        '  <div class="bg-bg border border-border rounded-lg px-3 py-2">' +
        '    <div class="text-xs text-text-muted mb-1 font-semibold uppercase tracking-wide">Syntax</div>' +
        '    <code class="text-xs font-mono text-text">' + cmd.syntax + '</code>' +
        '  </div>' +
        '  <div class="bg-bg border border-border rounded-lg px-3 py-2">' +
        '    <div class="text-xs text-text-muted mb-1 font-semibold uppercase tracking-wide">Example</div>' +
        '    <code class="text-xs font-mono text-text">' + cmd.example + '</code>' +
        '  </div>' +
        '</div>' +
        '</div>';
    }).join('');
  }

  document.getElementById('search-input').addEventListener('input', function () {
    searchTerm = this.value;
    renderCommands();
  });

  renderFilters();
  renderCommands();
})();
</script>
