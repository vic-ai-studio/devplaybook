---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JestCoverageConfig from '../../components/JestCoverageConfig.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What are the four Jest coverage metrics and what do they mean?",
    answer: "Lines: what percentage of executable code lines were executed during tests. Functions: what fraction of functions were called. Branches: what fraction of conditional branches (if/else, ternary, switch arms) were exercised — this is the hardest to hit 100% on. Statements: similar to lines but counts individual statements, not just lines. Branches coverage is most valuable because untested branches are where bugs hide."
  },
  {
    question: "What coverage thresholds should I set?",
    answer: "Start with 70-80% for branches and 80-90% for lines/functions/statements. 100% coverage is rarely worth pursuing — it often leads to testing implementation details. A good rule: require 80% global coverage, plus require 100% on critical modules (auth, payments) using per-file thresholds. Add thresholds gradually — start where you are and increase by 5% per quarter."
  },
  {
    question: "What is the difference between lcov and html reporters?",
    answer: "lcov generates two outputs: a data file (lcov.info) for CI tools like Codecov/SonarQube, and an HTML report in coverage/lcov-report/. html generates only the interactive HTML report (coverage/index.html) without the lcov.info data file. For local development, html is most useful (open in browser). For CI/CD badge integration, use lcov. Use both for full coverage: coverageReporters: ['text', 'lcov']."
  },
  {
    question: "How does collectCoverageFrom affect coverage reporting?",
    answer: "Without collectCoverageFrom, Jest only counts coverage for files that are imported during tests — files not touched by any test show 0% but aren't included in totals, giving a falsely optimistic number. With collectCoverageFrom: ['src/**/*.ts'], Jest includes ALL matching files in the report, even untested ones. This gives accurate coverage numbers. Always set this to your source directory for honest reporting."
  },
  {
    question: "How do I configure Jest coverage in a monorepo?",
    answer: "In a monorepo, run jest from each package with its own jest.config.ts, or use a root jest.config.ts with projects array. For coverage, add coveragePathIgnorePatterns to exclude other packages' files. Use rootDir to scope collectCoverageFrom: ['<rootDir>/src/**/*.ts']. For combined coverage across packages, collect lcov reports from each package and merge with lcov --add-tracefile in CI."
  },
  {
    question: "What is ts-jest and do I need it?",
    answer: "ts-jest is a Jest transformer that compiles TypeScript to JavaScript for Jest without a separate build step. You need it if you write tests in TypeScript and don't use Babel. Install: npm install --save-dev ts-jest @types/jest. Configure preset: 'ts-jest' in jest.config.ts. Alternatively, use babel-jest with @babel/preset-typescript — faster but less type-safe (skips type checking). For Vite projects, consider vitest instead of jest."
  },
];
---

<BaseLayout
  title="Jest Coverage Config Generator — Configure Test Coverage Thresholds"
  description="Generate Jest configuration with coverage thresholds, reporters, and collectCoverageFrom patterns. Set line, function, branch, and statement thresholds with live sliders. Supports TypeScript. Free, runs in your browser."
  tool="jest coverage config, jest configuration generator, test coverage setup, jest threshold config, jest coverage reporter, jest config typescript"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Jest Coverage Config Generator",
    "url": "https://devplaybook.cc/tools/jest-coverage-config",
    "description": "Generate Jest configuration with coverage thresholds and reporters. Set line/function/branch/statement thresholds, configure reporters, and manage collectCoverageFrom patterns.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Jest Coverage Config Generator</h1>
  <p class="text-text-muted mb-4">
    Generate a complete <strong>Jest configuration</strong> with coverage thresholds, reporters, and file patterns. Set line, function, branch, and statement coverage requirements with sliders, pick your reporters, and manage <code class="font-mono bg-surface px-1 rounded text-sm">collectCoverageFrom</code> globs — get a copy-ready <code class="font-mono bg-surface px-1 rounded text-sm">jest.config.ts</code> instantly.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Coverage thresholds</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All reporters</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> collectCoverageFrom patterns</span>
  </div>
  <JestCoverageConfig client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Jest Coverage Config Generator" relatedTags={['testing', 'jest', 'coverage', 'typescript', 'javascript', 'developer-tools']} />
</BaseLayout>
