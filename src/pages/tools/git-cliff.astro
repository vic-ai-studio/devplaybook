---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const cliffTomlExample = `[changelog]
header = """
# Changelog

All notable changes to this project will be documented in this file.
"""
body = """
{% if version %}\\
    ## [{{ version | trim_start_matches(pat="v") }}] - {{ timestamp | date(format="%Y-%m-%d") }}
{% else %}\\
    ## [Unreleased]
{% endif %}\\
{% for group, commits in commits | group_by(attribute="group") %}
    ### {{ group | striptags | trim | upper_first }}
    {% for commit in commits %}
        - {% if commit.scope %}*({{ commit.scope }})* {% endif %}{{ commit.message | upper_first }}\\
    {% endfor %}
{% endfor %}\\
"""
trim = true

[git]
conventional_commits = true
filter_unconventional = true
commit_parsers = [
    { message = "^feat", group = "Features" },
    { message = "^fix", group = "Bug Fixes" },
    { message = "^perf", group = "Performance" },
    { message = "^refactor", group = "Refactoring" },
    { message = "^docs", group = "Documentation" },
    { message = "^chore|^ci|^test", skip = true },
]
filter_commits = true
tag_pattern = "v[0-9].*"`;

const faq = [
  { question: "What is git-cliff?", answer: "git-cliff is a changelog generator that parses your Git commit history and produces a formatted CHANGELOG.md (or any format you define). It uses conventional commits (feat:, fix:, perf:, etc.) to categorize changes into sections like Features, Bug Fixes, and Performance. You configure it via a cliff.toml file using the Tera templating engine. It integrates with GitHub Actions for automatic changelog generation on release." },
  { question: "What is the conventional commits format?", answer: "Conventional Commits is a specification for commit messages that adds semantic meaning. The format is: type(scope): description. Common types are: feat (new feature, triggers MINOR bump), fix (bug fix, triggers PATCH bump), perf (performance improvement), refactor, docs, test, chore, ci. Breaking changes are marked with BREAKING CHANGE in the footer or an exclamation after the type (feat!:), triggering a MAJOR version bump. Tools like git-cliff, semantic-release, and standard-version rely on this format." },
  { question: "How does git-cliff compare to standard-version?", answer: "standard-version is a Node.js tool that handles both version bumping and changelog generation together. git-cliff is focused solely on changelog generation and is language-agnostic (written in Rust). git-cliff's Tera templating is significantly more flexible than standard-version's templates, letting you produce any format. standard-version is better for projects that want automatic semver bumping tied to changelog generation. git-cliff is better when you want full control over the changelog format or use it in non-Node projects." },
  { question: "How do I use git-cliff templates?", answer: "git-cliff uses the Tera templating engine (similar to Jinja2). In cliff.toml, the 'body' field is a Tera template that receives commit objects with fields like message, scope, group, author, timestamp, and version. You can use Tera filters (date, upper_first, striptags), conditionals (if version), and loops (for group, commits in commits | group_by). Set 'prepend = CHANGELOG.md' to prepend each new release to an existing file." },
  { question: "Can git-cliff generate changelogs for a specific tag range?", answer: "Yes. Run 'git cliff v1.0.0..v2.0.0' to generate a changelog for commits between two tags. Run 'git cliff --latest' to generate only the latest release's changes (since the previous tag). Run 'git cliff --unreleased' to generate changes since the last tag. The '--tag' flag lets you specify what version to use in the output when commits are not yet tagged." },
  { question: "Does git-cliff work with GitHub Actions?", answer: "Yes. git-cliff has an official GitHub Action (orhun/git-cliff-action) that generates your changelog and can commit it, create release notes, or pass the output to the GitHub Releases API. A common pattern is to trigger it on push to a tag: the action generates the changelog, creates a GitHub Release with the notes, and commits CHANGELOG.md if needed." },
];
---

<BaseLayout
  title="git-cliff — Changelog Generator from Conventional Commits"
  description="git-cliff generates changelogs from conventional commits using customizable Tera templates. Configure via cliff.toml, supports tag ranges, GitHub Actions, and any output format. Written in Rust."
  tool="git-cliff, changelog generator, conventional commits changelog, git cliff, CHANGELOG.md generator, semantic versioning changelog"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "git-cliff — Changelog Generator from Conventional Commits",
    "url": "https://devplaybook.cc/tools/git-cliff",
    "description": "git-cliff generates changelogs from conventional commits using customizable Tera templates. Written in Rust, configurable via cliff.toml.",
  })} />

  <h1 class="text-3xl font-bold mb-2">git-cliff</h1>
  <p class="text-text-muted mb-6">
    A <strong>changelog generator</strong> that parses conventional commits and produces
    beautifully formatted CHANGELOG files using customizable <strong>Tera templates</strong>.
    Written in Rust. Works with any language ecosystem.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Conventional commits</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Tera template engine</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GitHub Actions support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Written in Rust</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is git-cliff?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    git-cliff is a changelog generator that reads your Git history, parses commit messages following the <strong>Conventional Commits</strong> specification, and renders a formatted changelog using the <strong>Tera</strong> templating engine. It is language-agnostic, written in Rust, and configured via a <code class="bg-bg-card px-1 rounded text-xs">cliff.toml</code> file that lives in your repository root.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    Unlike tools such as standard-version that couple changelog generation with version bumping, git-cliff focuses purely on the changelog. This makes it flexible: use it standalone, as part of a release script, or via GitHub Actions to auto-generate release notes when you push a tag.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Conventional commits parsing</strong> — categorizes feat, fix, perf, refactor, docs, and more into changelog sections</li>
    <li><strong>Tera templating</strong> — full Jinja2-compatible template syntax for any output format (Markdown, AsciiDoc, HTML)</li>
    <li><strong>Tag range support</strong> — generate changelogs for specific version ranges, latest release, or unreleased commits</li>
    <li><strong>cliff.toml configuration</strong> — commit parsers, skip patterns, tag patterns, body template, and header all configurable</li>
    <li><strong>GitHub Actions integration</strong> — official action for automated changelog on tag push</li>
    <li><strong>Prepend mode</strong> — prepend new release notes to an existing CHANGELOG.md, building a cumulative file</li>
    <li><strong>Scope grouping</strong> — group commits by conventional commit scope (e.g., feat(auth):, fix(api):)</li>
    <li><strong>Breaking change highlighting</strong> — automatically surfaces BREAKING CHANGE commits in a separate section</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Installation</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-2"># macOS (Homebrew)
brew install git-cliff

# Rust / Cargo (any platform)
cargo install git-cliff

# Windows (Scoop)
scoop install git-cliff

# npm (for Node.js projects)
npm install --save-dev git-cliff

# Download binary from GitHub Releases
# https://github.com/orhun/git-cliff/releases</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Basic Usage</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Generate full changelog to stdout
git cliff

# Write to CHANGELOG.md
git cliff -o CHANGELOG.md

# Generate only unreleased changes
git cliff --unreleased

# Generate only the latest release's changes
git cliff --latest

# Generate changelog for a tag range
git cliff v1.0.0..v2.0.0

# Tag the current HEAD and generate with that version
git cliff --tag v1.2.3 --unreleased

# Init a default cliff.toml in the current directory
git cliff --init</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Example cliff.toml</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={cliffTomlExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Conventional Commits Quick Reference</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Type</th>
          <th class="border border-border px-3 py-2 text-left">Changelog section</th>
          <th class="border border-border px-3 py-2 text-left">Semver bump</th>
          <th class="border border-border px-3 py-2 text-left">Example</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2 font-mono">feat</td><td class="border border-border px-3 py-2">Features</td><td class="border border-border px-3 py-2">MINOR</td><td class="border border-border px-3 py-2 font-mono text-xs">feat(auth): add OAuth2 login</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2 font-mono">fix</td><td class="border border-border px-3 py-2">Bug Fixes</td><td class="border border-border px-3 py-2">PATCH</td><td class="border border-border px-3 py-2 font-mono text-xs">fix(api): handle null response</td></tr>
        <tr><td class="border border-border px-3 py-2 font-mono">perf</td><td class="border border-border px-3 py-2">Performance</td><td class="border border-border px-3 py-2">PATCH</td><td class="border border-border px-3 py-2 font-mono text-xs">perf: cache query results</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2 font-mono">refactor</td><td class="border border-border px-3 py-2">Refactoring</td><td class="border border-border px-3 py-2">PATCH</td><td class="border border-border px-3 py-2 font-mono text-xs">refactor: extract helper fn</td></tr>
        <tr><td class="border border-border px-3 py-2 font-mono">docs</td><td class="border border-border px-3 py-2">Documentation</td><td class="border border-border px-3 py-2">none</td><td class="border border-border px-3 py-2 font-mono text-xs">docs: update README</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2 font-mono">feat!</td><td class="border border-border px-3 py-2">Breaking Changes</td><td class="border border-border px-3 py-2">MAJOR</td><td class="border border-border px-3 py-2 font-mono text-xs">feat!: remove legacy endpoint</td></tr>
        <tr><td class="border border-border px-3 py-2 font-mono">chore/ci/test</td><td class="border border-border px-3 py-2">Skipped (default)</td><td class="border border-border px-3 py-2">none</td><td class="border border-border px-3 py-2 font-mono text-xs">chore: bump deps</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Use Cases</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li>Auto-generating CHANGELOG.md on every tagged release via GitHub Actions</li>
    <li>Producing GitHub Release notes from the latest tag's commits</li>
    <li>Enforcing conventional commits in a team by making the changelog meaningful and automated</li>
    <li>Generating release notes in custom formats (AsciiDoc, HTML, JSON) for documentation systems</li>
    <li>Auditing what changed between two versions during incident investigation</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pros and Cons</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-green-400 mb-2">Pros</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✓ Language-agnostic (not tied to Node.js ecosystem)</li>
        <li>✓ Extremely flexible Tera templates</li>
        <li>✓ Fast Rust binary with no runtime dependency</li>
        <li>✓ Official GitHub Actions integration</li>
        <li>✓ Handles partial changelogs (latest / unreleased / range)</li>
        <li>✓ Active maintenance and growing community</li>
      </ul>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-red-400 mb-2">Cons</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✗ Requires conventional commits discipline from the whole team</li>
        <li>✗ Does not bump version numbers (unlike standard-version)</li>
        <li>✗ Tera template syntax has a learning curve</li>
        <li>✗ Useless on repos with free-form commit messages</li>
        <li>✗ cliff.toml setup takes some initial configuration effort</li>
      </ul>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="git-cliff" relatedTags={['git', 'cli', 'devops', 'version-control', 'workflow']} />
</BaseLayout>
