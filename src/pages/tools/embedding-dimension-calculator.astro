---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What are embedding dimensions?", answer: "Embedding dimensions define the size of the vector produced for each piece of text. A model with 1536 dimensions outputs a 1536-element array of floating-point numbers for every text input. Higher dimensions can capture more semantic nuance but consume more storage and memory." },
  { question: "What is float32 storage?", answer: "Most embedding models output float32 (32-bit floating-point) numbers. Each float32 value takes exactly 4 bytes. So a 1536-dimension vector requires 1536 × 4 = 6,144 bytes (≈6 KB) per document. When storing millions of vectors, this adds up quickly." },
  { question: "Does higher dimension always mean better quality?", answer: "Not necessarily. text-embedding-3-large (3072 dims) generally outperforms text-embedding-ada-002 (1536 dims) on benchmarks, but the improvement depends on your task. For many retrieval tasks, smaller models like voyage-3 (1024 dims) are competitive while being 4× cheaper to store." },
  { question: "What is the difference between ANN and exact search?", answer: "Approximate Nearest Neighbor (ANN) search trades a small amount of accuracy for massive speed gains — typically 99%+ recall at 10-100× the speed. Exact search guarantees finding the true nearest neighbors but doesn't scale beyond ~1M vectors. All production vector databases use ANN." },
  { question: "How do I choose between OpenAI and Cohere embeddings?", answer: "OpenAI text-embedding-3 models excel at English and code tasks and integrate easily with the OpenAI ecosystem. Cohere embed-v3 models have strong multilingual support (100+ languages) and work well for enterprise search. For multilingal use cases, Cohere is often the better choice." },
];

const models = [
  { name: 'text-embedding-3-small', provider: 'OpenAI', dims: 1536, useCase: 'General purpose, cost-efficient', notes: 'Best price/performance for most tasks' },
  { name: 'text-embedding-3-large', provider: 'OpenAI', dims: 3072, useCase: 'High-accuracy retrieval, long docs', notes: 'Highest quality OpenAI embedding' },
  { name: 'text-embedding-ada-002', provider: 'OpenAI', dims: 1536, useCase: 'Legacy, broad compatibility', notes: 'Older model, use 3-small instead' },
  { name: 'voyage-3', provider: 'Anthropic / Voyage', dims: 1024, useCase: 'RAG, semantic search', notes: 'Strong retrieval performance' },
  { name: 'voyage-3-lite', provider: 'Anthropic / Voyage', dims: 512, useCase: 'Latency-sensitive, high-volume', notes: 'Fastest Voyage model' },
  { name: 'embed-english-v3.0', provider: 'Cohere', dims: 1024, useCase: 'English semantic search', notes: 'Top MTEB English score' },
  { name: 'embed-multilingual-v3.0', provider: 'Cohere', dims: 1024, useCase: 'Multilingual search (100+ langs)', notes: 'Best-in-class multilingual' },
  { name: 'textembedding-gecko@003', provider: 'Google', dims: 768, useCase: 'Compact, fast retrieval', notes: 'Vertex AI, cost-effective' },
  { name: 'text-multilingual-embedding-002', provider: 'Google', dims: 768, useCase: 'Multilingual on GCP', notes: 'Good quality, lower storage' },
];
---

<BaseLayout
  title="Embedding Dimension Calculator — Vector Storage & Model Comparison"
  description="Compare embedding model dimensions across OpenAI, Anthropic, Cohere, and Google. Calculate storage requirements for 1M, 10M, and 100M vectors. Find the right embedding model for your RAG or semantic search project."
  tool="Embedding Dimension Calculator, Vector Storage Calculator, OpenAI Embeddings, Sentence Embeddings Comparison, RAG Storage Estimator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Embedding Dimension Calculator</h1>
  <p class="text-text-muted mb-4">Compare embedding model dimensions, storage costs, and use cases. Calculate exactly how much disk space your vector database will need at scale.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 9 embedding models</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Storage at 1M / 10M / 100M vectors</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Custom vector count estimator</span>
  </div>

  <!-- Model comparison table -->
  <div class="overflow-x-auto mb-8">
    <table class="w-full text-sm min-w-[700px]">
      <thead>
        <tr class="text-text-muted text-xs uppercase border-b border-border">
          <th class="text-left pb-3 pr-4 font-medium">Model</th>
          <th class="text-left pb-3 pr-4 font-medium">Provider</th>
          <th class="text-right pb-3 pr-4 font-medium">Dims</th>
          <th class="text-right pb-3 pr-4 font-medium">Bytes/vec</th>
          <th class="text-right pb-3 pr-4 font-medium">1M vecs</th>
          <th class="text-right pb-3 pr-4 font-medium">10M vecs</th>
          <th class="text-right pb-3 pr-4 font-medium">100M vecs</th>
          <th class="text-left pb-3 font-medium">Best For</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        {models.map(m => {
          const bytesPerVec = m.dims * 4;
          const gb1M = (bytesPerVec * 1e6 / 1e9).toFixed(2);
          const gb10M = (bytesPerVec * 10e6 / 1e9).toFixed(1);
          const gb100M = (bytesPerVec * 100e6 / 1e9).toFixed(0);
          return (
            <tr class="hover:bg-bg-card/50 transition-colors">
              <td class="py-3 pr-4 font-semibold font-mono text-xs">{m.name}</td>
              <td class="py-3 pr-4 text-text-muted">{m.provider}</td>
              <td class="py-3 pr-4 text-right tabular-nums font-medium text-primary">{m.dims.toLocaleString()}</td>
              <td class="py-3 pr-4 text-right tabular-nums text-text-muted">{bytesPerVec.toLocaleString()}</td>
              <td class="py-3 pr-4 text-right tabular-nums">{gb1M} GB</td>
              <td class="py-3 pr-4 text-right tabular-nums">{gb10M} GB</td>
              <td class="py-3 pr-4 text-right tabular-nums">{gb100M} GB</td>
              <td class="py-3 text-xs text-text-muted">{m.useCase}</td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
  <p class="text-xs text-text-muted mb-8">Storage calculated as float32 (4 bytes/dim). Does not include vector DB overhead, indexes, or metadata. Actual usage is typically 1.5–2× raw vector size with HNSW indexes.</p>

  <!-- Custom storage estimator -->
  <div class="bg-bg-card border border-border rounded-xl p-6 mb-8">
    <h2 class="text-lg font-bold mb-4">Custom Storage Estimator</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
      <div>
        <label class="block text-sm font-medium mb-1.5">Embedding Model</label>
        <select id="model-select" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          {models.map(m => (
            <option value={m.dims}>{m.name} ({m.dims}d)</option>
          ))}
          <option value="custom">Custom dimensions...</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Custom Dims (if selected)</label>
        <input id="custom-dims" type="number" min="1" max="65536" placeholder="e.g. 768" disabled
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary disabled:opacity-40" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Number of Vectors</label>
        <input id="vector-count" type="number" min="1" value="1000000" placeholder="e.g. 1000000"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
    </div>

    <div id="estimator-result" class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      <div class="bg-bg-card border border-border rounded-lg p-4 text-center">
        <p class="text-xs text-text-muted mb-1">Dims</p>
        <p id="res-dims" class="text-2xl font-bold text-primary">1,536</p>
      </div>
      <div class="bg-bg-card border border-border rounded-lg p-4 text-center">
        <p class="text-xs text-text-muted mb-1">Bytes / Vector</p>
        <p id="res-bytes" class="text-2xl font-bold">6,144</p>
      </div>
      <div class="bg-bg-card border border-border rounded-lg p-4 text-center">
        <p class="text-xs text-text-muted mb-1">Raw Storage</p>
        <p id="res-storage" class="text-2xl font-bold">5.73 GB</p>
      </div>
      <div class="bg-bg-card border border-border rounded-lg p-4 text-center">
        <p class="text-xs text-text-muted mb-1">With Index (~1.5×)</p>
        <p id="res-indexed" class="text-2xl font-bold">8.59 GB</p>
      </div>
    </div>
  </div>

  <!-- Quick model cards -->
  <h2 class="text-lg font-bold mb-4">Model Recommendations</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <p class="text-xs text-text-muted uppercase tracking-wide mb-1">Best Overall (English)</p>
      <p class="font-bold text-primary mb-1">text-embedding-3-large</p>
      <p class="text-xs text-text-muted">3072 dims. Highest MTEB score from OpenAI. Use when retrieval quality is the priority. ~23 GB per 1M vectors.</p>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <p class="text-xs text-text-muted uppercase tracking-wide mb-1">Best Price/Performance</p>
      <p class="font-bold text-primary mb-1">text-embedding-3-small</p>
      <p class="text-xs text-text-muted">1536 dims. 5× cheaper than large, 80% of the quality. Ideal for most RAG pipelines. ~5.7 GB per 1M vectors.</p>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <p class="text-xs text-text-muted uppercase tracking-wide mb-1">Best Compact</p>
      <p class="font-bold text-primary mb-1">voyage-3-lite</p>
      <p class="text-xs text-text-muted">512 dims. Lowest storage footprint. Great for edge deployments or high-volume low-latency use cases. ~1.9 GB per 1M.</p>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <p class="text-xs text-text-muted uppercase tracking-wide mb-1">Best Multilingual</p>
      <p class="font-bold text-primary mb-1">embed-multilingual-v3.0</p>
      <p class="text-xs text-text-muted">Cohere, 1024 dims. Best-in-class for 100+ languages. Same storage as voyage-3. ~3.8 GB per 1M vectors.</p>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <p class="text-xs text-text-muted uppercase tracking-wide mb-1">Best for GCP / Vertex</p>
      <p class="font-bold text-primary mb-1">textembedding-gecko@003</p>
      <p class="text-xs text-text-muted">Google, 768 dims. Cost-effective on Vertex AI. Good performance for retrieval. ~2.9 GB per 1M vectors.</p>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <p class="text-xs text-text-muted uppercase tracking-wide mb-1">Best Legacy Migration</p>
      <p class="font-bold text-primary mb-1">text-embedding-ada-002</p>
      <p class="text-xs text-text-muted">1536 dims. Existing ada-002 users: migrate to 3-small for lower cost + better quality. Same dimension count.</p>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Embedding Dimension Calculator" relatedTags={['ai', 'llm', 'embeddings', 'vector-db', 'rag', 'openai']} />
</BaseLayout>

<script>
  const modelSelect = document.getElementById('model-select') as HTMLSelectElement;
  const customDimsInput = document.getElementById('custom-dims') as HTMLInputElement;
  const vectorCountInput = document.getElementById('vector-count') as HTMLInputElement;
  const resDims = document.getElementById('res-dims')!;
  const resBytes = document.getElementById('res-bytes')!;
  const resStorage = document.getElementById('res-storage')!;
  const resIndexed = document.getElementById('res-indexed')!;

  function formatBytes(bytes: number): string {
    if (bytes >= 1e12) return (bytes / 1e12).toFixed(2) + ' TB';
    if (bytes >= 1e9) return (bytes / 1e9).toFixed(2) + ' GB';
    if (bytes >= 1e6) return (bytes / 1e6).toFixed(2) + ' MB';
    return (bytes / 1e3).toFixed(1) + ' KB';
  }

  function calculate() {
    let dims: number;
    if (modelSelect.value === 'custom') {
      dims = parseInt(customDimsInput.value) || 0;
    } else {
      dims = parseInt(modelSelect.value);
    }
    const count = parseInt(vectorCountInput.value) || 0;

    if (!dims || !count) return;

    const bytesPerVec = dims * 4;
    const rawBytes = bytesPerVec * count;
    const indexedBytes = rawBytes * 1.5;

    resDims.textContent = dims.toLocaleString();
    resBytes.textContent = bytesPerVec.toLocaleString();
    resStorage.textContent = formatBytes(rawBytes);
    resIndexed.textContent = formatBytes(indexedBytes);
  }

  modelSelect.addEventListener('change', () => {
    const isCustom = modelSelect.value === 'custom';
    customDimsInput.disabled = !isCustom;
    if (isCustom) customDimsInput.focus();
    calculate();
  });

  customDimsInput.addEventListener('input', calculate);
  vectorCountInput.addEventListener('input', calculate);

  calculate();
</script>
