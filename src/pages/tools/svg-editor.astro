---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SvgEditor from '../../components/SvgEditor.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="SVG Editor & Optimizer — Online SVG Tool"
  description="Paste, preview, format, and optimize SVG code in your browser. Removes comments, collapses whitespace, shortens hex colors, and reduces file size. Generate base64 data URIs and download clean SVGs."
  tool="SVG Editor, SVG Optimizer, SVG Minifier, Online SVG Tool, SVG to Data URI"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "SVG Editor & Optimizer",
    "url": "https://devplaybook.cc/tools/svg-editor",
    "description": "Online SVG editor and optimizer. Preview, format, minify SVG code, and export as data URI — all in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">SVG Editor & Optimizer</h1>
  <p class="text-text-muted mb-8">
    Paste SVG code, preview it instantly, and optimize it for production. The optimizer removes comments, collapses whitespace,
    shortens hex colors (<code class="font-mono bg-surface px-1 rounded">#ffffff → #fff</code>), and strips default attribute values.
    Export as a data URI for inline use in CSS or HTML, or download the cleaned file.
  </p>
  <SvgEditor client:only="preact" />
  <ToolPageCta currentTool="SVG Editor & Optimizer" relatedTags={['svg', 'frontend', 'css', 'design', 'optimization']} />
</BaseLayout>
