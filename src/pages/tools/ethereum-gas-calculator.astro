---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is gas in Ethereum?",
    answer: "Gas is the unit that measures the computational work required to execute operations on the Ethereum network. Every operation — from a simple ETH transfer to a complex smart contract interaction — consumes a specific amount of gas. Gas prevents abuse of the network by ensuring each computation has a cost. You pay gas fees in ETH (in gwei units) to compensate validators who process your transaction."
  },
  {
    question: "What is gwei?",
    answer: "Gwei is a denomination of ETH used for gas prices. 1 ETH = 1,000,000,000 gwei (1 billion gwei). Gas prices are quoted in gwei because the values are easier to work with — saying '20 gwei' is clearer than '0.00000002 ETH'. After EIP-1559, gas price consists of a base fee (burned) plus a priority fee (tip to validators)."
  },
  {
    question: "What is the gas limit?",
    answer: "The gas limit is the maximum amount of gas you're willing to let a transaction consume. For a simple ETH transfer, 21,000 gas is always sufficient. For smart contract interactions, you set a higher limit (e.g. 200,000) to ensure the transaction doesn't run out of gas. Unused gas is refunded — you only pay for gas actually consumed. If gas runs out mid-execution, the transaction fails but you still pay the gas used."
  },
  {
    question: "How does EIP-1559 change gas fees?",
    answer: "EIP-1559 (August 2021) replaced the first-price auction model with a base fee + priority fee model. The base fee is set algorithmically by the network based on demand and is burned (destroyed), reducing ETH supply. The priority fee (tip) goes to validators. You set a max fee (maximum total you'll pay) and the actual cost is base fee + priority fee. This made fee estimation more predictable."
  },
  {
    question: "Why do different operations cost different amounts of gas?",
    answer: "Each EVM opcode has a fixed gas cost based on its computational complexity. Reading data from storage costs 100-2100 gas. Writing to storage costs 20,000 gas (first write) or 2,900 gas (update). A simple ETH transfer (no code) always costs exactly 21,000 gas. ERC-20 transfers cost ~65,000 gas because they execute contract code. Deploying a contract costs much more (500K–3M+ gas) depending on bytecode size."
  },
  {
    question: "What are Layer 2 gas fees?",
    answer: "Layer 2 networks like Arbitrum, Optimism, Base, and Polygon process transactions off-chain and periodically post batches to Ethereum mainnet. This dramatically reduces per-transaction costs — often 10-100x cheaper than mainnet. However, L2 transactions still use gwei and gas units, just at lower amounts. This calculator focuses on Ethereum mainnet; L2 costs vary by network."
  },
];
---

<BaseLayout
  title="Ethereum Gas Calculator — Transaction Cost in ETH and USD"
  description="Calculate Ethereum transaction costs instantly. Enter gas limit, gas price in gwei, and ETH price to see total fee in ETH and USD. Common operations gas reference table. Free browser tool."
  tool="Ethereum Gas Calculator, ETH Gas Fee Calculator, Gas Price Calculator, Ethereum Transaction Cost, Gwei Calculator, ETH Fee Estimator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Ethereum Gas Calculator",
    "url": "https://devplaybook.cc/tools/ethereum-gas-calculator",
    "description": "Calculate Ethereum transaction costs in ETH and USD. Enter gas limit, gas price, and ETH price to see total fee. Common operations reference table included.",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Ethereum Gas Calculator</h1>
  <p class="text-text-muted mb-4">
    Calculate Ethereum transaction costs in ETH and USD. Set gas limit, gas price (gwei), and current ETH price to see the exact fee.
    Common operations reference table included.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> ETH + USD cost</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Common ops reference</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <div id="gas-app" class="space-y-6">
    <!-- Main Calculator -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-semibold mb-1" for="gas-limit">Gas Limit</label>
          <input id="gas-limit" type="number" value="21000" min="21000" step="1000"
            class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text font-mono focus:outline-none focus:border-accent" />
          <p class="text-xs text-text-muted mt-1">ETH transfer = 21,000 · ERC-20 transfer ≈ 65,000 · Contract deploy ≈ 1,500,000</p>
        </div>
        <div>
          <label class="block text-sm font-semibold mb-1" for="gas-price">Gas Price (gwei)</label>
          <input id="gas-price" type="number" value="20" min="0" step="0.1"
            class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text font-mono focus:outline-none focus:border-accent" />
          <p class="text-xs text-text-muted mt-1">Current mainnet: check ethgasstation.info or Etherscan</p>
        </div>
        <div>
          <label class="block text-sm font-semibold mb-1" for="eth-price">ETH Price (USD)</label>
          <input id="eth-price" type="number" value="3200" min="0" step="10"
            class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text font-mono focus:outline-none focus:border-accent" />
        </div>

        <!-- Presets -->
        <div>
          <p class="text-xs font-semibold text-text-muted uppercase tracking-wide mb-2">Common Operations</p>
          <div class="flex flex-wrap gap-2">
            <button class="op-preset px-3 py-1.5 bg-surface border border-border hover:border-accent/50 text-text text-xs rounded-lg transition-colors" data-gas="21000">ETH Transfer</button>
            <button class="op-preset px-3 py-1.5 bg-surface border border-border hover:border-accent/50 text-text text-xs rounded-lg transition-colors" data-gas="65000">ERC-20 Transfer</button>
            <button class="op-preset px-3 py-1.5 bg-surface border border-border hover:border-accent/50 text-text text-xs rounded-lg transition-colors" data-gas="150000">Uniswap Swap</button>
            <button class="op-preset px-3 py-1.5 bg-surface border border-border hover:border-accent/50 text-text text-xs rounded-lg transition-colors" data-gas="65000">NFT Transfer</button>
            <button class="op-preset px-3 py-1.5 bg-surface border border-border hover:border-accent/50 text-text text-xs rounded-lg transition-colors" data-gas="1500000">Deploy Contract</button>
          </div>
        </div>
      </div>

      <!-- Result -->
      <div class="space-y-4">
        <div class="bg-surface border border-border rounded-xl p-5 space-y-4">
          <p class="text-xs font-semibold text-text-muted uppercase tracking-wide">Transaction Cost</p>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-sm text-text-muted">Gas Used</span>
              <span id="result-gas" class="font-mono text-sm text-text">21,000</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-sm text-text-muted">Gas Price</span>
              <span id="result-price" class="font-mono text-sm text-text">20 gwei</span>
            </div>
            <div class="border-t border-border pt-3">
              <div class="flex justify-between items-center mb-1">
                <span class="text-sm font-semibold">Cost in ETH</span>
                <span id="result-eth" class="font-mono text-lg font-bold text-text">0.00042 ETH</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-sm font-semibold">Cost in USD</span>
                <span id="result-usd" class="font-mono text-2xl font-bold text-accent">$1.34</span>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-surface border border-border rounded-xl p-5">
          <p class="text-xs font-semibold text-text-muted uppercase tracking-wide mb-3">Gwei Breakdown</p>
          <div class="space-y-2 text-sm">
            <div class="flex justify-between">
              <span class="text-text-muted">1 gwei =</span>
              <span class="font-mono text-text">0.000000001 ETH</span>
            </div>
            <div class="flex justify-between">
              <span class="text-text-muted">Gas cost in gwei =</span>
              <span id="result-total-gwei" class="font-mono text-text">420,000 gwei</span>
            </div>
            <div class="flex justify-between">
              <span class="text-text-muted">Gas cost in wei =</span>
              <span id="result-total-wei" class="font-mono text-text">420,000,000,000 wei</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Common Operations Table -->
    <div>
      <p class="text-sm font-semibold mb-3">Common Operations Gas Reference</p>
      <div class="overflow-x-auto rounded-lg border border-border">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-surface border-b border-border text-left">
              <th class="px-4 py-2.5 font-semibold text-text-muted">Operation</th>
              <th class="px-4 py-2.5 font-semibold text-text-muted">Gas (approx)</th>
              <th class="px-4 py-2.5 font-semibold text-text-muted">Cost (ETH)</th>
              <th class="px-4 py-2.5 font-semibold text-text-muted">Cost (USD)</th>
            </tr>
          </thead>
          <tbody id="ops-table-body"></tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    (function () {
      const ops = [
        { label: 'ETH Transfer', gas: 21000 },
        { label: 'ERC-20 Transfer', gas: 65000 },
        { label: 'ERC-20 Approve', gas: 46000 },
        { label: 'Uniswap V3 Swap', gas: 150000 },
        { label: 'ERC-721 Mint (NFT)', gas: 100000 },
        { label: 'ERC-721 Transfer', gas: 65000 },
        { label: 'ERC-1155 Transfer', gas: 60000 },
        { label: 'Deploy Simple Contract', gas: 500000 },
        { label: 'Deploy ERC-20 Contract', gas: 1500000 },
      ];

      function getNum(id) { return parseFloat(document.getElementById(id)?.value) || 0; }

      function format(n, decimals = 6) {
        if (n === 0) return '0';
        return n.toFixed(decimals).replace(/\.?0+$/, '');
      }

      function calculate() {
        const gasLimit = getNum('gas-limit');
        const gasPrice = getNum('gas-price'); // gwei
        const ethPrice = getNum('eth-price');

        const totalGwei = gasLimit * gasPrice;
        const totalWei = totalGwei * 1e9;
        const totalEth = totalGwei / 1e9;
        const totalUsd = totalEth * ethPrice;

        document.getElementById('result-gas').textContent = gasLimit.toLocaleString();
        document.getElementById('result-price').textContent = `${gasPrice} gwei`;
        document.getElementById('result-eth').textContent = `${format(totalEth)} ETH`;
        document.getElementById('result-usd').textContent = `$${totalUsd.toFixed(totalUsd < 0.01 ? 6 : 2)}`;
        document.getElementById('result-total-gwei').textContent = `${totalGwei.toLocaleString()} gwei`;
        document.getElementById('result-total-wei').textContent = `${totalWei.toLocaleString()} wei`;

        // Update table
        const tbody = document.getElementById('ops-table-body');
        tbody.innerHTML = ops.map((op, i) => {
          const opGwei = op.gas * gasPrice;
          const opEth = opGwei / 1e9;
          const opUsd = opEth * ethPrice;
          const highlight = op.gas === gasLimit ? ' bg-accent/5' : '';
          return `<tr class="border-b border-border last:border-0${highlight}">
            <td class="px-4 py-2.5 text-text">${op.label}</td>
            <td class="px-4 py-2.5 font-mono text-text-muted">${op.gas.toLocaleString()}</td>
            <td class="px-4 py-2.5 font-mono text-text">${format(opEth)} ETH</td>
            <td class="px-4 py-2.5 font-mono text-text">$${opUsd.toFixed(opUsd < 0.01 ? 4 : 2)}</td>
          </tr>`;
        }).join('');
      }

      document.querySelectorAll('#gas-app input').forEach(el => {
        el.addEventListener('input', calculate);
      });

      document.querySelectorAll('.op-preset').forEach(btn => {
        btn.addEventListener('click', function () {
          document.getElementById('gas-limit').value = this.dataset.gas;
          calculate();
        });
      });

      calculate();
    })();
  </script>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Ethereum Gas Calculator" relatedTags={['ethereum', 'blockchain', 'web3', 'crypto', 'smart-contracts']} />
</BaseLayout>
