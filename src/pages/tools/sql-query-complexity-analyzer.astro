---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What makes a SQL query complex?", answer: "SQL complexity is driven by: number of JOINs (each adds an exponential factor to the query plan), correlated subqueries (run once per row), CTEs with repeated references, large DISTINCT or GROUP BY operations, missing indexes on JOIN/WHERE columns, and HAVING clauses that filter after aggregation. The optimizer cost estimate and actual rows processed are the true measures." },
  { question: "How many JOINs is too many?", answer: "There is no hard limit, but queries with 5+ JOINs become hard to optimize and understand. The optimizer's search space grows factorially with JOIN count. Queries with 8+ JOINs often hit optimizer heuristics that skip exhaustive plan search. Consider CTEs, materialized views, or denormalization when JOIN counts grow large." },
  { question: "What is a correlated subquery and why is it slow?", answer: "A correlated subquery references columns from the outer query (e.g., WHERE salary > (SELECT AVG(salary) FROM employees e2 WHERE e2.dept = e1.dept)). It executes once per row of the outer query, making it O(n) instead of O(1). Rewrite with JOIN + aggregation or window functions for dramatic performance gains." },
  { question: "When should I use CTEs vs subqueries?", answer: "CTEs (WITH clauses) improve readability and allow recursive queries. In PostgreSQL, CTEs before PG12 were optimization fences (preventing push-down). Modern PostgreSQL, MySQL 8+, and SQL Server inline simple CTEs. Use CTEs for: recursive queries, reusing the same subquery multiple times, and improving readability. Use subqueries for simple one-off filters." },
  { question: "What optimization suggestions apply to most complex queries?", answer: "Common optimizations: (1) Add indexes on JOIN and WHERE columns, (2) Rewrite correlated subqueries as JOINs, (3) Use EXPLAIN ANALYZE to find seq scans, (4) Break complex queries into CTEs for the optimizer, (5) Use covering indexes for frequently queried column combinations, (6) Avoid SELECT * — name columns explicitly, (7) Use LIMIT early in subqueries." }
];
---

<BaseLayout
  title="SQL Query Complexity Analyzer — Analyze SQL Performance Cost"
  description="Paste any SQL query to analyze its complexity. Count JOINs, subqueries, CTEs, GROUP BY, DISTINCT, and more. Get a complexity score and optimization suggestions instantly."
  tool="SQL query complexity analyzer, SQL performance analyzer, SQL query analyzer, SQL complexity score, SQL optimization tips"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "SQL Query Complexity Analyzer",
    "url": "https://devplaybook.cc/tools/sql-query-complexity-analyzer",
    "description": "Analyze SQL query complexity. Count JOINs, subqueries, CTEs, and get optimization suggestions.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">SQL Query Complexity Analyzer</h1>
  <p class="text-text-muted mb-4">
    Paste a SQL query to analyze its complexity. Get counts of JOINs, subqueries, CTEs, aggregations, and a
    complexity score with targeted optimization suggestions.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> JOIN / subquery / CTE detection</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Complexity scoring</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Optimization suggestions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Works with any SQL dialect</span>
  </div>

  <!-- SQL input -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <div class="flex items-center justify-between mb-2">
      <label class="text-sm font-semibold">SQL Query</label>
      <div class="flex gap-2">
        <button id="load-sample" class="px-3 py-1.5 text-xs bg-surface border border-border rounded hover:border-primary transition-colors">Load Sample</button>
        <button id="clear-sql" class="px-3 py-1.5 text-xs bg-surface border border-border rounded hover:border-primary transition-colors">Clear</button>
      </div>
    </div>
    <textarea id="sql-input" rows="10" placeholder="Paste your SQL query here..." class="w-full bg-surface border border-border rounded p-3 text-sm font-mono focus:outline-none focus:border-primary resize-y min-h-[160px]" spellcheck="false"></textarea>
    <button id="analyze-btn" class="mt-3 w-full py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Analyze Query</button>
  </div>

  <!-- Results -->
  <div id="results" class="hidden">
    <!-- Complexity badge -->
    <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-semibold">Complexity Rating</h2>
        <span id="complexity-badge" class="px-3 py-1 rounded-full text-sm font-bold"></span>
      </div>
      <div class="w-full bg-surface rounded-full h-3 mb-2">
        <div id="complexity-bar" class="h-3 rounded-full transition-all"></div>
      </div>
      <p id="complexity-desc" class="text-xs text-text-muted"></p>
    </div>

    <!-- Breakdown -->
    <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
      <h2 class="text-sm font-semibold mb-3">Query Breakdown</h2>
      <div id="breakdown-grid" class="grid grid-cols-2 sm:grid-cols-4 gap-3"></div>
    </div>

    <!-- Suggestions -->
    <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
      <h2 class="text-sm font-semibold mb-3">Optimization Suggestions</h2>
      <div id="suggestions-list" class="space-y-2"></div>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SQL Query Complexity Analyzer" relatedTags={["sql", "database", "postgresql", "mysql", "performance", "optimization"]} />
</BaseLayout>

<script is:inline>
(function () {
  var SAMPLE_SQL = "WITH monthly_revenue AS (\n  SELECT\n    c.region,\n    DATE_TRUNC('month', o.created_at) AS month,\n    SUM(oi.quantity * oi.unit_price) AS revenue\n  FROM orders o\n  JOIN customers c ON c.id = o.customer_id\n  JOIN order_items oi ON oi.order_id = o.id\n  WHERE o.status = 'completed'\n    AND o.created_at >= '2024-01-01'\n  GROUP BY c.region, month\n)\nSELECT DISTINCT\n  r.region,\n  r.month,\n  r.revenue,\n  AVG(r.revenue) OVER (PARTITION BY r.region ORDER BY r.month ROWS BETWEEN 2 PRECEDING AND CURRENT ROW) AS rolling_avg,\n  (SELECT MAX(revenue) FROM monthly_revenue mr2 WHERE mr2.region = r.region) AS region_max\nFROM monthly_revenue r\nLEFT JOIN regions reg ON reg.code = r.region\nWHERE r.revenue > (SELECT AVG(revenue) FROM monthly_revenue)\nORDER BY r.region, r.month;";

  function countPattern(sql, pattern, flags){
    var re = new RegExp(pattern, flags || "gi");
    var m = sql.match(re);
    return m ? m.length : 0;
  }

  function analyze(sql){
    var up = sql.toUpperCase();

    // Basic token counting
    var joins = countPattern(sql, "\\bJOIN\\b");
    var leftJoins = countPattern(sql, "\\bLEFT\\s+(?:OUTER\\s+)?JOIN\\b");
    var rightJoins = countPattern(sql, "\\bRIGHT\\s+(?:OUTER\\s+)?JOIN\\b");
    var crossJoins = countPattern(sql, "\\bCROSS\\s+JOIN\\b");
    var subqueries = countPattern(sql, "\\(\\s*SELECT\\b");
    var ctes = countPattern(sql, "\\bWITH\\b[\\s\\S]*?\\bAS\\s*\\(");
    var cteCount = countPattern(sql, ",\\s*\\w+\\s+AS\\s*\\(");
    if(ctes > 0) cteCount += 1;
    var distinct = countPattern(sql, "\\bDISTINCT\\b");
    var groupBy = countPattern(sql, "\\bGROUP\\s+BY\\b");
    var having = countPattern(sql, "\\bHAVING\\b");
    var orderBy = countPattern(sql, "\\bORDER\\s+BY\\b");
    var whereConditions = countPattern(sql, "\\bWHERE\\b");
    var windowFns = countPattern(sql, "\\bOVER\\s*\\(");
    var unions = countPattern(sql, "\\bUNION\\b");
    var selectCount = countPattern(sql, "\\bSELECT\\b");
    var correlated = countPattern(sql, "\\(\\s*SELECT[^)]*\\bWHERE[^)]*\\b[a-z_]+\\.[a-z_]+\\s*=\\s*[a-z_]+\\.[a-z_]+");

    // Scoring (weighted)
    var score = 0;
    score += joins * 8;
    score += crossJoins * 15;
    score += (subqueries - cteCount) * 12;
    score += cteCount * 5;
    score += distinct * 6;
    score += groupBy * 5;
    score += having * 7;
    score += unions * 8;
    score += windowFns * 6;
    score += correlated * 20;
    score += (selectCount > 1 ? (selectCount - 1) * 5 : 0);
    score = Math.min(score, 100);

    var level, color, barColor, pct;
    if(score <= 15){ level="Simple"; color="text-green-400"; barColor="bg-green-500"; pct=Math.max(score/15*25,5); }
    else if(score <= 35){ level="Moderate"; color="text-yellow-400"; barColor="bg-yellow-500"; pct=25+(score-15)/20*25; }
    else if(score <= 60){ level="Complex"; color="text-orange-400"; barColor="bg-orange-500"; pct=50+(score-35)/25*25; }
    else { level="Very Complex"; color="text-red-400"; barColor="bg-red-500"; pct=75+(score-60)/40*25; }

    var descs = {
      "Simple": "Straightforward query — likely fast with proper indexes. Minimal optimizer effort needed.",
      "Moderate": "Some complexity present. Verify indexes on JOIN and WHERE columns. Review aggregation columns.",
      "Complex": "Multiple complexity factors. Use EXPLAIN ANALYZE to identify bottlenecks. Consider breaking into CTEs.",
      "Very Complex": "High complexity — significant optimization potential. Profile with EXPLAIN ANALYZE before deploying to production."
    };

    var suggestions = [];
    if(joins >= 3) suggestions.push({ icon:"&#9888;", text: joins+" JOINs detected — ensure all JOIN columns are indexed. Consider breaking into CTEs for readability." });
    if(crossJoins > 0) suggestions.push({ icon:"&#128683;", text: crossJoins+" CROSS JOIN(s) — produces a cartesian product. Confirm this is intentional; usually should be INNER JOIN." });
    if(correlated > 0) suggestions.push({ icon:"&#128683;", text: correlated+" likely correlated subquery — executes once per outer row. Rewrite as JOIN + aggregation or use a window function." });
    if(distinct >= 2) suggestions.push({ icon:"&#9888;", text: "Multiple DISTINCT clauses can indicate missing GROUP BY or duplicate data. Investigate data model." });
    if(having > 0 && groupBy === 0) suggestions.push({ icon:"&#9888;", text: "HAVING without GROUP BY is unusual. Verify query intent." });
    if(subqueries - cteCount >= 3) suggestions.push({ icon:"&#9888;", text: (subqueries-cteCount)+" nested subqueries — convert to CTEs for optimizer visibility and readability." });
    if(windowFns > 0) suggestions.push({ icon:"&#10003;", text: windowFns+" window function(s) — good choice over correlated subqueries. Ensure partition columns are indexed." });
    if(unions > 0) suggestions.push({ icon:"&#9888;", text: unions+" UNION(s) — each branch is independently executed. Use UNION ALL if duplicates are acceptable (faster)." });
    if(orderBy > 1) suggestions.push({ icon:"&#9888;", text: "Multiple ORDER BY clauses — only the outermost sort is typically needed. Inner sorts are often redundant." });
    if(suggestions.length === 0) suggestions.push({ icon:"&#10003;", text: "No major red flags detected. Profile with EXPLAIN ANALYZE on your actual database for accurate performance data." });

    return { score, level, color, barColor, pct: Math.min(pct,100), desc: descs[level],
      breakdown: { joins, leftJoins, rightJoins, crossJoins, subqueries, cteCount, distinct, groupBy, having, orderBy, windowFns, unions, whereConditions },
      suggestions };
  }

  function renderBreakdown(b){
    var items = [
      { label:"JOINs", val:b.joins, note: b.crossJoins>0?" (incl. "+b.crossJoins+" CROSS)":"" },
      { label:"Subqueries", val:b.subqueries, note:"" },
      { label:"CTEs", val:b.cteCount, note:"" },
      { label:"DISTINCT", val:b.distinct, note:"" },
      { label:"GROUP BY", val:b.groupBy, note:"" },
      { label:"HAVING", val:b.having, note:"" },
      { label:"ORDER BY", val:b.orderBy, note:"" },
      { label:"Window Fns", val:b.windowFns, note:"" },
      { label:"UNION", val:b.unions, note:"" },
      { label:"WHERE", val:b.whereConditions, note:"" }
    ];
    return items.map(function(i){
      var cls = i.val > 0 ? "text-accent font-bold" : "text-text-muted";
      return "<div class='bg-surface rounded-lg p-3 text-center'><div class='text-lg font-bold "+cls+"'>"+i.val+"</div><div class='text-xs text-text-muted'>"+i.label+(i.note?"<br><span class='text-xs'>"+i.note+"</span>":"")+"</div></div>";
    }).join("");
  }

  function run(){
    var sql = document.getElementById("sql-input").value.trim();
    if(!sql){ alert("Please paste a SQL query first."); return; }

    var r = analyze(sql);

    var badge = document.getElementById("complexity-badge");
    badge.textContent = r.level + " ("+r.score+")";
    badge.className = "px-3 py-1 rounded-full text-sm font-bold " + r.color.replace("text-","bg-").replace("-400","-400/20") + " " + r.color;

    document.getElementById("complexity-bar").style.width = r.pct + "%";
    document.getElementById("complexity-bar").className = "h-3 rounded-full transition-all " + r.barColor;
    document.getElementById("complexity-desc").textContent = r.desc;
    document.getElementById("breakdown-grid").innerHTML = renderBreakdown(r.breakdown);

    document.getElementById("suggestions-list").innerHTML = r.suggestions.map(function(s){
      var isOk = s.icon === "&#10003;";
      return "<div class='flex items-start gap-2 p-3 rounded-lg "+(isOk?"bg-green-500/10":"bg-orange-500/10")+"'>" +
        "<span class='mt-0.5 text-sm "+(isOk?"text-green-400":"text-orange-400")+"'>"+s.icon+"</span>" +
        "<span class='text-sm'>"+s.text+"</span></div>";
    }).join("");

    document.getElementById("results").classList.remove("hidden");
    document.getElementById("results").scrollIntoView({ behavior:"smooth", block:"nearest" });
  }

  document.getElementById("analyze-btn").onclick = run;
  document.getElementById("load-sample").onclick = function(){ document.getElementById("sql-input").value = SAMPLE_SQL; };
  document.getElementById("clear-sql").onclick = function(){
    document.getElementById("sql-input").value = "";
    document.getElementById("results").classList.add("hidden");
  };
  document.getElementById("sql-input").addEventListener("keydown", function(e){
    if(e.key === "Enter" && (e.ctrlKey || e.metaKey)) run();
  });
})();
</script>
