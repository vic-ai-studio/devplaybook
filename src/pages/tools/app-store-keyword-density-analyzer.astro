---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is App Store Optimization (ASO)?",
    answer: "App Store Optimization is the process of improving an app's visibility and conversion rate in the App Store and Google Play Store. It involves optimizing your app's title, subtitle, keyword field, description, screenshots, and ratings to rank higher in search results and convert more store page visitors into installs. ASO is often called 'SEO for app stores' — organic discovery is the highest-quality, lowest-cost acquisition channel for most apps."
  },
  {
    question: "How does the App Store keyword field work?",
    answer: "The App Store keyword field (iOS only) is a 100-character hidden field that tells Apple's algorithm which search terms to consider your app for. Words in the keyword field do not need to be repeated in your title or subtitle — the algorithm considers all three fields together. Use commas to separate keywords (spaces count against your limit), don't repeat words already in your title, and don't use competitor names (violates guidelines)."
  },
  {
    question: "What is keyword density and does it matter for ASO?",
    answer: "Keyword density refers to how often a keyword appears across your metadata fields (title, subtitle, description). Unlike web SEO, App Store algorithms do not reward repetition — repeating a keyword in the keyword field wastes character space. However, the title carries the most weight, subtitle carries moderate weight, and the keyword field the least. One strong placement in the title is worth more than multiple placements across less prominent fields."
  },
  {
    question: "What is the difference between App Store and Google Play metadata?",
    answer: "iOS App Store: Title (30 chars) + Subtitle (30 chars) + Keyword field (100 chars hidden). Google Play: Title (30 chars) + Short description (80 chars, visible) + Long description (4000 chars, indexed). Google Play indexes the full long description like a web page, so keyword placement within the first 250 characters of the long description is most important. There is no separate keyword field on Google Play."
  },
  {
    question: "How do I find the right keywords for my app?",
    answer: "Start with competitor research: find the top 3–5 competitors in your category and note the keywords in their titles and subtitles. Use ASO tools (AppFollow, MobileAction, Sensor Tower, AppTweak) to see keyword difficulty scores and traffic estimates. Look at search suggestion autocomplete in the App Store — these are high-intent queries. Prioritize keywords with high search volume and low competition where your app can realistically rank."
  },
  {
    question: "How often should I update my ASO metadata?",
    answer: "Revisit your keyword strategy every 4–6 weeks. Track your ranking for target keywords using an ASO tool and replace keywords where you're not ranking in the top 10 after 4+ weeks. Major updates (new features, seasonal content) warrant a metadata update. Avoid changing your title too frequently — it can temporarily hurt rankings and damages brand recognition. The keyword field and subtitle can be updated more aggressively."
  }
];
---
<BaseLayout
  title="App Store Keyword Density Analyzer: ASO Optimization Guide"
  description="Optimize your app store metadata for maximum organic discovery. Learn App Store keyword field strategy, keyword density best practices, iOS vs Google Play differences, and compare top ASO tools like AppFollow and Sensor Tower."
  tool="app-store-keyword-density-analyzer"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"App Store Keyword Density Analyzer: ASO Optimization Guide","url":"https://devplaybook.cc/tools/app-store-keyword-density-analyzer","description":"Optimize app store metadata for organic discovery. Master keyword field strategy, iOS vs Google Play differences, and ASO tools."})} />

  <h1 class="text-3xl font-bold mb-2">App Store Keyword Density Analyzer: ASO Optimization Guide</h1>
  <p class="text-text-muted mb-6">Maximize your app's organic discoverability on iOS and Google Play. Master keyword field strategy, understand keyword density rules, compare iOS vs Google Play metadata, and choose the right ASO tools for your workflow.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100-character keyword field strategy</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> iOS vs Google Play differences</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> ASO tools comparison</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Keyword research process</span>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-3">iOS App Store Metadata Structure</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 font-semibold">Field</th>
          <th class="text-left py-2 pr-4 font-semibold">Char Limit</th>
          <th class="text-left py-2 pr-4 font-semibold">Indexed?</th>
          <th class="text-left py-2 font-semibold">SEO Weight</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <tr>
          <td class="py-2 pr-4">App Name (Title)</td>
          <td class="py-2 pr-4">30 chars</td>
          <td class="py-2 pr-4">Yes</td>
          <td class="py-2 text-green-500">Highest</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">Subtitle</td>
          <td class="py-2 pr-4">30 chars</td>
          <td class="py-2 pr-4">Yes</td>
          <td class="py-2 text-yellow-500">Medium</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">Keyword Field (hidden)</td>
          <td class="py-2 pr-4">100 chars</td>
          <td class="py-2 pr-4">Yes</td>
          <td class="py-2 text-yellow-500">Lower</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">Description</td>
          <td class="py-2 pr-4">4000 chars</td>
          <td class="py-2 pr-4">No (iOS)</td>
          <td class="py-2 text-text-muted">Conversion only</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">Developer Name</td>
          <td class="py-2 pr-4">—</td>
          <td class="py-2 pr-4">Yes</td>
          <td class="py-2 text-text-muted">Low</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-3">iOS vs Google Play Metadata Differences</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 font-semibold">Feature</th>
          <th class="text-left py-2 pr-4 font-semibold">iOS App Store</th>
          <th class="text-left py-2 font-semibold">Google Play</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <tr>
          <td class="py-2 pr-4">Hidden keyword field</td>
          <td class="py-2 pr-4">Yes (100 chars)</td>
          <td class="py-2">No</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">Description indexed</td>
          <td class="py-2 pr-4">No</td>
          <td class="py-2">Yes (4000 chars)</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">Short description</td>
          <td class="py-2 pr-4">Subtitle (30 chars)</td>
          <td class="py-2">80 chars (visible + indexed)</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">Keyword update frequency</td>
          <td class="py-2 pr-4">Requires app update</td>
          <td class="py-2">Anytime (store listing)</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">Algorithm transparency</td>
          <td class="py-2 pr-4">Low</td>
          <td class="py-2">Moderate</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-3">100-Character Keyword Field Strategy</h2>
  <p class="mb-4">Your 100 characters must work hard. Follow these rules to maximize coverage:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm"># Keyword field rules:
# - Separate with commas (NOT spaces — spaces count as characters)
# - Do NOT repeat words already in your title or subtitle
# - Do NOT use competitor app names (guidelines violation)
# - Use singular OR plural — algorithm handles both
# - Use the most competitive form (shorter usually better)

# Bad keyword field (wasted characters):
# "task manager,task management app,best task manager,to do list app"
# 65 chars but "task", "manager", "app" repeated multiple times

# Good keyword field (maximum unique coverage):
# "planner,reminders,habit,tracker,organizer,notes,calendar,checklist"
# 67 chars, 8 unique keyword concepts, no repetition

# Analyze your title + subtitle + keyword field together:
TITLE: "TaskFlow - Daily Planner"          (24 chars)
SUBTITLE: "To-Do List & Habit Tracker"      (28 chars)
KEYWORDS: "reminders,organizer,notes,calendar,schedule,project,goals,routine"
# (66 chars — 34 chars remaining for additional terms)</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">ASO Tools Comparison</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 font-semibold">Tool</th>
          <th class="text-left py-2 pr-4 font-semibold">Best For</th>
          <th class="text-left py-2 pr-4 font-semibold">Pricing</th>
          <th class="text-left py-2 font-semibold">Standout Feature</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <tr>
          <td class="py-2 pr-4">AppFollow</td>
          <td class="py-2 pr-4">Review management + ASO</td>
          <td class="py-2 pr-4">From $39/mo</td>
          <td class="py-2">Review sentiment analysis</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">MobileAction</td>
          <td class="py-2 pr-4">Keyword intelligence</td>
          <td class="py-2 pr-4">Custom pricing</td>
          <td class="py-2">Largest keyword database</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">Sensor Tower</td>
          <td class="py-2 pr-4">Market intelligence</td>
          <td class="py-2 pr-4">From $79/mo</td>
          <td class="py-2">Download/revenue estimates</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">AppTweak</td>
          <td class="py-2 pr-4">Metadata optimization</td>
          <td class="py-2 pr-4">From $69/mo</td>
          <td class="py-2">Character counter + preview</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">App Store Connect</td>
          <td class="py-2 pr-4">First-party analytics</td>
          <td class="py-2 pr-4">Free</td>
          <td class="py-2">Impression & conversion data</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Google Play Long Description Optimization</h2>
  <p class="mb-4">Google Play indexes the full description. Place your primary keywords in the first 250 characters and repeat each target keyword 3–5 times naturally across the full description:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm"># Google Play description structure:
# First 250 chars = highest weight (above the fold on mobile)
# Total 4000 chars indexed as document similarity
# Target keyword density: 2-3% per major keyword

# Good structure:
# Paragraph 1 (250 chars): Primary value prop + 2-3 main keywords
# Bullet points: Feature list with natural keyword placement
# Paragraph 2: Social proof / use cases with secondary keywords
# Paragraph 3: Call to action + brand voice

# Check keyword frequency:
# Primary keyword: 4-6 times
# Secondary keywords: 2-3 times each
# Avoid stuffing — Google's algorithm penalizes unnatural density</code></pre>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="app-store-keyword-density-analyzer" relatedTags={['mobile', 'ios', 'android', 'aso', 'app-store', 'marketing', 'seo']} />
</BaseLayout>
