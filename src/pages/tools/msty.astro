---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Msty?", answer: "Msty is a cross-platform desktop AI application that lets you run and compare multiple AI models simultaneously — both local models (via Ollama, LM Studio, or other local backends) and remote cloud APIs (OpenAI, Anthropic, Groq, Gemini). Its standout feature is the ability to send the same prompt to multiple models and view responses side by side, making it ideal for model evaluation and comparison." },
  { question: "What makes Msty different from other local AI apps?", answer: "Msty's key differentiators are: (1) Multi-model comparison — run the same prompt on 2, 3, or more models simultaneously and compare responses; (2) Conversation branching — fork a conversation at any point to explore different directions; (3) Topic folders — organize conversations by project or subject; (4) Prompt library — save and reuse prompts; (5) Seamless local + remote model mixing in the same interface." },
  { question: "How does Msty connect to local models?", answer: "Msty connects to Ollama, LM Studio, Jan, LocalAI, and any other OpenAI-compatible local server. In Settings > Models, add a local provider by specifying the base URL (e.g., http://localhost:11434 for Ollama). Msty then fetches the available models and adds them to your model list alongside cloud models. No configuration files or terminal commands needed." },
  { question: "Does Msty store data locally?", answer: "Yes. Msty stores all conversation history, settings, and model configurations locally on your device. When using local AI models, no data is sent externally. When using cloud APIs (OpenAI, Anthropic), data goes to those providers under their standard privacy terms. Msty itself does not have its own backend server — it's a pure desktop app." },
  { question: "What is Msty's model comparison feature?", answer: "In Msty, you can open a 'Split View' and configure multiple model panels. Type a prompt once and it's sent to all active models simultaneously. Responses appear side by side in real time. This is invaluable for: choosing the right model for a task, comparing local vs cloud quality, evaluating model updates, and building intuition about different models' strengths." },
  { question: "Msty vs LM Studio vs Jan?", answer: "LM Studio focuses on downloading and managing GGUF models with a polished interface. Jan is open-source with an extension system and remote API support. Msty specializes in multi-model comparison and conversation management — features the others lack. If you regularly compare models or want to use both local and cloud models in one app, Msty is the best choice. For pure local model management, LM Studio or Jan may be simpler." },
];
---

<BaseLayout
  title="Msty: Local AI Desktop App with Multi-Model Support (2026)"
  description="Msty lets you run and compare multiple AI models simultaneously — local (Ollama, LM Studio) and cloud (OpenAI, Anthropic). Complete guide to installation, setup, and model comparison."
  tool="Msty, local AI desktop, multi-model AI, AI comparison tool, offline AI, local LLM, run AI locally"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"Msty: Local AI Desktop App with Multi-Model Support","url":"https://devplaybook.cc/tools/msty","description":"Msty is a desktop AI app for running and comparing multiple local and cloud models simultaneously — complete 2026 guide."})} />

  <h1 class="text-3xl font-bold mb-2">Msty: Local AI Desktop App with Multi-Model Support</h1>
  <p class="text-text-muted mb-6">Msty is a privacy-first desktop AI application built around one powerful idea: compare responses from multiple models side by side. Connect your local Ollama models, cloud APIs, or any OpenAI-compatible server — then run prompts across all of them simultaneously to find the best model for each task.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multi-model side-by-side comparison</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Local + cloud models in one interface</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Conversation branching</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No account required for local models</span>
  </div>

  <ToolPageCta />

  <!-- Installation -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Installation &amp; Setup</h2>
    <p class="text-text-muted text-sm mb-4">Msty is a standalone desktop app available for macOS, Windows, and Linux. Download from <strong>msty.app</strong> — no package manager or Docker required.</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># macOS
# Download from https://msty.app/download or:
brew install --cask msty

# Windows
# Download installer from https://msty.app/download

# Linux (AppImage)
# Download from https://msty.app/download
chmod +x Msty-*.AppImage
./Msty-*.AppImage

# After installation, connect your local backends:
# 1. Open Msty > Settings > Models > + Add Provider
# 2. Select "Ollama" — URL: http://localhost:11434
# 3. Select "LM Studio" — URL: http://localhost:1234
# 4. For cloud: add OpenAI, Anthropic, Groq API keys
# 5. Models appear in the model selector dropdown

# Prerequisites for local models:
# - Install Ollama: brew install ollama
# - Pull models: ollama pull llama3.2 mistral gemma3</code></pre>
  </div>

  <!-- Multi-model comparison -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Multi-Model Comparison</h2>
    <p class="text-text-muted text-sm mb-4">Msty's split-panel view is its defining feature. Send one prompt to multiple models and compare outputs in real time — perfect for model selection and quality evaluation:</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># How to use multi-model comparison in Msty:

# 1. Click "New Comparison" or use the split-view button
# 2. Select models for each panel, for example:
#    Panel 1: llama3.2:7b (local via Ollama)
#    Panel 2: mistral:7b (local via Ollama)
#    Panel 3: gpt-4o-mini (OpenAI cloud)
#    Panel 4: claude-3-5-haiku (Anthropic cloud)

# 3. Type your prompt once in the shared input bar
# 4. All panels respond simultaneously (streaming)

# Great comparison use cases:
# - "Write a regex to validate email addresses"
#   → compare accuracy and explanation quality
# - "Summarize this 500-word article in 3 bullet points"
#   → compare conciseness and accuracy
# - "Write a unit test for this Python function"
#   → compare code quality and coverage
# - "Explain quantum entanglement to a 10-year-old"
#   → compare clarity and creativity

# Save comparisons to reference later via the star/bookmark feature</code></pre>
  </div>

  <!-- Conversation branching -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Conversation Branching &amp; Organization</h2>
    <p class="text-text-muted text-sm mb-4">Msty lets you fork conversations at any message — useful when you want to explore different approaches without losing the original thread:</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
      <div class="border border-border rounded-lg p-4">
        <h3 class="font-semibold mb-2">Conversation Branching</h3>
        <ul class="space-y-1 text-text-muted text-xs">
          <li>• Hover over any message → click "Branch"</li>
          <li>• Creates a new conversation from that point</li>
          <li>• Original conversation remains unchanged</li>
          <li>• Branches share the same conversation history up to the fork point</li>
          <li>• Compare different follow-up directions</li>
        </ul>
      </div>
      <div class="border border-border rounded-lg p-4">
        <h3 class="font-semibold mb-2">Organization Features</h3>
        <ul class="space-y-1 text-text-muted text-xs">
          <li>• Topic folders: group chats by project</li>
          <li>• Prompt library: save &amp; reuse system prompts</li>
          <li>• Search: full-text search across all conversations</li>
          <li>• Tags: label conversations for quick filtering</li>
          <li>• Export: save conversations as Markdown or JSON</li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Comparison table -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-4">Msty vs LM Studio vs Jan</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-text-muted text-xs uppercase border-b border-border">
            <th class="text-left pb-2 pr-4">Feature</th>
            <th class="text-left pb-2 pr-4">Msty</th>
            <th class="text-left pb-2 pr-4">LM Studio</th>
            <th class="text-left pb-2">Jan</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border text-xs">
          <tr><td class="py-2 pr-4 font-medium">Multi-model comparison</td><td class="py-2 pr-4 text-green-500">Yes (core feature)</td><td class="py-2 pr-4 text-red-400">No</td><td class="py-2 text-red-400">No</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Conversation branching</td><td class="py-2 pr-4 text-green-500">Yes</td><td class="py-2 pr-4 text-red-400">No</td><td class="py-2 text-red-400">No</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Cloud API support</td><td class="py-2 pr-4 text-green-500">OpenAI, Anthropic, Groq…</td><td class="py-2 pr-4 text-yellow-500">Limited</td><td class="py-2 text-green-500">Yes</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Model management</td><td class="py-2 pr-4 text-yellow-500">Via Ollama/LM Studio</td><td class="py-2 pr-4 text-green-500">Built-in</td><td class="py-2 text-green-500">Built-in</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Open source</td><td class="py-2 pr-4 text-red-400">No</td><td class="py-2 pr-4 text-red-400">No</td><td class="py-2 text-green-500">Yes (MIT)</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Prompt library</td><td class="py-2 pr-4 text-green-500">Yes</td><td class="py-2 pr-4 text-red-400">No</td><td class="py-2 text-yellow-500">Basic</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Best for</td><td class="py-2 pr-4">Model comparison, evaluation</td><td class="py-2 pr-4">GGUF model management</td><td class="py-2">Privacy + extensibility</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Msty" relatedTags={['ai', 'llm', 'local-ai', 'multi-model', 'desktop', 'private-ai']} />
</BaseLayout>
