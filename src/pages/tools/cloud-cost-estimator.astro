---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "Is AWS Lambda cheaper than GCP Cloud Functions?",
    answer: "It depends on your workload. AWS Lambda and Azure Functions both charge $0.20 per million requests vs GCP's $0.40 — but GCP's per-GB-second compute rate ($0.0000100) is lower than AWS ($0.0000166667). For high-frequency, short-duration functions, GCP's cheaper compute rate often wins. For low-traffic or very fast functions, AWS Lambda's free tier (1M requests/month) provides the best value. Use this estimator with your actual numbers to compare."
  },
  {
    question: "How are serverless costs calculated?",
    answer: "Serverless pricing has two components: (1) Requests — charged per million invocations. (2) Compute — charged per GB-second (memory × duration in seconds). Example: 10M requests/month, 200ms avg duration, 512MB = 10M × $0.20/1M + (10M × 0.2s × 0.5GB) × $0.0000166667 = $2.00 + $16.67 = $18.67/month on AWS Lambda. Free tiers are excluded from estimates here; check each provider for current free tier limits."
  },
  {
    question: "What is included in cloud compute pricing?",
    answer: "Basic compute pricing covers CPU and RAM usage only. Additional costs not shown here include: egress bandwidth (varies by provider and region, typically $0.08–$0.12/GB after free tier), storage (S3/GCS/Blob), databases, load balancers, monitoring, and support plans. Always review the full pricing page and use provider calculators for production estimates. This tool is for quick comparison only."
  },
  {
    question: "When is a VM cheaper than serverless?",
    answer: "VMs become cost-effective when your workload runs at high utilization (>30–40% of the time). A t3.small EC2 instance at ~$15/month handles millions of requests without per-invocation charges. Serverless is optimal for spiky, unpredictable workloads or when traffic is low. A rough rule: if you'd need more than 50–100M serverless invocations/month for sustained workloads, a VM or container is likely cheaper. This estimator helps you compare both models side by side."
  },
  {
    question: "What about egress costs?",
    answer: "Egress (outbound data transfer) costs are a major hidden cost in cloud computing, not reflected in compute pricing. All three providers charge roughly $0.08–$0.12/GB after the first 100GB free/month. GCP has slightly more generous free egress to the internet than AWS. Azure charges for zone-to-zone traffic as well. For data-intensive applications (video, large API responses), egress often dominates the bill. Always factor in egress when building real cost estimates."
  }
];
---

<BaseLayout
  title="Cloud Cost Estimator — Compare AWS vs GCP vs Azure Compute Costs"
  description="Compare serverless and VM compute costs across AWS, GCP, and Azure. Estimate Lambda vs Cloud Functions vs Azure Functions, or EC2 vs Compute Engine vs Azure VMs. Uses real 2024 pricing."
  tool="Cloud Cost Estimator, AWS vs GCP vs Azure, Lambda vs Cloud Functions, serverless cost calculator, EC2 pricing, cloud compute comparison, cloud cost calculator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Cloud Cost Estimator",
    "url": "https://devplaybook.cc/tools/cloud-cost-estimator",
    "description": "Compare AWS, GCP, and Azure compute costs side by side. Estimate serverless and VM pricing with real approximate 2024 rates for quick cloud provider comparisons.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Cloud Cost Estimator</h1>
  <p class="text-text-muted mb-4">Compare AWS, GCP, and Azure compute costs side by side. Enter your workload parameters and see monthly cost estimates for serverless functions or virtual machines across all three major cloud providers.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> AWS vs GCP vs Azure side-by-side</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Serverless & VM pricing modes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Real ~2024 approximate pricing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Cheapest option highlighted</span>
  </div>

  <!-- Service type selector -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <label class="block text-sm font-medium mb-2">Service Type</label>
    <div class="flex gap-2 flex-wrap">
      <button data-mode="serverless" class="mode-btn px-4 py-2 rounded-lg text-sm font-medium border border-primary bg-primary/10 text-primary transition-colors">
        Serverless (Lambda / Cloud Functions / Azure Functions)
      </button>
      <button data-mode="vm" class="mode-btn px-4 py-2 rounded-lg text-sm font-medium border border-border text-text-muted hover:border-primary hover:text-foreground transition-colors">
        VMs (EC2 / Compute Engine / Azure VMs)
      </button>
    </div>
  </div>

  <!-- Serverless inputs -->
  <div id="serverless-inputs" class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-medium mb-4">Serverless Parameters</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <label class="block text-xs text-text-muted mb-1.5" for="requests-month">Requests / Month</label>
        <input
          id="requests-month"
          type="number"
          min="0"
          value="1000000"
          class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary"
        />
        <p class="text-xs text-text-muted mt-1">e.g. 1000000 = 1M</p>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1.5" for="avg-duration">Avg Duration (ms)</label>
        <input
          id="avg-duration"
          type="number"
          min="1"
          max="900000"
          value="200"
          class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary"
        />
        <p class="text-xs text-text-muted mt-1">Max 900,000 ms (15 min)</p>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1.5" for="memory-mb">Memory (MB)</label>
        <select
          id="memory-mb"
          class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary"
        >
          <option value="128">128 MB</option>
          <option value="256">256 MB</option>
          <option value="512" selected>512 MB</option>
          <option value="1024">1024 MB (1 GB)</option>
          <option value="2048">2048 MB (2 GB)</option>
          <option value="3008">3008 MB (3 GB)</option>
        </select>
      </div>
    </div>
  </div>

  <!-- VM inputs -->
  <div id="vm-inputs" class="hidden bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-medium mb-4">VM Parameters</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-xs text-text-muted mb-1.5">Instance Size</label>
        <div class="grid grid-cols-2 gap-2" id="instance-selector">
          <button data-size="small" class="instance-btn px-3 py-2.5 rounded-lg text-sm border border-primary bg-primary/10 text-primary text-left transition-colors">
            <div class="font-medium">Small</div>
            <div class="text-xs opacity-70">1 vCPU / 1 GB RAM</div>
          </button>
          <button data-size="medium" class="instance-btn px-3 py-2.5 rounded-lg text-sm border border-border text-text-muted text-left hover:border-primary transition-colors">
            <div class="font-medium">Medium</div>
            <div class="text-xs opacity-70">2 vCPU / 4 GB RAM</div>
          </button>
          <button data-size="large" class="instance-btn px-3 py-2.5 rounded-lg text-sm border border-border text-text-muted text-left hover:border-primary transition-colors">
            <div class="font-medium">Large</div>
            <div class="text-xs opacity-70">4 vCPU / 16 GB RAM</div>
          </button>
          <button data-size="xlarge" class="instance-btn px-3 py-2.5 rounded-lg text-sm border border-border text-text-muted text-left hover:border-primary transition-colors">
            <div class="font-medium">XLarge</div>
            <div class="text-xs opacity-70">8 vCPU / 32 GB RAM</div>
          </button>
        </div>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1.5" for="hours-month">Hours / Month</label>
        <input
          id="hours-month"
          type="number"
          min="1"
          max="744"
          value="730"
          class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary"
        />
        <p class="text-xs text-text-muted mt-1">730 hrs = full month (24/7)</p>
        <div class="flex gap-2 mt-2">
          <button onclick="document.getElementById('hours-month').value=730" class="px-2 py-1 bg-surface border border-border rounded text-xs hover:border-primary transition-colors">24/7</button>
          <button onclick="document.getElementById('hours-month').value=365" class="px-2 py-1 bg-surface border border-border rounded text-xs hover:border-primary transition-colors">50%</button>
          <button onclick="document.getElementById('hours-month').value=160" class="px-2 py-1 bg-surface border border-border rounded text-xs hover:border-primary transition-colors">Business hrs</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Calculate button -->
  <button id="btn-calculate" class="w-full sm:w-auto px-6 py-2.5 bg-primary text-white rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors mb-6">
    Calculate Costs
  </button>

  <!-- Results -->
  <div id="results" class="hidden">
    <!-- Comparison table -->
    <div class="bg-bg-card border border-border rounded-lg overflow-hidden mb-4">
      <div class="px-4 py-3 border-b border-border">
        <h2 class="text-sm font-medium">Monthly Cost Comparison</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border">
              <th class="text-left px-4 py-3 text-text-muted font-medium">Provider</th>
              <th class="text-left px-4 py-3 text-text-muted font-medium">Service</th>
              <th class="text-right px-4 py-3 text-text-muted font-medium">Monthly Cost</th>
              <th class="text-right px-4 py-3 text-text-muted font-medium">Daily Cost</th>
            </tr>
          </thead>
          <tbody id="results-tbody">
          </tbody>
        </table>
      </div>
    </div>

    <!-- Cost breakdown -->
    <div class="bg-bg-card border border-border rounded-lg mb-4">
      <button id="btn-toggle-breakdown" class="w-full flex items-center justify-between px-4 py-3 text-sm font-medium hover:bg-surface/50 transition-colors rounded-lg">
        <span>Cost Breakdown</span>
        <span id="breakdown-arrow" class="text-text-muted transition-transform">▼</span>
      </button>
      <div id="breakdown-content" class="hidden px-4 pb-4">
        <div id="breakdown-details" class="space-y-4 text-xs font-mono"></div>
      </div>
    </div>

    <!-- Disclaimer -->
    <div class="p-3 bg-yellow-500/10 border border-yellow-500/30 rounded-lg text-yellow-400 text-xs">
      <strong>Disclaimer:</strong> Prices are approximate and based on ~2024 US East region rates. Free tiers, sustained use discounts, reserved instance discounts, egress costs, storage, and other services are not included. Check each provider's official pricing pages for current, accurate rates: <span class="opacity-70">aws.amazon.com/pricing · cloud.google.com/pricing · azure.microsoft.com/pricing</span>
    </div>
  </div>

  <ToolPageCta />

  <FaqSection faqs={faq} />

  <script>
    // --- Pricing data (approximate ~2024 US-East rates) ---
    const PRICING = {
      serverless: {
        aws: {
          name: 'AWS Lambda',
          requestPricePer1M: 0.20,
          computePricePerGBs: 0.0000166667,
          freeRequestsPerMonth: 1_000_000,
          freeGBsPerMonth: 400_000
        },
        gcp: {
          name: 'GCP Cloud Functions (Gen 2)',
          requestPricePer1M: 0.40,
          computePricePerGBs: 0.0000100,
          freeRequestsPerMonth: 2_000_000,
          freeGBsPerMonth: 400_000
        },
        azure: {
          name: 'Azure Functions (Consumption)',
          requestPricePer1M: 0.20,
          computePricePerGBs: 0.000016,
          freeRequestsPerMonth: 1_000_000,
          freeGBsPerMonth: 400_000
        }
      },
      vm: {
        // hourly rates (on-demand, us-east, Linux)
        small:  { aws: { name: 'EC2 t3.small',    rate: 0.0208 }, gcp: { name: 'e2-small',        rate: 0.0170 }, azure: { name: 'B1ms',           rate: 0.0207 } },
        medium: { aws: { name: 'EC2 t3.medium',   rate: 0.0416 }, gcp: { name: 'e2-medium',       rate: 0.0335 }, azure: { name: 'B2s',            rate: 0.0416 } },
        large:  { aws: { name: 'EC2 m5.xlarge',   rate: 0.192  }, gcp: { name: 'n2-standard-4',   rate: 0.1900 }, azure: { name: 'D4s v3',         rate: 0.1920 } },
        xlarge: { aws: { name: 'EC2 m5.2xlarge',  rate: 0.384  }, gcp: { name: 'n2-standard-8',   rate: 0.3800 }, azure: { name: 'D8s v3',         rate: 0.3840 } }
      }
    };

    // --- State ---
    let currentMode = 'serverless';
    let currentInstanceSize = 'small';

    // --- Mode toggle ---
    document.querySelectorAll('.mode-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        currentMode = btn.dataset.mode;
        document.querySelectorAll('.mode-btn').forEach(b => {
          b.className = 'mode-btn px-4 py-2 rounded-lg text-sm font-medium border border-border text-text-muted hover:border-primary hover:text-foreground transition-colors';
        });
        btn.className = 'mode-btn px-4 py-2 rounded-lg text-sm font-medium border border-primary bg-primary/10 text-primary transition-colors';
        document.getElementById('serverless-inputs').classList.toggle('hidden', currentMode !== 'serverless');
        document.getElementById('vm-inputs').classList.toggle('hidden', currentMode !== 'vm');
        document.getElementById('results').classList.add('hidden');
      });
    });

    // --- Instance size selector ---
    document.querySelectorAll('.instance-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        currentInstanceSize = btn.dataset.size;
        document.querySelectorAll('.instance-btn').forEach(b => {
          b.className = 'instance-btn px-3 py-2.5 rounded-lg text-sm border border-border text-text-muted text-left hover:border-primary transition-colors';
        });
        btn.className = 'instance-btn px-3 py-2.5 rounded-lg text-sm border border-primary bg-primary/10 text-primary text-left transition-colors';
      });
    });

    // --- Breakdown toggle ---
    document.getElementById('btn-toggle-breakdown').addEventListener('click', () => {
      const content = document.getElementById('breakdown-content');
      const arrow = document.getElementById('breakdown-arrow');
      const hidden = content.classList.toggle('hidden');
      arrow.style.transform = hidden ? '' : 'rotate(180deg)';
    });

    // --- Calculate ---
    document.getElementById('btn-calculate').addEventListener('click', calculate);

    function fmt(n) {
      if (n >= 1000) return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
      if (n >= 0.01) return '$' + n.toFixed(2);
      return '$' + n.toFixed(4);
    }

    function calculate() {
      let results = [];
      let breakdowns = [];

      if (currentMode === 'serverless') {
        const requests = parseFloat(document.getElementById('requests-month').value) || 0;
        const durationMs = parseFloat(document.getElementById('avg-duration').value) || 200;
        const memoryMB = parseFloat(document.getElementById('memory-mb').value) || 512;
        const durationSec = durationMs / 1000;
        const memoryGB = memoryMB / 1024;
        const gbSeconds = requests * durationSec * memoryGB;

        ['aws', 'gcp', 'azure'].forEach(provider => {
          const p = PRICING.serverless[provider];
          // Note: not subtracting free tiers to give simple comparison
          const requestCost = (requests / 1_000_000) * p.requestPricePer1M;
          const computeCost = gbSeconds * p.computePricePerGBs;
          const total = requestCost + computeCost;
          results.push({ provider: provider.toUpperCase(), service: p.name, total, daily: total / 30 });
          breakdowns.push({
            provider: provider.toUpperCase(),
            service: p.name,
            lines: [
              `Requests: ${requests.toLocaleString()} × ${fmt(p.requestPricePer1M)}/1M = ${fmt(requestCost)}`,
              `GB-seconds: ${gbSeconds.toFixed(0)} × ${p.computePricePerGBs.toExponential(4)}/GB-s = ${fmt(computeCost)}`,
              `Total: ${fmt(total)}/month`
            ]
          });
        });
      } else {
        const hours = parseFloat(document.getElementById('hours-month').value) || 730;
        const sizeData = PRICING.vm[currentInstanceSize];
        ['aws', 'gcp', 'azure'].forEach(provider => {
          const p = sizeData[provider];
          const total = hours * p.rate;
          results.push({ provider: provider.toUpperCase(), service: p.name, total, daily: total / 30 });
          breakdowns.push({
            provider: provider.toUpperCase(),
            service: p.name,
            lines: [
              `${hours} hours × ${fmt(p.rate)}/hr = ${fmt(total)}/month`
            ]
          });
        });
      }

      // Find cheapest
      const minTotal = Math.min(...results.map(r => r.total));
      renderResults(results, minTotal, breakdowns);
    }

    function renderResults(results, minTotal, breakdowns) {
      const tbody = document.getElementById('results-tbody');
      const breakdownDetails = document.getElementById('breakdown-details');
      tbody.innerHTML = '';
      breakdownDetails.innerHTML = '';

      const providerColors = { AWS: 'text-orange-400', GCP: 'text-blue-400', AZURE: 'text-sky-400' };

      results.forEach(r => {
        const isCheapest = r.total === minTotal;
        const tr = document.createElement('tr');
        tr.className = `border-b border-border last:border-0 ${isCheapest ? 'bg-green-500/10' : ''}`;
        tr.innerHTML = `
          <td class="px-4 py-3 font-medium ${providerColors[r.provider] || ''}">
            ${r.provider}
            ${isCheapest ? '<span class="ml-2 px-1.5 py-0.5 text-xs bg-green-500/20 text-green-400 rounded">Cheapest</span>' : ''}
          </td>
          <td class="px-4 py-3 text-text-muted text-xs">${escapeHtml(r.service)}</td>
          <td class="px-4 py-3 text-right font-mono font-medium ${isCheapest ? 'text-green-400' : ''}">${fmt(r.total)}</td>
          <td class="px-4 py-3 text-right font-mono text-text-muted text-xs">${fmt(r.daily)}</td>
        `;
        tbody.appendChild(tr);
      });

      breakdowns.forEach(b => {
        const div = document.createElement('div');
        div.className = 'border-l-2 border-border pl-3 space-y-1';
        div.innerHTML = `<div class="font-medium text-xs text-foreground mb-1">${escapeHtml(b.provider)} — ${escapeHtml(b.service)}</div>`;
        b.lines.forEach(line => {
          const p = document.createElement('p');
          p.className = 'text-text-muted';
          p.textContent = line;
          div.appendChild(p);
        });
        breakdownDetails.appendChild(div);
      });

      document.getElementById('results').classList.remove('hidden');
    }

    function escapeHtml(str) {
      return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    // Auto-calculate on load
    calculate();
  </script>
</BaseLayout>
