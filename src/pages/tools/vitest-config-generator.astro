---
import BaseLayout from '../../layouts/BaseLayout.astro';
import VitestConfigGenerator from '../../components/VitestConfigGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is Vitest and why should I use it over Jest?",
    answer: "Vitest is a Vite-powered test framework compatible with Jest's API. It's significantly faster (uses native ES modules, no transpilation), has first-class TypeScript support, integrates natively with Vite, and shares your vite.config.ts configuration. If you're using Vite, Vitest is the natural choice. If you're not using Vite, it's still faster than Jest for TypeScript projects because it skips the babel/ts-jest setup."
  },
  {
    question: "Which test environment should I choose?",
    answer: "Use node (default) for backend code, utilities, and APIs — it's the fastest. Use jsdom for React/Vue/Angular component tests — it simulates a browser DOM in Node.js. Use happy-dom for the same purpose as jsdom but with better performance (less complete browser compatibility). Use edge-runtime for Cloudflare Workers or Vercel Edge Functions."
  },
  {
    question: "What's the difference between v8 and istanbul coverage?",
    answer: "v8 uses Node.js's built-in V8 coverage engine — it's fast and requires no instrumentation (install @vitest/coverage-v8). istanbul instruments your code by injecting counters — it's slower but more accurate, especially for complex code paths (install @vitest/coverage-istanbul). For most projects, v8 is sufficient. Use istanbul if you need precise branch coverage on complex conditional logic."
  },
  {
    question: "Should I enable globals: true?",
    answer: "globals: true injects describe, it, expect, beforeEach, etc. globally — you don't need to import them in test files, matching Jest behavior. The tradeoff is that these global variables aren't type-checked unless you add @types/vitest to your tsconfig.json types array. For new projects, explicit imports (import { describe, it, expect } from 'vitest') are more explicit and don't require any extra setup."
  },
  {
    question: "How do I run only specific tests in Vitest?",
    answer: "Use it.only() or test.only() to run a single test. Use describe.only() for a block. Run vitest -t 'test name pattern' to filter by name. Use vitest run --reporter=verbose for detailed output. Vitest also has a UI mode: npx vitest --ui gives you a browser-based test explorer with real-time test results."
  },
  {
    question: "How do I integrate Vitest with CI/CD?",
    answer: "Run vitest run (not vitest watch) in CI to execute once and exit. Add --reporter=junit to generate a JUnit XML report for CI dashboards. Add --coverage to generate coverage reports. Use --coverage.thresholds to fail the build if coverage drops. Example: vitest run --reporter=junit --coverage --outputFile=test-results.xml"
  },
];
---

<BaseLayout
  title="Vitest Config Generator — Build vitest.config.ts Visually"
  description="Generate a complete vitest.config.ts visually. Configure test environment, coverage provider, reporters, path aliases, and timeouts. Copy ready-to-use Vitest configuration. Free, runs in your browser."
  tool="Vitest Config Generator, vitest.config.ts, Vitest Setup, Vitest Coverage, Jest Alternative, Vite Testing"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Vitest Config Generator",
    "url": "https://devplaybook.cc/tools/vitest-config-generator",
    "description": "Generate a complete vitest.config.ts visually. Configure test environment (node/jsdom/happy-dom), coverage provider, reporters, thresholds, and path aliases.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Vitest Configuration Generator</h1>
  <p class="text-text-muted mb-4">
    Build a complete <code class="text-accent font-mono">vitest.config.ts</code> visually.
    Choose your test environment, configure coverage with thresholds, set up reporters, and copy the
    ready-to-use config. Works with Vite, Next.js, and Node.js projects.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> node / jsdom / happy-dom / edge-runtime</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> v8 + istanbul coverage</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Coverage thresholds</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Outputs vitest.config.ts</span>
  </div>
  <VitestConfigGenerator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Vitest Config Generator" relatedTags={['typescript', 'testing', 'vitest', 'javascript', 'vite', 'development']} />
</BaseLayout>
