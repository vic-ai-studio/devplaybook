---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CsvEditor from '../../components/CsvEditor.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="CSV Editor — Edit, Sort & Filter CSV Online"
  description="Edit CSV files directly in your browser. Upload or paste CSV data, then edit cells inline, sort columns, filter rows, add/delete rows and columns, and export back to CSV, TSV, or JSON. No install needed."
  tool="CSV Editor, CSV Viewer, CSV Formatter, Online CSV Tool, Edit CSV Online"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "CSV Editor",
    "url": "https://devplaybook.cc/tools/csv-editor",
    "description": "Free online CSV editor. Upload or paste CSV to edit cells, sort columns, filter rows, and export.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">CSV Editor</h1>
  <p class="text-text-muted mb-8">
    Upload or paste CSV data to edit it as a live table — no spreadsheet software needed.
    Click any cell to edit, sort by column header, filter rows by keyword, add or delete rows and columns, and export back to CSV or TSV.
    Pro: export to JSON and view per-column statistics (min, max, mean, unique count).
  </p>
  <CsvEditor client:load />
  <ToolPageCta currentTool="CSV Editor" relatedTags={['csv', 'json', 'data', 'formatting', 'development']} />
</BaseLayout>
