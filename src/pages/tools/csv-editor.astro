---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CsvEditor from '../../components/CsvEditor.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "Can I edit large CSV files?", answer: "Yes. The editor handles CSV files up to thousands of rows. For very large files (100k+ rows), paste a representative sample to avoid browser memory limits." },
  { question: "What delimiters are supported?", answer: "Comma (,), tab (\\t), semicolon (;), and pipe (|) are all supported. The editor auto-detects the delimiter when you paste data." },
  { question: "Does the editor send my data anywhere?", answer: "No. All processing is entirely client-side in your browser. Your CSV data never leaves your device." },
  { question: "Can I add or delete rows and columns?", answer: "Yes. You can add rows at the bottom, insert columns, delete selected rows, and reorder columns by dragging the headers." },
  { question: "What export formats are available?", answer: "You can export your edited data as CSV (comma-separated), TSV (tab-separated), or JSON array of objects." },
];
---

<BaseLayout
  title="CSV Editor — Edit, Sort, Filter & Export CSV in Your Browser"
  description="Free online CSV editor. Edit cells inline, sort columns, filter rows, add/delete rows and columns, and export to CSV, TSV, or JSON. No signup. Runs entirely in your browser."
  tool="CSV Editor, CSV Table Editor, Online CSV Editor, Edit CSV Online, CSV to JSON"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">CSV Editor</h1>
  <p class="text-text-muted mb-4">Edit CSV files directly in your browser. Inline cell editing, sort columns, filter rows, add/delete rows and columns, and export to CSV, TSV, or JSON. All processing client-side — your data stays private.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Inline cell editing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Sort & filter columns</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Export CSV / TSV / JSON</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Client-side only</span>
  </div>
  <CsvEditor client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CSV Editor" relatedTags={['csv', 'data', 'json', 'converter', 'spreadsheet']} />
</BaseLayout>
