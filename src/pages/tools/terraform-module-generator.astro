---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is a Terraform module?", answer: "A Terraform module is a container for multiple resources that are used together. Every Terraform configuration has at least one module (the root module). Child modules encapsulate and reuse infrastructure patterns — for example, a VPC module that creates a VPC, subnets, route tables, and security groups together. Modules let you abstract complexity, enforce standards, and share infrastructure code across teams." },
  { question: "What files does a Terraform module need?", answer: "A minimal module requires three files: main.tf (resource definitions), variables.tf (input variable declarations), and outputs.tf (output value declarations). You should also add versions.tf (provider and Terraform version constraints) and README.md for documentation. This generator scaffolds main.tf, variables.tf, and outputs.tf with proper HCL syntax." },
  { question: "What is the difference between variables and outputs in Terraform?", answer: "Variables (inputs) are parameters you pass into a module to customize its behavior — like an instance type or region. Outputs are values the module exposes after resources are created — like a created resource's ID or ARN. Outputs let parent modules or other configurations consume values from child modules using module.module_name.output_name syntax." },
  { question: "How do I use this generated module in my Terraform configuration?", answer: "Copy each generated file into a subdirectory (e.g., modules/my-module/). Then reference it from your root module with: module \"my_module\" { source = \"./modules/my-module\" variable_name = \"value\" }. Run terraform init to initialize the module, then terraform plan to preview changes." },
  { question: "What variable types does Terraform support?", answer: "Terraform supports: string (text), number (integer or float), bool (true/false), list(type) (ordered list), map(type) (key-value pairs), set(type) (unordered unique values), object({}) (structured object with named attributes), and any (dynamic type). The most common are string, number, bool, and list(string)." },
];
---

<BaseLayout
  title="Terraform Module Generator — HCL Scaffolder for AWS, GCP, Azure"
  description="Generate Terraform module scaffolding instantly. Input your module name, provider, resource type, and variables to get ready-to-use main.tf, variables.tf, and outputs.tf HCL code."
  tool="Terraform Module Generator, HCL Scaffolder, Terraform IaC Generator, AWS Terraform Module, GCP Terraform Template, Azure Terraform Module"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Terraform Module Generator",
    "description": "Generate Terraform HCL module scaffolding for AWS, GCP, and Azure. Produces main.tf, variables.tf, and outputs.tf instantly.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Terraform Module Generator</h1>
  <p class="text-text-muted mb-4">Scaffold a Terraform module in seconds. Fill in your module details and variables, then copy production-ready HCL for <code class="font-mono text-sm">main.tf</code>, <code class="font-mono text-sm">variables.tf</code>, and <code class="font-mono text-sm">outputs.tf</code>.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> AWS / GCP / Azure</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Variables + Outputs</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-ready HCL</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs in your browser</span>
  </div>

  <!-- Module Config -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Module Configuration</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium mb-1.5" for="module-name">Module Name</label>
        <input id="module-name" type="text" placeholder="e.g. vpc, s3-bucket, rds-cluster"
          value="my-module"
          class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5" for="provider-select">Cloud Provider</label>
        <select id="provider-select" class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="aws">AWS</option>
          <option value="google">GCP</option>
          <option value="azurerm">Azure</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5" for="resource-type">Primary Resource Type</label>
        <input id="resource-type" type="text" placeholder="e.g. aws_s3_bucket, google_compute_instance"
          value="aws_s3_bucket"
          class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5" for="resource-name">Resource Logical Name</label>
        <input id="resource-name" type="text" placeholder="e.g. main, this, primary"
          value="main"
          class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
    </div>
  </div>

  <!-- Variables Builder -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-base font-semibold">Input Variables</h2>
      <button id="add-var-btn" class="flex items-center gap-1.5 text-sm px-3 py-1.5 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Add Variable
      </button>
    </div>
    <div id="variables-list" class="space-y-3"></div>
  </div>

  <!-- Outputs Builder -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-base font-semibold">Outputs</h2>
      <button id="add-out-btn" class="flex items-center gap-1.5 text-sm px-3 py-1.5 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Add Output
      </button>
    </div>
    <div id="outputs-list" class="space-y-3"></div>
  </div>

  <button id="generate-btn" class="w-full bg-primary text-white px-4 py-3 rounded-lg hover:bg-primary/90 font-semibold text-sm mb-5 transition-colors">
    Generate Terraform Module
  </button>

  <!-- Generated Output -->
  <div id="output-section" class="space-y-4 hidden mb-5">
    <!-- main.tf -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <span class="font-mono text-sm font-semibold text-primary">main.tf</span>
        <button class="copy-btn text-xs px-3 py-1.5 bg-bg-surface border border-border rounded-lg hover:border-primary hover:text-primary transition-colors" data-target="out-main">Copy</button>
      </div>
      <pre id="out-main" class="font-mono text-sm bg-bg-surface rounded-lg p-4 overflow-x-auto text-text-muted whitespace-pre"></pre>
    </div>
    <!-- variables.tf -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <span class="font-mono text-sm font-semibold text-primary">variables.tf</span>
        <button class="copy-btn text-xs px-3 py-1.5 bg-bg-surface border border-border rounded-lg hover:border-primary hover:text-primary transition-colors" data-target="out-vars">Copy</button>
      </div>
      <pre id="out-vars" class="font-mono text-sm bg-bg-surface rounded-lg p-4 overflow-x-auto text-text-muted whitespace-pre"></pre>
    </div>
    <!-- outputs.tf -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <span class="font-mono text-sm font-semibold text-primary">outputs.tf</span>
        <button class="copy-btn text-xs px-3 py-1.5 bg-bg-surface border border-border rounded-lg hover:border-primary hover:text-primary transition-colors" data-target="out-outputs">Copy</button>
      </div>
      <pre id="out-outputs" class="font-mono text-sm bg-bg-surface rounded-lg p-4 overflow-x-auto text-text-muted whitespace-pre"></pre>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Terraform Module Generator" relatedTags={['terraform', 'iac', 'devops', 'aws', 'infrastructure']} />
</BaseLayout>

<script>
  var varCounter = 0;
  var outCounter = 0;

  function escHtml(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function addVariable(name, type, desc, def) {
    varCounter++;
    var id = 'var-' + varCounter;
    var html = '<div id="' + id + '" class="grid grid-cols-1 sm:grid-cols-4 gap-2 items-start bg-bg-surface border border-border rounded-lg p-3">' +
      '<input type="text" placeholder="Variable name" value="' + escHtml(name || '') + '" class="var-name bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />' +
      '<select class="var-type bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">' +
      ['string','number','bool','list(string)','map(string)','any'].map(function(t) {
        return '<option value="' + t + '"' + (t === (type || 'string') ? ' selected' : '') + '>' + t + '</option>';
      }).join('') +
      '</select>' +
      '<input type="text" placeholder="Description" value="' + escHtml(desc || '') + '" class="var-desc bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />' +
      '<div class="flex gap-2">' +
      '<input type="text" placeholder="Default (optional)" value="' + escHtml(def || '') + '" class="var-default flex-1 bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />' +
      '<button class="remove-row text-red-400 hover:text-red-300 px-2" data-id="' + id + '">✕</button>' +
      '</div>' +
      '</div>';
    var list = document.getElementById('variables-list');
    var div = document.createElement('div');
    div.innerHTML = html;
    list.appendChild(div.firstChild);
    document.querySelector('#' + id + ' .remove-row').addEventListener('click', function() {
      document.getElementById(id).remove();
    });
  }

  function addOutput(name, value, desc) {
    outCounter++;
    var id = 'out-' + outCounter;
    var html = '<div id="' + id + '" class="grid grid-cols-1 sm:grid-cols-3 gap-2 items-start bg-bg-surface border border-border rounded-lg p-3">' +
      '<input type="text" placeholder="Output name" value="' + escHtml(name || '') + '" class="out-name bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />' +
      '<input type="text" placeholder="Value expression" value="' + escHtml(value || '') + '" class="out-value bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />' +
      '<div class="flex gap-2">' +
      '<input type="text" placeholder="Description" value="' + escHtml(desc || '') + '" class="out-desc flex-1 bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />' +
      '<button class="remove-row text-red-400 hover:text-red-300 px-2" data-id="' + id + '">✕</button>' +
      '</div>' +
      '</div>';
    var list = document.getElementById('outputs-list');
    var div = document.createElement('div');
    div.innerHTML = html;
    list.appendChild(div.firstChild);
    document.querySelector('#' + id + ' .remove-row').addEventListener('click', function() {
      document.getElementById(id).remove();
    });
  }

  function getVars() {
    var rows = document.querySelectorAll('#variables-list > div');
    var result = [];
    rows.forEach(function(row) {
      result.push({
        name: row.querySelector('.var-name').value.trim(),
        type: row.querySelector('.var-type').value,
        desc: row.querySelector('.var-desc').value.trim(),
        def: row.querySelector('.var-default').value.trim()
      });
    });
    return result.filter(function(v) { return v.name; });
  }

  function getOuts() {
    var rows = document.querySelectorAll('#outputs-list > div');
    var result = [];
    rows.forEach(function(row) {
      result.push({
        name: row.querySelector('.out-name').value.trim(),
        value: row.querySelector('.out-value').value.trim(),
        desc: row.querySelector('.out-desc').value.trim()
      });
    });
    return result.filter(function(o) { return o.name; });
  }

  function generate() {
    var modName = document.getElementById('module-name').value.trim() || 'my-module';
    var provider = document.getElementById('provider-select').value;
    var resType = document.getElementById('resource-type').value.trim() || 'aws_s3_bucket';
    var resName = document.getElementById('resource-name').value.trim() || 'main';
    var vars = getVars();
    var outs = getOuts();

    // main.tf
    var mainLines = [
      'terraform {',
      '  required_providers {',
      '    ' + provider + ' = {',
      '      source  = "hashicorp/' + provider + '"',
      '      version = ">= 5.0"',
      '    }',
      '  }',
      '  required_version = ">= 1.5.0"',
      '}',
      '',
      '# ' + modName + ' — ' + resType,
      'resource "' + resType + '" "' + resName + '" {',
    ];
    vars.forEach(function(v) {
      mainLines.push('  ' + v.name.replace(/-/g,'_') + ' = var.' + v.name.replace(/-/g,'_'));
    });
    if (vars.length === 0) {
      mainLines.push('  # Add resource arguments here');
    }
    mainLines.push('}');

    // variables.tf
    var varLines = [];
    vars.forEach(function(v) {
      varLines.push('variable "' + v.name.replace(/-/g,'_') + '" {');
      varLines.push('  description = "' + (v.desc || v.name) + '"');
      varLines.push('  type        = ' + v.type);
      if (v.def) {
        var isStr = v.type === 'string';
        varLines.push('  default     = ' + (isStr ? '"' + v.def + '"' : v.def));
      }
      varLines.push('}');
      varLines.push('');
    });
    if (vars.length === 0) {
      varLines.push('# No variables defined. Add some above.');
    }

    // outputs.tf
    var outLines = [];
    outs.forEach(function(o) {
      outLines.push('output "' + o.name.replace(/-/g,'_') + '" {');
      if (o.desc) outLines.push('  description = "' + o.desc + '"');
      outLines.push('  value       = ' + (o.value || resType + '.' + resName + '.id'));
      outLines.push('}');
      outLines.push('');
    });
    if (outs.length === 0) {
      outLines.push('output "id" {');
      outLines.push('  description = "The ID of the ' + resType + ' resource"');
      outLines.push('  value       = ' + resType + '.' + resName + '.id');
      outLines.push('}');
    }

    document.getElementById('out-main').textContent = mainLines.join('\n');
    document.getElementById('out-vars').textContent = varLines.join('\n');
    document.getElementById('out-outputs').textContent = outLines.join('\n');
    document.getElementById('output-section').classList.remove('hidden');
  }

  // Seed defaults
  addVariable('bucket_name', 'string', 'Name of the S3 bucket', '');
  addVariable('environment', 'string', 'Deployment environment (dev/staging/prod)', 'dev');
  addOutput('bucket_id', 'aws_s3_bucket.main.id', 'The ID of the created bucket');
  addOutput('bucket_arn', 'aws_s3_bucket.main.arn', 'The ARN of the created bucket');

  document.getElementById('add-var-btn').addEventListener('click', function() { addVariable('','string','',''); });
  document.getElementById('add-out-btn').addEventListener('click', function() { addOutput('','',''); });
  document.getElementById('generate-btn').addEventListener('click', generate);

  document.querySelectorAll('.copy-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var target = btn.getAttribute('data-target');
      var text = document.getElementById(target).textContent;
      navigator.clipboard.writeText(text).then(function() {
        btn.textContent = 'Copied!';
        setTimeout(function() { btn.textContent = 'Copy'; }, 2000);
      });
    });
  });

  generate();
</script>
