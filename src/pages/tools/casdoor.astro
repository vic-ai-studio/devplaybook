---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const dockerExample = `# Casdoor — Docker with SQLite (dev)
docker run -d \
  --name casdoor \
  -p 8000:8000 \
  casbin/casdoor:latest

# Production with PostgreSQL
docker run -d \
  --name casdoor \
  -p 8000:8000 \
  -e driverName=postgres \
  -e dataSourceName="host=postgres user=casdoor password=casdoor dbname=casdoor sslmode=disable" \
  casbin/casdoor:latest

# Admin UI: http://localhost:8000
# Default credentials: admin / 123`;

const sdkExample = `// Node.js SDK — Casdoor OIDC integration
import { SDK } from 'casdoor-nodejs-sdk';

const config = {
  endpoint: 'https://auth.example.com',
  clientId: 'your-client-id',
  clientSecret: 'your-client-secret',
  certificate: '-----BEGIN CERTIFICATE-----\n...Casdoor public cert...',
  orgName: 'my-organization',
  appName: 'my-app',
};

const sdk = new SDK(config);

// Get OAuth login URL
const loginUrl = sdk.getAuthorizationUrl();

// Exchange code for token (after OAuth callback)
const tokenResponse = await sdk.getOAuthToken(code);
const userInfo = await sdk.parseJwtToken(tokenResponse.access_token);

// Get all users (admin API)
const users = await sdk.getUsers();`;

const reactExample = `// React — Casdoor login with SDK
import Casdoor from 'casdoor-js-sdk';

const casdoor = new Casdoor({
  serverUrl: 'https://auth.example.com',
  clientId: 'your-client-id',
  appName: 'my-app',
  organizationName: 'my-org',
  redirectPath: '/callback',
  signinPath: '/api/signin',
});

function LoginButton() {
  return (
    <button onClick={() => window.location.href = casdoor.getSigninUrl()}>
      Sign In with Casdoor
    </button>
  );
}

// Callback page
function CallbackPage() {
  const { code, state } = useSearchParams();
  useEffect(() => {
    casdoor.signin(code, state).then(token => {
      localStorage.setItem('token', token.access_token);
      navigate('/dashboard');
    });
  }, []);
}`;

const faq = [
  { question: "What is Casdoor?", answer: "Casdoor is an open-source identity platform (SSO/OAuth2 identity server) built by the Casbin team — the creators of the popular Casbin authorization library. It provides a web-based UI for user management, SSO with OIDC and OAuth 2.0, social login, LDAP federation, and multi-organization support. Casdoor is designed to be simpler to deploy than Keycloak while still supporting enterprise features, and integrates naturally with Casbin for fine-grained authorization policies." },
  { question: "How does Casdoor relate to Casbin?", answer: "Casbin and Casdoor are separate but complementary projects from the same team. Casbin is an authorization library (does user A have permission to do action B on resource C?) supporting role-based, attribute-based, and custom policy models. Casdoor handles authentication (who are you?). Used together: Casdoor authenticates users and issues JWT tokens with user roles; Casbin enforces authorization policies in your application using those roles. This separation of AuthN and AuthZ is architecturally clean." },
  { question: "What databases does Casdoor support?", answer: "Casdoor supports SQLite (development), MySQL, PostgreSQL, SQL Server, CockroachDB, and TiDB for its user and application data. The default development setup uses SQLite with no configuration needed. For production, PostgreSQL is recommended. Casdoor also supports LDAP user federation — it can authenticate users against an existing Active Directory or OpenLDAP server without migrating users to its own database." },
  { question: "What social login providers does Casdoor support?", answer: "Casdoor supports a wide range of social login providers: Google, GitHub, Microsoft, Facebook, Apple, Twitter, LinkedIn, WeChat, QQ, DingTalk, Lark/Feishu, Weibo, Gitee, Gitea, GitLab, Bitbucket, Discord, Twitch, Steam, BaiduCloud, Alipay, and custom OIDC/OAuth2 providers. The wide Chinese platform support (WeChat, QQ, DingTalk, Alipay) makes Casdoor particularly popular for applications targeting Chinese users or companies." },
  { question: "How does Casdoor handle multi-tenancy?", answer: "Casdoor's multi-tenancy model uses Organizations and Applications. An Organization is a tenant (a company, department, or customer). Each organization has its own users, groups, and roles. Applications belong to an organization and define the OAuth2 client configuration (redirect URIs, grant types, allowed providers). Users authenticate against a specific organization's application. This model supports scenarios where each of your customers has their own user pool and SSO configuration." },
  { question: "What is Casdoor's approach to passwordless login?", answer: "Casdoor supports email/SMS one-time codes, TOTP-based 2FA (Google Authenticator, Authy), WebAuthn passkeys, and magic link authentication. Users can be required to enroll in MFA at first login via configurable enrollment policies. For enterprise SSO, users can authenticate entirely through their corporate OIDC provider (no Casdoor password needed), making Casdoor fully passwordless for those users. The MFA policies are configurable per organization and application." },
];
---

<BaseLayout
  title="Casdoor — Open-Source SSO and OAuth2 Identity Platform"
  description="Casdoor is an open-source identity server from the Casbin team. SSO, OAuth 2.0, OIDC, social login, LDAP federation, and multi-org support with a modern web UI."
  tool="Casdoor SSO identity server, OAuth2 OIDC Casdoor, Casbin authorization, social login open-source, Casdoor Docker, multi-org identity platform"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Casdoor — Open-Source SSO and OAuth2 Identity Platform",
    "url": "https://devplaybook.cc/tools/casdoor",
    "description": "Casdoor is an open-source SSO/identity server from the Casbin team. OIDC, OAuth 2.0, social login, LDAP, and multi-organization support.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Casdoor</h1>
  <p class="text-text-muted mb-6">
    An <strong>open-source SSO and identity platform</strong> from the Casbin team. Casdoor provides
    OAuth 2.0, OIDC, SAML, social login (including WeChat, DingTalk, and Alipay), LDAP federation,
    and multi-organization support — with a clean web UI and SDKs for Node.js, Go, Python, Java, and React.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> OIDC + OAuth 2.0 + SAML</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 30+ social login providers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Casbin authorization integration</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Open source (Apache 2.0)</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Casdoor?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Casdoor is an authentication server (who are you?) designed as the companion to Casbin (what can you do?). Together, they provide a complete AuthN + AuthZ solution. Casdoor handles user registration, social login, SSO, and token issuance. Casbin enforces access policies using the JWT claims from Casdoor tokens in your application backend.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    Casdoor is notable for its <strong>extensive social login support</strong> — particularly Chinese platforms like WeChat, QQ, DingTalk, Alipay, and Weibo — and for its straightforward Docker deployment. It aims to be easier to operate than Keycloak while covering most enterprise SSO requirements.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Quick Start (Docker)</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={dockerExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Node.js SDK</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={sdkExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">React Integration</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={reactExample}></pre>

  <ToolPageCta />
  <FaqSection faqs={faq} />
</BaseLayout>
