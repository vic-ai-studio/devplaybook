---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GitignoreGenerator from '../../components/GitignoreGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title=".gitignore Generator — Free Online Tool"
  description="Generate .gitignore files for Node.js, Python, React, Java, Go, Rust, .NET, and Docker. Select your project type, add extras (VS Code, macOS, Windows), and download instantly."
  tool=".gitignore Generator, gitignore template, ignore file generator"
>
  <h1 class="text-3xl font-bold mb-2">.gitignore Generator</h1>
  <p class="text-text-muted mb-8">Select your project type and any extra patterns to generate a clean <code>.gitignore</code> file. Covers Node.js, Python, React, Java, Go, Rust, .NET, and Docker — plus IDE and OS extras. Fully client-side.</p>
  <GitignoreGenerator client:only="preact" />
  <ToolPageCta currentTool=".gitignore Generator" relatedTags={['git', 'gitignore', 'devops', 'node', 'python']} />
</BaseLayout>
