---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GitignoreGenerator from '../../components/GitignoreGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a .gitignore file?",
    answer: "A .gitignore file tells Git which files and directories to ignore in a repository. Files listed in .gitignore are not tracked by Git and won't appear in git status, git add, or commits. This keeps build artifacts, secrets, and editor config out of your version history."
  },
  {
    question: "Can I combine multiple stacks in one .gitignore?",
    answer: "Yes — and it's common. Monorepos and full-stack projects often need patterns from Node.js, Python, Docker, and multiple editors all in one file. Select multiple stacks with this tool and it will merge all relevant patterns with clear section comments."
  },
  {
    question: "What is the difference between a .gitignore and global gitignore?",
    answer: "A repository .gitignore applies only to that project and is committed to source control. A global gitignore (configured with git config --global core.excludesfile) applies to all repos on your machine and is ideal for editor files like .DS_Store, .vscode/, and Thumbs.db that are personal and shouldn't be shared."
  },
  {
    question: "Should I commit .gitignore to the repository?",
    answer: "Yes. The project-level .gitignore should be committed so all contributors share the same ignore rules. Editor-specific and OS-specific patterns (like .DS_Store or .idea/) are best placed in your global gitignore instead of the project file."
  },
  {
    question: "Why isn't my file being ignored even though it's in .gitignore?",
    answer: "Git won't ignore files that are already tracked. If you added a file before creating the .gitignore rule, you need to untrack it first: run git rm --cached <file> and then commit. After that, Git will respect the .gitignore rule."
  },
  {
    question: "What does a ** pattern mean in .gitignore?",
    answer: "A double asterisk (**) matches any number of directories. For example, **/logs matches a logs/ directory anywhere in the repo tree. logs/** matches everything inside the top-level logs/ directory. **/*.log matches all .log files at any depth."
  },
];
---

<BaseLayout
  title=".gitignore Generator — Free Multi-Stack .gitignore Builder"
  description="Generate .gitignore files for Node.js, Python, Go, Rust, Java, and more. Combine multiple stacks, add IDE and OS extras, then copy or download instantly. Runs entirely in your browser."
  tool=".gitignore Generator, gitignore template, ignore file generator, multi-stack gitignore"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": ".gitignore Generator",
    "url": "https://devplaybook.cc/tools/gitignore-generator",
    "description": "Generate .gitignore files for Node.js, Python, Go, Rust, Java, and more. Combine multiple stacks, add IDE and OS extras, then copy or download instantly.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">.gitignore Generator</h1>
  <p class="text-text-muted mb-4">
    Select one or more project types to generate a combined <code class="font-mono bg-surface px-1 rounded text-sm">.gitignore</code> file.
    Covers Node.js, Python, React, Java, Go, Rust, .NET, Docker, and more — plus IDE and OS extras. Fully client-side.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Combine multiple stacks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> One-click copy & download</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <GitignoreGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool=".gitignore Generator" relatedTags={['git', 'gitignore', 'devops', 'node', 'python']} />
</BaseLayout>
