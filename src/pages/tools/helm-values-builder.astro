---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a Helm values.yaml file?", answer: "values.yaml is the default configuration file for a Helm chart. It defines all the configurable parameters with their default values. When you run helm install or helm upgrade, Helm merges your custom values on top of these defaults. Child charts can have their own values.yaml, and you can override them from the parent." },
  { question: "How do I override values during install?", answer: "Use --set for single values: helm install myapp ./mychart --set image.tag=v2.0. Use -f or --values for a full values file: helm install myapp ./mychart -f prod-values.yaml. Multiple -f flags are merged left to right, with later files taking precedence. --set always takes highest precedence." },
  { question: "What is the difference between resources.requests and resources.limits?", answer: "requests is what the scheduler uses to find a node with enough capacity. Kubernetes guarantees the pod will get at least this much. limits is the maximum the container can consume — if it exceeds CPU limit it gets throttled; if it exceeds memory limit it gets OOMKilled. Set requests close to typical usage and limits to handle bursts." },
  { question: "When should I use a Deployment vs StatefulSet in values.yaml?", answer: "Deployments are for stateless workloads — pods are interchangeable and can be recreated anywhere. StatefulSets are for stateful apps (databases, message queues) that need stable network identities and persistent storage. If you need ordered rolling updates and persistent volume claims per pod, use StatefulSet." },
  { question: "What are common patterns for environment variables in values.yaml?", answer: "env: is typically a list of {name, value} pairs passed directly to the container. envFrom: mounts an entire ConfigMap or Secret as environment variables. For secrets, use secretKeyRef instead of plain values. Use extraEnv: or env: depending on the chart convention to inject per-environment overrides." },
  { question: "How do I enable ingress in values.yaml?", answer: "Set ingress.enabled: true and configure ingress.host to your domain. Also set ingress.className (e.g. nginx or traefik) to match your cluster's ingress controller. Annotations like kubernetes.io/ingress.class or cert-manager.io/cluster-issuer are added under ingress.annotations. Enable TLS with ingress.tls for HTTPS." },
];
---

<BaseLayout
  title="Helm Values Builder — Generate values.yaml Snippets for Common Config"
  description="Build Helm values.yaml configuration snippets with a visual form. Set image, replicas, resources, environment variables, ingress, service, probes, and autoscaling. Generates copy-ready YAML. Free, runs in your browser."
  tool="Helm values.yaml generator, Helm chart values builder, Kubernetes Helm config, Helm values snippet, Helm chart configuration"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Helm Values Builder",
    "url": "https://devplaybook.cc/tools/helm-values-builder",
    "description": "Build Helm values.yaml configuration snippets with a visual form. Set image, replicas, resources, environment variables, ingress, service, probes, and autoscaling.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Helm Values Builder</h1>
  <p class="text-text-muted mb-6">
    Generate <strong>Helm values.yaml</strong> snippets for common configuration patterns.
    Configure image, replicas, resources, environment variables, ingress, and more — then copy the YAML.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Image & replicas</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Resource limits</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Env vars & ingress</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-ready YAML</span>
  </div>

  <div id="builder-app" class="space-y-5">
    <!-- Image -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="text-sm font-semibold mb-3 text-text-muted uppercase tracking-wide">Image</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
        <div>
          <label class="block text-sm font-medium mb-1">Repository</label>
          <input id="image-repo" type="text" value="nginx" placeholder="nginx" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Tag</label>
          <input id="image-tag" type="text" value="1.25.3" placeholder="latest" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Pull Policy</label>
          <select id="pull-policy" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary">
            <option>IfNotPresent</option>
            <option>Always</option>
            <option>Never</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Replicas & Resources -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="text-sm font-semibold mb-3 text-text-muted uppercase tracking-wide">Replicas & Resources</h2>
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-3">
        <div class="sm:col-span-1">
          <label class="block text-sm font-medium mb-1">Replicas</label>
          <input id="replicas" type="number" value="2" min="1" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">CPU Request</label>
          <input id="cpu-req" type="text" value="100m" placeholder="100m" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">CPU Limit</label>
          <input id="cpu-lim" type="text" value="500m" placeholder="500m" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Mem Request</label>
          <input id="mem-req" type="text" value="128Mi" placeholder="128Mi" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Mem Limit</label>
          <input id="mem-lim" type="text" value="512Mi" placeholder="512Mi" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
        </div>
      </div>
    </div>

    <!-- Service -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="text-sm font-semibold mb-3 text-text-muted uppercase tracking-wide">Service</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
        <div>
          <label class="block text-sm font-medium mb-1">Service Type</label>
          <select id="svc-type" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary">
            <option>ClusterIP</option>
            <option>NodePort</option>
            <option>LoadBalancer</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Service Port</label>
          <input id="svc-port" type="number" value="80" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Container Port</label>
          <input id="container-port" type="number" value="8080" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
        </div>
      </div>
    </div>

    <!-- Ingress -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center gap-3 mb-3">
        <h2 class="text-sm font-semibold text-text-muted uppercase tracking-wide">Ingress</h2>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input id="enable-ingress" type="checkbox" checked class="rounded border-border" />
          Enable
        </label>
      </div>
      <div id="ingress-fields" class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div>
          <label class="block text-sm font-medium mb-1">Host</label>
          <input id="ingress-host" type="text" value="app.example.com" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Ingress Class</label>
          <input id="ingress-class" type="text" value="nginx" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
        </div>
        <label class="flex items-center gap-2 text-sm cursor-pointer col-span-2">
          <input id="enable-tls" type="checkbox" checked class="rounded border-border" />
          Enable TLS
        </label>
      </div>
    </div>

    <!-- Env vars -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="text-sm font-semibold mb-3 text-text-muted uppercase tracking-wide">Environment Variables</h2>
      <div id="env-list" class="space-y-2 mb-3"></div>
      <button id="add-env-btn" class="text-sm text-primary hover:underline">+ Add variable</button>
    </div>

    <!-- Options -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="text-sm font-semibold mb-3 text-text-muted uppercase tracking-wide">Options</h2>
      <div class="flex flex-wrap gap-4">
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input id="enable-hpa" type="checkbox" class="rounded border-border" />
          Horizontal Pod Autoscaler
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input id="enable-probes" type="checkbox" checked class="rounded border-border" />
          Liveness &amp; Readiness Probes
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input id="enable-sa" type="checkbox" class="rounded border-border" />
          Service Account
        </label>
      </div>
    </div>

    <button id="build-btn" class="px-6 py-2.5 bg-primary text-white font-medium rounded-lg hover:bg-primary/90 transition-colors text-sm">
      Generate values.yaml
    </button>

    <!-- Output -->
    <div id="output-section" class="hidden">
      <div class="flex justify-between items-center mb-2">
        <h2 class="text-base font-semibold">Generated values.yaml</h2>
        <button id="copy-btn" class="text-xs px-3 py-1.5 bg-surface-2 hover:bg-surface-3 rounded-lg border border-border transition-colors">Copy</button>
      </div>
      <pre id="yaml-output" class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text"></pre>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Helm Values Builder" relatedTags={['helm', 'kubernetes', 'devops', 'containers', 'k8s']} />
</BaseLayout>

<script>
  // Env var rows
  let envCount = 0;
  function addEnvRow(name = '', value = '') {
    envCount++;
    const id = `env-${envCount}`;
    const div = document.createElement('div');
    div.className = 'flex gap-2';
    div.innerHTML = `
      <input data-role="env-name" type="text" value="${name}" placeholder="KEY" class="flex-1 bg-bg border border-border rounded-lg px-3 py-1.5 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary" />
      <input data-role="env-value" type="text" value="${value}" placeholder="value" class="flex-1 bg-bg border border-border rounded-lg px-3 py-1.5 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary" />
      <button onclick="this.parentElement.remove()" class="text-text-muted hover:text-red-400 text-sm px-2">✕</button>
    `;
    document.getElementById('env-list')?.appendChild(div);
  }

  addEnvRow('NODE_ENV', 'production');
  addEnvRow('LOG_LEVEL', 'info');

  document.getElementById('add-env-btn')?.addEventListener('click', () => addEnvRow());

  document.getElementById('enable-ingress')?.addEventListener('change', (e) => {
    (document.getElementById('ingress-fields') as HTMLElement).style.opacity = (e.target as HTMLInputElement).checked ? '1' : '0.4';
  });

  function buildYaml(): string {
    const repo = (document.getElementById('image-repo') as HTMLInputElement).value.trim() || 'nginx';
    const tag = (document.getElementById('image-tag') as HTMLInputElement).value.trim() || 'latest';
    const pullPolicy = (document.getElementById('pull-policy') as HTMLSelectElement).value;
    const replicas = (document.getElementById('replicas') as HTMLInputElement).value || '2';
    const cpuReq = (document.getElementById('cpu-req') as HTMLInputElement).value.trim() || '100m';
    const cpuLim = (document.getElementById('cpu-lim') as HTMLInputElement).value.trim() || '500m';
    const memReq = (document.getElementById('mem-req') as HTMLInputElement).value.trim() || '128Mi';
    const memLim = (document.getElementById('mem-lim') as HTMLInputElement).value.trim() || '512Mi';
    const svcType = (document.getElementById('svc-type') as HTMLSelectElement).value;
    const svcPort = (document.getElementById('svc-port') as HTMLInputElement).value || '80';
    const containerPort = (document.getElementById('container-port') as HTMLInputElement).value || '8080';
    const ingressEnabled = (document.getElementById('enable-ingress') as HTMLInputElement).checked;
    const ingressHost = (document.getElementById('ingress-host') as HTMLInputElement).value.trim() || 'app.example.com';
    const ingressClass = (document.getElementById('ingress-class') as HTMLInputElement).value.trim() || 'nginx';
    const tlsEnabled = (document.getElementById('enable-tls') as HTMLInputElement).checked;
    const hpaEnabled = (document.getElementById('enable-hpa') as HTMLInputElement).checked;
    const probesEnabled = (document.getElementById('enable-probes') as HTMLInputElement).checked;
    const saEnabled = (document.getElementById('enable-sa') as HTMLInputElement).checked;

    // Collect env vars
    const envRows = Array.from(document.querySelectorAll('#env-list > div'));
    const envVars = envRows.map(row => ({
      name: (row.querySelector('[data-role="env-name"]') as HTMLInputElement)?.value.trim(),
      value: (row.querySelector('[data-role="env-value"]') as HTMLInputElement)?.value.trim(),
    })).filter(e => e.name);

    const lines: string[] = [];
    lines.push(`replicaCount: ${replicas}`);
    lines.push('');
    lines.push('image:');
    lines.push(`  repository: ${repo}`);
    lines.push(`  tag: "${tag}"`);
    lines.push(`  pullPolicy: ${pullPolicy}`);
    lines.push('');
    lines.push('service:');
    lines.push(`  type: ${svcType}`);
    lines.push(`  port: ${svcPort}`);
    lines.push(`  targetPort: ${containerPort}`);
    lines.push('');
    lines.push('resources:');
    lines.push('  requests:');
    lines.push(`    cpu: "${cpuReq}"`);
    lines.push(`    memory: "${memReq}"`);
    lines.push('  limits:');
    lines.push(`    cpu: "${cpuLim}"`);
    lines.push(`    memory: "${memLim}"`);

    if (envVars.length > 0) {
      lines.push('');
      lines.push('env:');
      envVars.forEach(e => {
        lines.push(`  - name: ${e.name}`);
        lines.push(`    value: "${e.value}"`);
      });
    }

    if (probesEnabled) {
      lines.push('');
      lines.push('livenessProbe:');
      lines.push('  httpGet:');
      lines.push('    path: /healthz');
      lines.push(`    port: ${containerPort}`);
      lines.push('  initialDelaySeconds: 30');
      lines.push('  periodSeconds: 10');
      lines.push('');
      lines.push('readinessProbe:');
      lines.push('  httpGet:');
      lines.push('    path: /ready');
      lines.push(`    port: ${containerPort}`);
      lines.push('  initialDelaySeconds: 5');
      lines.push('  periodSeconds: 5');
    }

    lines.push('');
    lines.push('ingress:');
    lines.push(`  enabled: ${ingressEnabled}`);
    if (ingressEnabled) {
      lines.push(`  className: "${ingressClass}"`);
      lines.push('  annotations: {}');
      lines.push('  hosts:');
      lines.push(`    - host: ${ingressHost}`);
      lines.push('      paths:');
      lines.push('        - path: /');
      lines.push('          pathType: ImplementationSpecific');
      if (tlsEnabled) {
        lines.push('  tls:');
        lines.push('    - secretName: tls-secret');
        lines.push(`      hosts:`);
        lines.push(`        - ${ingressHost}`);
      }
    }

    if (hpaEnabled) {
      lines.push('');
      lines.push('autoscaling:');
      lines.push('  enabled: true');
      lines.push('  minReplicas: 2');
      lines.push('  maxReplicas: 10');
      lines.push('  targetCPUUtilizationPercentage: 80');
    }

    if (saEnabled) {
      lines.push('');
      lines.push('serviceAccount:');
      lines.push('  create: true');
      lines.push('  name: ""');
      lines.push('  annotations: {}');
    }

    return lines.join('\n');
  }

  document.getElementById('build-btn')?.addEventListener('click', () => {
    const yaml = buildYaml();
    const output = document.getElementById('yaml-output') as HTMLElement;
    output.textContent = yaml;
    document.getElementById('output-section')?.classList.remove('hidden');
  });

  document.getElementById('copy-btn')?.addEventListener('click', () => {
    const text = (document.getElementById('yaml-output') as HTMLElement).textContent || '';
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById('copy-btn') as HTMLButtonElement;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
    });
  });
</script>
