---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Rolldown?", answer: "Rolldown is a next-generation JavaScript bundler built with Rust and the oxc (Oxidation Compiler) toolkit. It is designed to be the eventual replacement for Rollup inside Vite, delivering near-identical output semantics but dramatically faster build times due to Rust's multi-threaded processing and zero-cost abstractions." },
  { question: "How does Rolldown compare to Rollup?", answer: "Rolldown is designed to be API-compatible with Rollup. It supports the same plugin API (Rollup plugin hooks) and produces equivalent output. The key difference is speed: Rolldown is typically 10-100x faster than Rollup on large codebases because it runs in Rust instead of JavaScript. Rolldown also has built-in tree-shaking and code-splitting." },
  { question: "Rolldown vs esbuild — what is the difference?", answer: "esbuild is a fast bundler written in Go, optimised for speed over output fidelity. Rolldown is written in Rust and designed to produce webpack/Rollup-quality output (advanced tree-shaking, fine-grained code-splitting, full ESM semantics). Choose esbuild for simple, ultra-fast bundles; choose Rolldown when you need Rollup-level correctness and plugin compatibility." },
  { question: "When should I use Rolldown?", answer: "Rolldown is best suited for: library authors who want Rollup-compatible output at higher speed; teams planning to migrate to Vite 6+ (which will use Rolldown internally); projects that rely on Rollup plugins and want to keep that ecosystem while gaining Rust speed. For application bundling today, Vite (Rolldown-based) is the recommended path." },
  { question: "What output formats does Rolldown support?", answer: "Rolldown supports ESM (esm), CommonJS (cjs), IIFE (iife), UMD (umd), and AMD (amd) formats. ESM is the modern default for libraries and browser modules. CJS is required for Node.js compatibility. IIFE/UMD are useful for browser scripts loaded via a script tag." },
  { question: "How do I use Rolldown today?", answer: "Install with: npm install rolldown. Then create rolldown.config.js and run npx rolldown. Note that Rolldown is still under active development and stabilizing its API. For production use, check the current release status on the rolldown.rs website." },
];
---

<BaseLayout
  title="Rolldown Config Builder — Generate rolldown.config.js for Vite's Rust Bundler"
  description="Free Rolldown config generator. Set input, output dir, format (esm/cjs/iife/umd), sourcemap, minify, externals and globals — get a ready-to-use rolldown.config.js in seconds."
  tool="Rolldown config generator, rolldown.config.js builder, Vite Rust bundler, Rolldown vs Rollup, oxc bundler config"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Rolldown Config Builder",
    "url": "https://devplaybook.cc/tools/rolldown-config-builder",
    "description": "Generate rolldown.config.js visually with support for multiple output formats, sourcemaps, minification, and externals.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Rolldown Config Builder</h1>
  <p class="text-text-muted mb-4">Generate a <code class="bg-surface px-1 rounded text-sm">rolldown.config.js</code> for Vite's next-generation Rust-powered bundler. Configure input, output format, source maps, minification, external packages and UMD globals — then copy the config.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Rollup-compatible API</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Rust-powered speed</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> ESM / CJS / IIFE / UMD</span>
  </div>

  <div class="space-y-6">
    <div class="bg-surface border border-border rounded-xl p-5 space-y-5">
      <h2 class="text-sm font-semibold mb-1 text-text-muted uppercase tracking-wide">Configuration</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="rd-input" class="block text-sm font-medium mb-1.5">Input File</label>
          <input id="rd-input" type="text" placeholder="./src/index.js"
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-accent" />
        </div>
        <div>
          <label for="rd-outdir" class="block text-sm font-medium mb-1.5">Output Directory</label>
          <input id="rd-outdir" type="text" placeholder="./dist"
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-accent" />
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="rd-format" class="block text-sm font-medium mb-1.5">Output Format</label>
          <select id="rd-format" class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent">
            <option value="esm">esm (ES Module)</option>
            <option value="cjs">cjs (CommonJS)</option>
            <option value="iife">iife (Browser script)</option>
            <option value="umd">umd (Universal)</option>
          </select>
        </div>
        <div id="rd-name-wrap">
          <label for="rd-name" class="block text-sm font-medium mb-1.5">Library Name (for iife/umd)</label>
          <input id="rd-name" type="text" placeholder="MyLib"
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-accent" />
        </div>
      </div>

      <div>
        <label for="rd-externals" class="block text-sm font-medium mb-1.5">External Packages <span class="text-text-muted font-normal">(comma-separated)</span></label>
        <input id="rd-externals" type="text" placeholder="react, react-dom, lodash"
          class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-accent" />
      </div>

      <div id="rd-globals-wrap">
        <label for="rd-globals" class="block text-sm font-medium mb-1.5">UMD Globals <span class="text-text-muted font-normal">(format: pkg=GlobalName, comma-separated)</span></label>
        <input id="rd-globals" type="text" placeholder="react=React, react-dom=ReactDOM"
          class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-accent" />
      </div>

      <div class="flex flex-wrap gap-5">
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="rd-sourcemap" class="accent-accent" /> Source Map
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="rd-minify" class="accent-accent" /> Minify
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="rd-treeshake" checked class="accent-accent" /> Tree-shaking
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="rd-experimental" class="accent-accent" /> Experimental (Vite 6 plugin mode)
        </label>
      </div>

      <button id="rd-generate" class="bg-accent hover:bg-accent/80 text-white font-medium px-5 py-2 rounded-lg text-sm transition-colors">
        Generate Config
      </button>
    </div>

    <div class="bg-surface border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <label class="text-sm font-medium">rolldown.config.js</label>
        <button id="rd-copy" class="text-xs bg-background border border-border hover:bg-accent/20 px-3 py-1 rounded-lg transition-colors">Copy</button>
      </div>
      <pre id="rd-output" class="bg-background border border-border rounded-lg px-4 py-3 text-xs font-mono overflow-x-auto whitespace-pre leading-relaxed min-h-[180px]"></pre>
      <p class="text-xs text-text-muted mt-2">Install: <code class="bg-background px-1 rounded">npm install rolldown</code>. Run: <code class="bg-background px-1 rounded">npx rolldown</code>.</p>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Rolldown Config Builder" relatedTags={['build-tools', 'bundler', 'vite', 'javascript', 'typescript']} />
</BaseLayout>

<script>
(function() {
  function el(id) { return document.getElementById(id); }

  function generate() {
    var input = (el('rd-input') as HTMLInputElement).value.trim() || './src/index.js';
    var outdir = (el('rd-outdir') as HTMLInputElement).value.trim() || './dist';
    var format = (el('rd-format') as HTMLSelectElement).value;
    var libName = (el('rd-name') as HTMLInputElement).value.trim() || 'MyLib';
    var externalsRaw = (el('rd-externals') as HTMLInputElement).value.trim();
    var globalsRaw = (el('rd-globals') as HTMLInputElement).value.trim();
    var sourceMap = (el('rd-sourcemap') as HTMLInputElement).checked;
    var minify = (el('rd-minify') as HTMLInputElement).checked;
    var treeshake = (el('rd-treeshake') as HTMLInputElement).checked;
    var experimental = (el('rd-experimental') as HTMLInputElement).checked;

    var externals = externalsRaw ? externalsRaw.split(',').map(function(s) { return s.trim(); }).filter(Boolean) : [];

    var globalsMap = {};
    if (globalsRaw) {
      globalsRaw.split(',').forEach(function(pair) {
        var parts = pair.split('=');
        if (parts.length === 2) {
          globalsMap[parts[0].trim()] = parts[1].trim();
        }
      });
    }

    var lines = [];
    lines.push("import { defineConfig } from 'rolldown';");
    lines.push("");
    lines.push("export default defineConfig({");
    lines.push("  input: '" + input + "',");
    lines.push("  output: {");
    lines.push("    dir: '" + outdir + "',");
    lines.push("    format: '" + format + "',");
    if (format === 'iife' || format === 'umd') {
      lines.push("    name: '" + libName + "',");
    }
    if (sourceMap) {
      lines.push("    sourcemap: true,");
    }
    if (minify) {
      lines.push("    minify: true,");
    }
    if ((format === 'umd' || format === 'iife') && Object.keys(globalsMap).length > 0) {
      lines.push("    globals: " + JSON.stringify(globalsMap, null, 6).replace(/\n/g, '\n    ') + ",");
    }
    lines.push("  },");

    if (externals.length > 0) {
      lines.push("  external: " + JSON.stringify(externals) + ",");
    }

    if (!treeshake) {
      lines.push("  treeshake: false,");
    }

    if (experimental) {
      lines.push("  // Vite 6+ plugin mode (experimental)");
      lines.push("  // plugins: [rolldownPlugin()],");
    }

    lines.push("});");

    el('rd-output').textContent = lines.join('\n');
  }

  function updateGlobalsVisibility() {
    var format = (el('rd-format') as HTMLSelectElement).value;
    var show = format === 'umd' || format === 'iife';
    (el('rd-globals-wrap') as HTMLElement).style.display = show ? '' : 'none';
    (el('rd-name-wrap') as HTMLElement).style.display = show ? '' : 'none';
  }

  el('rd-generate').addEventListener('click', generate);
  el('rd-format').addEventListener('change', function() { updateGlobalsVisibility(); generate(); });
  ['rd-input','rd-outdir','rd-name','rd-externals','rd-globals'].forEach(function(id) {
    el(id).addEventListener('input', generate);
  });
  ['rd-sourcemap','rd-minify','rd-treeshake','rd-experimental'].forEach(function(id) {
    el(id).addEventListener('change', generate);
  });

  el('rd-copy').addEventListener('click', function() {
    var text = el('rd-output').textContent;
    navigator.clipboard.writeText(text).then(function() {
      var btn = el('rd-copy');
      btn.textContent = 'Copied!';
      setTimeout(function() { btn.textContent = 'Copy'; }, 1500);
    });
  });

  // Set defaults
  (el('rd-input') as HTMLInputElement).value = './src/index.js';
  (el('rd-outdir') as HTMLInputElement).value = './dist';
  (el('rd-name') as HTMLInputElement).value = 'MyLib';
  updateGlobalsVisibility();
  generate();
})();
</script>
