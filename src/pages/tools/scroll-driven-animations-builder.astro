---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollDrivenAnimationsBuilder from '../../components/ScrollDrivenAnimationsBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What are CSS Scroll-Driven Animations?", answer: "Scroll-Driven Animations let you tie CSS animations to scroll position instead of time. As the user scrolls, animation progress advances. No JavaScript, no IntersectionObserver, no GSAP — just CSS. There are two timeline types: scroll() (tied to a container's scroll position) and view() (tied to an element's visibility in the viewport)." },
  { question: "What is animation-timeline?", answer: "animation-timeline is a CSS property that replaces the default time-based progression with a scroll-based one. Set it to scroll() to link the animation to a scroll container's position, or view() to link it to the element's position within the viewport. You can target specific scrollable ancestors with scroll(nearest) or scroll(self)." },
  { question: "What is animation-range?", answer: "animation-range controls which part of the scroll timeline maps to the 0%–100% of the animation. With view(), you can use entry (element entering viewport), exit (leaving), or cover (fully covered). For example: animation-range: entry 0% entry 100% plays the animation as the element scrolls into view." },
  { question: "What does animation-timeline: view() do?", answer: "view() creates a timeline based on the element's visibility in the scroll container (by default, the viewport). The timeline starts when the element begins to appear and ends when it fully disappears. Combined with animation-range, you can trigger animations precisely as elements enter or exit the screen." },
  { question: "Should I use animation-timeline: scroll() or view()?", answer: "Use scroll() when you want an animation tied to scroll progress of a container — like a progress bar at the top of the page. Use view() when you want an element to animate as it becomes visible — like a card fading in as you scroll past it. For most 'scroll-reveal' effects, view() is what you want." },
];
---

<BaseLayout
  title="CSS Scroll-Driven Animations Builder — animation-timeline Generator"
  description="Generate CSS Scroll-Driven Animations code with animation-timeline, animation-range, and @keyframes. Choose scroll() or view() timelines, configure range presets, and preview the animation live."
  tool="Scroll-Driven Animations CSS, animation-timeline, scroll progress animation, CSS scroll reveal"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">CSS Scroll-Driven Animations Builder</h1>
  <p class="text-text-muted mb-4">
    Create scroll-triggered animations with the native CSS Scroll-Driven Animations API — no JavaScript required.
    Configure <code>animation-timeline</code>, <code>animation-range</code>, and <code>@keyframes</code>, then copy the generated CSS.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <ScrollDrivenAnimationsBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CSS Scroll-Driven Animations Builder" relatedTags={['css', 'animation', 'scroll', 'scroll-driven', 'animation-timeline', 'frontend']} />
</BaseLayout>
