---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What are Roman numerals?", answer: "Roman numerals are a numeral system originating in ancient Rome that uses letters from the Latin alphabet to represent numbers: I=1, V=5, X=10, L=50, C=100, D=500, M=1000. They were the standard writing system for numbers in Europe throughout the Middle Ages and are still used today for clock faces, book chapter numbers, movie sequel titles, Super Bowl editions, and year copyrights in formal contexts." },
  { question: "How does subtractive notation work?", answer: "Roman numerals use subtractive notation for six combinations: IV=4, IX=9, XL=40, XC=90, CD=400, CM=900. Instead of writing IIII for 4, you write IV (1 before 5 = 5-1 = 4). The rule: a smaller value numeral placed before a larger one means subtraction. Only I, X, and C can be used subtractively, and only before the next two higher values (I before V and X, X before L and C, C before D and M). IIIIX is invalid; only one smaller numeral can precede a larger one." },
  { question: "What is the largest standard Roman numeral?", answer: "The standard Roman numeral system without extensions represents numbers from 1 to 3,999. MMM=3000, CM=900, XC=90, IX=9 → MMMCMXCIX = 3,999. Numbers from 4,000 onward traditionally use a vinculum (overline) to multiply by 1,000, but this is rarely used in modern contexts. Roman numerals have no representation for zero or negative numbers." },
  { question: "Where are Roman numerals used today?", answer: "Roman numerals are used in: clock faces (especially analog clocks), Super Bowl and Olympic Games numbering (Super Bowl LVIII), monarchs and popes (King Charles III, Pope Francis I), movie sequels (Rocky II, The Godfather Part III), book preface page numbering (pages i, ii, iii), year of production on film credits (MMXXIV = 2024), chapter numbers in formal documents, and outline numbering in legal and academic writing." },
];
---

<BaseLayout
  title="Roman Numeral Converter — Numbers to Roman Numerals and Back"
  description="Convert integers to Roman numerals and decode Roman numerals back to numbers. Supports 1 to 3,999 with step-by-step breakdown."
  tool="Roman numeral converter, integer to Roman numerals, Roman numerals to numbers, decode Roman numerals, MMXXIV year converter"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Roman Numeral Converter",
    "url": "https://devplaybook.cc/tools/roman-numeral-converter",
    "description": "Convert integers to Roman numerals and back. Supports 1 to 3,999 with step-by-step breakdown.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Roman Numeral Converter</h1>
  <p class="text-text-muted mb-6">
    Convert integers to <strong>Roman numerals</strong> and decode Roman numerals back to integers.
    Supports 1 to 3,999 with a step-by-step conversion breakdown.
  </p>

  <div class="grid md:grid-cols-2 gap-6 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold mb-3">Integer → Roman</h3>
      <div class="flex gap-2 mb-3">
        <input type="number" id="intInput" min="1" max="3999" value="2024"
          class="flex-1 bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary" />
        <button id="convertToRoman" class="px-4 py-2 bg-primary text-white rounded-lg text-sm hover:bg-primary/90 transition-colors">Convert</button>
      </div>
      <div id="romanResult" class="text-4xl font-bold text-primary font-mono mb-3"></div>
      <div id="romanBreakdown" class="text-xs text-text-muted font-mono leading-relaxed"></div>
    </div>

    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold mb-3">Roman → Integer</h3>
      <div class="flex gap-2 mb-3">
        <input type="text" id="romanInput" value="MMXXIV" placeholder="e.g. XLII"
          class="flex-1 bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono uppercase focus:outline-none focus:ring-2 focus:ring-primary" />
        <button id="convertToInt" class="px-4 py-2 bg-primary text-white rounded-lg text-sm hover:bg-primary/90 transition-colors">Decode</button>
      </div>
      <div id="intResult" class="text-4xl font-bold text-primary font-mono mb-3"></div>
      <div id="intBreakdown" class="text-xs text-text-muted font-mono leading-relaxed"></div>
    </div>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Roman Numeral Reference</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-6 font-semibold">Symbol</th>
          <th class="text-left py-2 pr-6 font-semibold">Value</th>
          <th class="text-left py-2 pr-6 font-semibold">Symbol</th>
          <th class="text-left py-2 pr-6 font-semibold">Value</th>
          <th class="text-left py-2 pr-6 font-semibold">Symbol</th>
          <th class="text-left py-2 font-semibold">Value</th>
        </tr>
      </thead>
      <tbody class="text-text-muted font-mono">
        <tr class="border-b border-border/50"><td class="py-1.5 pr-6 font-bold text-primary">I</td><td class="py-1.5 pr-6">1</td><td class="py-1.5 pr-6 font-bold text-primary">X</td><td class="py-1.5 pr-6">10</td><td class="py-1.5 pr-6 font-bold text-primary">C</td><td class="py-1.5">100</td></tr>
        <tr class="border-b border-border/50"><td class="py-1.5 pr-6 font-bold text-primary">IV</td><td class="py-1.5 pr-6">4</td><td class="py-1.5 pr-6 font-bold text-primary">XL</td><td class="py-1.5 pr-6">40</td><td class="py-1.5 pr-6 font-bold text-primary">CD</td><td class="py-1.5">400</td></tr>
        <tr class="border-b border-border/50"><td class="py-1.5 pr-6 font-bold text-primary">V</td><td class="py-1.5 pr-6">5</td><td class="py-1.5 pr-6 font-bold text-primary">L</td><td class="py-1.5 pr-6">50</td><td class="py-1.5 pr-6 font-bold text-primary">D</td><td class="py-1.5">500</td></tr>
        <tr class="border-b border-border/50"><td class="py-1.5 pr-6 font-bold text-primary">IX</td><td class="py-1.5 pr-6">9</td><td class="py-1.5 pr-6 font-bold text-primary">XC</td><td class="py-1.5 pr-6">90</td><td class="py-1.5 pr-6 font-bold text-primary">CM</td><td class="py-1.5">900</td></tr>
        <tr><td class="py-1.5 pr-6 font-bold text-primary">M</td><td class="py-1.5">1000</td></tr>
      </tbody>
    </table>
  </div>

  <ToolPageCta />
  <FaqSection faqs={faq} />
</BaseLayout>

<script>
const MAP: [number, string][] = [
  [1000,'M'],[900,'CM'],[500,'D'],[400,'CD'],[100,'C'],[90,'XC'],
  [50,'L'],[40,'XL'],[10,'X'],[9,'IX'],[5,'V'],[4,'IV'],[1,'I']
];

function toRoman(n: number): {result: string, steps: string[]} {
  if (n < 1 || n > 3999) return {result:'Out of range (1-3999)', steps:[]};
  let result = '';
  const steps: string[] = [];
  let rem = n;
  for (const [val, sym] of MAP) {
    while (rem >= val) { result += sym; steps.push(`${rem} ≥ ${val} → add ${sym} (${rem}-${val}=${rem-val})`); rem -= val; }
  }
  return {result, steps};
}

function fromRoman(s: string): {result: number, steps: string[]} {
  const vals: Record<string,number> = {I:1,V:5,X:10,L:50,C:100,D:500,M:1000};
  const upper = s.toUpperCase().replace(/[^IVXLCDM]/g,'');
  let total = 0;
  const steps: string[] = [];
  for (let i = 0; i < upper.length; i++) {
    const cur = vals[upper[i]];
    const next = vals[upper[i+1]];
    if (!cur) { steps.push(`Unknown symbol: ${upper[i]}`); continue; }
    if (next && cur < next) {
      steps.push(`${upper[i]}${upper[i+1]}: ${next}-${cur} = +${next-cur}`);
      total += next - cur; i++;
    } else {
      steps.push(`${upper[i]}: +${cur}`);
      total += cur;
    }
  }
  return {result: total, steps};
}

document.getElementById('convertToRoman')?.addEventListener('click', () => {
  const n = parseInt((document.getElementById('intInput') as HTMLInputElement).value);
  const {result, steps} = toRoman(n);
  (document.getElementById('romanResult') as HTMLElement).textContent = result;
  (document.getElementById('romanBreakdown') as HTMLElement).textContent = steps.join('\n');
});
document.getElementById('convertToInt')?.addEventListener('click', () => {
  const s = (document.getElementById('romanInput') as HTMLInputElement).value;
  const {result, steps} = fromRoman(s);
  (document.getElementById('intResult') as HTMLElement).textContent = result > 0 ? String(result) : 'Invalid';
  (document.getElementById('intBreakdown') as HTMLElement).textContent = steps.join('\n');
});

// Auto-run on load
(document.getElementById('convertToRoman') as HTMLButtonElement).click();
(document.getElementById('convertToInt') as HTMLButtonElement).click();
</script>
