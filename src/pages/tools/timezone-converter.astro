---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TimezoneConverter from '../../components/TimezoneConverter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Timezone Converter"
  description="Convert times across multiple timezones at once. Live world clock, pick any date, add or remove zones, and copy results instantly. No signup required."
  tool="Timezone Converter, World Clock, Time Zone Converter, UTC Converter"
>
  <h1 class="text-3xl font-bold mb-2">Timezone Converter</h1>
  <p class="text-text-muted mb-8">Convert a date and time across multiple timezones simultaneously. Live clock, pick your source timezone, add any destination zones, and copy results in one click.</p>
  <TimezoneConverter client:only="preact" />
  <ToolPageCta currentTool="Timezone Converter" relatedTags={['time', 'timezone', 'utc', 'clock', 'productivity']} />
</BaseLayout>
