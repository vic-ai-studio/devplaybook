---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TypescriptToJs from "../../components/TypescriptToJs.tsx";
import ToolPageCta from "../../components/ToolPageCta.astro";
import FaqSection from "../../components/FaqSection.astro";

const faq = [
  { question: "What TypeScript syntax does this tool strip?", answer: "This tool removes TypeScript-specific syntax that has no JavaScript equivalent: type annotations (:string, :number), interface and type declarations, generic parameters (<T>), access modifiers (public, private, protected), readonly, abstract, enum declarations, and non-null assertion operators (!)." },
  { question: "Does this tool compile TypeScript to JavaScript?", answer: "No — it strips TypeScript syntax without compiling or transpiling. This means it does not convert ES6+ syntax (like optional chaining or class fields) to older JavaScript. For full TS compilation, use the TypeScript compiler (tsc) or a bundler like Vite or esbuild." },
  { question: "When would I use this tool?", answer: "Useful when you want to quickly understand what the runtime JavaScript looks like for a TypeScript snippet, or when you need a plain JS version of a function to paste into a non-TS environment. Also helpful for learning TypeScript by seeing which parts are just annotations." },
  { question: "What happens to TypeScript enums?", answer: "TypeScript enums are compile-time constructs that generate JavaScript code. This tool strips the enum declaration but cannot generate the equivalent JS object. For enum conversion, you need full TS compilation with tsc." },
  { question: "Does this preserve JSX syntax?", answer: "Yes. JSX syntax (React XML-like syntax) is passed through unchanged since JSX is not TypeScript-specific — it requires a JSX transform (like React) at build time. The output is valid TSX stripped of TypeScript types, ready for a JSX-aware bundler." },
];
---

<BaseLayout
  title="TypeScript to JavaScript Converter — Free Online TS Stripper"
  description="Strip TypeScript type annotations, interfaces, generics, enums, and decorators to convert TS to plain JavaScript. Client-side, no compilation needed, runs in your browser. Free, no signup."
  tool="TypeScript to JavaScript, TS to JS Converter, Strip TypeScript Types, TypeScript Stripper, Remove Type Annotations, TS to JS Online"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">TypeScript to JavaScript Converter</h1>
  <p class="text-text-muted mb-4">Strip TypeScript-specific syntax — interfaces, type annotations, generics, enums, access modifiers, and decorators — to get clean JavaScript. Useful for quick conversions and understanding TS concepts. No server needed.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <TypescriptToJs client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="TypeScript to JavaScript Converter" relatedTags={["typescript", "javascript", "conversion", "code", "development"]} />
</BaseLayout>
