---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TypescriptToJs from '../../components/TypescriptToJs.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="TypeScript to JavaScript Converter — Free Online Tool"
  description="Strip TypeScript type annotations, interfaces, generics, enums, and decorators to convert TS to plain JavaScript. Client-side, no compilation needed, runs in your browser."
  tool="TypeScript to JavaScript, TS to JS Converter, Strip Types, TypeScript Stripper"
>
  <h1 class="text-3xl font-bold mb-2">TypeScript to JavaScript Converter</h1>
  <p class="text-text-muted mb-8">Strip TypeScript-specific syntax — interfaces, type annotations, generics, enums, access modifiers, and decorators — to get clean JavaScript. Useful for quick conversions and understanding TS concepts. No server needed.</p>
  <TypescriptToJs client:only="preact" />
  <ToolPageCta currentTool="TypeScript to JavaScript Converter" relatedTags={['typescript', 'javascript', 'conversion', 'code', 'development']} />
</BaseLayout>
