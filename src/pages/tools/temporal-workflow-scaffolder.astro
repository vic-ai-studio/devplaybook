---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TemporalWorkflowScaffolder from '../../components/TemporalWorkflowScaffolder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Temporal and when should I use it?",
    answer: "Temporal is a durable execution platform for long-running workflows. It provides fault-tolerant, resumable workflows where state is automatically persisted. Use Temporal when you need: multi-step processes that take seconds to days (order processing, user onboarding), reliable distributed transactions with rollback/compensation, cron-like scheduled workflows, human-in-the-loop approval flows, or any workflow where reliability and observability are critical."
  },
  {
    question: "What is the difference between a Workflow and an Activity?",
    answer: "Workflows are deterministic orchestration code — they define the sequence of steps, handle retries, signals, and timers. They must be deterministic (no I/O, random numbers, or current time) because Temporal replays them to recover state. Activities are the actual work — calling external APIs, writing to databases, sending emails. Activities can do any I/O and are retried automatically on failure."
  },
  {
    question: "What is a Task Queue?",
    answer: "A Task Queue is a routing mechanism that matches Workflow and Activity tasks to Workers. Workers poll specific task queues and execute tasks. Using separate task queues for different services (e.g. 'payment-processing' vs 'notification-service') allows independent scaling and deployment of worker pools."
  },
  {
    question: "How does Temporal's retry policy work?",
    answer: "Temporal retries Activities automatically on failure with configurable policies: maximumAttempts limits total tries. initialInterval is the first retry delay. backoffCoefficient multiplies the delay each retry (exponential backoff). maximumInterval caps the delay. Workflow-level retries (for the entire workflow run) are separate from activity-level retries. The default retry policy retries indefinitely with exponential backoff up to 100 seconds."
  },
  {
    question: "What are Signals and Queries?",
    answer: "Signals are asynchronous messages sent to a running workflow to change its state or trigger behavior — like cancelling an order or approving a request. The workflow handles signals via setHandler (TS/Go) or signal handlers (Python). Queries are synchronous read-only requests to inspect a workflow's current state — like asking 'what step is this order on?' without affecting execution. Queries are answered immediately from the workflow's in-memory state."
  },
  {
    question: "Does this tool send my code to a server?",
    answer: "No. All code generation runs entirely in your browser using JavaScript. Your workflow names, activity names, and configuration never leave your machine."
  },
];
---

<BaseLayout
  title="Temporal Workflow Scaffolder — Generate Temporal Workflow Boilerplate"
  description="Scaffold Temporal workflow and activity boilerplate code for TypeScript, Go, and Python. Configure task queues, retry policies, signals, and queries. Free, runs in your browser."
  tool="Temporal workflow scaffolder, Temporal boilerplate generator, Temporal TypeScript Go Python template, Temporal activity generator, Temporal workflow code generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Temporal Workflow Scaffolder",
    "url": "https://devplaybook.cc/tools/temporal-workflow-scaffolder",
    "description": "Scaffold Temporal workflow and activity boilerplate for TypeScript, Go, and Python. Includes worker, client, retry policy, signals, and queries. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Temporal Workflow Scaffolder</h1>
  <p class="text-text-muted mb-4">
    Generate <a href="https://temporal.io" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">Temporal</a> workflow and activity boilerplate for TypeScript, Go, or Python.
    Configure workflow name, task queue, activities, retry policies, signals, and queries.
    Outputs complete, production-ready files including worker and client setup.
    Runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript, Go, Python</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Worker + client + activities</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Retry, signals & queries</span>
  </div>
  <TemporalWorkflowScaffolder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Temporal Workflow Scaffolder" relatedTags={['temporal', 'workflow', 'backend', 'microservices', 'typescript', 'go', 'python']} />
</BaseLayout>
