---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AwsIamSimulator from '../../components/AwsIamSimulator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How does AWS IAM policy evaluation work?", answer: "AWS evaluates IAM policies using a deny-overrides model: (1) Start with implicit DENY. (2) Evaluate all applicable policies. (3) If any policy has an explicit DENY matching the action+resource, access is denied regardless of any allows. (4) If any policy has an explicit ALLOW and no explicit deny exists, access is allowed. (5) Otherwise, implicit deny applies. This tool simulates steps 2-5 for a single policy document." },
  { question: "What is the difference between explicit deny and implicit deny?", answer: "Implicit deny is the default — if no policy explicitly allows an action, it is denied. Explicit deny is a statement with Effect: Deny that overrides any allow statements, even from other policies or roles. Explicit denies are used in Service Control Policies (SCPs) and permission boundaries to enforce hard limits that cannot be overridden by identity-based policies." },
  { question: "How does wildcard matching work in IAM?", answer: "IAM supports two wildcards: * (matches any combination of characters) and ? (matches any single character). For actions: s3:* matches all S3 actions, s3:Get* matches GetObject, GetBucketPolicy, etc. For resources: arn:aws:s3:::bucket/* matches all objects in a bucket. The wildcard * as the only resource matches everything." },
  { question: "What are ARNs (Amazon Resource Names)?", answer: "ARNs uniquely identify AWS resources. Format: arn:partition:service:region:account-id:resource. Examples: arn:aws:s3:::my-bucket (S3 bucket, no region/account needed), arn:aws:ec2:us-east-1:123456789012:instance/i-1234567890abcdef0 (EC2 instance), arn:aws:iam::123456789012:user/alice (IAM user). Use * as resource in policies to match all resources of a service." },
  { question: "What is the difference between identity-based and resource-based policies?", answer: "Identity-based policies attach to IAM users, groups, or roles and define what actions that identity can perform. Resource-based policies attach to AWS resources (S3 buckets, SQS queues, Lambda functions) and define who can access that resource. This simulator evaluates identity-based policies only. In real AWS, both types are evaluated together and access requires allows from both applicable policy types." },
];
---

<BaseLayout
  title="AWS IAM Policy Simulator — Test IAM Policies Online"
  description="Simulate AWS IAM policy evaluation without deploying to AWS. Paste a policy JSON, choose an action and resource ARN, and instantly see Allow or Deny with the matching statement explained."
  tool="AWS IAM simulator, IAM policy tester, IAM policy simulator, AWS permissions checker, IAM JSON policy, AWS access control"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">AWS IAM Policy Simulator</h1>
  <p class="text-text-muted mb-4">Paste an IAM policy JSON, enter an action and resource ARN, and instantly see whether access is <strong>Allowed</strong> or <strong>Denied</strong> — with the exact matching statement and reason explained.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No policy data sent to any server</span>
  </div>
  <AwsIamSimulator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="AWS IAM Policy Simulator" relatedTags={['aws', 'iam', 'security', 'cloud', 'permissions', 'devops']} />
</BaseLayout>
