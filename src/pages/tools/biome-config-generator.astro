---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BiomeConfigGenerator from '../../components/BiomeConfigGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is Biome?", answer: "Biome (formerly Rome) is an all-in-one toolchain for JavaScript and TypeScript projects. It replaces ESLint, Prettier, and import sorters with a single fast Rust-based tool. Biome formats, lints, and organizes imports — all configured in a single biome.json file." },
  { question: "How do I install Biome?", answer: "Install via npm: npm install --save-dev @biomejs/biome. Then initialize a config: npx @biomejs/biome init. Add scripts to package.json: \"format\": \"biome format --write .\" and \"lint\": \"biome lint .\"." },
  { question: "What is the difference between indentStyle tab and space?", answer: "Tabs use a single tab character (\\t) per indent level, which lets each developer set their preferred visual width in their editor. Spaces use a fixed number of space characters. Biome defaults to tabs, which is both compact in files and visually flexible." },
  { question: "Should I use single or double quotes?", answer: "Biome defaults to double quotes to align with JSON and HTML conventions. If your project already uses single quotes (common in older JavaScript style guides), choose single. The key is consistency — pick one and Biome will enforce it across all files." },
  { question: "What does 'recommended rules' mean in Biome?", answer: "Enabling recommended rules turns on Biome's curated set of high-confidence lint rules covering correctness, security, and style. These are rules where the benefit clearly outweighs false positives. You can then add or override individual rules on top of the recommended baseline." },
  { question: "How do I ignore files in Biome?", answer: "Add an \"ignore\" array to your biome.json: { \"files\": { \"ignore\": [\"dist/**\", \"node_modules/**\", \"*.min.js\"] } }. Biome also respects .gitignore by default in newer versions." },
];
---

<BaseLayout
  title="Biome Config Generator — Visual biome.json Builder"
  description="Generate a biome.json config file visually. Configure formatter settings (indent, quotes, semicolons), linter rules (style, correctness, a11y), and import organization. Free, runs in your browser."
  tool="Biome Config Generator, biome.json, Biome Linter, Biome Formatter, JavaScript Toolchain, ESLint Alternative"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Biome Config Generator</h1>
  <p class="text-text-muted mb-4">Build a complete <code class="text-accent font-mono">biome.json</code> configuration file visually. Toggle formatter settings, linter rules, and import organization — see the output update live. Copy and drop it into your project.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Replaces ESLint + Prettier</span>
  </div>
  <BiomeConfigGenerator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Biome Config Generator" relatedTags={['javascript', 'typescript', 'linting', 'formatting', 'development']} />
</BaseLayout>
