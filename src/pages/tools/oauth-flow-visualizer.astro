---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OAuthFlowVisualizer from '../../components/OAuthFlowVisualizer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is the difference between OAuth 2.0 and OpenID Connect (OIDC)?",
    answer: "OAuth 2.0 is an authorization framework — it answers 'can this app access this resource on behalf of the user?' It deals in access tokens scoped to specific resources. OpenID Connect (OIDC) is an identity layer built on top of OAuth 2.0 — it answers 'who is this user?' by adding an ID token (a JWT) containing the user's profile. When you see a scope like 'openid profile email', the openid scope triggers OIDC and the auth server returns an id_token in addition to the access_token. Use OAuth alone for delegated API access; add OIDC when you need authentication (login) as well."
  },
  {
    question: "What is PKCE and do I always need it?",
    answer: "PKCE (Proof Key for Code Exchange, RFC 7636) prevents authorization code interception attacks. Before redirecting, the client generates a random code_verifier, hashes it to produce a code_challenge, and sends the challenge to the auth server. When exchanging the code for tokens, the client sends the original code_verifier — the server verifies they match. Without PKCE, a malicious app on the same device could intercept the authorization code from the redirect and exchange it for tokens. PKCE is required for public clients (SPAs, mobile apps) and strongly recommended for confidential clients too. OAuth 2.1 (the upcoming simplified spec) mandates PKCE for all Authorization Code flows."
  },
  {
    question: "When should I use Client Credentials vs Authorization Code?",
    answer: "Use Client Credentials when there is no human user involved — your backend service, cron job, or microservice needs to call another API. The service authenticates as itself using its client_id and client_secret. Use Authorization Code when a human user is authorizing access — they need to log in and approve the scopes. The key question is: 'Is there a user who needs to consent?' If yes → Authorization Code. If no → Client Credentials."
  },
  {
    question: "How should I store access tokens and refresh tokens securely?",
    answer: "Access tokens used in SPAs should be stored in memory (JavaScript variable) — not localStorage or sessionStorage, which are vulnerable to XSS. For web apps with a backend, store the refresh token in an HttpOnly, Secure, SameSite=Strict cookie and issue short-lived session cookies to the browser. Never store sensitive tokens in localStorage. In mobile apps, use the platform's secure storage (iOS Keychain, Android Keystore). Refresh tokens must be treated like passwords — rotate them on use (refresh token rotation) and invalidate old ones immediately."
  },
  {
    question: "What happens when an access token expires?",
    answer: "When an API returns 401 Unauthorized, the client should check if it has a valid refresh token. If it does, it sends a POST /token request with grant_type=refresh_token and the refresh_token value. The auth server validates the refresh token and returns a new access_token (and often a new refresh_token — refresh token rotation). If the refresh token is also expired or revoked (e.g. user logged out, password changed, suspicious activity), the client must send the user back through the authorization flow from the beginning. Always implement token refresh logic before building any OAuth-protected feature."
  },
];
---

<BaseLayout
  title="OAuth 2.0 Flow Visualizer — Understand Authorization Code, Client Credentials & More"
  description="Interactive step-by-step visualizer for OAuth 2.0 flows: Authorization Code (with PKCE), Implicit (deprecated), Client Credentials, and Device Code. See every HTTP request, response, and parameter explained. Free, runs in browser."
  tool="OAuth 2.0 Flow Visualizer, Authorization Code Flow, Client Credentials, PKCE, Device Code Flow, OpenID Connect, OAuth Tutorial"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "OAuth 2.0 Flow Visualizer",
    "url": "https://devplaybook.cc/tools/oauth-flow-visualizer",
    "description": "Interactive step-by-step visualizer for OAuth 2.0 flows including Authorization Code with PKCE, Client Credentials, Device Code, and deprecated Implicit flow.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">OAuth 2.0 Flow Visualizer</h1>
  <p class="text-text-muted mb-4">
    Understand every OAuth 2.0 grant type through interactive step-by-step flows. See the exact HTTP requests,
    response payloads, and parameters for <strong>Authorization Code</strong>, <strong>Client Credentials</strong>,
    <strong>Device Code</strong>, and the deprecated <strong>Implicit</strong> flow — with PKCE, tokens, and security notes explained.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 4 OAuth 2.0 grant types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Real HTTP request/response examples</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> PKCE explained step-by-step</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Security notes per step</span>
  </div>
  <OAuthFlowVisualizer client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="OAuth 2.0 Flow Visualizer" relatedTags={['security', 'oauth', 'authentication', 'api', 'developer-tools']} />
</BaseLayout>
