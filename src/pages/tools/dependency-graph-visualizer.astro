---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a dependency graph?", answer: "A dependency graph is a directed graph where each node is a package and each edge shows that one package requires another. It helps visualize how packages relate, identify deeply nested dependencies, spot duplicate versions, and understand the weight of each top-level dependency. Tools like npm ls and yarn why generate these, but this tool lets you visualize them directly from package.json." },
  { question: "What is the difference between dependencies and devDependencies?", answer: "dependencies are packages required at runtime — they are bundled into production builds. devDependencies are only needed during development (testing, building, linting) and are not included in production bundles. peerDependencies are packages the host project must provide — common in plugin/library packages. Keeping these three groups correct reduces bundle size and security surface area." },
  { question: "What is dependency depth and why does it matter?", answer: "Dependency depth is how many levels of indirection separate your code from a package. A depth-1 package is in your package.json. A depth-3 package is a dependency of a dependency of a dependency. Deep dependencies are harder to audit, easier to have multiple conflicting versions, and can cause supply chain security risks (as shown by the leftpad and event-stream incidents)." },
  { question: "How do I identify unused dependencies?", answer: "Run npx depcheck or npx knip to find unused packages. A package in package.json but never imported in your source code wastes bundle space and is a security liability. Regularly audit with npm ls and remove anything not actively used. Note: some tools like babel presets or webpack plugins are used via config files, not direct imports." },
  { question: "What is a circular dependency?", answer: "A circular dependency is when package A requires B and B requires A (directly or transitively). In Node.js, this can cause one module to receive an incomplete exports object. Tools like madge detect circular dependencies in your own source files. In npm packages, circular deps are prevented by npm's resolution algorithm, but they can still cause subtle loading order issues." },
];
---

<BaseLayout
  title="Dependency Graph Visualizer — package.json Tree & Stats"
  description="Paste your package.json to visualize the dependency tree, count packages by category, see version numbers, and spot heavy or outdated dependencies. Runs entirely in your browser."
  tool="Dependency Graph Visualizer, package.json analyzer, npm dependency tree, node modules, devDependencies, peerDependencies, dependency audit"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Dependency Graph Visualizer",
    "url": "https://devplaybook.cc/tools/dependency-graph-visualizer",
    "description": "Paste package.json to visualize dependency tree, count packages, see version numbers, and audit categories. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Dependency Graph Visualizer</h1>
  <p class="text-text-muted mb-4">Paste your <code class="text-sm bg-bg-card border border-border px-1.5 py-0.5 rounded">package.json</code> to visualize your <strong>dependency tree</strong> — see all packages by category, version ranges, counts, and spot potential issues like too many dependencies or misplaced dev packages.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> dependencies / devDependencies / peer</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Version range analysis</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Package count stats</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No data leaves your browser</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-6">
    <!-- Input -->
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <div class="flex items-center justify-between mb-3">
        <label class="text-sm font-semibold">Paste package.json</label>
        <button id="btn-example-pkg" class="text-xs text-primary hover:underline">Load Example</button>
      </div>
      <textarea id="pkg-input" class="w-full bg-bg-page border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary resize-y" rows="18" placeholder='{"name": "my-app", "dependencies": {...}, "devDependencies": {...}}'></textarea>
      <div id="parse-error" class="hidden mt-2 text-xs text-red-400"></div>
      <button id="btn-visualize" class="mt-3 w-full px-4 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Visualize Dependencies</button>
    </div>

    <!-- Results -->
    <div class="space-y-4">
      <!-- Stats -->
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <h2 class="text-sm font-semibold mb-3">Overview</h2>
        <div class="grid grid-cols-3 gap-3">
          <div class="bg-bg-page rounded-lg p-3 text-center">
            <div class="text-xl font-bold text-green-400" id="stat-deps">—</div>
            <div class="text-xs text-text-muted">dependencies</div>
          </div>
          <div class="bg-bg-page rounded-lg p-3 text-center">
            <div class="text-xl font-bold text-yellow-400" id="stat-devdeps">—</div>
            <div class="text-xs text-text-muted">devDependencies</div>
          </div>
          <div class="bg-bg-page rounded-lg p-3 text-center">
            <div class="text-xl font-bold text-blue-400" id="stat-peer">—</div>
            <div class="text-xs text-text-muted">peerDependencies</div>
          </div>
        </div>
        <div id="dep-warnings" class="mt-3 space-y-1.5"></div>
      </div>

      <!-- Version range legend -->
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <h2 class="text-sm font-semibold mb-2">Version Range Guide</h2>
        <div class="grid grid-cols-2 gap-1.5 text-xs text-text-muted">
          <div><code class="text-foreground">^1.2.3</code> — compatible (minor+patch)</div>
          <div><code class="text-foreground">~1.2.3</code> — patch only</div>
          <div><code class="text-foreground">1.2.3</code> — exact version</div>
          <div><code class="text-foreground">*</code> / <code class="text-foreground">latest</code> — any (risky)</div>
          <div><code class="text-foreground">>=1.0 <2.0</code> — range</div>
          <div><code class="text-foreground">workspace:*</code> — monorepo</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Dependency tree -->
  <div id="tree-section" class="hidden space-y-4 mb-6">
    <div id="tree-deps" class="bg-bg-card border border-border rounded-lg p-4"></div>
    <div id="tree-devdeps" class="bg-bg-card border border-border rounded-lg p-4 hidden"></div>
    <div id="tree-peer" class="bg-bg-card border border-border rounded-lg p-4 hidden"></div>
    <div id="tree-optional" class="bg-bg-card border border-border rounded-lg p-4 hidden"></div>
  </div>

  <ToolPageCta currentTool="Dependency Graph Visualizer" relatedTags={['nodejs', 'npm', 'package-management', 'javascript', 'devops']} />
  <FaqSection faq={faq} />
</BaseLayout>

<script>
const EXAMPLE_PKG = JSON.stringify({
  "name": "my-nextjs-app",
  "version": "1.0.0",
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "axios": "^1.6.0",
    "zod": "^3.22.0",
    "zustand": "^4.5.0",
    "tailwindcss": "^3.4.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.0",
    "lucide-react": "^0.365.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/react": "^18.3.0",
    "@types/node": "^20.11.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "prettier": "^3.2.0",
    "vitest": "^1.4.0",
    "@testing-library/react": "^15.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}, null, 2);

function getVersionType(v: string): { label: string; color: string } {
  if (!v || v === '*' || v === 'latest' || v === 'x') return { label: 'ANY', color: 'text-red-400' };
  if (/^workspace:/.test(v)) return { label: 'WORKSPACE', color: 'text-purple-400' };
  if (/^\d+\.\d+\.\d+$/.test(v)) return { label: 'EXACT', color: 'text-blue-400' };
  if (v.startsWith('^')) return { label: 'COMPATIBLE', color: 'text-green-400' };
  if (v.startsWith('~')) return { label: 'PATCH', color: 'text-yellow-400' };
  if (v.startsWith('>=') || v.includes(' - ')) return { label: 'RANGE', color: 'text-orange-400' };
  return { label: 'OTHER', color: 'text-text-muted' };
}

function renderDepsSection(title: string, deps: Record<string, string>, color: string, containerId: string) {
  const container = document.getElementById(containerId)!;
  if (!deps || Object.keys(deps).length === 0) {
    container.classList.add('hidden');
    return;
  }
  container.classList.remove('hidden');

  const entries = Object.entries(deps);
  container.innerHTML = `
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-sm font-semibold">${title} <span class="${color} text-xs">(${entries.length})</span></h2>
      <span class="text-xs text-text-muted">${entries.length} package${entries.length !== 1 ? 's' : ''}</span>
    </div>
    <div class="space-y-1">
      ${entries.map(([name, ver]) => {
        const vt = getVersionType(ver);
        const isAtType = name.startsWith('@');
        const [scope, pkg] = isAtType ? name.split('/') : [null, name];
        return `<div class="flex items-center justify-between py-1.5 border-b border-border/50 last:border-0 hover:bg-bg-page/50 px-1 rounded transition-colors">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full ${color.replace('text-', 'bg-')} flex-shrink-0"></span>
            <span class="text-sm font-mono">${scope ? `<span class="text-text-muted">${scope}/</span>` : ''}${pkg || name}</span>
          </div>
          <div class="flex items-center gap-2">
            <code class="text-xs text-text-muted font-mono">${ver}</code>
            <span class="text-xs ${vt.color} font-semibold w-20 text-right">${vt.label}</span>
          </div>
        </div>`;
      }).join('')}
    </div>
  `;
}

function visualize() {
  const input = (document.getElementById('pkg-input') as HTMLTextAreaElement).value.trim();
  const errEl = document.getElementById('parse-error')!;
  errEl.classList.add('hidden');

  let pkg: Record<string, unknown>;
  try {
    pkg = JSON.parse(input);
  } catch (e) {
    errEl.textContent = `JSON parse error: ${(e as Error).message}`;
    errEl.classList.remove('hidden');
    return;
  }

  const deps = (pkg.dependencies || {}) as Record<string, string>;
  const devDeps = (pkg.devDependencies || {}) as Record<string, string>;
  const peer = (pkg.peerDependencies || {}) as Record<string, string>;
  const optional = (pkg.optionalDependencies || {}) as Record<string, string>;

  document.getElementById('stat-deps')!.textContent = String(Object.keys(deps).length);
  document.getElementById('stat-devdeps')!.textContent = String(Object.keys(devDeps).length);
  document.getElementById('stat-peer')!.textContent = String(Object.keys(peer).length);

  // Warnings
  const warnings: string[] = [];
  if (Object.keys(deps).length > 30) warnings.push(`⚠️ Large dependency count (${Object.keys(deps).length}). Consider auditing unused packages.`);
  const wildcards = [...Object.entries(deps), ...Object.entries(devDeps)].filter(([, v]) => v === '*' || v === 'latest');
  if (wildcards.length > 0) warnings.push(`⚠️ ${wildcards.length} wildcard version(s): ${wildcards.map(([n]) => n).join(', ')}. Pin versions for reproducible builds.`);
  const exact = Object.entries(deps).filter(([, v]) => /^\d+\.\d+\.\d+$/.test(v));
  if (exact.length > 5) warnings.push(`ℹ️ ${exact.length} exact versions in dependencies. Consider using ^ ranges for easier updates.`);

  const warnEl = document.getElementById('dep-warnings')!;
  warnEl.innerHTML = warnings.map(w => `<p class="text-xs ${w.startsWith('⚠') ? 'text-yellow-400' : 'text-blue-400'}">${w}</p>`).join('');

  document.getElementById('tree-section')!.classList.remove('hidden');
  renderDepsSection('dependencies', deps, 'text-green-400', 'tree-deps');
  renderDepsSection('devDependencies', devDeps, 'text-yellow-400', 'tree-devdeps');
  renderDepsSection('peerDependencies', peer, 'text-blue-400', 'tree-peer');
  renderDepsSection('optionalDependencies', optional, 'text-purple-400', 'tree-optional');
}

document.getElementById('btn-visualize')?.addEventListener('click', visualize);
document.getElementById('btn-example-pkg')?.addEventListener('click', () => {
  (document.getElementById('pkg-input') as HTMLTextAreaElement).value = EXAMPLE_PKG;
  visualize();
});
</script>
