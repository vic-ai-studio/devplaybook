---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HtmlFormatter from '../../components/HtmlFormatter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="HTML Formatter & Minifier — Free Online Tool"
  description="Format messy HTML with proper indentation or minify it to reduce file size. Handles void elements, pre/script blocks, and nested tags. Runs entirely in your browser."
  tool="HTML Formatter, HTML Beautifier, HTML Minifier, HTML Pretty Print"
>
  <h1 class="text-3xl font-bold mb-2">HTML Formatter & Minifier</h1>
  <p class="text-text-muted mb-8">Paste messy HTML to auto-indent and format it for readability. Or minify it to strip whitespace and reduce file size. Handles nested tags, void elements, and pre/script blocks correctly.</p>
  <HtmlFormatter client:only="preact" />
  <ToolPageCta currentTool="HTML Formatter & Minifier" relatedTags={['html', 'formatting', 'minifier', 'web', 'development']} />
</BaseLayout>
