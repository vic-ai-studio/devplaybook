---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HtmlFormatter from "../../components/HtmlFormatter.tsx";
import ToolPageCta from "../../components/ToolPageCta.astro";
import FaqSection from "../../components/FaqSection.astro";

const faq = [
  { question: "Why should I format my HTML?", answer: "Formatted HTML is easier to read, review, and debug. Proper indentation shows nesting structure at a glance, making it faster to spot unclosed tags, misplaced elements, and accidental nesting errors. Teams also benefit from consistent formatting in version-controlled HTML files." },
  { question: "What is the difference between formatting and minifying HTML?", answer: "Formatting (beautifying) adds indentation and line breaks to make HTML human-readable. Minifying removes all unnecessary whitespace to produce the smallest possible file — reducing bandwidth and improving page load times. Use formatting for development, minification for production." },
  { question: "Does minifying HTML remove comments?", answer: "This tool strips HTML comments during minification since they add bytes without value in production. If you need to preserve specific comments (e.g., IE conditional comments), add them back manually after minifying." },
  { question: "Will formatting break my HTML structure?", answer: "No. This tool only changes whitespace — it does not alter tag content, attributes, or structure. Pre-formatted blocks like pre and code are handled correctly. Inline elements (like span and a) are not broken across lines to avoid introducing unwanted text spacing." },
  { question: "Can I use this for email HTML templates?", answer: "Yes, for general formatting and review. Note that email clients have strict HTML support requirements — always test formatted email HTML in an email testing tool after reformatting, since some clients are sensitive to whitespace around table elements." },
];
---

<BaseLayout
  title="HTML Formatter & Minifier — Free Online HTML Beautifier"
  description="Format messy HTML with proper indentation or minify it to reduce file size. Handles void elements, pre/script blocks, and nested tags. Copy-ready output. Runs entirely in your browser — no upload needed."
  tool="HTML Formatter, HTML Beautifier, HTML Minifier, HTML Pretty Print, Format HTML Online, HTML Indentation"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">HTML Formatter & Minifier</h1>
  <p class="text-text-muted mb-4">Paste messy HTML to auto-indent and format it for readability. Or minify it to strip whitespace and reduce file size. Handles nested tags, void elements, and pre/script blocks correctly.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <HtmlFormatter client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="HTML Formatter & Minifier" relatedTags={["html", "formatting", "minifier", "web", "development"]} />
</BaseLayout>
