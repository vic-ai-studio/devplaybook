---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const installExample = `# Install Prism CLI globally
npm install -g @stoplight/prism-cli

# Or run with npx (no install required)
npx @stoplight/prism-cli mock api.yaml`;

const mockExample = `# Start a mock server from an OpenAPI 3.x spec
prism mock api.yaml

# Mock on a custom port
prism mock api.yaml --port 4010

# Mock with dynamic response generation (uses x-faker or spec examples)
prism mock api.yaml --dynamic

# Mock multiple specs at once
prism mock api.yaml users.yaml --port 4010`;

const proxyExample = `# Proxy mode: validate real API requests/responses against OpenAPI spec
prism proxy api.yaml https://api.example.com --port 4010

# Requests go through: client -> Prism (4010) -> real API -> Prism -> client
# Prism validates both request and response against your spec
# Violations are logged with detailed error messages`;

const specExample = `openapi: 3.0.3
info:
  title: Example API
  version: 1.0.0
paths:
  /users:
    get:
      summary: List users
      responses:
        '200':
          description: Success
          content:
            application/json:
              schema:
                type: array
                items:
                  type: object
                  required: [id, email]
                  properties:
                    id:
                      type: integer
                      example: 42
                    email:
                      type: string
                      format: email
                      example: jane@example.com`;

const faq = [
  { question: "What is the difference between Prism mock mode and proxy mode?", answer: "In mock mode, Prism generates HTTP responses directly from your OpenAPI spec — it uses the example values defined in the spec, or generates random values matching the schema when using --dynamic. No real backend is needed. In proxy mode, Prism sits between your API client and the real backend: it forwards requests to the real server and validates both the outgoing request and the incoming response against your OpenAPI spec. Any deviation (an undocumented field, a wrong status code, a type mismatch) is logged as a contract violation. Proxy mode is powerful for catching spec drift in existing APIs." },
  { question: "What is contract testing and why does Prism help?", answer: "Contract testing verifies that an API producer (the backend) and API consumers (frontend, mobile, other services) agree on the API contract — the routes, request schemas, response schemas, and status codes defined in an OpenAPI spec. Without contract testing, consumers discover breaking changes only when they deploy to staging or production. Prism enforces the contract by validating requests and responses against the OpenAPI spec at the HTTP layer. If the real API returns a field with the wrong type, or the client sends a request that violates the schema, Prism catches it immediately." },
  { question: "How does Prism compare to Mockoon?", answer: "Prism is spec-driven: it generates mock responses directly from an OpenAPI spec file, enforcing schema contracts automatically. Mockoon is a visual tool where you manually define routes and responses — great for quick prototyping but not tied to a spec by default. Prism requires an existing OpenAPI spec; Mockoon does not. Prism is better suited for API-first development workflows where the OpenAPI spec is the source of truth. Mockoon is better for teams that want a quick visual tool without a spec. Prism also has proxy mode for validating real APIs — Mockoon does not." },
  { question: "What does Prism do when a request fails validation?", answer: "By default, Prism returns a 422 Unprocessable Entity response when a request violates the OpenAPI spec — for example, when a required field is missing, a field type is wrong, or a route does not exist in the spec. This makes validation errors immediately visible to the API consumer. You can configure Prism to be more lenient with --errors=false to log violations without rejecting requests. In proxy mode, Prism passes the request through even if it is invalid but logs the contract violation with full details." },
  { question: "How does Prism compare to MSW (Mock Service Worker)?", answer: "MSW intercepts requests at the browser or Node.js level using Service Workers or Node.js HTTP interceptors — it is primarily used in frontend unit and integration tests (Jest, Vitest, Playwright). Prism runs as a real standalone HTTP server, making it usable from any HTTP client regardless of the test framework or language. Prism is spec-driven (OpenAPI), while MSW handlers are written in JavaScript. Prism is better for API contract validation and spec-driven development; MSW is better for JavaScript frontend testing where the mock server should be co-located with test code." },
  { question: "Can I use Prism with Stoplight Studio?", answer: "Yes, Stoplight Studio is a visual API design tool by the same company (Stoplight) that produces Prism. Stoplight Studio exports OpenAPI specs that Prism can consume immediately. The recommended workflow is: design the API in Stoplight Studio, use Prism to run a mock server from the exported spec during frontend development, and use Prism proxy mode to validate the real implementation when it is ready. This creates a fully API-first development loop from design through validation." },
];
---

<BaseLayout
  title="Prism — OpenAPI Mock Server and Contract Validator by Stoplight"
  description="Prism is an open-source CLI tool that creates mock HTTP servers from OpenAPI specs and validates API requests and responses against the spec. Essential for API-first development and contract testing."
  tool="Prism Stoplight, OpenAPI mock server, API contract testing, Prism mock, OpenAPI validation, Prism proxy mode, API-first development"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Prism — OpenAPI Mock Server and Contract Validator",
    "url": "https://devplaybook.cc/tools/prism",
    "description": "Prism is an open-source CLI that creates mock HTTP servers from OpenAPI specs and validates requests and responses. Essential for API-first development and contract testing.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Prism — OpenAPI Mock Server and Contract Validator</h1>
  <p class="text-text-muted mb-6">
    <strong>Prism</strong> by Stoplight is an open-source CLI tool that turns your OpenAPI spec into a real HTTP mock server in one command. It also operates as a validating proxy that checks whether your real API adheres to its OpenAPI contract — catching spec drift and schema violations before they reach production.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Mock server from OpenAPI spec</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Request and response validation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Proxy mode for real API validation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Dynamic response generation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Open source (Apache 2.0)</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Prism?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Prism is maintained by Stoplight (the company behind Stoplight Studio, the API design platform). It is a Node.js CLI that reads an OpenAPI 2.x or 3.x specification file and provides two core capabilities: a <strong>mock server</strong> that generates HTTP responses from the spec, and a <strong>validating proxy</strong> that forwards requests to a real backend while checking that all traffic conforms to the spec.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    The key difference from tools like Mockoon or Hoppscotch is that Prism is <em>spec-driven</em>. You do not manually define routes and responses — Prism derives everything from your OpenAPI spec. This makes it ideal for API-first workflows where the spec is the single source of truth. When the spec and the implementation disagree, Prism surfaces the violation immediately.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Mock mode</strong> — starts a real HTTP server serving responses from OpenAPI examples or dynamically generated data</li>
    <li><strong>Proxy mode</strong> — sits in front of a real API and validates every request and response against the spec</li>
    <li><strong>Request validation</strong> — validates method, path, query parameters, headers, and request body against the spec</li>
    <li><strong>Response validation</strong> — checks that the real API response matches the declared schema, status code, and content type</li>
    <li><strong>Dynamic generation</strong> — with <code class="font-mono bg-surface px-1 rounded text-xs">--dynamic</code>, Prism generates random but schema-valid response data using Faker</li>
    <li><strong>OpenAPI 2.x and 3.x</strong> — supports both Swagger 2.0 and OpenAPI 3.0/3.1 specifications</li>
    <li><strong>Multiple specs</strong> — merge multiple OpenAPI files into a single mock server</li>
    <li><strong>Content negotiation</strong> — respects Accept headers and returns the appropriate response format</li>
    <li><strong>Verbose logging</strong> — detailed logs of every request, response, and validation error</li>
    <li><strong>Docker image</strong> — official stoplight/prism Docker image for containerized environments</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Installation</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-6" set:html={installExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Mock Mode — Serve Responses from Your Spec</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={mockExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Proxy Mode — Validate a Real API</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-6" set:html={proxyExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Minimal OpenAPI Spec Example</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={specExample}></pre>
  <p class="text-text-muted mb-4">
    With the spec above, running <code class="font-mono bg-surface px-1 rounded text-sm">prism mock api.yaml</code> immediately starts a server that returns the example values defined in the spec. A GET request to <code class="font-mono bg-surface px-1 rounded text-sm">/users</code> returns the example user array without any additional configuration.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Prism vs Mockoon vs MSW</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">Prism</th>
          <th class="border border-border px-3 py-2 text-left">Mockoon</th>
          <th class="border border-border px-3 py-2 text-left">MSW</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-border px-3 py-2">Spec-driven</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes (OpenAPI required)</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Optional import</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Contract validation</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes (built-in)</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">Proxy mode</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Partial (record)</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Visual UI</td>
          <td class="border border-border px-3 py-2 text-red-400">CLI only</td>
          <td class="border border-border px-3 py-2 text-green-400">Desktop GUI</td>
          <td class="border border-border px-3 py-2 text-red-400">Code only</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">Target user</td>
          <td class="border border-border px-3 py-2">API-first teams</td>
          <td class="border border-border px-3 py-2">Frontend devs</td>
          <td class="border border-border px-3 py-2">JS frontend testing</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Docker support</td>
          <td class="border border-border px-3 py-2 text-green-400">Official image</td>
          <td class="border border-border px-3 py-2 text-green-400">Official image</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Via Node.js</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Use Cases</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li>API-first development: design the OpenAPI spec first, then let Prism serve a mock for parallel frontend and backend work</li>
    <li>Contract testing: use Prism proxy mode to verify that the real backend matches the agreed spec</li>
    <li>CI/CD validation: run Prism proxy in front of staging API and fail the build when spec violations are detected</li>
    <li>Consumer-driven contract checks: validate that third-party API responses match the schema you depend on</li>
    <li>Catching breaking changes: compare spec versions and use proxy mode to detect regressions in production APIs</li>
    <li>Generating realistic test data from OpenAPI schemas with the <code class="font-mono bg-surface px-1 rounded text-sm">--dynamic</code> flag</li>
  </ul>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Prism OpenAPI Mock Server" relatedTags={['api', 'openapi', 'mock', 'contract-testing', 'testing', 'rest', 'developer-tools']} />
</BaseLayout>
