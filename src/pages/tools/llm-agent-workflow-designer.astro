---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the ReAct pattern and when should I use it?",
    answer: "ReAct (Reasoning + Acting) interleaves chain-of-thought reasoning with action execution in a think → act → observe loop. The model reasons about what to do, calls a tool, observes the result, then reasons again. Use ReAct when your agent needs to use external tools (web search, APIs, code execution) and must adapt its plan based on intermediate results. It's the most common architecture for tool-using agents and the basis for LangChain's AgentExecutor."
  },
  {
    question: "What is the difference between Chain-of-Thought and Tree of Thoughts?",
    answer: "Chain-of-Thought (CoT) generates one linear reasoning path: step 1 → step 2 → answer. It works well for problems with a clear sequential solution path. Tree of Thoughts (ToT) generates multiple candidate reasoning paths in parallel, evaluates each branch, and backtracks from dead ends. ToT is better for complex problems with many possible approaches (e.g., math proofs, planning, puzzles), but costs 5–20× more tokens because it explores multiple branches simultaneously."
  },
  {
    question: "What is the Reflexion pattern?",
    answer: "Reflexion adds a self-critique loop to standard generation: the agent produces an output, then a separate 'evaluator' step (which can be the same model) scores the output and generates verbal feedback. The agent then revises its answer using that feedback. This mimics human iterative improvement. Reflexion is effective for coding tasks where you can run tests and feed failures back as feedback. It typically converges in 2–4 revision cycles."
  },
  {
    question: "When should I use multi-agent debate instead of a single agent?",
    answer: "Multi-agent debate is valuable when: (1) You need to catch hallucinations — agents arguing against each other surface errors that self-review misses. (2) The problem benefits from diverse perspectives (strategy planning, risk assessment). (3) You want to simulate adversarial conditions (security review, legal analysis). Downside: debate multiplies your token cost by the number of agents × rounds. Start with 2 agents and 2 rounds; add more only if quality improves measurably."
  },
  {
    question: "How do I estimate token usage for agent patterns?",
    answer: "Rough estimates per task: CoT adds ~200–500 tokens of reasoning overhead. ReAct adds ~500–2000 tokens depending on tool call count (each observe-reason cycle costs ~300–600 tokens). Self-Consistency runs the same prompt N times — multiply base cost by N. Tree of Thoughts explores K branches with depth D: cost ≈ base × K × D. Plan-and-Execute costs base + plan tokens upfront, then each sub-task execution cost. For production systems, instrument actual token counts and set budget limits per agent run."
  }
];
---

<BaseLayout
  title="LLM Agent Workflow Designer — ReAct, CoT, ToT Pattern Builder"
  description="Design LLM agent workflows visually. Explore ReAct, Chain-of-Thought, Tree of Thoughts, Reflexion, Self-Consistency, Plan-and-Execute, and multi-agent patterns. Get pseudocode templates, prompt examples, and token cost estimates."
  tool="LLM Agent Workflow Designer, ReAct Pattern Builder, Chain-of-Thought Designer, AI Agent Architecture, LLM Workflow Patterns"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">LLM Agent Workflow Designer</h1>
  <p class="text-text-muted mb-4">Explore, compare, and design LLM agent workflow patterns. Get pseudocode templates, prompt examples, pros/cons, and token cost estimates for each architecture.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 8 agent patterns</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Pseudocode templates</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Token cost estimates</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Visual flow builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Prompt templates</span>
  </div>

  <!-- Pattern Selection -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-3">Select Agent Pattern</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2" id="pattern-grid">
      <button class="pattern-btn active-pattern text-sm border border-primary bg-primary/10 text-primary rounded-lg px-3 py-2.5 hover:bg-primary/20 transition-colors text-left" data-pattern="react">
        <div class="font-medium">ReAct</div>
        <div class="text-xs opacity-75">Reasoning + Acting</div>
      </button>
      <button class="pattern-btn text-sm border border-border bg-black/20 rounded-lg px-3 py-2.5 hover:border-primary hover:text-primary transition-colors text-left" data-pattern="cot">
        <div class="font-medium">Chain-of-Thought</div>
        <div class="text-xs opacity-75">Step-by-step reasoning</div>
      </button>
      <button class="pattern-btn text-sm border border-border bg-black/20 rounded-lg px-3 py-2.5 hover:border-primary hover:text-primary transition-colors text-left" data-pattern="tot">
        <div class="font-medium">Tree of Thoughts</div>
        <div class="text-xs opacity-75">Multi-branch exploration</div>
      </button>
      <button class="pattern-btn text-sm border border-border bg-black/20 rounded-lg px-3 py-2.5 hover:border-primary hover:text-primary transition-colors text-left" data-pattern="sc">
        <div class="font-medium">Self-Consistency</div>
        <div class="text-xs opacity-75">Majority vote sampling</div>
      </button>
      <button class="pattern-btn text-sm border border-border bg-black/20 rounded-lg px-3 py-2.5 hover:border-primary hover:text-primary transition-colors text-left" data-pattern="reflexion">
        <div class="font-medium">Reflexion</div>
        <div class="text-xs opacity-75">Self-critique + revision</div>
      </button>
      <button class="pattern-btn text-sm border border-border bg-black/20 rounded-lg px-3 py-2.5 hover:border-primary hover:text-primary transition-colors text-left" data-pattern="plan-execute">
        <div class="font-medium">Plan-and-Execute</div>
        <div class="text-xs opacity-75">Upfront planning</div>
      </button>
      <button class="pattern-btn text-sm border border-border bg-black/20 rounded-lg px-3 py-2.5 hover:border-primary hover:text-primary transition-colors text-left" data-pattern="tool-use">
        <div class="font-medium">Tool-Use Agent</div>
        <div class="text-xs opacity-75">Function calling</div>
      </button>
      <button class="pattern-btn text-sm border border-border bg-black/20 rounded-lg px-3 py-2.5 hover:border-primary hover:text-primary transition-colors text-left" data-pattern="debate">
        <div class="font-medium">Multi-Agent Debate</div>
        <div class="text-xs opacity-75">Adversarial consensus</div>
      </button>
    </div>
  </div>

  <!-- Pattern Detail -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
      <div>
        <h2 id="pattern-title" class="text-xl font-bold mb-1"></h2>
        <p id="pattern-description" class="text-sm text-text-muted max-w-2xl"></p>
      </div>
      <div class="flex gap-2 text-xs shrink-0">
        <div class="bg-black/20 rounded-lg px-3 py-2 text-center">
          <div class="text-text-muted mb-0.5">Token overhead</div>
          <div id="token-badge" class="font-bold text-yellow-400"></div>
        </div>
        <div class="bg-black/20 rounded-lg px-3 py-2 text-center">
          <div class="text-text-muted mb-0.5">Complexity</div>
          <div id="complexity-badge" class="font-bold text-blue-400"></div>
        </div>
      </div>
    </div>

    <div class="mb-4">
      <div class="text-sm font-medium mb-1 text-text-muted">When to use</div>
      <div id="when-to-use" class="text-sm bg-black/20 rounded-lg p-3"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
      <div>
        <div class="text-sm font-medium mb-2 text-green-400">Pros</div>
        <ul id="pros-list" class="text-sm space-y-1"></ul>
      </div>
      <div>
        <div class="text-sm font-medium mb-2 text-red-400">Cons</div>
        <ul id="cons-list" class="text-sm space-y-1"></ul>
      </div>
    </div>
  </div>

  <!-- Pseudocode + Prompt Template Tabs -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <div class="flex gap-2 mb-4">
      <button id="tab-pseudo" class="tab-btn bg-primary text-white px-4 py-1.5 rounded-lg text-sm font-medium">Pseudocode</button>
      <button id="tab-prompt" class="tab-btn bg-black/20 border border-border px-4 py-1.5 rounded-lg text-sm font-medium hover:border-primary transition-colors">Prompt Template</button>
    </div>
    <div id="panel-pseudo">
      <div class="flex justify-between items-center mb-2">
        <span class="text-xs text-text-muted">pseudocode</span>
        <button id="copy-pseudo" class="bg-primary text-white px-3 py-1 rounded-lg text-xs hover:opacity-90">Copy</button>
      </div>
      <pre id="pseudocode-output" class="bg-black/30 rounded-lg p-4 text-xs font-mono overflow-x-auto whitespace-pre-wrap text-blue-300 min-h-40"></pre>
    </div>
    <div id="panel-prompt" class="hidden">
      <div class="flex justify-between items-center mb-2">
        <span class="text-xs text-text-muted">prompt template</span>
        <button id="copy-prompt" class="bg-primary text-white px-3 py-1 rounded-lg text-xs hover:opacity-90">Copy</button>
      </div>
      <pre id="prompt-output" class="bg-black/30 rounded-lg p-4 text-xs font-mono overflow-x-auto whitespace-pre-wrap text-green-300 min-h-40"></pre>
    </div>
  </div>

  <!-- Visual Flow Builder -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-3">Visual Flow Builder</h2>
    <p class="text-sm text-text-muted mb-4">Build a custom agent flow by adding steps. Generate a flowchart description and pseudocode from your design.</p>

    <div class="flex gap-2 mb-4 flex-wrap">
      <button class="step-add-btn bg-blue-500/20 border border-blue-500/40 text-blue-400 px-3 py-1.5 rounded-lg text-xs hover:bg-blue-500/30 transition-colors" data-step="Think">+ Think</button>
      <button class="step-add-btn bg-orange-500/20 border border-orange-500/40 text-orange-400 px-3 py-1.5 rounded-lg text-xs hover:bg-orange-500/30 transition-colors" data-step="Act">+ Act</button>
      <button class="step-add-btn bg-green-500/20 border border-green-500/40 text-green-400 px-3 py-1.5 rounded-lg text-xs hover:bg-green-500/30 transition-colors" data-step="Observe">+ Observe</button>
      <button class="step-add-btn bg-purple-500/20 border border-purple-500/40 text-purple-400 px-3 py-1.5 rounded-lg text-xs hover:bg-purple-500/30 transition-colors" data-step="Reflect">+ Reflect</button>
      <button class="step-add-btn bg-yellow-500/20 border border-yellow-500/40 text-yellow-400 px-3 py-1.5 rounded-lg text-xs hover:bg-yellow-500/30 transition-colors" data-step="Plan">+ Plan</button>
      <button class="step-add-btn bg-red-500/20 border border-red-500/40 text-red-400 px-3 py-1.5 rounded-lg text-xs hover:bg-red-500/30 transition-colors" data-step="Evaluate">+ Evaluate</button>
      <button id="clear-flow" class="bg-black/20 border border-border px-3 py-1.5 rounded-lg text-xs hover:border-red-400 hover:text-red-400 transition-colors ml-auto">Clear Flow</button>
    </div>

    <div id="flow-canvas" class="min-h-16 flex flex-wrap gap-3 items-center p-3 bg-black/20 rounded-lg border border-border mb-4">
      <span class="text-text-muted text-xs">Click steps above to build your flow...</span>
    </div>

    <button id="generate-flow" class="bg-primary text-white px-4 py-1.5 rounded-lg text-sm hover:opacity-90 mb-3">Generate Flow Description</button>
    <pre id="flow-output" class="bg-black/30 rounded-lg p-4 text-xs font-mono overflow-x-auto whitespace-pre-wrap text-green-300 min-h-16 hidden"></pre>
  </div>

  <ToolPageCta />
</BaseLayout>

<script>
  interface Pattern {
    title: string;
    description: string;
    whenToUse: string;
    tokenOverhead: string;
    complexity: string;
    pros: string[];
    cons: string[];
    pseudocode: string;
    promptTemplate: string;
  }

  const patterns: Record<string, Pattern> = {
    react: {
      title: "ReAct (Reasoning + Acting)",
      description: "Interleaves chain-of-thought reasoning with action execution in a think → act → observe cycle. The agent reasons about its next action, calls a tool, incorporates the observation, then reasons again until reaching a final answer.",
      whenToUse: "Use ReAct when your agent needs to call external tools (search, APIs, databases, code execution) and must adapt its plan based on intermediate results. It's the standard architecture for LangChain AgentExecutor and most production tool-using agents.",
      tokenOverhead: "500–2000 tokens/task",
      complexity: "Medium",
      pros: [
        "Transparent reasoning trace — easy to debug",
        "Naturally handles multi-step tool-use tasks",
        "Can course-correct after unexpected tool results",
        "Well-supported by all major LLM frameworks"
      ],
      cons: [
        "Sequential execution — each tool call must complete before next step",
        "Token cost grows linearly with number of tool calls",
        "Prone to looping if tool errors aren't handled",
        "Requires well-designed tool descriptions for reliable routing"
      ],
      pseudocode: `function react_agent(task, tools, max_steps=10):
  messages = [system_prompt, user_message(task)]

  for step in range(max_steps):
    # Reasoning phase
    response = llm.complete(messages)
    thought = extract_thought(response)
    action = extract_action(response)

    # Termination check
    if action.type == "final_answer":
      return action.value

    # Acting phase
    tool = tools[action.name]
    observation = tool.call(action.input)

    # Observation phase — update context
    messages.append(assistant_message(thought + action))
    messages.append(tool_result(observation))

  return "Max steps reached — partial result"`,
      promptTemplate: `You are an AI assistant with access to tools.
Solve the task by reasoning step-by-step and using tools when needed.

Format your response as:
Thought: [your reasoning about what to do next]
Action: [tool_name]
Action Input: [input to the tool as JSON]

When you have a final answer, use:
Thought: I now have enough information to answer.
Final Answer: [your complete answer]

Available tools:
{tools_description}

Task: {task}`
    },
    cot: {
      title: "Chain-of-Thought (CoT)",
      description: "Prompts the model to generate explicit intermediate reasoning steps before producing a final answer. Rather than jumping directly to the answer, the model is guided to 'think aloud' through the problem. Can be zero-shot ('think step by step') or few-shot (with worked examples).",
      whenToUse: "Use CoT for mathematical reasoning, logical deduction, multi-step analysis, and any problem where intermediate steps reduce error rate. Particularly effective for GPT-4 and Claude class models. Less effective for simple tasks where reasoning adds unnecessary overhead.",
      tokenOverhead: "200–500 tokens/task",
      complexity: "Low",
      pros: [
        "Simple to implement — just add 'think step by step' to your prompt",
        "Significantly improves accuracy on reasoning tasks",
        "Moderate token overhead compared to other patterns",
        "Reasoning trace is auditable for debugging"
      ],
      cons: [
        "Generated reasoning steps may be post-hoc rationalization",
        "Doesn't help with tasks that require external knowledge or tools",
        "Less effective for small models (<7B parameters)",
        "Fixed linear path — no exploration or backtracking"
      ],
      pseudocode: `function chain_of_thought(question, examples=None):
  if examples:
    # Few-shot CoT
    prompt = format_few_shot_examples(examples)
    prompt += f"\\nQ: {question}\\nA: Let's think step by step."
  else:
    # Zero-shot CoT
    prompt = f"Q: {question}\\nA: Let's think step by step."

  response = llm.complete(prompt)

  # Extract final answer after reasoning
  reasoning, answer = parse_cot_response(response)

  return {
    "reasoning": reasoning,
    "answer": answer
  }`,
      promptTemplate: `Solve the following problem by thinking through it step by step.
Show your reasoning clearly before giving the final answer.

Problem: {problem}

Let's think step by step:
Step 1: [First, identify what we know and what we need to find]
Step 2: [Break down the problem into sub-problems]
Step 3: [Solve each sub-problem]
Step 4: [Combine results to reach the final answer]

Final Answer: [clear, concise answer]`
    },
    tot: {
      title: "Tree of Thoughts (ToT)",
      description: "Explores multiple reasoning paths simultaneously, evaluating and pruning branches. At each decision point, the model generates K candidate next-thoughts, evaluates their promise, and continues exploring the most promising branches. Supports backtracking when branches lead to dead ends.",
      whenToUse: "Use ToT for creative problem-solving, game playing, complex planning, and mathematical proofs where the solution space is non-linear. Best when: there are multiple valid approaches, dead-ends are frequent, and you can define a clear evaluation function for branch quality.",
      tokenOverhead: "5–20× base cost",
      complexity: "High",
      pros: [
        "Finds better solutions than linear approaches for complex problems",
        "Can backtrack from dead ends — more robust than CoT",
        "Parallelizable — branches can be evaluated concurrently",
        "Effective for creative tasks requiring exploration"
      ],
      cons: [
        "Very high token cost — typically 5–20× standard CoT",
        "Requires defining branch evaluation criteria",
        "Complex to implement in production systems",
        "Can hit context limits for deep/wide trees"
      ],
      pseudocode: `function tree_of_thoughts(problem, k=3, depth=3, beam_width=2):
  # k = candidates per step, depth = max depth, beam_width = kept branches

  def expand(state, step_num):
    # Generate k candidate next thoughts
    candidates = []
    for _ in range(k):
      thought = llm.complete(state + f"\\nNext thought {step_num}:")
      score = evaluate_thought(thought)  # LLM or heuristic
      candidates.append((thought, score))
    return sorted(candidates, key=lambda x: x[1], reverse=True)[:beam_width]

  # BFS with beam search
  beam = [(problem, 0.0)]  # (state, cumulative_score)

  for depth_step in range(depth):
    next_beam = []
    for state, score in beam:
      candidates = expand(state, depth_step + 1)
      for thought, thought_score in candidates:
        next_beam.append((state + thought, score + thought_score))
    beam = sorted(next_beam, key=lambda x: x[1], reverse=True)[:beam_width]

    # Check if any branch has a final answer
    for state, _ in beam:
      if is_terminal(state):
        return extract_answer(state)

  # Return best branch result
  return extract_answer(beam[0][0])`,
      promptTemplate: `You are solving a complex problem by exploring multiple reasoning paths.

Problem: {problem}

Generate {k} distinct approaches to this problem. For each approach:
1. Describe the key insight
2. Outline the first 2-3 steps
3. Rate the approach's promise (1-10) and explain why

Approach 1:
Insight: [...]
Steps: [...]
Promise score: [X/10] — because [...]

Approach 2:
[...]

After generating all approaches, select the most promising one and continue developing it to a final answer.`
    },
    sc: {
      title: "Self-Consistency",
      description: "Samples multiple independent reasoning chains for the same problem and aggregates results via majority voting. Instead of relying on a single generation, the model generates N diverse reasoning paths and returns the most consistent answer across all paths.",
      whenToUse: "Use Self-Consistency for tasks with objective right answers: math problems, factual QA, classification, code generation. Particularly effective when your model has medium confidence (not near 100%). Works best with temperature > 0 to ensure diverse sampling.",
      tokenOverhead: "N× base cost (N = sample count)",
      complexity: "Low",
      pros: [
        "Simple to implement — just run the same prompt N times",
        "Provably improves accuracy for math and reasoning tasks",
        "Works without any architectural changes to the base prompt",
        "Calibrated — majority vote score correlates with answer correctness"
      ],
      cons: [
        "Cost scales linearly: 5 samples = 5× the token cost",
        "Only effective when there IS a consistent correct answer",
        "Doesn't help for open-ended creative tasks",
        "Slower due to serial or parallel multi-sampling"
      ],
      pseudocode: `function self_consistency(question, n_samples=5, temperature=0.7):
  reasoning_paths = []
  answers = []

  # Sample N independent reasoning chains
  for i in range(n_samples):
    response = llm.complete(
      prompt=cot_prompt(question),
      temperature=temperature  # Must be > 0 for diversity
    )
    reasoning, answer = parse_response(response)
    reasoning_paths.append(reasoning)
    answers.append(normalize_answer(answer))

  # Majority vote aggregation
  answer_counts = Counter(answers)
  majority_answer = answer_counts.most_common(1)[0][0]
  confidence = answer_counts[majority_answer] / n_samples

  return {
    "answer": majority_answer,
    "confidence": confidence,  # e.g. 0.8 = 4/5 paths agreed
    "all_answers": answers
  }`,
      promptTemplate: `Solve this problem carefully. Think through each step.

Problem: {problem}

Work through this step by step, then state your final answer clearly at the end.

Reasoning:
[work through the problem step by step]

Final Answer: [your answer]

Note: You are one of several reasoning agents solving this problem independently.
Focus on accuracy — show all your work so your reasoning can be verified.`
    },
    reflexion: {
      title: "Reflexion",
      description: "Adds verbal self-reflection and iterative revision cycles to agent execution. After each attempt, the agent evaluates its own output, identifies failures, and stores a verbal reflection in memory. Subsequent attempts are conditioned on prior reflections, guiding the agent toward correct behavior without gradient updates.",
      whenToUse: "Use Reflexion for code generation with test execution feedback, sequential decision making, and any task where you can programmatically evaluate success (test pass/fail, API response validity, constraint satisfaction). Typically converges in 2–4 revision cycles.",
      tokenOverhead: "2–4× per revision cycle",
      complexity: "Medium",
      pros: [
        "Improves performance iteratively without model retraining",
        "Verbal reflections are interpretable and debuggable",
        "Effective for code tasks with automated test evaluation",
        "Can recover from mistakes using stored memory"
      ],
      cons: [
        "Requires an evaluation signal — hard for open-ended tasks",
        "Reflections can reinforce wrong beliefs if evaluator is weak",
        "Memory grows with each failed attempt, increasing context size",
        "May not converge for tasks outside the model's knowledge"
      ],
      pseudocode: `function reflexion_agent(task, evaluator, max_trials=4):
  memory = []  # Stores verbal reflections from past failures

  for trial in range(max_trials):
    # Build prompt with task + past reflections
    prompt = build_prompt(task, memory)

    # Generate attempt
    attempt = llm.complete(prompt)

    # Evaluate attempt
    success, feedback = evaluator.evaluate(attempt)

    if success:
      return attempt  # Task solved

    # Generate verbal reflection on failure
    reflection_prompt = f"""
    Task: {task}
    My attempt: {attempt}
    Evaluation feedback: {feedback}

    Reflect on why this attempt failed and what to do differently:
    """
    reflection = llm.complete(reflection_prompt)
    memory.append(reflection)

  return "Failed after max trials — best attempt: " + attempt`,
      promptTemplate: `You are solving a task with iterative self-improvement.

Task: {task}

{memory_section}

Previous attempts and reflections:
{reflections}

Based on your past attempts and reflections, try again with a better approach.
First, briefly note what you learned from previous failures:
Lesson: [what went wrong and what to do differently]

New attempt:
[your improved solution]`
    },
    'plan-execute': {
      title: "Plan-and-Execute",
      description: "Separates high-level planning from execution. A planner LLM call creates a complete step-by-step plan upfront, then an executor agent works through each plan step sequentially. The plan can be revised if execution encounters blockers. Reduces the context window needed per step compared to ReAct.",
      whenToUse: "Use Plan-and-Execute for long-horizon tasks requiring 5+ steps, when upfront planning reduces wasted execution, and when you want to show users a preview of what the agent will do. Particularly useful for research workflows, code project generation, and complex multi-file operations.",
      tokenOverhead: "Planning: 300–800 tokens + execution cost",
      complexity: "Medium",
      pros: [
        "User can review and modify plan before execution begins",
        "Reduces context window per execution step vs ReAct",
        "Efficient for long-horizon tasks with predictable structure",
        "Easy to checkpoint and resume at any plan step"
      ],
      cons: [
        "Upfront plan may become invalid due to unexpected execution results",
        "Less adaptive than ReAct to mid-task discoveries",
        "Replanning on failure adds overhead",
        "Planner must accurately predict what's needed without executing"
      ],
      pseudocode: `function plan_and_execute(task, tools):
  # Phase 1: Planning
  plan_prompt = f"""
  Task: {task}
  Available tools: {list(tools.keys())}

  Create a numbered step-by-step plan to complete this task.
  Each step should specify: action, tool (if any), expected output.
  """
  plan = llm.complete(plan_prompt)
  steps = parse_plan(plan)

  # Phase 2: Execution
  results = {}
  for i, step in enumerate(steps):
    execution_prompt = f"""
    Overall task: {task}
    Current step ({i+1}/{len(steps)}): {step.description}
    Completed steps: {format_completed(results)}

    Execute this step. Use tool '{step.tool}' if specified.
    """

    if step.tool:
      result = tools[step.tool].call(step.tool_input)
    else:
      result = llm.complete(execution_prompt)

    results[i] = result

    # Replan if step fails
    if is_failed(result) and i < len(steps) - 1:
      steps = replan(task, steps, i, result)

  return synthesize_final_answer(task, results)`,
      promptTemplate: `You are a planning agent. Create a clear, executable plan for the following task.

Task: {task}
Available tools: {tools}

Create a numbered plan. Each step should be:
