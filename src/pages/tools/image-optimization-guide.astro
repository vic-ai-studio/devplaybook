---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "Should I use WebP or AVIF for images in 2026?", answer: "Use AVIF as the primary format and WebP as a fallback. AVIF provides 40–60% smaller files than JPEG at similar quality, with near-universal browser support in 2026. WebP provides 25–35% savings and has slightly wider compatibility. Use the HTML <picture> element with <source type='image/avif'> and <source type='image/webp'> before the <img> fallback. For Next.js, the Image component handles format negotiation automatically." },
  { question: "What image dimensions should I use for responsive images?", answer: "Generate multiple sizes for each image and use srcset: thumbnail (400w), small (800w), medium (1200w), large (1600w), XL (2400w for retina). Use the `sizes` attribute to tell the browser which size to download based on viewport: `sizes='(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw'`. This prevents downloading a 2400px image for a 400px mobile slot, which is the most common image performance mistake." },
  { question: "What quality setting should I use for WebP and AVIF compression?", answer: "WebP: 75–85 quality is nearly indistinguishable from the original for photos. AVIF: 50–70 quality matches WebP 75–85 in visual quality due to more efficient compression. For hero/product images, use 80–85. For thumbnails and gallery images, 70–75 is sufficient. Use Squoosh (squoosh.app) for visual comparison or run `sharp` with different quality settings and compare file sizes and SSIM scores. Never use quality 100 — it's 3–5x larger with no visible improvement." },
  { question: "How do I automate image optimization in a build pipeline?", answer: "Use Sharp (Node.js) for programmatic conversion and resizing: `sharp(input).resize(800).webp({quality: 80}).toFile(output)`. For Astro, use `@astrojs/image` or the built-in Image component which auto-optimizes. For Next.js, the Image component with a provider (Vercel Image Optimization, Cloudinary, Imgix) handles on-demand optimization. For CI, use `imagemin` with imagemin-webp/imagemin-avif to batch-convert assets during build." },
];
---

<BaseLayout
  title="Image Optimization Guide 2026 — WebP, AVIF, srcset & Next-Gen Formats"
  description="Optimize images for the web: convert to WebP and AVIF, implement responsive srcset, use Sharp and Next.js Image component, and reduce image payload by 40-60%."
  tool="image optimization, WebP, AVIF, srcset, responsive images, Sharp, Next.js Image, LCP, web performance"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Image Optimization Guide 2026",
    "url": "https://devplaybook.cc/tools/image-optimization-guide",
    "description": "Reduce image payload 40-60% with WebP/AVIF, responsive srcset, and modern image pipelines.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Image Optimization Guide 2026</h1>
  <p class="text-text-muted mb-6">
    Images account for 50–70% of average webpage weight. Converting to <strong>AVIF/WebP</strong>, implementing responsive <code class="font-mono text-sm bg-bg-card px-1 rounded">srcset</code>, and lazy loading below-fold images typically cuts page weight by 40–60% with zero visual quality loss.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> AVIF & WebP conversion</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Responsive srcset</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Sharp & Next.js Image</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> LCP image optimization</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Format Comparison 2026</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Format</th>
          <th class="border border-border px-3 py-2 text-left">Savings vs JPEG</th>
          <th class="border border-border px-3 py-2 text-left">Browser Support</th>
          <th class="border border-border px-3 py-2 text-left">Best For</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2 font-semibold text-green-400">AVIF</td><td class="border border-border px-3 py-2 text-green-400">40–60%</td><td class="border border-border px-3 py-2 text-green-400">~97% (2026)</td><td class="border border-border px-3 py-2">Photos, hero images</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2 font-semibold text-yellow-400">WebP</td><td class="border border-border px-3 py-2 text-yellow-400">25–35%</td><td class="border border-border px-3 py-2 text-green-400">99%+</td><td class="border border-border px-3 py-2">Fallback for AVIF</td></tr>
        <tr><td class="border border-border px-3 py-2">JPEG</td><td class="border border-border px-3 py-2">baseline</td><td class="border border-border px-3 py-2 text-green-400">100%</td><td class="border border-border px-3 py-2">Legacy fallback only</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">PNG</td><td class="border border-border px-3 py-2 text-red-400">+larger</td><td class="border border-border px-3 py-2 text-green-400">100%</td><td class="border border-border px-3 py-2">Transparency needed</td></tr>
        <tr><td class="border border-border px-3 py-2">SVG</td><td class="border border-border px-3 py-2 text-green-400">Best for icons</td><td class="border border-border px-3 py-2 text-green-400">100%</td><td class="border border-border px-3 py-2">Icons, logos, illustrations</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Responsive Images with srcset</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">&lt;!-- Full responsive image with AVIF/WebP/JPEG fallback --&gt;
&lt;picture&gt;
  &lt;!-- AVIF (best compression) --&gt;
  &lt;source
    type="image/avif"
    srcset="
      /img/hero-400.avif  400w,
      /img/hero-800.avif  800w,
      /img/hero-1200.avif 1200w,
      /img/hero-2400.avif 2400w
    "
    sizes="(max-width: 768px) 100vw, 1200px"
  &gt;
  &lt;!-- WebP fallback --&gt;
  &lt;source
    type="image/webp"
    srcset="
      /img/hero-400.webp  400w,
      /img/hero-800.webp  800w,
      /img/hero-1200.webp 1200w
    "
    sizes="(max-width: 768px) 100vw, 1200px"
  &gt;
  &lt;!-- JPEG final fallback --&gt;
  &lt;img
    src="/img/hero-800.jpg"
    width="1200"
    height="600"
    alt="Hero image"
    loading="eager"
    fetchpriority="high"
  &gt;
&lt;/picture&gt;</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Batch Conversion with Sharp (Node.js)</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">npm install sharp</pre>

  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// scripts/optimize-images.mjs
import sharp from 'sharp';
import &#123; glob &#125; from 'glob';
import path from 'path';

const WIDTHS = [400, 800, 1200, 2400];
const QUALITY = &#123; webp: 80, avif: 60, jpeg: 85 &#125;;

const images = await glob('src/assets/images/**/*.&#123;jpg,jpeg,png&#125;');

for (const file of images) &#123;
  const name = path.basename(file, path.extname(file));
  const dir  = path.dirname(file).replace('src/assets', 'public/img');

  for (const width of WIDTHS) &#123;
    const base = sharp(file).resize(width, null, &#123; withoutEnlargement: true &#125;);

    // Generate AVIF
    await base.clone()
      .avif(&#123; quality: QUALITY.avif &#125;)
      .toFile(`$&#123;dir&#125;/$&#123;name&#125;-$&#123;width&#125;.avif`);

    // Generate WebP
    await base.clone()
      .webp(&#123; quality: QUALITY.webp &#125;)
      .toFile(`$&#123;dir&#125;/$&#123;name&#125;-$&#123;width&#125;.webp`);
  &#125;
  console.log(`✓ $&#123;name&#125;: $&#123;WIDTHS.length * 2&#125; variants generated`);
&#125;</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Next.js Image Component</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">import Image from 'next/image';

// Hero image (LCP) — eager, high priority
&lt;Image
  src="/hero.jpg"
  width=&#123;1200&#125;
  height=&#123;600&#125;
  alt="Hero"
  priority     &#123;/* Sets loading="eager" + fetchpriority="high" */&#125;
  quality=&#123;85&#125;
/&gt;

// Below-fold images — lazy loaded by default
&lt;Image
  src="/product.jpg"
  width=&#123;400&#125;
  height=&#123;400&#125;
  alt="Product"
  sizes="(max-width: 768px) 100vw, 400px"
  quality=&#123;80&#125;
/&gt;

// next.config.js — configure formats
module.exports = &#123;
  images: &#123;
    formats: ['image/avif', 'image/webp'],  // AVIF first
    deviceSizes: [640, 828, 1080, 1200, 1920, 2048, 3840],
    imageSizes:  [16, 32, 48, 64, 96, 128, 256, 384],
  &#125;,
&#125;;</pre>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Image Optimization Guide" relatedTags={['images', 'performance', 'webp', 'avif', 'lcp', 'core-web-vitals']} />
</BaseLayout>
