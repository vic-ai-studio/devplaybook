---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AiModelBenchmarkComparator from '../../components/AiModelBenchmarkComparator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is MMLU and why does it matter?",
    answer: "MMLU (Massive Multitask Language Understanding) tests knowledge across 57 subjects — STEM, humanities, law, medicine, and more. It's the most widely cited general-knowledge benchmark. A score of 90%+ is roughly 'better than most human experts across all domains'. It's measured as % of correct multiple-choice answers."
  },
  {
    question: "What does HumanEval measure?",
    answer: "HumanEval is OpenAI's Python coding benchmark — 164 hand-written programming problems. The model generates a function implementation given a docstring, and it's graded by running unit tests. It measures practical coding ability better than perplexity or next-token prediction. Score = % of problems where all tests pass (pass@1)."
  },
  {
    question: "What is GSM8K?",
    answer: "GSM8K (Grade School Math 8K) contains 8,500 grade school math word problems requiring 2–8 step reasoning chains. It tests arithmetic reasoning and the ability to follow multi-step logical chains. Modern frontier models now score 90%+, while earlier GPT-3-class models scored under 10%."
  },
  {
    question: "Why is TruthfulQA typically lower than other benchmarks?",
    answer: "TruthfulQA specifically tests whether models give truthful answers to questions where humans tend to give misconceptions (e.g., 'Does eating before swimming cause cramps?'). Models trained on human data inherit human misconceptions. Scores in the 60–80% range are typical for frontier models — there is fundamental tension between fluency and factual accuracy."
  },
  {
    question: "Are these benchmark scores comparable across models?",
    answer: "Partially. Benchmark results vary significantly based on: (1) evaluation methodology — 5-shot vs 0-shot vs chain-of-thought prompting, (2) whether models were fine-tuned on benchmark-adjacent data, (3) sampling settings (temperature, top-p). Scores from different papers may not be directly comparable. Always check whether results use the same evaluation setup."
  },
  {
    question: "Which model should I use for coding tasks?",
    answer: "For raw coding (HumanEval), Claude 3.5 Sonnet and GPT-4o are both excellent (90%+ range). For agentic coding with long context (large codebases), Claude 3.5 Sonnet's 200K context window is a significant advantage. For cost-sensitive bulk code generation, GPT-4o mini or Gemini Flash offer strong performance at a fraction of the price."
  },
];
---

<BaseLayout
  title="AI Model Benchmark Comparator — MMLU, HumanEval, GSM8K Scores"
  description="Compare AI model benchmark scores across MMLU, HumanEval, GSM8K, HellaSwag, TruthfulQA, and more. GPT-4o vs Claude 3.5 vs Gemini 1.5 vs Llama 3.1 — interactive visualization."
  tool="AI Model Benchmark Comparator, LLM Benchmark Comparison, GPT-4 vs Claude Benchmark, MMLU Scores, HumanEval Comparison"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "AI Model Benchmark Comparator",
    "url": "https://devplaybook.cc/tools/ai-model-benchmark-comparator",
    "description": "Compare AI model benchmark scores across MMLU, HumanEval, GSM8K, HellaSwag, TruthfulQA, BIG-Bench Hard, ARC, and MATH. Interactive bar charts and full comparison matrix.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">AI Model Benchmark Comparator</h1>
  <p class="text-text-muted mb-4">
    Compare LLM benchmark scores across MMLU, HumanEval, GSM8K, HellaSwag, TruthfulQA, BIG-Bench Hard, ARC, and MATH. Click any benchmark to sort and visualize performance across GPT-4o, Claude, Gemini, Llama, Mistral, and DeepSeek.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 8 benchmarks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 10 frontier models</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Interactive bar charts</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Full comparison matrix</span>
  </div>
  <AiModelBenchmarkComparator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="AI Model Benchmark Comparator" relatedTags={['ai', 'llm', 'benchmark', 'gpt-4', 'claude', 'gemini', 'llama']} />
</BaseLayout>
