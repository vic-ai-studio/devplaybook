---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TypescriptPlayground from '../../components/TypescriptPlayground.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What does this TypeScript playground do?", answer: "It compiles TypeScript to JavaScript in real time. Paste or type TypeScript code and instantly see the equivalent JavaScript output with all type annotations, interfaces, generics, enums, and decorators stripped away." },
  { question: "Does it support all TypeScript features?", answer: "Yes. It handles interfaces, type aliases, generics, enums, access modifiers (public/private/protected), decorators, namespace declarations, and all standard TypeScript syntax. The output targets modern ES2020+ JavaScript." },
  { question: "Can I share my TypeScript code with others?", answer: "Yes. Your code is encoded in the URL. Copy the browser URL and share it — anyone who opens the link sees exactly the same code and output. No account or login needed." },
  { question: "Is the compilation done on a server?", answer: "No. The TypeScript compiler runs entirely in your browser. Your code is never sent to any server, making it safe for proprietary or sensitive code. The compilation uses the same TypeScript compiler that your IDE uses." },
  { question: "How is this different from the official TypeScript Playground?", answer: "This is a lightweight, fast alternative focused on quick TS-to-JS conversion. It loads instantly, has no external dependencies, and runs 100% client-side. For advanced compiler options and type-checking, the official playground offers more configuration." },
];
---

<BaseLayout
  title="TypeScript Playground — Free Online TS to JS Converter"
  description="Write TypeScript and instantly see compiled JavaScript output. Strip interfaces, types, generics, enums, and decorators. Share code via URL. No install needed — runs in your browser."
  tool="TypeScript Playground, TypeScript to JavaScript, TS Compiler Online, TypeScript Converter"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">TypeScript Playground</h1>
  <p class="text-text-muted mb-4">
    Write TypeScript and see the compiled JavaScript output instantly. Strips interfaces, type annotations, generics, enums, access modifiers, and decorators.
    Share your code with a single link — no install or signup required.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <TypescriptPlayground client:load />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="TypeScript Playground" relatedTags={['typescript', 'javascript', 'code', 'development', 'conversion']} />
</BaseLayout>
