---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CsvViewer from '../../components/CsvViewer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What delimiters does the viewer support?", answer: "Comma (,), tab (\\t), semicolon (;), and pipe (|). Select your delimiter from the dropdown if auto-detection picks the wrong one." },
  { question: "Can I view CSV files from my computer?", answer: "Yes. Use the file picker button to open a local .csv or .tsv file. The file is read locally — nothing is uploaded to any server." },
  { question: "Does it support quoted fields with commas inside?", answer: "Yes. RFC 4180 quoted fields are fully supported, including escaped quotes (\"\") and fields containing newlines." },
  { question: "How many rows can I view?", answer: "The viewer renders up to 5,000 rows. For larger files, paste or load the first portion of data." },
  { question: "Can I search within the table?", answer: "Yes. The search box filters rows in real-time across all columns. Matching cells are highlighted." },
];
---

<BaseLayout
  title="CSV Viewer — Preview CSV as a Formatted Table Online"
  description="Preview CSV as a formatted table — paste or open a local file. Supports comma, tab, semicolon, and pipe delimiters. Free CSV viewer, runs in browser."
  tool="CSV Viewer, CSV Table Viewer, View CSV Online, CSV Preview, CSV to Table"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">CSV Viewer</h1>
  <p class="text-text-muted mb-4">Paste CSV data or open a local file to instantly preview it as a formatted table. Supports multiple delimiters, quoted fields, and toggleable header rows. All processing runs in your browser — your data stays private.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Comma, tab, semicolon, pipe delimiters</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Quoted fields & escaped quotes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Search and filter rows</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Client-side only</span>
  </div>
  <CsvViewer client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CSV Viewer" relatedTags={['csv', 'data', 'table', 'viewer', 'spreadsheet']} />
</BaseLayout>
