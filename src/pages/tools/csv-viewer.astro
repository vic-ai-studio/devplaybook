---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CsvViewer from '../../components/CsvViewer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What delimiters does the CSV viewer support?", answer: "The CSV viewer supports comma (,), tab, semicolon (;), and pipe (|) delimiters. Select the correct delimiter from the dropdown — tab-separated files (TSV) are common exports from Excel and Google Sheets." },
  { question: "Does the CSV viewer handle quoted fields?", answer: "Yes. Fields wrapped in double quotes are handled correctly, including fields that contain the delimiter character or newlines. Escaped quotes (\"\") within quoted fields are also supported." },
  { question: "Is my CSV data sent to a server?", answer: "No. All CSV parsing and display happens entirely in your browser using JavaScript. No data is sent to any server." },
  { question: "What is the difference between CSV and TSV?", answer: "CSV (Comma-Separated Values) uses commas as the delimiter. TSV (Tab-Separated Values) uses tab characters. Both are plain text formats for tabular data. Select 'Tab' in the delimiter dropdown to view TSV files." },
];
---

<BaseLayout
  title="CSV Viewer & Table Preview — Free Online Tool"
  description="Paste CSV data and instantly preview it as a formatted table. Supports comma, tab, semicolon, and pipe delimiters. Handles quoted fields and headers. 100% client-side."
  tool="CSV viewer, CSV table preview, TSV viewer, CSV parser online, view CSV as table"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">CSV Viewer</h1>
  <p class="text-text-muted mb-4">Paste any CSV data to instantly preview it as a formatted table. Supports multiple delimiters, quoted fields, and toggleable header rows. Everything runs in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No data leaves your machine</span>
  </div>
  <CsvViewer client:only="preact" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more free developer tools?</p>
    <a href="/tools" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Browse All Free Tools →</a>
  </div>
  <ToolPageCta currentTool="CSV Viewer" relatedTags={['data', 'csv', 'json', 'converter']} />
</BaseLayout>
