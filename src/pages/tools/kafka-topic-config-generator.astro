---
import BaseLayout from '../../layouts/BaseLayout.astro';
import KafkaTopicConfigGenerator from '../../components/KafkaTopicConfigGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "How many partitions should I use?",
    answer: "Partitions determine parallelism. A common rule of thumb: start with max(T/p, T/c) where T is your target throughput, p is the write throughput per partition, and c is the read throughput per partition. For most use cases, 3-12 partitions is a good starting point. More partitions increase parallelism but also increase leader election overhead."
  },
  {
    question: "What replication factor should I use?",
    answer: "For production, use replication factor 3. This tolerates one broker failure while still maintaining a majority quorum (2 of 3 replicas). Replication factor 1 means no fault tolerance — one broker failure loses data. Replication factor 2 means you lose quorum when one broker fails."
  },
  {
    question: "What is min.insync.replicas?",
    answer: "min.insync.replicas defines the minimum number of replicas that must acknowledge a write before it's considered successful (when acks=all). Setting it to replication_factor - 1 is common: e.g., for RF=3, set min.insync.replicas=2. If this value equals or exceeds the replication factor, all replicas must be in sync — meaning any single broker failure blocks writes."
  },
  {
    question: "What's the difference between delete and compact cleanup policies?",
    answer: "cleanup.policy=delete removes messages older than the retention period (time or size based). cleanup.policy=compact retains only the latest message per key — useful for event sourcing and change data capture (CDC). Use compact,delete to apply both: keep only latest keys AND enforce a time-based retention on those records."
  },
  {
    question: "Which compression type should I use?",
    answer: "snappy offers the best balance of compression ratio and CPU cost for most workloads. lz4 is faster with slightly less compression. zstd provides the best compression ratio but requires Kafka 2.1+. gzip has good compression but higher CPU cost. none is zero overhead but increases network and storage costs significantly for text/JSON payloads."
  },
  {
    question: "How do I apply topic-level config changes?",
    answer: "Use kafka-configs.sh --alter --add-config: e.g., kafka-configs.sh --bootstrap-server localhost:9092 --entity-type topics --entity-name my-topic --alter --add-config retention.ms=604800000. Topic-level configs override the broker defaults. Use kafka-configs.sh --describe to see current effective config for a topic."
  },
];
---

<BaseLayout
  title="Kafka Topic Config Generator — CLI Commands & server.properties Snippets"
  description="Generate Kafka topic creation commands, config properties, and Terraform resource blocks. Configure partitions, replication factor, retention, cleanup policy, and compression. Free browser tool."
  tool="Kafka Topic Config Generator, kafka-topics.sh Generator, Kafka CLI Command Builder, Terraform Kafka"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Kafka Topic Config Generator",
    "url": "https://devplaybook.cc/tools/kafka-topic-config-generator",
    "description": "Generate Kafka topic creation CLI commands, config properties, server.properties snippets, and Terraform resource blocks. Configure partitions, replication, retention, and compression.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Kafka Topic Config Generator</h1>
  <p class="text-text-muted mb-4">
    Configure your Kafka topic and get ready-to-run <code class="font-mono bg-surface px-1 rounded text-sm">kafka-topics.sh</code> commands,
    config properties, and a Terraform resource block — all in one place.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> kafka-topics.sh CLI command</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Terraform confluent_kafka_topic</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Validation warnings</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <KafkaTopicConfigGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Kafka Topic Config Generator" relatedTags={['kafka', 'messaging', 'streaming', 'devops', 'infrastructure', 'developer-tools']} />
</BaseLayout>
