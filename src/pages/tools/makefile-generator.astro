---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MakefileGenerator from '../../components/MakefileGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a Makefile?", answer: "A Makefile is a build automation file used by the 'make' command. It defines targets (tasks) and their commands, making it easy to run common project operations like installing dependencies, running tests, building artifacts, or deploying — with a simple 'make <target>' command." },
  { question: "What does .PHONY mean?", answer: ".PHONY declares that a target is not a file on disk. Without it, if a file named 'test' or 'build' exists in your directory, make might skip running the target because it thinks the file is already up to date. Mark non-file targets as .PHONY to ensure they always run." },
  { question: "Why do Makefile commands need tabs (not spaces)?", answer: "The original make program requires a hard tab character at the start of each command line — this is a historical quirk. If you use spaces, make will fail with 'missing separator' errors. This generator adds tabs automatically in the output." },
  { question: "How do I use Makefile variables?", answer: "Variables are defined as NAME := value and referenced as $(NAME). They're useful for configuring values like Docker image names, ports, or environment names without hardcoding them. You can also override them at runtime: make build IMAGE_NAME=my-custom-image." },
  { question: "How do target dependencies work?", answer: "If target B depends on target A, write: B: A. When you run 'make B', make will first run A if it hasn't been run yet in the current session. This lets you chain tasks — for example, 'make deploy' can depend on 'make build' which depends on 'make test'." },
  { question: "Can I use Makefile on Windows?", answer: "Yes, but it requires installation. On Windows you can use GNU Make via WSL (Windows Subsystem for Linux), Chocolatey ('choco install make'), or Git Bash. On macOS and Linux, make is usually pre-installed or available via the system package manager." },
];
---

<BaseLayout
  title="Makefile Generator — Visual Makefile Task Builder"
  description="Free visual Makefile generator. Choose a preset (Node.js, Python, Docker, Go, Terraform), customize targets and variables, and copy a production-ready Makefile. Runs in your browser."
  tool="Makefile generator, Makefile builder, make file generator, Makefile template, build automation, make targets, Makefile tutorial"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Makefile Generator</h1>
  <p class="text-text-muted mb-4">Build Makefiles visually. Start from a preset (Node.js, Python, Docker, Go, Terraform, CI/CD), add or edit targets, define variables, then copy your ready-to-use Makefile — no sign-up required.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 6 language/tool presets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Edit targets interactively</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <MakefileGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Makefile Generator" relatedTags={['build', 'devops', 'automation', 'linux', 'nodejs', 'python', 'docker', 'go']} />
</BaseLayout>
