---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HttpApiTester from '../../components/HttpApiTester.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="HTTP API Tester — Free Online REST Client"
  description="Test REST APIs directly in your browser. Send GET, POST, PUT, PATCH, DELETE requests with custom headers and JSON body. View formatted responses, inspect status codes, and track request history. No install needed."
  tool="API Tester, REST Client, HTTP Tester, Online Postman, API Testing Tool"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "HTTP API Tester",
    "url": "https://devplaybook.cc/tools/api-tester",
    "description": "Free online REST API tester. Send HTTP requests with custom headers, body, and view formatted JSON responses.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">HTTP API Tester</h1>
  <p class="text-text-muted mb-8">
    Send REST API requests directly from your browser — no install, no account. Supports GET, POST, PUT, PATCH, DELETE with custom headers and JSON body.
    Responses are pretty-printed with status code, timing, size, and header inspection. Request history is saved locally.
  </p>
  <HttpApiTester client:load />
  <ToolPageCta currentTool="HTTP API Tester" relatedTags={['api-testing', 'rest-api', 'postman', 'http', 'debugging']} />
</BaseLayout>
