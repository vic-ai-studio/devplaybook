---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is a mobile performance budget?",
    answer: "A performance budget is a set of threshold values for performance metrics that your app must stay within. Examples: 'Cold start time must be under 2 seconds', 'Screen transitions must be ≥60fps', 'Home screen TTI must be under 3 seconds'. Budgets create accountability and catch regressions early — when a metric exceeds its budget, it triggers an investigation before it ships to users."
  },
  {
    question: "What is a good cold start time for a mobile app?",
    answer: "Industry benchmarks: under 2 seconds is considered fast, 2–5 seconds is acceptable, over 5 seconds causes significant abandonment. For context, Facebook targets sub-2-second cold start across all Android devices including low-end hardware. Cold start includes: OS process creation, runtime initialization, loading the first screen's data, and rendering the initial UI."
  },
  {
    question: "What is the difference between cold start and warm start?",
    answer: "Cold start (cold launch) happens when the app process doesn't exist — OS must create the process, load the runtime, and initialize everything from scratch. Warm start happens when the app was recently backgrounded and the process still exists in memory — the OS brings it to the foreground without re-initializing. Warm starts are typically 3–5x faster than cold starts. Always measure both."
  },
  {
    question: "How do I measure frames per second (FPS) in React Native?",
    answer: "React Native has two frame rate metrics: JS FPS (how fast the JavaScript thread can update) and UI FPS (how fast the native rendering thread can draw frames). Access both in the developer menu (shake device > Show Perf Monitor). Flipper's Performance plugin shows frame rate graphs. For automated measurement, Firebase Performance Monitoring can track frame rates in production."
  },
  {
    question: "What is Jank in mobile development?",
    answer: "Jank is visible stutter in animations or scrolling caused by frame rendering taking longer than the target frame time. At 60fps, each frame must complete in 16.67ms. At 120fps (ProMotion), each frame must complete in 8.33ms. A 'janky' frame exceeds this budget. Even occasional jank is noticeable to users — Google research shows 100ms transitions feel instant, 1s causes mental model interruption."
  },
  {
    question: "What tools monitor mobile app performance in production?",
    answer: "Firebase Performance Monitoring (free, integrates with Firebase) tracks launch time, screen rendering time, and custom traces in production. Datadog Mobile Real User Monitoring tracks crash-free sessions, screen load times, and resource loading. Sentry Performance tracks transactions and spans across mobile sessions. New Relic Mobile provides deep transaction tracing for complex backends."
  }
];
---
<BaseLayout
  title="Mobile Performance Budget Calculator: Set App Speed Targets"
  description="Define and enforce mobile performance budgets. Understand key metrics (cold start, FPS, TTI), set thresholds for React Native and native apps, and configure Firebase Performance and Datadog to monitor production."
  tool="mobile-performance-budget-calculator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"Mobile Performance Budget Calculator: Set App Speed Targets","url":"https://devplaybook.cc/tools/mobile-performance-budget-calculator","description":"Define mobile performance budgets, understand key metrics like cold start and FPS, and monitor with Firebase Performance."})} />

  <h1 class="text-3xl font-bold mb-2">Mobile Performance Budget Calculator: Set App Speed Targets</h1>
  <p class="text-text-muted mb-6">Define measurable performance targets for your mobile app. Covers cold start time, frame rate, screen load time, and API response budgets — with monitoring setup for Firebase Performance and Datadog.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Cold start benchmarks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> FPS and jank targets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Firebase Performance setup</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Custom trace instrumentation</span>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Key Mobile Performance Metrics</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 font-semibold">Metric</th>
          <th class="text-left py-2 pr-4 font-semibold">Budget (Fast)</th>
          <th class="text-left py-2 pr-4 font-semibold">Budget (Acceptable)</th>
          <th class="text-left py-2 font-semibold">Alert Threshold</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <tr>
          <td class="py-2 pr-4">Cold start time</td>
          <td class="py-2 pr-4">&lt;1.5s</td>
          <td class="py-2 pr-4">&lt;3s</td>
          <td class="py-2">&gt;5s</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">Warm start time</td>
          <td class="py-2 pr-4">&lt;500ms</td>
          <td class="py-2 pr-4">&lt;1s</td>
          <td class="py-2">&gt;2s</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">Screen load (with data)</td>
          <td class="py-2 pr-4">&lt;1s</td>
          <td class="py-2 pr-4">&lt;2s</td>
          <td class="py-2">&gt;3s</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">UI frame rate</td>
          <td class="py-2 pr-4">60fps</td>
          <td class="py-2 pr-4">55fps avg</td>
          <td class="py-2">&lt;45fps</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">API response (p95)</td>
          <td class="py-2 pr-4">&lt;500ms</td>
          <td class="py-2 pr-4">&lt;1s</td>
          <td class="py-2">&gt;2s</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">Scroll performance</td>
          <td class="py-2 pr-4">0 dropped frames</td>
          <td class="py-2 pr-4">&lt;5% dropped</td>
          <td class="py-2">&gt;15% dropped</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Measuring Cold Start Time</h2>
  <p class="mb-4">Cold start time is measured from when the user taps the app icon to when the first interactive screen is rendered. In React Native:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm">// Measure time to interactive in your root component
import { InteractionManager } from 'react-native';

// In App.tsx — record when app becomes interactive
const appStartTime = Date.now();

export default function App() &#123;
  useEffect(() => &#123;
    InteractionManager.runAfterInteractions(() => &#123;
      const timeToInteractive = Date.now() - appStartTime;
      console.log(`TTI: $&#123;timeToInteractive&#125;ms`);

      // Send to analytics
      analytics.logEvent('app_cold_start', &#123;
        time_ms: timeToInteractive,
        device_type: Platform.OS,
      &#125;);
    &#125;);
  &#125;, []);

  return &lt;RootNavigator /&gt;;
&#125;</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Firebase Performance Monitoring Setup</h2>
  <p class="mb-4">Firebase Performance Monitoring automatically tracks app start time, screen rendering time, and HTTP request performance. Custom traces let you measure any operation:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm">import perf from '@react-native-firebase/perf';

// Custom trace for a specific user flow
async function loadProductPage(productId: string) &#123;
  const trace = await perf().startTrace('product_page_load');

  try &#123;
    trace.putAttribute('product_id', productId);

    const product = await fetchProduct(productId);
    trace.putMetric('data_size_bytes', JSON.stringify(product).length);

    await renderProductDetails(product);
    trace.putMetric('image_count', product.images.length);

    await trace.stop();
    return product;
  &#125; catch (error) &#123;
    trace.putAttribute('error', error.message);
    await trace.stop();
    throw error;
  &#125;
&#125;

// HTTP metric tracking (automatic for fetch, manual for custom clients)
const metric = await perf().newHttpMetric(url, 'GET');
await metric.start();
const response = await fetch(url);
metric.httpResponseCode = response.status;
metric.responseContentType = response.headers.get('content-type') ?? '';
await metric.stop();</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Enforcing Budgets in CI</h2>
  <p class="mb-4">Performance budgets are only useful if they're enforced automatically. Add Detox performance assertions to your E2E test suite:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm">// e2e/performance.test.ts — Detox performance test
describe('Performance Budget', () => &#123;
  it('cold start should be under 3 seconds', async () => &#123;
    const startTime = Date.now();
    await device.launchApp(&#123; newInstance: true &#125;);

    // Wait for the home screen to be visible
    await waitFor(element(by.id('home-screen')))
      .toBeVisible()
      .withTimeout(3000); // Budget: 3 seconds

    const coldStartTime = Date.now() - startTime;
    console.log(`Cold start: $&#123;coldStartTime&#125;ms`);
    expect(coldStartTime).toBeLessThan(3000);
  &#125;);

  it('product list should scroll at 60fps', async () => &#123;
    await element(by.id('product-list')).scroll(1000, 'down');
    // Check Detox performance stats
    const stats = await device.getPerfStats();
    expect(stats.averageFPS).toBeGreaterThanOrEqual(55);
  &#125;);
&#125;);</code></pre>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="mobile-performance-budget-calculator" relatedTags={['react-native', 'mobile', 'performance', 'firebase', 'ios', 'android']} />
</BaseLayout>
