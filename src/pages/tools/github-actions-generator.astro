---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GithubActionsGenerator from '../../components/GithubActionsGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is GitHub Actions?", answer: "GitHub Actions is a CI/CD platform built into GitHub. It lets you automate workflows directly from your repository — running tests on every push, building Docker images on merge, deploying to production on release, and more. Workflows are defined as YAML files in .github/workflows/." },
  { question: "What triggers can I use in GitHub Actions?", answer: "Common triggers include: push (on git push), pull_request (on PR open/update), schedule (cron-based), workflow_dispatch (manual run), release (on GitHub release), and more. You can combine multiple triggers in a single workflow." },
  { question: "What is the difference between a job and a step?", answer: "A job is a collection of steps that run on the same runner (VM). Jobs run in parallel by default. A step is a single task within a job — running a command, using an action, or setting up a tool. Steps within a job run sequentially and share the same file system." },
  { question: "How do I use GitHub secrets in my workflow?", answer: "Store secrets in your repository Settings → Secrets and Variables → Actions. Reference them in your workflow with ${{ secrets.SECRET_NAME }}. Never hardcode tokens or passwords in your YAML — GitHub Actions will mask known secret values in logs." },
  { question: "What is actions/cache and why should I use it?", answer: "actions/cache saves and restores directories between workflow runs (e.g., node_modules, pip cache, Cargo registry). It can reduce workflow run time by 50-80% for dependency-heavy projects. Caches are keyed by a hash of your lock file so they invalidate automatically when dependencies change." },
];
---

<BaseLayout
  title="GitHub Actions Workflow Generator — Free CI/CD YAML Builder"
  description="Generate GitHub Actions YAML workflows instantly. Choose triggers (push, PR, schedule), runtime (Node.js, Python, Go, Rust), and jobs (test, lint, build, Docker, GitHub Pages). Copy-ready .github/workflows/ YAML with best practices built in."
  tool="GitHub Actions Generator, GitHub Actions YAML, CI/CD workflow generator, GitHub Actions Node.js, GitHub Actions Python, GitHub Actions Docker"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">GitHub Actions Workflow Generator</h1>
  <p class="text-text-muted mb-8">Generate a complete <code class="bg-surface px-1 rounded text-sm">.github/workflows/ci.yml</code> in seconds. Pick your triggers, runtime, and jobs — get production-ready YAML with caching, artifact uploads, and Docker support built in.</p>
  <GithubActionsGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="GitHub Actions Generator" relatedTags={['ci-cd', 'github', 'devops', 'automation', 'docker']} />
</BaseLayout>
