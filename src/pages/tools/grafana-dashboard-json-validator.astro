---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GrafanaDashboardJsonValidator from '../../components/GrafanaDashboardJsonValidator.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How do I export a Grafana dashboard to JSON?", answer: "In Grafana: open the dashboard → click the Share button (chain icon) → Export tab → Save to file. Or: Dashboard settings (gear icon) → JSON Model to view/copy inline. For API export: GET /api/dashboards/uid/{uid}. The exported JSON can be imported back or stored in version control for dashboard-as-code workflows." },
  { question: "What is the Grafana dashboard schema version?", answer: "The schemaVersion field tracks the Grafana internal dashboard format version. Current is 39 (Grafana 10.x). Old dashboards with schemaVersion below 30 may miss features like new panel types, datasource format changes, or unified alerting. When importing old dashboards, Grafana migrates them automatically, but storing the migrated version is recommended." },
  { question: "How do I manage Grafana dashboards as code?", answer: "Options: (1) Grafana provisioning — mount JSON files to /etc/grafana/provisioning/dashboards/ and add a YAML provisioner config. (2) Terraform with grafana provider — grafana_dashboard resource. (3) Ansible grafana_dashboard module. (4) Grizzly CLI (grafana/grizzly) for GitOps. All approaches require UID-based dashboards for idempotent updates." },
  { question: "What changed with datasources in Grafana 9/10?", answer: "Grafana 9+ changed datasource references from string names to objects: { 'type': 'prometheus', 'uid': '...' }. The UID is the datasource UID (visible in Admin > Data Sources). Using string names still works but shows deprecation warnings. For dashboard provisioning, use ${DS_PROMETHEUS} template variables so the datasource can be mapped at import time." },
  { question: "How do I fix panel gridPos layout issues?", answer: "Each panel needs a gridPos object: { h: rows, w: columns, x: col-offset, y: row-offset }. Grafana's grid is 24 columns wide. Full-width panel: w=24. Half-width: w=12. Quarter: w=6. Panels with overlapping gridPos will render incorrectly. If you're programmatically generating dashboards, use a layout helper or sort panels by y then x before setting positions." },
  { question: "Can I validate dashboard provisioning YAML?", answer: "This tool validates the dashboard JSON payload. For the provisioning YAML (grafana.ini / datasources.yaml / dashboards.yaml), use: grafana-cli --config /etc/grafana/grafana.ini admin data-migration, or simply restart Grafana and check logs. Provisioning errors appear in grafana.log as 'failed to save dashboard'. The Grafana provisioning docs cover the full YAML schema." },
];
---

<BaseLayout
  title="Grafana Dashboard JSON Validator — Check Panel Config & Datasources — Free Online Tool"
  description="Validate Grafana dashboard JSON files online. Detects syntax errors, missing required fields, panel configuration issues, datasource format problems, and gridPos layout errors. Works with Grafana 8, 9, and 10."
  tool="grafana dashboard json validator, grafana dashboard checker, grafana panel config, grafana datasource uid, grafana json model, grafana provisioning validator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Grafana Dashboard JSON Validator</h1>
  <p class="text-text-muted mb-8">Validate Grafana dashboard JSON files. Checks panel configuration, datasource references, gridPos layout, schema version compatibility, and Grafana 10+ datasource format requirements. Export your dashboard and paste below.</p>
  <GrafanaDashboardJsonValidator client:only="preact" />
  <FaqSection faq={faq} />
  <AffiliateSection category={['monitoring', 'devops']} />
  <ToolPageCta currentTool="Grafana Dashboard JSON Validator" relatedTags={['grafana', 'monitoring', 'devops', 'observability', 'dashboard']} />
</BaseLayout>
