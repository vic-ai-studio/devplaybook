---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What does the g (global) flag do in regex?", answer: "The g (global) flag makes the regex find all matches instead of stopping after the first one. Without g, methods like String.match() return only the first match. With g, they return an array of all matches. String.replace() with g replaces all occurrences; without it, only the first is replaced." },
  { question: "What does the i (case insensitive) flag do?", answer: "The i flag makes the regex match regardless of letter case. /hello/i matches 'Hello', 'HELLO', 'hElLo', and 'hello'. This is useful for user input validation where you don't want case to matter, like checking for keywords or usernames." },
  { question: "What is the m (multiline) flag used for?", answer: "The m flag changes how ^ and $ anchors behave. Without m, ^ matches the start of the entire string and $ matches the end. With m, ^ matches the start of each line and $ matches the end of each line. This is essential when processing multi-line text where you want to match patterns at line boundaries." },
  { question: "What does the s (dotAll) flag do?", answer: "The s flag (also called dotAll) makes the dot (.) match any character including newlines. Normally, . matches everything except \\n (newline). With /s, . matches \\n too, which is useful for matching patterns that span multiple lines like HTML tags or multi-line strings." },
  { question: "When should I use the u (unicode) flag?", answer: "The u flag enables proper Unicode support. Without it, regex treats emoji and characters outside the Basic Multilingual Plane (BMP) as two surrogate pairs. With /u, \\w, \\b, and character classes work correctly with Unicode. Use /u whenever your input may contain non-ASCII characters or emoji." },
  { question: "What is the y (sticky) flag?", answer: "The y flag makes the regex 'sticky' — it only matches at the exact position stored in regex.lastIndex. Unlike g which searches the whole string, y only succeeds if a match starts right at lastIndex. This is used in tokenizers and parsers where you need sequential matching at exact positions." },
];
---

<BaseLayout
  title="Regex Flags Explainer — Understand g, i, m, s, u, y JavaScript Regex Flags"
  description="Interactive JavaScript regex flags explainer. Understand what g, i, m, s, u, and y flags do with live examples. Test your regex with all flag combinations. Free, browser-based tool."
  tool="regex flags explainer, JavaScript regex flags, regex g flag, regex i flag, regex m flag, dotAll flag, unicode flag, sticky flag"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Regex Flags Explainer",
    "url": "https://devplaybook.cc/tools/regex-flags-explainer",
    "description": "Interactive tool to understand JavaScript regex flags (g, i, m, s, u, y). See what each flag does to matches with live examples.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Regex Flags Explainer</h1>
  <p class="text-text-muted mb-4">
    Enter a regex pattern and test string, then toggle flags to see how each one changes what matches.
    Covers all 6 JavaScript regex flags: <code class="font-mono text-sm">g</code>, <code class="font-mono text-sm">i</code>,
    <code class="font-mono text-sm">m</code>, <code class="font-mono text-sm">s</code>,
    <code class="font-mono text-sm">u</code>, and <code class="font-mono text-sm">y</code>.
  </p>
  <div class="flex items-center gap-3 mb-8 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live match highlighting</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Per-flag explanation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Toggle flags interactively</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <!-- Input section -->
  <div class="space-y-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
        <div>
          <label class="text-xs text-text-muted block mb-2" for="rf-pattern">Regex Pattern</label>
          <div class="flex items-center gap-1">
            <span class="text-text-muted font-mono">/</span>
            <input id="rf-pattern" type="text" value="hello" placeholder="pattern"
              class="flex-1 bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
            <span class="text-text-muted font-mono">/</span>
            <span id="rf-flags-display" class="text-primary font-mono text-sm min-w-[2ch]">g</span>
          </div>
        </div>
        <div>
          <label class="text-xs text-text-muted block mb-2">Active Flags</label>
          <div class="flex gap-2 flex-wrap" id="rf-flag-buttons">
            {['g', 'i', 'm', 's', 'u', 'y'].map(f => (
              <button
                data-flag={f}
                class={`rf-flag-btn px-3 py-1.5 rounded-lg font-mono text-sm font-bold border transition-colors ${f === 'g' ? 'bg-indigo-600 border-indigo-500 text-white' : 'bg-bg border-border text-text-muted hover:border-primary'}`}
              >
                {f}
              </button>
            ))}
          </div>
        </div>
      </div>

      <div>
        <div class="flex items-center justify-between mb-2">
          <label class="text-xs text-text-muted" for="rf-input">Test String</label>
          <button id="rf-example" class="text-xs text-primary hover:underline">Load example</button>
        </div>
        <textarea id="rf-input" rows="4"
          placeholder="Enter test string here..."
          class="w-full bg-bg border border-border rounded-lg px-3 py-3 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40 resize-y">Hello World! hello world. HELLO WORLD!</textarea>
      </div>
    </div>

    <!-- Results -->
    <div id="rf-results" class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <span class="font-semibold text-sm">Match Results</span>
        <span id="rf-match-count" class="text-xs text-text-muted"></span>
      </div>
      <div id="rf-error" class="hidden p-3 bg-red-500/10 border border-red-500/20 rounded-lg text-sm text-red-400 mb-3"></div>
      <div id="rf-highlighted" class="font-mono text-sm bg-bg border border-border rounded-lg px-3 py-3 whitespace-pre-wrap break-all leading-6 min-h-[60px]"></div>
      <div id="rf-matches-list" class="mt-3 space-y-1"></div>
    </div>
  </div>

  <!-- Flags reference -->
  <div class="bg-bg-card border border-border rounded-xl p-6 mb-8">
    <h2 class="font-bold text-sm uppercase tracking-wide text-text-muted mb-4">Flag Reference</h2>
    <div class="space-y-3" id="rf-flag-reference">
      {[
        { flag: 'g', name: 'global', color: 'indigo', desc: 'Find all matches instead of stopping after the first. Required for replace-all and match-all operations.', ex: '/hello/g on "hello hello" → 2 matches' },
        { flag: 'i', name: 'ignoreCase', color: 'blue', desc: 'Case-insensitive matching. /hello/i matches Hello, HELLO, hElLo.', ex: '/hello/i on "Hello World" → 1 match' },
        { flag: 'm', name: 'multiline', color: 'violet', desc: 'Makes ^ match start-of-line and $ match end-of-line (not just start/end of string).', ex: '/^hello/gm on "hello\\nworld\\nhello" → 2 matches' },
        { flag: 's', name: 'dotAll', color: 'purple', desc: 'Makes . match any character including newlines (\\n). Normally . does not match newlines.', ex: '/.+/gs on "line1\\nline2" → full string match' },
        { flag: 'u', name: 'unicode', color: 'pink', desc: 'Enables full Unicode support. Treats surrogate pairs correctly. Required for emoji and non-BMP characters.', ex: '/\\u{1F600}/u matches 😀 correctly' },
        { flag: 'y', name: 'sticky', color: 'rose', desc: 'Only matches at the exact position of regex.lastIndex. Does not advance through the string like g.', ex: '/hello/y with lastIndex=6 only matches at position 6' },
      ].map(f => (
        <div class={`p-4 rounded-xl border bg-${f.color}-500/5 border-${f.color}-500/20`}>
          <div class="flex items-start gap-3">
            <code class={`shrink-0 text-${f.color}-400 font-mono font-bold text-lg leading-none mt-0.5`}>{f.flag}</code>
            <div>
              <div class="flex items-center gap-2 mb-1">
                <span class="font-semibold text-sm">{f.name}</span>
                <code class={`text-xs px-2 py-0.5 rounded bg-${f.color}-500/10 text-${f.color}-400 font-mono`}>/{f.flag}</code>
              </div>
              <p class="text-sm text-text-muted mb-1">{f.desc}</p>
              <code class="text-xs text-text-muted/70 font-mono">{f.ex}</code>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <AffiliateSection />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Regex Flags Explainer" relatedTags={['regex', 'javascript', 'string', 'developer-tools']} />
</BaseLayout>

<script is:inline>
(function () {
  var activeFlags = new Set(['g']);

  var EXAMPLES = [
    { pattern: 'hello', input: 'Hello World! hello world. HELLO WORLD!' },
    { pattern: '^line', input: 'line one\nline two\nnot a line start' },
    { pattern: 'a.b', input: 'aXb\na\nb\naXXb' },
    { pattern: '\\w+', input: 'foo bar baz 123' },
  ];

  function getFlags() { return Array.from(activeFlags).join(''); }

  function updateFlagsDisplay() {
    document.getElementById('rf-flags-display').textContent = getFlags() || '';
  }

  function runMatch() {
    var patternInput = document.getElementById('rf-pattern').value;
    var testStr = document.getElementById('rf-input').value;
    var errEl = document.getElementById('rf-error');
    var highlEl = document.getElementById('rf-highlighted');
    var matchCount = document.getElementById('rf-match-count');
    var matchList = document.getElementById('rf-matches-list');

    errEl.classList.add('hidden');
    highlEl.innerHTML = '';
    matchList.innerHTML = '';
    matchCount.textContent = '';

    if (!patternInput) {
      highlEl.textContent = testStr;
      return;
    }

    var flags = getFlags();
    // y flag requires g removed
    var regexFlags = flags.replace('g', '') ; // keep y separate from g
    if (flags.includes('g') && !flags.includes('y')) regexFlags = flags;

    try {
      var re = new RegExp(patternInput, flags.replace('y', '') + (flags.includes('y') ? 'g' : ''));
      // For y flag, simulate sticky behavior
      if (flags.includes('y') && !flags.includes('g')) {
        re = new RegExp(patternInput, flags);
      }

      var matches = [];
      if (flags.includes('g') || flags.includes('y')) {
        var m;
        re.lastIndex = 0;
        while ((m = re.exec(testStr)) !== null) {
          matches.push({ index: m.index, length: m[0].length, value: m[0] });
          if (m[0].length === 0) re.lastIndex++;
          if (matches.length > 1000) break;
        }
      } else {
        var single = re.exec(testStr);
        if (single) matches.push({ index: single.index, length: single[0].length, value: single[0] });
      }

      matchCount.textContent = matches.length + ' match' + (matches.length !== 1 ? 'es' : '');

      // Highlight
      if (!matches.length) {
        highlEl.textContent = testStr;
      } else {
        var result = '';
        var prev = 0;
        matches.forEach(function(m) {
          result += escHtml(testStr.slice(prev, m.index));
          result += '<mark class="bg-yellow-400/30 text-yellow-200 rounded px-0.5">' + escHtml(m.value) + '</mark>';
          prev = m.index + m.length;
        });
        result += escHtml(testStr.slice(prev));
        highlEl.innerHTML = result;
      }

      // Match list (first 10)
      if (matches.length) {
        var shown = matches.slice(0, 10);
        shown.forEach(function(m, i) {
          var div = document.createElement('div');
          div.className = 'flex items-center gap-3 text-xs font-mono';
          div.innerHTML = '<span class="text-text-muted w-5 text-right">'+(i+1)+'.</span>'
            +'<span class="bg-yellow-400/20 text-yellow-300 px-2 py-0.5 rounded">'+escHtml(m.value)+'</span>'
            +'<span class="text-text-muted">index: '+m.index+'</span>';
          matchList.appendChild(div);
        });
        if (matches.length > 10) {
          var more = document.createElement('div');
          more.className = 'text-xs text-text-muted pl-8';
          more.textContent = '… and ' + (matches.length - 10) + ' more';
          matchList.appendChild(more);
        }
      }
    } catch (e) {
      errEl.textContent = 'Invalid regex: ' + e.message;
      errEl.classList.remove('hidden');
      highlEl.textContent = testStr;
    }
  }

  function escHtml(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // Flag buttons
  document.getElementById('rf-flag-buttons').addEventListener('click', function(e) {
    var btn = e.target.closest('.rf-flag-btn');
    if (!btn) return;
    var flag = btn.dataset.flag;

    // g and y are mutually exclusive
    if (flag === 'g' && activeFlags.has('y')) activeFlags.delete('y');
    if (flag === 'y' && activeFlags.has('g')) activeFlags.delete('g');

    if (activeFlags.has(flag)) {
      activeFlags.delete(flag);
      btn.className = 'rf-flag-btn px-3 py-1.5 rounded-lg font-mono text-sm font-bold border transition-colors bg-bg border-border text-text-muted hover:border-primary';
    } else {
      activeFlags.add(flag);
      btn.className = 'rf-flag-btn px-3 py-1.5 rounded-lg font-mono text-sm font-bold border transition-colors bg-indigo-600 border-indigo-500 text-white';
    }

    // Sync sibling buttons if g/y conflict
    document.querySelectorAll('.rf-flag-btn').forEach(function(b) {
      var f = b.dataset.flag;
      if (activeFlags.has(f)) {
        b.className = 'rf-flag-btn px-3 py-1.5 rounded-lg font-mono text-sm font-bold border transition-colors bg-indigo-600 border-indigo-500 text-white';
      } else {
        b.className = 'rf-flag-btn px-3 py-1.5 rounded-lg font-mono text-sm font-bold border transition-colors bg-bg border-border text-text-muted hover:border-primary';
      }
    });

    updateFlagsDisplay();
    runMatch();
  });

  document.getElementById('rf-pattern').addEventListener('input', function() { runMatch(); });
  document.getElementById('rf-input').addEventListener('input', function() { runMatch(); });

  document.getElementById('rf-example').addEventListener('click', function() {
    var ex = EXAMPLES[Math.floor(Math.random() * EXAMPLES.length)];
    document.getElementById('rf-pattern').value = ex.pattern;
    document.getElementById('rf-input').value = ex.input;
    runMatch();
  });

  // Initial run
  updateFlagsDisplay();
  runMatch();
})();
</script>
