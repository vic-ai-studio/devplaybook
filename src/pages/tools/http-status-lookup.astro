---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HttpStatusLookup from '../../components/HttpStatusLookup.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the difference between 401 and 403?",
    answer: "401 Unauthorized means the client is not authenticated — the server doesn't know who you are (despite the misleading name, it means 'unauthenticated'). 403 Forbidden means the client is authenticated but lacks permission to access the resource."
  },
  {
    question: "When should I use 404 vs 410?",
    answer: "Use 404 when a resource doesn't exist or you don't want to reveal its existence. Use 410 Gone when a resource has been permanently deleted and you want to signal this intentionally — search engines will de-index 410 pages faster than 404s."
  },
  {
    question: "What is the difference between 301 and 308?",
    answer: "Both are permanent redirects, but 301 allows browsers to change POST to GET on the redirect, while 308 preserves the original method. Use 308 when moving a POST API endpoint permanently."
  },
  {
    question: "When should I use 422 instead of 400?",
    answer: "Use 400 for syntactically malformed requests (invalid JSON, missing required headers). Use 422 for requests that are syntactically valid but fail semantic/business validation (invalid email format, end date before start date, etc.)."
  },
  {
    question: "What does 429 require in the response?",
    answer: "When returning 429, include a Retry-After header (seconds or HTTP-date) and optionally X-RateLimit-Limit, X-RateLimit-Remaining, and X-RateLimit-Reset headers for better developer experience."
  },
];
---

<BaseLayout
  title="HTTP Status Code Lookup — Search 1xx–5xx Codes with Descriptions"
  description="Search all HTTP status codes by number or keyword. Get plain-English descriptions, common use cases, and RFC references for 200, 201, 301, 400, 401, 403, 404, 422, 429, 500, 502, 503, 504, and more."
  tool="HTTP Status Code Lookup, HTTP Response Codes, HTTP Error Codes Reference, REST API Status Codes"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "HTTP Status Code Lookup",
    "url": "https://devplaybook.cc/tools/http-status-lookup",
    "description": "Search all HTTP status codes from 1xx to 5xx. Plain-English descriptions, use cases, and RFC references.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">HTTP Status Code Lookup</h1>
  <p class="text-text-muted mb-4">
    Search all HTTP status codes from 1xx to 5xx. Click any code to see a plain-English description,
    common use cases, and the RFC reference. Filter by category to browse all codes in a group.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All 1xx–5xx codes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Search by code or keyword</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> RFC references</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Filter by category</span>
  </div>
  <HttpStatusLookup client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="HTTP Status Code Lookup" relatedTags={['http', 'api', 'rest-api', 'web', 'developer-tools']} />
</BaseLayout>
