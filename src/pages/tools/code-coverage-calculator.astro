---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CodeCoverageCalculator from '../../components/CodeCoverageCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What are the four types of code coverage?",
    answer: "The four standard coverage types are: Lines (percentage of source lines executed), Functions (percentage of functions/methods called), Branches (percentage of decision branches taken — e.g. both true and false sides of an if statement), and Statements (percentage of individual statements executed). Branch coverage is generally the strictest and most meaningful measure of test thoroughness.",
  },
  {
    question: "What is a good code coverage percentage?",
    answer: "80% is the widely accepted industry standard for most production projects. Google's engineering practices recommend 60% as acceptable, 75% as good, and 90%+ as exemplary. However, raw coverage percentages can be misleading — 100% line coverage does not mean your tests verify the correct behavior. Focus on meaningful assertions alongside coverage targets.",
  },
  {
    question: "How do I enforce coverage thresholds in Jest or Vitest?",
    answer: "Add a coverageThreshold block to your jest.config.js or vitest.config.ts under the coverage key. Set global thresholds for lines, functions, branches, and statements as percentages (0–100). When running with --coverage, Jest/Vitest will fail the run if any metric falls below the configured threshold — perfect for CI enforcement.",
  },
  {
    question: "What is the difference between line coverage and branch coverage?",
    answer: "Line coverage counts whether a line was executed at least once. Branch coverage checks whether every logical path was taken — for example, both the true and false branches of an if/else. A line can be 'covered' even if only one branch was tested, so branch coverage catches gaps that line coverage misses. Always aim to meet both thresholds.",
  },
  {
    question: "Why does my CI fail even though my coverage looks high locally?",
    answer: "Common causes: (1) Your jest.config.js has a coverageThreshold that one metric falls below. (2) You are running coverage on a different set of files locally vs CI (check collectCoverageFrom). (3) A new file was added without tests, which reduces overall percentages. (4) You're comparing v8 vs babel coverage providers, which count differently. Run jest --coverage --verbose locally to match CI exactly.",
  },
  {
    question: "Does 100% code coverage mean my code is bug-free?",
    answer: "No. 100% coverage means every line was executed during tests, but it says nothing about whether those tests actually assert correct behavior. You can achieve 100% coverage with tests that never check any output. Coverage is a floor, not a ceiling — combine it with meaningful assertions, property-based testing, and integration tests for real confidence.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Code Coverage Calculator",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "description": "Calculate code coverage percentages for lines, functions, branches, and statements. Set thresholds, check pass/fail status, and generate Jest/Vitest config snippets.",
  "url": "https://devplaybook.cc/tools/code-coverage-calculator",
};
---

<BaseLayout
  title="Code Coverage Calculator — Calculate Coverage % & Thresholds"
  description="Free code coverage calculator for lines, functions, branches, and statements. Set thresholds, view pass/fail status, generate Jest/Vitest config, and preview coverage badges. Runs entirely in your browser."
  tool="Code Coverage Calculator, Jest Coverage Threshold, Vitest Coverage Config, Test Coverage Checker, Code Coverage Badge"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <h1 class="text-3xl font-bold mb-2">Code Coverage Calculator</h1>
  <p class="text-text-muted mb-4">Enter covered and total counts for each metric to instantly calculate coverage percentages, check against thresholds, and generate a ready-to-paste Jest or Vitest <code class="bg-bg-card px-1 py-0.5 rounded text-xs font-mono">coverageThreshold</code> config. Everything runs in your browser — no data leaves your machine.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Lines, Functions, Branches &amp; Statements</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Configurable pass/fail thresholds</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Jest &amp; Vitest config snippet</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Coverage badge preview</span>
  </div>
  <CodeCoverageCalculator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Code Coverage Calculator" relatedTags={['testing', 'jest', 'vitest', 'javascript', 'typescript', 'code-quality']} />
</BaseLayout>
