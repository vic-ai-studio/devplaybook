---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SshConfigGenerator from '../../components/SshConfigGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the SSH config file?", answer: "The SSH config file (~/.ssh/config) lets you define named aliases for SSH connections. Instead of typing 'ssh -i ~/.ssh/key.pem ubuntu@ec2-xx-xx.compute.amazonaws.com', you can define a Host alias and just type 'ssh my-ec2'. It supports all SSH options including port, user, identity file, proxy jump, and more." },
  { question: "How do I use the generated config?", answer: "Copy the output and paste it into ~/.ssh/config (create the file if it doesn't exist). Then set permissions with 'chmod 600 ~/.ssh/config'. After that, you can connect using just 'ssh <alias>' instead of the full command with flags." },
  { question: "What is ProxyJump used for?", answer: "ProxyJump lets you connect to a server that isn't directly accessible from the internet — you route the connection through a bastion or jump host. For example, if your internal server is only reachable from your bastion, set ProxyJump to the bastion host alias. SSH handles the tunneling automatically." },
  { question: "What is ForwardAgent?", answer: "ForwardAgent (yes/no) allows the SSH agent running on your local machine to be forwarded to the remote host. This means the remote host can use your local SSH keys to authenticate to other servers — useful for Git operations on remote servers without copying your private key there. Use with caution on untrusted hosts." },
  { question: "What is ServerAliveInterval?", answer: "ServerAliveInterval tells SSH to send a keepalive packet every N seconds when the connection is idle. This prevents the connection from being dropped by firewalls or NAT devices that close idle TCP sessions. A common value is 60 seconds." },
  { question: "Is it safe to store SSH config in a file?", answer: "Yes — the SSH config file contains connection parameters, not credentials. Your private key files (IdentityFile) are separate and protected by file permissions. The config file itself should be owned by your user and have permissions 600 or 644. Never store private keys or passphrases in the config file." },
];
---

<BaseLayout
  title="SSH Config Generator — Free ~/.ssh/config Builder"
  description="Generate ~/.ssh/config entries visually. Set host alias, hostname, user, port, identity file, ProxyJump, ForwardAgent, and compression. Templates for AWS EC2, GitHub, jump hosts. Copy-ready output."
  tool="SSH Config Generator, SSH Config Builder, ~/.ssh/config Generator, SSH Alias Builder, SSH ProxyJump, SSH Key Config, SSH Tunnel Config"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">SSH Config Generator</h1>
  <p class="text-text-muted mb-4">Build <code class="font-mono text-sm">~/.ssh/config</code> entries visually. Set host alias, hostname, user, port, identity file, ProxyJump for bastion hosts, and more. Templates for AWS EC2, GitHub, and jump hosts. Copy the output and save to <code class="font-mono text-sm">~/.ssh/config</code>.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> AWS, GitHub & jump host templates</span>
  </div>
  <SshConfigGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SSH Config Generator" relatedTags={['devops', 'security', 'linux', 'cloud', 'server']} />
</BaseLayout>
