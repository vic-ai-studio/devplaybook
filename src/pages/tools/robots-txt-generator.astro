---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RobotsTxtGenerator from '../../components/RobotsTxtGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is robots.txt?", answer: "robots.txt is a plain-text file placed at the root of your domain (e.g. https://example.com/robots.txt) that tells web crawlers which pages they are allowed or not allowed to access. It follows the Robots Exclusion Protocol and is the standard way to communicate crawl preferences to search engines and bots." },
  { question: "Does robots.txt block all bots?", answer: "No. robots.txt is a voluntary standard — well-behaved bots like Googlebot, Bingbot, and most major crawlers follow it. However, malicious scrapers and some AI training crawlers may ignore it entirely. For truly private content, use server-side access controls (authentication, firewall rules) rather than relying solely on robots.txt." },
  { question: "What is the difference between Disallow and Allow?", answer: "Disallow blocks a crawler from accessing a path. Allow explicitly permits access to a path that would otherwise be blocked by a more general Disallow rule. Allow rules take precedence over Disallow for the same path length — for example, you can Disallow /private/ but Allow /private/public/ to expose just that subfolder." },
  { question: "What does Crawl-delay do?", answer: "Crawl-delay tells a bot to wait N seconds between requests to your server. This prevents aggressive crawlers from overloading your server. Note: Googlebot ignores Crawl-delay in favor of its own crawl rate settings in Google Search Console. Bingbot and some others do respect it." },
  { question: "Should I block AI training crawlers?", answer: "Many site owners now block AI data-collection bots like GPTBot (OpenAI), CCBot (Common Crawl), and anthropic-ai to prevent their content from being used to train AI models without consent. You can add separate User-agent blocks for each. Use the 'Block AI crawlers' preset to generate these rules automatically." },
];
---

<BaseLayout
  title="Robots.txt Generator — Free Visual Builder"
  description="Free robots.txt generator with visual builder. Add user-agent rules, allow/disallow paths, crawl-delay, and sitemap URL. Block AI crawlers, protect admin paths, or allow all bots. Live preview with one-click copy."
  tool="Robots.txt Generator, Robots.txt Builder, Robots.txt Creator, Crawl Control, Block Googlebot, Block AI Crawlers, SEO Robots File, User-agent Rules"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Robots.txt Generator</h1>
  <p class="text-text-muted mb-4">Build your robots.txt file visually. Add user-agent rules, disallow/allow paths, crawl-delay, and sitemap URL. Use presets to block AI training crawlers or restrict search engines from private paths — everything runs in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Block AI crawlers preset</span>
  </div>
  <RobotsTxtGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Robots.txt Generator" relatedTags={['seo', 'web', 'security', 'devops', 'automation']} />
</BaseLayout>
