---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DnsLookup from '../../components/DnsLookup.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What DNS record types can I look up?",
    answer: "This tool supports A (IPv4 address), AAAA (IPv6 address), CNAME (canonical name / alias), MX (mail exchange), TXT (arbitrary text, used for SPF, DKIM, domain verification), NS (nameservers), SOA (start of authority — zone metadata), and PTR (reverse DNS — IP to hostname). These cover the vast majority of real-world DNS debugging scenarios.",
  },
  {
    question: "How does this DNS lookup tool work?",
    answer: "Queries are sent to Cloudflare's DNS-over-HTTPS (DoH) API at cloudflare-dns.com/dns-query. This means all lookups are encrypted (HTTPS), authoritative results come directly from Cloudflare's 1.1.1.1 resolver, and nothing passes through a proxy server. Your queries go directly from your browser to Cloudflare's public DNS.",
  },
  {
    question: "What is the difference between an A and AAAA record?",
    answer: "An A record maps a hostname to an IPv4 address (e.g. 93.184.216.34). An AAAA record maps a hostname to an IPv6 address (e.g. 2606:2800:220:1:248:1893:25c8:1946). Most domains have both for dual-stack connectivity. If you're diagnosing connectivity issues, check both — a missing AAAA record can cause IPv6 clients to fall back to IPv4.",
  },
  {
    question: "What is a CNAME record and when should I use it?",
    answer: "A CNAME (Canonical Name) record is an alias from one hostname to another. For example, www.example.com CNAME example.com means www resolves to whatever example.com resolves to. CNAMEs are useful for subdomains pointing to services (like a CDN or Vercel), but can't be used at the zone apex (root domain). At the root, use ALIAS or ANAME records (proprietary to some DNS providers) or A records.",
  },
  {
    question: "What is DNS TTL?",
    answer: "TTL (Time To Live) is the number of seconds resolvers and browsers should cache a DNS record before re-querying. A TTL of 300 means 5 minutes. Low TTLs (60–300s) allow fast failover and migrations. High TTLs (3600–86400s) reduce DNS query volume and improve performance. When planning a DNS change, lower TTL 24–48 hours in advance so caches clear faster.",
  },
  {
    question: "Why are my DNS changes not propagating?",
    answer: "DNS propagation is the time it takes for updated records to spread across all resolvers worldwide. This is determined by the old record's TTL — if your A record had TTL 86400 (24h), resolvers that cached it won't re-query for up to 24 hours. To check if propagation is complete, try querying multiple resolvers in different regions. Tools like dnschecker.org or this tool (which uses Cloudflare's 1.1.1.1) can show the current state.",
  },
];
---

<BaseLayout
  title="DNS Lookup Tool — Query A, AAAA, MX, TXT, CNAME Records"
  description="Look up A, AAAA, CNAME, MX, TXT, NS, SOA, and PTR records for any domain using the Cloudflare DNS-over-HTTPS API. Fully client-side, no server required."
  tool="DNS Lookup, DNS Record Checker, DNS Query Tool, MX Record Lookup, TXT Record Lookup"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "DNS Lookup Tool",
    "url": "https://devplaybook.cc/tools/dns-lookup",
    "description": "Look up A, AAAA, CNAME, MX, TXT, NS, SOA, and PTR records for any domain using Cloudflare DNS-over-HTTPS. Fully client-side.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">DNS Lookup Tool</h1>
  <p class="text-text-muted mb-4">Query A, AAAA, CNAME, MX, TXT, NS, SOA, and PTR records for any domain.
    Results come from Cloudflare's public DNS-over-HTTPS API — fully client-side, no proxy.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All major record types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Cloudflare 1.1.1.1 resolver</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TTL displayed per record</span>
  </div>
  <DnsLookup client:load />
  <AffiliateSection category="hosting" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="DNS Lookup Tool" relatedTags={['dns', 'networking', 'devops', 'web', 'security']} />
</BaseLayout>
