---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What are Core Web Vitals?", answer: "Core Web Vitals are a set of real-world metrics Google uses to measure user experience: LCP (Largest Contentful Paint) measures loading performance, CLS (Cumulative Layout Shift) measures visual stability, and INP (Interaction to Next Paint) measures responsiveness. Google uses these metrics as ranking signals in Search. All three are measured in field data from real users via the Chrome User Experience Report (CrUX)." },
  { question: "What is a performance budget?", answer: "A performance budget is a set of limits on metrics that affect website performance — page weight, resource sizes, number of requests, or Core Web Vitals scores. By setting a budget before building a feature, you create a constraint that forces you to optimize. Budgets should be tied to your user-facing targets (e.g., LCP ≤ 2.5s on 4G) and enforced in CI/CD using tools like Lighthouse CI or bundlesize." },
  { question: "How is the hero image size budget calculated?", answer: "The hero image size limit is estimated by assuming a 4G connection speed of approximately 10 Mbps (1.25 MB/s) and allocating a fraction of your LCP budget to the hero image download. Since the hero image is typically the LCP element, it must be downloaded and decoded before LCP fires. The formula used here is: LCP target (seconds) × 100 KB/s network allowance. Optimize with modern formats (WebP/AVIF), responsive srcset, and priority fetchpriority attribute." },
  { question: "What is INP and how does it differ from FID?", answer: "INP (Interaction to Next Paint) replaced FID (First Input Delay) as a Core Web Vital in March 2024. FID only measured the delay before the first interaction was processed. INP measures the latency of ALL interactions throughout the page lifecycle — clicks, taps, and keyboard inputs — and reports the worst percentile. A poor INP usually means too much long-task JavaScript blocking the main thread." },
  { question: "What causes CLS and how do I fix it?", answer: "CLS is caused by content that shifts after the initial render: images without explicit width/height, ads that expand, web fonts causing text reflow (FOUT), or dynamically injected content above existing content. Fixes: always set explicit dimensions on images and video elements, use font-display: optional or preload fonts, reserve space for ads with min-height, and avoid inserting content above the fold after page load." },
];
---

<BaseLayout
  title="Web Vitals Budget Planner — Core Web Vitals Performance Budget Calculator"
  description="Calculate your Core Web Vitals performance budget. Set LCP, CLS, and INP targets by page type and get resource size limits, JS budget, image limits, and third-party script constraints."
  tool="Web Vitals Budget, Core Web Vitals Calculator, LCP Budget, Performance Budget Tool, CLS INP Targets"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Web Vitals Budget Planner</h1>
  <p class="text-text-muted mb-4">Set LCP, CLS, and INP targets for your page type and get a full resource budget breakdown with pass/fail indicators.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Page type presets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Resource size limits</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Third-party budget</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Google thresholds reference</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">

    <!-- Config panel -->
    <div class="lg:col-span-1 space-y-4">

      <!-- Page type selector -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold mb-3">Page Type</h2>
        <div class="space-y-2" id="page-type-list">
          <label class="flex items-center gap-3 cursor-pointer p-2 rounded-lg hover:bg-bg-surface transition-colors">
            <input type="radio" name="page-type" value="ecommerce" class="accent-primary" checked />
            <div>
              <div class="text-sm font-medium">E-commerce Product Page</div>
              <div class="text-xs text-text-muted">LCP 2.5s · CLS 0.1 · INP 200ms</div>
            </div>
          </label>
          <label class="flex items-center gap-3 cursor-pointer p-2 rounded-lg hover:bg-bg-surface transition-colors">
            <input type="radio" name="page-type" value="blog" class="accent-primary" />
            <div>
              <div class="text-sm font-medium">Blog / Editorial</div>
              <div class="text-xs text-text-muted">LCP 2.0s · CLS 0.05 · INP 150ms</div>
            </div>
          </label>
          <label class="flex items-center gap-3 cursor-pointer p-2 rounded-lg hover:bg-bg-surface transition-colors">
            <input type="radio" name="page-type" value="saas" class="accent-primary" />
            <div>
              <div class="text-sm font-medium">SaaS Dashboard</div>
              <div class="text-xs text-text-muted">LCP 3.0s · CLS 0.15 · INP 250ms</div>
            </div>
          </label>
          <label class="flex items-center gap-3 cursor-pointer p-2 rounded-lg hover:bg-bg-surface transition-colors">
            <input type="radio" name="page-type" value="landing" class="accent-primary" />
            <div>
              <div class="text-sm font-medium">Landing Page</div>
              <div class="text-xs text-text-muted">LCP 1.8s · CLS 0.05 · INP 150ms</div>
            </div>
          </label>
          <label class="flex items-center gap-3 cursor-pointer p-2 rounded-lg hover:bg-bg-surface transition-colors">
            <input type="radio" name="page-type" value="custom" class="accent-primary" />
            <div>
              <div class="text-sm font-medium">Custom</div>
              <div class="text-xs text-text-muted">Set your own targets below</div>
            </div>
          </label>
        </div>
      </div>

      <!-- Custom targets -->
      <div id="custom-panel" class="bg-bg-card border border-border rounded-xl p-5 hidden">
        <h2 class="text-sm font-semibold mb-3">Custom Targets</h2>
        <div class="space-y-3">
          <div>
            <label class="block text-xs text-text-muted mb-1">LCP Target (seconds)</label>
            <input id="custom-lcp" type="number" value="2.5" min="0.5" max="10" step="0.1"
              class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="block text-xs text-text-muted mb-1">CLS Target</label>
            <input id="custom-cls" type="number" value="0.1" min="0" max="1" step="0.01"
              class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="block text-xs text-text-muted mb-1">INP Target (milliseconds)</label>
            <input id="custom-inp" type="number" value="200" min="50" max="1000" step="10"
              class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
          </div>
        </div>
      </div>

      <!-- Google thresholds reference -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold mb-3">Google Thresholds</h2>
        <div class="space-y-3 text-xs">
          <div>
            <div class="font-medium mb-1">LCP</div>
            <div class="flex gap-2">
              <span class="px-2 py-0.5 bg-green-500/15 text-green-400 rounded">Good ≤2.5s</span>
              <span class="px-2 py-0.5 bg-yellow-500/15 text-yellow-400 rounded">NI ≤4.0s</span>
              <span class="px-2 py-0.5 bg-red-500/15 text-red-400 rounded">Poor >4.0s</span>
            </div>
          </div>
          <div>
            <div class="font-medium mb-1">CLS</div>
            <div class="flex gap-2">
              <span class="px-2 py-0.5 bg-green-500/15 text-green-400 rounded">Good ≤0.1</span>
              <span class="px-2 py-0.5 bg-yellow-500/15 text-yellow-400 rounded">NI ≤0.25</span>
              <span class="px-2 py-0.5 bg-red-500/15 text-red-400 rounded">Poor >0.25</span>
            </div>
          </div>
          <div>
            <div class="font-medium mb-1">INP</div>
            <div class="flex gap-2">
              <span class="px-2 py-0.5 bg-green-500/15 text-green-400 rounded">Good ≤200ms</span>
              <span class="px-2 py-0.5 bg-yellow-500/15 text-yellow-400 rounded">NI ≤500ms</span>
              <span class="px-2 py-0.5 bg-red-500/15 text-red-400 rounded">Poor >500ms</span>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- Budget results panel -->
    <div class="lg:col-span-2 space-y-4">

      <!-- Active targets -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold mb-3">Active Targets</h2>
        <div class="grid grid-cols-3 gap-4" id="active-targets"></div>
      </div>

      <!-- Budget breakdown -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold mb-4">Resource Budget Breakdown</h2>
        <div id="budget-breakdown" class="space-y-3"></div>
      </div>

      <!-- Rules & recommendations -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold mb-4">Optimization Rules</h2>
        <div id="rules-list" class="space-y-3"></div>
      </div>

      <!-- Third-party budget -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold mb-3">Third-Party Script Budget</h2>
        <div id="third-party-budget"></div>
      </div>

    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Web Vitals Budget Planner" relatedTags={['performance', 'web-vitals', 'lcp', 'cls', 'inp', 'lighthouse', 'optimization', 'seo']} />
</BaseLayout>

<script>
  var PRESETS = {
    ecommerce: { lcp: 2.5, cls: 0.1,  inp: 200, label: 'E-commerce Product Page' },
    blog:      { lcp: 2.0, cls: 0.05, inp: 150, label: 'Blog / Editorial' },
    saas:      { lcp: 3.0, cls: 0.15, inp: 250, label: 'SaaS Dashboard' },
    landing:   { lcp: 1.8, cls: 0.05, inp: 150, label: 'Landing Page' },
    custom:    { lcp: 2.5, cls: 0.1,  inp: 200, label: 'Custom' },
  };

  function getLcpRating(lcp) {
    if (lcp <= 2.5) return { label: 'Good', cls: 'text-green-400', bg: 'bg-green-500/15' };
    if (lcp <= 4.0) return { label: 'Needs Improvement', cls: 'text-yellow-400', bg: 'bg-yellow-500/15' };
    return { label: 'Poor', cls: 'text-red-400', bg: 'bg-red-500/15' };
  }

  function getClsRating(cls) {
    if (cls <= 0.1) return { label: 'Good', cls: 'text-green-400', bg: 'bg-green-500/15' };
    if (cls <= 0.25) return { label: 'Needs Improvement', cls: 'text-yellow-400', bg: 'bg-yellow-500/15' };
    return { label: 'Poor', cls: 'text-red-400', bg: 'bg-red-500/15' };
  }

  function getInpRating(inp) {
    if (inp <= 200) return { label: 'Good', cls: 'text-green-400', bg: 'bg-green-500/15' };
    if (inp <= 500) return { label: 'Needs Improvement', cls: 'text-yellow-400', bg: 'bg-yellow-500/15' };
    return { label: 'Poor', cls: 'text-red-400', bg: 'bg-red-500/15' };
  }

  function calcBudget(lcp, cls, inp) {
    // LCP resource budgets
    var heroImageKB = Math.round(lcp * 100);  // LCP × 100 KB/s for 4G
    var totalPageKB = lcp <= 2 ? 500 : lcp <= 2.5 ? 750 : lcp <= 3 ? 1024 : 1500;
    var cssKB = 50;
    var htmlKB = 15;
    var fontKB = 40;
    var remainingKB = Math.max(0, totalPageKB - heroImageKB - cssKB - htmlKB - fontKB);
    var jsKB = Math.min(remainingKB, Math.round(inp / 3));  // JS exec ≈ INP / 3

    // INP JS budget
    var jsBudgetMs = Math.round(inp / 3);
    var mainThreadMs = Math.round(inp * 0.8);

    return {
      heroImageKB: heroImageKB,
      totalPageKB: totalPageKB,
      cssKB: cssKB,
      htmlKB: htmlKB,
      fontKB: fontKB,
      jsKB: jsKB,
      jsBudgetMs: jsBudgetMs,
      mainThreadMs: mainThreadMs,
    };
  }

  function renderBadge(rating) {
    return '<span class="px-2 py-0.5 text-xs rounded ' + rating.bg + ' ' + rating.cls + '">' + rating.label + '</span>';
  }

  function renderBudgetRow(label, value, hint, rating) {
    return '<div class="flex items-center justify-between py-2.5 border-b border-border last:border-0">'
      + '<div>'
      + '<div class="text-sm font-medium">' + label + '</div>'
      + (hint ? '<div class="text-xs text-text-muted mt-0.5">' + hint + '</div>' : '')
      + '</div>'
      + '<div class="flex items-center gap-3">'
      + '<span class="font-mono text-sm font-semibold">' + value + '</span>'
      + (rating ? renderBadge(rating) : '')
      + '</div>'
      + '</div>';
  }

  function renderRuleRow(icon, text, sub) {
    return '<div class="flex items-start gap-3 p-3 bg-bg-surface rounded-lg">'
      + '<span class="text-base mt-0.5">' + icon + '</span>'
      + '<div>'
      + '<div class="text-sm">' + text + '</div>'
      + (sub ? '<div class="text-xs text-text-muted mt-0.5">' + sub + '</div>' : '')
      + '</div>'
      + '</div>';
  }

  function update() {
    var pageType = document.querySelector('input[name="page-type"]:checked').value;
    var preset = PRESETS[pageType];

    var lcp, cls, inp;
    if (pageType === 'custom') {
      lcp = parseFloat(document.getElementById('custom-lcp').value) || 2.5;
      cls = parseFloat(document.getElementById('custom-cls').value) || 0.1;
      inp = parseInt(document.getElementById('custom-inp').value) || 200;
      document.getElementById('custom-panel').classList.remove('hidden');
    } else {
      lcp = preset.lcp;
      cls = preset.cls;
      inp = preset.inp;
      document.getElementById('custom-panel').classList.add('hidden');
    }

    var lcpR = getLcpRating(lcp);
    var clsR = getClsRating(cls);
    var inpR = getInpRating(inp);
    var budget = calcBudget(lcp, cls, inp);

    // Active targets
    document.getElementById('active-targets').innerHTML = [
      { metric: 'LCP', value: lcp + 's', rating: lcpR },
      { metric: 'CLS', value: cls.toString(), rating: clsR },
      { metric: 'INP', value: inp + 'ms', rating: inpR },
    ].map(function(t) {
      return '<div class="text-center p-3 ' + t.rating.bg + ' rounded-xl">'
        + '<div class="text-xs text-text-muted mb-1">' + t.metric + '</div>'
        + '<div class="text-xl font-bold ' + t.rating.cls + ' mb-1">' + t.value + '</div>'
        + '<div class="text-xs ' + t.rating.cls + '">' + t.rating.label + '</div>'
        + '</div>';
    }).join('');

    // Budget breakdown
    document.getElementById('budget-breakdown').innerHTML = [
      renderBudgetRow('Total Page Weight', (budget.totalPageKB >= 1024 ? (budget.totalPageKB / 1024).toFixed(1) + ' MB' : budget.totalPageKB + ' KB'), 'All resources combined (HTML + CSS + JS + images + fonts)', null),
      renderBudgetRow('Hero / LCP Image', budget.heroImageKB + ' KB', 'Must load before LCP fires — use WebP/AVIF + fetchpriority="high"', null),
      renderBudgetRow('HTML Document', budget.htmlKB + ' KB', 'Inline critical CSS, defer non-critical resources', null),
      renderBudgetRow('CSS (total)', budget.cssKB + ' KB', 'Remove unused CSS, use code-splitting, critical CSS inline', null),
      renderBudgetRow('Web Fonts', budget.fontKB + ' KB', 'Subset fonts, use font-display: swap, preload critical fonts', null),
      renderBudgetRow('JavaScript Execution Budget', budget.jsBudgetMs + ' ms', 'Max JS execution time per interaction (INP ÷ 3)', getInpRating(inp)),
      renderBudgetRow('Main Thread Budget', budget.mainThreadMs + ' ms', 'Total main thread blocking time per interaction', getInpRating(inp)),
      renderBudgetRow('CLS Max Score', cls.toString(), 'Set explicit width/height on images, avoid dynamic above-fold content', clsR),
    ].join('');

    // Rules
    var clsRules = [
      renderRuleRow('📐', 'Set explicit dimensions on all images and video', 'Add width and height attributes or use aspect-ratio CSS'),
      renderRuleRow('✏️', 'Avoid inserting content above the fold after load', 'Reserve space for banners, ads, and cookie notices with min-height'),
      renderRuleRow('🔤', 'Preload critical fonts and use font-display: optional', 'Prevents layout shifts from font swaps (FOUT)'),
    ];

    var lcpRules = [
      renderRuleRow('🖼️', 'Use modern image formats (WebP / AVIF)', 'AVIF is 50% smaller than JPEG at equivalent quality'),
      renderRuleRow('⚡', 'Add fetchpriority="high" to hero image', 'Tells browser to prioritize this resource above all others'),
      renderRuleRow('📦', 'Inline critical CSS, defer render-blocking resources', 'Move non-critical CSS to async load'),
    ];

    var inpRules = [
      renderRuleRow('⏱️', 'Break up long tasks into smaller chunks', 'Use scheduler.yield() or setTimeout to yield to the browser'),
      renderRuleRow('🧹', 'Remove or defer unnecessary JavaScript', 'Each KB of JS = parse + compile + execute time'),
      renderRuleRow('🎯', 'Use event delegation and avoid heavy event handlers', 'Keep interaction handlers under ' + budget.jsBudgetMs + 'ms execution time'),
    ];

    document.getElementById('rules-list').innerHTML =
      '<div class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-2">LCP Rules</div>'
      + lcpRules.join('')
      + '<div class="text-xs font-semibold text-text-muted uppercase tracking-wider mt-4 mb-2">CLS Rules</div>'
      + clsRules.join('')
      + '<div class="text-xs font-semibold text-text-muted uppercase tracking-wider mt-4 mb-2">INP Rules</div>'
      + inpRules.join('');

    // Third-party budget
    var thirdPartyHeavy = budget.totalPageKB < 500;
    document.getElementById('third-party-budget').innerHTML =
      '<div class="grid grid-cols-3 gap-4 mb-4">'
      + '<div class="text-center p-3 bg-bg-surface rounded-xl">'
      + '<div class="text-xs text-text-muted mb-1">Max Scripts</div>'
      + '<div class="text-2xl font-bold text-primary">3</div>'
      + '</div>'
      + '<div class="text-center p-3 bg-bg-surface rounded-xl">'
      + '<div class="text-xs text-text-muted mb-1">Combined Size</div>'
      + '<div class="text-2xl font-bold ' + (thirdPartyHeavy ? 'text-yellow-400' : 'text-primary') + '">100 KB</div>'
      + '</div>'
      + '<div class="text-center p-3 bg-bg-surface rounded-xl">'
      + '<div class="text-xs text-text-muted mb-1">Load Strategy</div>'
      + '<div class="text-sm font-bold text-primary">defer / async</div>'
      + '</div>'
      + '</div>'
      + '<div class="space-y-2 text-sm">'
      + '<div class="flex items-start gap-2"><span class="text-yellow-400 mt-0.5">⚠</span><span>Analytics scripts should be loaded after the page is interactive (defer or lazy-load)</span></div>'
      + '<div class="flex items-start gap-2"><span class="text-yellow-400 mt-0.5">⚠</span><span>Chat widgets and video embeds are high-risk — use facade patterns to defer until interaction</span></div>'
      + '<div class="flex items-start gap-2"><span class="text-green-400 mt-0.5">✓</span><span>Use Resource Hints (<code class="text-xs bg-bg-surface px-1 rounded">preconnect</code>) for known third-party origins to reduce DNS+TLS overhead</span></div>'
      + '</div>';
  }

  document.querySelectorAll('input[name="page-type"]').forEach(function(radio) {
    radio.addEventListener('change', update);
  });

  ['custom-lcp', 'custom-cls', 'custom-inp'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.addEventListener('input', update);
  });

  update();
</script>
