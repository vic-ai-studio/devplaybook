---
import BaseLayout from '../../layouts/BaseLayout.astro';
import IpCidrCalculator from '../../components/IpCidrCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is CIDR notation?", answer: "CIDR (Classless Inter-Domain Routing) notation represents an IP address and its network prefix length. For example, 192.168.1.0/24 means the first 24 bits are the network portion, giving 256 total addresses. For IPv6, 2001:db8::/32 means a /32 prefix with 2^96 addresses in the block." },
  { question: "How do I calculate usable hosts in a subnet?", answer: "For IPv4, usable hosts = 2^(32-prefix) - 2 (subtract network and broadcast addresses). A /24 gives 254 usable hosts, a /30 gives 2, and a /31 gives 2 (RFC 3021 point-to-point). For /32, it's a single host route. IPv6 subnets don't have a broadcast address." },
  { question: "What is a wildcard mask?", answer: "A wildcard mask is the inverse of the subnet mask. For a /24 subnet (mask 255.255.255.0), the wildcard is 0.0.0.255. Wildcard masks are used in Cisco ACLs and OSPF area configuration where a 1-bit means 'any value' and a 0-bit means 'must match'." },
  { question: "Does this support IPv6?", answer: "Yes. Enter any valid IPv6 CIDR notation (e.g. 2001:db8::/32 or fe80::/10). The calculator shows the network address, last address in the block, total address count, and binary representation for all 128 bits." },
  { question: "What are private IPv4 address ranges?", answer: "RFC 1918 defines three private ranges: 10.0.0.0/8 (16.7M addresses), 172.16.0.0/12 (1M addresses), and 192.168.0.0/16 (65K addresses). These are not routed on the public internet. IPv6 uses fc00::/7 (ULA) for private addresses." },
  { question: "What does the binary representation show?", answer: "For IPv4, the binary view shows the 32-bit representation of the network address, subnet mask, and broadcast address split into four octets (e.g. 11000000.10101000.00000001.00000000). This helps visualize exactly which bits are the network vs host portion." },
];
---

<BaseLayout
  title="IP CIDR Calculator — IPv4 & IPv6 Subnet Calculator"
  description="Free IP CIDR calculator supporting both IPv4 and IPv6. Enter any CIDR notation to get network address, broadcast, host range, subnet mask, wildcard mask, and binary representation. Runs 100% in your browser."
  tool="IP CIDR calculator, IPv4 subnet calculator, IPv6 CIDR calculator, subnet mask calculator, network address calculator, wildcard mask, binary subnet"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "IP CIDR Calculator",
    "url": "https://devplaybook.cc/tools/ip-cidr-calculator",
    "description": "Calculate IPv4 and IPv6 subnet details from CIDR notation. Get network address, broadcast, host range, subnet mask, wildcard mask, and binary representation.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">IP CIDR Calculator</h1>
  <p class="text-text-muted mb-4">
    Calculate subnet details for any IPv4 or IPv6 CIDR block. Enter notation like
    <code class="font-mono bg-surface px-1 rounded text-sm">192.168.1.0/24</code> or
    <code class="font-mono bg-surface px-1 rounded text-sm">2001:db8::/32</code> to instantly see network address,
    broadcast, host range, subnet mask, wildcard mask, and binary representation. All computation runs in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> IPv4 + IPv6 support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Binary representation</span>
  </div>
  <IpCidrCalculator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="IP CIDR Calculator" relatedTags={['networking', 'devops', 'infrastructure', 'linux', 'cloud', 'ipv6']} />
</BaseLayout>
