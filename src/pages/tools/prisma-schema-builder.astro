---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is a Prisma schema file?", answer: "A Prisma schema file (schema.prisma) is the single source of truth for your database. It defines the datasource (DB connection), generator (Prisma Client), and data models. Prisma uses it to generate type-safe client code, run migrations, and introspect existing databases." },
  { question: "What Prisma field types are available?", answer: "Prisma supports: String, Int, Float, Decimal, Boolean, DateTime, Json, Bytes, BigInt. String maps to VARCHAR, Int to INTEGER, DateTime to TIMESTAMP, Json to JSONB in PostgreSQL. Use @db attributes for native type overrides like @db.VarChar(255)." },
  { question: "What is the difference between @id, @unique, and @@unique?", answer: "@id marks a single field as the primary key (e.g., id Int @id). @unique ensures column-level uniqueness. @@unique is a multi-field composite unique constraint at the model level, e.g. @@unique([userId, slug]). Every Prisma model needs exactly one @id or @@id." },
  { question: "What does @default() do in Prisma?", answer: "@default() sets the value inserted when none is provided. Common patterns: @default(autoincrement()) for integer PKs, @default(cuid()) or @default(uuid()) for string IDs, @default(now()) for creation timestamps, @default(false) for boolean flags." },
  { question: "How do I add relations in Prisma?", answer: "Pair a relation field with a scalar FK field: 'author User @relation(fields: [authorId], references: [id])' alongside 'authorId Int'. Prisma supports one-to-one, one-to-many, and many-to-many (implicit via Prisma-managed join table, or explicit via a join model)." }
];
---

<BaseLayout
  title="Prisma Schema Builder — Generate prisma.schema Online"
  description="Build Prisma schema files visually. Add models and fields with types, @id, @unique, @default, and optional modifiers. Generate valid schema.prisma syntax instantly. Free browser tool."
  tool="prisma schema builder, prisma schema generator, prisma ORM schema, generate prisma schema, prisma model builder"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Prisma Schema Builder",
    "url": "https://devplaybook.cc/tools/prisma-schema-builder",
    "description": "Build Prisma schema files visually with model and field configuration.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Prisma Schema Builder</h1>
  <p class="text-text-muted mb-4">
    Build Prisma schema files visually. Add models, define fields with types and attributes (@id, @unique, @default),
    and generate ready-to-use <code class="text-accent">schema.prisma</code> syntax instantly.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Visual model builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> All Prisma scalar types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> @id, @unique, @default</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Copy-ready output</span>
  </div>

  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-semibold mb-3">Datasource &amp; Generator</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <div>
        <label class="block text-xs text-text-muted mb-1">Database Provider</label>
        <select id="db-provider" class="w-full bg-surface border border-border rounded px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="postgresql">PostgreSQL</option>
          <option value="mysql">MySQL</option>
          <option value="sqlite">SQLite</option>
          <option value="sqlserver">SQL Server</option>
          <option value="mongodb">MongoDB</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Connection URL env var</label>
        <input id="db-url" type="text" value="DATABASE_URL" class="w-full bg-surface border border-border rounded px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
      </div>
    </div>
  </div>

  <div id="models-container" class="space-y-4 mb-4"></div>

  <button id="add-model" class="w-full py-2.5 border-2 border-dashed border-border rounded-lg text-sm text-text-muted hover:border-primary hover:text-foreground transition-colors mb-4">
    + Add Model
  </button>

  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <div class="flex items-center justify-between mb-2">
      <h2 class="text-sm font-semibold">Generated schema.prisma</h2>
      <button id="copy-schema" class="px-4 py-1.5 bg-primary text-white rounded text-sm font-medium hover:bg-primary/90 transition-colors">Copy</button>
    </div>
    <pre id="schema-output" class="bg-surface rounded p-3 text-xs font-mono text-foreground/90 overflow-x-auto whitespace-pre min-h-[120px]"></pre>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Prisma Schema Builder" relatedTags={["prisma", "database", "orm", "postgresql", "schema", "typescript"]} />
</BaseLayout>

<script is:inline>
(function () {
  var TYPES = ["String","Int","Float","Decimal","Boolean","DateTime","Json","Bytes","BigInt"];
  var DEF_OPTS = {
    String:["","cuid()","uuid()"],Int:["","autoincrement()","0","1"],
    Float:["","0.0"],Decimal:["","0"],Boolean:["","false","true"],
    DateTime:["","now()"],Json:[""],Bytes:[""],BigInt:["","autoincrement()"]
  };
  var models = [{id:uid(),name:"User",fields:[
    {id:uid(),name:"id",type:"Int",opt:false,isId:true,uniq:false,dv:"autoincrement()"},
    {id:uid(),name:"email",type:"String",opt:false,isId:false,uniq:true,dv:""},
    {id:uid(),name:"name",type:"String",opt:true,isId:false,uniq:false,dv:""},
    {id:uid(),name:"createdAt",type:"DateTime",opt:false,isId:false,uniq:false,dv:"now()"}
  ]}];

  function uid(){return Math.random().toString(36).slice(2,9);}
  function esc(s){return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");}
  function findM(mid){return models.find(function(m){return m.id===mid;});}
  function findF(m,fid){return m&&m.fields.find(function(f){return f.id===fid;});}
  function pad(s,n){var r=String(s);while(r.length<n)r+=" ";return r;}

  function hModel(m){
    return "<div class='bg-bg-card border border-border rounded-lg p-4 mb-3' data-mid='"+m.id+"'>" +
      "<div class='flex items-center gap-2 mb-3'>" +
      "<input type='text' value='"+esc(m.name)+"' placeholder='ModelName' class='model-name flex-1 bg-surface border border-border rounded px-3 py-1.5 text-sm font-bold font-mono focus:outline-none focus:border-primary' data-mid='"+m.id+"' />" +
      "<button class='del-model px-2 py-1 text-xs text-red-400 border border-border rounded hover:text-red-300 transition-colors' data-mid='"+m.id+"'>Remove</button>" +
      "</div>" +
      "<div class='mb-1 hidden sm:grid gap-1 text-xs text-text-muted font-semibold' style='grid-template-columns:1fr 90px 100px 36px 36px 44px 48px'><span>Name</span><span>Type</span><span>Default</span><span>opt</span><span>@id</span><span>uniq</span><span></span></div>" +
      "<div class='space-y-1.5 mb-3'>"+m.fields.map(function(f){return hField(m.id,f);}).join("")+"</div>" +
      "<button class='add-field text-xs text-text-muted border border-dashed border-border rounded px-3 py-1.5 w-full hover:border-primary hover:text-foreground transition-colors' data-mid='"+m.id+"'>+ Add Field</button>" +
      "</div>";
  }

  function hField(mid,f){
    var to=TYPES.map(function(t){return "<option value='"+t+"'"+(f.type===t?" selected":"")+">"+t+"</option>";}).join("");
    var dv=DEF_OPTS[f.type]||[""];
    var dop=dv.map(function(v){return "<option value='"+esc(v)+"'"+(f.dv===v?" selected":"")+">"+(v||"(none)")+"</option>";}).join("");
    return "<div class='grid gap-1 items-center mb-1' style='grid-template-columns:1fr 90px 100px 36px 36px 44px 48px' data-fid='"+f.id+"' data-mid='"+mid+"'>" +
      "<input type='text' value='"+esc(f.name)+"' class='f-name bg-surface border border-border rounded px-2 py-1 text-xs font-mono focus:outline-none focus:border-primary' data-fid='"+f.id+"' data-mid='"+mid+"' />" +
      "<select class='f-type bg-surface border border-border rounded px-1 py-1 text-xs focus:outline-none focus:border-primary' data-fid='"+f.id+"' data-mid='"+mid+"'>"+to+"</select>" +
      "<select class='f-def bg-surface border border-border rounded px-1 py-1 text-xs focus:outline-none focus:border-primary' data-fid='"+f.id+"' data-mid='"+mid+"'>"+dop+"</select>" +
      "<label class='flex justify-center cursor-pointer text-xs text-text-muted'><input type='checkbox' class='f-opt' data-fid='"+f.id+"' data-mid='"+mid+"'"+(f.opt?" checked":"")+" />opt</label>" +
      "<label class='flex justify-center cursor-pointer text-xs text-text-muted'><input type='checkbox' class='f-id' data-fid='"+f.id+"' data-mid='"+mid+"'"+(f.isId?" checked":"")+" />@id</label>" +
      "<label class='flex justify-center cursor-pointer text-xs text-text-muted'><input type='checkbox' class='f-uniq' data-fid='"+f.id+"' data-mid='"+mid+"'"+(f.uniq?" checked":"")+" />uniq</label>" +
      "<button class='del-field text-xs text-red-400 border border-border rounded px-1 py-1 hover:text-red-300 transition-colors' data-fid='"+f.id+"' data-mid='"+mid+"'>Del</button>" +
      "</div>";
  }

  function render(){
    document.getElementById("models-container").innerHTML=models.map(hModel).join("");
    attach(); gen();
  }

  function attach(){
    var c=document.getElementById("models-container");
    c.querySelectorAll(".model-name").forEach(function(el){el.oninput=function(e){var m=findM(e.target.dataset.mid);if(m){m.name=e.target.value;gen();}};});
    c.querySelectorAll(".del-model").forEach(function(el){el.onclick=function(e){models=models.filter(function(m){return m.id!==e.target.dataset.mid;});render();};});
    c.querySelectorAll(".add-field").forEach(function(el){el.onclick=function(e){var m=findM(e.target.dataset.mid);if(m){m.fields.push({id:uid(),name:"field",type:"String",opt:false,isId:false,uniq:false,dv:""});render();}};});
    c.querySelectorAll(".del-field").forEach(function(el){el.onclick=function(e){var m=findM(e.target.dataset.mid);if(m){m.fields=m.fields.filter(function(f){return f.id!==e.target.dataset.fid;});render();}};});
    c.querySelectorAll(".f-name").forEach(function(el){el.oninput=function(e){var f=findF(findM(e.target.dataset.mid),e.target.dataset.fid);if(f){f.name=e.target.value;gen();}};});
    c.querySelectorAll(".f-type").forEach(function(el){el.onchange=function(e){var f=findF(findM(e.target.dataset.mid),e.target.dataset.fid);if(f){f.type=e.target.value;f.dv="";render();}};});
    c.querySelectorAll(".f-def").forEach(function(el){el.onchange=function(e){var f=findF(findM(e.target.dataset.mid),e.target.dataset.fid);if(f){f.dv=e.target.value;gen();}};});
    c.querySelectorAll(".f-opt").forEach(function(el){el.onchange=function(e){var f=findF(findM(e.target.dataset.mid),e.target.dataset.fid);if(f){f.opt=e.target.checked;gen();}};});
    c.querySelectorAll(".f-id").forEach(function(el){el.onchange=function(e){var f=findF(findM(e.target.dataset.mid),e.target.dataset.fid);if(f){f.isId=e.target.checked;gen();}};});
    c.querySelectorAll(".f-uniq").forEach(function(el){el.onchange=function(e){var f=findF(findM(e.target.dataset.mid),e.target.dataset.fid);if(f){f.uniq=e.target.checked;gen();}};});
  }

  function gen(){
    var p=document.getElementById("db-provider").value;
    var u=document.getElementById("db-url").value||"DATABASE_URL";
    var out="datasource db {\n  provider = \""+p+"\"\n  url      = env(\""+u+"\")\n}\n\ngenerator client {\n  provider = \"prisma-client-js\"\n}\n";
    models.forEach(function(m){
      out+="\nmodel "+(m.name||"Model")+" {\n";
      m.fields.forEach(function(f){
        var ft=f.type+(f.opt?"?":"");
        var attr="";
        if(f.isId) attr+=" @id";
        if(f.uniq&&!f.isId) attr+=" @unique";
        if(f.dv) attr+=" @default("+f.dv+")";
        out+="  "+pad(f.name||"field",14)+" "+ft+attr+"\n";
      });
      out+="}\n";
    });
    document.getElementById("schema-output").textContent=out;
  }

  document.getElementById("add-model").onclick=function(){
    models.push({id:uid(),name:"NewModel",fields:[{id:uid(),name:"id",type:"Int",opt:false,isId:true,uniq:false,dv:"autoincrement()"}]});
    render();
  };
  document.getElementById("copy-schema").onclick=function(){
    navigator.clipboard.writeText(document.getElementById("schema-output").textContent).then(function(){
      var b=document.getElementById("copy-schema"); b.textContent="Copied!"; setTimeout(function(){b.textContent="Copy";},1500);
    });
  };
  document.getElementById("db-provider").onchange=gen;
  document.getElementById("db-url").oninput=gen;
  render();
})();
</script>
