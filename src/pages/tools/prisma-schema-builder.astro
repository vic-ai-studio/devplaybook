---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Prisma and what is schema.prisma?", answer: "Prisma is a TypeScript ORM for Node.js. schema.prisma defines your data models, database connection, and generator config. Prisma Client is auto-generated from this schema and gives you fully typed database queries without writing SQL." },
  { question: "What field types does Prisma support?", answer: "Prisma supports: String, Int, Float, Boolean, DateTime, Json, Bytes, BigInt, Decimal. Each maps to your database's native types. Use @db modifiers for specific types (e.g. @db.VarChar(255)). Enum types and relation fields are also supported." },
  { question: "What are @id, @default, @unique, and @updatedAt?", answer: "@id marks the primary key. @default(value) sets a default (autoincrement(), uuid(), now(), cuid(), or a literal). @unique adds a unique constraint. @updatedAt auto-updates the field on every write — perfect for updatedAt timestamps." },
  { question: "How do I run migrations after editing the schema?", answer: "Run: npx prisma migrate dev --name init (development). This creates a SQL migration file and applies it. For production: npx prisma migrate deploy. After schema changes, regenerate the client with: npx prisma generate." },
];
---

<BaseLayout
  title="Prisma Schema Builder — Generate schema.prisma Visually"
  description="Build Prisma ORM schema.prisma files visually. Add models and fields, configure types and attributes, and generate copy-ready Prisma schema code. Free, runs in browser."
  tool="Prisma schema builder, schema.prisma generator, Prisma ORM, Prisma model builder, Prisma TypeScript"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Prisma Schema Builder</h1>
  <p class="text-text-muted mb-6">Add models and fields visually, then copy the generated <code class="text-primary">schema.prisma</code> output directly into your project.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All Prisma field types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> @id, @default, @unique, @updatedAt</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multiple models</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <div>
      <div class="flex items-center justify-between mb-3">
        <label class="text-sm font-medium">Models</label>
        <button id="add-model" class="text-xs px-3 py-1.5 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors">+ Add Model</button>
      </div>

      <div class="mb-4">
        <label class="block text-xs text-text-muted mb-1">Database provider</label>
        <select id="db-provider" class="bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="postgresql">PostgreSQL</option>
          <option value="mysql">MySQL</option>
          <option value="sqlite">SQLite</option>
          <option value="sqlserver">SQL Server</option>
          <option value="mongodb">MongoDB</option>
        </select>
      </div>

      <div id="models-container" class="space-y-4"></div>
    </div>

    <div>
      <div class="flex items-center justify-between mb-2">
        <label class="text-sm font-medium">schema.prisma</label>
        <button id="copy-schema" class="text-xs px-3 py-1.5 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors">Copy</button>
      </div>
      <pre id="schema-output" class="bg-bg-card border border-border rounded-lg p-3 text-xs font-mono overflow-auto min-h-[400px] whitespace-pre text-text"></pre>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Prisma Schema Builder" relatedTags={['prisma', 'database', 'typescript', 'orm', 'postgresql']} />
</BaseLayout>

<script>
  interface Field {
    id: string;
    name: string;
    type: string;
    required: boolean;
    isId: boolean;
    isUnique: boolean;
    isUpdatedAt: boolean;
    defaultVal: string;
  }
  interface Model {
    id: string;
    name: string;
    fields: Field[];
  }

  const FIELD_TYPES = ['String', 'Int', 'Float', 'Boolean', 'DateTime', 'Json', 'Bytes', 'BigInt', 'Decimal'];
  const DEFAULT_OPTIONS: Record<string, string[]> = {
    String: ['', 'uuid()', 'cuid()', '""'],
    Int: ['', 'autoincrement()', '0', '1'],
    Float: ['', '0.0'],
    Boolean: ['', 'true', 'false'],
    DateTime: ['', 'now()'],
    Json: [''],
    Bytes: [''],
    BigInt: ['', '0'],
    Decimal: ['', '0'],
  };

  let models: Model[] = [];
  let modelCounter = 0;
  let fieldCounter = 0;

  function uid() { return String(++fieldCounter); }
  function mid() { return String(++modelCounter); }

  function newField(override: Partial<Field> = {}): Field {
    return {
      id: uid(),
      name: 'field',
      type: 'String',
      required: true,
      isId: false,
      isUnique: false,
      isUpdatedAt: false,
      defaultVal: '',
      ...override,
    };
  }

  function newModel(): Model {
    return {
      id: mid(),
      name: 'Model' + modelCounter,
      fields: [
        newField({ name: 'id', type: 'Int', isId: true, defaultVal: 'autoincrement()' }),
        newField({ name: 'createdAt', type: 'DateTime', defaultVal: 'now()' }),
        newField({ name: 'updatedAt', type: 'DateTime', isUpdatedAt: true }),
      ],
    };
  }

  function generateSchema(): string {
    const provider = (document.getElementById('db-provider') as HTMLSelectElement).value;
    let s = `// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "${provider}"
  url      = env("DATABASE_URL")
}\n`;

    for (const model of models) {
      if (!model.name) continue;
      s += `\nmodel ${model.name} {\n`;
      for (const f of model.fields) {
        if (!f.name) continue;
        let line = `  ${f.name}  ${f.type}`;
        if (!f.required) line += '?';
        const attrs: string[] = [];
        if (f.isId) attrs.push('@id');
        if (f.defaultVal) attrs.push(`@default(${f.defaultVal})`);
        if (f.isUnique && !f.isId) attrs.push('@unique');
        if (f.isUpdatedAt) attrs.push('@updatedAt');
        if (attrs.length) line += '  ' + attrs.join(' ');
        s += line + '\n';
      }
      s += '}\n';
    }
    return s;
  }

  function renderModels() {
    const container = document.getElementById('models-container')!;
    container.innerHTML = models.map((model, mi) => `
      <div class="bg-bg-card border border-border rounded-xl p-4" data-model-id="${model.id}">
        <div class="flex items-center gap-2 mb-3">
          <input
            type="text"
            value="${model.name}"
            placeholder="ModelName"
            class="model-name flex-1 bg-bg border border-border rounded px-2 py-1 text-sm font-semibold focus:outline-none focus:border-primary"
            data-model-idx="${mi}"
          />
          <button class="remove-model text-xs text-red-400 hover:text-red-300 transition-colors" data-model-idx="${mi}">Remove</button>
        </div>
        <div class="space-y-2 mb-3">
          ${model.fields.map((f, fi) => `
            <div class="flex flex-wrap items-center gap-1.5 text-xs" data-field-id="${f.id}">
              <input type="text" value="${f.name}" placeholder="fieldName"
                class="field-name w-24 bg-bg border border-border rounded px-1.5 py-1 focus:outline-none focus:border-primary font-mono"
                data-model-idx="${mi}" data-field-idx="${fi}" />
              <select class="field-type bg-bg border border-border rounded px-1.5 py-1 focus:outline-none focus:border-primary"
                data-model-idx="${mi}" data-field-idx="${fi}">
                ${FIELD_TYPES.map(t => `<option${t === f.type ? ' selected' : ''}>${t}</option>`).join('')}
              </select>
              <select class="field-default bg-bg border border-border rounded px-1.5 py-1 focus:outline-none focus:border-primary"
                data-model-idx="${mi}" data-field-idx="${fi}">
                ${(DEFAULT_OPTIONS[f.type] || ['']).map(d => `<option${d === f.defaultVal ? ' selected' : ''} value="${d}">${d || '—'}</option>`).join('')}
              </select>
              <label class="flex items-center gap-1 cursor-pointer" title="Required">
                <input type="checkbox" class="field-required" ${f.required ? 'checked' : ''}
                  data-model-idx="${mi}" data-field-idx="${fi}" />
                <span>Req</span>
              </label>
              <label class="flex items-center gap-1 cursor-pointer" title="@unique">
                <input type="checkbox" class="field-unique" ${f.isUnique ? 'checked' : ''}
                  data-model-idx="${mi}" data-field-idx="${fi}" />
                <span>Uniq</span>
              </label>
              <label class="flex items-center gap-1 cursor-pointer" title="@updatedAt">
                <input type="checkbox" class="field-updatedat" ${f.isUpdatedAt ? 'checked' : ''}
                  data-model-idx="${mi}" data-field-idx="${fi}" />
                <span>UpdAt</span>
              </label>
              <button class="remove-field text-red-400 hover:text-red-300 transition-colors px-1" data-model-idx="${mi}" data-field-idx="${fi}">✕</button>
            </div>
          `).join('')}
        </div>
        <button class="add-field text-xs text-primary hover:underline" data-model-idx="${mi}">+ Add field</button>
      </div>
    `).join('');

    // Bind events
    container.querySelectorAll('.model-name').forEach(el => {
      el.addEventListener('input', (e) => {
        const mi = parseInt((e.target as HTMLElement).getAttribute('data-model-idx')!);
        models[mi].name = (e.target as HTMLInputElement).value;
        updateOutput();
      });
    });
    container.querySelectorAll('.remove-model').forEach(el => {
      el.addEventListener('click', (e) => {
        const mi = parseInt((e.target as HTMLElement).getAttribute('data-model-idx')!);
        models.splice(mi, 1);
        renderModels();
        updateOutput();
      });
    });
    container.querySelectorAll('.field-name').forEach(el => {
      el.addEventListener('input', (e) => {
        const mi = parseInt((e.target as HTMLElement).getAttribute('data-model-idx')!);
        const fi = parseInt((e.target as HTMLElement).getAttribute('data-field-idx')!);
        models[mi].fields[fi].name = (e.target as HTMLInputElement).value;
        updateOutput();
      });
    });
    container.querySelectorAll('.field-type').forEach(el => {
      el.addEventListener('change', (e) => {
        const mi = parseInt((e.target as HTMLElement).getAttribute('data-model-idx')!);
        const fi = parseInt((e.target as HTMLElement).getAttribute('data-field-idx')!);
        const newType = (e.target as HTMLSelectElement).value;
        models[mi].fields[fi].type = newType;
        models[mi].fields[fi].defaultVal = '';
        renderModels();
        updateOutput();
      });
    });
    container.querySelectorAll('.field-default').forEach(el => {
      el.addEventListener('change', (e) => {
        const mi = parseInt((e.target as HTMLElement).getAttribute('data-model-idx')!);
        const fi = parseInt((e.target as HTMLElement).getAttribute('data-field-idx')!);
        models[mi].fields[fi].defaultVal = (e.target as HTMLSelectElement).value;
        updateOutput();
      });
    });
    container.querySelectorAll('.field-required').forEach(el => {
      el.addEventListener('change', (e) => {
        const mi = parseInt((e.target as HTMLElement).getAttribute('data-model-idx')!);
        const fi = parseInt((e.target as HTMLElement).getAttribute('data-field-idx')!);
        models[mi].fields[fi].required = (e.target as HTMLInputElement).checked;
        updateOutput();
      });
    });
    container.querySelectorAll('.field-unique').forEach(el => {
      el.addEventListener('change', (e) => {
        const mi = parseInt((e.target as HTMLElement).getAttribute('data-model-idx')!);
        const fi = parseInt((e.target as HTMLElement).getAttribute('data-field-idx')!);
        models[mi].fields[fi].isUnique = (e.target as HTMLInputElement).checked;
        updateOutput();
      });
    });
    container.querySelectorAll('.field-updatedat').forEach(el => {
      el.addEventListener('change', (e) => {
        const mi = parseInt((e.target as HTMLElement).getAttribute('data-model-idx')!);
        const fi = parseInt((e.target as HTMLElement).getAttribute('data-field-idx')!);
        models[mi].fields[fi].isUpdatedAt = (e.target as HTMLInputElement).checked;
        updateOutput();
      });
    });
    container.querySelectorAll('.remove-field').forEach(el => {
      el.addEventListener('click', (e) => {
        const mi = parseInt((e.target as HTMLElement).getAttribute('data-model-idx')!);
        const fi = parseInt((e.target as HTMLElement).getAttribute('data-field-idx')!);
        models[mi].fields.splice(fi, 1);
        renderModels();
        updateOutput();
      });
    });
    container.querySelectorAll('.add-field').forEach(el => {
      el.addEventListener('click', (e) => {
        const mi = parseInt((e.target as HTMLElement).getAttribute('data-model-idx')!);
        models[mi].fields.push(newField());
        renderModels();
        updateOutput();
      });
    });
  }

  function updateOutput() {
    document.getElementById('schema-output')!.textContent = generateSchema();
  }

  document.getElementById('add-model')!.addEventListener('click', () => {
    models.push(newModel());
    renderModels();
    updateOutput();
  });

  document.getElementById('db-provider')!.addEventListener('change', updateOutput);

  document.getElementById('copy-schema')!.addEventListener('click', () => {
    const text = document.getElementById('schema-output')!.textContent || '';
    navigator.clipboard.writeText(text);
    const btn = document.getElementById('copy-schema')!;
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
  });

  // Start with one model
  models.push(newModel());
  renderModels();
  updateOutput();
</script>
