---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is OpenAPI 3.0?", answer: "OpenAPI 3.0 is the industry-standard specification for describing HTTP APIs. It defines endpoints, request/response schemas, authentication, and more in a machine-readable YAML or JSON format. Tools like Swagger UI, Postman, and code generators consume OpenAPI specs to create documentation, client SDKs, and server stubs." },
  { question: "What is the difference between a path parameter and a query parameter?", answer: "Path parameters are part of the URL path (e.g., /users/{id}) and are required. Query parameters come after ? in the URL (e.g., /users?page=2&limit=10) and are typically optional filters or pagination controls. Both are described in the 'parameters' section of an OpenAPI operation." },
  { question: "How do I describe request body schemas in OpenAPI?", answer: "Use the 'requestBody' field with a 'content' map. For JSON: content: application/json: schema: {type: object, ...}. Define required vs optional fields with the 'required' array at the object level. Use $ref to reference shared schemas in the components/schemas section." },
  { question: "What are OpenAPI response codes and when do I use them?", answer: "Document all expected HTTP status codes: 200 (success), 201 (created), 204 (no content), 400 (bad request/validation), 401 (unauthorized), 403 (forbidden), 404 (not found), 409 (conflict), 422 (unprocessable entity), 500 (server error). Include at least success and error responses." },
  { question: "What is $ref in OpenAPI and when should I use it?", answer: "$ref allows you to reference shared schemas defined in components/schemas instead of repeating them. This keeps your spec DRY and consistent. For example, an 'Error' schema used in all 4xx responses should be defined once in components and referenced with $ref: '#/components/schemas/Error'." },
];
---

<BaseLayout
  title="OpenAPI Snippet Generator — Generate OpenAPI 3.0 YAML from Endpoint Info"
  description="Input your API endpoint details to generate a valid OpenAPI 3.0 YAML snippet. Supports GET/POST/PUT/PATCH/DELETE with request/response schemas. Free browser tool."
  tool="OpenAPI generator, Swagger YAML generator, OpenAPI 3.0 snippet, REST API documentation generator, API spec builder"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">OpenAPI Snippet Generator</h1>
  <p class="text-text-muted mb-4">Fill in your endpoint details to generate a valid OpenAPI 3.0 YAML snippet — ready to paste into your <code class="font-mono bg-surface px-1 rounded text-sm">openapi.yaml</code>. Runs entirely in your browser.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> OpenAPI 3.0 compliant</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Request + response schemas</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auth / parameters support</span>
  </div>

  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5 space-y-4">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="text-xs font-medium text-text-muted block mb-1">HTTP Method</label>
        <select id="oas-method" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="get">GET</option>
          <option value="post" selected>POST</option>
          <option value="put">PUT</option>
          <option value="patch">PATCH</option>
          <option value="delete">DELETE</option>
        </select>
      </div>
      <div class="md:col-span-2">
        <label class="text-xs font-medium text-text-muted block mb-1">Path</label>
        <input id="oas-path" type="text" value="/users/{id}" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" placeholder="/users/{id}" />
      </div>
    </div>

    <div>
      <label class="text-xs font-medium text-text-muted block mb-1">Summary</label>
      <input id="oas-summary" type="text" value="Update user profile" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
    </div>

    <div>
      <label class="text-xs font-medium text-text-muted block mb-1">Description (optional)</label>
      <input id="oas-desc" type="text" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" placeholder="Updates the name and email of an existing user" />
    </div>

    <div>
      <label class="text-xs font-medium text-text-muted block mb-1">Tags (comma-separated)</label>
      <input id="oas-tags" type="text" value="users" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" placeholder="users, auth" />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="text-xs font-medium text-text-muted block mb-1">Path Parameters (comma-separated)</label>
        <input id="oas-path-params" type="text" value="id:string:User ID" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" placeholder="id:string:User ID, orgId:integer:Org ID" />
        <p class="text-xs text-text-muted mt-1">Format: name:type:description</p>
      </div>
      <div>
        <label class="text-xs font-medium text-text-muted block mb-1">Query Parameters (comma-separated)</label>
        <input id="oas-query-params" type="text" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" placeholder="page:integer:Page number, limit:integer:Items per page" />
        <p class="text-xs text-text-muted mt-1">Format: name:type:description</p>
      </div>
    </div>

    <div id="oas-body-section">
      <label class="text-xs font-medium text-text-muted block mb-1">Request Body Fields (one per line)</label>
      <textarea id="oas-body-fields" rows="5" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono resize-y" placeholder="name:string:true:User full name&#10;email:string:true:User email address&#10;bio:string:false:Optional bio">name:string:true:User full name
email:string:true:User email address
bio:string:false:Optional biography</textarea>
      <p class="text-xs text-text-muted mt-1">Format: fieldName:type:required(true/false):description</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="text-xs font-medium text-text-muted block mb-1">Response Schema Fields (success, one per line)</label>
        <textarea id="oas-resp-fields" rows="4" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono resize-y" placeholder="id:string:User ID&#10;name:string:User name">id:string:User ID
name:string:User full name
email:string:User email
updatedAt:string:ISO timestamp</textarea>
      </div>
      <div>
        <label class="text-xs font-medium text-text-muted block mb-1">Auth</label>
        <select id="oas-auth" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary mb-2">
          <option value="">None</option>
          <option value="bearer" selected>Bearer Token (JWT)</option>
          <option value="apikey">API Key (header)</option>
          <option value="basic">HTTP Basic</option>
        </select>
        <label class="text-xs font-medium text-text-muted block mb-1">Success Status Code</label>
        <select id="oas-success-code" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="200">200 OK</option>
          <option value="201">201 Created</option>
          <option value="204">204 No Content</option>
        </select>
      </div>
    </div>

    <button id="oas-generate" class="bg-primary text-white rounded-lg px-6 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity">Generate YAML</button>
  </div>

  <div id="oas-output-section" class="hidden bg-bg-card border border-border rounded-xl p-5 mb-5">
    <div class="flex justify-between items-center mb-3">
      <h2 class="text-sm font-semibold">Generated OpenAPI 3.0 YAML</h2>
      <button id="oas-copy" class="border border-border rounded-lg px-4 py-2 text-sm hover:bg-surface transition-colors">Copy YAML</button>
    </div>
    <pre id="oas-output" class="font-mono text-xs bg-surface rounded-lg p-4 overflow-x-auto whitespace-pre text-text-primary"></pre>
  </div>

  <script>
    const generateBtn = document.getElementById('oas-generate') as HTMLButtonElement;
    const copyBtn = document.getElementById('oas-copy') as HTMLButtonElement;
    const outputSection = document.getElementById('oas-output-section') as HTMLDivElement;
    const outputEl = document.getElementById('oas-output') as HTMLPreElement;

    function indent(s: string, n: number): string {
      return s.split('\n').map(l => ' '.repeat(n) + l).join('\n');
    }

    function parseParams(raw: string): Array<{name: string; type: string; desc: string}> {
      return raw.split(',').map(s => s.trim()).filter(Boolean).map(p => {
        const parts = p.split(':');
        return { name: parts[0]?.trim() || p, type: parts[1]?.trim() || 'string', desc: parts.slice(2).join(':').trim() || '' };
      });
    }

    function parseBodyFields(raw: string): Array<{name: string; type: string; required: boolean; desc: string}> {
      return raw.split('\n').map(s => s.trim()).filter(Boolean).map(p => {
        const parts = p.split(':');
        return {
          name: parts[0]?.trim() || p,
          type: parts[1]?.trim() || 'string',
          required: (parts[2]?.trim() || 'true') === 'true',
          desc: parts.slice(3).join(':').trim() || ''
        };
      });
    }

    generateBtn.addEventListener('click', () => {
      const method = (document.getElementById('oas-method') as HTMLSelectElement).value;
      const path = (document.getElementById('oas-path') as HTMLInputElement).value.trim() || '/endpoint';
      const summary = (document.getElementById('oas-summary') as HTMLInputElement).value.trim();
      const desc = (document.getElementById('oas-desc') as HTMLInputElement).value.trim();
      const tags = (document.getElementById('oas-tags') as HTMLInputElement).value.split(',').map(s => s.trim()).filter(Boolean);
      const pathParams = parseParams((document.getElementById('oas-path-params') as HTMLInputElement).value);
      const queryParams = parseParams((document.getElementById('oas-query-params') as HTMLInputElement).value);
      const bodyFields = parseBodyFields((document.getElementById('oas-body-fields') as HTMLTextAreaElement).value);
      const respFields = parseBodyFields((document.getElementById('oas-resp-fields') as HTMLTextAreaElement).value);
      const auth = (document.getElementById('oas-auth') as HTMLSelectElement).value;
      const successCode = (document.getElementById('oas-success-code') as HTMLSelectElement).value;
      const hasBody = ['post', 'put', 'patch'].includes(method);

      const lines: string[] = [];
      lines.push(`paths:`);
      lines.push(`  '${path}':`);
      lines.push(`    ${method}:`);
      if (tags.length > 0) lines.push(`      tags:\n        - ${tags.join('\n        - ')}`);
      if (summary) lines.push(`      summary: '${summary.replace(/'/g, "''")}'`);
      if (desc) lines.push(`      description: '${desc.replace(/'/g, "''")}'`);
      lines.push(`      operationId: ${method}${path.split('/').filter(Boolean).map(s => s.replace(/[{}]/g, '').replace(/[-_](.)/g, (_, c) => c.toUpperCase())).map(s => s.charAt(0).toUpperCase() + s.slice(1)).join('')}`);

      // Security
      if (auth === 'bearer') lines.push(`      security:\n        - bearerAuth: []`);
      else if (auth === 'apikey') lines.push(`      security:\n        - apiKeyAuth: []`);
      else if (auth === 'basic') lines.push(`      security:\n        - basicAuth: []`);

      // Parameters
      const allParams = [
        ...pathParams.map(p => ({ ...p, in: 'path', required: true })),
        ...queryParams.map(p => ({ ...p, in: 'query', required: false })),
      ];
      if (allParams.length > 0) {
        lines.push(`      parameters:`);
        for (const p of allParams) {
          lines.push(`        - name: ${p.name}`);
          lines.push(`          in: ${p.in}`);
          if (p.desc) lines.push(`          description: '${p.desc.replace(/'/g, "''")}'`);
          lines.push(`          required: ${p.required}`);
          lines.push(`          schema:`);
          lines.push(`            type: ${p.type}`);
        }
      }

      // Request body
      if (hasBody && bodyFields.length > 0) {
        const requiredFields = bodyFields.filter(f => f.required).map(f => f.name);
        lines.push(`      requestBody:`);
        lines.push(`        required: true`);
        lines.push(`        content:`);
        lines.push(`          application/json:`);
        lines.push(`            schema:`);
        lines.push(`              type: object`);
        if (requiredFields.length > 0) lines.push(`              required:\n                - ${requiredFields.join('\n                - ')}`);
        lines.push(`              properties:`);
        for (const f of bodyFields) {
          lines.push(`                ${f.name}:`);
          lines.push(`                  type: ${f.type}`);
          if (f.desc) lines.push(`                  description: '${f.desc.replace(/'/g, "''")}'`);
        }
      }

      // Responses
      lines.push(`      responses:`);
      if (successCode !== '204') {
        lines.push(`        '${successCode}':`);
        lines.push(`          description: Success`);
        if (respFields.length > 0) {
          lines.push(`          content:`);
          lines.push(`            application/json:`);
          lines.push(`              schema:`);
          lines.push(`                type: object`);
          lines.push(`                properties:`);
          for (const f of respFields) {
            lines.push(`                  ${f.name}:`);
            lines.push(`                    type: ${f.type}`);
            if (f.desc) lines.push(`                    description: '${f.desc.replace(/'/g, "''")}'`);
          }
        }
      } else {
        lines.push(`        '204':\n          description: No Content`);
      }
      lines.push(`        '400':`);
      lines.push(`          description: Bad Request`);
      lines.push(`          content:`);
      lines.push(`            application/json:`);
      lines.push(`              schema:`);
      lines.push(`                $ref: '#/components/schemas/Error'`);
      if (auth) {
        lines.push(`        '401':`);
        lines.push(`          description: Unauthorized`);
      }
      lines.push(`        '500':`);
      lines.push(`          description: Internal Server Error`);

      // Components hint
      lines.push(`\n# Add to components/schemas:`);
      lines.push(`# components:`);
      lines.push(`#   schemas:`);
      lines.push(`#     Error:`);
      lines.push(`#       type: object`);
      lines.push(`#       properties:`);
      lines.push(`#         message:`);
      lines.push(`#           type: string`);
      if (auth === 'bearer') {
        lines.push(`#   securitySchemes:`);
        lines.push(`#     bearerAuth:`);
        lines.push(`#       type: http`);
        lines.push(`#       scheme: bearer`);
        lines.push(`#       bearerFormat: JWT`);
      }

      outputEl.textContent = lines.join('\n');
      outputSection.classList.remove('hidden');
    });

    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(outputEl.textContent || '').then(() => { copyBtn.textContent = 'Copied!'; setTimeout(() => copyBtn.textContent = 'Copy YAML', 2000); });
    });
  </script>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="OpenAPI Snippet Generator" relatedTags={['api', 'openapi', 'swagger', 'documentation', 'developer-tools']} />
</BaseLayout>
