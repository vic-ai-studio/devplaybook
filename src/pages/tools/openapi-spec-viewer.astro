---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OpenApiSpecViewer from '../../components/OpenApiSpecViewer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is OpenAPI and how is it different from Swagger?",
    answer: "OpenAPI (formerly Swagger) is the industry-standard specification for describing RESTful APIs. Swagger was the original name when SmartBear owned it. In 2016, the spec was donated to the OpenAPI Initiative and renamed to OpenAPI Specification (OAS). Today 'Swagger' often refers to the tooling (Swagger UI, Swagger Editor), while 'OpenAPI' refers to the spec itself. OpenAPI 3.0 was a major redesign over Swagger 2.0, introducing cleaner request body handling, multiple server support, and better component reuse.",
  },
  {
    question: "What versions of OpenAPI does this viewer support?",
    answer: "This viewer is optimized for OpenAPI 3.0.x and 3.1.x specs. It also renders many Swagger 2.0 (OAS 2) documents since the core path/operation/schema structure is similar, though some OAS 2-specific fields like 'definitions' (vs 'components/schemas') and 'produces'/'consumes' are not fully parsed. For best results, use an OpenAPI 3.x spec.",
  },
  {
    question: "Can I paste YAML or only JSON?",
    answer: "Both formats are supported. The viewer auto-detects the format: if your input starts with '{' it is treated as JSON and parsed with JSON.parse. Everything else is treated as YAML and processed with the built-in YAML parser. The YAML parser handles all OpenAPI-relevant constructs including nested mappings, sequences, block scalars, and inline values.",
  },
  {
    question: "What do the colored method badges mean?",
    answer: "The color coding follows REST conventions: GET (green) retrieves data without side effects; POST (blue) creates a new resource; PUT (yellow) replaces a resource entirely; PATCH (orange) partially updates a resource; DELETE (red) removes a resource. HEAD and OPTIONS use gray as they are utility methods. These colors help you quickly identify the intent and safety characteristics of each endpoint.",
  },
  {
    question: "What is a $ref in OpenAPI and how does this viewer handle it?",
    answer: "$ref is OpenAPI's way of referencing a schema defined elsewhere in the document, such as '#/components/schemas/User'. This avoids duplication and keeps specs maintainable. This viewer resolves $ref references inline when rendering endpoint details and schema tables — so instead of showing the raw $ref string, it follows the reference and displays the actual property list. Only local $ref references (within the same document) are resolved.",
  },
  {
    question: "How do I generate an OpenAPI spec for my API?",
    answer: "Most frameworks have libraries that auto-generate OpenAPI specs from your code. For Node.js: fastify-swagger, tsoa, or @nestjs/swagger. For Python: FastAPI generates specs automatically; Flask/Django can use flask-smorest or drf-spectacular. For Go: swaggo/swag. For Java/Kotlin: springdoc-openapi or swagger-core. Alternatively, write your spec first using the OpenAPI 3.x specification directly in YAML — this 'API-first' approach is recommended for better design consistency.",
  },
];
---

<BaseLayout
  title="OpenAPI Spec Viewer — Visualize Swagger/OpenAPI 3.x Specs"
  description="Paste any OpenAPI 3.x JSON or YAML spec and instantly visualize it. Browse endpoints by tag, expand request/response schemas, filter by method or path. Free, runs in your browser."
  tool="OpenAPI Viewer, Swagger Viewer, OpenAPI 3 Visualizer, API Documentation Viewer, OAS3 Parser"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">OpenAPI Spec Viewer</h1>
  <p class="text-text-muted mb-4">Paste an OpenAPI 3.x spec in JSON or YAML and get a clean, human-readable view. Browse endpoints grouped by tag, expand each one to see parameters and schemas, and explore all component definitions.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> JSON &amp; YAML auto-detect</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Endpoints grouped by tag</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Inline $ref resolution</span>
  </div>

  <OpenApiSpecViewer client:only="preact" />

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="OpenAPI Spec Viewer" relatedTags={['openapi', 'swagger', 'api', 'development', 'documentation']} />
</BaseLayout>
