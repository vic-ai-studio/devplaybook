---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EslintConfigGenerator from '../../components/EslintConfigGenerator.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is ESLint and how is it different from Prettier?", answer: "ESLint is a static analysis tool that finds code quality issues — unused variables, missing dependencies, potential bugs, and security risks. Prettier is a formatter that enforces consistent whitespace and style. They're complementary: ESLint catches logic and quality problems, Prettier handles aesthetics. Use both together: ESLint + eslint-config-prettier to disable formatting conflicts." },
  { question: "What is the difference between ESLint flat config (v9) and the legacy .eslintrc format?", answer: "Flat config (eslint.config.js) is the new default in ESLint v9+. It uses standard ESM imports instead of string-based plugin names, making dependencies explicit and eliminating magic. The legacy .eslintrc format uses JSON/YAML with string plugin names resolved via node_modules lookup. Flat config is more explicit, easier to debug, and is the recommended approach for new projects." },
  { question: "What does 'no-unused-vars' warn about?", answer: "It flags variables, function parameters, and imports that are declared but never read. Unused code is noise — it confuses readers and bloats bundles. The argsIgnorePattern: '^_' exception is a common convention: prefix intentionally-ignored function parameters with _ (e.g., (_, index) => ...) to suppress the warning." },
  { question: "Do I need eslint-plugin-import?", answer: "It's recommended for larger codebases. eslint-plugin-import enforces correct import paths, detects circular dependencies, and optionally sorts imports by group (built-ins, external packages, local files). The import/order rule paired with Prettier makes import blocks clean and consistent across the team." },
  { question: "How do I set up ESLint with TypeScript?", answer: "Install @typescript-eslint/eslint-plugin and @typescript-eslint/parser. Set the parser to @typescript-eslint/parser and extend from @typescript-eslint/recommended. This enables TypeScript-specific rules like no-explicit-any, proper handling of async/await return types, and accurate unused variable detection that understands TypeScript types." },
  { question: "What is jsx-a11y and should I enable it?", answer: "eslint-plugin-jsx-a11y enforces accessibility best practices in JSX — alt text on images, aria attributes, keyboard event handlers, and ARIA role requirements. Enabling it catches accessibility issues at development time rather than during an audit. Highly recommended for any public-facing React or Next.js application." },
];
---

<BaseLayout
  title="ESLint Config Generator — React, Next.js, TypeScript, Vue Flat Config"
  description="Generate ESLint configuration for React, Next.js, TypeScript, Node.js, or Vue. Supports ESLint v9 flat config (eslint.config.js) and legacy .eslintrc.json. Includes Prettier integration, import order, a11y, and TypeScript rules."
  tool="ESLint config generator, eslint.config.js generator, .eslintrc generator, ESLint React, ESLint TypeScript, ESLint flat config, ESLint Next.js"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "ESLint Config Generator",
    "url": "https://devplaybook.cc/tools/eslint-config-generator",
    "description": "Generate ESLint configuration files for React, Next.js, TypeScript, Node.js, and Vue. Supports ESLint v9 flat config and legacy formats.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">ESLint Config Generator</h1>
  <p class="text-text-muted mb-4">
    Generate an <a href="https://eslint.org" class="text-accent hover:underline" target="_blank" rel="noopener">ESLint</a> configuration for your framework. Choose between the new flat config format (ESLint v9+) or legacy <code class="font-mono bg-surface px-1 rounded text-sm">.eslintrc.json</code>. Includes Prettier integration, TypeScript support, and accessibility rules.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 framework presets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Flat config + legacy</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <EslintConfigGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <AffiliateSection category={['developer-tools']} />
  <ToolPageCta currentTool="ESLint Config Generator" relatedTags={['eslint', 'linter', 'code-quality', 'javascript', 'typescript', 'react']} />
</BaseLayout>
