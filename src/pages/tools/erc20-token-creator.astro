---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is an ERC-20 token?", answer: "ERC-20 is the standard interface for fungible tokens on Ethereum. All ERC-20 tokens implement the same functions: totalSupply(), balanceOf(), transfer(), transferFrom(), approve(), and allowance(). This standard lets wallets, DEXes, and DeFi protocols interact with any ERC-20 token without custom integration." },
  { question: "What decimals should I use?", answer: "18 decimals is the standard (matching ETH). It means 1 token = 10^18 smallest units. Use 18 unless you have a specific reason (e.g., stablecoins often use 6). Fewer decimals makes math simpler but limits divisibility." },
  { question: "How do I deploy this contract?", answer: "1. Copy the generated Solidity code. 2. Open Remix IDE (remix.ethereum.org). 3. Create a new .sol file and paste the code. 4. Compile with Solidity 0.8.x. 5. In Deploy tab, select 'Injected Web3' (MetaMask). 6. Deploy to your chosen network. Total cost depends on gas price." },
  { question: "What is the Ownable pattern?", answer: "Ownable from OpenZeppelin adds an owner address with an onlyOwner modifier. Functions marked onlyOwner (like mint) can only be called by the deploying address. The owner can be transferred or renounced. It's the simplest access control pattern for small projects." },
];
---

<BaseLayout
  title="ERC-20 Token Creator — Generate Solidity Token Contract Code"
  description="Generate a complete ERC-20 token Solidity contract with OpenZeppelin. Configure name, symbol, decimals, initial supply, mintable, burnable, and pausable features."
  tool="ERC-20 Token Creator, Solidity Token Generator, ERC20 Contract Generator, Ethereum Token Creator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">ERC-20 Token Creator</h1>
  <p class="text-text-muted mb-4">Generate a complete ERC-20 token contract using OpenZeppelin. Configure your token's properties and features, then deploy to Ethereum or any EVM chain.</p>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
    <!-- Config -->
    <div class="space-y-4">
      <div class="bg-bg-card border border-border rounded-xl p-5 space-y-3">
        <h2 class="text-base font-semibold">Token Details</h2>
        <div><label class="block text-xs font-medium mb-1">Token Name</label>
          <input id="token-name" type="text" value="My Token" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" /></div>
        <div><label class="block text-xs font-medium mb-1">Token Symbol</label>
          <input id="token-symbol" type="text" value="MTK" maxlength="10" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" /></div>
        <div><label class="block text-xs font-medium mb-1">Decimals</label>
          <input id="token-decimals" type="number" value="18" min="0" max="18" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" /></div>
        <div><label class="block text-xs font-medium mb-1">Initial Supply</label>
          <input id="token-supply" type="number" value="1000000" min="0" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
          <p class="text-xs text-text-muted mt-0.5">Minted to deployer on deploy</p></div>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5 space-y-3">
        <h2 class="text-base font-semibold">Features</h2>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="feat-mintable" checked /> Mintable (owner can create new tokens)
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="feat-burnable" /> Burnable (holders can burn tokens)
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="feat-pausable" /> Pausable (owner can pause all transfers)
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="feat-permit" /> Permit (gasless approvals via EIP-2612)
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="feat-capped" /> Capped supply (max token limit)
        </label>
        <div id="cap-input" class="hidden pl-4">
          <input id="token-cap" type="number" value="10000000" placeholder="Max supply"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5 space-y-3">
        <h2 class="text-base font-semibold">Solidity Version</h2>
        <select id="sol-version" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="0.8.24">0.8.24 (latest)</option>
          <option value="0.8.20">0.8.20</option>
          <option value="0.8.19">0.8.19</option>
        </select>
      </div>
    </div>

    <!-- Output -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-semibold">Generated Contract</h2>
        <div class="flex gap-2">
          <button id="copy-sol" class="text-xs text-text-muted border border-border px-2 py-1 rounded hover:bg-bg">Copy</button>
          <a id="remix-link" href="https://remix.ethereum.org" target="_blank" rel="noopener"
            class="text-xs bg-primary/10 text-primary border border-primary/30 px-2 py-1 rounded hover:bg-primary/20">Open in Remix</a>
        </div>
      </div>
      <pre id="sol-output" class="text-xs font-mono bg-bg rounded-lg p-3 overflow-auto text-text-muted whitespace-pre max-h-[65vh]"></pre>
    </div>
  </div>

  <AdUnit slot="in-content" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="ERC-20 Token Creator" relatedTags={['blockchain', 'ethereum', 'solidity', 'web3', 'smart-contracts']} />
</BaseLayout>

<script>
document.getElementById('feat-capped')!.addEventListener('change', (e) => {
  document.getElementById('cap-input')!.classList.toggle('hidden', !(e.target as HTMLInputElement).checked);
  update();
});

function sv(id: string) { return (document.getElementById(id) as HTMLInputElement)?.value || ''; }
function sb(id: string) { return (document.getElementById(id) as HTMLInputElement)?.checked || false; }

function update() {
  const name = sv('token-name') || 'MyToken';
  const symbol = sv('token-symbol').toUpperCase() || 'MTK';
  const decimals = parseInt(sv('token-decimals')) || 18;
  const supply = sv('token-supply') || '1000000';
  const cap = sv('token-cap') || '10000000';
  const solVer = sv('sol-version') || '0.8.24';
  const mintable = sb('feat-mintable');
  const burnable = sb('feat-burnable');
  const pausable = sb('feat-pausable');
  const permit = sb('feat-permit');
  const capped = sb('feat-capped');

  const contractName = name.replace(/\s+/g, '');

  const imports = [`import "@openzeppelin/contracts/token/ERC20/ERC20.sol";`];
  const inherits = ['ERC20'];

  if (mintable || capped) {
    imports.push(`import "@openzeppelin/contracts/access/Ownable.sol";`);
    if (!inherits.includes('Ownable')) inherits.push('Ownable');
  }
  if (burnable) imports.push(`import "@openzeppelin/contracts/token/ERC20/extensions/ERC20Burnable.sol";`);
  if (pausable) imports.push(`import "@openzeppelin/contracts/token/ERC20/extensions/ERC20Pausable.sol";`);
  if (permit) imports.push(`import "@openzeppelin/contracts/token/ERC20/extensions/ERC20Permit.sol";`);
  if (capped) imports.push(`import "@openzeppelin/contracts/token/ERC20/extensions/ERC20Capped.sol";`);

  if (burnable) inherits.push('ERC20Burnable');
  if (pausable) inherits.push('ERC20Pausable');
  if (permit) inherits.push('ERC20Permit');
  if (capped) inherits.push('ERC20Capped');

  const constructorBase = [
    `ERC20("${name}", "${symbol}")`,
    (mintable || capped) ? 'Ownable(msg.sender)' : null,
    permit ? `ERC20Permit("${name}")` : null,
    capped ? `ERC20Capped(${cap} * 10 ** decimals())` : null,
  ].filter(Boolean).join('\n        ');

  const decimalsOverride = decimals !== 18 ? `
    function decimals() public pure override returns (uint8) {
        return ${decimals};
    }
` : '';

  const mintFn = mintable ? `
    function mint(address to, uint256 amount) public onlyOwner {
        _mint(to, amount);
    }
` : '';

  const pauseFns = pausable ? `
    function pause() public onlyOwner {
        _pause();
    }

    function unpause() public onlyOwner {
        _unpause();
    }

    function _update(address from, address to, uint256 value)
        internal
        override(ERC20${pausable ? ', ERC20Pausable' : ''}${capped ? ', ERC20Capped' : ''})
    {
        super._update(from, to, value);
    }
` : (capped ? `
    function _update(address from, address to, uint256 value)
        internal
        override(ERC20, ERC20Capped)
    {
        super._update(from, to, value);
    }
` : '');

  const code = `// SPDX-License-Identifier: MIT
pragma solidity ^${solVer};

${imports.join('\n')}

contract ${contractName} is ${inherits.join(', ')} {
    constructor()
        ${constructorBase}
    {
        _mint(msg.sender, ${supply} * 10 ** decimals());
    }
${decimalsOverride}${mintFn}${pauseFns}}`;

  document.getElementById('sol-output')!.textContent = code;

  // Remix link
  const encoded = btoa(encodeURIComponent(code));
  (document.getElementById('remix-link') as HTMLAnchorElement).href =
    `https://remix.ethereum.org/?#code=${encoded}`;
}

['token-name','token-symbol','token-decimals','token-supply','token-cap','sol-version'].forEach(id => {
  document.getElementById(id)?.addEventListener('input', update);
});
['feat-mintable','feat-burnable','feat-pausable','feat-permit','feat-capped'].forEach(id => {
  document.getElementById(id)?.addEventListener('change', update);
});

document.getElementById('copy-sol')!.addEventListener('click', () => {
  navigator.clipboard.writeText(document.getElementById('sol-output')!.textContent || '');
});

update();
</script>
