---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PactContractBuilder from '../../components/PactContractBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is consumer-driven contract testing?",
    answer: "Consumer-driven contract testing (CDCT) is an approach where the consumer of an API defines the contract — what requests it makes and what responses it expects. The provider then verifies it can satisfy those contracts. This ensures API changes don't silently break consumers, catching integration bugs before they reach production."
  },
  {
    question: "What is Pact and how does it work?",
    answer: "Pact is the most popular CDCT framework. The consumer runs tests against a mock server that records interactions into a Pact file (JSON contract). That file is shared with the provider (via Pact Broker or directly), and the provider verifies it can satisfy all interactions. Both sides are tested independently, avoiding the need for a shared test environment."
  },
  {
    question: "What is a provider state?",
    answer: "A provider state describes the precondition the provider needs to be in for a given interaction to succeed — for example, 'a user with id 123 exists'. When the provider runs verification, it reads the provider state and sets up the necessary data before replaying the request. Without provider states, the provider has no way to know how to prepare for the test."
  },
  {
    question: "What is the difference between Pact v2, v3, and v4?",
    answer: "Pact v2 is the most widely supported spec and covers basic request/response contracts. Pact v3 adds support for message-based interactions (Kafka, SNS, queues) and provider states as parameters. Pact v4 adds support for asynchronous interactions, plugins, and combined HTTP + message contracts in a single file. For REST APIs, v2 or v3 is sufficient."
  },
  {
    question: "How do I use the generated Pact contract?",
    answer: "Save the JSON file and point your Pact consumer test framework at it (e.g. in Jest: PactV2.fromFile('./contract.json')). For provider verification, publish the contract to a Pact Broker or share the file directly, then run provider tests with the Pact verifier library for your language (Ruby, Go, Java, JS, etc.)."
  },
  {
    question: "What is a Pact Broker?",
    answer: "A Pact Broker is a shared server that stores and retrieves Pact contract files. It lets teams share contracts between consumer and provider CI pipelines automatically, tracks contract compatibility by version, and can block deployments if contracts are broken. PactFlow (pactflow.io) is the hosted SaaS version; you can also self-host the open-source pact-broker."
  },
];
---

<BaseLayout
  title="Pact Contract Builder — Generate Consumer-Driven Contract JSON"
  description="Build and export Pact contract JSON for consumer-driven contract testing. Define consumer, provider, interactions, request/response pairs, and provider states. Supports Pact Spec v2, v3, and v4."
  tool="Pact contract builder, consumer driven contract testing, Pact JSON generator, Pact framework, API contract testing"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Pact Contract Builder",
    "url": "https://devplaybook.cc/tools/pact-contract-builder",
    "description": "Build consumer-driven Pact contract JSON. Define consumer, provider, interactions, HTTP request/response pairs, and provider states. Supports Pact Spec v2, v3, and v4.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Pact Contract Builder</h1>
  <p class="text-text-muted mb-4">
    Build consumer-driven contract test JSON for the <a href="https://docs.pact.io" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">Pact framework</a>.
    Define consumer and provider names, add HTTP interactions with request/response pairs and provider states,
    then generate and download a valid Pact JSON contract file. Supports Pact Spec v2, v3, and v4.
    All generation runs in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Pact Spec v2/v3/v4</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Provider states</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Download .json</span>
  </div>
  <PactContractBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Pact Contract Builder" relatedTags={['testing', 'api', 'contract-testing', 'pact', 'integration', 'developer-tools']} />
</BaseLayout>
