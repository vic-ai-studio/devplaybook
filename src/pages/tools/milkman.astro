---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "How does Milkman compare to Postman?", answer: "Milkman is a privacy-first, open-source desktop API client with zero telemetry, no account requirement, and no cloud dependency — all data stays on your local machine. Postman is a commercially operated product that requires an account, stores collections in the cloud, and collects usage telemetry. Milkman is built in Java and runs on any platform with Java 11+. Postman is Electron-based. Milkman's plugin architecture allows extending it with support for many protocols beyond REST, whereas Postman's extensibility is more limited. The trade-off is that Milkman has a smaller community and fewer built-in integrations than Postman." },
  { question: "What plugins are available for Milkman?", answer: "Milkman has a rich plugin ecosystem. Core plugins include: REST (HTTP/HTTPS requests), GraphQL, WebSocket, gRPC, SQL (execute queries against databases), JavaScript (run scripts), Git (commit and push from inside Milkman), and Cassandra. Community plugins extend it further. Plugins are JAR files placed in the plugins directory. Each plugin adds a new request type — for example, the WebSocket plugin adds a WebSocket connection tab, the gRPC plugin adds support for protobuf services. This makes Milkman unusually versatile for a desktop API client." },
  { question: "Why would a developer choose a privacy-first API client?", answer: "API clients regularly handle sensitive data: production credentials, authentication tokens, API keys, PII in request/response bodies, and internal endpoint URLs. Tools that sync this data to the cloud or collect telemetry create a potential data leakage surface. Regulated industries (healthcare, finance, government) often have policies that prohibit sending API request data to third-party cloud services. Privacy-first tools like Milkman and Bruno store everything locally with no outbound data transmission, making them compliant with strict data handling requirements and eliminating the risk of credentials being exposed via a vendor's cloud infrastructure." },
  { question: "How does Milkman handle environment variables?", answer: "Milkman supports named environments, each containing a set of key-value variable pairs. Switch between environments (development, staging, production) from the environment dropdown. Variables are referenced in request URLs, headers, and body using double-curly brace syntax. Environments are stored as local files and can be imported/exported for sharing with teammates via Git or file share without involving any cloud service. Secret values in environments are masked in the UI to prevent accidental exposure." },
  { question: "Does Milkman support GraphQL and gRPC?", answer: "Yes, both via plugins. The GraphQL plugin provides a dedicated query editor with schema introspection support — Milkman can fetch the schema from a GraphQL endpoint and display it for reference. The gRPC plugin supports unary, server-streaming, client-streaming, and bidirectional-streaming calls. You provide the .proto file or a reflection-enabled endpoint, define the request message, and execute the call. Both plugins are maintained as part of the Milkman plugin ecosystem and are available in the official releases." },
  { question: "What are the system requirements for Milkman?", answer: "Milkman requires Java 11 or higher. It is distributed as a platform-specific installer for Windows (installer and portable ZIP) and macOS, and as a cross-platform JAR for Linux. On most systems you can check your Java version with java -version. If Java is not installed, adopt OpenJDK from adoptium.net — it is free and open-source. Milkman itself is open-source under the MIT license and available at milkman.dev. It has modest hardware requirements and runs well on older machines." },
];
---

<BaseLayout
  title="Milkman — Privacy-First API Client with Extensible Plugin System"
  description="Milkman is a free, open-source Java desktop API client with no telemetry, no account, and no cloud. Supports REST, GraphQL, WebSocket, gRPC via plugins. The privacy-first Postman alternative."
  tool="Milkman API client, privacy API client, Milkman vs Postman, open source API client Java, Milkman plugins, gRPC API client, no telemetry API tool"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Milkman — Privacy-First API Client",
    "url": "https://devplaybook.cc/tools/milkman",
    "description": "Milkman is a free, open-source Java desktop API client with no telemetry, no account, and no cloud. Supports REST, GraphQL, WebSocket, gRPC via plugins.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Milkman — Privacy-First API Client</h1>
  <p class="text-text-muted mb-6">
    <strong>Milkman</strong> is a free, open-source desktop API client built on Java, designed for developers who care about data privacy. It stores all request data locally, sends zero telemetry, requires no account, and never touches a cloud server. An extensible, multi-protocol alternative to Postman for privacy-conscious developers and regulated environments.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Zero telemetry, no account</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> REST, GraphQL, WebSocket, gRPC</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Extensible plugin system</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Environment variables</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> MIT licensed, open source</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Milkman?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Milkman was created by Florian Enner as a privacy-respecting API client after growing concerns about cloud-synced API tools handling sensitive credentials and request data. It is built in Java with a JavaFX UI, making it lightweight and cross-platform. All collections and environments are stored as local files — nothing is ever uploaded to any external server.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    What makes Milkman particularly distinctive is its <strong>plugin architecture</strong>. Rather than supporting a fixed set of protocols, Milkman provides a core plugin host and each protocol (REST, GraphQL, gRPC, WebSocket, SQL) is a separate JAR plugin. This makes it unusually extensible: adding a new protocol is as simple as dropping a plugin file into the plugins directory and restarting the application.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Zero telemetry</strong> — no analytics, no usage tracking, no data sent to any external server</li>
    <li><strong>No account required</strong> — install and use immediately; no registration, no email, no subscription</li>
    <li><strong>Plugin system</strong> — REST, GraphQL, WebSocket, gRPC, SQL, JavaScript, Git plugins available</li>
    <li><strong>Environment variables</strong> — named environments with key-value variables, switchable per request</li>
    <li><strong>Request history</strong> — local request history with search; all data stored on disk</li>
    <li><strong>Collections</strong> — organize requests into workspaces and collections stored as local files</li>
    <li><strong>Import/export</strong> — import from Postman collections (JSON format)</li>
    <li><strong>GraphQL</strong> — schema introspection and query editor via GraphQL plugin</li>
    <li><strong>gRPC</strong> — unary and streaming gRPC calls via gRPC plugin with .proto file support</li>
    <li><strong>Scripting</strong> — pre/post-request JavaScript scripts via the JavaScript plugin</li>
    <li><strong>Cross-platform</strong> — Windows, macOS, Linux; requires Java 11+</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Installation</h2>
  <div class="bg-bg-card border border-border rounded-xl p-4 mb-4">
    <p class="text-xs text-text-muted uppercase font-semibold mb-2">Download (all platforms)</p>
    <pre class="text-sm font-mono text-text">Download installer from milkman.dev
Requires Java 11+ (get from adoptium.net)</pre>
  </div>
  <div class="bg-bg-card border border-border rounded-xl p-4 mb-4">
    <p class="text-xs text-text-muted uppercase font-semibold mb-2">Check Java version</p>
    <pre class="text-sm font-mono text-text">java -version
# Should show 11.x or higher</pre>
  </div>
  <div class="bg-bg-card border border-border rounded-xl p-4 mb-6">
    <p class="text-xs text-text-muted uppercase font-semibold mb-2">Install a plugin</p>
    <pre class="text-sm font-mono text-text"># Download plugin JAR from GitHub releases
# Place in: ~/.milkman/plugins/
# Restart Milkman to activate the plugin</pre>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Available Plugins</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Plugin</th>
          <th class="border border-border px-3 py-2 text-left">Protocol / Feature</th>
          <th class="border border-border px-3 py-2 text-left">Notes</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-border px-3 py-2 font-mono text-xs">milkman-rest</td>
          <td class="border border-border px-3 py-2">HTTP / HTTPS REST</td>
          <td class="border border-border px-3 py-2">Core plugin, bundled by default</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2 font-mono text-xs">milkman-graphql</td>
          <td class="border border-border px-3 py-2">GraphQL queries and mutations</td>
          <td class="border border-border px-3 py-2">Schema introspection support</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2 font-mono text-xs">milkman-grpc</td>
          <td class="border border-border px-3 py-2">gRPC (unary + streaming)</td>
          <td class="border border-border px-3 py-2">Proto file or server reflection</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2 font-mono text-xs">milkman-websocket</td>
          <td class="border border-border px-3 py-2">WebSocket connections</td>
          <td class="border border-border px-3 py-2">Send and receive messages</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2 font-mono text-xs">milkman-sql</td>
          <td class="border border-border px-3 py-2">SQL database queries</td>
          <td class="border border-border px-3 py-2">JDBC-based, any SQL database</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2 font-mono text-xs">milkman-scripting</td>
          <td class="border border-border px-3 py-2">Pre/post-request JavaScript</td>
          <td class="border border-border px-3 py-2">Dynamic request manipulation</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2 font-mono text-xs">milkman-git-sync</td>
          <td class="border border-border px-3 py-2">Git workspace sync</td>
          <td class="border border-border px-3 py-2">Commit collections directly from app</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Milkman vs Bruno vs Postman</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">Milkman</th>
          <th class="border border-border px-3 py-2 text-left">Bruno</th>
          <th class="border border-border px-3 py-2 text-left">Postman</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-border px-3 py-2">Telemetry</td>
          <td class="border border-border px-3 py-2 text-green-400">None</td>
          <td class="border border-border px-3 py-2 text-green-400">None</td>
          <td class="border border-border px-3 py-2 text-red-400">Yes</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Account required</td>
          <td class="border border-border px-3 py-2 text-green-400">No</td>
          <td class="border border-border px-3 py-2 text-green-400">No</td>
          <td class="border border-border px-3 py-2 text-red-400">Yes</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">gRPC support</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes (plugin)</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Experimental</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Git-friendly collections</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Via git-sync plugin</td>
          <td class="border border-border px-3 py-2 text-green-400">Native (.bru files)</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Export only</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">Runtime</td>
          <td class="border border-border px-3 py-2">Java 11+</td>
          <td class="border border-border px-3 py-2">Electron</td>
          <td class="border border-border px-3 py-2">Electron</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">SQL queries</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes (plugin)</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Use Cases</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li>API development in regulated industries (healthcare, finance, government) where cloud data policies prohibit third-party sync</li>
    <li>Testing gRPC services with the milkman-grpc plugin and .proto reflection</li>
    <li>Developers who need a single tool for REST, GraphQL, WebSocket, gRPC, and SQL queries</li>
    <li>Teams migrating away from Postman who want a privacy-respecting alternative with zero cloud dependency</li>
    <li>Secure environments (air-gapped networks, VPNs) where external API calls from the tool itself are not permitted</li>
    <li>Postman collection import for quick migration of existing request libraries</li>
  </ul>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Milkman API Client" relatedTags={['api', 'rest', 'grpc', 'graphql', 'privacy', 'http', 'developer-tools']} />
</BaseLayout>
