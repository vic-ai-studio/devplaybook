---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GitCheatsheetInteractive from '../../components/GitCheatsheetInteractive.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the difference between git fetch and git pull?", answer: "git fetch downloads changes from the remote but does NOT merge them into your working branch. git pull is essentially git fetch + git merge — it downloads and integrates remote changes. Use fetch when you want to review changes before merging." },
  { question: "How do I undo the last commit without losing changes?", answer: "Use 'git reset HEAD~1'. This moves the branch pointer back one commit but keeps your files unchanged (staged changes become unstaged). To also unstage, use 'git reset HEAD~1 --mixed'. To discard changes entirely, use 'git reset --hard HEAD~1'." },
  { question: "What is git stash used for?", answer: "git stash temporarily saves your uncommitted changes so you can work on something else. Use 'git stash' to save and 'git stash pop' to restore. This is useful when you need to switch branches mid-task without committing unfinished work." },
  { question: "What is the difference between git merge and git rebase?", answer: "git merge creates a new 'merge commit' that joins two branches while preserving history. git rebase rewrites history by moving your commits on top of another branch, creating a linear history. Rebase is cleaner but rewrites commits — never rebase shared/public branches." },
];
---

<BaseLayout
  title="Git Cheatsheet Interactive — Search Git Commands Fast"
  description="Searchable, interactive Git cheatsheet with 50+ commands. Filter by category, copy commands instantly. Covers setup, staging, branching, remotes, history, undo, and tags. Free."
  tool="Git Cheatsheet, Git Commands Reference, Git Quick Reference, Git Command List"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Git Cheatsheet Interactive</h1>
  <p class="text-text-muted mb-4">Search and filter 50+ essential Git commands. Click any command to copy it instantly. Organized by category: setup, staging, branches, remotes, history, and more. <span class="text-xs text-text-muted">Free, no sign-up.</span></p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> One-click copy</span>
  </div>
  <GitCheatsheetInteractive client:load />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Git Cheatsheet Interactive" relatedTags={['git', 'devops', 'cli', 'workflow']} />
</BaseLayout>
