---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DockerLayerOptimizer from '../../components/DockerLayerOptimizer.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "Why does my Docker build take so long after every code change?",
    answer: "Docker caches each layer. If you COPY your entire project before running npm install, any code change invalidates the install layer, forcing a full dependency re-download. The fix: COPY package*.json first, run npm install (this layer is cached), then COPY the rest of your source code."
  },
  {
    question: "What is a multi-stage Docker build and when should I use it?",
    answer: "Multi-stage builds use multiple FROM instructions. The first stage (builder) compiles your code with all build tools. The second stage (runtime) copies only the compiled artifacts — no build tools, no dev dependencies. Result: images that are 3-10x smaller and more secure."
  },
  {
    question: "Should I use COPY . . or specific paths?",
    answer: "Prefer specific paths when possible: COPY src/ ./src/ or COPY package*.json ./. This gives Docker better granularity for cache invalidation. Always use a .dockerignore file to exclude node_modules, .git, .env, and build artifacts from COPY . . to avoid bloating the context."
  },
  {
    question: "Why should I combine RUN commands with &&?",
    answer: "Each RUN instruction creates a separate layer. Combining commands in one RUN (e.g., RUN apt-get update && apt-get install -y curl && apt-get clean) keeps related changes atomic, reduces layer count, and prevents apt-get cache from being baked into the image."
  },
  {
    question: "How do I reduce Docker image size?",
    answer: "1) Use slim or alpine base images (node:20-alpine vs node:20). 2) Use multi-stage builds. 3) Run apt-get clean && rm -rf /var/lib/apt/lists/* after installs. 4) Add .dockerignore. 5) Avoid installing debugging tools in production images."
  },
  {
    question: "Why should containers not run as root?",
    answer: "If an attacker escapes the container, they would have root access on the host. Create a dedicated user: RUN addgroup -S app && adduser -S app -G app and then USER app. Most modern base images (distroless, etc.) default to non-root users."
  },
];
---

<BaseLayout
  title="Docker Layer Optimizer — Analyze Dockerfile Cache & Best Practices"
  description="Analyze your Dockerfile for layer caching anti-patterns, multi-stage build opportunities, and security issues. Get an optimization score with actionable fixes."
  tool="docker layer optimizer, dockerfile analyzer, docker cache, multi-stage build, dockerfile best practices"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Docker Layer Optimizer</h1>
  <p class="text-text-muted mb-8">Paste your Dockerfile to detect layer caching anti-patterns, multi-stage build opportunities, and security issues. Get an optimization score with concrete fixes.</p>
  <DockerLayerOptimizer client:only="preact" />
  <FaqSection faq={faq} />
  <AffiliateSection category={['devops', 'deployment']} />
  <ToolPageCta currentTool="Docker Layer Optimizer" relatedTags={['docker', 'devops', 'ci-cd', 'containers', 'optimization']} />
</BaseLayout>
