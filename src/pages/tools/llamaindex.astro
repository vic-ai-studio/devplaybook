---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is LlamaIndex and what problems does it solve?",
    answer: "LlamaIndex (formerly GPT Index) is a data framework for building LLM applications that need to reason over custom data. Its core strength is the ingestion, structuring, and retrieval layer — it handles loading data from 100+ sources, chunking, embedding, storing in vector indexes, and building sophisticated query engines. It is the go-to choice for complex RAG patterns like multi-document synthesis, hierarchical retrieval, and query routing."
  },
  {
    question: "What is the difference between Documents, Nodes, and Indexes?",
    answer: "Documents are the raw data containers — loaded from files, web pages, or databases. Nodes are the chunked, processed units derived from Documents — each Node has text, metadata, and an embedding. Indexes organize Nodes for retrieval: VectorStoreIndex stores Nodes as embeddings for semantic search, SummaryIndex chains Nodes for sequential processing, KeywordTableIndex enables keyword lookup. The Document → Node → Index pipeline is the core LlamaIndex data model."
  },
  {
    question: "What are query engines in LlamaIndex?",
    answer: "A QueryEngine is the interface that takes a natural language query and returns a response using the data in an index. VectorIndexQueryEngine does similarity search + LLM synthesis. SummaryIndexQueryEngine iterates through all nodes to synthesize an answer. RouterQueryEngine dynamically selects which sub-engine to use based on the query. SubQuestionQueryEngine breaks complex queries into sub-questions, queries multiple indexes, then synthesizes a combined answer."
  },
  {
    question: "How does LlamaIndex integrate with HuggingFace models?",
    answer: "LlamaIndex supports HuggingFace for both LLMs and embeddings. For embeddings, use HuggingFaceEmbedding with any sentence-transformer model — the embedding runs locally with no API cost. For LLMs, use HuggingFaceLLM to run open-source models (Llama 3, Mistral, Qwen) locally via transformers. This enables fully local RAG pipelines with zero API costs and complete data privacy."
  },
  {
    question: "LlamaIndex vs LangChain: which should I choose for RAG?",
    answer: "LlamaIndex excels at sophisticated RAG — advanced chunking strategies, multi-document synthesis, hierarchical indexes, query routing, and retrieval evaluation. LangChain excels at agent orchestration, multi-step tool use, diverse LLM integrations, and general application chains. For pure RAG with complex retrieval requirements, LlamaIndex is the stronger choice. For agentic workflows with tools, LangChain wins. Many teams use both: LlamaIndex for the retrieval layer, LangChain for agent orchestration."
  },
  {
    question: "What is LlamaCloud?",
    answer: "LlamaCloud is LlamaIndex's managed platform providing hosted parsing (LlamaParse — best-in-class PDF/document parsing), managed indexing pipelines, and observability. LlamaParse handles complex PDFs with tables, images, and multi-column layouts far better than PyPDF2 or pdfminer. It is available on a free tier (1000 pages/day) and paid plans for production use."
  },
];
---

<BaseLayout
  title="LlamaIndex: Data Framework for LLM Applications & RAG"
  description="Complete LlamaIndex guide — Documents/Nodes/Indexes core concepts, SimpleDirectoryReader, VectorStoreIndex, query engines, RAG pipeline, HuggingFace and OpenAI integration, and LlamaIndex vs LangChain comparison."
  tool="LlamaIndex, RAG, vector index, LLM data framework, document retrieval"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"LlamaIndex: Data Framework for LLM Applications & RAG","url":"https://devplaybook.cc/tools/llamaindex","description":"Complete LlamaIndex guide — Documents, Nodes, Indexes, RAG pipeline, query engines, and HuggingFace integration."})} />

  <h1 class="text-3xl font-bold mb-2">LlamaIndex: Data Framework for LLM Applications &amp; RAG</h1>
  <p class="text-text-muted mb-6">LlamaIndex is the leading data framework for building LLM applications over custom data. It excels at the ingestion-to-retrieval pipeline: loading from 100+ data sources, intelligent chunking into Nodes, building vector/summary/keyword indexes, and powering sophisticated query engines for RAG, multi-document Q&amp;A, and agent tool use.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100+ data source loaders</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Advanced RAG patterns</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multiple index types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Query routing &amp; synthesis</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Local HuggingFace support</span>
  </div>

  <ToolPageCta />

  <!-- Core Concepts: Load + Index -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">Core Pipeline: Load, Index, and Query</h2>
    <p class="text-text-muted mb-4">The fundamental LlamaIndex workflow — load documents, build a VectorStoreIndex, and query with natural language.</p>
    <pre class="bg-bg-card border border-border rounded-xl p-4 text-sm font-mono overflow-x-auto mb-4"><code class="text-green-400">pip install llama-index llama-index-embeddings-openai llama-index-llms-openai

from llama_index.core import (
    SimpleDirectoryReader,
    VectorStoreIndex,
    Settings,
    StorageContext,
    load_index_from_storage
)
from llama_index.llms.openai import OpenAI
from llama_index.embeddings.openai import OpenAIEmbedding

# Global settings — applied to all indexes and query engines
Settings.llm = OpenAI(model="gpt-4o-mini", temperature=0)
Settings.embed_model = OpenAIEmbedding(model="text-embedding-3-small")
Settings.chunk_size = 1024
Settings.chunk_overlap = 128

# Load documents from a directory (supports PDF, DOCX, MD, TXT, HTML, CSV...)
documents = SimpleDirectoryReader("./data").load_data()
print(f"Loaded &#123;len(documents)&#125; documents")

# Build a VectorStoreIndex (embeddings auto-generated for each chunk)
index = VectorStoreIndex.from_documents(documents, show_progress=True)

# Persist to disk
index.storage_context.persist(persist_dir="./index_storage")

# Later: reload from disk (no re-embedding needed)
storage_context = StorageContext.from_defaults(persist_dir="./index_storage")
loaded_index = load_index_from_storage(storage_context)

# Create a query engine and ask questions
query_engine = loaded_index.as_query_engine(similarity_top_k=4)
response = query_engine.query("What is the main architecture of the system?")
print(response)
# Access source nodes used for the answer
for node in response.source_nodes:
    print(f"  score=&#123;node.score:.3f&#125; | &#123;node.text[:100]&#125;...")</code></pre>
  </section>

  <!-- Advanced: Custom Node Parser + Metadata -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">Custom Node Parsing &amp; Metadata Enrichment</h2>
    <p class="text-text-muted mb-4">Control how Documents are split into Nodes and enrich Nodes with metadata for better retrieval.</p>
    <pre class="bg-bg-card border border-border rounded-xl p-4 text-sm font-mono overflow-x-auto mb-4"><code class="text-green-400">from llama_index.core.node_parser import (
    SentenceSplitter,
    SemanticSplitterNodeParser,
    HierarchicalNodeParser
)
from llama_index.core.extractors import (
    TitleExtractor,
    QuestionsAnsweredExtractor,
    SummaryExtractor
)
from llama_index.core.ingestion import IngestionPipeline

# Build an ingestion pipeline with custom transformations
pipeline = IngestionPipeline(
    transformations=[
        # Hierarchical splitter: creates parent (512) + child (128) chunks
        HierarchicalNodeParser.from_defaults(chunk_sizes=[512, 128]),

        # Auto-extract metadata using LLM
        TitleExtractor(nodes=3),               # extract document titles
        QuestionsAnsweredExtractor(questions=3), # what questions does this answer?
    ]
)

nodes = pipeline.run(documents=documents)
print(f"Created &#123;len(nodes)&#125; nodes from &#123;len(documents)&#125; documents")
for node in nodes[:2]:
    print(f"  chars=&#123;len(node.text)&#125; | metadata=&#123;list(node.metadata.keys())&#125;")

# Auto-merging retriever (retrieves child chunks, merges to parent context)
from llama_index.core.retrievers import AutoMergingRetriever
from llama_index.core.storage.docstore import SimpleDocumentStore

docstore = SimpleDocumentStore()
docstore.add_documents(nodes)
index = VectorStoreIndex(nodes)

base_retriever = index.as_retriever(similarity_top_k=12)
auto_merging_retriever = AutoMergingRetriever(
    base_retriever, storage_context=index.storage_context, verbose=True
)</code></pre>
  </section>

  <!-- Multi-engine Query Routing -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">Query Routing &amp; Multi-Document Synthesis</h2>
    <p class="text-text-muted mb-4">Route queries to different indexes automatically, or break complex questions into sub-questions.</p>
    <pre class="bg-bg-card border border-border rounded-xl p-4 text-sm font-mono overflow-x-auto mb-4"><code class="text-green-400">from llama_index.core.tools import QueryEngineTool
from llama_index.core.query_engine import SubQuestionQueryEngine, RouterQueryEngine
from llama_index.core.selectors import LLMSingleSelector

# Create specialized indexes for different document sets
qdrant_index = VectorStoreIndex.from_documents(qdrant_docs)
milvus_index  = VectorStoreIndex.from_documents(milvus_docs)

# Wrap as tools with descriptions for routing
tools = [
    QueryEngineTool.from_defaults(
        query_engine=qdrant_index.as_query_engine(),
        name="qdrant_guide",
        description="Information about Qdrant vector database, payload filtering, and sparse vectors"
    ),
    QueryEngineTool.from_defaults(
        query_engine=milvus_index.as_query_engine(),
        name="milvus_guide",
        description="Information about Milvus distributed database, DiskANN, and billion-scale search"
    ),
]

# RouterQueryEngine — LLM picks which tool to use
router_engine = RouterQueryEngine(
    selector=LLMSingleSelector.from_defaults(),
    query_engine_tools=tools,
    verbose=True
)
response = router_engine.query("How does Qdrant's payload filtering compare to SQL WHERE clauses?")
print(response)

# SubQuestionQueryEngine — breaks complex queries into sub-questions
sub_engine = SubQuestionQueryEngine.from_defaults(query_engine_tools=tools, verbose=True)
response = sub_engine.query(
    "Compare the index types supported by Qdrant and Milvus, and which is better for 1B vectors?"
)</code></pre>
  </section>

  <!-- Comparison Table -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">LlamaIndex vs LangChain vs Haystack</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm min-w-[640px]">
        <thead>
          <tr class="text-text-muted text-xs uppercase border-b border-border">
            <th class="text-left pb-3 pr-4 font-medium">Dimension</th>
            <th class="text-left pb-3 pr-4 font-medium">LlamaIndex</th>
            <th class="text-left pb-3 pr-4 font-medium">LangChain</th>
            <th class="text-left pb-3 font-medium">Haystack</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border text-text-muted">
          <tr><td class="py-3 pr-4 font-medium text-text">Primary strength</td><td class="py-3 pr-4 text-green-500">Data ingestion + RAG</td><td class="py-3 pr-4">Agents + chaining</td><td class="py-3 pr-4">NLP pipelines</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">RAG sophistication</td><td class="py-3 pr-4 text-green-500">Excellent (hierarchical, multi-doc)</td><td class="py-3 pr-4">Good</td><td class="py-3 pr-4">Good</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Agent support</td><td class="py-3 pr-4">Good</td><td class="py-3 pr-4 text-green-500">Excellent</td><td class="py-3 pr-4">Basic</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Data loaders</td><td class="py-3 pr-4 text-green-500">100+ (LlamaHub)</td><td class="py-3 pr-4">80+</td><td class="py-3 pr-4">40+</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">PDF parsing</td><td class="py-3 pr-4 text-green-500">LlamaParse (best-in-class)</td><td class="py-3 pr-4">PyPDF2 / Unstructured</td><td class="py-3 pr-4">Haystack PDF converters</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Observability</td><td class="py-3 pr-4">LlamaCloud</td><td class="py-3 pr-4 text-green-500">LangSmith</td><td class="py-3 pr-4">Hayhooks</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Best for</td><td class="py-3 pr-4">Complex RAG, doc Q&amp;A</td><td class="py-3 pr-4">General AI apps, agents</td><td class="py-3 pr-4">Production NLP systems</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="LlamaIndex RAG Framework Guide" relatedTags={['ai', 'llm', 'rag', 'llamaindex', 'embeddings', 'vector-database']} />
</BaseLayout>
