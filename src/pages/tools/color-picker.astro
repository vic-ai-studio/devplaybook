---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ColorPicker from '../../components/ColorPicker.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Color Picker & Palette Generator"
  description="Pick any color and instantly get its HEX, RGB, and HSL values. Check WCAG contrast ratios against white and black, and generate a 5-shade palette. Runs entirely in your browser."
  tool="Color Picker, Hex Color Converter, WCAG Contrast Checker, Palette Generator"
>
  <h1 class="text-3xl font-bold mb-2">Color Picker & Palette Generator</h1>
  <p class="text-text-muted mb-8">Pick a color to get HEX, RGB, and HSL values with one-click copy. Instantly check WCAG AA/AAA contrast ratios against white and black, and generate a 5-shade palette for your design system.</p>
  <ColorPicker client:only="preact" />
  <ToolPageCta currentTool="Color Picker & Palette Generator" relatedTags={['color', 'css', 'design', 'accessibility', 'wcag']} />
</BaseLayout>
