---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NpmPackageCompare from '../../components/NpmPackageCompare.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What does gzipped bundle size mean?", answer: "The gzipped size is what actually gets transferred over the network when a user loads your site. Servers compress JS files with gzip before sending. The raw (minified) size is what gets parsed and executed by the JavaScript engine. Both matter: gzip determines download time, raw size affects parse/execution time on slower devices." },
  { question: "When should I choose dayjs over moment?", answer: "dayjs (3 kB gzipped) vs moment (69 kB gzipped) — a 23x difference. Choose dayjs for basic date formatting without complex timezone handling. dayjs uses the same API as Moment.js so migration is minimal. Only use moment if you need heavy locale/timezone features that dayjs plugins cannot provide." },
  { question: "Does bundle size matter if I use tree-shaking?", answer: "Tree-shaking removes unused exports — it helps with ESM libraries like lodash-es but not CJS libraries that export a single object. Moment.js cannot be tree-shaken because of how it registers locales. Check if the library has a module field in package.json (ESM build) — that is a prerequisite for effective tree-shaking." },
  { question: "How does dependency count affect my bundle?", answer: "Each dependency can add transitive dependencies (dependencies of dependencies). Libraries with many dependencies increase the chance of version conflicts, security vulnerabilities, and bundle bloat. Prefer libraries with zero or few dependencies for critical performance paths." },
  { question: "What is a good bundle size for a web app?", answer: "Google Core Web Vitals guidance: total JS under 300 kB gzipped for good LCP. Per library: under 5 kB is tiny, 5-25 kB small, 25-100 kB medium, over 100 kB should trigger a review. Use dynamic import() to lazy-load large libraries not needed on the initial render." },
];
---

<BaseLayout
  title="npm Package Compare — Compare Bundle Size, Dependencies & Downloads"
  description="Compare two npm packages side by side: bundle size (minified + gzipped), dependency count. Make informed decisions choosing between libraries like moment vs dayjs, lodash vs ramda. Free developer tool."
  tool="npm package compare, npm bundle size comparison, JavaScript library comparison, npm vs comparison, bundle size checker, dependency count comparison, moment vs dayjs, lodash vs ramda"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "npm Package Compare",
    "url": "https://devplaybook.cc/tools/npm-package-compare",
    "description": "Compare two npm packages side by side: minified size, gzipped size, dependency count. Powered by bundlephobia.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">npm Package Compare</h1>
  <p class="text-text-muted mb-4">
    Compare two npm packages side by side — bundle size (minified + gzipped), dependency count, and load time estimate.
    Make informed library choices before adding weight to your bundle.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Bundlephobia data</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Gzipped size comparison</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Popular pairs pre-loaded</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Dependency count</span>
  </div>
  <NpmPackageCompare client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="npm Package Compare" relatedTags={['javascript', 'npm', 'performance', 'bundling', 'developer-tools']} />
</BaseLayout>
