---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a sitemap.xml and why does it matter for SEO?", answer: "A sitemap.xml is an XML file that lists all the URLs on your website that you want search engines to crawl and index. It helps search engines discover pages they might not find through normal link-following (especially for new sites, deep pages, or pages with thin internal links). While Google doesn't guarantee it will index everything in your sitemap, it's a reliable signal. Submit it via Google Search Console for fastest indexing." },
  { question: "What is the required XML structure for a sitemap?", answer: "A standard sitemap must start with: <?xml version='1.0' encoding='UTF-8'?><urlset xmlns='http://www.sitemaps.org/schemas/sitemap/0.9'>. Each URL entry uses <url><loc>https://example.com/page</loc></url>. Optional elements per URL: <lastmod> (ISO 8601 date like 2024-03-15), <changefreq> (always/hourly/daily/weekly/monthly/yearly/never), and <priority> (0.0–1.0, default 0.5). The sitemap must be UTF-8 encoded and under 50MB / 50,000 URLs." },
  { question: "What are the sitemap size limits?", answer: "Google's limits: maximum 50,000 URLs per sitemap file, maximum 50MB uncompressed file size. If you exceed these, create a sitemap index file that references multiple sitemap files: <sitemapindex><sitemap><loc>https://example.com/sitemap1.xml</loc></sitemap></sitemapindex>. Large e-commerce sites often split by category: products-sitemap.xml, categories-sitemap.xml, blog-sitemap.xml." },
  { question: "Should I include noindex pages in my sitemap?", answer: "No. Never include pages with noindex meta tags or X-Robots-Tag: noindex in your sitemap. This sends conflicting signals to search engines. Also exclude: redirect pages (301/302 targets), pages returning 4xx/5xx errors, login-required pages, thin duplicate content, and pages blocked by robots.txt. Your sitemap should contain only canonical, indexable pages." },
  { question: "How do I submit my sitemap to Google?", answer: "Three methods: (1) Google Search Console → Sitemaps → Enter sitemap URL → Submit. This is the most reliable method for monitoring. (2) robots.txt: add 'Sitemap: https://example.com/sitemap.xml' as a separate line. Googlebot reads this automatically. (3) Ping Google: fetch https://www.google.com/ping?sitemap=https://example.com/sitemap.xml (effective for new/updated sitemaps). Most frameworks (Next.js, Astro, WordPress) generate sitemaps automatically." },
  { question: "What common sitemap errors should I watch for?", answer: "Common issues: (1) Missing XML declaration or wrong namespace URL. (2) Non-absolute URLs (must start with http:// or https://). (3) URLs not matching the domain in Search Console. (4) Special characters not escaped (& must be &amp;, < must be &lt;). (5) lastmod not in ISO 8601 format. (6) priority values outside 0.0–1.0. (7) changefreq typos (must be exact values). (8) File over 50MB or 50,000 URLs — use sitemap index." },
];
---

<BaseLayout
  title="Sitemap.xml Validator — Check Sitemap Structure & URL Format"
  description="Validate your sitemap.xml structure and URLs. Checks XML format, namespace, URL count, required fields, special characters, and common SEO mistakes. Paste XML and get instant results."
  tool="sitemap.xml validator, sitemap checker, sitemap XML validator, sitemap structure check, SEO sitemap tool"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Sitemap.xml Validator",
    "url": "https://devplaybook.cc/tools/sitemap-validator",
    "description": "Validate sitemap.xml structure and URLs. Checks namespace, URL count, required fields, special character encoding, and common sitemap mistakes.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Sitemap.xml Validator</h1>
  <p class="text-text-muted mb-4">
    Paste your <code class="font-mono bg-surface px-1 rounded text-sm">sitemap.xml</code> content to validate its structure, namespace, URL count, and required fields. Flags common issues that prevent Google from reading your sitemap. Runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> XML structure & namespace</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> URL count & format check</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Common SEO mistakes detection</span>
  </div>

  <!-- Input -->
  <div class="bg-bg-card border border-border rounded-xl p-6 mb-6">
    <div class="flex items-center justify-between mb-2">
      <label class="font-semibold text-sm" for="sitemap-input">Paste sitemap.xml content</label>
      <button id="load-example-btn" class="text-xs text-primary hover:underline">Load example</button>
    </div>
    <textarea id="sitemap-input" rows="10"
      placeholder="<?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot;?>&#10;<urlset xmlns=&quot;http://www.sitemaps.org/schemas/sitemap/0.9&quot;>&#10;  <url>&#10;    <loc>https://example.com/</loc>&#10;    <lastmod>2024-03-15</lastmod>&#10;    <priority>1.0</priority>&#10;  </url>&#10;</urlset>"
      class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-xs font-mono focus:outline-none focus:ring-2 focus:ring-primary/50 resize-y min-h-[200px]"></textarea>
    <button id="validate-btn"
      class="mt-3 bg-primary text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors">
      Validate Sitemap
    </button>
  </div>

  <!-- Results -->
  <div id="results" class="hidden space-y-4 mb-6">

    <!-- Overall status -->
    <div id="status-banner" class="rounded-xl border p-4 flex items-start gap-3">
      <span id="status-icon" class="text-2xl mt-0.5">✓</span>
      <div>
        <div class="font-semibold" id="status-title"></div>
        <div class="text-sm text-text-muted" id="status-desc"></div>
      </div>
    </div>

    <!-- Stats -->
    <div id="stats-grid" class="grid grid-cols-2 sm:grid-cols-4 gap-3"></div>

    <!-- Issues -->
    <div id="issues-section" class="hidden bg-bg-card border border-border rounded-xl p-5">
      <h3 class="font-semibold text-sm mb-3">Issues Found</h3>
      <ul class="space-y-2" id="issues-list"></ul>
    </div>

    <!-- URL preview -->
    <div id="url-preview-section" class="bg-bg-card border border-border rounded-xl p-5">
      <h3 class="font-semibold text-sm mb-3">URL Preview <span class="text-text-muted font-normal" id="url-count-label"></span></h3>
      <div class="space-y-1.5" id="url-list"></div>
    </div>

  </div>
</BaseLayout>

<script is:inline>
  const NAMESPACE = 'http://www.sitemaps.org/schemas/sitemap/0.9';
  const MAX_URLS = 50000;

  function stat(label, value, colorClass) {
    return `<div class="bg-bg-card border border-border rounded-lg p-3 text-center">
      <div class="text-xl font-bold ${colorClass || 'text-text'}">${value}</div>
      <div class="text-xs text-text-muted mt-0.5">${label}</div>
    </div>`;
  }

  function validate() {
    const raw = document.getElementById('sitemap-input').value.trim();
    if (!raw) { alert('Please paste sitemap XML content.'); return; }

    const issues = [];
    const warnings = [];
    let urlCount = 0;
    let urls = [];
    let parsed = null;

    // Parse XML
    try {
      const parser = new DOMParser();
      parsed = parser.parseFromString(raw, 'application/xml');
      const parseError = parsed.querySelector('parsererror');
      if (parseError) {
        issues.push({ level: 'error', msg: 'XML parse error: ' + parseError.textContent.split('\n')[0].trim() });
      }
    } catch(e) {
      issues.push({ level: 'error', msg: 'Failed to parse XML: ' + e.message });
    }

    // Check namespace
    if (parsed && !issues.length) {
      const urlset = parsed.documentElement;
      const ns = urlset.getAttribute('xmlns');
      if (!ns) {
        issues.push({ level: 'error', msg: 'Missing xmlns namespace attribute on <urlset>. Add: xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"' });
      } else if (ns !== NAMESPACE) {
        issues.push({ level: 'warning', msg: `Namespace "${ns}" is non-standard. Expected: ${NAMESPACE}` });
      }

      // Detect sitemap index
      const isSitemapIndex = urlset.nodeName === 'sitemapindex' || urlset.localName === 'sitemapindex';
      const urlEls = isSitemapIndex ? [] : Array.from(parsed.getElementsByTagNameNS('*', 'url'));
      const sitemapEls = isSitemapIndex ? Array.from(parsed.getElementsByTagNameNS('*', 'sitemap')) : [];

      urlCount = isSitemapIndex ? sitemapEls.length : urlEls.length;

      if (urlCount === 0 && !isSitemapIndex) {
        issues.push({ level: 'error', msg: 'No <url> elements found in the sitemap.' });
      }
      if (urlCount > MAX_URLS) {
        issues.push({ level: 'error', msg: `URL count (${urlCount.toLocaleString()}) exceeds the 50,000 limit. Use a sitemap index file.` });
      }

      const urlEls2 = isSitemapIndex ? sitemapEls : urlEls;
      urlEls2.forEach((urlEl, i) => {
        const locEl = urlEl.querySelector('loc') || urlEl.getElementsByTagNameNS('*', 'loc')[0];
        const loc = locEl ? locEl.textContent.trim() : '';

        if (!loc) {
          issues.push({ level: 'error', msg: `URL #${i+1}: Missing <loc> element.` });
          return;
        }
        if (!loc.startsWith('http://') && !loc.startsWith('https://')) {
          issues.push({ level: 'error', msg: `URL #${i+1}: Non-absolute URL "${loc.substring(0,60)}". Must start with http:// or https://.` });
        }
        if (raw.includes('&amp;') === false && loc.includes('&')) {
          issues.push({ level: 'error', msg: `URL #${i+1}: Unescaped "&" in URL. Use "&amp;" in XML.` });
        }

        const lastmodEl = urlEl.querySelector('lastmod') || urlEl.getElementsByTagNameNS('*', 'lastmod')[0];
        if (lastmodEl) {
          const lm = lastmodEl.textContent.trim();
          if (!/^\d{4}-\d{2}-\d{2}/.test(lm)) {
            issues.push({ level: 'warning', msg: `URL #${i+1}: lastmod "${lm}" may not be valid ISO 8601 format (expected YYYY-MM-DD).` });
          }
        }

        const priorityEl = urlEl.querySelector('priority') || urlEl.getElementsByTagNameNS('*', 'priority')[0];
        if (priorityEl) {
          const p = parseFloat(priorityEl.textContent);
          if (isNaN(p) || p < 0 || p > 1) {
            issues.push({ level: 'warning', msg: `URL #${i+1}: priority "${priorityEl.textContent}" is invalid. Must be 0.0–1.0.` });
          }
        }

        const changefreqEl = urlEl.querySelector('changefreq') || urlEl.getElementsByTagNameNS('*', 'changefreq')[0];
        const validFreqs = ['always','hourly','daily','weekly','monthly','yearly','never'];
        if (changefreqEl && !validFreqs.includes(changefreqEl.textContent.trim())) {
          issues.push({ level: 'warning', msg: `URL #${i+1}: changefreq "${changefreqEl.textContent}" is not a valid value.` });
        }

        if (i < 20) urls.push(loc);
      });
    }

    const errors = issues.filter(i => i.level === 'error');
    const warns = issues.filter(i => i.level === 'warning');

    // Overall status
    const banner = document.getElementById('status-banner');
    const icon = document.getElementById('status-icon');
    const title = document.getElementById('status-title');
    const desc = document.getElementById('status-desc');

    if (errors.length === 0) {
      banner.className = 'rounded-xl border border-green-500/30 bg-green-500/10 p-4 flex items-start gap-3';
      icon.textContent = '✓';
      icon.className = 'text-2xl mt-0.5 text-green-500';
      title.textContent = warns.length > 0 ? 'Valid with warnings' : 'Valid sitemap.xml';
      desc.textContent = `${urlCount.toLocaleString()} URL${urlCount !== 1 ? 's' : ''} found. ${warns.length > 0 ? warns.length + ' warning(s) to review.' : 'No issues detected.'}`;
    } else {
      banner.className = 'rounded-xl border border-red-500/30 bg-red-500/10 p-4 flex items-start gap-3';
      icon.textContent = '✗';
      icon.className = 'text-2xl mt-0.5 text-red-500';
      title.textContent = `${errors.length} error${errors.length !== 1 ? 's' : ''} found`;
      desc.textContent = `Fix the errors below to ensure Google can read your sitemap. ${warns.length} warning${warns.length !== 1 ? 's' : ''} also found.`;
    }

    // Stats
    document.getElementById('stats-grid').innerHTML =
      stat('URLs Found', urlCount.toLocaleString(), urlCount > MAX_URLS ? 'text-red-500' : 'text-text') +
      stat('Errors', errors.length, errors.length > 0 ? 'text-red-500' : 'text-green-500') +
      stat('Warnings', warns.length, warns.length > 0 ? 'text-yellow-500' : 'text-text') +
      stat('Limit', '50,000', 'text-text-muted');

    // Issues
    const issuesSection = document.getElementById('issues-section');
    const issuesList = document.getElementById('issues-list');
    if (issues.length > 0) {
      issuesList.innerHTML = issues.map(i =>
        `<li class="flex gap-2 text-sm">
          <span class="${i.level === 'error' ? 'text-red-500' : 'text-yellow-500'} shrink-0 mt-0.5">${i.level === 'error' ? '✗' : '⚠'}</span>
          <span>${i.msg}</span>
        </li>`
      ).join('');
      issuesSection.classList.remove('hidden');
    } else {
      issuesSection.classList.add('hidden');
    }

    // URL preview
    document.getElementById('url-count-label').textContent = urlCount > 20 ? `(showing first 20 of ${urlCount.toLocaleString()})` : `(${urlCount} total)`;
    document.getElementById('url-list').innerHTML = urls.map(u =>
      `<div class="text-xs font-mono text-text-muted truncate hover:text-text transition-colors" title="${u}">${u}</div>`
    ).join('') || '<div class="text-sm text-text-muted">No URLs to display.</div>';

    document.getElementById('results').classList.remove('hidden');
  }

  const EXAMPLE = `<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://example.com/</loc>
    <lastmod>2024-03-15</lastmod>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://example.com/about</loc>
    <lastmod>2024-02-20</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
  <url>
    <loc>https://example.com/blog/post-1</loc>
    <lastmod>2024-03-10</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.6</priority>
  </url>
</urlset>`;

  document.getElementById('validate-btn').addEventListener('click', validate);
  document.getElementById('load-example-btn').addEventListener('click', () => {
    document.getElementById('sitemap-input').value = EXAMPLE;
  });
</script>

<FaqSection faq={faq} />
<ToolPageCta currentTool="Sitemap.xml Validator" relatedTags={['seo', 'sitemap', 'xml', 'crawling', 'indexing', 'developer-tools']} />
