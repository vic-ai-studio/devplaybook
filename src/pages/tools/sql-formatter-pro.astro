---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "Why should I format my SQL queries?",
    answer: "Formatted SQL is dramatically easier to read, debug, and maintain. Consistent indentation, keyword casing, and line breaks let you instantly identify clauses, spot logical errors, and understand query structure — especially in complex multi-join or subquery scenarios. Most teams enforce a SQL style guide for exactly this reason."
  },
  {
    question: "Does SQL formatting affect query performance?",
    answer: "No. Whitespace and casing are stripped by the SQL parser before execution. A minified single-line query and a beautifully formatted multi-line query are identical from the database engine's perspective. Formatting is purely for human readability."
  },
  {
    question: "What is the difference between leading and trailing comma style?",
    answer: "Trailing commas (the default in most editors) place the comma at the end of each line: 'col1,' then 'col2'. Leading commas place the comma at the start of the next line: 'col1' then ',col2'. Leading commas make it easier to see missing commas (they're always at the left margin) and simpler to add/remove the last column."
  },
  {
    question: "Does dialect selection change the formatting?",
    answer: "Currently dialect selection is informational and helps with keyword highlighting — the core formatting (indentation, line breaks, keyword casing) is standard SQL compatible with all major databases. Dialect-specific syntax like MySQL backtick identifiers or PostgreSQL dollar-quoting is preserved as-is."
  },
  {
    question: "What does Minify SQL do?",
    answer: "Minify collapses a formatted SQL query into a single line by removing all extra whitespace, newlines, and comments. This is useful when embedding SQL in code strings, configuration files, or API requests where you want the most compact representation."
  },
  {
    question: "Are there SQL keywords this formatter doesn't handle?",
    answer: "The formatter handles all common DML (SELECT, INSERT, UPDATE, DELETE), DDL (CREATE, ALTER, DROP), and TCL (COMMIT, ROLLBACK) keywords. Complex dialect-specific syntax like stored procedures, PL/pgSQL blocks, or T-SQL control flow may not be formatted perfectly — always review output before use in production."
  }
];
---

<BaseLayout
  title="SQL Formatter Pro — Beautify & Format SQL Queries Online"
  description="Free SQL formatter and beautifier. Format SELECT, INSERT, CREATE TABLE, and subqueries with proper indentation. Supports MySQL, PostgreSQL, SQLite, MSSQL, Oracle. Minify SQL too. Runs in your browser."
  tool="SQL Formatter, SQL Beautifier, SQL Pretty Printer, Format SQL Online, SQL Minifier, MySQL Formatter, PostgreSQL Formatter, SQL Indenter"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "SQL Formatter Pro",
    "url": "https://devplaybook.cc/tools/sql-formatter-pro",
    "description": "Format and beautify SQL queries with proper keyword casing, indentation, and clause alignment. Supports multiple SQL dialects.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">SQL Formatter Pro</h1>
  <p class="text-text-muted mb-4">Paste any SQL query to instantly format it with proper keyword casing, indentation, and clause alignment. Toggle between leading and trailing comma styles, minify, and copy — all in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Uppercase SQL keywords automatically</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Smart JOIN & WHERE indentation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Leading or trailing comma style</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Minify to single line</span>
  </div>

  <!-- Controls row -->
  <div class="flex flex-wrap items-center gap-3 mb-4">
    <div class="flex items-center gap-2">
      <label class="text-sm font-medium text-text-muted">Dialect:</label>
      <select id="sql-dialect" class="bg-bg-card border border-border rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:border-primary">
        <option value="generic">Generic SQL</option>
        <option value="mysql">MySQL</option>
        <option value="postgresql">PostgreSQL</option>
        <option value="sqlite">SQLite</option>
        <option value="mssql">MSSQL / SQL Server</option>
        <option value="oracle">Oracle</option>
      </select>
    </div>
    <div class="flex items-center gap-2">
      <label class="text-sm font-medium text-text-muted">Comma style:</label>
      <select id="comma-style" class="bg-bg-card border border-border rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:border-primary">
        <option value="trailing">Trailing (col1,)</option>
        <option value="leading">Leading (,col2)</option>
      </select>
    </div>
    <div class="flex items-center gap-2">
      <label class="flex items-center gap-2 text-sm font-medium text-text-muted cursor-pointer select-none">
        <input type="checkbox" id="minify-toggle" class="w-4 h-4 accent-primary" />
        Minify
      </label>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <!-- Input panel -->
    <div class="flex flex-col gap-2">
      <div class="flex items-center justify-between">
        <label class="block text-sm font-medium">SQL Input</label>
        <div class="flex gap-2">
          <button id="btn-clear" class="px-3 py-1.5 bg-bg-card border border-border rounded-lg text-xs hover:border-primary transition-colors">Clear</button>
          <div class="relative">
            <button id="btn-examples" class="px-3 py-1.5 bg-bg-card border border-border rounded-lg text-xs hover:border-primary transition-colors">Examples ▾</button>
            <div id="examples-menu" class="hidden absolute right-0 top-full mt-1 bg-bg-card border border-border rounded-lg shadow-lg z-10 min-w-[180px]">
              <button class="example-btn w-full text-left px-3 py-2 text-xs hover:bg-border/30 transition-colors" data-example="select">SELECT with JOINs</button>
              <button class="example-btn w-full text-left px-3 py-2 text-xs hover:bg-border/30 transition-colors" data-example="insert">INSERT statement</button>
              <button class="example-btn w-full text-left px-3 py-2 text-xs hover:bg-border/30 transition-colors" data-example="create">CREATE TABLE</button>
              <button class="example-btn w-full text-left px-3 py-2 text-xs hover:bg-border/30 transition-colors" data-example="subquery">Subquery</button>
              <button class="example-btn w-full text-left px-3 py-2 text-xs hover:bg-border/30 transition-colors" data-example="update">UPDATE with WHERE</button>
            </div>
          </div>
        </div>
      </div>
      <textarea
        id="sql-input"
        class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary resize-none flex-1"
        rows="20"
        placeholder="Paste your SQL query here and click Format..."
        spellcheck="false"
      ></textarea>
      <div class="flex items-center justify-between text-xs text-text-muted">
        <span id="input-stats">0 chars · 0 lines</span>
        <button id="btn-format" class="px-4 py-2 bg-primary text-white rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors">Format SQL →</button>
      </div>
    </div>

    <!-- Output panel -->
    <div class="flex flex-col gap-2">
      <div class="flex items-center justify-between">
        <label class="block text-sm font-medium">Formatted Output</label>
        <div class="flex gap-2">
          <button id="btn-copy" class="px-3 py-1.5 bg-bg-card border border-border rounded-lg text-xs hover:border-primary transition-colors">Copy</button>
          <button id="btn-use-as-input" class="px-3 py-1.5 bg-bg-card border border-border rounded-lg text-xs hover:border-primary transition-colors" title="Send output back to input">↺ Use as input</button>
        </div>
      </div>
      <div id="sql-output-wrap" class="relative flex-1">
        <pre
          id="sql-output"
          class="w-full h-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono overflow-auto min-h-[420px] whitespace-pre-wrap break-all leading-relaxed"
          style="min-height: 420px;"
        ><span class="text-text-muted">Formatted SQL will appear here...</span></pre>
      </div>
      <div class="flex items-center justify-between text-xs text-text-muted">
        <span id="output-stats">—</span>
        <span id="dialect-badge" class="px-2 py-0.5 bg-bg-card border border-border rounded text-xs">Generic SQL</span>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SQL Formatter Pro" relatedTags={['sql', 'database', 'mysql', 'postgresql', 'sqlite', 'query']} />
</BaseLayout>

<script>
// ─── SQL Keywords ─────────────────────────────────────────────────────────────

const KEYWORDS_MAIN = [
  'SELECT', 'FROM', 'WHERE', 'JOIN', 'INNER JOIN', 'LEFT JOIN', 'RIGHT JOIN',
  'FULL JOIN', 'FULL OUTER JOIN', 'LEFT OUTER JOIN', 'RIGHT OUTER JOIN',
  'CROSS JOIN', 'ON', 'GROUP BY', 'ORDER BY', 'HAVING', 'LIMIT', 'OFFSET',
  'UNION', 'UNION ALL', 'INTERSECT', 'EXCEPT',
  'INSERT INTO', 'INSERT', 'VALUES', 'UPDATE', 'SET', 'DELETE FROM', 'DELETE',
  'CREATE TABLE', 'CREATE INDEX', 'CREATE VIEW', 'CREATE', 'ALTER TABLE',
  'ALTER', 'DROP TABLE', 'DROP INDEX', 'DROP VIEW', 'DROP',
  'TRUNCATE', 'WITH', 'AS', 'DISTINCT', 'TOP', 'INTO',
];

const KEYWORDS_INLINE = [
  'AND', 'OR', 'NOT', 'IN', 'NOT IN', 'EXISTS', 'NOT EXISTS', 'BETWEEN',
  'LIKE', 'ILIKE', 'IS NULL', 'IS NOT NULL', 'IS', 'NULL', 'TRUE', 'FALSE',
  'CASE', 'WHEN', 'THEN', 'ELSE', 'END', 'CAST', 'AS', 'COALESCE',
  'NULLIF', 'IF', 'IIF', 'COUNT', 'SUM', 'AVG', 'MIN', 'MAX',
  'PRIMARY KEY', 'FOREIGN KEY', 'REFERENCES', 'UNIQUE', 'NOT NULL',
  'DEFAULT', 'AUTO_INCREMENT', 'AUTOINCREMENT', 'SERIAL', 'CONSTRAINT',
  'INDEX', 'CHECK', 'COMMENT', 'COLLATE', 'CHARACTER SET', 'CHARSET',
  'ASC', 'DESC', 'LIMIT', 'OFFSET', 'RETURNING', 'OUTPUT',
  'BEGIN', 'COMMIT', 'ROLLBACK', 'TRANSACTION', 'SAVEPOINT',
  'GRANT', 'REVOKE', 'EXPLAIN', 'ANALYZE',
];

// These trigger a new line + indent in the formatter
const CLAUSE_BREAK_KEYWORDS = new Set([
  'SELECT', 'FROM', 'WHERE', 'JOIN', 'INNER JOIN', 'LEFT JOIN', 'RIGHT JOIN',
  'FULL JOIN', 'FULL OUTER JOIN', 'LEFT OUTER JOIN', 'RIGHT OUTER JOIN',
  'CROSS JOIN', 'GROUP BY', 'ORDER BY', 'HAVING', 'LIMIT', 'OFFSET',
  'UNION', 'UNION ALL', 'INTERSECT', 'EXCEPT', 'ON',
  'SET', 'VALUES',
]);

const SUBCLAUSE_KEYWORDS = new Set([
  'AND', 'OR',
]);

// ─── Tokenizer ────────────────────────────────────────────────────────────────

type Token = { type: 'keyword' | 'string' | 'comment' | 'whitespace' | 'other'; value: string };

function tokenize(sql: string): Token[] {
  const tokens: Token[] = [];
  let i = 0;
  const upper = sql.toUpperCase();

  while (i < sql.length) {
    // Line comment
    if (sql[i] === '-' && sql[i + 1] === '-') {
      let end = sql.indexOf('\n', i);
      if (end === -1) end = sql.length;
      tokens.push({ type: 'comment', value: sql.slice(i, end) });
      i = end;
      continue;
    }
    // Block comment
    if (sql[i] === '/' && sql[i + 1] === '*') {
      const end = sql.indexOf('*/', i + 2);
      const endIdx = end === -1 ? sql.length : end + 2;
      tokens.push({ type: 'comment', value: sql.slice(i, endIdx) });
      i = endIdx;
      continue;
    }
    // String literal single quote
    if (sql[i] === "'") {
      let j = i + 1;
      while (j < sql.length) {
        if (sql[j] === "'" && sql[j + 1] === "'") { j += 2; continue; }
        if (sql[j] === "'") { j++; break; }
        j++;
      }
      tokens.push({ type: 'string', value: sql.slice(i, j) });
      i = j;
      continue;
    }
    // String literal double quote (identifiers in MySQL / standard strings in PostgreSQL)
    if (sql[i] === '"') {
      let j = i + 1;
      while (j < sql.length && sql[j] !== '"') j++;
      tokens.push({ type: 'string', value: sql.slice(i, j + 1) });
      i = j + 1;
      continue;
    }
    // Backtick identifiers (MySQL)
    if (sql[i] === '`') {
      let j = i + 1;
      while (j < sql.length && sql[j] !== '`') j++;
      tokens.push({ type: 'string', value: sql.slice(i, j + 1) });
      i = j + 1;
      continue;
    }
    // Whitespace
    if (/\s/.test(sql[i])) {
      let j = i;
      while (j < sql.length && /\s/.test(sql[j])) j++;
      tokens.push({ type: 'whitespace', value: sql.slice(i, j) });
      i = j;
      continue;
    }
    // Try multi-word keyword match (longest first)
    const allKw = [...KEYWORDS_MAIN, ...KEYWORDS_INLINE].sort((a, b) => b.length - a.length);
    let matched = false;
    for (const kw of allKw) {
      if (upper.startsWith(kw, i)) {
        const after = sql[i + kw.length];
        if (!after || /[\s,();*]/.test(after)) {
          tokens.push({ type: 'keyword', value: kw });
          i += kw.length;
          matched = true;
          break;
        }
      }
    }
    if (!matched) {
      tokens.push({ type: 'other', value: sql[i] });
      i++;
    }
  }

  return tokens;
}

// ─── Formatter ────────────────────────────────────────────────────────────────

function formatSQL(sql: string, commaStyle: 'trailing' | 'leading'): string {
  // Collapse all whitespace to single spaces first
  const normalized = sql.replace(/\s+/g, ' ').trim();
  const tokens = tokenize(normalized);

  const indent = '  '; // 2 spaces
  let result = '';
  let currentIndent = 0;
  let inSelect = false;
  let lineStart = true;

  // We'll build a flat token list with the whitespace stripped, then format
  const meaningful = tokens.filter(t => t.type !== 'whitespace');

  for (let i = 0; i < meaningful.length; i++) {
    const tok = meaningful[i];
    const kw = tok.value.toUpperCase();
    const prevTok = i > 0 ? meaningful[i - 1] : null;
    const nextTok = i < meaningful.length - 1 ? meaningful[i + 1] : null;

    if (tok.type === 'keyword' && CLAUSE_BREAK_KEYWORDS.has(kw)) {
      if (result.length > 0 && !result.endsWith('\n')) result += '\n';
      result += indent.repeat(currentIndent);
      result += kw;
      inSelect = kw === 'SELECT';
      // After FROM, JOIN etc. we indent contents one level if a subquery follows
      if (nextTok?.value === '(') {
        currentIndent++;
      }
      lineStart = false;
      // Add a space after clause keyword
      if (nextTok && nextTok.value !== '(' && nextTok.value !== ';') result += ' ';
      continue;
    }

    if (tok.type === 'keyword' && SUBCLAUSE_KEYWORDS.has(kw)) {
      result += '\n' + indent.repeat(currentIndent + 1) + kw + ' ';
      lineStart = false;
      continue;
    }

    if (tok.value === '(') {
      result += '(';
      // Check if this starts a subquery
      const isSubquery = nextTok?.type === 'keyword' && nextTok.value.toUpperCase() === 'SELECT';
      if (isSubquery) {
        currentIndent++;
        result += '\n';
        lineStart = true;
      }
      continue;
    }

    if (tok.value === ')') {
      // Check if we need to dedent
      if (currentIndent > 0) {
        const peek = result.trimEnd();
        if (result.endsWith('\n') || result.endsWith(' ')) {
          result = result.trimEnd() + '\n' + indent.repeat(currentIndent - 1);
          currentIndent--;
        }
      }
      result += ')';
      lineStart = false;
      continue;
    }

    if (tok.value === ',') {
      if (inSelect) {
        if (commaStyle === 'trailing') {
          result += ',\n' + indent.repeat(currentIndent + 1);
        } else {
          result += '\n' + indent.repeat(currentIndent + 1) + ',';
        }
        lineStart = false;
        continue;
      }
      result += ', ';
      continue;
    }

    if (tok.value === ';') {
      result += ';\n';
      currentIndent = 0;
      inSelect = false;
      lineStart = true;
      continue;
    }

    if (lineStart) {
      result += indent.repeat(currentIndent);
      lineStart = false;
    }

    if (tok.type === 'keyword') {
      result += kw;
    } else {
      result += tok.value;
    }

    if (tok.type !== 'other' || /[a-zA-Z0-9_"'`]/.test(tok.value)) {
      if (nextTok && nextTok.value !== ',' && nextTok.value !== ')' && nextTok.value !== '(' && nextTok.value !== ';' && nextTok.value !== '.') {
        if (tok.value !== '(' && tok.value !== '.') result += ' ';
      }
    }
  }

  // Clean up: collapse multiple blank lines, trim trailing spaces per line
  return result
    .split('\n')
    .map(line => line.trimEnd())
    .join('\n')
    .replace(/\n{3,}/g, '\n\n')
    .trim();
}

function minifySQL(sql: string): string {
  // Remove comments, collapse whitespace
  return sql
    .replace(/--[^\n]*/g, ' ')
    .replace(/\/\*[\s\S]*?\*\//g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

// ─── Syntax highlighting (HTML output) ───────────────────────────────────────

const KW_COLOR_MAP: Record<string, string> = {
  'SELECT': '#60a5fa',  // blue
  'FROM': '#60a5fa',
  'WHERE': '#60a5fa',
  'JOIN': '#a78bfa',    // purple
  'INNER JOIN': '#a78bfa',
  'LEFT JOIN': '#a78bfa',
  'RIGHT JOIN': '#a78bfa',
  'FULL JOIN': '#a78bfa',
  'FULL OUTER JOIN': '#a78bfa',
  'LEFT OUTER JOIN': '#a78bfa',
  'RIGHT OUTER JOIN': '#a78bfa',
  'CROSS JOIN': '#a78bfa',
  'ON': '#a78bfa',
  'GROUP BY': '#60a5fa',
  'ORDER BY': '#60a5fa',
  'HAVING': '#60a5fa',
  'LIMIT': '#60a5fa',
  'OFFSET': '#60a5fa',
  'UNION': '#60a5fa',
  'UNION ALL': '#60a5fa',
  'INTERSECT': '#60a5fa',
  'EXCEPT': '#60a5fa',
  'INSERT': '#34d399',  // green
  'INSERT INTO': '#34d399',
  'VALUES': '#34d399',
  'UPDATE': '#34d399',
  'SET': '#34d399',
  'DELETE': '#f87171',  // red
  'DELETE FROM': '#f87171',
  'CREATE': '#fbbf24',  // yellow
  'CREATE TABLE': '#fbbf24',
  'CREATE INDEX': '#fbbf24',
  'CREATE VIEW': '#fbbf24',
  'ALTER': '#fbbf24',
  'ALTER TABLE': '#fbbf24',
  'DROP': '#f87171',
  'DROP TABLE': '#f87171',
  'TRUNCATE': '#f87171',
  'AND': '#94a3b8',
  'OR': '#94a3b8',
  'NOT': '#94a3b8',
  'IN': '#94a3b8',
  'NOT IN': '#94a3b8',
  'LIKE': '#94a3b8',
  'IS': '#94a3b8',
  'NULL': '#fb923c',
  'TRUE': '#fb923c',
  'FALSE': '#fb923c',
  'AS': '#94a3b8',
  'DISTINCT': '#a78bfa',
  'CASE': '#fbbf24',
  'WHEN': '#fbbf24',
  'THEN': '#fbbf24',
  'ELSE': '#fbbf24',
  'END': '#fbbf24',
  'WITH': '#60a5fa',
  'PRIMARY KEY': '#a78bfa',
  'FOREIGN KEY': '#a78bfa',
  'REFERENCES': '#a78bfa',
  'UNIQUE': '#a78bfa',
  'NOT NULL': '#94a3b8',
  'DEFAULT': '#94a3b8',
  'CONSTRAINT': '#a78bfa',
  'COUNT': '#34d399',
  'SUM': '#34d399',
  'AVG': '#34d399',
  'MIN': '#34d399',
  'MAX': '#34d399',
  'COALESCE': '#34d399',
};

function escapeHtml(s: string): string {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

function highlightSQL(sql: string): string {
  const tokens = tokenize(sql);
  return tokens.map(tok => {
    if (tok.type === 'comment') {
      return `<span style="color:#6b7280;font-style:italic">${escapeHtml(tok.value)}</span>`;
    }
    if (tok.type === 'string') {
      return `<span style="color:#f59e0b">${escapeHtml(tok.value)}</span>`;
    }
    if (tok.type === 'keyword') {
      const color = KW_COLOR_MAP[tok.value.toUpperCase()] || '#94a3b8';
      return `<span style="color:${color};font-weight:600">${escapeHtml(tok.value.toUpperCase())}</span>`;
    }
    return escapeHtml(tok.value);
  }).join('');
}

// ─── Example queries ──────────────────────────────────────────────────────────

const EXAMPLES: Record<string, string> = {
  select: `select u.id, u.name, u.email, o.order_id, o.total_amount, p.product_name from users u inner join orders o on u.id = o.user_id left join order_items oi on o.order_id = oi.order_id left join products p on oi.product_id = p.id where u.active = true and o.created_at >= '2024-01-01' and o.total_amount > 100 group by u.id, u.name, u.email, o.order_id, o.total_amount, p.product_name having count(oi.id) > 0 order by o.total_amount desc limit 50 offset 0`,

  insert: `insert into users (id, name, email, role, created_at, is_active) values (uuid_generate_v4(), 'Jane Doe', 'jane@example.com', 'admin', now(), true)`,

  create: `create table orders (id serial primary key, user_id integer not null references users(id) on delete cascade, total_amount decimal(10,2) not null default 0.00, status varchar(50) not null default 'pending', created_at timestamp not null default current_timestamp, updated_at timestamp, constraint orders_status_check check (status in ('pending','processing','shipped','delivered','cancelled')))`,

  subquery: `select department, avg_salary from (select d.name as department, avg(e.salary) as avg_salary, count(e.id) as headcount from employees e inner join departments d on e.department_id = d.id where e.active = true group by d.name having count(e.id) >= 3) as dept_stats where avg_salary > (select avg(salary) from employees where active = true) order by avg_salary desc`,

  update: `update products set price = price * 1.05, updated_at = current_timestamp, last_modified_by = 'system' where category_id in (select id from categories where name = 'Electronics') and stock_quantity > 0 and discontinued = false`,
};

// ─── DOM wiring ───────────────────────────────────────────────────────────────

const sqlInput = document.getElementById('sql-input') as HTMLTextAreaElement;
const sqlOutput = document.getElementById('sql-output')!;
const inputStats = document.getElementById('input-stats')!;
const outputStats = document.getElementById('output-stats')!;
const dialectSel = document.getElementById('sql-dialect') as HTMLSelectElement;
const commaSel = document.getElementById('comma-style') as HTMLSelectElement;
const minifyToggle = document.getElementById('minify-toggle') as HTMLInputElement;
const dialectBadge = document.getElementById('dialect-badge')!;
const examplesMenu = document.getElementById('examples-menu')!;

function updateInputStats() {
  const chars = sqlInput.value.length;
  const lines = sqlInput.value ? sqlInput.value.split('\n').length : 0;
  inputStats.textContent = `${chars.toLocaleString()} chars · ${lines} lines`;
}

function updateOutputStats(text: string) {
  const chars = text.length;
  const lines = text.split('\n').length;
  outputStats.textContent = `${chars.toLocaleString()} chars · ${lines} lines`;
}

function doFormat() {
  const raw = sqlInput.value.trim();
  if (!raw) {
    sqlOutput.innerHTML = '<span class="text-text-muted">Formatted SQL will appear here...</span>';
    outputStats.textContent = '—';
    return;
  }

  const commaStyle = commaSel.value as 'trailing' | 'leading';
  const isMinify = minifyToggle.checked;

  let formatted: string;
  if (isMinify) {
    formatted = minifySQL(raw);
  } else {
    try {
      formatted = formatSQL(raw, commaStyle);
    } catch {
      formatted = raw;
    }
  }

  sqlOutput.innerHTML = highlightSQL(formatted);
  updateOutputStats(formatted);
  (sqlOutput as any)._plainText = formatted;
}

sqlInput.addEventListener('input', () => { updateInputStats(); doFormat(); });
dialectSel.addEventListener('change', () => {
  dialectBadge.textContent = dialectSel.options[dialectSel.selectedIndex].text;
  doFormat();
});
commaSel.addEventListener('change', doFormat);
minifyToggle.addEventListener('change', doFormat);

document.getElementById('btn-format')!.addEventListener('click', doFormat);

document.getElementById('btn-clear')!.addEventListener('click', () => {
  sqlInput.value = '';
  updateInputStats();
  sqlOutput.innerHTML = '<span class="text-text-muted">Formatted SQL will appear here...</span>';
  outputStats.textContent = '—';
});

document.getElementById('btn-copy')!.addEventListener('click', () => {
  const text = (sqlOutput as any)._plainText || sqlOutput.textContent || '';
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.getElementById('btn-copy')!;
    const orig = btn.textContent;
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = orig; }, 1500);
  });
});

document.getElementById('btn-use-as-input')!.addEventListener('click', () => {
  const text = (sqlOutput as any)._plainText || sqlOutput.textContent || '';
  if (text && text !== 'Formatted SQL will appear here...') {
    sqlInput.value = text;
    updateInputStats();
    doFormat();
  }
});

// Examples dropdown
document.getElementById('btn-examples')!.addEventListener('click', (e) => {
  e.stopPropagation();
  examplesMenu.classList.toggle('hidden');
});

document.addEventListener('click', () => examplesMenu.classList.add('hidden'));

document.querySelectorAll<HTMLButtonElement>('.example-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const key = btn.dataset.example!;
    sqlInput.value = EXAMPLES[key] || '';
    updateInputStats();
    doFormat();
    examplesMenu.classList.add('hidden');
  });
});

// Initial stats
updateInputStats();
</script>
