---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CorsHeadersChecker from '../../components/CorsHeadersChecker.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What CORS headers should I look for in an API response?",
    answer: "The key headers are: Access-Control-Allow-Origin (which origins can read the response), Access-Control-Allow-Methods (which HTTP methods are permitted), Access-Control-Allow-Headers (which request headers are allowed), Access-Control-Allow-Credentials (whether cookies/auth are permitted), and Access-Control-Max-Age (how long preflight results can be cached). Paste your response headers here and this tool shows what each one means and whether your request would be allowed."
  },
  {
    question: "What does Access-Control-Allow-Origin: * mean?",
    answer: "Wildcard (*) means any origin can read the response. This is appropriate for public APIs (CDN assets, open data APIs) but dangerous for APIs that return user-specific data. Crucially, * cannot be combined with Access-Control-Allow-Credentials: true — the browser will block the request with a CORS error. For credentialed requests, the server must echo back the specific requesting origin."
  },
  {
    question: "Why do I get a CORS error even though the header is present?",
    answer: "Several gotchas: (1) The header value doesn't match your origin exactly — scheme, host, and port must all match. (2) You're using credentials (cookies, Authorization header) with a wildcard origin. (3) The server is only sending CORS headers for OPTIONS preflight, not for the actual request. (4) Your server framework strips headers on error responses. (5) A CDN or proxy is stripping CORS headers before they reach the browser."
  },
  {
    question: "What is an OPTIONS preflight request?",
    answer: "For 'non-simple' cross-origin requests — those using methods other than GET/POST/HEAD, or custom headers like Authorization or Content-Type: application/json — browsers first send an HTTP OPTIONS request to ask the server what it permits. The server must respond with Access-Control-Allow-Methods and Access-Control-Allow-Headers. If the preflight fails or is missing required headers, the actual request is never sent."
  },
  {
    question: "How does Access-Control-Max-Age reduce latency?",
    answer: "Access-Control-Max-Age tells the browser how many seconds to cache the preflight result. Without it (or with a low value), the browser sends an OPTIONS preflight before every cross-origin request. With a high value (e.g., 86400 = 1 day), the browser skips the preflight for subsequent requests to the same endpoint. This eliminates the round-trip latency of the OPTIONS request for repeat callers."
  },
  {
    question: "What does Access-Control-Expose-Headers do?",
    answer: "By default, JavaScript can only read a small set of 'safe' response headers (like Content-Type and Cache-Control). Access-Control-Expose-Headers explicitly whitelists additional headers for JavaScript access. This is commonly needed for pagination (Link header), rate limiting (X-Rate-Limit-Remaining), request tracing (X-Request-Id), and API versioning headers. Without it, response.headers.get('x-request-id') returns null even if the header is present."
  },
];
---

<BaseLayout
  title="CORS Header Analyzer — Decode & Validate CORS Response Headers"
  description="Paste HTTP response headers and instantly see which origins, methods, and headers are allowed. Analyzes Access-Control-Allow-Origin, credentials, preflight settings, and more. Free CORS debugging tool."
  tool="CORS Header Analyzer, CORS Debugger, CORS Headers Checker, Analyze CORS Headers"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "CORS Header Analyzer",
    "url": "https://devplaybook.cc/tools/cors-header-analyzer",
    "description": "Paste HTTP response headers to analyze CORS configuration. Shows allowed origins, methods, headers, credentials policy, and preflight requirements.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">CORS Header Analyzer</h1>
  <p class="text-text-muted mb-4">
    Paste HTTP response headers from any API and instantly decode the CORS policy.
    See which origins and methods are allowed, whether credentials are permitted,
    and what preflight requirements apply — with plain-English explanations for each header.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Decode all CORS headers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Credential + preflight analysis</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <CorsHeadersChecker client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CORS Header Analyzer" relatedTags={['cors', 'http', 'security', 'api', 'developer-tools']} />
</BaseLayout>
