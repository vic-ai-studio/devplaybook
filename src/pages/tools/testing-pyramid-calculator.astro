---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is the testing pyramid?", answer: "The testing pyramid (introduced by Mike Cohn) is a framework for balancing test types by speed, cost, and coverage. Unit tests form the base (many, fast, cheap), integration tests are in the middle (some, moderate speed), and end-to-end (E2E) tests sit at the top (few, slow, expensive). The shape represents the recommended count ratio." },
  { question: "What are the ideal ratios for the testing pyramid?", answer: "A common starting point is 70% unit / 20% integration / 10% E2E. Kent Beck's original guidance was roughly 10:1 unit-to-integration. The ideal ratios depend on your architecture — microservices need more integration tests, UI-heavy apps need more E2E tests. Use this as a direction, not a rigid rule." },
  { question: "Why does the pyramid matter?", answer: "E2E tests are 10-100x slower than unit tests and much more brittle (flaky). Over-investing in E2E tests slows CI, wastes budget, and creates a frustrating development experience. The pyramid pushes teams toward fast, reliable unit tests as the foundation, using E2E tests only for critical user journeys." },
  { question: "What is an 'ice cream cone' anti-pattern?", answer: "An ice cream cone (inverted pyramid) has too many E2E tests and too few unit tests. This leads to slow CI (20+ minute pipelines), high flakiness rates, expensive maintenance, and poor coverage of edge cases. If your ratio is inverted, prioritize writing unit tests before adding more E2E tests." },
  { question: "What is the testing trophy?", answer: "The Testing Trophy (by Kent C. Dodds) de-emphasizes unit tests in favor of integration tests, arguing that integration tests give higher confidence per test. It has: Static (linting/types) → Unit → Integration (center, biggest) → E2E. This is popular in React testing with Testing Library." },
];
---

<BaseLayout
  title="Testing Pyramid Calculator — Calculate Unit/Integration/E2E Test Ratios"
  description="Free testing pyramid calculator for engineering teams. Enter your test counts, see your current pyramid shape, compare to recommended ratios, and get actionable advice for rebalancing your test suite."
  tool="testing pyramid calculator, unit integration e2e ratio, test suite balance, testing strategy calculator, test coverage ratio"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Testing Pyramid Calculator",
    "url": "https://devplaybook.cc/tools/testing-pyramid-calculator",
    "description": "Calculate and visualize your testing pyramid ratios. Enter test counts for unit, integration, and E2E tests to see recommendations.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Testing Pyramid Calculator</h1>
  <p class="text-text-muted mb-4">Enter your current test counts for unit, integration, and E2E tests. See your pyramid shape, compare to recommended ratios, and get advice on rebalancing your test suite.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Visual pyramid diagram</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Ratio vs recommendation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Health score & advice</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multiple target strategies</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Inputs -->
    <div class="bg-bg-card border border-border rounded-xl p-5 flex flex-col gap-5">
      <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Your Test Suite</h2>

      <div>
        <label class="block text-sm font-medium mb-1" for="unit-count">Unit Tests</label>
        <input id="unit-count" type="number" value="450" min="0" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
        <p class="text-xs text-text-muted mt-1">Fast, isolated tests for functions, classes, and modules</p>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" for="integration-count">Integration Tests</label>
        <input id="integration-count" type="number" value="80" min="0" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
        <p class="text-xs text-text-muted mt-1">Tests that verify component interaction, DB, or API calls</p>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" for="e2e-count">End-to-End Tests (E2E)</label>
        <input id="e2e-count" type="number" value="30" min="0" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
        <p class="text-xs text-text-muted mt-1">Browser/UI tests that simulate full user journeys</p>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" for="strategy">Target Strategy</label>
        <select id="strategy" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors">
          <option value="classic">Classic Pyramid (70/20/10)</option>
          <option value="trophy">Testing Trophy (40/40/20 integration-heavy)</option>
          <option value="aggressive">Aggressive Unit (80/15/5)</option>
          <option value="balanced">Balanced (60/30/10)</option>
        </select>
      </div>

      <button id="calculate-btn" class="w-full bg-accent hover:bg-accent/90 text-white font-semibold px-4 py-2.5 rounded-lg transition-colors text-sm">
        Calculate
      </button>
    </div>

    <!-- Results -->
    <div class="flex flex-col gap-4">
      <!-- Pyramid Visual -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted mb-4">Your Pyramid</h2>
        <div id="pyramid-visual" class="flex flex-col items-center gap-1 mb-4"></div>
        <div id="health-badge" class="text-center"></div>
      </div>

      <!-- Stats -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted mb-3">Ratio Analysis</h2>
        <div id="ratio-grid" class="grid grid-cols-3 gap-3 mb-4"></div>
        <div id="advice" class="text-sm text-text-muted bg-bg border border-border rounded-lg p-3"></div>
      </div>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Testing Pyramid Calculator" relatedTags={['testing', 'developer-tools', 'engineering', 'ci-cd', 'quality']} />
</BaseLayout>

<script>
const strategies: Record<string, { unit: number; integration: number; e2e: number; name: string }> = {
  classic: { unit: 70, integration: 20, e2e: 10, name: 'Classic Pyramid' },
  trophy: { unit: 25, integration: 50, e2e: 25, name: 'Testing Trophy' },
  aggressive: { unit: 80, integration: 15, e2e: 5, name: 'Aggressive Unit' },
  balanced: { unit: 60, integration: 30, e2e: 10, name: 'Balanced' },
};

function calculate() {
  const unit = Math.max(0, parseInt((document.getElementById('unit-count') as HTMLInputElement).value) || 0);
  const integration = Math.max(0, parseInt((document.getElementById('integration-count') as HTMLInputElement).value) || 0);
  const e2e = Math.max(0, parseInt((document.getElementById('e2e-count') as HTMLInputElement).value) || 0);
  const total = unit + integration + e2e;
  const strategy = (document.getElementById('strategy') as HTMLSelectElement).value;
  const target = strategies[strategy];

  if (total === 0) return;

  const unitPct = Math.round((unit / total) * 100);
  const intPct = Math.round((integration / total) * 100);
  const e2ePct = 100 - unitPct - intPct;

  // Pyramid visual
  const maxWidth = 300;
  const pyramid = document.getElementById('pyramid-visual')!;
  pyramid.innerHTML = [
    { label: 'E2E', count: e2e, pct: e2ePct, color: 'bg-red-500/70', targetPct: target.e2e },
    { label: 'Integration', count: integration, pct: intPct, color: 'bg-yellow-500/70', targetPct: target.integration },
    { label: 'Unit', count: unit, pct: unitPct, color: 'bg-green-500/70', targetPct: target.unit },
  ].map(({ label, count, pct, color }, i) => {
    const width = Math.max(40, Math.round((pct / 100) * maxWidth));
    const widthClass = i === 0 ? 'w-1/3' : i === 1 ? 'w-2/3' : 'w-full';
    return `
      <div class="w-full flex flex-col items-center">
        <div class="${widthClass} ${color} rounded flex items-center justify-center py-2 text-white text-xs font-semibold min-h-10">
          ${label}: ${pct}% (${count})
        </div>
      </div>
    `;
  }).join('');

  // Health score
  const unitDiff = Math.abs(unitPct - target.unit);
  const intDiff = Math.abs(intPct - target.integration);
  const e2eDiff = Math.abs(e2ePct - target.e2e);
  const totalDiff = unitDiff + intDiff + e2eDiff;
  const score = Math.max(0, 100 - totalDiff * 2);

  const scoreColor = score >= 80 ? 'text-green-400' : score >= 60 ? 'text-yellow-400' : 'text-red-400';
  const scoreLabel = score >= 80 ? 'Healthy Pyramid ✅' : score >= 60 ? 'Needs Adjustment ⚠️' : 'Inverted / Ice Cream Cone 🍦';

  document.getElementById('health-badge')!.innerHTML = `
    <div class="text-5xl font-bold ${scoreColor}">${score}</div>
    <div class="text-sm text-text-muted mt-1">${scoreLabel}</div>
    <div class="text-xs text-text-muted mt-1">vs. ${target.name} target</div>
  `;

  // Ratio grid
  document.getElementById('ratio-grid')!.innerHTML = [
    { label: 'Unit', actual: unitPct, target: target.unit, color: 'text-green-400' },
    { label: 'Integration', actual: intPct, target: target.integration, color: 'text-yellow-400' },
    { label: 'E2E', actual: e2ePct, target: target.e2e, color: 'text-red-400' },
  ].map(({ label, actual, target: t, color }) => {
    const diff = actual - t;
    const diffStr = diff >= 0 ? `+${diff}%` : `${diff}%`;
    const diffColor = Math.abs(diff) <= 5 ? 'text-green-400' : Math.abs(diff) <= 15 ? 'text-yellow-400' : 'text-red-400';
    return `
      <div class="bg-bg border border-border rounded-lg p-3 text-center">
        <div class="text-xs text-text-muted mb-1">${label}</div>
        <div class="text-xl font-bold ${color}">${actual}%</div>
        <div class="text-xs ${diffColor} mt-1">Target: ${t}% (${diffStr})</div>
      </div>
    `;
  }).join('');

  // Advice
  let advice = '';
  if (e2ePct > target.e2e + 15) advice += `⚠️ Too many E2E tests (${e2ePct}% vs ${target.e2e}% target). Slow CI and high flakiness risk. Convert some E2E tests to integration or unit tests. `;
  if (unitPct < target.unit - 15) advice += `⚠️ Too few unit tests (${unitPct}% vs ${target.unit}% target). Increase unit test coverage for better speed and reliability. `;
  if (intPct > target.integration + 20) advice += `ℹ️ High integration test ratio. Ensure they're not duplicating unit test logic. `;
  if (score >= 80) advice = `✅ Your test suite distribution is well-balanced for the ${target.name} strategy. Total tests: ${total.toLocaleString()}.`;
  if (!advice) advice = `ℹ️ Minor adjustments needed. Focus on the categories highlighted above. Total tests: ${total.toLocaleString()}.`;

  document.getElementById('advice')!.textContent = advice;
}

['unit-count', 'integration-count', 'e2e-count', 'strategy'].forEach(id => {
  document.getElementById(id)!.addEventListener('input', calculate);
  document.getElementById(id)!.addEventListener('change', calculate);
});
document.getElementById('calculate-btn')!.addEventListener('click', calculate);
calculate();
</script>
