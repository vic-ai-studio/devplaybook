---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is KoboldCpp?", answer: "KoboldCpp is a local LLM inference tool built on llama.cpp and specifically optimized for creative writing, roleplay, and interactive fiction. It exposes the KoboldAI API (used by SillyTavern and other frontends) alongside an OpenAI-compatible API, supports special memory and world info features for long-form writing, and runs as a single portable executable — no installation required." },
  { question: "What makes KoboldCpp better for creative writing than Ollama?", answer: "KoboldCpp includes features specifically for creative writing: (1) Author's Note — inject context at any position in the prompt to guide the narrative; (2) World Info — a knowledge base that auto-injects relevant context when trigger keywords appear; (3) Memory — a persistent block of text always included in the context; (4) Story mode with proper novel formatting; (5) Configurable sampler ordering (Typical P, Mirostat, etc.) that gives more natural, creative text." },
  { question: "How do I use KoboldCpp with SillyTavern?", answer: "SillyTavern is the most popular character roleplay frontend that connects to KoboldCpp. Start KoboldCpp with your model, note the URL and port (default: http://localhost:5001). In SillyTavern, go to API Connections > KoboldAI and enter the URL. SillyTavern handles character cards, persona management, and chat UI while KoboldCpp handles inference. This is the most feature-rich local AI roleplay setup available." },
  { question: "What GGUF models work best with KoboldCpp for creative writing?", answer: "Models fine-tuned for roleplay and creative writing perform significantly better than base instruct models. Top choices in 2026: MythoMax 13B (general creative writing), Noromaid 20B (character roleplay), Airoboros 70B (story generation, requires 48+ GB RAM), Fimbulvetr 11B (balanced creative/instruct). Look for models tagged 'roleplay', 'creative writing', or 'storytelling' on HuggingFace." },
  { question: "What is World Info in KoboldCpp?", answer: "World Info is a dynamic context injection system. You define entries with a title, content, and trigger keywords. When a trigger keyword appears in the recent conversation history, that World Info entry is automatically injected into the model's context. This lets you define characters, locations, lore, and rules that the model references without you manually repeating them. Essential for long-running stories and complex roleplay scenarios." },
  { question: "KoboldCpp vs text-generation-webui for creative writing?", answer: "Both support GGUF models via llama.cpp. KoboldCpp wins for creative writing because of its native World Info, Memory, Author's Note features and its KoboldAI API compatibility (required by SillyTavern and KoboldAI Lite). text-generation-webui has more model format options (GPTQ, AWQ, EXL2) and extensions, but its creative writing support is mostly through third-party extensions. For roleplay with SillyTavern, KoboldCpp is the clear choice." },
];
---

<BaseLayout
  title="KoboldCpp: Local LLM Inference for Creative Writing &amp; RP (2026)"
  description="KoboldCpp runs local GGUF models optimized for creative writing, roleplay, and SillyTavern integration. Complete guide to installation, World Info, Memory, and KoboldAI API setup."
  tool="KoboldCpp, KoboldAI, local LLM, creative writing AI, SillyTavern, GGUF, roleplay AI, private LLM"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"KoboldCpp: Local LLM Inference for Creative Writing & RP","url":"https://devplaybook.cc/tools/koboldcpp","description":"KoboldCpp is a local GGUF inference tool built for creative writing, roleplay, and SillyTavern integration — 2026 guide."})} />

  <h1 class="text-3xl font-bold mb-2">KoboldCpp: Local LLM Inference for Creative Writing &amp; Roleplay</h1>
  <p class="text-text-muted mb-6">KoboldCpp is a single-file LLM inference tool built on llama.cpp and purpose-built for creative writing and roleplay. It ships with World Info, Memory, and Author's Note features for long-form storytelling, integrates natively with SillyTavern, and runs anywhere llama.cpp does — all in one portable executable.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> World Info + Memory for long-form writing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> SillyTavern-compatible (KoboldAI API)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Single portable executable</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GPU support (CUDA, Metal, Vulkan)</span>
  </div>

  <ToolPageCta />

  <!-- Installation -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Installation &amp; Quick Start</h2>
    <p class="text-text-muted text-sm mb-4">KoboldCpp is distributed as a single executable file — no installation required. Download the right binary for your platform from GitHub Releases:</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># Download from: https://github.com/LostRuins/koboldcpp/releases

# Windows (NVIDIA GPU)
# Download: koboldcpp_cu12.exe (CUDA 12) or koboldcpp_cu11.exe (CUDA 11)

# Windows (CPU only)
# Download: koboldcpp.exe

# macOS (Apple Silicon)
# Download: koboldcpp-mac-arm64

# Linux (CPU + CUDA)
# Download: koboldcpp-linux-x64 or koboldcpp-linux-x64-cuda1150

# Run with the GUI launcher (recommended for beginners):
./koboldcpp.exe  # Opens a configuration GUI

# Run headless with command line:
./koboldcpp.exe \
  --model /path/to/model.gguf \
  --contextsize 8192 \
  --gpulayers 35 \
  --port 5001

# Access the web UI at http://localhost:5001
# KoboldAI API at http://localhost:5001/api/v1
# OpenAI API at http://localhost:5001/v1</code></pre>
  </div>

  <!-- World Info and Memory -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">World Info, Memory &amp; Author's Note</h2>
    <p class="text-text-muted text-sm mb-4">These three features are what make KoboldCpp uniquely powerful for long-form creative writing and roleplay:</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code"># MEMORY (always-on context block)
# Text always included at the start of the model's context
# Use for: setting, rules, character descriptions, writing style notes
# Example Memory entry:
# "Setting: A cyberpunk city in 2157. Technology is advanced but society
#  is stratified. The protagonist is a hacker named Yara, 28, cynical
#  but idealistic. Writing style: noir, present tense, first person."

# AUTHOR'S NOTE (injected near the end of context)
# Guides the model's immediate output style
# Example: "[Write in the style of Philip K. Dick. Build tension slowly.]"
# Position: 3 (default) = inject 3 turns from the bottom of context

# WORLD INFO (keyword-triggered dynamic injection)
# Each entry has: title, content, trigger keywords, priority
# Example entries:
# Title: Yara's Apartment
# Content: "Yara lives in a cramped 200 sq ft pod in sector 7.
#            Her walls are covered in hacked display panels."
# Triggers: "apartment, home, pod, sector 7"
# → Injected automatically when these words appear in conversation

# Title: Nexus Corp
# Content: "Nexus Corp is the megacorporation controlling water and power.
#            CEO: Director Chen. Known for human experimentation."
# Triggers: "nexus, corporation, nexus corp, director chen"</code></pre>
  </div>

  <!-- SillyTavern integration -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">SillyTavern Integration</h2>
    <p class="text-text-muted text-sm mb-4">SillyTavern is the most popular character-based roleplay frontend. It connects to KoboldCpp's API to handle all inference while SillyTavern manages characters, personas, and UI:</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># 1. Start KoboldCpp with your model:
./koboldcpp.exe --model mymodel.gguf --contextsize 8192 --gpulayers 35

# 2. Install SillyTavern:
git clone https://github.com/SillyTavern/SillyTavern
cd SillyTavern
npm install
node server.js

# 3. Connect SillyTavern to KoboldCpp:
# Open SillyTavern at http://localhost:8000
# Click the API icon (top bar)
# Select "KoboldAI" as the API type
# Enter: http://localhost:5001
# Click "Test Connection" — should show green

# 4. Key SillyTavern features with KoboldCpp:
# - Character cards (PNG with embedded JSON)
# - Persona management (your character)
# - World info editor (syncs with KoboldCpp)
# - Lorebooks (additional world info)
# - Prompt templates (Alpaca, ChatML, Llama3, etc.)
# - Chat export and import

# Character cards: https://chub.ai (largest library)</code></pre>
  </div>

  <!-- Comparison -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-4">KoboldCpp vs text-generation-webui</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-text-muted text-xs uppercase border-b border-border">
            <th class="text-left pb-2 pr-4">Feature</th>
            <th class="text-left pb-2 pr-4">KoboldCpp</th>
            <th class="text-left pb-2">text-gen-webui</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border text-xs">
          <tr><td class="py-2 pr-4 font-medium">World Info / Memory</td><td class="py-2 pr-4 text-green-500">Native, built-in</td><td class="py-2 text-yellow-500">Via extensions</td></tr>
          <tr><td class="py-2 pr-4 font-medium">SillyTavern API</td><td class="py-2 pr-4 text-green-500">Native KoboldAI API</td><td class="py-2 text-yellow-500">Via extension</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Model formats</td><td class="py-2 pr-4 text-yellow-500">GGUF only</td><td class="py-2 text-green-500">GGUF, GPTQ, AWQ, EXL2</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Installation</td><td class="py-2 pr-4 text-green-500">Single executable</td><td class="py-2 text-yellow-500">Script installer</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Creative writing features</td><td class="py-2 pr-4 text-green-500">Excellent</td><td class="py-2 text-yellow-500">Basic</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Model format variety</td><td class="py-2 pr-4 text-yellow-500">GGUF focused</td><td class="py-2 text-green-500">All formats</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Best for</td><td class="py-2 pr-4">Roleplay, SillyTavern, stories</td><td class="py-2">General power users</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="KoboldCpp" relatedTags={['ai', 'llm', 'local-ai', 'creative-writing', 'roleplay', 'gguf', 'private-ai']} />
</BaseLayout>
