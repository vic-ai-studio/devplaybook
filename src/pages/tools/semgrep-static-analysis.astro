---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is SAST and how does Semgrep work?",
    answer: "SAST (Static Application Security Testing) analyzes source code without executing it to find security bugs, code quality issues, and policy violations. Semgrep works by matching syntactic patterns against your AST (Abstract Syntax Tree) rather than using regex on raw text. This means it understands code structure — it can match a function call regardless of whitespace or variable name variations."
  },
  {
    question: "How do I write a custom Semgrep rule?",
    answer: "Custom rules are YAML files with a rules key. Each rule needs an id, pattern (what to match), message (what to report), languages list, and severity. Use metavariables like $VAR to match any expression. Test rules with 'semgrep --config my-rule.yaml .' and iterate in the Semgrep Playground at semgrep.dev/playground for instant feedback."
  },
  {
    question: "What is the difference between pattern and pattern-either in Semgrep?",
    answer: "pattern matches a single syntactic pattern. pattern-either is an OR operator — it matches if any of its sub-patterns match. Use pattern-either when a vulnerability can be expressed multiple ways (e.g., both mysql_query() and pg_query() for SQL injection). Combine with pattern-not to exclude safe patterns and reduce false positives."
  },
  {
    question: "How do I integrate Semgrep in GitHub Actions?",
    answer: "Use the returntocorp/semgrep action with the SEMGREP_APP_TOKEN secret if using Semgrep Cloud, or run 'semgrep --config=auto --sarif --output=semgrep.sarif' and upload via github/codeql-action/upload-sarif. Set semgrep to scan only changed files on PRs with --diff-depth to avoid rescanning the entire codebase on every commit."
  },
  {
    question: "What are the best free rulesets for Node.js and Python?",
    answer: "For Node.js: p/nodejs, p/express, p/jwt, and p/react cover the most impactful patterns. For Python: p/python, p/django, p/flask, and p/bandit cover injection, deserialization, and SSRF patterns. Run 'semgrep --config=auto' to auto-select the best rulesets for your detected languages. The full registry is at semgrep.dev/r."
  },
  {
    question: "How does Semgrep compare to SonarQube?",
    answer: "Semgrep excels at security-focused, customizable rules that run fast in CI. SonarQube is broader — it covers code smells, coverage, duplication, and maintainability in addition to security. SonarQube requires a server and has more enterprise features (branch analysis, quality gates). Semgrep is lighter and developer-friendly for writing project-specific security rules."
  },
];
---

<BaseLayout
  title="Semgrep Static Analysis: Custom Rules, CI Integration & SAST Guide"
  description="Semgrep SAST guide: write custom security rules, use community rulesets, integrate in CI/CD, detect injection bugs, hardcoded secrets, and insecure patterns in any language."
  tool="Semgrep, SAST, static analysis, custom rules, security scanning, code analysis, CI/CD"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Semgrep Static Analysis: Custom Rules, CI Integration & SAST Guide",
    "url": "https://devplaybook.cc/tools/semgrep-static-analysis",
    "description": "Semgrep SAST guide: write custom security rules, use community rulesets, integrate in CI/CD, detect injection bugs, hardcoded secrets, and insecure patterns in any language.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Semgrep Static Analysis: Custom Rules, CI Integration & SAST Guide</h1>
  <p class="text-text-muted mb-6">Semgrep is a fast, open-source SAST tool that finds bugs and security vulnerabilities using pattern-based rules. Unlike regex, Semgrep understands code structure — making it easy to write precise custom rules for your codebase and integrate security checks directly into CI/CD pipelines.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 30+ languages supported</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5,000+ community rules</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Custom rule authoring in YAML</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> SARIF output for GitHub Security tab</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs in seconds on large codebases</span>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-3">What is Semgrep vs Other SAST Tools?</h2>
  <p class="text-text-muted mb-4">Traditional SAST tools like Fortify or Checkmarx use complex data-flow analysis — powerful but slow and hard to customize. Semgrep takes a different approach: lightweight syntactic pattern matching against the AST. This makes it fast enough to run on every PR, easy to write custom rules for, and flexible enough to catch business-logic bugs alongside security vulnerabilities.</p>
  <p class="text-text-muted mb-4">Semgrep is fully open-source (OSS tier). Semgrep Code (cloud) adds cross-file taint analysis and a web dashboard for team management.</p>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Installation and Quickstart</h2>
  <pre class="bg-surface rounded-lg p-4 text-sm overflow-x-auto mb-4"><code># Install via pip
pip install semgrep

# Or via Homebrew
brew install semgrep

# Run with auto-selected rules for your languages
semgrep --config=auto .

# Run a specific ruleset
semgrep --config=p/nodejs .

# Run against a single file
semgrep --config=auto src/auth.js</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Using Community Rulesets</h2>
  <pre class="bg-surface rounded-lg p-4 text-sm overflow-x-auto mb-4"><code># Auto-detect language and apply best rulesets
semgrep --config=auto .

# Security-focused rulesets
semgrep --config=p/owasp-top-ten .
semgrep --config=p/nodejs .
semgrep --config=p/python .
semgrep --config=p/django .
semgrep --config=p/react .

# Secret detection
semgrep --config=p/secrets .

# Multiple configs
semgrep --config=p/nodejs --config=p/jwt .</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Writing Custom Rules</h2>
  <p class="text-text-muted mb-3">Rules are YAML files. Here's a rule that catches SQL injection via string concatenation in Python:</p>
  <pre class="bg-surface rounded-lg p-4 text-sm overflow-x-auto mb-4"><code>rules:
  - id: sql-injection-string-concat
    pattern: |
      cursor.execute("..." + $USER_INPUT)
    message: |
      SQL injection risk: do not concatenate user input into queries.
      Use parameterized queries: cursor.execute("SELECT ...", (value,))
    languages: [python]
    severity: ERROR
    metadata:
      category: security
      cwe: CWE-89

  - id: hardcoded-aws-secret
    pattern-either:
      - pattern: |
          $KEY = "AKIA..."
      - pattern: |
          aws_secret_access_key = "..."
    message: Hardcoded AWS credentials detected
    languages: [python, javascript, typescript]
    severity: ERROR</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">CI Integration — GitHub Actions</h2>
  <pre class="bg-surface rounded-lg p-4 text-sm overflow-x-auto mb-4"><code>name: Semgrep SAST

on:
  push:
    branches: [main]
  pull_request:

jobs:
  semgrep:
    runs-on: ubuntu-latest
    container:
      image: semgrep/semgrep
    steps:
      - uses: actions/checkout@v4

      - name: Run Semgrep
        run: |
          semgrep \
            --config=auto \
            --sarif \
            --output=semgrep.sarif \
            --error
        env:
          SEMGREP_APP_TOKEN: &#123;&#123; secrets.SEMGREP_APP_TOKEN &#125;&#125;

      - name: Upload SARIF
        uses: github/codeql-action/upload-sarif@v3
        if: always()
        with:
          sarif_file: semgrep.sarif</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Detecting Common Security Issues</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 font-semibold">Vulnerability</th>
          <th class="text-left py-2 pr-4 font-semibold">Ruleset</th>
          <th class="text-left py-2 pr-4 font-semibold">Pattern Example</th>
        </tr>
      </thead>
      <tbody class="text-text-muted">
        <tr class="border-b border-border/50"><td class="py-2 pr-4">SQL Injection</td><td class="py-2 pr-4">p/owasp-top-ten</td><td class="py-2 pr-4">String concat in query</td></tr>
        <tr class="border-b border-border/50"><td class="py-2 pr-4">XSS</td><td class="py-2 pr-4">p/react, p/nodejs</td><td class="py-2 pr-4">innerHTML = userInput</td></tr>
        <tr class="border-b border-border/50"><td class="py-2 pr-4">Hardcoded Secrets</td><td class="py-2 pr-4">p/secrets</td><td class="py-2 pr-4">password = "literal"</td></tr>
        <tr class="border-b border-border/50"><td class="py-2 pr-4">Insecure Deserialization</td><td class="py-2 pr-4">p/python</td><td class="py-2 pr-4">pickle.loads(data)</td></tr>
        <tr><td class="py-2 pr-4">Path Traversal</td><td class="py-2 pr-4">p/nodejs</td><td class="py-2 pr-4">path.join(req.params.x)</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Semgrep vs SonarQube vs CodeQL</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 font-semibold">Aspect</th>
          <th class="text-left py-2 pr-4 font-semibold">Semgrep</th>
          <th class="text-left py-2 pr-4 font-semibold">SonarQube</th>
          <th class="text-left py-2 pr-4 font-semibold">CodeQL</th>
        </tr>
      </thead>
      <tbody class="text-text-muted">
        <tr class="border-b border-border/50"><td class="py-2 pr-4">Custom rules</td><td class="py-2 pr-4">Easy YAML</td><td class="py-2 pr-4">Complex Java API</td><td class="py-2 pr-4">QL language</td></tr>
        <tr class="border-b border-border/50"><td class="py-2 pr-4">Speed</td><td class="py-2 pr-4">Very fast</td><td class="py-2 pr-4">Moderate</td><td class="py-2 pr-4">Slow (deep analysis)</td></tr>
        <tr class="border-b border-border/50"><td class="py-2 pr-4">Data-flow analysis</td><td class="py-2 pr-4">Cloud tier</td><td class="py-2 pr-4">Yes</td><td class="py-2 pr-4">Yes (best-in-class)</td></tr>
        <tr><td class="py-2 pr-4">Free tier</td><td class="py-2 pr-4">OSS fully free</td><td class="py-2 pr-4">Community edition</td><td class="py-2 pr-4">Free on GitHub</td></tr>
      </tbody>
    </table>
  </div>

  <ToolPageCta />
  <FaqSection faqs={faq} />
</BaseLayout>
