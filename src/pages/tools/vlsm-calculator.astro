---
import BaseLayout from '../../layouts/BaseLayout.astro';
import VlsmCalculator from '../../components/VlsmCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is VLSM (Variable Length Subnet Masking)?",
    answer: "VLSM allows a network administrator to divide an IP address space into subnets of different sizes, each with its own prefix length. Unlike fixed-length subnetting (FLSM), which forces all subnets to be the same size, VLSM lets you allocate exactly as many addresses as each subnet needs — a /30 for a 2-host point-to-point link, a /25 for a 126-host LAN, and anything in between, all carved out of the same parent block."
  },
  {
    question: "How does the VLSM allocation algorithm work?",
    answer: "The standard VLSM algorithm sorts subnets from largest to smallest host requirement. For each subnet it finds the smallest power-of-2 block that fits (required hosts + 2 for the network and broadcast addresses). Blocks are then assigned sequentially from the start of the parent network, aligned to their natural boundaries. Allocating largest-first avoids fragmentation and guarantees the most efficient packing possible within a given address range."
  },
  {
    question: "When should I use VLSM instead of fixed-length subnetting?",
    answer: "Use VLSM whenever your subnets have significantly different size requirements — for example, a /24 LAN, a /27 server VLAN, and several /30 point-to-point WAN links all carved from a single /20. Fixed-length subnetting (FLSM) wastes addresses because every subnet gets padded to the same size. VLSM is the industry standard for modern enterprise and ISP network design because it makes optimal use of scarce address space."
  },
  {
    question: "What are network address, broadcast address, and usable hosts?",
    answer: "Every IPv4 subnet reserves two addresses: the network address (the first address, all host bits zero) and the broadcast address (the last address, all host bits one). Every address between them is usable by hosts. A /24 block has 256 total addresses — 1 network + 1 broadcast + 254 usable. A /30 has 4 total — 1 + 1 + 2 usable, which is the classic point-to-point link subnet. A /31 (RFC 3021) omits broadcast and gives exactly 2 usable addresses for router-to-router links."
  },
  {
    question: "What is the difference between a subnet mask and a CIDR prefix?",
    answer: "They represent the same information in two different formats. A CIDR prefix like /24 is simply the count of consecutive 1-bits in the subnet mask. The /24 prefix corresponds to the subnet mask 255.255.255.0 (24 ones followed by 8 zeros in binary). CIDR notation is more compact and easier to read; subnet masks in dotted-decimal form are what network devices historically accepted in configuration. Modern equipment accepts both, and this calculator shows you both for every subnet it allocates."
  },
];
---

<BaseLayout
  title="VLSM Calculator — Variable Length Subnet Masking"
  description="Calculate Variable Length Subnet Masking (VLSM) for optimized IP address allocation. Enter a network and required host counts per subnet to get optimized CIDR allocations."
  tool="VLSM calculator, variable length subnet masking, subnet calculator, IP address allocation, CIDR calculator, network design"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">VLSM Calculator</h1>
  <p class="text-text-muted mb-4">
    Enter a parent network and the number of hosts each subnet needs. The calculator allocates the smallest possible CIDR block to each subnet — largest first — so you waste zero address space.
    All computation runs in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Supports up to 32 subnets</span>
  </div>
  <VlsmCalculator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="VLSM Calculator" relatedTags={['networking', 'devops', 'infrastructure', 'linux', 'cloud']} />
</BaseLayout>
