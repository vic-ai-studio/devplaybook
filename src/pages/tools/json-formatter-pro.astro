---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonFormatterPro from '../../components/JsonFormatterPro.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is JSONPath and how do I use it?", answer: "JSONPath is a query language for JSON, similar to XPath for XML. Use $ as the root, dot notation for properties ($..name), brackets for arrays ($[0]), and wildcards for all values ($.*). For example, $.store.books[*].title returns the title of every book in the store array." },
  { question: "How does this differ from a basic JSON formatter?", answer: "JSON Formatter Pro adds JSONPath querying — you can extract specific values, arrays, or nested objects from your JSON without manually scanning it. It's useful when working with large API responses or configuration files where you only need a subset of the data." },
  { question: "What JSONPath syntax is supported?", answer: "This tool supports: $ (root), .key (property), [0] (array index), [*] or .* (wildcard — all items), and chaining like $.data.users[0].email. Recursive descent (..) is normalized to single-level access." },
  { question: "Is it safe to paste sensitive JSON data here?", answer: "Yes. This tool runs 100% in your browser. No data is sent to any server — not for formatting, not for JSONPath queries. Your JSON never leaves your machine." },
  { question: "What is the difference between format and minify?", answer: "Formatting adds indentation and newlines to make JSON human-readable. Minifying removes all whitespace to produce the smallest possible string — ideal for API payloads, config files, and network transmission." },
];
---

<BaseLayout
  title="JSON Formatter Pro — Format, Validate & JSONPath Query Online"
  description="Format, validate, and query JSON with JSONPath expressions. Extract nested values instantly. Free JSON Formatter Pro — no data leaves your browser."
  tool="JSON Formatter Pro, JSONPath Query, JSON Validator, JSON Beautifier, JSON Pretty Print, JSONPath Online"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">JSON Formatter Pro</h1>
  <p class="text-text-muted mb-4">Format, validate, and beautify JSON instantly — then query it with JSONPath to extract exactly the data you need. Choose your indent style, minify to one line, or run <code class="font-mono text-sm">$.path.to.value</code> queries. Syntax errors highlighted immediately.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> JSONPath query support</span>
  </div>
  <JsonFormatterPro client:load />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <AffiliateSection category="database" />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Need the basic JSON Formatter?</p>
    <a href="/tools/json-formatter" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">JSON Formatter (Standard) →</a>
  </div>
  <ToolPageCta currentTool="JSON Formatter Pro" relatedTags={['json', 'api', 'debugging', 'development']} />
</BaseLayout>
