---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ElasticsearchQueryTester from '../../components/ElasticsearchQueryTester.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the Elasticsearch bool query?", answer: "The bool query is the primary way to combine multiple queries. It has four clauses: must (all must match, contributes to relevance score), filter (must match but doesn't affect score — cached, faster), should (optional — boosts score if matched), and must_not (excluded, cached). Use filter for structured data like status or date ranges, and must for full-text relevance." },
  { question: "What's the difference between match and term?", answer: "match is for full-text fields — it analyzes the query string using the same analyzer as the indexed field (lowercasing, stemming, etc.). term is for exact value matching on keyword, numeric, and boolean fields. Using term on a text field usually fails because the stored value is tokenized, not the original string." },
  { question: "When should I use filter vs must?", answer: "Use filter for anything where relevance score doesn't matter — IDs, status codes, date ranges, numeric thresholds. Filter results are cached by Elasticsearch, making them significantly faster on repeated queries. Use must only when you want the clause to contribute to the _score (full-text relevance)." },
  { question: "What does size: 0 mean in aggregations?", answer: "Setting size: 0 tells Elasticsearch not to return any document hits — only the aggregation results. This is the standard pattern for analytics queries where you only care about counts, averages, or groupings, not the actual documents." },
  { question: "What is minimum_should_match?", answer: "In a bool query with should clauses, minimum_should_match controls how many should conditions must match. Normally if must or filter clauses exist, should is optional. Set minimum_should_match: 1 to require at least one should clause to match even when must/filter is present." },
  { question: "Does this tool send my query to Elasticsearch?", answer: "No. All analysis runs entirely in your browser. Nothing is sent to any server — not Elasticsearch, not our servers, nothing. Your query stays local." },
];
---

<BaseLayout
  title="Elasticsearch Query Tester — Validate and Explain ES Queries"
  description="Paste or build Elasticsearch queries and get instant explanations of each clause — bool, match, term, range, wildcard, aggregations. Understand filter vs must, field type guide, and JSON validation."
  tool="Elasticsearch query tester, ES query validator, Elasticsearch bool query explainer, Elasticsearch DSL analyzer"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Elasticsearch Query Tester",
    "url": "https://devplaybook.cc/tools/elasticsearch-query-tester",
    "description": "Paste or build Elasticsearch queries and get instant explanations of each clause. Validates JSON, explains bool/match/term/range/aggregation clauses, and provides field type guidance.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Elasticsearch Query Tester</h1>
  <p class="text-text-muted mb-4">
    Paste or build Elasticsearch queries and get instant explanations of each clause.
    Validates your JSON, explains
    <code class="font-mono bg-surface px-1 rounded text-sm">bool</code>,
    <code class="font-mono bg-surface px-1 rounded text-sm">match</code>,
    <code class="font-mono bg-surface px-1 rounded text-sm">term</code>,
    <code class="font-mono bg-surface px-1 rounded text-sm">range</code>,
    <code class="font-mono bg-surface px-1 rounded text-sm">wildcard</code>,
    and aggregation clauses. Includes a field type guide.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 8 query type templates</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Clause-by-clause analysis</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <ElasticsearchQueryTester client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Elasticsearch Query Tester" relatedTags={['elasticsearch', 'search', 'database', 'nosql', 'developer-tools', 'backend']} />
</BaseLayout>
