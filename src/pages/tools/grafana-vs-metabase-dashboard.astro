---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Grafana best used for?",
    answer: "Grafana is the industry standard for infrastructure observability and operational dashboards. It connects to virtually any time-series database (Prometheus, InfluxDB, Elasticsearch, Loki, Tempo) and supports Kubernetes, cloud infrastructure, application performance monitoring, and log visualization. Grafana's alerting engine, on-call management (Grafana OnCall), and incident workflows make it the go-to platform for SRE and DevOps teams. It is NOT primarily designed for business intelligence — connecting to relational databases like PostgreSQL or BigQuery for business metrics is possible but less ergonomic than Metabase or Superset. Grafana Cloud has a generous free tier; self-hosted Grafana OSS is completely free."
  },
  {
    question: "How does Metabase compare to Superset for business analytics?",
    answer: "Metabase is the friendliest business intelligence tool available — non-technical users can build charts and dashboards without writing SQL using the visual question editor. It connects to any relational database, has a polished UI, and supports email/Slack scheduled reports. The tradeoff is limited customization in the free tier: advanced features like SSO, embedding, and white-labeling require the Pro plan (~$500/month). Apache Superset is more powerful and fully free/open-source, with a SQL Lab IDE, rich chart library, and fine-grained access control, but it requires more technical setup and the UI is more complex. Choose Metabase for non-technical teams and stakeholder-facing dashboards; choose Superset when you need full control, complex charts, and no budget for paid tiers."
  },
  {
    question: "Can I embed dashboards in my web application?",
    answer: "All three tools support embedding, with different approaches and cost implications. Metabase Pro offers signed embedding — generate a signed URL server-side and embed any dashboard or chart in an iframe with full security isolation. Grafana supports public dashboards (anonymous access) and Grafana Embedding SDK for private iframe embedding. Apache Superset supports guest token authentication for embedding in third-party apps. For customer-facing analytics embedded in SaaS products, Metabase's embedding API is the most developer-friendly. For internal operations dashboards, Grafana's public dashboards work without a paid plan. Consider Redash (free, open-source) or Retool if your primary use case is embedded BI in a product."
  },
  {
    question: "What is the best free dashboard tool in 2026?",
    answer: "It depends on your use case. For infrastructure/DevOps: Grafana OSS (fully free, self-host) with Prometheus is the default. For SQL-based business analytics: Metabase Community Edition (free, self-host) is the easiest non-technical dashboard tool. For advanced BI with no paid tier: Apache Superset (free, complex to set up). For quick, temporary charts: Redash or Observable Framework. For Google Workspace users: Looker Studio (formerly Data Studio) is completely free and connects directly to BigQuery, Google Sheets, and 30+ data sources. If you are budget-constrained, Grafana + Prometheus + Loki for observability and Metabase OSS for business metrics covers 90% of dashboard needs at zero licensing cost."
  },
];
---

<BaseLayout
  title="Grafana vs Metabase vs Superset: Data Viz & Dashboards 2026"
  description="Compare Grafana, Metabase, and Apache Superset for data visualization. Use-case quiz recommends the best tool. Feature comparison table and pricing breakdown included."
  tool="Grafana vs Metabase, Apache Superset comparison, dashboard tools comparison, data visualization tools, BI tools 2026, Grafana vs Superset"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Grafana vs Metabase vs Apache Superset</h1>
  <p class="text-text-muted mb-4">Three dashboard and data visualization tools built for very different audiences. Answer the quiz to find the right tool for your team, then compare features and pricing.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Use-case quiz</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Feature comparison table</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Pricing breakdown</span>
  </div>

  <!-- Use-case Quiz -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-1">Find Your Dashboard Tool</h2>
    <p class="text-xs text-text-muted mb-4">Answer all questions to get your recommendation.</p>

    <div class="space-y-5">

      <div>
        <p class="text-sm font-medium mb-2">1. Who will build the dashboards?</p>
        <div class="flex flex-wrap gap-2">
          <button class="dash-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="builder" data-v="nontechnical">Non-technical / business analysts</button>
          <button class="dash-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="builder" data-v="technical">Engineers / data analysts (SQL-comfortable)</button>
          <button class="dash-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="builder" data-v="devops">SRE / DevOps / infra team</button>
        </div>
      </div>

      <div>
        <p class="text-sm font-medium mb-2">2. What data sources do you need?</p>
        <div class="flex flex-wrap gap-2">
          <button class="dash-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="datasource" data-v="timeseries">Prometheus / InfluxDB / Loki (time-series)</button>
          <button class="dash-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="datasource" data-v="sql">PostgreSQL / BigQuery / Snowflake (SQL)</button>
          <button class="dash-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="datasource" data-v="mixed">Both time-series and SQL</button>
        </div>
      </div>

      <div>
        <p class="text-sm font-medium mb-2">3. Use case?</p>
        <div class="flex flex-wrap gap-2">
          <button class="dash-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="usecase" data-v="infra">Infrastructure monitoring / alerting</button>
          <button class="dash-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="usecase" data-v="bi">Business intelligence / KPI tracking</button>
          <button class="dash-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="usecase" data-v="embed">Embed dashboards in a product/app</button>
          <button class="dash-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="usecase" data-v="explore">Ad-hoc SQL exploration + charts</button>
        </div>
      </div>

      <div>
        <p class="text-sm font-medium mb-2">4. Budget?</p>
        <div class="flex flex-wrap gap-2">
          <button class="dash-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="budget" data-v="free">Free only</button>
          <button class="dash-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="budget" data-v="small">Under $200/month</button>
          <button class="dash-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="budget" data-v="flexible">Flexible / enterprise</button>
        </div>
      </div>
    </div>

    <div id="dash-result" class="hidden mt-5 bg-primary/10 border border-primary/30 rounded-xl p-4">
      <p class="text-sm font-bold text-primary mb-1" id="dash-tool"></p>
      <p class="text-sm text-text-muted" id="dash-reason"></p>
    </div>
  </div>

  <!-- Feature Comparison Table -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6 overflow-x-auto">
    <h2 class="text-base font-semibold mb-4">Feature Comparison</h2>
    <table class="w-full text-sm min-w-[580px]">
      <thead>
        <tr class="text-text-muted text-xs border-b border-border">
          <th class="text-left pb-3 font-medium w-52">Feature</th>
          <th class="text-center pb-3 font-medium">Grafana</th>
          <th class="text-center pb-3 font-medium">Metabase</th>
          <th class="text-center pb-3 font-medium">Superset</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border text-xs">
        <tr><td class="py-2.5 text-text-muted font-medium">Open Source</td><td class="py-2.5 text-center text-green-500">✓ OSS core</td><td class="py-2.5 text-center text-green-500">✓ Community</td><td class="py-2.5 text-center text-green-500">✓ Apache 2.0</td></tr>
        <tr><td class="py-2.5 text-text-muted font-medium">No-SQL chart builder</td><td class="py-2.5 text-center text-red-400">Limited</td><td class="py-2.5 text-center text-green-500">✓ Best-in-class</td><td class="py-2.5 text-center text-yellow-500">Partial</td></tr>
        <tr><td class="py-2.5 text-text-muted font-medium">SQL Lab / IDE</td><td class="py-2.5 text-center text-red-400">✗</td><td class="py-2.5 text-center text-yellow-500">Basic</td><td class="py-2.5 text-center text-green-500">✓ Full SQL Lab</td></tr>
        <tr><td class="py-2.5 text-text-muted font-medium">Time-series data sources</td><td class="py-2.5 text-center text-green-500">✓ 50+ plugins</td><td class="py-2.5 text-center text-red-400">Limited</td><td class="py-2.5 text-center text-red-400">Limited</td></tr>
        <tr><td class="py-2.5 text-text-muted font-medium">Alerting / on-call</td><td class="py-2.5 text-center text-green-500">✓ Full alerting</td><td class="py-2.5 text-center text-yellow-500">Basic alerts</td><td class="py-2.5 text-center text-yellow-500">Basic alerts</td></tr>
        <tr><td class="py-2.5 text-text-muted font-medium">Embedding API</td><td class="py-2.5 text-center text-yellow-500">Public dashboards</td><td class="py-2.5 text-center text-green-500">✓ Signed embed (Pro)</td><td class="py-2.5 text-center text-green-500">✓ Guest tokens</td></tr>
        <tr><td class="py-2.5 text-text-muted font-medium">Scheduled email reports</td><td class="py-2.5 text-center text-yellow-500">Grafana Cloud</td><td class="py-2.5 text-center text-green-500">✓ Free</td><td class="py-2.5 text-center text-green-500">✓ Free</td></tr>
        <tr><td class="py-2.5 text-text-muted font-medium">Chart types</td><td class="py-2.5 text-center">50+ (plugins)</td><td class="py-2.5 text-center">30+</td><td class="py-2.5 text-center text-green-500">60+</td></tr>
        <tr><td class="py-2.5 text-text-muted font-medium">Setup complexity</td><td class="py-2.5 text-center">Low (Docker)</td><td class="py-2.5 text-center text-green-500">Very Low</td><td class="py-2.5 text-center text-yellow-500">Medium</td></tr>
      </tbody>
    </table>
  </div>

  <!-- Pricing Breakdown -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-4">Pricing Breakdown (2026)</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="border border-border rounded-lg p-4">
        <p class="text-sm font-semibold mb-1">Grafana</p>
        <p class="text-xl font-bold text-green-500 mb-1">Free <span class="text-sm font-normal text-text-muted">OSS / Cloud free tier</span></p>
        <ul class="space-y-1.5 text-xs text-text-muted mt-2">
          <li class="flex items-start gap-1.5"><span class="text-green-500">✓</span>Self-hosted: completely free</li>
          <li class="flex items-start gap-1.5"><span class="text-green-500">✓</span>Grafana Cloud free: 10k metrics + 50 GB logs</li>
          <li class="flex items-start gap-1.5"><span class="text-yellow-500">→</span>Pro: $8/user/month</li>
          <li class="flex items-start gap-1.5"><span class="text-yellow-500">→</span>Enterprise: custom (SSO, data source permissions)</li>
        </ul>
      </div>
      <div class="border border-primary/30 rounded-lg p-4 bg-primary/5">
        <p class="text-sm font-semibold mb-1">Metabase</p>
        <p class="text-xl font-bold text-primary mb-1">Free <span class="text-sm font-normal text-text-muted">Community / $500/mo Pro</span></p>
        <ul class="space-y-1.5 text-xs text-text-muted mt-2">
          <li class="flex items-start gap-1.5"><span class="text-green-500">✓</span>Self-hosted Community: free (unlimited)</li>
          <li class="flex items-start gap-1.5"><span class="text-green-500">✓</span>Metabase Cloud Starter: $85/month (5 users)</li>
          <li class="flex items-start gap-1.5"><span class="text-yellow-500">→</span>Pro: $500/month (SSO, embedding, auditing)</li>
          <li class="flex items-start gap-1.5"><span class="text-yellow-500">→</span>Enterprise: custom pricing</li>
        </ul>
      </div>
      <div class="border border-border rounded-lg p-4">
        <p class="text-sm font-semibold mb-1">Apache Superset</p>
        <p class="text-xl font-bold text-green-500 mb-1">Free <span class="text-sm font-normal text-text-muted">fully open-source</span></p>
        <ul class="space-y-1.5 text-xs text-text-muted mt-2">
          <li class="flex items-start gap-1.5"><span class="text-green-500">✓</span>Self-hosted: completely free (Apache 2.0)</li>
          <li class="flex items-start gap-1.5"><span class="text-green-500">✓</span>No paid tiers — all features open source</li>
          <li class="flex items-start gap-1.5"><span class="text-yellow-500">→</span>Preset.io (managed Superset): $20/user/month</li>
          <li class="flex items-start gap-1.5"><span class="text-yellow-500">→</span>Setup requires Docker + config knowledge</li>
        </ul>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Grafana vs Metabase vs Superset" relatedTags={['grafana', 'metabase', 'superset', 'dashboard', 'data-visualization', 'bi-tools', 'analytics', 'observability']} />
</BaseLayout>

<script>
  const dashAnswers: Record<string, string> = {};

  function getDashRecommendation() {
    const { builder, datasource, usecase, budget } = dashAnswers;
    if (!builder || !datasource || !usecase || !budget) return null;

    if (usecase === 'infra' || datasource === 'timeseries' || builder === 'devops') {
      return { tool: 'Grafana', reason: 'Grafana is the uncontested leader for infrastructure monitoring, time-series visualization, and alerting. Its 50+ data source plugins, mature alerting engine, and massive plugin ecosystem make it the default for DevOps and SRE teams. Grafana Cloud free tier includes Prometheus, Loki, and Tempo.' };
    }
    if (builder === 'nontechnical' || (usecase === 'bi' && budget !== 'free')) {
      return { tool: 'Metabase', reason: 'Metabase\'s no-SQL visual question builder makes it the most accessible BI tool for non-technical stakeholders. Clean UI, scheduled reports, and dashboard subscriptions mean business users become self-sufficient. Community edition is free for self-hosting.' };
    }
    if (usecase === 'explore' || budget === 'free' || builder === 'technical') {
      return { tool: 'Apache Superset', reason: 'Apache Superset is 100% free and open-source with a full SQL Lab IDE, 60+ chart types, and fine-grained role-based access control. Ideal for data-savvy teams building an internal BI platform with no licensing budget. Setup requires Docker knowledge.' };
    }
    if (usecase === 'embed') {
      return { tool: 'Metabase', reason: 'Metabase Pro\'s signed embedding API is the most developer-friendly option for embedding dashboards and individual charts in your application. Generate signed tokens server-side and render any Metabase content in an iframe with full row-level security.' };
    }
    return { tool: 'Metabase', reason: 'For most teams getting started with business intelligence, Metabase offers the best balance of ease-of-use, feature coverage, and free self-hosting. Upgrade to Pro when you need SSO or embedding.' };
  }

  document.querySelectorAll('.dash-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const q = (btn as HTMLElement).dataset.q!;
      const v = (btn as HTMLElement).dataset.v!;
      dashAnswers[q] = v;

      document.querySelectorAll(`.dash-btn[data-q="${q}"]`).forEach(b => {
        b.classList.remove('border-primary', 'bg-primary/10', 'text-primary');
        b.classList.add('border-border');
      });
      btn.classList.remove('border-border');
      btn.classList.add('border-primary', 'bg-primary/10', 'text-primary');

      const rec = getDashRecommendation();
      const resultEl = document.getElementById('dash-result')!;
      if (rec) {
        resultEl.classList.remove('hidden');
        document.getElementById('dash-tool')!.textContent = `Recommended: ${rec.tool}`;
        document.getElementById('dash-reason')!.textContent = rec.reason;
      }
    });
  });
</script>
