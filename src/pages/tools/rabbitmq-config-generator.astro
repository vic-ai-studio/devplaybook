---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RabbitmqConfigGenerator from '../../components/RabbitmqConfigGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What exchange types does RabbitMQ support?",
    answer: "RabbitMQ has four built-in exchange types: Direct routes messages by exact routing key match (good for task queues). Topic routes by pattern matching using * (one word) and # (zero or more words) wildcards — great for pub/sub with namespaced topics. Fanout broadcasts to all bound queues regardless of routing key — useful for notifications and cache invalidation. Headers routes by message header attributes instead of routing key."
  },
  {
    question: "What is a durable queue/exchange?",
    answer: "Durable queues and exchanges survive broker restarts. Non-durable (transient) resources are deleted when RabbitMQ restarts. For production use cases where losing messages is not acceptable, always use durable queues with persistent message delivery (delivery_mode: 2). Note that durability applies to the queue definition — messages themselves also need to be published as persistent to survive restarts."
  },
  {
    question: "What is a Dead Letter Exchange (DLX)?",
    answer: "A Dead Letter Exchange receives messages that cannot be processed — they've expired (exceeded TTL), been rejected, or the queue has exceeded its max-length limit. Set x-dead-letter-exchange on a queue to redirect failed messages to a DLX for later inspection, retry, or alerting. This is essential for building resilient message pipelines."
  },
  {
    question: "How does x-message-ttl work?",
    answer: "x-message-ttl sets the maximum time (in milliseconds) a message can stay in the queue before being discarded or dead-lettered. For example, 86400000 = 24 hours. Per-message TTL can also be set at publish time via the expiration property. If both are set, the shorter of the two applies."
  },
  {
    question: "What is x-max-length?",
    answer: "x-max-length caps the number of messages in a queue. When the limit is reached, the oldest messages (head of queue) are dropped or dead-lettered to make room for new ones. This prevents unbounded queue growth in cases where consumers fall behind. You can also set x-max-length-bytes to cap by total byte size."
  },
  {
    question: "How do I apply this configuration to RabbitMQ?",
    answer: "For JSON output: use the RabbitMQ Management API (POST /api/definitions) or the rabbitmqadmin CLI import command. For YAML: use it with your infrastructure-as-code tooling like Ansible or Terraform's RabbitMQ provider. In application code, use your client library's channel.exchangeDeclare(), channel.queueDeclare(), and channel.queueBind() methods."
  },
];
---

<BaseLayout
  title="RabbitMQ Config Generator — Generate Exchange, Queue & Binding Configuration"
  description="Generate RabbitMQ exchanges, queues, and binding configurations in JSON or YAML. Configure exchange types, durability, TTL, max-length, dead letter exchanges, and routing keys. Free, runs in browser."
  tool="RabbitMQ config generator, RabbitMQ exchange generator, RabbitMQ queue configuration, AMQP config builder, RabbitMQ topology generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "RabbitMQ Config Generator",
    "url": "https://devplaybook.cc/tools/rabbitmq-config-generator",
    "description": "Generate RabbitMQ exchange, queue, and binding configurations in JSON or YAML. Configure all exchange types, queue arguments, and routing key patterns.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">RabbitMQ Config Generator</h1>
  <p class="text-text-muted mb-4">
    Build RabbitMQ exchanges, queues, and bindings visually — export as JSON or YAML.
    Configure exchange types (direct, topic, fanout, headers), queue arguments (TTL, max-length, DLX), and routing key patterns.
    Runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> JSON & YAML output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All 4 exchange types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> DLX & TTL support</span>
  </div>
  <RabbitmqConfigGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="RabbitMQ Config Generator" relatedTags={['rabbitmq', 'messaging', 'queue', 'backend', 'microservices', 'devops']} />
</BaseLayout>
