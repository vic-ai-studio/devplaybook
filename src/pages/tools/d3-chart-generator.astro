---
import BaseLayout from '../../layouts/BaseLayout.astro';
import D3ChartGenerator from '../../components/D3ChartGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is D3.js and why use it for charts?",
    answer: "D3.js (Data-Driven Documents) is a JavaScript library for producing dynamic, interactive data visualizations using SVG. Unlike Chart.js or Recharts which give you pre-built chart types, D3 gives you low-level control over every visual element. This makes D3 ideal for custom visualizations, non-standard chart types, and complex animations that off-the-shelf libraries can't handle. The trade-off is a steeper learning curve — this generator handles the boilerplate for the five most common chart types."
  },
  {
    question: "What format should my data be in?",
    answer: "The tool accepts two formats. CSV-style (one per line): label,value — e.g. 'Jan,42'. Or a JSON array: [{\"label\":\"Jan\",\"value\":42},{\"label\":\"Feb\",\"value\":68}]. The JSON array also accepts 'name' or 'x' as the label key, and 'y' or 'count' as the value key. Numbers are parsed automatically. Invalid entries are ignored."
  },
  {
    question: "How do I embed the generated chart in my HTML page?",
    answer: "Add a <div id=\"chart\"></div> where you want the chart to appear. Include D3 via CDN: <script src=\"https://cdn.jsdelivr.net/npm/d3@7\"></script>. Then paste the generated JavaScript. For production, install D3 with npm install d3 and use the import statement shown in the code comment. The chart appends an SVG to the #chart container automatically."
  },
  {
    question: "How do I use the D3 chart in a React or Next.js component?",
    answer: "Use useEffect with a ref: const svgRef = useRef(null); useEffect(() => { const svg = d3.select(svgRef.current); /* your D3 code */ return () => { d3.select(svgRef.current).selectAll('*').remove(); }; }, [data]); return <div ref={svgRef} />; The cleanup function prevents duplicate charts on re-render. React strict mode can cause double-renders in dev — the cleanup handles that."
  },
  {
    question: "What is the difference between line, area, and scatter charts?",
    answer: "Line charts connect data points with a smooth path — best for showing trends over time. Area charts are like line charts but fill the area below the line with a color — useful for emphasizing volume (e.g. traffic, revenue). Scatter charts show individual data points without connecting them — best for showing distribution, correlation, or clustering across two variables. D3's d3.curveMonotoneX interpolation prevents artificial peaks between your data points."
  },
  {
    question: "Can I make the chart responsive/resizable?",
    answer: "Yes — add a ResizeObserver in your component: const observer = new ResizeObserver(() => { redrawChart(); }); observer.observe(container); For SVG-based D3 charts, set viewBox instead of fixed width/height: svg.attr('viewBox', '0 0 600 400').attr('preserveAspectRatio', 'xMidYMid meet'). Add CSS: svg { width: 100%; height: auto; } — the chart will scale with its container without JavaScript involvement."
  },
];
---

<BaseLayout
  title="D3.js Chart Generator — Generate D3 v7 Chart Code with Live Preview"
  description="Generate D3.js v7 chart code with live SVG preview. Select bar, line, area, pie, or scatter chart. Input CSV or JSON data, configure colors and labels. Copy-ready D3 code for React, plain HTML, and Node.js."
  tool="d3 chart generator, d3js examples, d3 bar chart code, d3 line chart generator, d3js visualization"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "D3.js Chart Generator",
    "url": "https://devplaybook.cc/tools/d3-chart-generator",
    "description": "Generate D3.js v7 chart code for bar, line, area, pie, and scatter charts with live preview.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">D3.js Chart Generator</h1>
  <p class="text-text-muted mb-4">
    Generate <strong>D3.js v7</strong> chart code with a live SVG preview. Select chart type, paste CSV or JSON data,
    configure colors and axis labels — get copy-ready D3 code for bar, line, area, pie, and scatter charts.
    Works with plain HTML, React, and Node.js.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 chart types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CSV & JSON input</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live SVG preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> D3 v7 + TypeScript ready</span>
  </div>
  <D3ChartGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="D3.js Chart Generator" relatedTags={['visualization', 'charts', 'javascript', 'd3', 'data', 'developer-tools']} />
</BaseLayout>
