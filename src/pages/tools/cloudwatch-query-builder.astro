---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="CloudWatch Logs Insights Query Builder — Visual AWS Query Generator"
  description="Build AWS CloudWatch Logs Insights queries visually. Select log groups, add filter conditions, parse fields, aggregate with stats, and generate ready-to-run queries. Free, runs in your browser."
  tool="CloudWatch Logs Insights, AWS CloudWatch query builder, CloudWatch filter, CloudWatch stats, AWS logging, observability, cloud monitoring"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "CloudWatch Logs Insights Query Builder",
    "url": "https://devplaybook.cc/tools/cloudwatch-query-builder",
    "description": "Build AWS CloudWatch Logs Insights queries visually. Select log groups, add filter conditions, parse fields, aggregate with stats, and generate ready-to-run queries.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">CloudWatch Logs Insights Query Builder</h1>
  <p class="text-text-muted mb-4">Build AWS CloudWatch Logs Insights queries visually. Add filter conditions, parse fields, aggregate with stats, and generate ready-to-run queries for Lambda, API Gateway, and ECS.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> filter, parse, stats, sort</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Example queries built-in</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy to clipboard</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs entirely in your browser</span>
  </div>

  <!-- Log Group & Time Range -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
    <div>
      <label class="block text-sm font-medium mb-2">Log Group (optional)</label>
      <input id="cw-loggroup" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="/aws/lambda/my-function" />
    </div>
    <div>
      <label class="block text-sm font-medium mb-2">Time Range</label>
      <select id="cw-timerange" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
        <option value="1h">Last 1 hour</option>
        <option value="3h">Last 3 hours</option>
        <option value="6h" selected>Last 6 hours</option>
        <option value="12h">Last 12 hours</option>
        <option value="24h">Last 24 hours</option>
        <option value="3d">Last 3 days</option>
        <option value="7d">Last 7 days</option>
      </select>
    </div>
  </div>

  <!-- Query Type -->
  <div class="mb-5">
    <label class="block text-sm font-medium mb-2">Query Type</label>
    <div class="flex gap-2 flex-wrap">
      <button class="qtype-btn px-4 py-2 rounded-lg text-sm font-medium border transition-colors border-primary bg-primary/10 text-primary" data-type="filter">filter</button>
      <button class="qtype-btn px-4 py-2 rounded-lg text-sm font-medium border transition-colors border-border text-text-muted hover:border-primary" data-type="parse">parse</button>
      <button class="qtype-btn px-4 py-2 rounded-lg text-sm font-medium border transition-colors border-border text-text-muted hover:border-primary" data-type="stats">stats</button>
      <button class="qtype-btn px-4 py-2 rounded-lg text-sm font-medium border transition-colors border-border text-text-muted hover:border-primary" data-type="sort">sort</button>
    </div>
  </div>

  <!-- Filter section -->
  <div id="section-filter" class="query-section mb-5">
    <div class="flex items-center justify-between mb-3">
      <label class="text-sm font-medium">Filter Conditions</label>
      <button id="btn-add-filter" class="flex items-center gap-1.5 px-3 py-1.5 bg-primary text-white rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors">
        <span class="text-base leading-none">+</span> Add Condition
      </button>
    </div>
    <div id="filter-list" class="space-y-3"></div>
  </div>

  <!-- Parse section -->
  <div id="section-parse" class="query-section hidden mb-5">
    <label class="block text-sm font-medium mb-2">Parse Pattern</label>
    <input id="parse-pattern" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary mb-3" placeholder='@message "RequestId: *  Duration: * ms"' />
    <label class="block text-sm font-medium mb-2">Fields to Extract (comma-separated)</label>
    <input id="parse-fields" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="requestId, duration" />
  </div>

  <!-- Stats section -->
  <div id="section-stats" class="query-section hidden mb-5">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium mb-2">Aggregation Function</label>
        <select id="stats-func" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
          <option value="count()">count()</option>
          <option value="avg">avg(field)</option>
          <option value="sum">sum(field)</option>
          <option value="min">min(field)</option>
          <option value="max">max(field)</option>
          <option value="count_distinct">count_distinct(field)</option>
          <option value="pct">pct(field, percentile)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Field (if applicable)</label>
        <input id="stats-field" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="@duration" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Group By (optional)</label>
        <input id="stats-groupby" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="statusCode" />
      </div>
    </div>
    <div class="mt-3">
      <label class="block text-sm font-medium mb-2">Result Alias (as)</label>
      <input id="stats-alias" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="count, avgDuration" />
    </div>
  </div>

  <!-- Sort section -->
  <div id="section-sort" class="query-section hidden mb-5">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="sm:col-span-2">
        <label class="block text-sm font-medium mb-2">Sort Field</label>
        <input id="sort-field" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="@timestamp" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Direction</label>
        <select id="sort-dir" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
          <option value="desc">desc (newest first)</option>
          <option value="asc">asc (oldest first)</option>
        </select>
      </div>
    </div>
    <div class="mt-3">
      <label class="block text-sm font-medium mb-2">Limit</label>
      <input id="sort-limit" type="number" min="1" max="10000" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="100" value="100" />
    </div>
  </div>

  <!-- Additional fields / display -->
  <div class="mb-5">
    <label class="block text-sm font-medium mb-2">Display Fields (fields command, comma-separated)</label>
    <input id="cw-display-fields" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="@timestamp, @message, statusCode, requestId" />
  </div>

  <div class="flex gap-3 mb-6 flex-wrap">
    <button id="btn-generate" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Generate Query</button>
    <button id="btn-example-lambda" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Lambda Errors</button>
    <button id="btn-example-apigw" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">API Gateway 5xx</button>
    <button id="btn-example-ecs" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">ECS Task Failures</button>
    <button id="btn-clear" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Clear</button>
  </div>

  <!-- Output -->
  <div id="output-section" class="hidden">
    <h2 class="text-lg font-semibold mb-3">Generated Query</h2>
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <div class="flex items-center justify-between mb-3">
        <span class="text-xs text-text-muted font-mono">CloudWatch Logs Insights</span>
        <button id="btn-copy" class="px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">Copy</button>
      </div>
      <pre id="query-output" class="font-mono text-sm whitespace-pre-wrap break-words text-green-300 overflow-x-auto"></pre>
    </div>
    <div id="cli-section" class="mt-4">
      <h3 class="text-sm font-semibold mb-2 text-text-muted">AWS CLI Command</h3>
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <div class="flex justify-end mb-2">
          <button id="btn-copy-cli" class="px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">Copy CLI</button>
        </div>
        <pre id="cli-output" class="font-mono text-xs whitespace-pre-wrap break-words text-blue-300 overflow-x-auto"></pre>
      </div>
    </div>
  </div>

  <ToolPageCta />
</BaseLayout>

<script>
let currentType = 'filter';
let filters = [];
let filterIdSeq = 0;

const FILTER_FIELDS = ['@message', '@level', 'level', 'statusCode', 'requestId', 'errorCode', 'errorType', '@logStream', 'functionName'];
const FILTER_OPS = ['=', '!=', '<', '>', '<=', '>=', 'like', 'not like'];

function switchType(type) {
  currentType = type;
  document.querySelectorAll('.qtype-btn').forEach(b => {
    const active = b.dataset.type === type;
    b.classList.toggle('border-primary', active);
    b.classList.toggle('bg-primary/10', active);
    b.classList.toggle('text-primary', active);
    b.classList.toggle('border-border', !active);
    b.classList.toggle('text-text-muted', !active);
  });
  document.querySelectorAll('.query-section').forEach(s => s.classList.add('hidden'));
  document.getElementById(`section-${type}`)?.classList.remove('hidden');
}

document.querySelectorAll('.qtype-btn').forEach(b => b.addEventListener('click', () => switchType(b.dataset.type)));

function esc(s) { return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function renderFilters() {
  const list = document.getElementById('filter-list');
  if (!list) return;
  list.innerHTML = '';
  if (filters.length === 0) {
    list.innerHTML = '<p class="text-sm text-text-muted text-center py-6 border border-dashed border-border rounded-lg">No conditions yet. Click &quot;+ Add Condition&quot; to begin.</p>';
    return;
  }
  filters.forEach((f, idx) => {
    const div = document.createElement('div');
    div.className = 'grid grid-cols-1 sm:grid-cols-4 gap-3 bg-bg-card border border-border rounded-lg p-3 items-end';
    div.innerHTML = `
      <div>
        <label class="block text-xs text-text-muted mb-1">Field</label>
        <input class="f-field w-full bg-bg-card border border-border rounded p-2 text-sm font-mono focus:outline-none focus:border-primary" list="cw-fields-list" value="${esc(f.field)}" data-idx="${idx}" placeholder="statusCode" />
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Operator</label>
        <select class="f-op w-full bg-bg-card border border-border rounded p-2 text-sm focus:outline-none focus:border-primary" data-idx="${idx}">
          ${FILTER_OPS.map(o => `<option value="${o}"${f.op===o?' selected':''}>${o}</option>`).join('')}
        </select>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Value</label>
        <input class="f-value w-full bg-bg-card border border-border rounded p-2 text-sm font-mono focus:outline-none focus:border-primary" value="${esc(f.value)}" data-idx="${idx}" placeholder="500" />
      </div>
      <div class="flex justify-end">
        <button class="btn-rm-filter px-3 py-2 text-text-muted hover:text-red-400 transition-colors text-xl leading-none" data-idx="${idx}" aria-label="Remove">&#215;</button>
      </div>
    `;
    list.appendChild(div);
  });
  list.querySelectorAll('.btn-rm-filter').forEach(b => b.addEventListener('click', () => { filters.splice(+b.dataset.idx, 1); renderFilters(); }));
  list.querySelectorAll('.f-field').forEach(i => i.addEventListener('input', () => { filters[+i.dataset.idx].field = i.value; }));
  list.querySelectorAll('.f-op').forEach(s => s.addEventListener('change', () => { filters[+s.dataset.idx].op = s.value; }));
  list.querySelectorAll('.f-value').forEach(i => i.addEventListener('input', () => { filters[+i.dataset.idx].value = i.value; }));
}

document.getElementById('btn-add-filter')?.addEventListener('click', () => {
  filters.push({ _id: ++filterIdSeq, field: '', op: '=', value: '' });
  renderFilters();
});

function generateQuery() {
  const logGroup = (document.getElementById('cw-loggroup')?.value || '').trim();
  const displayFields = (document.getElementById('cw-display-fields')?.value || '').trim();
  const timeRange = document.getElementById('cw-timerange')?.value || '6h';
  const lines = [];

  if (displayFields) {
    lines.push(`fields ${displayFields}`);
  }

  if (currentType === 'filter') {
    const conds = filters.map(f => {
      const field = f.field || '@message';
      const val = /^\d+(\.\d+)?$/.test(f.value) ? f.value : `"${f.value}"`;
      if (f.op === 'like' || f.op === 'not like') return `${field} ${f.op} /.*${f.value}.*/`;
      return `${field} ${f.op} ${val}`;
    }).filter(Boolean);
    if (conds.length > 0) lines.push(`filter ${conds.join('\n  | and ')}`);
    else lines.push('filter @message like /ERROR/');
  } else if (currentType === 'parse') {
    const pattern = (document.getElementById('parse-pattern')?.value || '').trim();
    const fields = (document.getElementById('parse-fields')?.value || '').trim();
    if (pattern && fields) lines.push(`parse @message "${pattern}" as ${fields}`);
    else lines.push('parse @message "* * *" as field1, field2, field3');
  } else if (currentType === 'stats') {
    const func = document.getElementById('stats-func')?.value || 'count()';
    const field = (document.getElementById('stats-field')?.value || '').trim();
    const groupBy = (document.getElementById('stats-groupby')?.value || '').trim();
    const alias = (document.getElementById('stats-alias')?.value || '').trim();
    let statsExpr = '';
    if (func === 'count()') {
      statsExpr = alias ? `count() as ${alias}` : 'count()';
    } else if (func === 'pct') {
      const pctField = field || '@duration';
      statsExpr = alias ? `pct(${pctField}, 95) as ${alias}` : `pct(${pctField}, 95)`;
    } else {
      const f = field || '@duration';
      statsExpr = alias ? `${func}(${f}) as ${alias}` : `${func}(${f})`;
    }
    const byClause = groupBy ? ` by ${groupBy}` : '';
    lines.push(`stats ${statsExpr}${byClause}`);
  } else if (currentType === 'sort') {
    const field = (document.getElementById('sort-field')?.value || '@timestamp').trim();
    const dir = document.getElementById('sort-dir')?.value || 'desc';
    const limit = document.getElementById('sort-limit')?.value || '100';
    lines.push(`sort ${field} ${dir}`);
    lines.push(`limit ${limit}`);
  }

  const query = lines.join('\n| ');

  document.getElementById('query-output').textContent = query;

  // Build CLI command
  const timeMap = { '1h': 3600, '3h': 10800, '6h': 21600, '12h': 43200, '24h': 86400, '3d': 259200, '7d': 604800 };
  const seconds = timeMap[timeRange] || 21600;
  const endTime = Math.floor(Date.now() / 1000);
  const startTime = endTime - seconds;
  const lgFlag = logGroup ? `--log-group-name "${logGroup}"` : '--log-group-name "/aws/lambda/my-function"';
  const cli = `aws logs start-query \\
  ${lgFlag} \\
  --start-time ${startTime} \\
  --end-time ${endTime} \\
  --query-string '${query.replace(/'/g, "'\\''")}'`;

  document.getElementById('cli-output').textContent = cli;
  document.getElementById('output-section').classList.remove('hidden');
  setTimeout(() => document.getElementById('output-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
}

document.getElementById('btn-generate')?.addEventListener('click', generateQuery);

document.getElementById('btn-clear')?.addEventListener('click', () => {
  filters = [];
  renderFilters();
  document.getElementById('cw-loggroup').value = '';
  document.getElementById('cw-display-fields').value = '';
  document.getElementById('output-section').classList.add('hidden');
});

function loadExample(type) {
  if (type === 'lambda') {
    switchType('filter');
    document.getElementById('cw-loggroup').value = '/aws/lambda/my-function';
    document.getElementById('cw-display-fields').value = '@timestamp, @requestId, @message, @duration, @billedDuration';
    filters = [
      { _id: ++filterIdSeq, field: '@message', op: 'like', value: 'ERROR' }
    ];
    renderFilters();
  } else if (type === 'apigw') {
    switchType('stats');
    document.getElementById('cw-loggroup').value = 'API-Gateway-Execution-Logs';
    document.getElementById('cw-display-fields').value = 'status, resourcePath';
    document.getElementById('stats-func').value = 'count()';
    document.getElementById('stats-field').value = '';
    document.getElementById('stats-groupby').value = 'status, resourcePath';
    document.getElementById('stats-alias').value = 'requestCount';
    filters = [];
    renderFilters();
  } else if (type === 'ecs') {
    switchType('filter');
    document.getElementById('cw-loggroup').value = '/ecs/my-service';
    document.getElementById('cw-display-fields').value = '@timestamp, @message, level, taskId';
    filters = [
      { _id: ++filterIdSeq, field: 'level', op: '=', value: 'ERROR' }
    ];
    renderFilters();
  }
}

document.getElementById('btn-example-lambda')?.addEventListener('click', () => loadExample('lambda'));
document.getElementById('btn-example-apigw')?.addEventListener('click', () => loadExample('apigw'));
document.getElementById('btn-example-ecs')?.addEventListener('click', () => loadExample('ecs'));

function copyText(id, btn) {
  const el = document.getElementById(id);
  if (!el) return;
  navigator.clipboard.writeText(el.textContent).then(() => {
    const b = document.getElementById(btn);
    if (b) { b.textContent = 'Copied!'; setTimeout(() => b.textContent = btn === 'btn-copy' ? 'Copy' : 'Copy CLI', 2000); }
  });
}
document.getElementById('btn-copy')?.addEventListener('click', () => copyText('query-output', 'btn-copy'));
document.getElementById('btn-copy-cli')?.addEventListener('click', () => copyText('cli-output', 'btn-copy-cli'));

// Add datalist for field suggestions
const dl = document.createElement('datalist');
dl.id = 'cw-fields-list';
['@message','@level','@timestamp','@requestId','@logStream','@log','level','statusCode','requestId','errorCode','errorType','functionName','duration'].forEach(f => {
  const opt = document.createElement('option');
  opt.value = f;
  dl.appendChild(opt);
});
document.body.appendChild(dl);

renderFilters();
</script>
