---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UnixTimestamp from '../../components/UnixTimestamp.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a Unix timestamp?", answer: "A Unix timestamp (also called epoch time) is the number of seconds that have elapsed since January 1, 1970, 00:00:00 UTC — known as the Unix Epoch. It is a timezone-independent way to represent a specific moment in time, widely used in programming, databases, and APIs." },
  { question: "How do I convert a Unix timestamp to a human-readable date?", answer: "Paste or type the Unix timestamp (e.g., 1711238400) into the converter field. The tool instantly shows the equivalent date and time in UTC, your local timezone, and ISO 8601 format." },
  { question: "What is the difference between seconds and milliseconds timestamps?", answer: "Classic Unix timestamps count seconds since the epoch (10 digits, e.g., 1711238400). JavaScript and many modern APIs use milliseconds (13 digits, e.g., 1711238400000). This tool auto-detects which format you're using and converts both." },
  { question: "What does epoch time mean?", answer: "Epoch refers to the starting reference point for a time system. The Unix epoch is January 1, 1970, 00:00:00 UTC. A Unix timestamp is simply how many seconds have passed since that moment. The word 'epoch' comes from its use as a fixed point from which time is measured." },
  { question: "Why do developers use Unix timestamps instead of formatted dates?", answer: "Unix timestamps are timezone-agnostic, compact, and trivially comparable with simple arithmetic. Storing timestamps as integers avoids timezone ambiguities during sorting, filtering, or calculations. When displaying to users, you convert to local time — but the stored value stays universal." },
];
---

<BaseLayout
  title="Unix Timestamp Converter — Epoch to Date, Date to Epoch"
  description="Unix timestamp converter. Convert epoch to UTC, local time, and ISO 8601, or dates to Unix time. Live current timestamp, auto-detects seconds vs milliseconds. Runs in your browser."
  tool="Unix Timestamp Converter, Epoch Converter, Timestamp to Date, Epoch to Human Readable, Unix Time Converter, Milliseconds Timestamp, ISO 8601 Converter"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Unix Timestamp Converter</h1>
  <p class="text-text-muted mb-4">Convert between Unix epoch timestamps and human-readable dates. See the live current timestamp, convert to UTC or local time formats, and decode any timestamp instantly — auto-detects seconds vs milliseconds. All in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <UnixTimestamp client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Unix Timestamp Converter" relatedTags={['datetime', 'timestamp', 'epoch', 'api', 'debugging']} />
</BaseLayout>
