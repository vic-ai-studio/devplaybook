---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UnixTimestamp from '../../components/UnixTimestamp.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Unix Timestamp Converter"
  description="Convert Unix timestamps to human-readable dates and vice versa. See the live current timestamp, convert to UTC or local time, ISO 8601, and more. Runs entirely in your browser."
  tool="Unix Timestamp Converter, Epoch Converter, Timestamp to Date"
>
  <h1 class="text-3xl font-bold mb-2">Unix Timestamp Converter</h1>
  <p class="text-text-muted mb-8">Convert between Unix epoch timestamps and human-readable dates. See the live current timestamp, convert to UTC or local time formats, and decode any timestamp instantly — all in your browser.</p>
  <UnixTimestamp client:only="preact" />
  <ToolPageCta currentTool="Unix Timestamp Converter" relatedTags={['datetime', 'timestamp', 'epoch', 'api', 'debugging']} />
</BaseLayout>
