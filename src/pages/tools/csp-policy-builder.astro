---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is Content-Security-Policy?", answer: "CSP is an HTTP response header that tells browsers which sources are allowed to load scripts, styles, images, fonts, and other resources. A well-configured CSP is one of the most effective defenses against XSS attacks — even if an attacker injects a script tag, the browser won't execute it unless the source is allowlisted." },
  { question: "What is default-src?", answer: "default-src is the fallback for all resource fetch directives (script-src, style-src, img-src, etc.). Any directive you don't explicitly set falls back to default-src. Always set a restrictive default-src ('self' or 'none') and only loosen specific directives you need." },
  { question: "Why is 'unsafe-inline' dangerous?", answer: "'unsafe-inline' allows inline <script> and <style> blocks. This defeats XSS protection because injected inline scripts execute freely. Use nonces (a random per-request value in script-src 'nonce-{value}') or hashes (sha256-{hash}) instead. For styles, move inline styles to external .css files." },
  { question: "What is report-uri / report-to?", answer: "report-uri (legacy) and report-to (modern) tell the browser where to POST violation reports when a resource is blocked by CSP. Use Content-Security-Policy-Report-Only header with report-to while auditing — no resources are blocked, only violations reported. Then switch to Content-Security-Policy when confident." },
  { question: "How do I test CSP without breaking my site?", answer: "Use the Content-Security-Policy-Report-Only header first. Set report-to to a service like report-uri.com or your own endpoint. Monitor violations for 1-2 weeks. Iterate until violations stop, then switch to enforcing CSP. The Report-Only header never blocks anything — safe to test in production." },
];
---

<BaseLayout
  title="CSP Policy Builder — Build Content-Security-Policy Headers Interactively"
  description="Build a Content-Security-Policy header interactively. Configure script-src, style-src, img-src, connect-src, and more. Get your header string plus meta tag and Nginx/Express snippets."
  tool="CSP Policy Builder, Content Security Policy Generator, CSP Header Builder, CSP Generator, XSS Protection Header"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">CSP Policy Builder</h1>
  <p class="text-text-muted mb-4">Build your Content-Security-Policy header directive by directive. Each setting shows an explanation of what it does and the security trade-off.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All major CSP directives</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Report-Only mode</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Express, Nginx & meta tag output</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
    <!-- Config Panel -->
    <div class="space-y-4">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Preset</h2>
        <div class="flex flex-wrap gap-2">
          <button class="preset-btn text-xs px-3 py-1.5 border border-border rounded-lg hover:bg-bg" data-preset="strict">Strict</button>
          <button class="preset-btn text-xs px-3 py-1.5 border border-border rounded-lg hover:bg-bg" data-preset="moderate">Moderate</button>
          <button class="preset-btn text-xs px-3 py-1.5 border border-border rounded-lg hover:bg-bg" data-preset="spa">SPA (React/Vue)</button>
          <button class="preset-btn text-xs px-3 py-1.5 border border-border rounded-lg hover:bg-bg" data-preset="blank">Blank</button>
        </div>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5 space-y-4">
        <h2 class="text-base font-semibold">Directives</h2>

        <div id="directives-list" class="space-y-3">
          <!-- Dynamically rendered -->
        </div>

        <div class="pt-2">
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="report-only" />
            <span>Use <code class="text-xs font-mono">Content-Security-Policy-Report-Only</code> (non-blocking)</span>
          </label>
        </div>

        <div>
          <label class="block text-sm font-medium mb-1">report-uri (optional)</label>
          <input id="report-uri" type="text" placeholder="https://report.example.com/csp"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>
      </div>
    </div>

    <!-- Output Panel -->
    <div class="space-y-4">
      <!-- Security Score -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold">Security Score</h2>
          <span id="score-label" class="text-sm font-bold">—</span>
        </div>
        <div class="h-2 bg-bg rounded-full overflow-hidden">
          <div id="score-bar" class="h-full rounded-full transition-all duration-300" style="width:0%"></div>
        </div>
        <div id="score-issues" class="mt-3 space-y-1 text-xs text-text-muted"></div>
      </div>

      <!-- Header Output -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold">Header</h2>
          <button id="copy-header" class="text-xs text-text-muted border border-border px-2 py-1 rounded hover:bg-bg transition-colors">Copy</button>
        </div>
        <pre id="output-header" class="text-xs font-mono bg-bg rounded-lg p-3 overflow-auto text-text-muted whitespace-pre-wrap break-all"></pre>
      </div>

      <!-- Code Snippets -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex gap-2 mb-3 border-b border-border pb-2">
          <button class="snippet-tab text-xs px-2 py-1 rounded font-mono bg-primary text-white" data-snippet="express">Express</button>
          <button class="snippet-tab text-xs px-2 py-1 rounded font-mono text-text-muted border border-border hover:bg-bg" data-snippet="nginx">Nginx</button>
          <button class="snippet-tab text-xs px-2 py-1 rounded font-mono text-text-muted border border-border hover:bg-bg" data-snippet="meta">Meta Tag</button>
        </div>
        <div class="flex items-center justify-between mb-2">
          <button id="copy-snippet" class="text-xs text-text-muted border border-border px-2 py-1 rounded hover:bg-bg transition-colors ml-auto">Copy</button>
        </div>
        <pre id="output-snippet" class="text-xs font-mono bg-bg rounded-lg p-3 overflow-auto text-text-muted whitespace-pre max-h-48"></pre>
      </div>
    </div>
  </div>

  <AdUnit slot="in-content" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CSP Policy Builder" relatedTags={['security', 'web', 'http', 'xss', 'frontend']} />
</BaseLayout>

<script>
const DIRECTIVES = [
  { id: 'default-src', label: 'default-src', desc: 'Fallback for all fetch directives not explicitly set.', default: "'self'" },
  { id: 'script-src', label: 'script-src', desc: 'Allowed sources for JavaScript.', default: '' },
  { id: 'style-src', label: 'style-src', desc: 'Allowed sources for CSS.', default: '' },
  { id: 'img-src', label: 'img-src', desc: 'Allowed sources for images.', default: '' },
  { id: 'font-src', label: 'font-src', desc: 'Allowed sources for fonts.', default: '' },
  { id: 'connect-src', label: 'connect-src', desc: 'Allowed fetch/XHR/WebSocket destinations.', default: '' },
  { id: 'frame-src', label: 'frame-src', desc: 'Allowed sources for <frame> and <iframe>.', default: '' },
  { id: 'object-src', label: 'object-src', desc: 'Allowed sources for <object>, <embed>, <applet>.', default: '' },
  { id: 'base-uri', label: 'base-uri', desc: 'Restricts URLs for <base> element.', default: '' },
  { id: 'form-action', label: 'form-action', desc: 'Restricts form submission targets.', default: '' },
  { id: 'frame-ancestors', label: 'frame-ancestors', desc: "Controls who can embed this page in <iframe>. Replaces X-Frame-Options.", default: '' },
  { id: 'upgrade-insecure-requests', label: 'upgrade-insecure-requests', desc: 'Upgrades all HTTP requests to HTTPS automatically.', toggle: true, default: '' },
  { id: 'block-all-mixed-content', label: 'block-all-mixed-content', desc: 'Blocks all HTTP resources on HTTPS pages.', toggle: true, default: '' },
];

const PRESETS: Record<string, Record<string, string>> = {
  strict: {
    'default-src': "'none'",
    'script-src': "'self'",
    'style-src': "'self'",
    'img-src': "'self' data:",
    'font-src': "'self'",
    'connect-src': "'self'",
    'frame-src': "'none'",
    'object-src': "'none'",
    'base-uri': "'self'",
    'form-action': "'self'",
    'frame-ancestors': "'none'",
    'upgrade-insecure-requests': 'on',
  },
  moderate: {
    'default-src': "'self'",
    'script-src': "'self' 'unsafe-inline'",
    'style-src': "'self' 'unsafe-inline'",
    'img-src': "'self' data: https:",
    'font-src': "'self' https://fonts.gstatic.com",
    'connect-src': "'self'",
    'object-src': "'none'",
    'upgrade-insecure-requests': 'on',
  },
  spa: {
    'default-src': "'self'",
    'script-src': "'self' 'unsafe-eval'",
    'style-src': "'self' 'unsafe-inline'",
    'img-src': "'self' data: blob:",
    'connect-src': "'self' https://api.example.com wss://api.example.com",
    'font-src': "'self' data:",
    'object-src': "'none'",
    'frame-ancestors': "'none'",
  },
  blank: {},
};

let currentSnippet = 'express';

function renderDirectives() {
  const container = document.getElementById('directives-list')!;
  container.innerHTML = DIRECTIVES.map(d => {
    if (d.toggle) {
      return `<div class="flex items-start gap-2">
        <input type="checkbox" id="dir-${d.id}" class="directive-toggle mt-0.5 flex-shrink-0" data-id="${d.id}" />
        <div>
          <label for="dir-${d.id}" class="text-sm font-mono font-medium cursor-pointer">${d.label}</label>
          <p class="text-xs text-text-muted">${d.desc}</p>
        </div>
      </div>`;
    }
    return `<div>
      <label class="block text-xs font-mono font-medium mb-1">${d.label}</label>
      <input type="text" id="dir-${d.id}" placeholder="e.g. 'self' https://cdn.example.com"
        class="w-full bg-bg border border-border rounded-lg px-2 py-1.5 text-xs font-mono focus:outline-none focus:border-primary directive-input" data-id="${d.id}" />
      <p class="text-xs text-text-muted mt-0.5">${d.desc}</p>
    </div>`;
  }).join('');

  container.querySelectorAll('.directive-input, .directive-toggle').forEach(el => {
    el.addEventListener('input', update);
    el.addEventListener('change', update);
  });
}

function buildPolicy(): string {
  const parts: string[] = [];
  DIRECTIVES.forEach(d => {
    const el = document.getElementById(`dir-${d.id}`) as HTMLInputElement;
    if (!el) return;
    if (d.toggle) {
      if (el.checked) parts.push(d.id);
    } else {
      const val = el.value.trim();
      if (val) parts.push(`${d.id} ${val}`);
    }
  });
  const reportUri = (document.getElementById('report-uri') as HTMLInputElement).value.trim();
  if (reportUri) parts.push(`report-uri ${reportUri}`);
  return parts.join('; ');
}

function scorePolicy(policy: string): { score: number; issues: string[] } {
  const issues: string[] = [];
  let score = 100;
  if (!policy) return { score: 0, issues: ['Policy is empty.'] };
  if (policy.includes("'unsafe-eval'")) { score -= 20; issues.push("⚠ 'unsafe-eval' enabled — allows eval(), a common XSS vector."); }
  if (policy.includes("'unsafe-inline'") && policy.includes('script-src')) { score -= 20; issues.push("⚠ 'unsafe-inline' in script-src — inline scripts can execute. Use nonces instead."); }
  if (!policy.includes('default-src') && !policy.includes('script-src')) { score -= 15; issues.push('⚠ No default-src or script-src — all script sources are allowed.'); }
  if (policy.includes('object-src') && !policy.includes("object-src 'none'")) { score -= 10; issues.push('⚠ object-src allows plugins. Set to none unless required.'); }
  if (!policy.includes('frame-ancestors')) { score -= 5; issues.push('ℹ frame-ancestors not set — consider adding to prevent clickjacking.'); }
  if (!policy.includes('upgrade-insecure-requests')) { score -= 5; issues.push('ℹ upgrade-insecure-requests not set — HTTP resources may load on HTTPS pages.'); }
  return { score: Math.max(0, score), issues };
}

function update() {
  const policy = buildPolicy();
  const reportOnly = (document.getElementById('report-only') as HTMLInputElement).checked;
  const headerName = reportOnly ? 'Content-Security-Policy-Report-Only' : 'Content-Security-Policy';
  const headerStr = `${headerName}: ${policy || "(empty — add directives above)"}`;

  document.getElementById('output-header')!.textContent = headerStr;

  const { score, issues } = scorePolicy(policy);
  const color = score >= 80 ? '#22c55e' : score >= 50 ? '#eab308' : '#ef4444';
  const label = score >= 80 ? 'Strong' : score >= 50 ? 'Moderate' : 'Weak';
  document.getElementById('score-label')!.textContent = `${score}/100 — ${label}`;
  (document.getElementById('score-label')! as HTMLElement).style.color = color;
  const bar = document.getElementById('score-bar')!;
  bar.style.width = score + '%';
  bar.style.background = color;
  document.getElementById('score-issues')!.innerHTML = issues.map(i => `<div>${i}</div>`).join('');

  updateSnippet(policy, headerName);
}

function updateSnippet(policy: string, headerName: string) {
  let code = '';
  if (currentSnippet === 'express') {
    code = `// Express.js (helmet recommended)
const helmet = require('helmet');
app.use(helmet.contentSecurityPolicy({
  useDefaults: false,
  directives: {
    // parsed from your policy:
    ${policy.split(';').filter(Boolean).map(p => {
      const parts = p.trim().split(/\s+/);
      const key = parts[0].replace(/-([a-z])/g, (_:string, c:string) => c.toUpperCase());
      const vals = parts.slice(1);
      if (vals.length === 0) return `"${key}": []`;
      return `"${key}": [${vals.map(v => `"${v}"`).join(', ')}]`;
    }).join(',\n    ')},
  },
  reportOnly: ${(document.getElementById('report-only') as HTMLInputElement).checked},
}));`;
  } else if (currentSnippet === 'nginx') {
    code = `# nginx.conf
add_header ${headerName} "${policy}" always;`;
  } else if (currentSnippet === 'meta') {
    code = `<!-- Note: frame-ancestors and report-uri don't work via meta tag -->
<meta http-equiv="Content-Security-Policy"
  content="${policy}">`;
  }
  document.getElementById('output-snippet')!.textContent = code;
}

document.querySelectorAll('.preset-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const preset = PRESETS[(btn as HTMLElement).dataset.preset || 'blank'];
    DIRECTIVES.forEach(d => {
      const el = document.getElementById(`dir-${d.id}`) as HTMLInputElement;
      if (!el) return;
      if (d.toggle) {
        el.checked = !!(preset[d.id]);
      } else {
        el.value = preset[d.id] || '';
      }
    });
    update();
  });
});

document.querySelectorAll('.snippet-tab').forEach(btn => {
  btn.addEventListener('click', () => {
    currentSnippet = (btn as HTMLElement).dataset.snippet || 'express';
    document.querySelectorAll('.snippet-tab').forEach(b => {
      b.className = 'snippet-tab text-xs px-2 py-1 rounded font-mono text-text-muted border border-border hover:bg-bg';
    });
    btn.className = 'snippet-tab text-xs px-2 py-1 rounded font-mono bg-primary text-white';
    update();
  });
});

document.getElementById('copy-header')!.addEventListener('click', () => {
  navigator.clipboard.writeText(document.getElementById('output-header')!.textContent || '');
});
document.getElementById('copy-snippet')!.addEventListener('click', () => {
  navigator.clipboard.writeText(document.getElementById('output-snippet')!.textContent || '');
});
document.getElementById('report-only')!.addEventListener('change', update);
document.getElementById('report-uri')!.addEventListener('input', update);

renderDirectives();
// Load moderate preset by default
(document.querySelector('[data-preset="moderate"]') as HTMLElement)?.click();
</script>
