---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RedisCLISimulator from '../../components/RedisCLISimulator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What Redis commands are supported?", answer: "The tester supports Strings (SET, GET, DEL, EXISTS, EXPIRE, TTL, KEYS, TYPE, INCR, DECR), Lists (LPUSH, RPUSH, LRANGE, LLEN), Hashes (HSET, HGET, HGETALL, HDEL, HKEYS, HVALS), Sets (SADD, SMEMBERS, SCARD, SISMEMBER), and general commands (PING, ECHO, DBSIZE, FLUSHALL, HELP). Type HELP to see the full list." },
  { question: "Does this connect to a real Redis server?", answer: "No. All data is stored in-memory in your browser tab. Nothing is sent to any server. This is a simulator designed for learning Redis commands and prototyping data structures without needing a Redis installation." },
  { question: "Can I use EXPIRE and TTL?", answer: "Yes. Use EXPIRE key seconds to set a TTL, and TTL key to check how many seconds remain. The simulator tracks expiry times and returns -2 for expired or non-existent keys, and -1 for keys with no expiry, matching real Redis behavior." },
  { question: "How do I see all my keys?", answer: "Use the KEYS * command to list all keys in the current session. You can also use KEYS prefix* for pattern matching. Use DBSIZE to get the total count of keys." },
  { question: "What is the HSET / HGET workflow for hash maps?", answer: "Use HSET user name Alice age 30 to set multiple hash fields at once. Then HGET user name returns 'Alice', HGETALL user returns all field-value pairs, and HKEYS user returns just the field names. This mirrors Redis hash map behavior exactly." },
];
---

<BaseLayout
  title="Redis Command Tester — Test Redis Commands Online Free"
  description="Test Redis commands in your browser with no install needed. Simulate SET, GET, HSET, LPUSH, EXPIRE, TTL and more. Color-coded output, command reference sidebar, and example commands. Free online Redis playground."
  tool="Redis command tester, Redis simulator online, test Redis commands, Redis playground, Redis CLI browser, Redis learning tool"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Redis Command Tester",
    "url": "https://devplaybook.cc/tools/redis-command-tester",
    "description": "Test Redis commands in your browser with no install needed. Simulate SET, GET, HSET, LPUSH, EXPIRE, TTL and more with color-coded output.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Redis Command Tester</h1>
  <p class="text-text-muted mb-4">
    Test Redis commands directly in your browser — no install, no server required. Supports
    <code class="font-mono bg-surface px-1 rounded text-sm">SET</code>,
    <code class="font-mono bg-surface px-1 rounded text-sm">GET</code>,
    <code class="font-mono bg-surface px-1 rounded text-sm">HSET</code>,
    <code class="font-mono bg-surface px-1 rounded text-sm">LPUSH</code>,
    <code class="font-mono bg-surface px-1 rounded text-sm">EXPIRE</code>,
    <code class="font-mono bg-surface px-1 rounded text-sm">TTL</code>, and more.
    Results are color-coded, data lives in-memory in your tab. Type <code class="font-mono bg-surface px-1 rounded text-sm">HELP</code> for all supported commands.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No Redis install needed</span>
  </div>
  <RedisCLISimulator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Redis Command Tester" relatedTags={['redis', 'database', 'cache', 'cli', 'developer-tools', 'backend']} />
</BaseLayout>
