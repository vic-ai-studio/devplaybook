---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is semantic versioning?",
    answer: "Semantic versioning (SemVer) uses a three-part version number: MAJOR.MINOR.PATCH. MAJOR increments for breaking changes (incompatible API changes), MINOR for new backwards-compatible features, and PATCH for backwards-compatible bug fixes. For example, bumping from v2.0.0 to v3.0.0 signals breaking changes, while v2.1.0 signals new non-breaking features."
  },
  {
    question: "What makes an API change breaking?",
    answer: "A breaking change forces API consumers to update their integration code or it will fail. Common breaking changes include: removing or renaming an endpoint, changing an HTTP method, removing required or optional fields from a response, adding required request parameters, changing authentication schemes, or altering error response formats. Adding optional fields or new endpoints is typically non-breaking."
  },
  {
    question: "What is the Keep a Changelog format?",
    answer: "Keep a Changelog (keepachangelog.com) is a standard changelog format that organises changes under a version heading by change type: Added, Changed, Deprecated, Removed, Fixed, and Security. It prioritises human readability and follows semantic versioning conventions. It is one of the most widely adopted changelog standards in open-source projects."
  },
  {
    question: "How often should I release API changelogs?",
    answer: "Best practice is to maintain a living changelog updated with every release. For production APIs, publish changelogs with each versioned release. For breaking changes specifically, notify consumers at least 2–4 weeks in advance, keep the old version alive during a deprecation window (typically 3–6 months), and provide migration guides. Never silently break an API."
  },
  {
    question: "What should be in a migration guide?",
    answer: "A migration guide for breaking changes should include: what changed and why, the old behaviour vs new behaviour with code examples, step-by-step migration instructions, a timeline for when the old behaviour will be fully removed, and contact or support information. The goal is to make upgrading as frictionless as possible for consumers."
  }
];
---

<BaseLayout
  title="API Changelog Generator — Generate Structured API Release Notes"
  description="Generate structured API changelogs from a list of changes. Output in Markdown, JSON, and Keep a Changelog format. Highlights breaking changes, colour-coded by type. Runs 100% in your browser."
  tool="API Changelog Generator, API release notes, API versioning, Keep a Changelog, breaking changes, API changelog markdown, semantic versioning, API documentation"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "API Changelog Generator",
    "url": "https://devplaybook.cc/tools/api-changelog-generator",
    "description": "Generate structured changelogs from API changes in Markdown, JSON, and Keep a Changelog format. Highlights breaking changes and supports semantic versioning.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">API Changelog Generator</h1>
  <p class="text-text-muted mb-4">Add your API changes, set a version and date, then generate a professional changelog in Markdown, JSON, or Keep a Changelog format. Breaking changes are highlighted automatically.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Markdown, JSON &amp; Keep a Changelog output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Breaking changes highlighted</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy to clipboard</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs entirely in your browser</span>
  </div>

  <!-- Version / Date row -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
    <div>
      <label class="block text-sm font-medium mb-2">Version</label>
      <input id="cl-version" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary font-mono" placeholder="v2.1.0" value="v2.1.0" />
    </div>
    <div>
      <label class="block text-sm font-medium mb-2">Release Date</label>
      <input id="cl-date" type="date" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
    </div>
    <div>
      <label class="block text-sm font-medium mb-2">API Name (optional)</label>
      <input id="cl-api-name" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="Payments API" value="Payments API" />
    </div>
  </div>

  <!-- Changes list -->
  <div class="mb-4">
    <div class="flex items-center justify-between mb-3">
      <label class="text-sm font-medium">API Changes</label>
      <button id="btn-add-change" class="flex items-center gap-1.5 px-3 py-1.5 bg-primary text-white rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors">
        <span class="text-base leading-none">+</span> Add Change
      </button>
    </div>
    <div id="changes-list" class="space-y-3"></div>
  </div>

  <div class="flex gap-3 mb-6 flex-wrap">
    <button id="btn-generate" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Generate Changelog</button>
    <button id="btn-load-example" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Load Example</button>
    <button id="btn-clear-all" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Clear All</button>
  </div>

  <!-- Output -->
  <div id="output-section" class="hidden">
    <div class="mb-4">
      <h2 class="text-lg font-semibold">Generated Changelog</h2>
    </div>

    <!-- Breaking changes alert -->
    <div id="breaking-alert" class="hidden mb-4 p-4 bg-red-500/10 border border-red-500/30 rounded-lg">
      <div class="flex items-center gap-2 text-red-400 font-semibold text-sm mb-1">
        <span>&#9888;</span> Breaking Changes Detected
      </div>
      <p id="breaking-alert-text" class="text-sm text-red-300"></p>
    </div>

    <!-- Format tab switcher -->
    <div class="flex gap-1 mb-4 border-b border-border">
      <button data-fmt="markdown" class="fmt-tab px-4 py-2 text-sm font-medium border-b-2 border-primary text-primary transition-colors">Markdown</button>
      <button data-fmt="json" class="fmt-tab px-4 py-2 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-foreground transition-colors">JSON</button>
      <button data-fmt="keepachangelog" class="fmt-tab px-4 py-2 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-foreground transition-colors">Keep a Changelog</button>
    </div>

    <div id="fmt-panel-markdown" class="fmt-panel bg-bg-card border border-border rounded-lg p-4">
      <div class="flex justify-end mb-2">
        <button class="copy-output-btn px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-panel="markdown">Copy</button>
      </div>
      <pre id="output-markdown" class="font-mono text-sm whitespace-pre-wrap break-words text-foreground overflow-x-auto max-h-96 overflow-y-auto"></pre>
    </div>
    <div id="fmt-panel-json" class="fmt-panel hidden bg-bg-card border border-border rounded-lg p-4">
      <div class="flex justify-end mb-2">
        <button class="copy-output-btn px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-panel="json">Copy</button>
      </div>
      <pre id="output-json" class="font-mono text-sm whitespace-pre-wrap break-words text-green-300 overflow-x-auto max-h-96 overflow-y-auto"></pre>
    </div>
    <div id="fmt-panel-keepachangelog" class="fmt-panel hidden bg-bg-card border border-border rounded-lg p-4">
      <div class="flex justify-end mb-2">
        <button class="copy-output-btn px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-panel="keepachangelog">Copy</button>
      </div>
      <pre id="output-keepachangelog" class="font-mono text-sm whitespace-pre-wrap break-words text-blue-300 overflow-x-auto max-h-96 overflow-y-auto"></pre>
    </div>
  </div>

  <ToolPageCta />
  <FaqSection faq={faq} />
</BaseLayout>

<script>
const TYPE_CONFIG = {
  breaking:   { label: 'Breaking',   color: 'text-red-400',     bg: 'bg-red-500/10',     border: 'border-red-500/30',     emoji: '🔴' },
  added:      { label: 'Added',      color: 'text-green-400',   bg: 'bg-green-500/10',   border: 'border-green-500/30',   emoji: '🟢' },
  deprecated: { label: 'Deprecated', color: 'text-yellow-400',  bg: 'bg-yellow-500/10',  border: 'border-yellow-500/30',  emoji: '🟡' },
  removed:    { label: 'Removed',    color: 'text-gray-400',    bg: 'bg-gray-500/10',    border: 'border-gray-500/30',    emoji: '⚫' },
  changed:    { label: 'Changed',    color: 'text-blue-400',    bg: 'bg-blue-500/10',    border: 'border-blue-500/30',    emoji: '🔵' },
  fixed:      { label: 'Fixed',      color: 'text-emerald-400', bg: 'bg-emerald-500/10', border: 'border-emerald-500/30', emoji: '🟢' },
};

const METHODS = ['any','GET','POST','PUT','DELETE','PATCH','HEAD','OPTIONS'];
const COMPONENTS = ['endpoint','schema','header','auth','parameter','response','webhook'];

let changes = [];
let idSeq = 0;
let currentFmt = 'markdown';

// Set today's date
const dateEl = document.getElementById('cl-date');
if (dateEl) dateEl.value = new Date().toISOString().slice(0, 10);

function esc(str) {
  return (str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function renderChanges() {
  const list = document.getElementById('changes-list');
  if (!list) return;
  list.innerHTML = '';
  if (changes.length === 0) {
    list.innerHTML = '<p class="text-sm text-text-muted text-center py-8 border border-dashed border-border rounded-lg">No changes yet. Click &quot;+ Add Change&quot; to begin.</p>';
    return;
  }
  changes.forEach((ch, idx) => {
    const cfg = TYPE_CONFIG[ch.type] || TYPE_CONFIG.changed;
    const isBreaking = ch.type === 'breaking';
    const div = document.createElement('div');
    div.className = `border rounded-lg p-4 ${isBreaking ? 'border-red-500/40 bg-red-500/5' : 'border-border bg-bg-card'}`;
    div.dataset.idx = idx;
    div.innerHTML = `
      <div class="flex items-start justify-between gap-2 mb-3">
        <div class="flex items-center gap-2 flex-wrap">
          <span class="text-xs font-semibold px-2 py-0.5 rounded-full ${cfg.bg} ${cfg.border} border ${cfg.color}">${cfg.emoji} ${cfg.label}</span>
          ${ch.method !== 'any' ? `<span class="text-xs font-mono px-2 py-0.5 rounded bg-bg-card border border-border text-text-muted">${ch.method}</span>` : ''}
          ${ch.path ? `<span class="text-xs font-mono text-text-muted truncate max-w-xs">${esc(ch.path)}</span>` : ''}
        </div>
        <button class="btn-remove-change flex-shrink-0 text-text-muted hover:text-red-400 transition-colors text-xl leading-none" data-idx="${idx}" aria-label="Remove">&#215;</button>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-3">
        <div>
          <label class="block text-xs text-text-muted mb-1">Type</label>
          <select class="ch-type w-full bg-bg-card border border-border rounded p-2 text-sm focus:outline-none focus:border-primary" data-idx="${idx}">
            ${Object.entries(TYPE_CONFIG).map(([k,v]) => `<option value="${k}"${ch.type===k?' selected':''}>${v.emoji} ${v.label}</option>`).join('')}
          </select>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">Component</label>
          <select class="ch-component w-full bg-bg-card border border-border rounded p-2 text-sm focus:outline-none focus:border-primary" data-idx="${idx}">
            ${COMPONENTS.map(c => `<option value="${c}"${ch.component===c?' selected':''}>${c.charAt(0).toUpperCase()+c.slice(1)}</option>`).join('')}
          </select>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">HTTP Method</label>
          <select class="ch-method w-full bg-bg-card border border-border rounded p-2 text-sm focus:outline-none focus:border-primary" data-idx="${idx}">
            ${METHODS.map(m => `<option value="${m}"${ch.method===m?' selected':''}>${m === 'any' ? 'ANY' : m}</option>`).join('')}
          </select>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">Path / Name</label>
          <input class="ch-path w-full bg-bg-card border border-border rounded p-2 text-sm font-mono focus:outline-none focus:border-primary" placeholder="/v2/payments" value="${esc(ch.path)}" data-idx="${idx}" />
        </div>
      </div>
      <div class="mb-3">
        <label class="block text-xs text-text-muted mb-1">Description</label>
        <input class="ch-desc w-full bg-bg-card border border-border rounded p-2 text-sm focus:outline-none focus:border-primary" placeholder="Describe what changed..." value="${esc(ch.desc)}" data-idx="${idx}" />
      </div>
      ${isBreaking ? `
      <div>
        <label class="block text-xs text-text-muted mb-1">Migration Guide <span class="text-red-400">(required for breaking changes)</span></label>
        <textarea class="ch-migration w-full bg-bg-card border border-border rounded p-2 text-sm focus:outline-none focus:border-primary resize-none" rows="2" placeholder="Steps consumers must follow to migrate..." data-idx="${idx}">${esc(ch.migration || '')}</textarea>
      </div>` : ''}
    `;
    list.appendChild(div);
  });

  // Bind events
  list.querySelectorAll('.btn-remove-change').forEach(btn => {
    btn.addEventListener('click', () => { changes.splice(+btn.dataset.idx, 1); renderChanges(); });
  });
  list.querySelectorAll('.ch-type').forEach(sel => {
    sel.addEventListener('change', () => { changes[+sel.dataset.idx].type = sel.value; renderChanges(); });
  });
  list.querySelectorAll('.ch-component').forEach(sel => {
    sel.addEventListener('change', () => { changes[+sel.dataset.idx].component = sel.value; });
  });
  list.querySelectorAll('.ch-method').forEach(sel => {
    sel.addEventListener('change', () => { changes[+sel.dataset.idx].method = sel.value; renderChanges(); });
  });
  list.querySelectorAll('.ch-path').forEach(inp => {
    inp.addEventListener('input', () => { changes[+inp.dataset.idx].path = inp.value; });
  });
  list.querySelectorAll('.ch-desc').forEach(inp => {
    inp.addEventListener('input', () => { changes[+inp.dataset.idx].desc = inp.value; });
  });
  list.querySelectorAll('.ch-migration').forEach(ta => {
    ta.addEventListener('input', () => { changes[+ta.dataset.idx].migration = ta.value; });
  });
}

function addChange(overrides = {}) {
  changes.push({ _id: ++idSeq, type: 'added', component: 'endpoint', method: 'any', path: '', desc: '', migration: '', ...overrides });
  renderChanges();
}

document.getElementById('btn-add-change')?.addEventListener('click', () => addChange());

document.getElementById('btn-clear-all')?.addEventListener('click', () => {
  if (changes.length > 0 && !confirm('Clear all changes?')) return;
  changes = [];
  renderChanges();
  document.getElementById('output-section').classList.add('hidden');
});

document.getElementById('btn-load-example')?.addEventListener('click', () => {
  changes = [];
  const vEl = document.getElementById('cl-version');
  const nEl = document.getElementById('cl-api-name');
  if (vEl) vEl.value = 'v3.0.0';
  if (nEl) nEl.value = 'Payments API';
  addChange({ type: 'breaking', component: 'auth', method: 'any', path: '/v2/auth/token', desc: 'OAuth token endpoint moved from /v2/auth/token to /v3/oauth/token. Legacy endpoint returns 410 after 2026-06-01.', migration: 'Update your token request URL from /v2/auth/token to /v3/oauth/token. The response schema is unchanged.' });
  addChange({ type: 'breaking', component: 'schema', method: 'POST', path: '/v3/payments', desc: 'amount field now requires integer cents instead of float dollars. Sending 9.99 must become 999.', migration: 'Multiply all amount values by 100 before sending. Update response parsing to divide by 100 for display.' });
  addChange({ type: 'added', component: 'endpoint', method: 'GET', path: '/v3/payments/{id}/timeline', desc: 'New timeline endpoint returns full event history including status transitions, webhooks, and disputes.' });
  addChange({ type: 'added', component: 'parameter', method: 'GET', path: '/v3/payments', desc: 'Added cursor-based pagination via cursor and limit query parameters. Responses include next_cursor field.' });
  addChange({ type: 'deprecated', component: 'parameter', method: 'GET', path: '/v3/payments', desc: 'page and per_page query parameters deprecated in favour of cursor-based pagination. Removed in v4.' });
  addChange({ type: 'fixed', component: 'response', method: 'POST', path: '/v3/refunds', desc: 'Fixed edge case where partial refund on a disputed charge returned 500 instead of 409 conflict.' });
  addChange({ type: 'changed', component: 'header', method: 'any', path: 'X-Rate-Limit-Reset', desc: 'X-Rate-Limit-Reset header now returns Unix timestamp (integer) instead of RFC 1123 date string.' });
});

document.getElementById('btn-generate')?.addEventListener('click', generateChangelog);

function getLiveChanges() {
  return changes.map((ch, idx) => {
    const g = (sel) => document.querySelector(`${sel}[data-idx="${idx}"]`);
    return {
      ...ch,
      type: g('.ch-type')?.value || ch.type,
      component: g('.ch-component')?.value || ch.component,
      method: g('.ch-method')?.value || ch.method,
      path: g('.ch-path')?.value ?? ch.path,
      desc: g('.ch-desc')?.value ?? ch.desc,
      migration: g('.ch-migration')?.value ?? ch.migration,
    };
  });
}

function generateChangelog() {
  const version = (document.getElementById('cl-version')?.value || 'v1.0.0').trim();
  const date = (document.getElementById('cl-date')?.value || new Date().toISOString().slice(0,10)).trim();
  const apiName = (document.getElementById('cl-api-name')?.value || 'API').trim();

  if (changes.length === 0) { alert('Add at least one change first.'); return; }

  const live = getLiveChanges();
  const breaking = live.filter(c => c.type === 'breaking');
  const typeOrder = ['breaking','added','changed','deprecated','removed','fixed'];

  function groupBy(arr) {
    const g = {};
    arr.forEach(c => { if (!g[c.type]) g[c.type] = []; g[c.type].push(c); });
    return g;
  }

  // Markdown
  let md = `# ${apiName} Changelog\n\n## [${version}] — ${date}\n\n`;
  if (breaking.length) md += `> ⚠️ **${breaking.length} breaking change${breaking.length > 1 ? 's' : ''}** in this release. Review migration guides before upgrading.\n\n`;
  const grouped = groupBy(live);
  typeOrder.forEach(t => {
    if (!grouped[t]) return;
    const cfg = TYPE_CONFIG[t];
    md += `### ${cfg.emoji} ${cfg.label}\n\n`;
    grouped[t].forEach(c => {
      const m = c.method !== 'any' ? `\`${c.method}\` ` : '';
      const p = c.path ? `\`${c.path}\` — ` : '';
      md += `- **[${c.component.toUpperCase()}]** ${m}${p}${c.desc || '(no description)'}\n`;
      if (c.type === 'breaking' && c.migration) md += `  - **Migration:** ${c.migration}\n`;
    });
    md += '\n';
  });

  // JSON
  const jsonObj = {
    api: apiName, version, date,
    breakingChangesCount: breaking.length,
    changes: live.map(c => ({
      type: c.type,
      component: c.component,
      method: c.method === 'any' ? null : c.method,
      path: c.path || null,
      description: c.desc || '',
      ...(c.type === 'breaking' && c.migration ? { migrationGuide: c.migration } : {})
    }))
  };

  // Keep a Changelog
  const kacMap = { breaking: 'Changed', added: 'Added', changed: 'Changed', deprecated: 'Deprecated', removed: 'Removed', fixed: 'Fixed' };
  const kacGrouped = {};
  live.forEach(c => {
    const kt = kacMap[c.type] || 'Changed';
    if (!kacGrouped[kt]) kacGrouped[kt] = [];
    kacGrouped[kt].push(c);
  });
  let kac = `# Changelog\n\nAll notable changes to the ${apiName} are documented here.\nThis project adheres to [Semantic Versioning](https://semver.org/) and [Keep a Changelog](https://keepachangelog.com/).\n\n## [${version}] - ${date}\n\n`;
  ['Added','Changed','Deprecated','Removed','Fixed'].forEach(kt => {
    if (!kacGrouped[kt]) return;
    kac += `### ${kt}\n\n`;
    kacGrouped[kt].forEach(c => {
      const m = c.method !== 'any' ? `${c.method} ` : '';
      const p = c.path ? `${c.path} - ` : '';
      const b = c.type === 'breaking' ? '**[BREAKING]** ' : '';
      kac += `- ${b}${m}${p}${c.desc || '(no description)'}\n`;
      if (c.type === 'breaking' && c.migration) kac += `  > Migration: ${c.migration}\n`;
    });
    kac += '\n';
  });

  document.getElementById('output-markdown').textContent = md;
  document.getElementById('output-json').textContent = JSON.stringify(jsonObj, null, 2);
  document.getElementById('output-keepachangelog').textContent = kac;

  const alertEl = document.getElementById('breaking-alert');
  const alertTxt = document.getElementById('breaking-alert-text');
  if (breaking.length > 0) {
    alertTxt.textContent = `${breaking.length} breaking change${breaking.length > 1 ? 's' : ''} detected. Consumers must follow migration guides before upgrading to ${version}.`;
    alertEl.classList.remove('hidden');
  } else {
    alertEl.classList.add('hidden');
  }

  document.getElementById('output-section').classList.remove('hidden');
  switchFmt(currentFmt);
  setTimeout(() => document.getElementById('output-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
}

function switchFmt(fmt) {
  currentFmt = fmt;
  document.querySelectorAll('.fmt-tab').forEach(t => {
    const active = t.dataset.fmt === fmt;
    t.classList.toggle('border-primary', active);
    t.classList.toggle('text-primary', active);
    t.classList.toggle('border-transparent', !active);
    t.classList.toggle('text-text-muted', !active);
  });
  document.querySelectorAll('.fmt-panel').forEach(p => p.classList.add('hidden'));
  document.getElementById(`fmt-panel-${fmt}`)?.classList.remove('hidden');
}

document.querySelectorAll('.fmt-tab').forEach(t => t.addEventListener('click', () => switchFmt(t.dataset.fmt)));

document.querySelectorAll('.copy-output-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const el = document.getElementById(`output-${btn.dataset.panel}`);
    if (!el) return;
    navigator.clipboard.writeText(el.textContent).then(() => {
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 2000);
    });
  });
});

// Init
renderChanges();
</script>
