---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ApiChangelogGenerator from '../../components/ApiChangelogGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is an API breaking change?", answer: "A breaking change is any API modification that requires clients to update their code. This includes: removing an endpoint, changing an HTTP method (GET→POST), removing or renaming a required parameter, changing a response field type, or adding a required field to a request. Non-breaking changes include adding optional parameters, adding response fields, or updating documentation." },
  { question: "What OpenAPI versions are supported?", answer: "The tool supports OpenAPI 3.x and Swagger 2.x JSON format. It parses the paths object to compare endpoints, their HTTP methods, parameters, and response codes. For best results, use valid JSON format — YAML support is basic." },
  { question: "How do I use this with my CI/CD pipeline?", answer: "Export your API specs as JSON before and after a change. Paste both into this tool to preview the generated changelog. For automated CI/CD integration, consider tools like openapi-diff or oasdiff that can be run as CLI commands in your pipeline and fail builds on breaking changes." },
  { question: "What is semantic versioning for APIs?", answer: "API versioning follows semver conventions: MAJOR version for breaking changes (v1→v2), MINOR for backwards-compatible new features (v1.1), PATCH for backwards-compatible bug fixes (v1.0.1). Breaking changes should always increment the major version and may require maintaining the old version endpoint (/v1/) in parallel during a deprecation period." },
  { question: "What should an API changelog include?", answer: "A good API changelog groups changes by type: Breaking Changes (with migration instructions), New Features (new endpoints or optional parameters), Deprecations (with removal timeline and alternatives), and Bug Fixes. Include the affected endpoint path, HTTP method, and specific field or parameter for each change." },
];
---

<BaseLayout
  title="API Changelog Generator — Detect OpenAPI Breaking Changes"
  description="Compare two OpenAPI/Swagger specs to automatically generate a changelog. Detects breaking changes, new endpoints, removed paths, parameter changes, and deprecations. Outputs formatted markdown."
  tool="API changelog generator, OpenAPI diff, Swagger diff, API breaking changes, API versioning, REST API changelog, openapi compare"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">API Changelog Generator</h1>
  <p class="text-text-muted mb-4">Paste two OpenAPI or Swagger JSON specs to automatically detect breaking changes, new features, and deprecations. Outputs a formatted markdown changelog ready for your release notes or documentation.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No API specs sent to any server</span>
  </div>
  <ApiChangelogGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="API Changelog Generator" relatedTags={['api', 'openapi', 'swagger', 'versioning', 'documentation', 'rest']} />
</BaseLayout>
