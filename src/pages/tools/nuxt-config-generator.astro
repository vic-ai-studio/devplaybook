---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NuxtConfigGenerator from '../../components/NuxtConfigGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is nuxt.config.ts and what can it configure?",
    answer: "nuxt.config.ts is the central configuration file for a Nuxt 3 project. It controls: which modules are loaded, SSR vs SPA mode, TypeScript strictness, runtime environment variables (runtimeConfig), SEO defaults (app.head), route rules, global CSS, Vite/Webpack build options, and module-specific configuration blocks. Everything in nuxt.config.ts is type-safe — your editor gets IntelliSense because Nuxt exports typed defineNuxtConfig()."
  },
  {
    question: "What is the difference between public and private runtimeConfig?",
    answer: "runtimeConfig.public keys are exposed to the browser and accessible via useRuntimeConfig() on both client and server. runtimeConfig keys (outside public) are server-only — never sent to the browser. Use private keys for database URLs, API secrets, and third-party keys that must not leak. Both types read from NUXT_* environment variables at runtime: `runtimeConfig.apiBase` maps to NUXT_API_BASE, `runtimeConfig.public.siteUrl` maps to NUXT_PUBLIC_SITE_URL."
  },
  {
    question: "When should I use SSR vs SPA mode in Nuxt?",
    answer: "Keep `ssr: true` (the default) for marketing sites, blogs, e-commerce, and any page that needs SEO or fast initial load — the server renders HTML before sending it to the browser. Set `ssr: false` to switch to SPA (Single Page Application) mode, which skips server rendering entirely. SPA mode is appropriate for dashboards, internal tools, or apps behind authentication where SEO doesn't matter. Nuxt also supports hybrid rendering per-route via routeRules."
  },
  {
    question: "How do I add Nuxt modules?",
    answer: "Install the module package (e.g., `npm install @nuxtjs/tailwindcss`), then add it to the `modules` array in nuxt.config.ts. Most modules also accept a configuration key at the top level (e.g., `tailwindcss: { config: { ... } }`). Nuxt modules run at build time — they can add plugins, composables, components, and Nitro middleware. Check nuxt.com/modules for the official module catalog."
  },
  {
    question: "What are routeRules and how do they enable hybrid rendering?",
    answer: "routeRules let you set per-route rendering strategies. `{ '/blog/**': { isr: 60 } }` caches blog pages for 60 seconds with Incremental Static Regeneration. `{ '/dashboard/**': { ssr: false } }` disables SSR for dashboard routes (SPA behavior). `{ '/api/**': { cors: true } }` adds CORS headers to API routes. `{ '/old-page': { redirect: '/new-page' } }` handles redirects. Combine SSR, ISR, SWR, and SPA per route without multiple deployments."
  },
  {
    question: "How does Nuxt handle environment variables?",
    answer: "Nuxt reads .env files (using dotenv) at dev time. In production, set real environment variables on your host. All NUXT_* and NUXT_PUBLIC_* variables are automatically injected into runtimeConfig at runtime — no manual process.env reading needed. This means you can deploy the same build to different environments (staging, production) by changing environment variables. Never commit secrets to .env files; use .env.example with placeholder values instead."
  },
];
---

<BaseLayout
  title="Nuxt Config Generator — Build nuxt.config.ts with Modules, Runtime Config, and SEO"
  description="Generate nuxt.config.ts configuration for Nuxt 3. Select modules (Tailwind, Pinia, Image, i18n), set runtime config keys, SEO app.head defaults, routeRules, and TypeScript options. Runs in your browser."
  tool="nuxt config generator, nuxt.config.ts, nuxt 3 configuration, nuxt modules setup, nuxt runtimeConfig"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Nuxt Config Generator",
    "url": "https://devplaybook.cc/tools/nuxt-config-generator",
    "description": "Generate nuxt.config.ts with module selection, runtimeConfig, SEO defaults, SSR/SPA mode, TypeScript, and routeRules. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Nuxt Config Generator</h1>
  <p class="text-text-muted mb-4">
    Build a <code class="font-mono text-sm bg-bg-card px-1 rounded">nuxt.config.ts</code> for your Nuxt 3 project.
    Select modules, configure runtime environment variables with proper public/private separation,
    set SEO <code class="font-mono text-sm bg-bg-card px-1 rounded">app.head</code> defaults, and toggle TypeScript strict mode and SSR.
    The generated config is copy-paste ready and follows Nuxt 3 best practices.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Module selection</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runtime config</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> SEO defaults</span>
  </div>
  <NuxtConfigGenerator client:only="preact" />

  <section class="mt-12 space-y-8 text-sm text-text-muted">
    <div>
      <h2 class="text-xl font-semibold text-text mb-3">Nuxt 3 runtimeConfig Cheat Sheet</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-xs font-mono">
          <thead>
            <tr class="border-b border-border">
              <th class="text-left py-2 pr-4 text-text font-semibold">Config key</th>
              <th class="text-left py-2 pr-4 text-text font-semibold">Env var name</th>
              <th class="text-left py-2 text-text font-semibold">Available</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border/50">
            <tr>
              <td class="py-2 pr-4">runtimeConfig.dbUrl</td>
              <td class="py-2 pr-4">NUXT_DB_URL</td>
              <td class="py-2 text-orange-400">Server only</td>
            </tr>
            <tr>
              <td class="py-2 pr-4">runtimeConfig.stripeSecret</td>
              <td class="py-2 pr-4">NUXT_STRIPE_SECRET</td>
              <td class="py-2 text-orange-400">Server only</td>
            </tr>
            <tr>
              <td class="py-2 pr-4">runtimeConfig.public.apiBase</td>
              <td class="py-2 pr-4">NUXT_PUBLIC_API_BASE</td>
              <td class="py-2 text-green-400">Client + Server</td>
            </tr>
            <tr>
              <td class="py-2 pr-4">runtimeConfig.public.stripeKey</td>
              <td class="py-2 pr-4">NUXT_PUBLIC_STRIPE_KEY</td>
              <td class="py-2 text-green-400">Client + Server</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div>
      <h2 class="text-xl font-semibold text-text mb-3">Hybrid Rendering with routeRules</h2>
      <p class="mb-3">
        Nuxt 3 lets you mix rendering strategies per route — no need to choose between a purely SSR or
        purely static site:
      </p>
      <pre class="bg-surface border border-border rounded-lg p-4 text-xs font-mono overflow-auto"><code>{`// nuxt.config.ts
export default defineNuxtConfig({
  routeRules: {
    // Static generation at build time
    '/': { prerender: true },

    // Incremental Static Regeneration (revalidate every 60s)
    '/blog/**': { isr: 60 },

    // SPA mode — no SSR for authenticated pages
    '/dashboard/**': { ssr: false },

    // Cache API responses at CDN edge for 10 minutes
    '/api/public/**': { cache: { maxAge: 600 } },

    // Add CORS headers to API routes
    '/api/**': { cors: true },

    // 301 redirect
    '/old-path': { redirect: '/new-path' },
  },
})`}</code></pre>
    </div>

    <div>
      <h2 class="text-xl font-semibold text-text mb-3">Essential Nuxt 3 Modules</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-xs">
          <thead>
            <tr class="border-b border-border">
              <th class="text-left py-2 pr-4 text-text font-semibold">Module</th>
              <th class="text-left py-2 pr-4 text-text font-semibold">Install</th>
              <th class="text-left py-2 text-text font-semibold">Purpose</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border/50">
            <tr>
              <td class="py-2 pr-4 font-mono">@nuxtjs/tailwindcss</td>
              <td class="py-2 pr-4 font-mono">npx nuxi module add tailwindcss</td>
              <td class="py-2">Tailwind CSS with auto-config</td>
            </tr>
            <tr>
              <td class="py-2 pr-4 font-mono">@pinia/nuxt</td>
              <td class="py-2 pr-4 font-mono">npx nuxi module add pinia</td>
              <td class="py-2">State management (Pinia)</td>
            </tr>
            <tr>
              <td class="py-2 pr-4 font-mono">@nuxt/image</td>
              <td class="py-2 pr-4 font-mono">npx nuxi module add image</td>
              <td class="py-2">Image optimization (WebP, lazy)</td>
            </tr>
            <tr>
              <td class="py-2 pr-4 font-mono">nuxt-icon</td>
              <td class="py-2 pr-4 font-mono">npm install nuxt-icon</td>
              <td class="py-2">100,000+ icons via Iconify</td>
            </tr>
            <tr>
              <td class="py-2 pr-4 font-mono">@nuxtjs/color-mode</td>
              <td class="py-2 pr-4 font-mono">npx nuxi module add color-mode</td>
              <td class="py-2">Dark/light mode toggle</td>
            </tr>
            <tr>
              <td class="py-2 pr-4 font-mono">@nuxtjs/i18n</td>
              <td class="py-2 pr-4 font-mono">npx nuxi module add i18n</td>
              <td class="py-2">Internationalization (i18n)</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div>
      <h2 class="text-xl font-semibold text-text mb-3">nuxt.config.ts Best Practices</h2>
      <ul class="space-y-1 list-disc list-inside">
        <li>Never hardcode secrets — use environment variables via runtimeConfig</li>
        <li>Keep <code class="font-mono text-xs bg-surface px-1 rounded">typescript.strict: true</code> enabled from the start — retrofitting is painful</li>
        <li>Use <code class="font-mono text-xs bg-surface px-1 rounded">devtools: &#123; enabled: true &#125;</code> only in development — strip for production</li>
        <li>Prefer <code class="font-mono text-xs bg-surface px-1 rounded">npx nuxi module add &lt;name&gt;</code> over manual installs — it updates config automatically</li>
        <li>Add <code class="font-mono text-xs bg-surface px-1 rounded">.nuxt/</code> and <code class="font-mono text-xs bg-surface px-1 rounded">.output/</code> to your <code class="font-mono text-xs bg-surface px-1 rounded">.gitignore</code></li>
        <li>Set <code class="font-mono text-xs bg-surface px-1 rounded">compatibilityDate</code> to lock behavior for future Nuxt versions</li>
      </ul>
    </div>
  </section>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Nuxt Config Generator" relatedTags={['frontend', 'vue', 'nuxt', 'javascript', 'typescript', 'configuration']} />
</BaseLayout>
