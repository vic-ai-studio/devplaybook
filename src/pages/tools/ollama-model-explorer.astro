---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OllamaModelExplorer from '../../components/OllamaModelExplorer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Ollama?",
    answer: "Ollama is an open-source tool that lets you run large language models locally on your machine. It handles model downloading, GPU acceleration, and exposes an OpenAI-compatible REST API at localhost:11434. You can use it to run models like Llama 3, Mistral, Gemma, and hundreds more without any API key or internet connection."
  },
  {
    question: "How much RAM/VRAM do I need to run Ollama models?",
    answer: "Roughly: 7B models need 4–8 GB VRAM (or 8–16 GB RAM for CPU-only), 13B models need 8–16 GB VRAM, 70B models need 40–80 GB VRAM. For CPU-only inference, multiply by ~2x for RAM. Smaller models like Phi-3.5 (3.8B) and Llama 3.2 (3B) run well even on laptops with 8 GB RAM. Embedding models are very lightweight (under 1 GB)."
  },
  {
    question: "How do I use Ollama with LangChain?",
    answer: "Install langchain-ollama: pip install langchain-ollama. Then use: from langchain_ollama import ChatOllama; llm = ChatOllama(model='llama3.2'). You can also use any OpenAI-compatible SDK by pointing the base_url to http://localhost:11434/v1 — no API key needed for local models."
  },
  {
    question: "What is the difference between chat, code, vision, and embedding models?",
    answer: "Chat models (Llama, Mistral, Gemma) are general-purpose instruction-following models. Code models (CodeLlama, DeepSeek Coder) are fine-tuned on code datasets and excel at generation, completion, and debugging. Vision models (Llama 3.2 Vision) accept both text and image inputs. Embedding models (nomic-embed-text, mxbai-embed-large) convert text to vector representations for semantic search and RAG — they don't generate text."
  },
  {
    question: "Which model is best for RAG (Retrieval-Augmented Generation)?",
    answer: "For RAG, you need two types of models: (1) An embedding model to convert documents to vectors — use nomic-embed-text or mxbai-embed-large. (2) A chat model to answer questions using retrieved context — Llama 3.1 8B or Mistral Nemo work well. The combination gives you a fully local RAG pipeline with no API costs."
  },
  {
    question: "Can I run multiple Ollama models at the same time?",
    answer: "Yes. Ollama can keep multiple models loaded simultaneously (subject to VRAM limits). By default it keeps the last used model in memory for faster subsequent requests. You can configure the keep_alive parameter per request. The REST API handles concurrent requests, so you can run multiple pipelines against different models at once."
  },
];
---

<BaseLayout
  title="Ollama Model Explorer — Browse & Compare Local LLMs"
  description="Browse and compare Ollama local LLM models. Filter by category, see parameter size, context length, and use case. Copy the ollama pull command for any model."
  tool="ollama models, ollama llm, local llm models, ollama pull commands, ollama model list"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Ollama Model Explorer",
    "url": "https://devplaybook.cc/tools/ollama-model-explorer",
    "description": "Browse and compare Ollama local LLM models. Filter by Chat, Code, Vision, and Embedding categories. Copy ollama pull commands instantly.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Ollama Model Explorer</h1>
  <p class="text-text-muted mb-4">
    Browse and compare <strong class="text-text">Ollama local LLM models</strong>. Filter by category (Chat, Code, Vision, Embedding),
    search by name or use case, and copy the <code class="font-mono bg-bg-card px-1 rounded text-sm">ollama pull</code> command
    for any model with one click.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 15+ real Ollama models</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Filter by Chat / Code / Vision / Embedding</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> One-click copy pull command</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Params, context window, use case</span>
  </div>
  <OllamaModelExplorer client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Ollama Model Explorer" relatedTags={['ai', 'llm', 'ollama', 'local-ai', 'langchain', 'rag']} />
</BaseLayout>
