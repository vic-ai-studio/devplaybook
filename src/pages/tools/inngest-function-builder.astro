---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InngestFunctionBuilder from '../../components/InngestFunctionBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Inngest and how does it work?",
    answer: "Inngest is an event-driven background job platform that runs on your existing infrastructure. You define functions that trigger on events (like 'user.signup') or cron schedules. Inngest handles retries, concurrency, throttling, and step-level durability without requiring a separate queue infrastructure. Functions run as HTTP endpoints — Inngest calls your server when a trigger fires."
  },
  {
    question: "What is the difference between step.run, step.sleep, and step.waitForEvent?",
    answer: "step.run wraps a code block in a durable, retried step — if the function crashes mid-execution, Inngest replays it from the last successful step rather than re-running everything. step.sleep pauses execution for a duration without holding a server connection — ideal for delays between retries or reminder sequences. step.waitForEvent pauses execution until a specific event is received or a timeout expires — perfect for human-in-the-loop flows like email confirmation."
  },
  {
    question: "What is concurrency limiting and when should I use it?",
    answer: "Concurrency limiting controls how many simultaneous runs of a function can execute. Use it to prevent overwhelming downstream services (e.g., limit 10 concurrent Stripe API calls), to enforce per-user rate limits (using concurrency key by user ID), or to protect database connection pools. Inngest queues excess runs and drains them as capacity frees up."
  },
  {
    question: "What does cancelOn do?",
    answer: "cancelOn lets you automatically cancel a running function when a specific event is received. For example: start an order fulfillment function on 'app/order.created', but cancel it immediately if 'app/order.cancelled' arrives. This prevents wasted work and ensures clean state transitions without requiring manual cancellation logic in your code."
  },
  {
    question: "How does throttle differ from concurrency in Inngest?",
    answer: "Concurrency limits how many runs execute simultaneously at any moment. Throttle limits how many runs can START within a time period — for example, no more than 100 per minute — regardless of how long each run takes. Use throttle for rate-limiting external API calls (respecting third-party rate limits) and concurrency for controlling resource utilization."
  },
  {
    question: "Does this tool send my function configuration to a server?",
    answer: "No. All code generation runs entirely in your browser using JavaScript. Your function names, event names, and step configurations never leave your machine."
  },
];
---

<BaseLayout
  title="Inngest Function Builder — Event-Driven Background Job Generator"
  description="Build Inngest background functions visually. Configure event triggers, step.run/sleep/waitForEvent steps, concurrency, throttle, and retry settings. Generates TypeScript or Python code. Free, runs in your browser."
  tool="Inngest function builder, Inngest event-driven job generator, Inngest TypeScript Python, Inngest step function, Inngest background job creator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Inngest Function Builder",
    "url": "https://devplaybook.cc/tools/inngest-function-builder",
    "description": "Build Inngest event-driven background functions visually. Configure triggers, steps (run/sleep/waitForEvent/invoke/sendEvent), concurrency, throttle, and retry. Generate TypeScript or Python code.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Inngest Function Builder</h1>
  <p class="text-text-muted mb-4">
    Build <a href="https://inngest.com" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">Inngest</a> event-driven background functions visually.
    Configure event or cron triggers, add step.run / step.sleep / step.waitForEvent steps,
    set concurrency limits, throttle, and retry policies.
    Generates ready-to-paste TypeScript or Python code.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript + Python</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 step types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Concurrency & throttle</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Cancel-on event</span>
  </div>
  <InngestFunctionBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Inngest Function Builder" relatedTags={['inngest', 'background-jobs', 'event-driven', 'typescript', 'python', 'serverless', 'queues']} />
</BaseLayout>
