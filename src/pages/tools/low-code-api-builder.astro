---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the difference between Postman, Insomnia, and Hoppscotch?",
    answer: "All three are API client tools used for testing, debugging, and documenting REST, GraphQL, and gRPC APIs. Postman is the market leader with the most features — collections, environments, automated testing, mock servers, API monitoring, and a large public API hub. It's closed-source with a generous free tier. Insomnia (by Kong) is open-source, focused on simplicity and plugin extensibility, and popular with developers who find Postman bloated. Hoppscotch is a fully open-source, browser-based alternative that's lightweight, privacy-friendly, and free to self-host — it's the 'developer-native' choice."
  },
  {
    question: "Is Hoppscotch free?",
    answer: "Hoppscotch is fully open-source (MIT license) and free to self-host. The community edition runs entirely in the browser at hoppscotch.io with no login required — just open and use. It supports REST, GraphQL, WebSocket, SSE, Socket.IO, and gRPC. Hoppscotch Cloud (for teams with sync and collaboration) starts at $12/user/month. For individual developers and small teams, the free browser version or self-hosted version is completely free and covers all major API testing needs without any account."
  },
  {
    question: "Can I use Postman or Insomnia for automated API testing?",
    answer: "Both support automated testing. Postman has the most mature testing ecosystem — you write JavaScript tests in the 'Tests' tab using the pm.test() API, run them with Newman (CLI runner) in CI/CD pipelines, and schedule monitors in the cloud. Insomnia also supports test suites via its 'Unit Tests' feature with JavaScript assertions, and Inso (CLI runner) for CI integration. Hoppscotch has more limited automated testing built-in, though scripts and pre-request hooks are available. For heavy test automation and CI/CD integration, Postman + Newman is the most battle-tested option."
  },
  {
    question: "Which API tool is best for GraphQL?",
    answer: "All three support GraphQL with schema introspection, query/mutation editors, and variable support. Postman has a dedicated GraphQL mode with an auto-populated schema explorer. Insomnia has excellent GraphQL support with a built-in schema viewer and query editor with autocomplete. Hoppscotch's GraphQL mode is clean and capable with schema introspection. Insomnia is often considered the best GraphQL experience among developers, while Postman wins on ecosystem and team collaboration features around GraphQL APIs."
  }
];
---

<BaseLayout
  title="Best Low-code API Builder Tools: Postman vs Insomnia vs Hoppscotch 2026"
  description="Interactive API tool picker quiz. Compare Postman, Insomnia, and Hoppscotch for REST/GraphQL testing, CI/CD integration, team collaboration, and open-source options."
  tool="Postman vs Insomnia vs Hoppscotch, API Tool Comparison, Best API Client 2026, API Testing Tool Picker, Postman Alternative"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Postman vs Insomnia vs Hoppscotch: API Tool Comparison 2026</h1>
  <p class="text-text-muted mb-4">
    Every developer needs an API client for testing, debugging, and documenting their APIs.
    Postman is the industry standard with the widest feature set and a massive public API hub.
    Insomnia (by Kong) is the clean, open-source alternative loved by developers who want simplicity and plugins.
    Hoppscotch is the lightweight, privacy-focused, browser-native option with full open-source self-hosting.
    Take the quiz below to find out which tool fits your workflow, then check the feature comparison table.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Tool picker quiz</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Feature comparison table</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Pricing & licensing breakdown</span>
  </div>

  <!-- Tool Picker Quiz -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-1">API Tool Picker Quiz</h2>
    <p class="text-text-muted text-sm mb-5">Answer 5 questions to get a personalized recommendation.</p>

    <div class="space-y-5" id="api-quiz">
      <!-- Q1 -->
      <div>
        <div class="text-sm font-medium mb-2">1. What's your primary use case?</div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          <label class="cursor-pointer flex items-start gap-2 border border-border rounded-lg p-2.5 text-sm hover:border-primary transition-colors">
            <input type="radio" name="aq1" value="test" class="accent-primary mt-0.5"> Testing and debugging APIs during development
          </label>
          <label class="cursor-pointer flex items-start gap-2 border border-border rounded-lg p-2.5 text-sm hover:border-primary transition-colors">
            <input type="radio" name="aq1" value="collab"> Team collaboration and API documentation sharing
          </label>
          <label class="cursor-pointer flex items-start gap-2 border border-border rounded-lg p-2.5 text-sm hover:border-primary transition-colors">
            <input type="radio" name="aq1" value="cicd"> Automated testing in CI/CD pipelines
          </label>
          <label class="cursor-pointer flex items-start gap-2 border border-border rounded-lg p-2.5 text-sm hover:border-primary transition-colors">
            <input type="radio" name="aq1" value="quick"> Quick one-off API checks, no account needed
          </label>
        </div>
      </div>

      <!-- Q2 -->
      <div>
        <div class="text-sm font-medium mb-2">2. How important is open-source / self-hosting to you?</div>
        <div class="flex flex-wrap gap-2">
          <label class="cursor-pointer flex items-center gap-2 border border-border rounded-lg px-3 py-2 text-sm hover:border-primary transition-colors">
            <input type="radio" name="aq2" value="notimportant" class="accent-primary"> Not important
          </label>
          <label class="cursor-pointer flex items-center gap-2 border border-border rounded-lg px-3 py-2 text-sm hover:border-primary transition-colors">
            <input type="radio" name="aq2" value="preferred"> Preferred
          </label>
          <label class="cursor-pointer flex items-center gap-2 border border-border rounded-lg px-3 py-2 text-sm hover:border-primary transition-colors">
            <input type="radio" name="aq2" value="required"> Required (data sovereignty / compliance)
          </label>
        </div>
      </div>

      <!-- Q3 -->
      <div>
        <div class="text-sm font-medium mb-2">3. Which API protocol do you use most?</div>
        <div class="flex flex-wrap gap-2">
          <label class="cursor-pointer flex items-center gap-2 border border-border rounded-lg px-3 py-2 text-sm hover:border-primary transition-colors">
            <input type="radio" name="aq3" value="rest" class="accent-primary"> REST / HTTP
          </label>
          <label class="cursor-pointer flex items-center gap-2 border border-border rounded-lg px-3 py-2 text-sm hover:border-primary transition-colors">
            <input type="radio" name="aq3" value="graphql"> GraphQL
          </label>
          <label class="cursor-pointer flex items-center gap-2 border border-border rounded-lg px-3 py-2 text-sm hover:border-primary transition-colors">
            <input type="radio" name="aq3" value="ws"> WebSocket / SSE
          </label>
          <label class="cursor-pointer flex items-center gap-2 border border-border rounded-lg px-3 py-2 text-sm hover:border-primary transition-colors">
            <input type="radio" name="aq3" value="grpc"> gRPC
          </label>
        </div>
      </div>

      <!-- Q4 -->
      <div>
        <div class="text-sm font-medium mb-2">4. Team size?</div>
        <div class="flex flex-wrap gap-2">
          <label class="cursor-pointer flex items-center gap-2 border border-border rounded-lg px-3 py-2 text-sm hover:border-primary transition-colors">
            <input type="radio" name="aq4" value="solo" class="accent-primary"> Just me
          </label>
          <label class="cursor-pointer flex items-center gap-2 border border-border rounded-lg px-3 py-2 text-sm hover:border-primary transition-colors">
            <input type="radio" name="aq4" value="small"> Small team (2–10)
          </label>
          <label class="cursor-pointer flex items-center gap-2 border border-border rounded-lg px-3 py-2 text-sm hover:border-primary transition-colors">
            <input type="radio" name="aq4" value="large"> Large team / enterprise
          </label>
        </div>
      </div>

      <!-- Q5 -->
      <div>
        <div class="text-sm font-medium mb-2">5. Budget preference?</div>
        <div class="flex flex-wrap gap-2">
          <label class="cursor-pointer flex items-center gap-2 border border-border rounded-lg px-3 py-2 text-sm hover:border-primary transition-colors">
            <input type="radio" name="aq5" value="free" class="accent-primary"> Free only
          </label>
          <label class="cursor-pointer flex items-center gap-2 border border-border rounded-lg px-3 py-2 text-sm hover:border-primary transition-colors">
            <input type="radio" name="aq5" value="low"> Low cost (&lt;$20/user/mo)
          </label>
          <label class="cursor-pointer flex items-center gap-2 border border-border rounded-lg px-3 py-2 text-sm hover:border-primary transition-colors">
            <input type="radio" name="aq5" value="enterprise"> Enterprise OK if worth it
          </label>
        </div>
      </div>
    </div>

    <button id="api-quiz-btn" class="w-full mt-5 py-2 bg-primary text-white text-sm rounded-lg hover:bg-primary/80 transition-colors">Get My Recommendation</button>
    <div id="api-quiz-result" class="mt-4 hidden"></div>
  </div>

  <!-- Feature Comparison Table -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6 overflow-x-auto">
    <h2 class="text-base font-semibold mb-4">Feature Comparison Table</h2>
    <table class="w-full text-sm border-collapse min-w-[580px]">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 text-text-muted font-medium w-48">Feature</th>
          <th class="text-center py-2 px-3 text-orange-400 font-semibold">Postman</th>
          <th class="text-center py-2 px-3 text-purple-400 font-semibold">Insomnia</th>
          <th class="text-center py-2 px-3 text-green-400 font-semibold">Hoppscotch</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <tr><td class="py-2.5 pr-4 text-text-muted">Open source</td><td class="text-center py-2.5 px-3 text-red-400">No</td><td class="text-center py-2.5 px-3 text-green-500">Yes (MIT)</td><td class="text-center py-2.5 px-3 text-green-500">Yes (MIT)</td></tr>
        <tr><td class="py-2.5 pr-4 text-text-muted">Self-host</td><td class="text-center py-2.5 px-3 text-red-400">No</td><td class="text-center py-2.5 px-3 text-yellow-500">Partial</td><td class="text-center py-2.5 px-3 text-green-500">Yes (free)</td></tr>
        <tr><td class="py-2.5 pr-4 text-text-muted">Free tier</td><td class="text-center py-2.5 px-3 text-green-500">Generous</td><td class="text-center py-2.5 px-3 text-green-500">Free (local)</td><td class="text-center py-2.5 px-3 text-green-500">Full free (browser)</td></tr>
        <tr><td class="py-2.5 pr-4 text-text-muted">Paid plan</td><td class="text-center py-2.5 px-3">$14/user/mo</td><td class="text-center py-2.5 px-3">$9/user/mo</td><td class="text-center py-2.5 px-3">$12/user/mo</td></tr>
        <tr><td class="py-2.5 pr-4 text-text-muted">REST support</td><td class="text-center py-2.5 px-3 text-green-500">Excellent</td><td class="text-center py-2.5 px-3 text-green-500">Excellent</td><td class="text-center py-2.5 px-3 text-green-500">Excellent</td></tr>
        <tr><td class="py-2.5 pr-4 text-text-muted">GraphQL support</td><td class="text-center py-2.5 px-3 text-green-500">Full</td><td class="text-center py-2.5 px-3 text-green-500">Excellent</td><td class="text-center py-2.5 px-3 text-green-500">Full</td></tr>
        <tr><td class="py-2.5 pr-4 text-text-muted">WebSocket / SSE</td><td class="text-center py-2.5 px-3 text-green-500">Yes</td><td class="text-center py-2.5 px-3 text-yellow-500">Limited</td><td class="text-center py-2.5 px-3 text-green-500">Yes</td></tr>
        <tr><td class="py-2.5 pr-4 text-text-muted">gRPC support</td><td class="text-center py-2.5 px-3 text-green-500">Yes</td><td class="text-center py-2.5 px-3 text-green-500">Yes</td><td class="text-center py-2.5 px-3 text-yellow-500">Yes</td></tr>
        <tr><td class="py-2.5 pr-4 text-text-muted">Automated testing</td><td class="text-center py-2.5 px-3 text-green-500">Excellent (Newman)</td><td class="text-center py-2.5 px-3 text-green-500">Good (Inso CLI)</td><td class="text-center py-2.5 px-3 text-yellow-500">Basic</td></tr>
        <tr><td class="py-2.5 pr-4 text-text-muted">Mock servers</td><td class="text-center py-2.5 px-3 text-green-500">Yes</td><td class="text-center py-2.5 px-3 text-red-400">No</td><td class="text-center py-2.5 px-3 text-red-400">No</td></tr>
        <tr><td class="py-2.5 pr-4 text-text-muted">API monitoring</td><td class="text-center py-2.5 px-3 text-green-500">Yes</td><td class="text-center py-2.5 px-3 text-red-400">No</td><td class="text-center py-2.5 px-3 text-red-400">No</td></tr>
        <tr><td class="py-2.5 pr-4 text-text-muted">Requires login to use</td><td class="text-center py-2.5 px-3 text-yellow-500">Yes (for sync)</td><td class="text-center py-2.5 px-3 text-yellow-500">Yes (for sync)</td><td class="text-center py-2.5 px-3 text-green-500">No (browser works)</td></tr>
        <tr><td class="py-2.5 pr-4 text-text-muted">Plugin/extension system</td><td class="text-center py-2.5 px-3 text-green-500">Yes</td><td class="text-center py-2.5 px-3 text-green-500">Yes</td><td class="text-center py-2.5 px-3 text-yellow-500">Extensions</td></tr>
      </tbody>
    </table>
  </div>

  <!-- Pricing Cards -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-4">Pricing &amp; Licensing</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm">
      <div class="border border-orange-400/30 rounded-lg p-4">
        <div class="font-semibold text-orange-400 mb-2">Postman</div>
        <div class="space-y-1.5 text-text-muted">
          <div><span class="text-white font-medium">Free:</span> Unlimited requests, 3 users, 25 mock calls/mo</div>
          <div><span class="text-white font-medium">Basic $14/user:</span> Unlimited mock + monitoring</div>
          <div><span class="text-white font-medium">Professional $29/user:</span> SSO, audit, versioning</div>
          <div><span class="text-white font-medium">Enterprise:</span> Custom + SAML</div>
        </div>
        <div class="mt-2 text-xs text-text-muted border-t border-border pt-2">Closed source, proprietary</div>
      </div>
      <div class="border border-purple-400/30 rounded-lg p-4">
        <div class="font-semibold text-purple-400 mb-2">Insomnia</div>
        <div class="space-y-1.5 text-text-muted">
          <div><span class="text-white font-medium">Free (local):</span> Full features, no cloud sync</div>
          <div><span class="text-white font-medium">Individual $9:</span> Cloud sync + backup</div>
          <div><span class="text-white font-medium">Team $9/user:</span> Shared workspaces</div>
          <div><span class="text-white font-medium">Enterprise:</span> SSO + RBAC</div>
        </div>
        <div class="mt-2 text-xs text-text-muted border-t border-border pt-2">Core is MIT open-source</div>
      </div>
      <div class="border border-green-400/30 rounded-lg p-4">
        <div class="font-semibold text-green-400 mb-2">Hoppscotch</div>
        <div class="space-y-1.5 text-text-muted">
          <div><span class="text-white font-medium">Browser (free):</span> Everything, no login needed</div>
          <div><span class="text-white font-medium">Self-host (free):</span> Full team features</div>
          <div><span class="text-white font-medium">Cloud Team $12/user:</span> Managed hosting</div>
          <div><span class="text-white font-medium">Enterprise:</span> Custom + on-prem</div>
        </div>
        <div class="mt-2 text-xs text-text-muted border-t border-border pt-2">MIT open-source, self-host free</div>
      </div>
    </div>
  </div>

  <!-- Pro CTA -->
  <div class="bg-bg-card border border-primary/30 rounded-xl p-5 mb-6">
    <div class="flex items-start gap-4">
      <div class="flex-1">
        <h3 class="font-semibold mb-1">DevPlaybook Pro — $9/month</h3>
        <p class="text-text-muted text-sm">API testing checklists, Postman collection templates, Newman CI/CD integration guides, and 500+ developer tools. Everything you need to ship APIs confidently.</p>
      </div>
      <a href="https://gumroad.com/l/devplaybook-pro" target="_blank" rel="noopener" class="flex-shrink-0 px-4 py-2 bg-primary text-white text-sm rounded-lg hover:bg-primary/80 transition-colors">Get Pro</a>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Postman vs Insomnia vs Hoppscotch" relatedTags={['postman', 'insomnia', 'hoppscotch', 'api', 'rest', 'graphql', 'api-testing']} />
</BaseLayout>

<script is:inline>
  document.getElementById('api-quiz-btn').addEventListener('click', () => {
    const answers = {};
    ['aq1','aq2','aq3','aq4','aq5'].forEach(q => {
      const checked = document.querySelector('input[name="' + q + '"]:checked');
      answers[q] = checked ? checked.value : null;
    });

    const result = document.getElementById('api-quiz-result');
    if (Object.values(answers).some(v => !v)) {
      result.innerHTML = '<p class="text-yellow-500 text-sm">Please answer all 5 questions first.</p>';
      result.classList.remove('hidden');
      return;
    }

    // Scoring
    let scores = { postman: 0, insomnia: 0, hoppscotch: 0 };

    // Q1: primary use case
    const useCaseMap = {
      test:      { postman: 4, insomnia: 5, hoppscotch: 3 },
      collab:    { postman: 5, insomnia: 3, hoppscotch: 2 },
      cicd:      { postman: 5, insomnia: 4, hoppscotch: 2 },
      quick:     { postman: 2, insomnia: 3, hoppscotch: 5 },
    };
    const oss = {
      notimportant: { postman: 4, insomnia: 3, hoppscotch: 2 },
      preferred:    { postman: 2, insomnia: 4, hoppscotch: 5 },
      required:     { postman: 0, insomnia: 3, hoppscotch: 5 },
    };
    const protocol = {
      rest:    { postman: 5, insomnia: 5, hoppscotch: 5 },
      graphql: { postman: 4, insomnia: 5, hoppscotch: 4 },
      ws:      { postman: 4, insomnia: 2, hoppscotch: 5 },
      grpc:    { postman: 4, insomnia: 4, hoppscotch: 3 },
    };
    const teamSize = {
      solo:      { postman: 3, insomnia: 4, hoppscotch: 5 },
      small:     { postman: 4, insomnia: 5, hoppscotch: 3 },
      large:     { postman: 5, insomnia: 3, hoppscotch: 2 },
    };
    const budget = {
      free:       { postman: 3, insomnia: 4, hoppscotch: 5 },
      low:        { postman: 3, insomnia: 5, hoppscotch: 4 },
      enterprise: { postman: 5, insomnia: 3, hoppscotch: 3 },
    };

    [
      useCaseMap[answers.aq1],
      oss[answers.aq2],
      protocol[answers.aq3],
      teamSize[answers.aq4],
      budget[answers.aq5],
    ].forEach(scoreBlock => {
      scores.postman += scoreBlock.postman;
      scores.insomnia += scoreBlock.insomnia;
      scores.hoppscotch += scoreBlock.hoppscotch;
    });

    const maxScore = 25;
    const pcts = {
      postman: Math.round((scores.postman / maxScore) * 100),
      insomnia: Math.round((scores.insomnia / maxScore) * 100),
      hoppscotch: Math.round((scores.hoppscotch / maxScore) * 100),
    };

    const winner = Object.keys(pcts).reduce((a, b) => pcts[a] >= pcts[b] ? a : b);
    const names = { postman: 'Postman', insomnia: 'Insomnia', hoppscotch: 'Hoppscotch' };
    const colors = {
      postman: 'border-orange-500/40 bg-orange-500/5',
      insomnia: 'border-purple-500/40 bg-purple-500/5',
      hoppscotch: 'border-green-500/40 bg-green-500/5',
    };
    const explanations = {
      postman: 'Your needs point to <strong>Postman</strong>. You value team collaboration, CI/CD test automation, mock servers, or enterprise-grade API monitoring. Postman\'s comprehensive feature set and Newman CLI runner make it the most complete API platform for production teams.',
      insomnia: 'Your needs point to <strong>Insomnia</strong>. You want a clean, open-source API client with excellent GraphQL support and plugin extensibility, without Postman\'s bloat. Insomnia\'s local-first design keeps your data on your machine.',
      hoppscotch: 'Your needs point to <strong>Hoppscotch</strong>. You value open-source, self-hosting, zero signup friction, or need WebSocket/SSE support alongside REST and GraphQL. Hoppscotch runs entirely in the browser — open it, start testing. Free forever.',
    };

    result.innerHTML = `
      <div class="border rounded-lg p-4 ${colors[winner]}">
        <div class="flex flex-wrap gap-4 mb-3 text-sm">
          <div><span class="text-orange-400 font-semibold">Postman:</span> ${pcts.postman}%</div>
          <div><span class="text-purple-400 font-semibold">Insomnia:</span> ${pcts.insomnia}%</div>
          <div><span class="text-green-400 font-semibold">Hoppscotch:</span> ${pcts.hoppscotch}%</div>
        </div>
        <p class="text-sm">${explanations[winner]}</p>
      </div>
    `;
    result.classList.remove('hidden');
  });
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "API Tool Picker: Postman vs Insomnia vs Hoppscotch",
