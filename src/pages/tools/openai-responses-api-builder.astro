---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the OpenAI Responses API?", answer: "The Responses API (launched March 2025) is OpenAI's unified interface for agentic AI tasks. It replaces the older Completions and Chat Completions for complex workflows, adding built-in tools (web search, file search, computer use), stateful runs, and streaming events. It's designed for multi-step agent tasks rather than single-turn Q&A." },
  { question: "How is Responses API different from Chat Completions?", answer: "Chat Completions is stateless (you send full history each time). Responses API maintains state with 'previous_response_id', has native built-in tools without extra code, supports background runs, and has a richer streaming event system. Use Chat Completions for simple Q&A; use Responses for agent workflows." },
  { question: "What built-in tools does the Responses API support?", answer: "Built-in tools: web_search_preview (live web access), file_search (vector store search), computer_use_preview (screen/mouse/keyboard control), and code_interpreter. You can combine these with custom function tools. No extra setup needed — just include them in the tools array." },
  { question: "How does stateful continuation work?", answer: "Pass the 'id' from a previous response as 'previous_response_id' in your next request. OpenAI maintains the conversation state server-side, so you don't need to resend the full history. This is more token-efficient for long agent sessions. Use 'store: false' if you don't want server-side storage." },
  { question: "What models support the Responses API?", answer: "GPT-4o, GPT-4o mini, o1, o3, o3-mini, and o4-mini support the Responses API. GPT-4.5 (preview) also works. Not all models support all built-in tools — computer_use requires specific models. Always check the model capabilities in the OpenAI documentation." },
];
---

<BaseLayout
  title="OpenAI Responses API Builder — Build 2026 Request Payloads & Code Snippets"
  description="Generate OpenAI Responses API request payloads with built-in tools, stateful runs, and streaming. Supports GPT-4o, o3, o4-mini with web search, file search, and computer use."
  tool="OpenAI Responses API Builder, GPT-4o Responses API, OpenAI Agent API Builder, OpenAI API Payload Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">OpenAI Responses API Builder</h1>
  <p class="text-text-muted mb-4">Build complete OpenAI Responses API (2025+) request payloads with built-in tools, stateful continuation, and streaming. Generate ready-to-use code for your agent workflows.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Built-in tool support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Stateful runs</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Streaming events</span>
  </div>

  <!-- Model & Config -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Model & Configuration</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Model</label>
        <select id="model" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="gpt-4o" selected>gpt-4o (Latest)</option>
          <option value="gpt-4o-mini">gpt-4o-mini (Fast)</option>
          <option value="o4-mini">o4-mini (Reasoning, fast)</option>
          <option value="o3">o3 (Strong reasoning)</option>
          <option value="o3-mini">o3-mini (Reasoning, efficient)</option>
          <option value="o1">o1 (Advanced reasoning)</option>
          <option value="gpt-4.5-preview">gpt-4.5-preview</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Language</label>
        <select id="lang" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="node" selected>Node.js (openai SDK)</option>
          <option value="python">Python (openai SDK)</option>
          <option value="curl">cURL (REST)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Max Output Tokens</label>
        <input id="max-tokens" type="number" value="1024" min="1" max="16384"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-4">
      <div>
        <label class="block text-xs text-text-muted mb-1">Temperature (0-2)</label>
        <input id="temperature" type="number" value="1" step="0.1" min="0" max="2"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Previous Response ID (stateful)</label>
        <input id="prev-id" type="text" placeholder="resp_abc123... (optional)"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
      </div>
      <div class="flex flex-col justify-end gap-2">
        <label class="flex items-center gap-2 cursor-pointer">
          <input id="stream" type="checkbox" class="rounded" />
          <span class="text-sm font-medium">Enable streaming</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input id="store" type="checkbox" checked class="rounded" />
          <span class="text-sm font-medium">Store response (server-side)</span>
        </label>
      </div>
    </div>
  </div>

  <!-- System & Input -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-3">Instructions & Input</h2>
    <div class="space-y-3">
      <div>
        <label class="block text-sm font-medium mb-1">Instructions (system prompt)</label>
        <textarea id="instructions" rows="3" placeholder="You are a helpful assistant..."
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary resize-y font-mono">You are a helpful assistant. Complete tasks efficiently and accurately.</textarea>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Input (user message)</label>
        <textarea id="input" rows="3"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary resize-y font-mono">Search the web for the latest news on AI agents and summarize the top 3 results.</textarea>
      </div>
    </div>
  </div>

  <!-- Built-in Tools -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-3">Built-in Tools</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <label class="flex items-center gap-2 cursor-pointer p-3 border border-border rounded-lg hover:border-primary/50 transition-colors">
        <input id="tool-web-search" type="checkbox" checked class="rounded" />
        <div>
          <div class="text-sm font-medium">Web Search</div>
          <div class="text-xs text-text-muted">web_search_preview</div>
        </div>
      </label>
      <label class="flex items-center gap-2 cursor-pointer p-3 border border-border rounded-lg hover:border-primary/50 transition-colors">
        <input id="tool-file-search" type="checkbox" class="rounded" />
        <div>
          <div class="text-sm font-medium">File Search</div>
          <div class="text-xs text-text-muted">file_search</div>
        </div>
      </label>
      <label class="flex items-center gap-2 cursor-pointer p-3 border border-border rounded-lg hover:border-primary/50 transition-colors">
        <input id="tool-computer" type="checkbox" class="rounded" />
        <div>
          <div class="text-sm font-medium">Computer Use</div>
          <div class="text-xs text-text-muted">computer_use_preview</div>
        </div>
      </label>
      <label class="flex items-center gap-2 cursor-pointer p-3 border border-border rounded-lg hover:border-primary/50 transition-colors">
        <input id="tool-code" type="checkbox" class="rounded" />
        <div>
          <div class="text-sm font-medium">Code Interpreter</div>
          <div class="text-xs text-text-muted">code_interpreter</div>
        </div>
      </label>
    </div>
    <div id="vector-store-config" class="mt-3 hidden">
      <label class="block text-xs text-text-muted mb-1">Vector Store IDs (comma-separated)</label>
      <input id="vector-stores" type="text" placeholder="vs_abc123,vs_def456"
        class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
    </div>
  </div>

  <!-- Generated Code -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-base font-semibold">Generated Code</h2>
      <button id="copy-btn" class="text-xs bg-primary/10 hover:bg-primary/20 text-primary px-3 py-1.5 rounded-lg transition-colors">Copy</button>
    </div>
    <pre id="code-output" class="bg-bg-card border border-border rounded-lg p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text leading-relaxed"></pre>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="OpenAI Responses API Builder" relatedTags={['openai', 'api', 'ai', 'agent', 'gpt4o', 'responses']} />
</BaseLayout>

<script>
  function getVal(id: string): string {
    return (document.getElementById(id) as HTMLInputElement).value;
  }
  function isChecked(id: string): boolean {
    return (document.getElementById(id) as HTMLInputElement).checked;
  }

  function buildTools(): unknown[] {
    const tools: unknown[] = [];
    if (isChecked('tool-web-search')) tools.push({ type: 'web_search_preview' });
    if (isChecked('tool-file-search')) {
      const vsIds = getVal('vector-stores').split(',').map(s => s.trim()).filter(Boolean);
      const t: Record<string, unknown> = { type: 'file_search' };
      if (vsIds.length) t.vector_store_ids = vsIds;
      tools.push(t);
    }
    if (isChecked('tool-computer')) tools.push({ type: 'computer_use_preview', display_width: 1280, display_height: 800, environment: 'browser' });
    if (isChecked('tool-code')) tools.push({ type: 'code_interpreter' });
    return tools;
  }

  function generateCode(): string {
    const model = getVal('model');
    const maxTokens = parseInt(getVal('max-tokens'));
    const temp = parseFloat(getVal('temperature'));
    const instructions = (document.getElementById('instructions') as HTMLTextAreaElement).value;
    const input = (document.getElementById('input') as HTMLTextAreaElement).value;
    const prevId = getVal('prev-id').trim();
    const stream = isChecked('stream');
    const store = isChecked('store');
    const lang = getVal('lang');
    const tools = buildTools();

    const params: Record<string, unknown> = {
      model,
      instructions,
      input,
      max_output_tokens: maxTokens,
    };
    if (temp !== 1) params.temperature = temp;
    if (prevId) params.previous_response_id = prevId;
    if (!store) params.store = false;
    if (tools.length) params.tools = tools;
    if (stream) params.stream = true;

    if (lang === 'curl') {
      return `curl https://api.openai.com/v1/responses \\
  -H "Authorization: Bearer $OPENAI_API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '${JSON.stringify(params, null, 2)}'`;
    }

    if (lang === 'python') {
      const lines = Object.entries(params).map(([k, v]) => {
        if (typeof v === 'string') return `    ${k}="${v.replace(/"/g, '\\"').replace(/\n/g, '\\n')}",`;
        return `    ${k}=${JSON.stringify(v)},`;
      }).join('\n');

      if (stream) {
        return `from openai import OpenAI

client = OpenAI()  # uses OPENAI_API_KEY env var

with client.responses.stream(
${lines}
) as stream:
    for event in stream:
        if event.type == "response.output_text.delta":
            print(event.delta, end="", flush=True)`;
      }

      return `from openai import OpenAI

client = OpenAI()  # uses OPENAI_API_KEY env var

response = client.responses.create(
${lines}
)

print(response.output_text)`;
    }

    // Node.js
    const lines = Object.entries(params).map(([k, v]) => {
      const camel = k.replace(/_([a-z])/g, (_, c) => c.toUpperCase());
      if (typeof v === 'string') return `  ${camel}: '${v.replace(/'/g, "\\'").replace(/\n/g, '\\n')}',`;
      return `  ${camel}: ${JSON.stringify(v)},`;
    }).join('\n');

    if (stream) {
      return `import OpenAI from 'openai';

const client = new OpenAI(); // uses OPENAI_API_KEY env var

const stream = await client.responses.stream({
${lines}
});

for await (const event of stream) {
  if (event.type === 'response.output_text.delta') {
    process.stdout.write(event.delta);
  }
}`;
    }

    return `import OpenAI from 'openai';

const client = new OpenAI(); // uses OPENAI_API_KEY env var

const response = await client.responses.create({
${lines}
});

console.log(response.output_text);`;
  }

  function update() {
    const fileSearchChecked = isChecked('tool-file-search');
    document.getElementById('vector-store-config')!.classList.toggle('hidden', !fileSearchChecked);
    document.getElementById('code-output')!.textContent = generateCode();
  }

  document.getElementById('copy-btn')!.addEventListener('click', () => {
    const code = (document.getElementById('code-output') as HTMLPreElement).textContent || '';
    navigator.clipboard.writeText(code).then(() => {
      const btn = document.getElementById('copy-btn')!;
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 1500);
    });
  });

  document.querySelectorAll('input, select, textarea').forEach(el => el.addEventListener('input', update));
  update();
</script>
