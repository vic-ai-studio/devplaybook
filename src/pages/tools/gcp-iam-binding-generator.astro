---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="GCP IAM Binding Generator — gcloud & Terraform IAM Policy Builder"
  description="Generate Google Cloud Platform IAM role binding configurations. Build gcloud commands and Terraform google_project_iam_binding resources for project, bucket, or service-level IAM policies. Free, runs in your browser."
  tool="GCP IAM binding, Google Cloud IAM, gcloud iam command, Terraform google_project_iam_binding, GCP IAM policy, cloud security, IAM role generator"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "GCP IAM Binding Generator",
    "url": "https://devplaybook.cc/tools/gcp-iam-binding-generator",
    "description": "Generate Google Cloud Platform IAM role binding configurations. Build gcloud commands and Terraform resources for project, bucket, or service-level IAM policies.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">GCP IAM Binding Generator</h1>
  <p class="text-text-muted mb-4">Generate Google Cloud IAM role bindings. Get the gcloud CLI command, Terraform resource, and IAM policy JSON for project, bucket, dataset, or service account resources.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> gcloud command</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Terraform resource</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> IAM policy JSON</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs entirely in your browser</span>
  </div>

  <!-- Resource Type -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
    <div>
      <label class="block text-sm font-medium mb-2">Resource Type</label>
      <select id="iam-resource-type" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
        <option value="project">Project</option>
        <option value="bucket">Cloud Storage Bucket</option>
        <option value="dataset">BigQuery Dataset</option>
        <option value="serviceaccount">Service Account</option>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium mb-2" id="resource-id-label">Project ID</label>
      <input id="iam-resource-id" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="my-gcp-project" />
    </div>
  </div>

  <!-- Role -->
  <div class="mb-5">
    <label class="block text-sm font-medium mb-2">IAM Role</label>
    <div class="flex gap-2 mb-2 flex-wrap">
      <button class="preset-role px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-role="roles/viewer">Viewer</button>
      <button class="preset-role px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-role="roles/editor">Editor</button>
      <button class="preset-role px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-role="roles/owner">Owner</button>
      <button class="preset-role px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-role="roles/storage.objectViewer">Storage Object Viewer</button>
      <button class="preset-role px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-role="roles/storage.admin">Storage Admin</button>
      <button class="preset-role px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-role="roles/bigquery.dataViewer">BQ Data Viewer</button>
      <button class="preset-role px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-role="roles/run.invoker">Cloud Run Invoker</button>
      <button class="preset-role px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-role="roles/cloudfunctions.invoker">Cloud Functions Invoker</button>
    </div>
    <input id="iam-role" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="roles/viewer" value="roles/viewer" />
  </div>

  <!-- Member -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-5">
    <div>
      <label class="block text-sm font-medium mb-2">Member Type</label>
      <select id="iam-member-type" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
        <option value="user">user</option>
        <option value="serviceAccount">serviceAccount</option>
        <option value="group">group</option>
        <option value="domain">domain</option>
        <option value="allUsers">allUsers (public)</option>
        <option value="allAuthenticatedUsers">allAuthenticatedUsers</option>
      </select>
    </div>
    <div class="sm:col-span-2">
      <label class="block text-sm font-medium mb-2">Member Email / Domain</label>
      <input id="iam-member-email" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="user@example.com" />
    </div>
  </div>

  <!-- TF Resource Name -->
  <div class="mb-5">
    <label class="block text-sm font-medium mb-2">Terraform Resource Name (optional)</label>
    <input id="tf-resource-name" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="binding" value="binding" />
  </div>

  <div class="flex gap-3 mb-6 flex-wrap">
    <button id="btn-generate" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Generate IAM Config</button>
    <button id="btn-example-sa" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Example: SA → Bucket</button>
    <button id="btn-example-user" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Example: User → Project</button>
    <button id="btn-clear" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Clear</button>
  </div>

  <!-- Output -->
  <div id="output-section" class="hidden">
    <div class="flex gap-1 mb-4 border-b border-border">
      <button data-fmt="gcloud" class="fmt-tab px-4 py-2 text-sm font-medium border-b-2 border-primary text-primary transition-colors">gcloud CLI</button>
      <button data-fmt="terraform" class="fmt-tab px-4 py-2 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-foreground transition-colors">Terraform</button>
      <button data-fmt="json" class="fmt-tab px-4 py-2 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-foreground transition-colors">IAM Policy JSON</button>
    </div>

    <div id="fmt-panel-gcloud" class="fmt-panel bg-bg-card border border-border rounded-lg p-4">
      <div class="flex justify-end mb-2"><button class="copy-btn px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-target="output-gcloud">Copy</button></div>
      <pre id="output-gcloud" class="font-mono text-sm whitespace-pre-wrap break-words text-green-300 overflow-x-auto"></pre>
    </div>
    <div id="fmt-panel-terraform" class="fmt-panel hidden bg-bg-card border border-border rounded-lg p-4">
      <div class="flex justify-end mb-2"><button class="copy-btn px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-target="output-terraform">Copy</button></div>
      <pre id="output-terraform" class="font-mono text-sm whitespace-pre-wrap break-words text-blue-300 overflow-x-auto"></pre>
    </div>
    <div id="fmt-panel-json" class="fmt-panel hidden bg-bg-card border border-border rounded-lg p-4">
      <div class="flex justify-end mb-2"><button class="copy-btn px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-target="output-json">Copy</button></div>
      <pre id="output-json" class="font-mono text-sm whitespace-pre-wrap break-words text-yellow-300 overflow-x-auto"></pre>
    </div>
  </div>

  <ToolPageCta />
</BaseLayout>

<script>
let currentFmt = 'gcloud';

// Resource type label update
const RESOURCE_LABELS = { project: 'Project ID', bucket: 'Bucket Name', dataset: 'Dataset ID (project/dataset)', serviceaccount: 'Service Account Email' };
const RESOURCE_PLACEHOLDERS = { project: 'my-gcp-project', bucket: 'my-storage-bucket', dataset: 'my-project/my-dataset', serviceaccount: 'sa@my-project.iam.gserviceaccount.com' };

document.getElementById('iam-resource-type')?.addEventListener('change', function() {
  const label = document.getElementById('resource-id-label');
  const input = document.getElementById('iam-resource-id');
  if (label) label.textContent = RESOURCE_LABELS[this.value] || 'Resource ID';
  if (input) input.placeholder = RESOURCE_PLACEHOLDERS[this.value] || '';
});

document.querySelectorAll('.preset-role').forEach(b => {
  b.addEventListener('click', () => {
    const roleInput = document.getElementById('iam-role');
    if (roleInput) roleInput.value = b.dataset.role;
  });
});

document.getElementById('iam-member-type')?.addEventListener('change', function() {
  const emailInput = document.getElementById('iam-member-email');
  if (!emailInput) return;
  if (this.value === 'allUsers' || this.value === 'allAuthenticatedUsers') {
    emailInput.value = '';
    emailInput.disabled = true;
    emailInput.placeholder = 'N/A for this member type';
  } else {
    emailInput.disabled = false;
    emailInput.placeholder = 'user@example.com';
  }
});

function getMember() {
  const type = document.getElementById('iam-member-type')?.value || 'user';
  if (type === 'allUsers' || type === 'allAuthenticatedUsers') return type;
  const email = (document.getElementById('iam-member-email')?.value || '').trim();
  return email ? `${type}:${email}` : `${type}:user@example.com`;
}

function generate() {
  const resourceType = document.getElementById('iam-resource-type')?.value || 'project';
  const resourceId = (document.getElementById('iam-resource-id')?.value || '').trim() || 'my-gcp-project';
  const role = (document.getElementById('iam-role')?.value || '').trim() || 'roles/viewer';
  const member = getMember();
  const tfName = (document.getElementById('tf-resource-name')?.value || 'binding').trim();

  // gcloud command
  let gcloudCmd = '';
  if (resourceType === 'project') {
    gcloudCmd = `gcloud projects add-iam-policy-binding ${resourceId} \\\n  --member="${member}" \\\n  --role="${role}"`;
  } else if (resourceType === 'bucket') {
    gcloudCmd = `gcloud storage buckets add-iam-policy-binding gs://${resourceId} \\\n  --member="${member}" \\\n  --role="${role}"`;
  } else if (resourceType === 'dataset') {
    const [proj, ds] = resourceId.includes('/') ? resourceId.split('/') : [resourceId, resourceId];
    gcloudCmd = `bq add-iam-policy-binding \\\n  --member="${member}" \\\n  --role="${role}" \\\n  ${proj}:${ds}`;
  } else if (resourceType === 'serviceaccount') {
    gcloudCmd = `gcloud iam service-accounts add-iam-policy-binding ${resourceId} \\\n  --member="${member}" \\\n  --role="${role}"`;
  }

  // Terraform
  let tfResource = '';
  if (resourceType === 'project') {
    tfResource = `resource "google_project_iam_binding" "${tfName}" {
  project = "${resourceId}"
  role    = "${role}"
  members = [
    "${member}",
  ]
}`;
  } else if (resourceType === 'bucket') {
    tfResource = `resource "google_storage_bucket_iam_binding" "${tfName}" {
  bucket  = "${resourceId}"
  role    = "${role}"
  members = [
    "${member}",
  ]
}`;
  } else if (resourceType === 'dataset') {
    const [proj, ds] = resourceId.includes('/') ? resourceId.split('/') : [resourceId, resourceId];
    tfResource = `resource "google_bigquery_dataset_iam_binding" "${tfName}" {
  project    = "${proj}"
  dataset_id = "${ds}"
  role       = "${role}"
  members = [
    "${member}",
  ]
}`;
  } else if (resourceType === 'serviceaccount') {
    tfResource = `resource "google_service_account_iam_binding" "${tfName}" {
  service_account_id = "projects/-/serviceAccounts/${resourceId}"
  role               = "${role}"
  members = [
    "${member}",
  ]
}`;
  }

  // IAM Policy JSON
  const policyJson = JSON.stringify({
    bindings: [
      {
        role: role,
        members: [member]
      }
    ],
    etag: "BwXXXXXXXXX=",
    version: 1
  }, null, 2);

  document.getElementById('output-gcloud').textContent = gcloudCmd;
  document.getElementById('output-terraform').textContent = tfResource;
  document.getElementById('output-json').textContent = policyJson;
  document.getElementById('output-section').classList.remove('hidden');
  switchFmt(currentFmt);
  setTimeout(() => document.getElementById('output-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
}

document.getElementById('btn-generate')?.addEventListener('click', generate);

document.getElementById('btn-example-sa')?.addEventListener('click', () => {
  document.getElementById('iam-resource-type').value = 'bucket';
  document.getElementById('resource-id-label').textContent = 'Bucket Name';
  document.getElementById('iam-resource-id').value = 'my-data-bucket';
  document.getElementById('iam-resource-id').placeholder = 'my-storage-bucket';
  document.getElementById('iam-role').value = 'roles/storage.objectViewer';
  document.getElementById('iam-member-type').value = 'serviceAccount';
  document.getElementById('iam-member-email').value = 'pipeline-sa@my-project.iam.gserviceaccount.com';
  document.getElementById('iam-member-email').disabled = false;
  document.getElementById('tf-resource-name').value = 'pipeline_bucket_access';
});

document.getElementById('btn-example-user')?.addEventListener('click', () => {
  document.getElementById('iam-resource-type').value = 'project';
  document.getElementById('resource-id-label').textContent = 'Project ID';
  document.getElementById('iam-resource-id').value = 'my-gcp-project';
  document.getElementById('iam-resource-id').placeholder = 'my-gcp-project';
  document.getElementById('iam-role').value = 'roles/viewer';
  document.getElementById('iam-member-type').value = 'user';
  document.getElementById('iam-member-email').value = 'developer@example.com';
  document.getElementById('iam-member-email').disabled = false;
  document.getElementById('tf-resource-name').value = 'dev_viewer';
});

document.getElementById('btn-clear')?.addEventListener('click', () => {
  document.getElementById('iam-resource-id').value = '';
  document.getElementById('iam-role').value = 'roles/viewer';
  document.getElementById('iam-member-email').value = '';
  document.getElementById('tf-resource-name').value = 'binding';
  document.getElementById('output-section').classList.add('hidden');
});

function switchFmt(fmt) {
  currentFmt = fmt;
  document.querySelectorAll('.fmt-tab').forEach(t => {
    const active = t.dataset.fmt === fmt;
    t.classList.toggle('border-primary', active);
    t.classList.toggle('text-primary', active);
    t.classList.toggle('border-transparent', !active);
    t.classList.toggle('text-text-muted', !active);
  });
  document.querySelectorAll('.fmt-panel').forEach(p => p.classList.add('hidden'));
  document.getElementById(`fmt-panel-${fmt}`)?.classList.remove('hidden');
}

document.querySelectorAll('.fmt-tab').forEach(t => t.addEventListener('click', () => switchFmt(t.dataset.fmt)));

document.querySelectorAll('.copy-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const el = document.getElementById(btn.dataset.target);
    if (!el) return;
    navigator.clipboard.writeText(el.textContent).then(() => {
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 2000);
    });
  });
});
</script>
