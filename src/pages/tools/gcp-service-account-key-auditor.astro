---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a GCP service account key JSON?", answer: "A service account key JSON file contains credentials for authenticating as a GCP service account. It includes private key material, the service account email, and project information. These files grant persistent access to GCP APIs and must be treated as secrets — never commit them to version control." },
  { question: "Why are long-lived service account keys risky?", answer: "Service account key JSON files don't expire by default (they're valid until rotated or deleted) and can be exfiltrated silently. Google recommends using Workload Identity Federation or short-lived tokens (via gcloud auth) instead of key files in production. Key files should only be used when other authentication methods are unavailable." },
  { question: "What is the principle of least privilege for service accounts?", answer: "Assign only the roles a service account needs for its specific job. Instead of project-level Owner/Editor, use granular roles like roles/storage.objectViewer or custom roles. Audit service accounts regularly to remove unused roles. Use per-service accounts rather than one shared account for multiple workloads." },
  { question: "How do I rotate a service account key?", answer: "In GCP Console: IAM > Service Accounts > select account > Keys tab > Add Key. Download the new key, update your applications to use it, then delete the old key. Alternatively, use Workload Identity Federation to eliminate key files entirely for GKE, Cloud Run, and other GCP compute services." },
  { question: "What is Workload Identity Federation?", answer: "Workload Identity Federation lets external identities (GitHub Actions, AWS IAM, Azure AD) authenticate to GCP without service account key files. You map external credentials to a service account using impersonation. This eliminates long-lived key files and is the recommended approach for CI/CD pipelines and cross-cloud workloads." },
];
---

<BaseLayout
  title="GCP Service Account Key Auditor — Audit Google Cloud SA Key JSON Security"
  description="Paste a GCP service account key JSON to audit it for security best practices. Checks for missing scopes, key age indicators, dangerous permissions, and generates remediation recommendations. Runs in your browser."
  tool="GCP service account key auditor, Google Cloud SA key security, GCP IAM security audit, service account key best practices, GCP credentials audit"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "GCP Service Account Key Auditor",
    "url": "https://devplaybook.cc/tools/gcp-service-account-key-auditor",
    "description": "Audit GCP service account key JSON files for security best practices. All processing runs in your browser — no data is sent to any server.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">GCP Service Account Key Auditor</h1>
  <p class="text-text-muted mb-4">Paste a GCP service account key JSON to audit it for security issues and get actionable remediation steps. All processing runs locally in your browser — your credentials never leave your machine.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100% local — no server upload</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Key structure validation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Security best practices</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Remediation commands</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <div class="space-y-4">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold">Service Account Key JSON</h2>
          <button id="load-sample" class="text-xs text-primary border border-border rounded px-2 py-0.5 hover:border-primary">Load sample</button>
        </div>
        <textarea id="key-input" rows="14" placeholder='Paste your service account key JSON here...' class="w-full bg-bg-card border border-border rounded-lg p-3 text-xs font-mono focus:outline-none focus:border-primary resize-none"></textarea>
        <div class="flex gap-2 mt-3">
          <button id="audit-btn" class="flex-1 py-2.5 bg-primary text-white font-medium rounded-lg hover:bg-primary/80 transition-colors text-sm">Audit Key</button>
          <button id="clear-btn" class="px-4 py-2 border border-border text-text-muted rounded-lg hover:border-primary text-sm">Clear</button>
        </div>
      </div>

      <div class="bg-amber-500/10 border border-amber-500/30 rounded-xl p-4 text-xs text-amber-400">
        <strong>Privacy notice:</strong> This tool runs entirely in your browser. No key data is transmitted to any server. Still, avoid pasting production keys in shared or untrusted environments.
      </div>
    </div>

    <div class="space-y-4">
      <div id="results-panel" class="bg-bg-card border border-border rounded-xl p-5 hidden">
        <h2 class="text-sm font-semibold mb-4">Audit Results</h2>
        <div id="summary-box" class="rounded-lg p-3 mb-4"></div>
        <div id="checks-list" class="space-y-3"></div>
      </div>
      <div id="remediation-panel" class="bg-bg-card border border-border rounded-xl p-5 hidden">
        <h2 class="text-sm font-semibold mb-3">Remediation Commands</h2>
        <pre id="remediation-output" class="font-mono text-xs bg-bg rounded p-3 border border-border overflow-auto whitespace-pre text-text"></pre>
      </div>
      <div id="placeholder" class="bg-bg-card border border-border rounded-xl p-8 text-center text-text-muted text-sm">
        Paste a service account key JSON and click "Audit Key" to see results.
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="GCP Service Account Key Auditor" relatedTags={['gcp', 'security', 'iam', 'cloud', 'google-cloud', 'devops']} />
</BaseLayout>

<script>
  const SAMPLE_KEY = JSON.stringify({
    type: "service_account",
    project_id: "my-project-123",
    private_key_id: "a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2",
    private_key: "-----BEGIN RSA PRIVATE KEY-----\n[REDACTED FOR SAMPLE]\n-----END RSA PRIVATE KEY-----\n",
    client_email: "my-service@my-project-123.iam.gserviceaccount.com",
    client_id: "123456789012345678901",
    auth_uri: "https://accounts.google.com/o/oauth2/auth",
    token_uri: "https://oauth2.googleapis.com/token",
    auth_provider_x509_cert_url: "https://www.googleapis.com/oauth2/v1/certs",
    client_x509_cert_url: "https://www.googleapis.com/robot/v1/metadata/x509/my-service%40my-project-123.iam.gserviceaccount.com",
    universe_domain: "googleapis.com"
  }, null, 2);

  document.getElementById('load-sample')!.addEventListener('click', () => {
    (document.getElementById('key-input') as HTMLTextAreaElement).value = SAMPLE_KEY;
  });

  document.getElementById('clear-btn')!.addEventListener('click', () => {
    (document.getElementById('key-input') as HTMLTextAreaElement).value = '';
    document.getElementById('results-panel')!.classList.add('hidden');
    document.getElementById('remediation-panel')!.classList.add('hidden');
    document.getElementById('placeholder')!.classList.remove('hidden');
  });

  interface Check { icon: string; color: string; title: string; detail: string; severity: 'pass' | 'warn' | 'fail' | 'info' }

  document.getElementById('audit-btn')!.addEventListener('click', () => {
    const raw = (document.getElementById('key-input') as HTMLTextAreaElement).value.trim();
    if (!raw) { alert('Please paste a service account key JSON first.'); return; }

    let parsed: Record<string, unknown>;
    try { parsed = JSON.parse(raw); } catch { alert('Invalid JSON. Please paste a valid service account key file.'); return; }

    const checks: Check[] = [];

    // Check 1: correct type
    if (parsed.type === 'service_account') {
      checks.push({ icon: '✓', color: 'text-green-400', title: 'Key type is service_account', detail: 'Correct key type for service account credentials.', severity: 'pass' });
    } else {
      checks.push({ icon: '✗', color: 'text-red-400', title: `Key type is "${parsed.type}"`, detail: 'Expected type: service_account. This may not be a service account key.', severity: 'fail' });
    }

    // Check 2: project_id
    const projectId = parsed.project_id as string || '';
    if (projectId) {
      checks.push({ icon: '✓', color: 'text-green-400', title: `Project: ${projectId}`, detail: 'Project ID is present.', severity: 'pass' });
    } else {
      checks.push({ icon: '✗', color: 'text-red-400', title: 'Missing project_id', detail: 'project_id field is absent or empty.', severity: 'fail' });
    }

    // Check 3: private_key presence and redaction
    const pk = parsed.private_key as string || '';
    const isRedacted = pk.includes('REDACTED') || pk.length < 100;
    if (!pk) {
      checks.push({ icon: '✗', color: 'text-red-400', title: 'Missing private_key', detail: 'private_key field is absent — this key cannot be used for authentication.', severity: 'fail' });
    } else if (isRedacted) {
      checks.push({ icon: 'ℹ', color: 'text-blue-400', title: 'Private key appears to be redacted', detail: 'The private key seems truncated or redacted in this sample. Real keys start with -----BEGIN RSA PRIVATE KEY----- and are ~1700 chars.', severity: 'info' });
    } else if (pk.includes('BEGIN RSA PRIVATE KEY') || pk.includes('BEGIN PRIVATE KEY')) {
      checks.push({ icon: '✓', color: 'text-green-400', title: 'Private key format valid', detail: 'PEM-encoded RSA private key detected.', severity: 'pass' });
    } else {
      checks.push({ icon: '⚠', color: 'text-yellow-400', title: 'Private key format unexpected', detail: 'Key does not start with expected PEM header.', severity: 'warn' });
    }

    // Check 4: client_email naming
    const email = parsed.client_email as string || '';
    if (email.includes('owner') || email.includes('admin') || email.includes('editor')) {
      checks.push({ icon: '⚠', color: 'text-yellow-400', title: `SA name suggests broad permissions: ${email}`, detail: 'Service account name contains "owner", "admin", or "editor". Review that this SA does not have project Owner/Editor roles.', severity: 'warn' });
    } else if (email) {
      checks.push({ icon: '✓', color: 'text-green-400', title: `SA email: ${email}`, detail: 'Service account email is present and does not suggest overly broad permissions by name.', severity: 'pass' });
    }

    // Check 5: default compute SA warning
    if (email.includes('compute@developer.gserviceaccount.com') || email.includes('appspot.gserviceaccount.com')) {
      checks.push({ icon: '⚠', color: 'text-yellow-400', title: 'Default compute/AppEngine service account', detail: 'Using the default compute or App Engine SA is not recommended. Create a dedicated SA with minimal permissions instead.', severity: 'warn' });
    }

    // Check 6: key_id length
    const keyId = parsed.private_key_id as string || '';
    if (keyId && keyId.length === 40) {
      checks.push({ icon: '✓', color: 'text-green-400', title: 'Key ID format valid (40 chars)', detail: 'private_key_id is the expected 40-character hex string.', severity: 'pass' });
    } else if (!keyId) {
      checks.push({ icon: '⚠', color: 'text-yellow-400', title: 'Missing private_key_id', detail: 'private_key_id is absent. This field is needed to identify and rotate the key.', severity: 'warn' });
    }

    // Check 7: universe_domain
    if ((parsed.universe_domain as string) === 'googleapis.com' || !parsed.universe_domain) {
      checks.push({ icon: '✓', color: 'text-green-400', title: 'Standard universe domain', detail: 'Using standard googleapis.com universe.', severity: 'pass' });
    }

    // Check 8: recommendation — avoid key files
    checks.push({ icon: 'ℹ', color: 'text-blue-400', title: 'Consider Workload Identity Federation', detail: 'For GKE, Cloud Run, GitHub Actions, and AWS workloads, Workload Identity Federation eliminates long-lived key files entirely.', severity: 'info' });

    // Render
    const failCount = checks.filter(c => c.severity === 'fail').length;
    const warnCount = checks.filter(c => c.severity === 'warn').length;
    const passCount = checks.filter(c => c.severity === 'pass').length;

    const summaryBox = document.getElementById('summary-box') as HTMLDivElement;
    if (failCount > 0) {
      summaryBox.className = 'rounded-lg p-3 bg-red-500/10 border border-red-500/30 text-red-400';
      summaryBox.textContent = `${failCount} failure(s), ${warnCount} warning(s), ${passCount} passing`;
    } else if (warnCount > 0) {
      summaryBox.className = 'rounded-lg p-3 bg-yellow-500/10 border border-yellow-500/30 text-yellow-400';
      summaryBox.textContent = `${warnCount} warning(s), ${passCount} passing — review warnings`;
    } else {
      summaryBox.className = 'rounded-lg p-3 bg-green-500/10 border border-green-500/30 text-green-400';
      summaryBox.textContent = `All checks passed (${passCount} checks)`;
    }

    const checksList = document.getElementById('checks-list') as HTMLDivElement;
    checksList.innerHTML = checks.map(c => `
      <div class="flex gap-3 p-3 bg-bg border border-border rounded-lg">
        <span class="${c.color} font-bold text-sm flex-shrink-0 w-4">${c.icon}</span>
        <div>
          <div class="text-sm font-medium">${c.title}</div>
          <div class="text-xs text-text-muted mt-0.5">${c.detail}</div>
        </div>
      </div>
    `).join('');

    // Remediation
    const saEmail = parsed.client_email as string || 'SA_EMAIL@PROJECT.iam.gserviceaccount.com';
    const projId = parsed.project_id as string || 'YOUR_PROJECT_ID';
    const remLines = [
      `# GCP Service Account Key Remediation`,
      `# Project: ${projId}`,
      `# Service Account: ${saEmail}`,
      ``,
      `# 1. List current roles assigned to this SA`,
      `gcloud projects get-iam-policy ${projId} \\`,
      `  --flatten="bindings[].members" \\`,
      `  --format="table(bindings.role)" \\`,
      `  --filter="bindings.members:${saEmail}"`,
      ``,
      `# 2. Rotate the key (create new key, delete old)`,
      `gcloud iam service-accounts keys create new-key.json \\`,
      `  --iam-account=${saEmail}`,
      `# Then delete old key (replace KEY_ID with private_key_id from JSON)`,
      `gcloud iam service-accounts keys delete KEY_ID \\`,
      `  --iam-account=${saEmail}`,
      ``,
      `# 3. Recommended: migrate to Workload Identity Federation`,
      `gcloud iam workload-identity-pools create my-pool \\`,
      `  --location=global --project=${projId}`,
    ];
    (document.getElementById('remediation-output') as HTMLPreElement).textContent = remLines.join('\n');

    document.getElementById('placeholder')!.classList.add('hidden');
    document.getElementById('results-panel')!.classList.remove('hidden');
    document.getElementById('remediation-panel')!.classList.remove('hidden');
  });
</script>
