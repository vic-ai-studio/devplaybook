---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How are LLM API costs calculated?", answer: "LLM providers charge separately for input tokens (your prompt) and output tokens (the model's response). Prices are listed per 1 million tokens (1M tokens). For example, GPT-4o costs $5 per 1M input tokens and $15 per 1M output tokens. To calculate a single call's cost: (input_tokens / 1,000,000 × input_price) + (output_tokens / 1,000,000 × output_price)." },
  { question: "Which model is the most cost-effective for my use case?", answer: "It depends on the task. For high-volume, simple tasks (classification, summaries) use GPT-3.5-turbo or Llama 3 on Groq — both are very cheap. For complex reasoning or long context, GPT-4o or Claude 3.5 Sonnet offer the best quality-to-cost ratio. Gemini 1.5 Pro is excellent for very long documents due to its 1M token context window. Always benchmark quality vs. cost for your specific use case." },
  { question: "What is the difference between input and output token pricing?", answer: "Input tokens are tokens in your prompt (system message + user messages). Output tokens are tokens the model generates in its response. Output tokens typically cost 3-5x more than input tokens because generating text is computationally more expensive than reading it. This means keeping your prompts concise and limiting max_tokens for the response are key levers for cost control." },
  { question: "Are these prices current and accurate?", answer: "This calculator uses approximate 2024 pricing from public documentation. AI pricing changes frequently — providers regularly drop prices as competition increases. Always verify current pricing on the official provider's pricing page before making budget decisions. OpenAI: platform.openai.com/pricing, Anthropic: anthropic.com/pricing, Google: cloud.google.com/vertex-ai/pricing, Groq: console.groq.com." },
];
---

<BaseLayout
  title="LLM Prompt Cost Calculator — Compare GPT, Claude, Gemini API Costs"
  description="Calculate and compare LLM API costs across GPT-4o, Claude 3.5, Gemini 1.5, and Llama 3. Enter prompt and completion tokens to see real-time cost breakdown. Free, browser-based."
  tool="LLM cost calculator, GPT API cost, Claude API pricing, Gemini API cost, compare LLM prices, prompt token cost"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "LLM Prompt Cost Calculator",
    "url": "https://devplaybook.cc/tools/llm-prompt-cost-calculator",
    "description": "Calculate and compare API costs across GPT-4o, Claude 3.5 Sonnet, Gemini 1.5 Pro, and Llama 3. Enter token counts for real-time cost comparison.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">LLM Prompt Cost Calculator</h1>
  <p class="text-text-muted mb-4">
    Enter your prompt and completion token counts to compare API costs across the major LLM providers.
    Useful for budgeting AI features, comparing models, and optimizing your token usage.
    All calculations run in your browser using approximate 2024 public pricing.
  </p>
  <div class="flex items-center gap-3 mb-8 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GPT-4o, GPT-3.5, Claude 3.5</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Gemini 1.5 Pro &amp; Llama 3</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Real-time calculation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Monthly volume estimate</span>
  </div>

  <!-- Inputs -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="font-semibold text-sm mb-4">Token Inputs</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block text-xs text-text-muted mb-1" for="input-tokens">Prompt (Input) Tokens</label>
        <input id="input-tokens" type="number" min="0" value="1000"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40" />
        <p class="text-xs text-text-muted mt-1">≈ 1 token per 4 chars (English)</p>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1" for="output-tokens">Completion (Output) Tokens</label>
        <input id="output-tokens" type="number" min="0" value="500"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40" />
        <p class="text-xs text-text-muted mt-1">Tokens generated by the model</p>
      </div>
    </div>
    <div>
      <label class="block text-xs text-text-muted mb-1" for="calls-per-month">API Calls per Month (for volume estimate)</label>
      <input id="calls-per-month" type="number" min="1" value="1000"
        class="w-full sm:w-64 bg-bg border border-border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40" />
    </div>
  </div>

  <!-- Results table -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-8 overflow-x-auto">
    <h2 class="font-semibold text-sm mb-4">Cost Comparison</h2>
    <table class="w-full text-sm min-w-[600px]">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 text-text-muted font-medium">Model</th>
          <th class="text-right py-2 pr-4 text-text-muted font-medium">Input $/1M</th>
          <th class="text-right py-2 pr-4 text-text-muted font-medium">Output $/1M</th>
          <th class="text-right py-2 pr-4 text-text-muted font-medium">Per Call</th>
          <th class="text-right py-2 text-text-muted font-medium">Monthly (×calls)</th>
        </tr>
      </thead>
      <tbody id="cost-table-body" class="text-xs">
      </tbody>
    </table>
  </div>

  <!-- Cheapest highlight -->
  <div id="cheapest-banner" class="hidden bg-green-500/10 border border-green-500/20 rounded-xl p-4 mb-8 text-sm text-green-400"></div>

  <!-- Pricing reference -->
  <div class="bg-bg-card border border-border rounded-xl p-6 mb-8">
    <h2 class="font-bold text-sm uppercase tracking-wide text-text-muted mb-4">Pricing Reference (Approx. 2024)</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-xs min-w-[560px]">
        <thead>
          <tr class="border-b border-border">
            <th class="text-left py-2 pr-4 text-text-muted font-medium">Model</th>
            <th class="text-left py-2 pr-4 text-text-muted font-medium">Provider</th>
            <th class="text-right py-2 pr-4 text-text-muted font-medium">Input / 1M tokens</th>
            <th class="text-right py-2 text-text-muted font-medium">Output / 1M tokens</th>
          </tr>
        </thead>
        <tbody class="text-text-muted">
          <tr class="border-b border-border/50"><td class="py-2 pr-4 text-text">GPT-4o</td><td class="pr-4">OpenAI</td><td class="text-right pr-4">$5.00</td><td class="text-right">$15.00</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4 text-text">GPT-3.5-turbo</td><td class="pr-4">OpenAI</td><td class="text-right pr-4">$0.50</td><td class="text-right">$1.50</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4 text-text">Claude 3.5 Sonnet</td><td class="pr-4">Anthropic</td><td class="text-right pr-4">$3.00</td><td class="text-right">$15.00</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4 text-text">Gemini 1.5 Pro</td><td class="pr-4">Google</td><td class="text-right pr-4">$3.50</td><td class="text-right">$10.50</td></tr>
          <tr><td class="py-2 pr-4 text-text">Llama 3 70B (Groq)</td><td class="pr-4">Groq</td><td class="text-right pr-4">$0.59</td><td class="text-right">$0.79</td></tr>
        </tbody>
      </table>
    </div>
    <p class="text-xs text-text-muted mt-3">Prices are approximate and subject to change. Verify on provider pricing pages before budgeting.</p>
  </div>

  <AffiliateSection />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="LLM Prompt Cost Calculator" relatedTags={['llm', 'openai', 'api', 'cost', 'gpt', 'claude', 'gemini']} />
</BaseLayout>

<script is:inline>
(function () {
  var MODELS = [
    { name: 'GPT-4o',            provider: 'OpenAI',    inputPer1M: 5.00,  outputPer1M: 15.00, color: 'text-green-400' },
    { name: 'GPT-3.5-turbo',     provider: 'OpenAI',    inputPer1M: 0.50,  outputPer1M: 1.50,  color: 'text-blue-400' },
    { name: 'Claude 3.5 Sonnet', provider: 'Anthropic', inputPer1M: 3.00,  outputPer1M: 15.00, color: 'text-orange-400' },
    { name: 'Gemini 1.5 Pro',    provider: 'Google',    inputPer1M: 3.50,  outputPer1M: 10.50, color: 'text-purple-400' },
    { name: 'Llama 3 70B (Groq)',provider: 'Groq',      inputPer1M: 0.59,  outputPer1M: 0.79,  color: 'text-yellow-400' },
  ];

  function fmt(n, decimals) {
    if (n === 0) return '$0.00';
    if (n < 0.00001) return '<$0.00001';
    return '$' + n.toFixed(decimals !== undefined ? decimals : (n < 0.01 ? 6 : n < 1 ? 4 : 2));
  }

  function calculate() {
    var inputTokens = Math.max(0, parseInt(document.getElementById('input-tokens').value) || 0);
    var outputTokens = Math.max(0, parseInt(document.getElementById('output-tokens').value) || 0);
    var callsPerMonth = Math.max(1, parseInt(document.getElementById('calls-per-month').value) || 1000);

    var rows = '';
    var minCost = Infinity;
    var minModel = '';

    MODELS.forEach(function (m) {
      var inputCost = (inputTokens / 1000000) * m.inputPer1M;
      var outputCost = (outputTokens / 1000000) * m.outputPer1M;
      var perCall = inputCost + outputCost;
      var monthly = perCall * callsPerMonth;

      if (perCall < minCost) { minCost = perCall; minModel = m.name; }

      rows += '<tr class="border-b border-border/50 hover:bg-bg/50 transition-colors">'
        + '<td class="py-2.5 pr-4"><span class="font-medium text-text">' + m.name + '</span><br><span class="text-text-muted">' + m.provider + '</span></td>'
        + '<td class="text-right pr-4 text-text-muted">' + fmt(m.inputPer1M, 2) + '</td>'
        + '<td class="text-right pr-4 text-text-muted">' + fmt(m.outputPer1M, 2) + '</td>'
        + '<td class="text-right pr-4 font-mono ' + m.color + '">' + fmt(perCall) + '</td>'
        + '<td class="text-right font-mono ' + m.color + '">' + fmt(monthly, 2) + '</td>'
        + '</tr>';
    });

    document.getElementById('cost-table-body').innerHTML = rows;

    var banner = document.getElementById('cheapest-banner');
    if (inputTokens > 0 || outputTokens > 0) {
      banner.textContent = '✓ Cheapest option: ' + minModel + ' at ' + fmt(minCost) + ' per call (' + fmt(minCost * callsPerMonth, 2) + '/month for ' + callsPerMonth.toLocaleString() + ' calls).';
      banner.classList.remove('hidden');
    } else {
      banner.classList.add('hidden');
    }
  }

  ['input-tokens', 'output-tokens', 'calls-per-month'].forEach(function (id) {
    document.getElementById(id).addEventListener('input', calculate);
  });

  calculate();
})();
</script>
