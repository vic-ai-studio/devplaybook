---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RegexTester from '../../components/RegexTester.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Regex Tester"
  description="Test your regular expressions against multiple strings at once. See pass/fail assertions, match highlights, and use built-in presets. Free, no signup."
  tool="Regex Tester, Regular Expression Validator, Regex Batch Test"
>
  <h1 class="text-3xl font-bold mb-2">Regex Tester</h1>
  <p class="text-text-muted mb-8">Test your regex against multiple strings simultaneously. Define expected match/no-match assertions and see instant pass/fail results — perfect for building robust validation patterns.</p>
  <RegexTester client:load />
  <ToolPageCta currentTool="Regex Tester" relatedTags={['regex', 'validation', 'testing', 'strings']} />
</BaseLayout>
