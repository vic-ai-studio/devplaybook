---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RegexTester from '../../components/RegexTester.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How do I test a regular expression online?", answer: "Paste your regex pattern in the top field, then add test strings below. The tool instantly shows which strings match and which don't. Use the built-in presets for common patterns like email, URL, or IPv4." },
  { question: "What regex flavor does this tester use?", answer: "This tool uses JavaScript's built-in RegExp engine, which supports standard regex syntax including lookahead, lookbehind (ES2018+), named capture groups, and Unicode property escapes." },
  { question: "Is my data safe when using this regex tester?", answer: "Yes. Everything runs 100% in your browser using JavaScript. No data is ever sent to any server. Your patterns and test strings never leave your machine." },
  { question: "Can I test regex against multiple strings at once?", answer: "Yes. Add multiple test strings and mark each as 'should match' or 'should not match'. The tool shows pass/fail results for all strings simultaneously — great for building reliable validation patterns." },
  { question: "What is the difference between match and test in regex?", answer: "In JavaScript, test() returns true/false for whether a pattern matches, while match() returns the actual matched substrings. This tool uses both — showing pass/fail status plus the matched portions of each string." },
];
---

<BaseLayout
  title="Regex Tester — Free Online Regular Expression Validator"
  description="Free regex tester. Test regular expressions against multiple strings with expected match/no-match assertions — see instant pass/fail results. Built-in presets for email, URL, IPv4, and phone. Pro: unlimited test strings and CSV export. No signup needed."
  tool="Regex Tester, Regular Expression Validator, Regex Batch Test, Regex Assertion, Test Regex Online, Regex Pass Fail, JavaScript Regex Tester"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Regex Tester</h1>
  <p class="text-text-muted mb-4">Test your regex against multiple strings simultaneously. Define expected match / no-match assertions and see instant pass/fail results — perfect for validating patterns. Presets for email, URL, IPv4, and phone. Pro: unlimited test strings + CSV export.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <RegexTester client:load />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Regex Tester" relatedTags={['regex', 'validation', 'testing', 'strings']} />
</BaseLayout>
