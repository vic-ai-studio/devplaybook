---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "How do I add plugins to vite.config.ts?",
    answer: "Import each plugin at the top of vite.config.ts and add them to the plugins array inside defineConfig(). Each plugin is called as a function, often with an options object. The order of plugins can matter — transforms are applied in order, and some plugins need to be before or after others."
  },
  {
    question: "What is the difference between Vite plugins and Rollup plugins?",
    answer: "Vite extends Rollup's plugin API with additional Vite-specific hooks. Most Rollup plugins work in Vite's build mode (using Rollup under the hood), but not all work in dev mode. Rollup plugins prefixed with 'rollup-plugin-' may need to be wrapped or may only run during build. Vite-native plugins work in both dev and build."
  },
  {
    question: "Should I install Vite plugins as devDependencies?",
    answer: "Yes. Vite plugins are only used at build time and during development, never at runtime in production. Always install them with 'npm install -D plugin-name' or 'bun add -d plugin-name'. They should appear in the 'devDependencies' section of your package.json."
  },
  {
    question: "What is vite-plugin-pwa and when should I use it?",
    answer: "vite-plugin-pwa automatically generates a Web App Manifest and Service Worker for your Vite app, turning it into a Progressive Web App (PWA) that can be installed on devices and work offline. Use it when you want offline support, push notifications, or app-like installation for your web app."
  },
  {
    question: "What does rollup-plugin-visualizer do?",
    answer: "rollup-plugin-visualizer generates an interactive treemap HTML report showing your bundle composition — which packages take up how much space. It's invaluable for identifying large dependencies, duplicate code, and optimization opportunities. Run 'npx vite build' and then open the generated stats.html file."
  },
  {
    question: "Can I use multiple framework plugins in one Vite config?",
    answer: "Generally no — framework plugins like @vitejs/plugin-react and @vitejs/plugin-vue each take over JSX/SFC transformation for their framework. You can't use both React and Vue plugins in the same project. However, utility plugins (PWA, compression, SVG, etc.) work alongside any framework plugin."
  }
];

const PLUGINS = [
  { id: 'plugin-react', pkg: '@vitejs/plugin-react', import: "import react from '@vitejs/plugin-react'", usage: 'react()', desc: 'Official React plugin with Fast Refresh support.', category: 'Framework' },
  { id: 'plugin-vue', pkg: '@vitejs/plugin-vue', import: "import vue from '@vitejs/plugin-vue'", usage: 'vue()', desc: 'Official Vue 3 Single File Components support.', category: 'Framework' },
  { id: 'plugin-svelte', pkg: '@sveltejs/vite-plugin-svelte', import: "import { svelte } from '@sveltejs/vite-plugin-svelte'", usage: 'svelte()', desc: 'Official Svelte plugin for Vite.', category: 'Framework' },
  { id: 'plugin-solid', pkg: 'vite-plugin-solid', import: "import solidPlugin from 'vite-plugin-solid'", usage: 'solidPlugin()', desc: 'SolidJS JSX transformation plugin.', category: 'Framework' },
  { id: 'plugin-pwa', pkg: 'vite-plugin-pwa', import: "import { VitePWA } from 'vite-plugin-pwa'", usage: "VitePWA({ registerType: 'autoUpdate' })", desc: 'Progressive Web App with service worker & manifest generation.', category: 'PWA' },
  { id: 'plugin-svgr', pkg: 'vite-plugin-svgr', import: "import svgr from 'vite-plugin-svgr'", usage: 'svgr()', desc: 'Import SVGs as React components.', category: 'Assets' },
  { id: 'plugin-compression', pkg: 'vite-plugin-compression', import: "import viteCompression from 'vite-plugin-compression'", usage: "viteCompression({ algorithm: 'gzip' })", desc: 'Gzip/Brotli asset compression for production builds.', category: 'Optimization' },
  { id: 'rollup-visualizer', pkg: 'rollup-plugin-visualizer', import: "import { visualizer } from 'rollup-plugin-visualizer'", usage: "visualizer({ open: true, gzipSize: true })", desc: 'Bundle size treemap visualizer.', category: 'Optimization' },
  { id: 'vite-tsconfig-paths', pkg: 'vite-tsconfig-paths', import: "import tsconfigPaths from 'vite-tsconfig-paths'", usage: 'tsconfigPaths()', desc: 'Resolve TypeScript path aliases from tsconfig.json.', category: 'TypeScript' },
  { id: 'unplugin-vue-components', pkg: 'unplugin-vue-components', import: "import Components from 'unplugin-vue-components/vite'", usage: 'Components({ dts: true })', desc: 'Auto-import Vue components on demand.', category: 'Framework' },
  { id: 'unplugin-auto-import', pkg: 'unplugin-auto-import', import: "import AutoImport from 'unplugin-auto-import/vite'", usage: "AutoImport({ imports: ['vue', 'vue-router'] })", desc: 'Auto-import Vue/React APIs without explicit imports.', category: 'DX' },
  { id: 'vite-plugin-inspect', pkg: 'vite-plugin-inspect', import: "import Inspect from 'vite-plugin-inspect'", usage: 'Inspect()', desc: 'Inspect intermediate state of Vite plugins (dev only).', category: 'DX' },
  { id: 'vite-plugin-checker', pkg: 'vite-plugin-checker', import: "import checker from 'vite-plugin-checker'", usage: "checker({ typescript: true })", desc: 'TypeScript / ESLint / Stylelint checks in dev overlay.', category: 'TypeScript' },
  { id: 'vite-imagetools', pkg: 'vite-imagetools', import: "import { imagetools } from 'vite-imagetools'", usage: 'imagetools()', desc: 'On-demand image transformation and optimization.', category: 'Assets' },
  { id: 'vite-plugin-legacy', pkg: '@vitejs/plugin-legacy', import: "import legacy from '@vitejs/plugin-legacy'", usage: "legacy({ targets: ['defaults', 'not IE 11'] })", desc: 'Legacy browser support via Babel & SystemJS.', category: 'Compatibility' },
  { id: 'vite-plugin-mock', pkg: 'vite-plugin-mock', import: "import { viteMockServe } from 'vite-plugin-mock'", usage: "viteMockServe({ mockPath: 'mock' })", desc: 'Local mock server for API development.', category: 'DX' },
  { id: 'vite-plugin-fonts', pkg: 'vite-plugin-fonts', import: "import VitePluginFonts from 'vite-plugin-fonts'", usage: "VitePluginFonts({ google: { families: ['Inter'] } })", desc: 'Automatically load Google Fonts or self-host fonts.', category: 'Assets' },
  { id: 'vite-plugin-wasm', pkg: 'vite-plugin-wasm', import: "import wasm from 'vite-plugin-wasm'", usage: 'wasm()', desc: 'Native ESM-based WebAssembly support.', category: 'WebAssembly' },
  { id: 'vite-plugin-top-level-await', pkg: 'vite-plugin-top-level-await', import: "import topLevelAwait from 'vite-plugin-top-level-await'", usage: 'topLevelAwait()', desc: 'Enable top-level await in modules (needed with vite-plugin-wasm).', category: 'WebAssembly' },
  { id: 'vite-plugin-env-compatible', pkg: 'vite-plugin-env-compatible', import: "import envCompatible from 'vite-plugin-env-compatible'", usage: 'envCompatible()', desc: 'Support VUE_APP_ / REACT_APP_ env variable prefixes.', category: 'DX' },
];
---

<BaseLayout
  title="Vite Plugin Explorer — Browse Plugins & Generate vite.config.ts"
  description="Browse 20 common Vite plugins, select the ones you need, and get a complete vite.config.ts file with proper imports and configuration. Zero guesswork setup."
  tool="Vite plugin explorer, vite.config.ts generator, Vite plugins list, vite-plugin-pwa, vite-plugin-svgr, Vite React plugin, Vite config builder"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Vite Plugin Explorer",
    "url": "https://devplaybook.cc/tools/vite-plugin-explorer",
    "description": "Browse common Vite plugins and generate a complete vite.config.ts file with selected plugins imported and configured.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Vite Plugin Explorer</h1>
  <p class="text-text-muted mb-4">Browse {PLUGINS.length} common Vite plugins, select the ones you need, and get a ready-to-use <code class="bg-bg-card px-1 rounded text-sm">vite.config.ts</code> with correct imports and configuration. Also shows the <code class="bg-bg-card px-1 rounded text-sm">npm install</code> command.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> {PLUGINS.length} curated plugins</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Filter by category or search</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Full vite.config.ts output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Install command included</span>
  </div>

  <!-- Search + filter -->
  <div class="flex flex-wrap gap-3 mb-4">
    <input id="plugin-search" type="text" placeholder="Search plugins..." class="flex-1 min-w-[180px] bg-bg-card border border-border rounded-lg p-2.5 text-sm focus:outline-none focus:border-primary" />
    <select id="cat-filter" class="bg-bg-card border border-border rounded-lg p-2.5 text-sm focus:outline-none focus:border-primary">
      <option value="">All categories</option>
      {[...new Set(PLUGINS.map(p => p.category))].map(c => <option value={c}>{c}</option>)}
    </select>
    <button id="btn-clear-selection" class="px-3 py-2 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Clear selection</button>
  </div>

  <!-- Plugin grid -->
  <div id="plugin-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-6">
    {PLUGINS.map(p => (
      <label class="plugin-card flex gap-3 items-start bg-bg-card border border-border rounded-lg p-3 cursor-pointer hover:border-primary transition-colors" data-pkg={p.pkg} data-cat={p.category}>
        <input type="checkbox" class="plugin-check mt-0.5 accent-primary" data-id={p.id} />
        <div class="min-w-0">
          <div class="flex items-center gap-2 flex-wrap">
            <span class="text-sm font-medium font-mono text-primary truncate">{p.pkg}</span>
            <span class="text-xs text-text-muted bg-surface px-1.5 py-0.5 rounded">{p.category}</span>
          </div>
          <p class="text-xs text-text-muted mt-1 leading-relaxed">{p.desc}</p>
        </div>
      </label>
    ))}
  </div>

  <!-- Output -->
  <div id="output-section" class="hidden">
    <div class="mb-4 p-3 bg-bg-card border border-border rounded-lg">
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs font-medium text-text-muted">Install command</span>
        <button id="copy-install" class="px-2 py-1 bg-surface border border-border rounded text-xs hover:border-primary transition-colors">Copy</button>
      </div>
      <pre id="install-cmd" class="text-sm font-mono text-yellow-300 whitespace-pre-wrap break-all"></pre>
    </div>
    <div class="flex items-center justify-between mb-2">
      <span class="text-base font-semibold">vite.config.ts</span>
      <button id="copy-config" class="px-3 py-1.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Copy</button>
    </div>
    <pre id="vite-config-output" class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono text-green-300 whitespace-pre overflow-x-auto"></pre>
  </div>

  <div id="no-selection" class="p-6 text-center text-text-muted text-sm bg-bg-card border border-border rounded-lg">
    Select one or more plugins above to generate your vite.config.ts
  </div>

  <ToolPageCta />
  <FaqSection faq={faq} />
</BaseLayout>

<script>
(function() {
  const PLUGINS = JSON.parse(document.getElementById('plugins-data').textContent);

  const searchInput = document.getElementById('plugin-search');
  const catFilter = document.getElementById('cat-filter');
  const pluginGrid = document.getElementById('plugin-grid');
  const outputSection = document.getElementById('output-section');
  const noSelection = document.getElementById('no-selection');
  const viteConfigOut = document.getElementById('vite-config-output');
  const installCmdEl = document.getElementById('install-cmd');

  function filterPlugins() {
    const q = searchInput.value.toLowerCase();
    const cat = catFilter.value;
    pluginGrid.querySelectorAll('.plugin-card').forEach(card => {
      const pkg = (card.dataset.pkg || '').toLowerCase();
      const cardCat = card.dataset.cat || '';
      const visible = (!q || pkg.includes(q)) && (!cat || cardCat === cat);
      card.style.display = visible ? '' : 'none';
    });
  }

  function getSelected() {
    return Array.from(document.querySelectorAll('.plugin-check:checked')).map(cb => cb.dataset.id);
  }

  function generateConfig() {
    const selectedIds = getSelected();
    const selected = PLUGINS.filter(p => selectedIds.includes(p.id));

    if (selected.length === 0) {
      outputSection.classList.add('hidden');
      noSelection.classList.remove('hidden');
      return;
    }
    outputSection.classList.remove('hidden');
    noSelection.classList.add('hidden');

    const pkgs = selected.map(p => p.pkg).join(' ');
    installCmdEl.textContent = `npm install -D ${pkgs}`;

    const imports = selected.map(p => p.import).join('\n');
    const usages = selected.map(p => `    ${p.usage},`).join('\n');
    const config = `import { defineConfig } from 'vite'\n${imports}\n\nexport default defineConfig({\n  plugins: [\n${usages}\n  ],\n})\n`;
    viteConfigOut.textContent = config;
  }

  searchInput.addEventListener('input', filterPlugins);
  catFilter.addEventListener('change', filterPlugins);
  document.getElementById('btn-clear-selection').addEventListener('click', () => {
    document.querySelectorAll('.plugin-check').forEach(cb => { cb.checked = false; });
    generateConfig();
  });

  document.querySelectorAll('.plugin-check').forEach(cb => cb.addEventListener('change', generateConfig));

  document.getElementById('copy-install').addEventListener('click', function() {
    navigator.clipboard.writeText(installCmdEl.textContent || '');
    this.textContent = 'Copied!';
    setTimeout(() => { this.textContent = 'Copy'; }, 2000);
  });
  document.getElementById('copy-config').addEventListener('click', function() {
    navigator.clipboard.writeText(viteConfigOut.textContent || '');
    this.textContent = 'Copied!';
    setTimeout(() => { this.textContent = 'Copy'; }, 2000);
  });
})();
</script>

<!-- Pass plugin data to script -->
