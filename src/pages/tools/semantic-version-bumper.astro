---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SemanticVersionBumper from '../../components/SemanticVersionBumper.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is semantic versioning (semver)?",
    answer: "Semantic Versioning (semver) is a versioning scheme in the format MAJOR.MINOR.PATCH. MAJOR is incremented for breaking (incompatible) API changes. MINOR is incremented for new backward-compatible features. PATCH is incremented for backward-compatible bug fixes. Pre-release identifiers (e.g. 1.0.0-alpha.1) and build metadata (e.g. 1.0.0+build.42) are optional extensions."
  },
  {
    question: "When should I bump the major version?",
    answer: "Bump MAJOR when you introduce a breaking change — meaning existing code that depends on your package may break after upgrading. Examples: removing a public function, changing a function signature in an incompatible way, changing authentication format. For public APIs, a major bump communicates to users that they need to take care when upgrading."
  },
  {
    question: "When should I bump the minor version?",
    answer: "Bump MINOR when you add new functionality that is backward-compatible. Existing code should continue to work after a minor bump. Examples: adding a new optional parameter, adding a new public method, adding a new endpoint. When MINOR is bumped, PATCH resets to 0."
  },
  {
    question: "What is the difference between alpha, beta, and rc pre-release tags?",
    answer: "These are conventions within the semver pre-release field. alpha = early testing, may be unstable. beta = feature-complete, stabilization phase. rc (release candidate) = potentially final version pending last verification. They carry no semantic meaning within the semver spec itself — but the dot-separated numeric suffix (e.g. alpha.1, alpha.2) does affect precedence: alpha.1 < alpha.2 < beta.1 < rc.1 < 1.0.0."
  },
  {
    question: "Does build metadata affect version precedence?",
    answer: "No. Build metadata (the +suffix) is explicitly ignored when determining version precedence according to the semver spec. 1.0.0+build.1 and 1.0.0+build.2 have identical precedence — they are treated as the same version for dependency resolution purposes. Build metadata is typically used for CI build numbers or git SHA references."
  },
  {
    question: "What happens to the pre-release when I bump major, minor, or patch?",
    answer: "Bumping MAJOR, MINOR, or PATCH clears the pre-release identifier and build metadata. For example, bumping PATCH on 1.2.3-beta.4 produces 1.2.4 (not 1.2.4-beta.4). If you are in a pre-release cycle and want to promote to a release, bump the appropriate level without adding a new pre-release tag."
  },
];
---

<BaseLayout
  title="Semantic Version Bumper — Increment semver Versions Online"
  description="Bump semantic version numbers (major, minor, patch, pre-release) with a click. See what each bump produces, get copy-ready new versions, and review semver rules. Free, runs in your browser."
  tool="Semver Bumper, Semantic Version Calculator, semver bump, version increment, major minor patch"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Semantic Version Bumper",
    "url": "https://devplaybook.cc/tools/semantic-version-bumper",
    "description": "Enter a semver version and click major, minor, patch, or pre-release to get the next version. Shows a live preview of all bumps, explains semver rules, and copies new version in one click.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Semantic Version Bumper</h1>
  <p class="text-text-muted mb-4">
    Enter a <a href="https://semver.org" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">semver</a> version and click a bump type to get the next version.
    Preview all bump results at a glance, configure pre-release and build metadata tags, and copy the new version instantly.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Major / minor / patch / pre-release</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live preview of all bump types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Bump history with copy</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100% browser — no server</span>
  </div>
  <SemanticVersionBumper client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Semantic Version Bumper" relatedTags={['developer-tools', 'versioning', 'git', 'npm', 'ci-cd']} />
</BaseLayout>
