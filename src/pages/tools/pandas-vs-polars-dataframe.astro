---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "Why is Polars so much faster than Pandas?",
    answer: "Polars is written in Rust and built on Apache Arrow's columnar memory format, with a query optimizer that compiles expressions to multi-threaded execution plans. Pandas uses NumPy's row-major memory layout, executes operations eagerly in a single thread (by default), and has significant Python overhead per operation. The performance gap widens with larger datasets: on a 1 GB CSV with a groupby-aggregate, Polars is typically 5–20x faster and uses 3–5x less memory than Pandas. Polars also has a lazy evaluation mode (LazyFrame) that automatically optimizes query plans — pushing predicates down and eliminating unnecessary column scans before any data is read."
  },
  {
    question: "What is DuckDB and how does it fit in the DataFrame ecosystem?",
    answer: "DuckDB is an in-process OLAP database — think SQLite but columnar and optimized for analytical queries. You can query Pandas DataFrames, Polars DataFrames, Parquet files, CSV files, and JSON directly from DuckDB with standard SQL. DuckDB's vectorized engine often outperforms both Pandas and Polars for aggregation-heavy SQL-style queries, especially on multi-core machines. The key advantage: SQL syntax is familiar to data analysts who don't want to learn DataFrame APIs. DuckDB works in-process (no server), has a free Python package, and handles files larger than RAM via streaming. Ideal for ad-hoc analytics, replacing Spark for local workloads, and as the engine behind dbt for local development."
  },
  {
    question: "Should I migrate from Pandas to Polars?",
    answer: "It depends on your workload. For datasets under 100k rows, Pandas is fast enough and has the richest ecosystem (sklearn, seaborn, statsmodels all accept Pandas DataFrames natively). For datasets between 100k and 10M rows where performance matters, Polars is a significant upgrade worth the API learning curve. For production ETL pipelines processing millions of rows regularly, the memory and speed savings of Polars typically justify the migration. The Polars API is more explicit than Pandas — operations like filtering use expressions rather than boolean indexing, and the lack of an index forces cleaner column-based thinking. Migration is easiest when you have good test coverage of expected outputs."
  },
  {
    question: "Can Polars and DuckDB replace Spark for large datasets?",
    answer: "For single-machine workloads, yes — Polars and DuckDB can handle datasets up to the available RAM plus disk (via streaming mode). Polars' streaming engine and DuckDB's out-of-core processing can handle datasets of several hundred GB on a single 32-core machine. Apache Spark is still necessary when your data genuinely requires distributed processing across multiple machines (multiple TB or PB scale), or when you need Spark's ecosystem: MLlib, Structured Streaming, Delta Lake connectors, or existing PySpark infrastructure. The trend in 2025–2026 is to replace Spark with DuckDB or Polars for datasets that fit on a large single machine (256 GB RAM), dramatically reducing infrastructure cost and pipeline complexity."
  },
];

const benchmarks = [
  { op: 'Read 1 GB CSV', pandas: 100, polars: 18, duckdb: 12 },
  { op: 'GroupBy + Aggregate', pandas: 100, polars: 8, duckdb: 6 },
  { op: 'Join (1M × 10M rows)', pandas: 100, polars: 12, duckdb: 9 },
  { op: 'Filter + Select (10M rows)', pandas: 100, polars: 5, duckdb: 7 },
  { op: 'Sort (5M rows)', pandas: 100, polars: 15, duckdb: 11 },
];
---

<BaseLayout
  title="Pandas vs Polars vs DuckDB: Python DataFrame Performance 2026"
  description="Compare Pandas, Polars, and DuckDB for Python data processing. Benchmark table, memory comparison, and code snippet switcher showing the same operation in all three APIs."
  tool="Pandas vs Polars, DuckDB comparison, Python DataFrame performance, Polars vs DuckDB, data processing Python, Pandas alternative"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Pandas vs Polars vs DuckDB</h1>
  <p class="text-text-muted mb-4">Three Python data processing tools with very different performance profiles. Compare benchmarks, memory usage, and API ergonomics to pick the right tool for your pipeline.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Performance benchmark table</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Memory comparison</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Code snippet switcher</span>
  </div>

  <!-- Benchmark Table -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6 overflow-x-auto">
    <h2 class="text-base font-semibold mb-1">Performance Benchmark</h2>
    <p class="text-xs text-text-muted mb-4">Normalized relative execution time — Pandas = 100 (baseline). Lower is faster. Based on community benchmarks on a 16-core machine with 32 GB RAM.</p>
    <table class="w-full text-sm min-w-[520px]">
      <thead>
        <tr class="text-text-muted text-xs border-b border-border">
          <th class="text-left pb-3 font-medium">Operation</th>
          <th class="text-center pb-3 font-medium">Pandas</th>
          <th class="text-center pb-3 font-medium">Polars</th>
          <th class="text-center pb-3 font-medium">DuckDB</th>
          <th class="text-center pb-3 font-medium">Polars speedup</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border text-xs">
        {benchmarks.map(row => (
          <tr>
            <td class="py-2.5 text-text-muted font-medium">{row.op}</td>
            <td class="py-2.5 text-center text-red-400">{row.pandas}×</td>
            <td class="py-2.5 text-center text-green-500">{row.polars}×</td>
            <td class="py-2.5 text-center text-primary">{row.duckdb}×</td>
            <td class="py-2.5 text-center font-semibold text-green-500">{Math.round(row.pandas / row.polars)}× faster</td>
          </tr>
        ))}
      </tbody>
    </table>
    <p class="text-xs text-text-muted mt-3">Note: DuckDB benefits most from SQL aggregations; Polars shines at complex multi-step DataFrame operations. Both exceed Pandas by 5–20× in most real-world scenarios.</p>
  </div>

  <!-- Memory Comparison -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-3">Memory Usage Comparison (1 GB CSV file)</h2>
    <div class="space-y-3">
      {[
        { name: 'Pandas', mem: 3.2, pct: 100, color: 'bg-red-500', note: '~3.2 GB RAM (3.2× file size — object dtype, Python overhead)' },
        { name: 'Polars', mem: 0.9, pct: 28, color: 'bg-green-500', note: '~0.9 GB RAM (near file size — Arrow columnar, Rust memory model)' },
        { name: 'DuckDB', mem: 0.4, pct: 13, color: 'bg-primary', note: '~0.4 GB RAM (streaming execution — only materializes result, not full dataset)' },
      ].map(({ name, mem, pct, color, note }) => (
        <div>
          <div class="flex items-center justify-between mb-1">
            <span class="text-xs font-medium">{name}</span>
            <span class="text-xs text-text-muted">{mem} GB</span>
          </div>
          <div class="bg-border rounded-full h-4 overflow-hidden mb-1">
            <div class={`h-full rounded-full ${color}`} style={`width: ${pct}%`}></div>
          </div>
          <p class="text-xs text-text-muted">{note}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Code Snippet Switcher -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-3">Code Snippet Switcher</h2>
    <p class="text-xs text-text-muted mb-3">Same operation — read CSV, filter, groupby, aggregate — in all three APIs:</p>

    <div class="flex gap-2 mb-3 flex-wrap" id="snippet-tabs">
      <button class="snippet-tab active px-3 py-1.5 text-xs rounded-lg bg-primary text-white transition-colors" data-tab="pandas">Pandas</button>
      <button class="snippet-tab px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-tab="polars">Polars</button>
      <button class="snippet-tab px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-tab="duckdb">DuckDB</button>
    </div>

    <div id="tab-pandas" class="snippet-content">
      <pre class="bg-bg-card border border-border rounded-lg p-4 text-xs overflow-x-auto font-mono leading-relaxed"><code>import pandas as pd

# Read CSV
df = pd.read_csv("sales.csv")

# Filter
df = df[df["revenue"] &gt; 1000]

# GroupBy + Aggregate
result = (
    df
    .groupby("region")
    .agg(
        total_revenue=("revenue", "sum"),
        avg_revenue=("revenue", "mean"),
        order_count=("order_id", "count"),
    )
    .reset_index()
    .sort_values("total_revenue", ascending=False)
)

print(result.head(10))</code></pre>
    </div>

    <div id="tab-polars" class="snippet-content hidden">
      <pre class="bg-bg-card border border-border rounded-lg p-4 text-xs overflow-x-auto font-mono leading-relaxed"><code>import polars as pl

# Read CSV (lazy — no data loaded yet)
result = (
    pl.scan_csv("sales.csv")           # LazyFrame
    .filter(pl.col("revenue") &gt; 1000)  # predicate pushdown
    .group_by("region")
    .agg([
        pl.col("revenue").sum().alias("total_revenue"),
        pl.col("revenue").mean().alias("avg_revenue"),
        pl.col("order_id").count().alias("order_count"),
    ])
    .sort("total_revenue", descending=True)
    .collect()                         # execute NOW
)

print(result.head(10))</code></pre>
    </div>

    <div id="tab-duckdb" class="snippet-content hidden">
      <pre class="bg-bg-card border border-border rounded-lg p-4 text-xs overflow-x-auto font-mono leading-relaxed"><code>import duckdb

# Query CSV directly — no load step needed
result = duckdb.sql("""
    SELECT
        region,
        SUM(revenue)        AS total_revenue,
        AVG(revenue)        AS avg_revenue,
        COUNT(order_id)     AS order_count
    FROM read_csv_auto('sales.csv')
    WHERE revenue &gt; 1000
    GROUP BY region
    ORDER BY total_revenue DESC
    LIMIT 10
""").df()   # .df() returns a Pandas DataFrame

print(result)</code></pre>
    </div>

    <div class="mt-3 grid grid-cols-1 sm:grid-cols-3 gap-3">
      {[
        { lib: 'Pandas', verdict: 'Most familiar API. Largest ecosystem. Use for prototyping and small datasets.', color: 'border-yellow-500/30' },
        { lib: 'Polars', verdict: 'Best for complex multi-step transformations. Type-safe expressions. Lazy optimization.', color: 'border-green-500/30' },
        { lib: 'DuckDB', verdict: 'Best for SQL-style aggregations. Queries files directly. Zero setup — pip install duckdb.', color: 'border-primary/30' },
      ].map(({ lib, verdict, color }) => (
        <div class={`border ${color} rounded-lg p-3`}>
          <p class="text-xs font-semibold mb-1">{lib}</p>
          <p class="text-xs text-text-muted">{verdict}</p>
        </div>
      ))}
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Pandas vs Polars vs DuckDB" relatedTags={['pandas', 'polars', 'duckdb', 'python', 'data-science', 'dataframe', 'data-engineering', 'analytics']} />
</BaseLayout>

<script>
  document.querySelectorAll('.snippet-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.tab!;

      document.querySelectorAll('.snippet-tab').forEach(t => {
        t.classList.remove('bg-primary', 'text-white');
        t.classList.add('border', 'border-border');
      });
      tab.classList.add('bg-primary', 'text-white');
      tab.classList.remove('border', 'border-border');

      document.querySelectorAll('.snippet-content').forEach(el => el.classList.add('hidden'));
      document.getElementById(`tab-${target}`)!.classList.remove('hidden');
    });
  });
</script>
