---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TechSalaryCalculator from '../../components/TechSalaryCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Tech Salary Calculator — Software Engineer Salary by Role, City & Experience"
  description="Estimate software engineer salary ranges by role, location, and experience level. Covers SF, NYC, Seattle, Remote, London, Berlin, Toronto & more. Free, no signup."
  tool="Tech Salary Calculator, Software Engineer Salary, Developer Salary by City, Tech Salary by Experience"
>
  <h1 class="text-3xl font-bold mb-2">Tech Salary Calculator</h1>
  <p class="text-text-muted mb-8">Estimate software engineer compensation by role, location, and experience level. Data sourced from Levels.fyi, LinkedIn Salary, and Glassdoor (2024–2025). Runs entirely in your browser.</p>
  <TechSalaryCalculator client:only="preact" />
  <ToolPageCta currentTool="Tech Salary Calculator" relatedTags={['career', 'salary', 'job', 'developer']} />
</BaseLayout>
