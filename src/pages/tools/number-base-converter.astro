---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NumberBaseConverter from '../../components/NumberBaseConverter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Number Base Converter"
  description="Convert numbers between binary, octal, decimal, and hexadecimal instantly. Enter any value in any base and see all conversions at once. Runs in your browser."
  tool="Number Base Converter, Binary to Decimal, Hex to Binary, Base Conversion Calculator"
>
  <h1 class="text-3xl font-bold mb-2">Number Base Converter</h1>
  <p class="text-text-muted mb-8">Convert between binary (base 2), octal (base 8), decimal (base 10), and hexadecimal (base 16) instantly. Enter a number in any field — all others update automatically.</p>
  <NumberBaseConverter client:only="preact" />
  <ToolPageCta currentTool="Number Base Converter" relatedTags={['binary', 'hex', 'math', 'encoding', 'low-level']} />
</BaseLayout>
