---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is alert fatigue and why is it dangerous?", answer: "Alert fatigue occurs when on-call engineers are overwhelmed by high volumes of alerts — many of which are noise, duplicates, or self-resolving. The danger: engineers start ignoring or bulk-dismissing alerts, which means real critical incidents get missed. Studies show that teams with >50% noisy alerts have significantly higher MTTR because genuine signals are buried. Alert fatigue also causes burnout and increased on-call attrition." },
  { question: "What is a good alert noise ratio?", answer: "A healthy alert environment has an actionable rate of 75%+, meaning most alerts require human action. Noise ratio below 25% is the target. Teams with noise ratios above 50% should immediately audit their alerting rules — start with flapping alerts (self-resolving within 5 minutes) and alerts that have been ACKd without action for 30+ days." },
  { question: "What are flapping alerts and how do I fix them?", answer: "Flapping alerts fire and resolve within minutes (typically <5 minutes) repeatedly, often without meaningful human intervention. Common causes: thresholds set too close to normal operating levels, missing hysteresis (the threshold for alerting vs. clearing should differ), or genuinely intermittent infrastructure issues. Fix by: adding minimum-duration requirements (alert only if condition persists 5+ minutes), adding hysteresis, or addressing the underlying instability." },
  { question: "How should I calculate alert fatigue score?", answer: "A pragmatic fatigue score factors in: noise ratio (high noise = high score), acknowledgement time (slow ack = engineers are overwhelmed), resolution time relative to ack time (long gap = poor runbooks or unclear alerts), and flapping rate. A score above 70/100 indicates severe fatigue requiring immediate intervention. Below 30 is healthy." },
  { question: "What are the best practices for reducing alert noise?", answer: "Key strategies: (1) Alert on symptoms, not causes — 'user checkout failing' not 'high CPU on checkout-service-3'. (2) Set meaningful thresholds with hysteresis. (3) Group related alerts into single incidents (alert correlation). (4) Add minimum duration requirements. (5) Regular alert reviews — monthly audit to delete alerts unacted on in 30 days. (6) Ownership — every alert must have a clear owner who maintains it." },
];
---

<BaseLayout
  title="Alert Fatigue Analyzer — On-Call Alert Noise & Actionability Analyzer"
  description="Analyze your alert volume and quality to diagnose on-call fatigue. Calculate noise ratio, actionable rate, MTTA, MTTR, and fatigue score. Get actionable improvement recommendations."
  tool="Alert Fatigue Analyzer, Alert Noise Calculator, On-Call Alert Quality, MTTA Calculator, Alert Actionability Score, SRE Alert Audit"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Alert Fatigue Analyzer</h1>
  <p class="text-text-muted mb-4">Diagnose alert fatigue by analyzing your alert volume, actionability, and engineer workload. Get a fatigue score and prioritized recommendations to reduce noise.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Alert noise & actionability ratio</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> MTTA & MTTR calculation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Fatigue score with recommendations</span>
  </div>

  <!-- Alert Volume Inputs -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Alert Volume (Weekly)</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Total Alerts per Week</label>
        <input id="total-alerts" type="number" value="420" min="0"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Actionable Alerts per Week</label>
        <input id="actionable-alerts" type="number" value="140" min="0"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        <p class="text-xs text-text-muted mt-1">Alerts that required engineer action</p>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Flapping Alerts per Week</label>
        <input id="flapping-alerts" type="number" value="85" min="0"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        <p class="text-xs text-text-muted mt-1">Auto-resolved within 5 minutes</p>
      </div>
    </div>
  </div>

  <!-- Response Time Inputs -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Response Times & Team Size</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Avg Time to Acknowledge (min)</label>
        <input id="avg-ack-time" type="number" value="18" min="0" step="0.5"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Avg Time to Resolve (min)</label>
        <input id="avg-resolve-time" type="number" value="95" min="0"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">On-Call Engineers</label>
        <input id="oncall-engineers" type="number" value="3" min="1" max="50"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Working Hours per Day</label>
        <select id="working-hours" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="8">8h (business hours only)</option>
          <option value="12" selected>12h (extended coverage)</option>
          <option value="24">24h (follow-the-sun / 24x7)</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Results -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Analysis Results</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-5">
      <div class="bg-bg-card border border-border rounded-lg p-3 text-center">
        <div id="noise-ratio" class="text-2xl font-bold mb-1">66.7%</div>
        <div class="text-xs text-text-muted">Alert Noise Ratio</div>
      </div>
      <div class="bg-bg-card border border-border rounded-lg p-3 text-center">
        <div id="actionable-rate" class="text-2xl font-bold text-primary mb-1">33.3%</div>
        <div class="text-xs text-text-muted">Actionable Rate</div>
      </div>
      <div class="bg-bg-card border border-border rounded-lg p-3 text-center">
        <div id="mtta-result" class="text-2xl font-bold text-primary mb-1">18m</div>
        <div class="text-xs text-text-muted">MTTA</div>
      </div>
      <div class="bg-bg-card border border-border rounded-lg p-3 text-center">
        <div id="mttr-result" class="text-2xl font-bold text-primary mb-1">95m</div>
        <div class="text-xs text-text-muted">MTTR</div>
      </div>
    </div>

    <!-- Fatigue Score -->
    <div class="bg-bg-card border border-border rounded-lg p-5 mb-4">
      <div class="flex items-center justify-between mb-3">
        <span class="text-sm font-medium">Alert Fatigue Score</span>
        <span id="fatigue-score-text" class="text-lg font-bold">72 / 100</span>
      </div>
      <div class="w-full bg-bg-card border border-border rounded-full h-4 mb-2">
        <div id="fatigue-bar" class="h-full rounded-full transition-all duration-500" style="width:72%"></div>
      </div>
      <div class="flex justify-between text-xs text-text-muted">
        <span>Healthy (0-30)</span>
        <span>Moderate (31-60)</span>
        <span>Severe (61-80)</span>
        <span>Critical (81-100)</span>
      </div>
    </div>

    <div id="alerts-per-engineer" class="bg-bg-card border border-border rounded-lg p-4 text-sm mb-3"></div>
    <div id="recommendations" class="bg-bg-card border border-border rounded-lg p-4 text-sm"></div>
  </div>

  <!-- Benchmark Comparison -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-3">Industry Benchmarks</h2>
    <div id="benchmark-table" class="overflow-x-auto"></div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Alert Fatigue Analyzer" relatedTags={['devops', 'sre', 'monitoring', 'alerting', 'oncall', 'reliability']} />
</BaseLayout>

<script>
  function getVal(id: string): number {
    return parseFloat((document.getElementById(id) as HTMLInputElement).value) || 0;
  }
  function getSel(id: string): number {
    return parseFloat((document.getElementById(id) as HTMLSelectElement).value) || 0;
  }

  function calculate() {
    const totalAlerts = getVal('total-alerts');
    const actionableAlerts = Math.min(getVal('actionable-alerts'), totalAlerts);
    const flappingAlerts = getVal('flapping-alerts');
    const avgAckMin = getVal('avg-ack-time');
    const avgResolveMin = getVal('avg-resolve-time');
    const oncallEngineers = Math.max(1, getVal('oncall-engineers'));
    const workingHours = getSel('working-hours');

    const noiseAlerts = totalAlerts - actionableAlerts;
    const noiseRatio = totalAlerts > 0 ? (noiseAlerts / totalAlerts) * 100 : 0;
    const actionableRate = totalAlerts > 0 ? (actionableAlerts / totalAlerts) * 100 : 100;

    // Noise ratio display
    const noiseEl = document.getElementById('noise-ratio')!;
    noiseEl.textContent = `${noiseRatio.toFixed(1)}%`;
    noiseEl.className = `text-2xl font-bold mb-1 ${noiseRatio > 60 ? 'text-red-500' : noiseRatio > 30 ? 'text-yellow-500' : 'text-green-500'}`;

    document.getElementById('actionable-rate')!.textContent = `${actionableRate.toFixed(1)}%`;
    document.getElementById('mtta-result')!.textContent = `${avgAckMin.toFixed(0)}m`;
    document.getElementById('mttr-result')!.textContent = `${avgResolveMin.toFixed(0)}m`;

    // Fatigue score (0-100)
    let fatigueScore = 0;

    // Noise contribution (0-35)
    fatigueScore += Math.min(35, (noiseRatio / 100) * 35);

    // Flapping contribution (0-20)
    const flappingRate = totalAlerts > 0 ? (flappingAlerts / totalAlerts) * 100 : 0;
    fatigueScore += Math.min(20, (flappingRate / 100) * 20);

    // MTTA contribution (0-20) — >30min is bad
    fatigueScore += Math.min(20, (avgAckMin / 60) * 20);

    // Alerts per engineer per day (0-25)
    const alertsPerEngPerDay = (totalAlerts / 7) / oncallEngineers;
    fatigueScore += Math.min(25, (alertsPerEngPerDay / 20) * 25); // 20 alerts/eng/day = max score

    fatigueScore = Math.min(100, Math.round(fatigueScore));

    document.getElementById('fatigue-score-text')!.textContent = `${fatigueScore} / 100`;
    const bar = document.getElementById('fatigue-bar')!;
    bar.style.width = `${fatigueScore}%`;
    if (fatigueScore >= 81) bar.className = 'h-full rounded-full bg-red-500 transition-all duration-500';
    else if (fatigueScore >= 61) bar.className = 'h-full rounded-full bg-orange-500 transition-all duration-500';
    else if (fatigueScore >= 31) bar.className = 'h-full rounded-full bg-yellow-500 transition-all duration-500';
    else bar.className = 'h-full rounded-full bg-green-500 transition-all duration-500';

    // Alerts per engineer
    const hoursOnCall = workingHours * 7;
    const actionablePerEng = (actionableAlerts / 7) / oncallEngineers;
    const totalTimeInAlerts = actionableAlerts * (avgResolveMin / 60) / oncallEngineers;
    document.getElementById('alerts-per-engineer')!.innerHTML = `
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <div class="text-text-muted text-xs mb-1">Alerts per Eng / Day</div>
          <div class="font-semibold ${alertsPerEngPerDay > 15 ? 'text-red-500' : alertsPerEngPerDay > 8 ? 'text-yellow-500' : 'text-green-500'}">${alertsPerEngPerDay.toFixed(1)}</div>
        </div>
        <div>
          <div class="text-text-muted text-xs mb-1">Actionable / Eng / Day</div>
          <div class="font-semibold">${actionablePerEng.toFixed(1)}</div>
        </div>
        <div>
          <div class="text-text-muted text-xs mb-1">Hours/Eng/Wk on Alerts</div>
          <div class="font-semibold ${totalTimeInAlerts > 20 ? 'text-red-500' : totalTimeInAlerts > 10 ? 'text-yellow-500' : 'text-green-500'}">${totalTimeInAlerts.toFixed(1)}h / ${hoursOnCall}h coverage</div>
        </div>
      </div>
    `;

    // Recommendations
    const recs: string[] = [];
    if (noiseRatio > 50) recs.push(`<strong>Critical: ${noiseRatio.toFixed(0)}% noise ratio</strong> — Audit all alerts. Delete any alert that hasn't been acted on in 30 days.`);
    if (flappingRate > 15) recs.push(`<strong>Fix flapping alerts</strong> — ${flappingAlerts} alerts/week self-resolve. Add 5-minute minimum-duration rules and hysteresis to these alert definitions.`);
    if (avgAckMin > 20) recs.push(`<strong>Slow acknowledgement (${avgAckMin}min)</strong> — Engineers are overwhelmed. Reduce alert volume first, then improve runbook quality.`);
    if (alertsPerEngPerDay > 10) recs.push(`<strong>High alert density (${alertsPerEngPerDay.toFixed(1)}/eng/day)</strong> — Consider adding on-call rotation engineers or aggressive noise reduction before the next quarter.`);
    if (actionableRate < 50) recs.push('Switch to symptom-based alerting — alert on user-visible failures, not internal metrics. Reduces noise by 40-60% in most systems.');
    if (totalTimeInAlerts > hoursOnCall * 0.3) recs.push(`Engineers spending ${((totalTimeInAlerts / hoursOnCall) * 100).toFixed(0)}% of on-call time on alerts — unsustainable. Prioritize runbook automation.`);
    if (recs.length === 0) recs.push('Alert health looks good! Maintain regular monthly reviews to prevent regression.');

    document.getElementById('recommendations')!.innerHTML = `
      <div class="font-medium mb-2">Recommendations</div>
      <ul class="space-y-2 text-text-muted">
        ${recs.map(r => `<li class="flex items-start gap-2"><span class="mt-0.5 text-primary">→</span><span>${r}</span></li>`).join('')}
      </ul>
    `;

    // Benchmark table
    const benchmarks = [
      { metric: 'Alert Noise Ratio', yours: `${noiseRatio.toFixed(1)}%`, good: '<25%', acceptable: '25-50%', poor: '>50%', status: noiseRatio < 25 ? 'good' : noiseRatio < 50 ? 'ok' : 'poor' },
      { metric: 'Actionable Rate', yours: `${actionableRate.toFixed(1)}%`, good: '>75%', acceptable: '50-75%', poor: '<50%', status: actionableRate > 75 ? 'good' : actionableRate > 50 ? 'ok' : 'poor' },
      { metric: 'MTTA', yours: `${avgAckMin}min`, good: '<5min', acceptable: '5-20min', poor: '>20min', status: avgAckMin < 5 ? 'good' : avgAckMin < 20 ? 'ok' : 'poor' },
      { metric: 'Flapping Rate', yours: `${flappingRate.toFixed(1)}%`, good: '<5%', acceptable: '5-15%', poor: '>15%', status: flappingRate < 5 ? 'good' : flappingRate < 15 ? 'ok' : 'poor' },
      { metric: 'Alerts/Eng/Day', yours: `${alertsPerEngPerDay.toFixed(1)}`, good: '<5', acceptable: '5-10', poor: '>10', status: alertsPerEngPerDay < 5 ? 'good' : alertsPerEngPerDay < 10 ? 'ok' : 'poor' },
    ];
    const statusColors: Record<string, string> = { good: 'text-green-500', ok: 'text-yellow-500', poor: 'text-red-500' };
    const statusLabels: Record<string, string> = { good: 'Good', ok: 'Acceptable', poor: 'Needs Work' };
    document.getElementById('benchmark-table')!.innerHTML = `
      <table class="w-full text-sm min-w-[500px]">
        <thead><tr class="text-text-muted text-xs uppercase border-b border-border">
          <th class="text-left pb-2 pr-4">Metric</th>
          <th class="text-right pb-2 pr-4">Your Value</th>
          <th class="text-right pb-2 pr-4 text-green-500">Good</th>
          <th class="text-right pb-2 pr-4 text-yellow-500">Acceptable</th>
          <th class="text-right pb-2 pr-4 text-red-500">Poor</th>
          <th class="text-right pb-2">Status</th>
        </tr></thead>
        <tbody class="divide-y divide-border">
          ${benchmarks.map(b => `<tr>
            <td class="py-2.5 pr-4 font-medium">${b.metric}</td>
            <td class="py-2.5 pr-4 text-right font-mono font-semibold ${statusColors[b.status]}">${b.yours}</td>
            <td class="py-2.5 pr-4 text-right text-text-muted text-xs">${b.good}</td>
            <td class="py-2.5 pr-4 text-right text-text-muted text-xs">${b.acceptable}</td>
            <td class="py-2.5 pr-4 text-right text-text-muted text-xs">${b.poor}</td>
            <td class="py-2.5 text-right font-medium ${statusColors[b.status]}">${statusLabels[b.status]}</td>
          </tr>`).join('')}
        </tbody>
      </table>
    `;
  }

  document.querySelectorAll('input, select').forEach(el => el.addEventListener('input', calculate));
  calculate();
</script>
