---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is the simplest way to convert a Jupyter notebook to a Python script?",
    answer: "The simplest method is using nbconvert from the command line: `jupyter nbconvert --to script notebook.ipynb`. This produces a .py file with all code cells preserved and markdown cells converted to comments. Install nbconvert with `pip install nbconvert` if it's not already available in your environment."
  },
  {
    question: "How do I strip outputs and metadata when converting notebooks?",
    answer: "Use the `--no-input` flag to omit input cells or combine nbconvert with nbstripout. For stripping outputs before conversion run: `nbstripout notebook.ipynb && jupyter nbconvert --to script notebook.ipynb`. You can also add a pre-commit hook with nbstripout to automatically strip outputs on every commit, keeping your repository clean."
  },
  {
    question: "What is the difference between nbconvert, jupytext, and papermill?",
    answer: "nbconvert is the standard one-way export tool — it converts .ipynb to .py, HTML, PDF, etc. Jupytext keeps notebooks and scripts in sync bidirectionally: edit either file and both stay updated, which is ideal for version control workflows. Papermill is for parameterized notebook execution — it runs notebooks with injected parameters and saves outputs, making it perfect for scheduled batch jobs without converting to scripts at all."
  },
  {
    question: "How can I integrate notebook-to-script conversion into a CI/CD pipeline?",
    answer: "Add a GitHub Actions step that runs `jupyter nbconvert --to script notebooks/*.ipynb` and commits the resulting .py files, or use them directly as pipeline stages. Alternatively, use Makefile targets or pre-commit hooks. For data science teams, a common pattern is to keep .ipynb for exploration, auto-generate .py for CI tests, and run pytest against the generated scripts to validate reproducibility."
  },
  {
    question: "How do I preserve cell tags or only export specific cells?",
    answer: "Tag cells in Jupyter with the 'tags' metadata field (e.g., 'parameters', 'injected-parameters', 'exclude'). Then use nbconvert with a custom Exporter or the TagRemovePreprocessor to skip tagged cells: `jupyter nbconvert --to script --TagRemovePreprocessor.enabled=True --TagRemovePreprocessor.remove_cell_tags='[\"exclude\"]' notebook.ipynb`. This lets you keep exploratory cells in the notebook while exporting only production-ready code."
  },
  {
    question: "What is jupytext and why would I use it instead of nbconvert?",
    answer: "Jupytext pairs every .ipynb notebook with a lightweight .py (or .md, .R) file and keeps them synchronized. Unlike nbconvert which is one-shot, jupytext is designed for ongoing workflows. You can open the .py file in any editor, run it as a normal script, commit clean diffs to Git, and Jupyter will automatically sync changes back to the notebook. Enable it with `pip install jupytext` and configure it in jupyter_notebook_config.py or per-notebook via the Jupytext menu."
  }
];

const nbconvertExample = `# Basic conversion
jupyter nbconvert --to script analysis.ipynb

# Convert all notebooks in a directory
jupyter nbconvert --to script notebooks/*.ipynb

# Convert and execute before exporting
jupyter nbconvert --to script --execute analysis.ipynb

# Strip outputs first, then convert
pip install nbstripout
nbstripout analysis.ipynb
jupyter nbconvert --to script analysis.ipynb

# Export only code (no markdown as comments)
jupyter nbconvert --to script --no-prompt analysis.ipynb`;

const papermillExample = `# Install papermill
pip install papermill

# Run notebook with parameters
papermill input_notebook.ipynb output_notebook.ipynb \\
  -p alpha 0.05 \\
  -p data_path /data/train.csv \\
  -p n_estimators 200

# Run from Python
import papermill as pm

pm.execute_notebook(
   'analysis_template.ipynb',
   'analysis_output_2026-04-02.ipynb',
   parameters=dict(
       alpha=0.05,
       data_path='/data/train.csv',
       n_estimators=200
   )
)`;

const jupytextExample = `# Install jupytext
pip install jupytext

# Pair an existing notebook with a .py file
jupytext --set-formats ipynb,py:percent analysis.ipynb

# Sync changes from .py back to .ipynb
jupytext --sync analysis.py

# Convert .py to .ipynb
jupytext --to notebook analysis.py

# Auto-pair all new notebooks (add to jupyter_notebook_config.py)
# c.ContentsManager.default_jupytext_formats = "ipynb,py:percent"

# The percent format looks like this in .py:
# %% [markdown]
# # Section Title

# %%
import pandas as pd
df = pd.read_csv('data.csv')`;

const cicdExample = `# .github/workflows/notebook-tests.yml
name: Notebook Tests

on: [push, pull_request]

jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.11'

      - name: Install dependencies
        run: |
          pip install jupyter nbconvert nbstripout pytest

      - name: Strip outputs
        run: nbstripout notebooks/*.ipynb

      - name: Convert notebooks to scripts
        run: jupyter nbconvert --to script notebooks/*.ipynb --output-dir=tests/

      - name: Run tests
        run: pytest tests/ -v`;
---
<BaseLayout
  title="Jupyter Notebook to Python Script Converter — Convert .ipynb to .py"
  description="Complete guide to converting Jupyter notebooks to Python scripts using nbconvert, jupytext, and papermill. Includes CI/CD integration, output stripping, and best practices."
  tool="jupyter-nb-to-script-converter"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Jupyter Notebook to Python Script Converter</h1>
  <p class="text-text-muted mb-6">Convert .ipynb notebooks to clean .py scripts with nbconvert, jupytext, and papermill — with CI/CD integration and best practices.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="text-green-500">✓ nbconvert CLI</span>
    <span class="text-green-500">✓ Jupytext sync</span>
    <span class="text-green-500">✓ Papermill params</span>
    <span class="text-green-500">✓ CI/CD ready</span>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Why Convert Notebooks to Scripts?</h2>
  <p class="mb-4">Jupyter notebooks are indispensable for exploratory data analysis and rapid prototyping, but they come with real friction in production workflows. Version control diffs are noisy JSON blobs, notebooks can't be imported as modules, and CI/CD pipelines expect plain Python files. Converting .ipynb files to .py scripts unlocks cleaner Git history, standard linting tools, automated testing with pytest, and straightforward deployment to production systems.</p>
  <p class="mb-4">The Python ecosystem offers three distinct tools for this — each solving a different part of the problem. <strong>nbconvert</strong> is the standard one-way exporter. <strong>Jupytext</strong> maintains bidirectional sync between notebook and script formats. <strong>Papermill</strong> executes parameterized notebooks without converting them at all. Understanding which tool fits your workflow is the first step.</p>

  <h2 class="text-2xl font-semibold mt-8 mb-3">nbconvert: The Standard CLI Converter</h2>
  <p class="mb-4">nbconvert ships with JupyterLab and is the go-to tool for one-time or scripted conversions. It supports multiple output formats including Python scripts, HTML, LaTeX, PDF, Markdown, and RST. For script conversion, markdown cells become Python comments and code cells are preserved as-is.</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto text-sm mb-6"><code set:html={nbconvertExample}></code></pre>
  <p class="mb-4">Key flags to know:</p>
  <ul class="list-disc pl-6 mb-4 space-y-1">
    <li><code>--to script</code> — output format (also: html, pdf, markdown, rst)</li>
    <li><code>--execute</code> — run the notebook before exporting</li>
    <li><code>--output-dir</code> — specify a different output directory</li>
    <li><code>--no-prompt</code> — omit In[N] / Out[N] prompts</li>
    <li><code>--TagRemovePreprocessor.enabled=True</code> — filter cells by tag</li>
  </ul>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Papermill: Parameterized Notebook Execution</h2>
  <p class="mb-4">Papermill takes a different approach — instead of converting notebooks to scripts, it runs them with injected parameters and saves the executed output as a new notebook. This is ideal for scheduled reports, batch processing jobs, and model retraining pipelines where you want to preserve the rich output (plots, DataFrames, logs) alongside the code.</p>
  <p class="mb-4">Tag a cell with <code>parameters</code> in Jupyter's cell metadata to mark it as the injection point. Papermill replaces that cell's values at runtime.</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto text-sm mb-6"><code set:html={papermillExample}></code></pre>
  <p class="mb-4">Papermill integrates naturally with Airflow, Prefect, and Luigi. Each DAG task can execute a notebook with different parameters, and the output notebooks serve as self-documenting execution logs — far richer than plain text logs.</p>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Jupytext: Bidirectional Sync for Teams</h2>
  <p class="mb-4">Jupytext solves the version control problem by pairing every notebook with a lightweight text representation (.py, .md, or .R). When you edit either file, Jupytext synchronizes the changes to the other. Your Git diffs become readable Python code, code review in GitHub PRs becomes possible, and any developer can work in their preferred editor without losing notebook functionality.</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto text-sm mb-6"><code set:html={jupytextExample}></code></pre>
  <p class="mb-4">The <code>percent</code> format is the most popular — cells are delimited by <code># %%</code> markers, which VS Code, Spyder, and PyCharm all recognize natively. The <code>light</code> format is even cleaner but less compatible with editors.</p>

  <h2 class="text-2xl font-semibold mt-8 mb-3">CI/CD Integration</h2>
  <p class="mb-4">A robust notebook CI/CD pipeline typically combines nbstripout (to strip outputs before commit), nbconvert (to generate testable scripts), and pytest (to validate the generated code). Here is a complete GitHub Actions workflow:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto text-sm mb-6"><code set:html={cicdExample}></code></pre>
  <p class="mb-4">For pre-commit hooks, add nbstripout to your <code>.pre-commit-config.yaml</code>:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto text-sm mb-6"><code>{`repos:
  - repo: https://github.com/kynan/nbstripout
    rev: 0.6.1
    hooks:
      - id: nbstripout`}</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Best Practices for Production Notebook Workflows</h2>
  <ul class="list-disc pl-6 mb-4 space-y-2">
    <li><strong>Separate exploration from production:</strong> Keep exploratory notebooks in a <code>notebooks/</code> folder and auto-generate scripts to <code>src/</code> for import and testing.</li>
    <li><strong>Always strip outputs before committing:</strong> Use nbstripout as a pre-commit hook to keep repository size manageable and diffs meaningful.</li>
    <li><strong>Use cell tags consistently:</strong> Tag cells as <code>parameters</code>, <code>imports</code>, <code>visualization</code>, or <code>exclude</code> to enable selective export and papermill parameterization.</li>
    <li><strong>Test generated scripts in CI:</strong> Convert notebooks and run basic smoke tests (import, shape checks, output type checks) in every pull request.</li>
    <li><strong>Pin nbconvert version:</strong> Conversion behavior can change between versions. Pin to a specific version in requirements-dev.txt to ensure reproducible builds.</li>
    <li><strong>Consider Quarto for documentation:</strong> If your notebooks produce reports, Quarto extends the nbconvert concept with richer templating and multi-format publishing.</li>
  </ul>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Choosing the Right Tool</h2>
  <p class="mb-4">Use <strong>nbconvert</strong> when you need a one-off or scripted export and don't need the scripts to stay in sync with the notebook. Use <strong>jupytext</strong> when your team works across notebooks and editors and you want clean Git history. Use <strong>papermill</strong> when you want to run notebooks as scheduled jobs with varying parameters and need execution records. Many mature data science teams use all three in combination — jupytext for development, nbconvert for CI tests, and papermill for production scheduling.</p>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="jupyter-nb-to-script-converter" relatedTags={['jupyter', 'python', 'data-science', 'notebooks', 'automation', 'ml']} />
</BaseLayout>
