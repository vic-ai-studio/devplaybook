---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="TLS Certificate Decoder — Parse PEM Certificates Online"
  description="Decode and inspect TLS/SSL certificates online. Parse PEM-encoded certificates to view subject, issuer, validity dates, SANs (Subject Alternative Names), key usage, and fingerprints. Free, runs in your browser."
  tool="TLS certificate decoder, SSL certificate parser, PEM decoder, X.509 certificate, SAN viewer, certificate expiry checker, certificate fingerprint, PKI tools"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "TLS Certificate Decoder",
    "url": "https://devplaybook.cc/tools/tls-certificate-decoder",
    "description": "Decode and inspect TLS/SSL certificates online. Parse PEM-encoded certificates to view subject, issuer, validity dates, SANs, key usage, and fingerprints. Free, runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">TLS Certificate Decoder</h1>
  <p class="text-text-muted mb-4">Paste a PEM-encoded TLS/SSL certificate to decode all fields: subject, issuer, validity dates, SANs, serial number, key usage, and more. No data leaves your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Parses PEM certificates (X.509)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Subject, issuer, SANs, key usage</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Expiry warning detection</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs entirely in your browser</span>
  </div>

  <div class="mb-4">
    <label class="block text-sm font-medium mb-2">Paste PEM Certificate</label>
    <textarea id="pem-input" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary resize-none" rows="10" placeholder="-----BEGIN CERTIFICATE-----&#10;MIIDazCCAlOgAwIBAgIUE...&#10;-----END CERTIFICATE-----"></textarea>
  </div>
  <div class="flex gap-3 mb-6 flex-wrap">
    <button id="btn-decode-cert" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Decode Certificate</button>
    <button id="btn-cert-example" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Load Example</button>
    <button id="btn-cert-clear" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Clear</button>
  </div>

  <div id="cert-error" class="hidden mb-4 p-4 bg-red-500/10 border border-red-500/30 rounded-lg text-sm text-red-400"></div>

  <div id="cert-result" class="hidden space-y-4">
    <!-- Status banner -->
    <div id="cert-status-banner" class="p-4 rounded-lg text-sm font-semibold flex items-center gap-2"></div>

    <!-- Subject -->
    <div class="bg-bg-card border border-border rounded-lg overflow-hidden">
      <div class="flex items-center justify-between px-4 py-2.5 border-b border-border bg-blue-500/5">
        <span class="text-sm font-semibold text-blue-400">Subject</span>
        <button class="cert-copy-section px-3 py-1 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-target="cert-subject-content">Copy</button>
      </div>
      <div id="cert-subject-content" class="p-4 space-y-2"></div>
    </div>

    <!-- Issuer -->
    <div class="bg-bg-card border border-border rounded-lg overflow-hidden">
      <div class="flex items-center justify-between px-4 py-2.5 border-b border-border bg-purple-500/5">
        <span class="text-sm font-semibold text-purple-400">Issuer</span>
        <button class="cert-copy-section px-3 py-1 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-target="cert-issuer-content">Copy</button>
      </div>
      <div id="cert-issuer-content" class="p-4 space-y-2"></div>
    </div>

    <!-- Validity -->
    <div class="bg-bg-card border border-border rounded-lg overflow-hidden">
      <div class="px-4 py-2.5 border-b border-border bg-green-500/5">
        <span class="text-sm font-semibold text-green-400">Validity Period</span>
      </div>
      <div class="p-4 grid grid-cols-1 sm:grid-cols-2 gap-4" id="cert-validity-content"></div>
    </div>

    <!-- SANs -->
    <div id="cert-sans-wrapper" class="bg-bg-card border border-border rounded-lg overflow-hidden">
      <div class="flex items-center justify-between px-4 py-2.5 border-b border-border">
        <span class="text-sm font-semibold">Subject Alternative Names (SANs)</span>
        <span id="cert-sans-count" class="text-xs text-text-muted"></span>
      </div>
      <div id="cert-sans-content" class="p-4 flex flex-wrap gap-2"></div>
    </div>

    <!-- Technical details -->
    <div class="bg-bg-card border border-border rounded-lg overflow-hidden">
      <div class="px-4 py-2.5 border-b border-border">
        <span class="text-sm font-semibold">Technical Details</span>
      </div>
      <div id="cert-technical-content" class="p-4 space-y-2"></div>
    </div>

    <!-- Raw DER info -->
    <div class="bg-bg-card border border-border rounded-lg overflow-hidden">
      <div class="flex items-center justify-between px-4 py-2.5 border-b border-border">
        <span class="text-sm font-semibold">Raw Base64 (DER encoded)</span>
        <button id="btn-copy-raw" class="px-3 py-1 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">Copy</button>
      </div>
      <pre id="cert-raw-content" class="p-4 font-mono text-xs text-text-muted whitespace-pre-wrap break-all overflow-x-auto max-h-48 overflow-y-auto"></pre>
    </div>
  </div>

  <ToolPageCta />
</BaseLayout>

<script>
// ── PEM / ASN.1 Parser ─────────────────────────────────────────────────────
// Lightweight client-side X.509 PEM decoder using ASN.1 DER parsing

const EXAMPLE_PEM = `-----BEGIN CERTIFICATE-----
MIIFazCCA1OgAwIBAgIRAIIQz7DSQONZRGPgu2OCiwAwDQYJKoZIhvcNAQELBQAw
TzELMAkGA1UEBhMCVVMxKTAnBgNVBAoTIEludGVybmV0IFNlY3VyaXR5IFJlc2Vh
cmNoIEdyb3VwMRUwEwYDVQQDEwxJU1JHIFJvb3QgWDEwHhcNMTUwNjA0MTEwNDM4
