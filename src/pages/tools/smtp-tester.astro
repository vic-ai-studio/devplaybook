---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SmtpTester from '../../components/SmtpTester.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "Why can't this tool make a real SMTP connection?",
    answer: "Browsers enforce a strict security model: they cannot open raw TCP sockets. All HTTP requests go through the browser's networking stack which only supports HTTP/HTTPS/WebSocket protocols. Real SMTP operates on raw TCP (ports 25, 465, 587). To test live connectivity, use swaks, Telnet, or a server-side script from your production environment."
  },
  {
    question: "What is the difference between port 25, 465, and 587?",
    answer: "Port 25 is the original SMTP relay port — often blocked by ISPs and cloud providers (AWS, GCP, Azure) to prevent spam. Port 465 uses implicit TLS (SMTPS) — the connection is encrypted from the start. Port 587 uses STARTTLS — starts as plaintext then upgrades to TLS. Port 587 with STARTTLS is the recommended choice for application email submission."
  },
  {
    question: "What is STARTTLS and how is it different from SSL/TLS?",
    answer: "STARTTLS is a protocol command that upgrades an existing unencrypted connection to TLS. It uses port 587. SSL/TLS (sometimes called SMTPS) creates an encrypted tunnel from the very first byte on port 465. Both are secure when properly configured — STARTTLS has a theoretical downgrade attack risk if the server doesn't enforce it, but modern servers do."
  },
  {
    question: "Why is port 25 blocked?",
    answer: "ISPs and cloud providers (AWS EC2, Google Cloud, Azure) block outbound port 25 by default to prevent spam. If you need to send email from a cloud VM, use port 587 through a transactional email service (SendGrid, Mailgun, Amazon SES) or request that your provider unblock port 25 for legitimate use cases."
  },
  {
    question: "What is an SMTP app password vs a regular password?",
    answer: "Many providers (Gmail, Outlook) require an app-specific password for SMTP access when 2FA is enabled. These are separate from your account password and can be revoked independently. For Gmail: Account → Security → App passwords. For Outlook: Account settings → Security → Advanced security options."
  },
  {
    question: "How do I test SMTP from the command line?",
    answer: "Use swaks: swaks --to test@example.com --server smtp.gmail.com --port 587 --tls --auth-user you@gmail.com --auth-password yourpass. Or use Telnet: telnet smtp.example.com 587, then manually type EHLO, AUTH, MAIL FROM, RCPT TO, DATA. OpenSSL also works for TLS: openssl s_client -starttls smtp -connect smtp.gmail.com:587"
  },
];
---

<BaseLayout
  title="SMTP Server Tester — Validate Config, Ports & TLS Online"
  description="Validate SMTP server config in your browser. Check host, port (25/465/587), TLS, STARTTLS, and credentials. No data sent to any server. Free, instant."
  tool="SMTP Tester, SMTP Server Checker, Email Server Test, SMTP Configuration Validator, STARTTLS Checker"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "SMTP Server Tester",
    "url": "https://devplaybook.cc/tools/smtp-tester",
    "description": "Validate SMTP server configuration including host, port, TLS, and authentication. Detects common issues like blocked ports and missing credentials.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">SMTP Server Tester</h1>
  <p class="text-text-muted mb-4">
    Validate your SMTP server configuration — host, port, TLS mode, and credentials.
    Instantly detects common issues like blocked ports, missing auth, and misconfigured TLS.
    Runs entirely in your browser as a guided simulation.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Port 25 / 465 / 587 / 2525</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> STARTTLS support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Gmail, Outlook, SES presets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No data sent to server</span>
  </div>
  <SmtpTester client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SMTP Server Tester" relatedTags={['email', 'server', 'security', 'devops', 'networking']} />
</BaseLayout>
