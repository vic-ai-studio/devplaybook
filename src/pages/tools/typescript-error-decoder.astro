---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What does TypeScript error TS2345 mean?",
    answer: "TS2345 is 'Argument of type X is not assignable to parameter of type Y'. It appears when you pass a value to a function that expects a different type — for example, passing a string to a function that expects a number. Fix by ensuring the types match, adding a type assertion, or widening the function's parameter type."
  },
  {
    question: "What is TS2304 and how do I fix it?",
    answer: "TS2304 is 'Cannot find name X'. TypeScript cannot find the declaration for a variable, function, or type. Common causes: missing import, wrong variable name, missing @types package, or forgot to declare a global. Fix by importing the symbol, installing the type package (e.g., @types/node), or adding a declaration file."
  },
  {
    question: "What does TS7006 (implicitly has an 'any' type) mean?",
    answer: "TS7006 means a function parameter has no type annotation and TypeScript infers it as 'any' in strict mode. This is an error when noImplicitAny is enabled (part of strict: true). Fix by adding an explicit type annotation to the parameter: (x: string) => ... or (item: MyType) => ..."
  },
  {
    question: "Why am I getting TS2307 (Cannot find module)?",
    answer: "TS2307 means TypeScript cannot find the module you're importing. Causes: wrong path, missing @types package, the package has no type declarations, or moduleResolution is misconfigured. For npm packages without built-in types, install @types/package-name. For packages with no types at all, add declare module 'package-name' in a .d.ts file."
  },
  {
    question: "How do I suppress a TypeScript error on one line?",
    answer: "Use // @ts-ignore on the line before to suppress the error on the next line. Use // @ts-expect-error to suppress AND be warned if the error disappears (safer). Use // @ts-nocheck at the top of a file to disable TypeScript for the whole file. Prefer fixing the underlying type issue rather than suppressing."
  }
];
---

<BaseLayout
  title="TypeScript Error Decoder — TS Error Codes Explained with Fix Suggestions"
  description="Decode TypeScript error codes and messages. Get plain-English explanations and fix suggestions for TS2345, TS2304, TS7006, TS2307, TS2322, and 50+ more TypeScript errors. Free browser tool."
  tool="TypeScript error decoder, TS error codes explained, typescript errors, TS2345, TS2304, TS7006, TS2307, typescript error explainer"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "TypeScript Error Decoder",
    "url": "https://devplaybook.cc/tools/typescript-error-decoder",
    "description": "Decode TypeScript error codes and messages. Get plain-English explanations and fix suggestions for 50+ TypeScript errors.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">TypeScript Error Decoder</h1>
  <p class="text-text-muted mb-4">
    Paste a TypeScript error code (e.g. <code class="font-mono text-accent">TS2345</code>) or message to get a plain-English explanation and actionable fix suggestions.
    Covers 50+ common TypeScript errors.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 50+ error codes covered</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Plain-English explanations</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Fix code examples</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Searchable error database</span>
  </div>

  <!-- Search input -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <label class="block text-sm font-medium mb-2" for="ts-search">Search error code or message</label>
    <div class="flex gap-2">
      <input
        id="ts-search"
        type="text"
        placeholder="e.g. TS2345, TS7006, or paste error message"
        class="flex-1 bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary"
        autocomplete="off"
        spellcheck="false"
      />
      <button id="search-btn" class="px-4 py-2 bg-primary text-white rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors">
        Decode
      </button>
    </div>
    <div class="flex flex-wrap gap-2 mt-3">
      {['TS2345','TS2304','TS7006','TS2307','TS2322','TS2339','TS2554','TS2741','TS18048','TS2590'].map(code => (
        <button class="quick-btn px-2.5 py-1 bg-surface border border-border rounded text-xs hover:border-primary hover:text-foreground transition-colors text-text-muted font-mono" data-code={code}>{code}</button>
      ))}
    </div>
  </div>

  <!-- Result card -->
  <div id="result-card" class="hidden bg-bg-card border border-border rounded-lg p-4 mb-4">
    <div class="flex items-start gap-3 mb-3">
      <span id="result-code" class="font-mono text-sm font-bold text-accent bg-accent/10 px-2 py-1 rounded shrink-0"></span>
      <h2 id="result-title" class="font-semibold text-base"></h2>
    </div>
    <div class="mb-3">
      <h3 class="text-xs font-medium text-text-muted uppercase tracking-wider mb-1.5">What it means</h3>
      <p id="result-desc" class="text-sm text-text-muted leading-relaxed"></p>
    </div>
    <div class="mb-3">
      <h3 class="text-xs font-medium text-text-muted uppercase tracking-wider mb-1.5">Common causes</h3>
      <ul id="result-causes" class="space-y-1 text-sm text-text-muted list-disc list-inside"></ul>
    </div>
    <div>
      <h3 class="text-xs font-medium text-text-muted uppercase tracking-wider mb-1.5">How to fix</h3>
      <pre id="result-fix" class="bg-surface rounded-lg p-3 text-xs font-mono overflow-x-auto whitespace-pre-wrap text-foreground/90"></pre>
    </div>
  </div>

  <!-- Browse all -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-sm font-medium">All Errors</h2>
      <input id="filter-input" type="text" placeholder="Filter…" class="bg-surface border border-border rounded px-2 py-1 text-xs focus:outline-none focus:border-primary w-36" />
    </div>
    <div id="error-list" class="space-y-1 max-h-96 overflow-y-auto pr-1"></div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="TypeScript Error Decoder" relatedTags={['typescript', 'errors', 'debugging', 'javascript', 'developer-tools']} />
</BaseLayout>

<script is:inline>
(function() {
  const ERRORS = [
    { code: 'TS1005', title: "Expected token", desc: "A required syntax token (like '}', ';', or ',') is missing.", causes: ["Missing closing bracket or brace","Syntax error in JSX or template literal","Wrong use of arrow function syntax"], fix: `// Wrong\nconst obj = { a: 1 b: 2 }\n\n// Fixed\nconst obj = { a: 1, b: 2 }` },
    { code: 'TS2304', title: "Cannot find name", desc: "TypeScript cannot find the declaration for a name (variable, function, type, or class).", causes: ["Missing import statement","@types package not installed","Typo in identifier","Using a global that TypeScript doesn't know about"], fix: `// Add missing import\nimport { debounce } from 'lodash'\n\n// Or install types\nnpm install --save-dev @types/node\n\n// Or declare globally\ndeclare const __DEV__: boolean` },
    { code: 'TS2307', title: "Cannot find module", desc: "TypeScript cannot resolve the module you're importing.", causes: ["Wrong relative path","Missing @types/package","Package has no type declarations","moduleResolution mismatch"], fix: `// Install types\nnpm install --save-dev @types/express\n\n// Or declare the module\n// types.d.ts\ndeclare module 'untyped-pkg' {\n  export function doThing(): void\n}` },
    { code: 'TS2322', title: "Type X is not assignable to type Y", desc: "You're trying to assign a value to a variable whose type doesn't match.", causes: ["Assigning wrong type (e.g. string to number)","Optional vs required mismatch","Null/undefined not handled"], fix: `// Wrong\nconst n: number = 'hello'\n\n// Fixed\nconst n: number = 42\n\n// Or widen the type\nconst n: number | string = 'hello'` },
    { code: 'TS2345', title: "Argument of type X is not assignable to parameter of type Y", desc: "A function argument's type doesn't match the expected parameter type.", causes: ["Passing string where number is expected","Object missing required property","Union type not narrowed before passing"], fix: `// Wrong\nfunction add(a: number, b: number) { return a + b }\nadd('1', 2) // TS2345\n\n// Fixed\nadd(1, 2)\n\n// Or cast (when safe)\nadd(parseInt(str), 2)` },
    { code: 'TS2339', title: "Property does not exist on type", desc: "You're accessing a property that TypeScript cannot find on the type.", causes: ["Typo in property name","Property not declared in interface/type","Accessing property before it's added"], fix: `interface User { name: string }\nconst u: User = { name: 'Alice' }\nconsole.log(u.age) // TS2339\n\n// Fix: add to interface\ninterface User { name: string; age?: number }\n\n// Or narrow/cast\n(u as any).age` },
    { code: 'TS2354', title: "This syntax requires an imported helper", desc: "A TypeScript downcompile feature needs tslib helper.", causes: ["Using async/await with older target","Missing tslib dependency","importHelpers: true but tslib not installed"], fix: `// Install tslib\nnpm install tslib\n\n// tsconfig.json\n{\n  "compilerOptions": {\n    "importHelpers": true,\n    "target": "ES5"\n  }\n}` },
    { code: 'TS2454', title: "Variable is used before being assigned", desc: "TypeScript detected a code path where a variable might not have been assigned before use.", causes: ["Variable declared but assigned only in one branch","let declaration without initial value","Async race condition"], fix: `// Wrong\nlet result: string\nif (condition) result = 'yes'\nconsole.log(result) // TS2454\n\n// Fixed\nlet result: string | undefined\nif (condition) result = 'yes'\nconsole.log(result ?? 'default')` },
    { code: 'TS2531', title: "Object is possibly null", desc: "A value could be null at this point, but you're accessing it without a null check.", causes: ["DOM query (getElementById can return null)","Optional chaining not used","Function return type includes null"], fix: `// Wrong\nconst el = document.getElementById('app')\nel.style.color = 'red' // TS2531\n\n// Fixed\nconst el = document.getElementById('app')\nif (el) el.style.color = 'red'\n// Or: el?.style.color = 'red'` },
    { code: 'TS2532', title: "Object is possibly undefined", desc: "A value could be undefined at this point.", causes: ["Accessing optional property","Array element access without bounds check","Function parameter is optional"], fix: `interface Config { timeout?: number }\nconst c: Config = {}\nconsole.log(c.timeout.toString()) // TS2532\n\n// Fixed\nconsole.log(c.timeout?.toString() ?? '0')\n// Or: if (c.timeout !== undefined) ...` },
    { code: 'TS2540', title: "Cannot assign to X because it is a read-only property", desc: "You're trying to write to a readonly property.", causes: ["Readonly modifier on interface/type","const assertion (as const)","React props are readonly by default"], fix: `interface User { readonly id: number }\nconst u: User = { id: 1 }\nu.id = 2 // TS2540\n\n// Fix: remove readonly, or create new object\nconst updated: User = { ...u, id: 2 }` },
    { code: 'TS2551', title: "Property X does not exist. Did you mean Y?", desc: "A property doesn't exist, and TypeScript found a similar name.", causes: ["Typo in property name","Renamed property not updated everywhere"], fix: `interface User { firstName: string }\nconst u: User = { firstName: 'Alice' }\nconsole.log(u.firstname) // TS2551 - did you mean firstName?\n\n// Fix the typo\nconsole.log(u.firstName)` },
    { code: 'TS2554', title: "Expected N arguments, but got M", desc: "You called a function with the wrong number of arguments.", causes: ["Missing required arguments","Extra arguments passed","Function signature doesn't match call"], fix: `function greet(name: string, greeting: string) {\n  return \`\${greeting}, \${name}\`\n}\ngreet('Alice') // TS2554 - expected 2, got 1\n\n// Fix\ngreet('Alice', 'Hello')\n\n// Or make parameter optional\nfunction greet(name: string, greeting = 'Hello') {}` },
    { code: 'TS2590', title: "Expression produces a union type that is too complex", desc: "TypeScript gave up evaluating a union type because it has too many possible members (limit: 100,000).", causes: ["Very large union type","Recursive conditional types","Generated types with thousands of members"], fix: `// Simplify complex unions\n// Use type aliases to break up the computation\n// Or use // @ts-ignore as last resort\n\n// Example: replace inferred large union with explicit type\ntype Result = string | number | boolean // explicit\n// instead of deep conditional inference` },
    { code: 'TS2614', title: "Module X has no exported member Y", desc: "You're importing a named export that doesn't exist in the module.", causes: ["Wrong export name","Module changed API","Default export used as named export"], fix: `// Wrong\nimport { helper } from 'some-lib' // helper not exported\n\n// Check actual exports\nimport { actualExport } from 'some-lib'\n\n// Or import default\nimport SomeLib from 'some-lib'\nconst result = SomeLib.helper()` },
    { code: 'TS2693', title: "X only refers to a type, but is being used as a value", desc: "You're using a type or interface where a value (runtime value) is expected.", causes: ["Using interface as a constructor","instanceof check on an interface","Type used in a value position"], fix: `interface Animal { name: string }\n// Wrong - interface doesn't exist at runtime\nif (pet instanceof Animal) {} // TS2693\n\n// Fix: use a class instead of interface\nclass Animal { name: string = '' }\nif (pet instanceof Animal) {}` },
    { code: 'TS2698', title: "Spread types may only be created from object types", desc: "You tried to spread a non-object type.", causes: ["Spreading undefined or null","Spreading primitive type","Union type includes non-object"], fix: `// Wrong\nconst val: string | undefined = getVal()\nconst copy = { ...val } // TS2698\n\n// Fixed\nconst copy = val ? { ...val } : {}\n\n// Or narrow type first\nif (val && typeof val === 'object') { const copy = { ...val } }` },
    { code: 'TS6133', title: "X is declared but its value is never read", desc: "A variable or import is declared but never used.", causes: ["Unused import","Variable set but never read","Dead code"], fix: `// Remove unused imports\n// Wrong: import { unused } from './util'\nimport { used } from './util'\n\n// Prefix with _ to intentionally ignore\nfunction handler(_event: Event) {\n  // event intentionally unused\n}` },
    { code: 'TS7006', title: "Parameter X implicitly has an 'any' type", desc: "A function parameter has no type annotation and TypeScript infers it as 'any' (error in strict mode).", causes: ["noImplicitAny: true (part of strict)","Callback without typed parameter","Arrow function without type annotation"], fix: `// Wrong\nconst fn = (x) => x + 1 // TS7006\n\n// Fixed\nconst fn = (x: number) => x + 1\n\n// Or type the whole function\ntype Transform = (x: number) => number\nconst fn: Transform = (x) => x + 1` },
    { code: 'TS7017', title: "Element implicitly has an 'any' type (index signature)", desc: "You're accessing an object with a computed key, but the object type has no index signature.", causes: ["Accessing object with dynamic key","Object type doesn't allow string indexing","Record type not used"], fix: `const map = { a: 1, b: 2 }\nconst key = 'a'\nconsole.log(map[key]) // TS7017\n\n// Fix: use Record or index signature\nconst map: Record<string, number> = { a: 1, b: 2 }\nconsole.log(map[key]) // OK` },
    { code: 'TS7031', title: "Binding element X implicitly has an 'any' type", desc: "A destructured element has no type annotation in strict mode.", causes: ["Destructured function parameters without types","noImplicitAny with complex destructuring"], fix: `// Wrong\nfunction process({ name, age }) {} // TS7031\n\n// Fixed\nfunction process({ name, age }: { name: string; age: number }) {}\n\n// Or use interface\ninterface Params { name: string; age: number }\nfunction process({ name, age }: Params) {}` },
    { code: 'TS18047', title: "X is possibly null", desc: "TypeScript's strictNullChecks flagged a potentially null value.", causes: ["API returns T | null","DOM query results","Database ORM fields"], fix: `const el = document.querySelector('.btn') // HTMLElement | null\nel.click() // TS18047\n\n// Fix: null check\nif (el) el.click()\n// Or: el?.click()\n// Or: el!.click() (assert not null — only when certain)` },
    { code: 'TS18048', title: "X is possibly undefined", desc: "TypeScript's strictNullChecks flagged a potentially undefined value.", causes: ["Optional chaining result","Array find() returns T | undefined","Optional function parameters"], fix: `const arr = [1, 2, 3]\nconst found = arr.find(x => x > 2) // number | undefined\nconsole.log(found.toFixed(2)) // TS18048\n\n// Fix\nif (found !== undefined) console.log(found.toFixed(2))\n// Or: found?.toFixed(2)\n// Or: (found ?? 0).toFixed(2)` },
    { code: 'TS2769', title: "No overload matches this call", desc: "You called a function with overloads, but no overload signature matches your arguments.", causes: ["Wrong combination of argument types","Overloaded function expects specific type pairs","Optional argument order mismatch"], fix: `// Check the function's overload signatures\n// Ensure argument types exactly match one overload\n\n// Example fix: use explicit type assertion\nconst result = overloadedFn(arg as ExpectedType)\n\n// Or check TypeScript docs for correct overload` },
    { code: 'TS2741', title: "Property X is missing in type Y but required in type Z", desc: "An object literal is missing a required property.", causes: ["Object literal doesn't include all required interface fields","Partial update without Partial<T>","Copy-paste error in object creation"], fix: `interface User { id: number; name: string; email: string }\nconst u: User = { id: 1, name: 'Alice' } // TS2741 - missing email\n\n// Fix: add missing property\nconst u: User = { id: 1, name: 'Alice', email: 'a@b.com' }\n\n// Or use Partial for optional assignments\nconst partial: Partial<User> = { name: 'Alice' }` },
    { code: 'TS5023', title: "Unknown compiler option", desc: "A tsconfig.json option is not recognized by this version of TypeScript.", causes: ["Newer tsconfig option used with older TypeScript","Typo in option name","Plugin option format issue"], fix: `// Check option spelling in tsconfig.json\n// Run: npx tsc --version\n// Upgrade TypeScript if needed: npm install --save-dev typescript@latest\n\n// Or remove unknown option\n{\n  "compilerOptions": {\n    "target": "ES2020" // not "target": "ES-2020"\n  }\n}` },
  ];

  let filteredErrors = [...ERRORS];

  function renderList(errors) {
    const list = document.getElementById('error-list');
    list.innerHTML = errors.map(e => `
      <button class="error-item w-full text-left px-3 py-2 rounded-lg hover:bg-surface transition-colors flex items-center gap-3 group" data-code="${e.code}">
        <span class="font-mono text-xs font-bold text-accent bg-accent/10 px-2 py-0.5 rounded shrink-0 group-hover:bg-accent/20">${e.code}</span>
        <span class="text-sm text-text-muted truncate group-hover:text-foreground">${e.title}</span>
      </button>
    `).join('');

    list.querySelectorAll('.error-item').forEach(btn => {
      btn.addEventListener('click', () => {
        showError(btn.dataset.code);
      });
    });
  }

  function showError(code) {
    const err = ERRORS.find(e => e.code === code.toUpperCase().trim().replace(/^TS/i, 'TS'));
    if (!err) return;

    document.getElementById('result-card').classList.remove('hidden');
    document.getElementById('result-code').textContent = err.code;
    document.getElementById('result-title').textContent = err.title;
    document.getElementById('result-desc').textContent = err.desc;
    document.getElementById('result-causes').innerHTML = err.causes.map(c => `<li>${c}</li>`).join('');
    document.getElementById('result-fix').textContent = err.fix;
    document.getElementById('result-card').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function search(q) {
    q = q.toLowerCase().trim();
    if (!q) { renderList(ERRORS); return; }
    filteredErrors = ERRORS.filter(e =>
      e.code.toLowerCase().includes(q) ||
      e.title.toLowerCase().includes(q) ||
      e.desc.toLowerCase().includes(q) ||
      e.causes.some(c => c.toLowerCase().includes(q))
    );
    renderList(filteredErrors);
  }

  document.getElementById('search-btn').addEventListener('click', () => {
    const v = document.getElementById('ts-search').value.trim();
    const code = v.match(/TS?\d+/i);
    if (code) showError(code[0]);
    else search(v);
  });

  document.getElementById('ts-search').addEventListener('keydown', e => {
    if (e.key === 'Enter') {
      const v = e.target.value.trim();
      const code = v.match(/TS?\d+/i);
      if (code) showError(code[0]);
      else search(v);
    }
  });

  document.getElementById('ts-search').addEventListener('input', e => {
    search(e.target.value);
  });

  document.getElementById('filter-input').addEventListener('input', e => {
    search(e.target.value);
  });

  document.querySelectorAll('.quick-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      showError(btn.dataset.code);
      document.getElementById('ts-search').value = btn.dataset.code;
    });
  });

  renderList(ERRORS);
})();
</script>
