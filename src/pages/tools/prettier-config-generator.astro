---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PrettierConfigGenerator from '../../components/PrettierConfigGenerator.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Prettier and why should I use it?", answer: "Prettier is an opinionated code formatter that enforces a consistent style across your entire codebase. Unlike linters that flag style issues, Prettier rewrites your code automatically on save. It supports JavaScript, TypeScript, JSX, CSS, HTML, Markdown, JSON, and more. Teams that use Prettier spend zero time debating code style — the formatter just decides." },
  { question: "What is the difference between .prettierrc, .prettierrc.json, and prettier.config.js?", answer: "They're equivalent in functionality — Prettier accepts all three formats. .prettierrc is a shorthand JSON file. .prettierrc.json is explicit JSON. prettier.config.js uses ESM exports and lets you add comments or dynamic logic. Use .prettierrc for simple projects, prettier.config.js when you need to share settings between tools or add conditional logic." },
  { question: "Should I use singleQuote or doubleQuote?", answer: "Both are valid — the key is consistency. JavaScript/TypeScript codebases often use single quotes (singleQuote: true) because it avoids escaping apostrophes in strings. JSON always requires double quotes regardless. React projects frequently use double quotes for JSX attributes to match HTML conventions. Pick one and enforce it via Prettier." },
  { question: "What does trailingComma: 'all' do?", answer: "It adds trailing commas to multi-line arrays, objects, function parameters, and destructuring patterns. This makes git diffs cleaner — adding a new item to the last position of an array only shows one changed line (the new item) instead of two (the existing last item gaining a comma + the new item)." },
  { question: "How do I integrate Prettier with ESLint?", answer: "Install eslint-config-prettier, then add 'prettier' to the end of your ESLint extends array (or use the flat config equivalent). This disables all ESLint formatting rules that conflict with Prettier. Never install eslint-plugin-prettier — it's slow and adds redundant errors. Let Prettier handle formatting, ESLint handle code quality." },
  { question: "What print width should I use?", answer: "80 is the traditional terminal width and the Prettier default. 100 or 120 are popular in modern codebases where developers use wide monitors. Note: printWidth is a soft guideline, not a hard limit — Prettier won't break a string or import across lines just to stay under it. Use a value your team is comfortable reading." },
];
---

<BaseLayout
  title="Prettier Config Generator — .prettierrc, prettier.config.js, YAML"
  description="Generate a Prettier configuration file with your formatting preferences. Supports .prettierrc JSON, prettier.config.js ESM, and .prettierrc.yaml. Set print width, tabs, quotes, trailing commas, and more."
  tool="Prettier config generator, .prettierrc generator, prettier configuration, code formatter config, prettier setup"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Prettier Config Generator",
    "url": "https://devplaybook.cc/tools/prettier-config-generator",
    "description": "Generate Prettier configuration files for your project. Supports JSON, JS, and YAML formats with all major Prettier options.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Prettier Config Generator</h1>
  <p class="text-text-muted mb-4">
    Generate a <a href="https://prettier.io" class="text-accent hover:underline" target="_blank" rel="noopener">Prettier</a> configuration file for your project. Choose output format, set your formatting preferences, and get a ready-to-use config file.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 3 output formats</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All major options</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <PrettierConfigGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <AffiliateSection category={['developer-tools']} />
  <ToolPageCta currentTool="Prettier Config Generator" relatedTags={['prettier', 'formatter', 'code-quality', 'javascript', 'typescript']} />
</BaseLayout>
