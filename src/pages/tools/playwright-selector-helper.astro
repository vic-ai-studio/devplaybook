---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PlaywrightSelectorHelper from '../../components/PlaywrightSelectorHelper.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is the difference between page.locator() and getByRole()?",
    answer: "page.locator() accepts any CSS or XPath selector and is the most flexible — but also the most brittle. getByRole() targets elements by their ARIA role and accessible name, which is how screen readers and keyboard users navigate. Playwright's documentation recommends preferring getByRole, getByLabel, and getByText because they are resilient to structural changes in the HTML and simultaneously verify your app's accessibility.",
  },
  {
    question: "When should I use getByTestId() vs getByRole()?",
    answer: "Use getByRole() whenever the element has a meaningful ARIA role and accessible name — buttons, links, form controls, headings. Fall back to getByTestId() only for elements that have no stable semantic meaning from a user perspective (e.g., a container div or a custom widget with no accessible label). Add data-testid attributes deliberately rather than sprinkling them across every element.",
  },
  {
    question: "How do I configure a custom testId attribute name?",
    answer: "By default Playwright looks for data-testid. You can change this in playwright.config.ts: set use: { testIdAttribute: 'data-cy' } to match Cypress conventions, or any other attribute your codebase uses. getByTestId() will then match that attribute instead. This is useful when migrating test suites from other frameworks.",
  },
  {
    question: "What does the { exact: true } option do for getByText()?",
    answer: "Without exact: true, getByText('Submit') will match any element whose text content includes the word 'Submit' — such as 'Submit your form' or 'Please Submit'. With exact: true, it performs a case-sensitive, full-string match. This is useful when multiple elements on the page contain similar text and you need to target one specific element precisely.",
  },
  {
    question: "How do I select elements inside a scoped component or iframe?",
    answer: "Chain locators with .locator() to scope queries: page.locator('#sidebar').getByRole('link') finds links only inside #sidebar. For iframes, use page.frameLocator('iframe[name=checkout]').getByRole('button', { name: 'Pay' }). This avoids false matches from elsewhere in the page and is much more maintainable than using complex CSS descendant selectors.",
  },
  {
    question: "What are the best practices for Playwright selectors in CI/CD?",
    answer: "Prefer user-visible locators (role, label, placeholder, text) over implementation details (CSS classes, XPath). Avoid nth-child or index-based selectors which break on DOM reorder. Use data-testid for custom components that lack semantic roles. Keep selectors in Page Object Model classes so they are centrally maintained. Enable Playwright's built-in retry and waitFor to handle async rendering without adding manual timeouts.",
  },
];
---

<BaseLayout
  title="Playwright Selector Helper — Build CSS & Locator Selectors Instantly"
  description="Free online Playwright selector builder. Generate page.locator(), getByRole(), getByText(), getByLabel(), and getByTestId() code with await statements. Includes quick reference and selector best practices."
  tool="Playwright selector helper, Playwright locator generator, getByRole generator, Playwright CSS selector, e2e test selector, Playwright test builder"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Playwright Selector Helper",
    "url": "https://devplaybook.cc/tools/playwright-selector-helper",
    "description": "Build Playwright CSS, role, text, label, placeholder, and testId selectors interactively. Generates ready-to-paste await statements with chaining options.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Playwright Selector Helper</h1>
  <p class="text-text-muted mb-4">
    Build <a href="https://playwright.dev/docs/locators" class="text-accent hover:underline" target="_blank" rel="noopener">Playwright</a> selectors interactively — CSS, role, text, label, placeholder, and testId. Choose a chaining action and get a copy-ready <code class="text-sm bg-surface border border-border rounded px-1.5 py-0.5">await</code> statement instantly.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 6 selector types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> click / fill / expect chains</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> ARIA role dropdown</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Quick reference table</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs in browser — no signup</span>
  </div>
  <PlaywrightSelectorHelper client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Playwright Selector Helper" relatedTags={['testing', 'playwright', 'javascript', 'typescript', 'e2e-testing']} />
</BaseLayout>
