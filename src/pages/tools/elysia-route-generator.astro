---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ElysiaRouteGenerator from '../../components/ElysiaRouteGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is Elysia.js?", answer: "Elysia is a TypeScript-first web framework for Bun (and Node.js) focused on performance and developer experience. It provides end-to-end type safety using its treaty client, built-in schema validation via TypeBox (t.*), and a fluent route builder API. Elysia is known for being one of the fastest JavaScript web frameworks available." },
  { question: "How does Elysia's type system work?", answer: "Elysia uses TypeBox schemas (t.Object, t.String, t.Number, etc.) for request body, query parameters, and response types. These schemas are used both for runtime validation AND for generating TypeScript types automatically — eliminating the need to write types separately. The treaty client (Eden) then picks up these types for fully typed API calls." },
  { question: "What is the difference between .get() and .post() in Elysia?", answer: "Elysia's route methods mirror HTTP verbs: .get() for read operations, .post() for creating resources, .put() for full updates, .patch() for partial updates, .delete() for deletion. Each accepts a path string, a handler function, and an optional config object for body/query/params schemas and documentation metadata." },
  { question: "How do I add authentication to Elysia routes?", answer: "Elysia authentication is typically handled with plugins or derive/onBeforeHandle hooks. For Bearer token auth, add .onBeforeHandle(({ headers, set }) => { const token = headers.authorization?.split(' ')[1]; if (!token) { set.status = 401; return 'Unauthorized'; } }) as a guard. For reusable auth, create a plugin with new Elysia().derive({ as: 'scoped' }, () => ({ user })) and compose it." },
  { question: "What is Eden treaty in Elysia?", answer: "Eden treaty is Elysia's type-safe client library. After defining your Elysia app, use treaty(app) on the client side to get a fully typed API client — autocomplete for routes, request bodies, and response types. This is Elysia's flagship feature: zero-effort end-to-end TypeScript without code generation or separate type definitions." },
  { question: "How do I handle errors in Elysia?", answer: "Use .onError({ code, error, set }) for global error handling, or throw new Error() with Elysia's built-in error classes like error('NOT_FOUND', 'Resource not found'). Elysia maps HTTP error codes automatically: error('NOT_FOUND') → 404, error('VALIDATION') → 422, error('UNAUTHORIZED') → 401. Add .error({ MyCustomError }) to register custom error types with proper status codes." },
];
---

<BaseLayout
  title="Elysia Route Generator — Bun TypeScript Route Builder"
  description="Generate Elysia.js route code for Bun. Configure path, HTTP method, request body schema, auth, and response type. Get copy-ready TypeScript with t.Object validation. Free tool."
  tool="Elysia Route Generator, Elysia.js, Bun framework, TypeScript routes, Eden treaty, TypeBox schema"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Elysia Route Generator",
    "url": "https://devplaybook.cc/tools/elysia-route-generator",
    "description": "Generate Elysia.js (Bun) route code with TypeBox schema validation, Bearer auth guards, and response types. Produces idiomatic TypeScript ready to paste into your Elysia app.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Elysia Route Generator</h1>
  <p class="text-text-muted mb-4">Generate <strong>Elysia.js</strong> route code for Bun. Configure your path, method, body schema, and auth — get idiomatic TypeScript with <code class="text-accent font-mono">t.Object</code> validation ready to paste into your app.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeBox schema validation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Bearer auth guard</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> JSON/text/stream responses</span>
  </div>
  <ElysiaRouteGenerator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Elysia Route Generator" relatedTags={['typescript', 'bun', 'backend', 'api', 'elysia', 'rest']} />
</BaseLayout>
