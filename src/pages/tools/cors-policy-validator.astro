---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CorsPolicyValidator from '../../components/CorsPolicyValidator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is CORS and why does it matter for security?",
    answer: "CORS (Cross-Origin Resource Sharing) is a browser security mechanism that controls which websites can make requests to your API. Without proper CORS configuration, your API could allow any malicious website to make authenticated requests using a visitor's cookies or credentials. A misconfigured CORS policy (like reflecting any Origin or using wildcard with credentials) effectively removes the browser's same-origin protection."
  },
  {
    question: "What is the difference between simple and preflighted requests?",
    answer: "Simple requests (GET/HEAD/POST with only safelisted headers and content types) are sent directly — the browser checks the CORS headers on the response. Preflighted requests (DELETE, PUT, PATCH, or requests with custom headers) first send an OPTIONS request to check if the actual request is allowed. Your server must respond to OPTIONS with appropriate Access-Control-Allow-* headers. If the preflight fails, the actual request is never sent."
  },
  {
    question: "Why is Access-Control-Allow-Origin: * dangerous for APIs with auth?",
    answer: "When you respond with Access-Control-Allow-Origin: *, any website can read your API responses. For truly public, read-only APIs this is fine. But combined with Access-Control-Allow-Credentials: true (which allows cookies/auth headers), browsers reject the combination. Attackers exploit misconfigured wildcard origins to perform CSRF-style attacks — they create pages that silently make API calls from victims' browsers. Always use specific origins for authenticated APIs."
  },
  {
    question: "What does Access-Control-Allow-Credentials: true enable?",
    answer: "By default, cross-origin requests don't include credentials (cookies, HTTP auth headers, client certificates). Setting this header to 'true' tells the browser to include them. This requires: a specific origin (not *), the client JavaScript to set 'credentials: include' on fetch or 'withCredentials: true' on XMLHttpRequest. Enabling this for an authenticated session API is common, but requires a carefully restricted Allow-Origin."
  },
  {
    question: "What is Access-Control-Max-Age?",
    answer: "This header tells browsers how long to cache the preflight (OPTIONS) response in seconds. Without it, browsers send an OPTIONS request before every cross-origin request, adding latency. Set it to 600 (10 minutes) or 86400 (24 hours, the maximum browsers honor) to cache preflight results. Note: Chrome caps at 7200s (2 hours), Firefox at 86400s."
  },
  {
    question: "What should I put in Access-Control-Expose-Headers?",
    answer: "By default, JavaScript can only read a limited set of response headers (CORS-safelisted headers: Cache-Control, Content-Language, Content-Length, Content-Type, Expires, Last-Modified, Pragma). To expose custom headers like X-Request-ID, X-Rate-Limit-Remaining, X-Pagination-*, or Location, list them in Access-Control-Expose-Headers. Without this, fetch response.headers.get('X-Request-ID') returns null even if the header is present."
  },
];
---

<BaseLayout
  title="CORS Policy Validator — Analyze CORS Headers for Security Issues"
  description="Validate CORS response headers for security issues. Checks wildcard origins, credentials misconfiguration, missing methods/headers, Max-Age optimization, and preflight correctness. Paste your headers and get instant analysis."
  tool="cors validator, cors tester, cross origin policy, cors checker online, cors header analyzer"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "CORS Policy Validator",
    "url": "https://devplaybook.cc/tools/cors-policy-validator",
    "description": "Validate CORS response headers for security issues. Checks wildcard origins, credentials misconfiguration, missing methods/headers, and preflight optimization. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">CORS Policy Validator</h1>
  <p class="text-text-muted mb-4">
    Validate your API's CORS headers for security misconfigurations.
    Paste the <code class="font-mono text-sm bg-surface px-1 rounded">Access-Control-*</code> headers
    from your server response and get an instant security analysis: wildcard origin risks, credentials
    misconfiguration, missing headers, and preflight optimization hints.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Wildcard origin detection</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Credentials misconfiguration check</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Preflight cache optimization</span>
  </div>
  <CorsPolicyValidator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CORS Policy Validator" relatedTags={['security', 'api', 'http', 'cors', 'web', 'authentication']} />
</BaseLayout>
