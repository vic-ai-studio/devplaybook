---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HttpHeadersInspector from '../../components/HttpHeadersInspector.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="HTTP Headers Inspector"
  description="Inspect HTTP response headers for any URL. View security headers, cache directives, and CORS settings — with plain-English explanations for every header."
  tool="HTTP Headers Inspector, HTTP Response Headers, Header Checker"
>
  <h1 class="text-3xl font-bold mb-2">HTTP Headers Inspector</h1>
  <p class="text-text-muted mb-8">Paste any URL to fetch its HTTP response headers. Each header is explained in plain English, tagged by category, and scored for security coverage.</p>
  <HttpHeadersInspector client:load />
  <ToolPageCta currentTool="HTTP Headers Inspector" relatedTags={['http', 'security', 'api', 'cors', 'devops']} />
</BaseLayout>
