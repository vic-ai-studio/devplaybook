---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HttpHeadersInspector from '../../components/HttpHeadersInspector.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What are HTTP response headers?", answer: "HTTP response headers are metadata sent by a server alongside the response body. They control caching (Cache-Control, ETag), security (Content-Security-Policy, Strict-Transport-Security), content type (Content-Type), CORS (Access-Control-Allow-Origin), and more. Every HTTP response includes headers — understanding them is essential for debugging APIs and web applications." },
  { question: "What security headers should every site have?", answer: "The essential security headers are: Strict-Transport-Security (HSTS) to enforce HTTPS, Content-Security-Policy (CSP) to prevent XSS, X-Content-Type-Options: nosniff to stop MIME sniffing, X-Frame-Options or frame-ancestors CSP to prevent clickjacking, and Referrer-Policy to control referrer leakage. Missing any of these is a common finding in security audits." },
  { question: "What is CORS and how do I debug it?", answer: "CORS (Cross-Origin Resource Sharing) controls which domains can make requests to your API from a browser. The key headers are Access-Control-Allow-Origin, Access-Control-Allow-Methods, and Access-Control-Allow-Headers. CORS errors appear in the browser console when a frontend on one domain calls an API on another. Use this tool to check whether the API returns the correct CORS headers." },
  { question: "What does the Cache-Control header do?", answer: "Cache-Control tells browsers and CDNs how to cache a response. Common directives: max-age=3600 (cache for 1 hour), no-cache (revalidate before using cached copy), no-store (never cache — use for sensitive data), public (CDNs can cache), private (only the browser can cache). Misconfigured caching is a top cause of stale content bugs." },
  { question: "How do I check if a site uses HSTS?", answer: "Inspect the response headers for Strict-Transport-Security. A proper HSTS header looks like: Strict-Transport-Security: max-age=31536000; includeSubDomains; preload. This tells browsers to always use HTTPS for the domain. The preload directive registers the domain in browser HSTS preload lists for even stronger protection." },
];
---

<BaseLayout
  title="HTTP Headers Inspector — Check Security, Cache & CORS Headers"
  description="Inspect HTTP response headers for any URL. View security headers (HSTS, CSP, X-Frame-Options), cache directives, and CORS settings — with plain-English explanations for every header. Free, no signup."
  tool="HTTP Headers Inspector, HTTP Response Headers, Header Checker, Security Header Check, CORS Header Checker"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">HTTP Headers Inspector</h1>
  <p class="text-text-muted mb-4">Paste any URL to fetch its HTTP response headers. Each header is explained in plain English, tagged by category, and scored for security coverage.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Security header scoring</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <HttpHeadersInspector client:load />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="HTTP Headers Inspector" relatedTags={['http', 'security', 'api', 'cors', 'devops']} />
</BaseLayout>
