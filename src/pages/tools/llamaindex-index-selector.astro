---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is LlamaIndex and why does index type matter?", answer: "LlamaIndex (formerly GPT Index) is a framework for connecting LLMs to external data. The index type determines how your data is stored and retrieved: VectorStoreIndex uses embeddings for semantic search, SummaryIndex is optimized for summarization over all documents, KnowledgeGraphIndex extracts entity relationships, and SQLStructStoreIndex wraps relational databases for structured queries." },
  { question: "When should I use VectorStoreIndex vs SummaryIndex?", answer: "Use VectorStoreIndex when users ask specific questions and you want to retrieve the most relevant chunks (top-K retrieval). Use SummaryIndex when you need to answer questions that require synthesizing information across the entire document set, such as 'what are the main themes across all these reports?'. SummaryIndex reads all nodes, so it is slower and more expensive." },
  { question: "What is a KnowledgeGraphIndex good for?", answer: "KnowledgeGraphIndex extracts (subject, predicate, object) triplets from your documents and stores them as a graph. It excels at multi-hop reasoning: 'What companies did Alice work for that are headquartered in Berlin?' It also makes relationships between entities explicit and queryable, which pure vector search cannot do reliably." },
  { question: "Can I use LlamaIndex with my own vector database?", answer: "Yes. LlamaIndex has integrations with Pinecone, Weaviate, Qdrant, Chroma, Milvus, Elasticsearch, and many others via the VectorStore abstraction. Pass your vector store to VectorStoreIndex.from_vector_store(). This lets you persist vectors externally and scale beyond memory limits." },
  { question: "How do I handle frequent document updates?", answer: "For frequent updates use VectorStoreIndex with an external vector store that supports upsert (Pinecone, Qdrant). You can call index.insert(document) or index.delete_ref_doc(doc_id) at runtime. SummaryIndex and KnowledgeGraphIndex are better suited for static or infrequently updated corpora because rebuilding them is expensive." },
];
---

<BaseLayout
  title="LlamaIndex Index Selector — Choose the Right Index Type"
  description="Interactive decision tree to choose the right LlamaIndex index type for your use case. Answer 4 questions and get a recommended index (VectorStoreIndex, SummaryIndex, KnowledgeGraphIndex, SQLStructStoreIndex) with Python code."
  tool="LlamaIndex Index Selector, VectorStoreIndex, SummaryIndex, KnowledgeGraphIndex, LLM RAG Index"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">LlamaIndex Index Selector</h1>
  <p class="text-text-muted mb-4">Answer 4 questions about your data and query needs to get the right LlamaIndex index recommendation with a Python setup snippet.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 4-step decision tree</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Instant recommendation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Ready-to-run Python code</span>
  </div>

  <!-- Decision Tree -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-5">Step-by-step Index Finder</h2>

    <div class="space-y-6" id="decision-tree">
      <!-- Q1 -->
      <div class="decision-step" data-step="1">
        <p class="text-sm font-medium mb-3">1. What type of data are you indexing?</p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2" id="q1">
          <label class="decision-opt cursor-pointer">
            <input type="radio" name="q1" value="documents" class="sr-only" />
            <div class="border border-border rounded-lg p-3 text-center text-sm hover:border-primary transition-colors">
              <div class="text-xl mb-1">📄</div>
              <div class="font-medium">Documents</div>
              <div class="text-xs text-text-muted mt-0.5">PDFs, markdown, text</div>
            </div>
          </label>
          <label class="decision-opt cursor-pointer">
            <input type="radio" name="q1" value="code" class="sr-only" />
            <div class="border border-border rounded-lg p-3 text-center text-sm hover:border-primary transition-colors">
              <div class="text-xl mb-1">💻</div>
              <div class="font-medium">Code</div>
              <div class="text-xs text-text-muted mt-0.5">Source files, repos</div>
            </div>
          </label>
          <label class="decision-opt cursor-pointer">
            <input type="radio" name="q1" value="structured" class="sr-only" />
            <div class="border border-border rounded-lg p-3 text-center text-sm hover:border-primary transition-colors">
              <div class="text-xl mb-1">🗄️</div>
              <div class="font-medium">Structured</div>
              <div class="text-xs text-text-muted mt-0.5">SQL / CSV tables</div>
            </div>
          </label>
          <label class="decision-opt cursor-pointer">
            <input type="radio" name="q1" value="graph" class="sr-only" />
            <div class="border border-border rounded-lg p-3 text-center text-sm hover:border-primary transition-colors">
              <div class="text-xl mb-1">🕸️</div>
              <div class="font-medium">Knowledge Graph</div>
              <div class="text-xs text-text-muted mt-0.5">Entities & relations</div>
            </div>
          </label>
        </div>
      </div>

      <!-- Q2 -->
      <div class="decision-step" data-step="2">
        <p class="text-sm font-medium mb-3">2. What is your primary query type?</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-2" id="q2">
          <label class="decision-opt cursor-pointer">
            <input type="radio" name="q2" value="semantic" class="sr-only" />
            <div class="border border-border rounded-lg p-3 text-sm hover:border-primary transition-colors">
              <div class="font-medium">Semantic Search</div>
              <div class="text-xs text-text-muted mt-0.5">Find relevant passages, Q&amp;A</div>
            </div>
          </label>
          <label class="decision-opt cursor-pointer">
            <input type="radio" name="q2" value="summarization" class="sr-only" />
            <div class="border border-border rounded-lg p-3 text-sm hover:border-primary transition-colors">
              <div class="font-medium">Summarization</div>
              <div class="text-xs text-text-muted mt-0.5">Synthesize across all docs</div>
            </div>
          </label>
          <label class="decision-opt cursor-pointer">
            <input type="radio" name="q2" value="structured" class="sr-only" />
            <div class="border border-border rounded-lg p-3 text-sm hover:border-primary transition-colors">
              <div class="font-medium">Structured Queries</div>
              <div class="text-xs text-text-muted mt-0.5">Filters, aggregations, SQL</div>
            </div>
          </label>
        </div>
      </div>

      <!-- Q3 -->
      <div class="decision-step" data-step="3">
        <p class="text-sm font-medium mb-3">3. What is your data scale?</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-2" id="q3">
          <label class="decision-opt cursor-pointer">
            <input type="radio" name="q3" value="small" class="sr-only" />
            <div class="border border-border rounded-lg p-3 text-sm hover:border-primary transition-colors">
              <div class="font-medium">Small</div>
              <div class="text-xs text-text-muted mt-0.5">&lt; 1,000 documents</div>
            </div>
          </label>
          <label class="decision-opt cursor-pointer">
            <input type="radio" name="q3" value="medium" class="sr-only" />
            <div class="border border-border rounded-lg p-3 text-sm hover:border-primary transition-colors">
              <div class="font-medium">Medium</div>
              <div class="text-xs text-text-muted mt-0.5">1K – 100K documents</div>
            </div>
          </label>
          <label class="decision-opt cursor-pointer">
            <input type="radio" name="q3" value="large" class="sr-only" />
            <div class="border border-border rounded-lg p-3 text-sm hover:border-primary transition-colors">
              <div class="font-medium">Large</div>
              <div class="text-xs text-text-muted mt-0.5">&gt; 100K documents</div>
            </div>
          </label>
        </div>
      </div>

      <!-- Q4 -->
      <div class="decision-step" data-step="4">
        <p class="text-sm font-medium mb-3">4. How often does your data update?</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2" id="q4">
          <label class="decision-opt cursor-pointer">
            <input type="radio" name="q4" value="static" class="sr-only" />
            <div class="border border-border rounded-lg p-3 text-sm hover:border-primary transition-colors">
              <div class="font-medium">Static / Rarely</div>
              <div class="text-xs text-text-muted mt-0.5">Build once, query many times</div>
            </div>
          </label>
          <label class="decision-opt cursor-pointer">
            <input type="radio" name="q4" value="frequent" class="sr-only" />
            <div class="border border-border rounded-lg p-3 text-sm hover:border-primary transition-colors">
              <div class="font-medium">Frequently Updated</div>
              <div class="text-xs text-text-muted mt-0.5">New docs added regularly</div>
            </div>
          </label>
        </div>
      </div>
    </div>
  </div>

  <!-- Recommendation -->
  <div id="recommendation" class="hidden bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Recommended Index</h2>
    <div id="rec-badge" class="inline-flex items-center gap-2 bg-primary/10 text-primary px-4 py-2 rounded-lg font-mono text-sm font-semibold mb-4"></div>
    <p id="rec-explanation" class="text-sm text-text-muted mb-5"></p>
    <div class="flex items-center justify-between mb-2">
      <h3 class="text-sm font-semibold">Python Setup Code</h3>
      <button id="copy-rec-btn" class="text-xs bg-primary text-white px-3 py-1.5 rounded-lg hover:opacity-90 flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
        <span id="copy-rec-label">Copy</span>
      </button>
    </div>
    <pre id="rec-code" class="text-xs font-mono bg-black/20 rounded-lg p-4 overflow-auto whitespace-pre text-green-400 leading-relaxed"></pre>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="LlamaIndex Index Selector" relatedTags={['ai', 'llm', 'rag', 'llamaindex', 'vector', 'python']} />
</BaseLayout>

<script is:inline>
  const RECOMMENDATIONS = {
    structured: {
      name: 'SQLStructStoreIndex',
      explanation: 'Your data is structured (tables/SQL). SQLStructStoreIndex lets the LLM generate SQL queries against your database, enabling precise filtering, aggregations, and joins that vector search cannot do reliably.',
      code: `from llama_index.core import SQLDatabase
from llama_index.core.indices.struct_store import SQLStructStoreIndex
from sqlalchemy import create_engine

# Connect to your database
engine = create_engine("sqlite:///your_database.db")
sql_database = SQLDatabase(engine, include_tables=["your_table"])

# Build the index
index = SQLStructStoreIndex(
    [],
    sql_database=sql_database,
)

# Query
query_engine = index.as_query_engine()
response = query_engine.query("What is the average revenue by region?")
print(response)`,
    },
    graph: {
      name: 'KnowledgeGraphIndex',
      explanation: 'Your data has rich entity relationships. KnowledgeGraphIndex extracts (subject, predicate, object) triplets, enabling multi-hop reasoning and relationship queries that semantic search handles poorly.',
      code: `from llama_index.core import SimpleDirectoryReader, KnowledgeGraphIndex
from llama_index.core import Settings
from llama_index.llms.openai import OpenAI

Settings.llm = OpenAI(model="gpt-4o-mini", temperature=0)
Settings.chunk_size = 512

# Load documents
documents = SimpleDirectoryReader("./data").load_data()

# Build knowledge graph index
index = KnowledgeGraphIndex.from_documents(
    documents,
    max_triplets_per_chunk=10,
    include_embeddings=True,
)

# Query with multi-hop reasoning
query_engine = index.as_query_engine(
    include_text=True,
    response_mode="tree_summarize",
)
response = query_engine.query("What companies is Alice connected to?")
print(response)`,
    },
    summarization: {
      name: 'SummaryIndex',
      explanation: 'You need to synthesize information across your entire document set. SummaryIndex sequentially reads all nodes, making it ideal for document-level summarization and holistic analysis.',
      code: `from llama_index.core import SimpleDirectoryReader, SummaryIndex
from llama_index.core import Settings
from llama_index.llms.openai import OpenAI

Settings.llm = OpenAI(model="gpt-4o-mini")

# Load documents
documents = SimpleDirectoryReader("./data").load_data()

# Build summary index
index = SummaryIndex.from_documents(documents)

# Use tree summarize for large corpora
query_engine = index.as_query_engine(
    response_mode="tree_summarize",
)
response = query_engine.query(
    "Summarize the key themes across all documents."
)
print(response)`,
    },
    vector_small: {
      name: 'VectorStoreIndex (in-memory)',
      explanation: 'For small corpora (<1K docs) semantic search is the best fit. An in-memory VectorStoreIndex is perfect — fast to build, no external dependencies, and great retrieval quality.',
      code: `from llama_index.core import SimpleDirectoryReader, VectorStoreIndex
from llama_index.core import Settings
from llama_index.llms.openai import OpenAI
from llama_index.embeddings.openai import OpenAIEmbedding

Settings.llm = OpenAI(model="gpt-4o-mini")
Settings.embed_model = OpenAIEmbedding(model="text-embedding-3-small")

# Load documents
documents = SimpleDirectoryReader("./data").load_data()

# Build in-memory vector index
index = VectorStoreIndex.from_documents(
    documents,
    show_progress=True,
)

# Query
query_engine = index.as_query_engine(similarity_top_k=5)
response = query_engine.query("Your question here")
print(response)`,
    },
    vector_large: {
      name: 'VectorStoreIndex (Pinecone/Qdrant)',
      explanation: 'For medium-to-large corpora or frequent updates, use VectorStoreIndex backed by an external vector database. This scales to millions of documents and supports incremental upserts.',
      code: `from llama_index.core import SimpleDirectoryReader, VectorStoreIndex, StorageContext
from llama_index.vector_stores.qdrant import QdrantVectorStore
from llama_index.embeddings.openai import OpenAIEmbedding
from llama_index.core import Settings
import qdrant_client

Settings.embed_model = OpenAIEmbedding(model="text-embedding-3-small")

# Connect to Qdrant (or swap for Pinecone, Weaviate, etc.)
client = qdrant_client.QdrantClient(url="http://localhost:6333")
vector_store = QdrantVectorStore(
    client=client,
    collection_name="my_collection",
)
storage_context = StorageContext.from_defaults(vector_store=vector_store)

# Load and index documents
documents = SimpleDirectoryReader("./data").load_data()
index = VectorStoreIndex.from_documents(
    documents,
    storage_context=storage_context,
    show_progress=True,
)

# Query
query_engine = index.as_query_engine(similarity_top_k=5)
response = query_engine.query("Your question here")
print(response)`,
    },
  };

  function getAnswers() {
    return {
      q1: document.querySelector('input[name="q1"]:checked')?.value,
      q2: document.querySelector('input[name="q2"]:checked')?.value,
      q3: document.querySelector('input[name="q3"]:checked')?.value,
      q4: document.querySelector('input[name="q4"]:checked')?.value,
    };
  }

  function recommend() {
    const a = getAnswers();
    if (!a.q1 || !a.q2 || !a.q3 || !a.q4) {
      document.getElementById('recommendation').classList.add('hidden');
      return;
    }

    let rec;
    if (a.q1 === 'structured') {
      rec = RECOMMENDATIONS.structured;
    } else if (a.q1 === 'graph') {
      rec = RECOMMENDATIONS.graph;
    } else if (a.q2 === 'summarization') {
      rec = RECOMMENDATIONS.summarization;
    } else if (a.q3 === 'small') {
      rec = RECOMMENDATIONS.vector_small;
    } else {
      rec = RECOMMENDATIONS.vector_large;
    }

    document.getElementById('rec-badge').textContent = rec.name;
    document.getElementById('rec-explanation').textContent = rec.explanation;
    document.getElementById('rec-code').textContent = rec.code;
    document.getElementById('recommendation').classList.remove('hidden');
  }

  // Style selected options
  document.querySelectorAll('.decision-opt input[type="radio"]').forEach(radio => {
    radio.addEventListener('change', function() {
      const name = this.name;
      document.querySelectorAll(`input[name="${name}"]`).forEach(r => {
        r.closest('label').querySelector('div').classList.remove('border-primary', 'bg-primary/5');
      });
      this.closest('label').querySelector('div').classList.add('border-primary', 'bg-primary/5');
      recommend();
    });
  });

  document.getElementById('copy-rec-btn').addEventListener('click', () => {
    const code = document.getElementById('rec-code').textContent;
    navigator.clipboard.writeText(code).then(() => {
      const lbl = document.getElementById('copy-rec-label');
      lbl.textContent = 'Copied!';
      setTimeout(() => lbl.textContent = 'Copy', 2000);
    });
  });
</script>
