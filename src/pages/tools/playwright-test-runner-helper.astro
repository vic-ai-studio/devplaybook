---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PlaywrightTestRunnerHelper from '../../components/PlaywrightTestRunnerHelper.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is playwright.config.ts used for?",
    answer: "playwright.config.ts (or .js) is the central configuration file for Playwright Test. It defines which browsers to test, timeouts, retry counts, reporters, artifact collection (screenshots, video, traces), and test file patterns. Every setting has a sensible default, so you only need to configure what differs from the defaults."
  },
  {
    question: "How many browsers should I test?",
    answer: "For most web apps, starting with Chromium alone covers ~65% of users and is fastest. Add Firefox for cross-browser compatibility. Add WebKit (Safari) if you have macOS/iOS users. Testing all three gives the best coverage but roughly triples test time. Use the --project flag to run a single browser in CI for speed: `npx playwright test --project=chromium`."
  },
  {
    question: "What are retries and when should I use them?",
    answer: "Retries re-run a failed test up to N times before marking it as failed. Use 0 in local development (fail fast, debug immediately). Use 1-2 in CI to handle flaky tests caused by network timing or race conditions. Never use retries to mask genuinely broken tests — fix the root cause instead."
  },
  {
    question: "What is the difference between trace, video, and screenshot?",
    answer: "Screenshots capture the page state at the moment of failure. Videos record the full test run as an mp4. Traces (Playwright Trace Viewer) capture network requests, console logs, DOM snapshots, and an action timeline — the most powerful debugging artifact. `retain-on-failure` and `on-first-retry` are good balanced defaults that only collect artifacts when tests fail, saving disk space."
  },
  {
    question: "What does fullyParallel mean?",
    answer: "When fullyParallel is true, each individual test runs in parallel across workers. When false, each test file runs in one worker but files run in parallel. fullyParallel: true is faster for suites with many small tests. Set workers to '50%' or '100%' to use multiple CPU cores. In CI, typically use workers: 1 for serial execution to avoid resource contention."
  },
  {
    question: "How does the webServer option work?",
    answer: "The webServer config tells Playwright to auto-start your dev server (e.g., `npm run dev`) before running tests and wait for it to be ready. Set reuseExistingServer: !process.env.CI so it reuses an already-running server locally but always starts fresh in CI. This avoids port conflicts and ensures tests always run against the correct version."
  },
];
---

<BaseLayout
  title="Playwright Config Generator — Build playwright.config.ts Online"
  description="Generate a playwright.config.ts file with browser selection, timeouts, retries, reporters, screenshots, video, trace, and web server settings. Copy-ready output for TypeScript or JavaScript."
  tool="Playwright Config Generator, playwright.config.ts, Playwright Test Configuration, Playwright Setup"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Playwright Test Configuration Generator",
    "url": "https://devplaybook.cc/tools/playwright-test-runner-helper",
    "description": "Build a playwright.config.ts or playwright.config.js file visually. Configure browsers, timeouts, retries, reporters, and artifact collection. Copy-ready output.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Playwright Config Generator</h1>
  <p class="text-text-muted mb-4">
    Build a <code class="font-mono bg-surface px-1 rounded text-sm">playwright.config.ts</code> file visually.
    Choose browsers, set timeouts and retries, pick reporters, and configure screenshot/video/trace collection.
    Copy the ready-to-use output directly into your project.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Chromium, Firefox, WebKit</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript & JavaScript</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Screenshots, Video, Traces</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-ready output</span>
  </div>
  <PlaywrightTestRunnerHelper client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Playwright Config Generator" relatedTags={['testing', 'playwright', 'e2e', 'automation', 'developer-tools']} />
</BaseLayout>
