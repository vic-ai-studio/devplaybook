---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What are binary, octal, decimal, and hexadecimal?", answer: "These are four positional numeral systems using different bases. Decimal (base 10) is the everyday number system (digits 0-9). Binary (base 2) uses only 0 and 1 — the language of computers at the hardware level (transistors are either on or off). Octal (base 8) uses digits 0-7 — historically used in older computing systems and still used in Unix file permissions (chmod 755). Hexadecimal (base 16) uses digits 0-9 and letters A-F — widely used in programming for memory addresses, colors (#FF8C00), and byte values because 2 hex digits = exactly 1 byte." },
  { question: "How do you convert binary to decimal?", answer: "Each bit position represents a power of 2, starting from the rightmost bit (2^0 = 1). To convert 1011 in binary: 1×2³ + 0×2² + 1×2¹ + 1×2⁰ = 8 + 0 + 2 + 1 = 11 in decimal. Or use JavaScript: parseInt('1011', 2) → 11. To convert decimal to binary: repeatedly divide by 2 and collect remainders from bottom to top, or use (11).toString(2) → '1011'." },
  { question: "How do you convert hexadecimal to decimal?", answer: "Each hex digit represents a power of 16. Digits A-F represent 10-15. To convert 2AF in hex: 2×16² + A×16¹ + F×16⁰ = 2×256 + 10×16 + 15×1 = 512 + 160 + 15 = 687 in decimal. In JavaScript: parseInt('2AF', 16) → 687. To convert back: (687).toString(16) → '2af'. Hex is popular because it maps neatly to binary: each hex digit = exactly 4 binary bits (a nibble)." },
  { question: "What is two's complement?", answer: "Two's complement is the standard method for representing signed integers in binary. For an n-bit number: positive numbers are stored as normal binary. For negative numbers, take the positive binary, flip all bits (one's complement), then add 1. For 8-bit signed: -1 = 11111111, -128 = 10000000, 127 = 01111111. The leftmost bit is the sign bit (0=positive, 1=negative). Two's complement allows the same binary addition circuit to handle both positive and negative numbers, simplifying CPU design." },
];
---

<BaseLayout
  title="Number System Converter — Binary, Octal, Decimal, Hexadecimal"
  description="Convert numbers between binary (base 2), octal (base 8), decimal (base 10), and hexadecimal (base 16). Shows bit visualization and two's complement."
  tool="number system converter, binary to decimal, hex to binary, octal converter, base conversion, two's complement, binary calculator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Number System Converter — Binary, Octal, Decimal, Hex",
    "url": "https://devplaybook.cc/tools/number-system-converter",
    "description": "Convert numbers between binary, octal, decimal, and hexadecimal with bit visualization and two's complement.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Number System Converter</h1>
  <p class="text-text-muted mb-6">
    Convert numbers between <strong>Binary</strong> (base 2), <strong>Octal</strong> (base 8),
    <strong>Decimal</strong> (base 10), and <strong>Hexadecimal</strong> (base 16).
    Supports integers up to 64-bit with bit visualization.
  </p>

  <div class="grid md:grid-cols-2 gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <label class="block text-xs text-text-muted mb-1">Binary (base 2)</label>
      <div class="flex gap-2">
        <input id="binInput" type="text" placeholder="e.g. 1010"
          class="flex-1 font-mono bg-transparent border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
        <button class="copy-btn text-xs text-primary px-2" data-target="binInput">Copy</button>
      </div>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <label class="block text-xs text-text-muted mb-1">Octal (base 8)</label>
      <div class="flex gap-2">
        <input id="octInput" type="text" placeholder="e.g. 755"
          class="flex-1 font-mono bg-transparent border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
        <button class="copy-btn text-xs text-primary px-2" data-target="octInput">Copy</button>
      </div>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <label class="block text-xs text-text-muted mb-1">Decimal (base 10)</label>
      <div class="flex gap-2">
        <input id="decInput" type="text" placeholder="e.g. 255"
          class="flex-1 font-mono bg-transparent border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
        <button class="copy-btn text-xs text-primary px-2" data-target="decInput">Copy</button>
      </div>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <label class="block text-xs text-text-muted mb-1">Hexadecimal (base 16)</label>
      <div class="flex gap-2">
        <input id="hexInput" type="text" placeholder="e.g. FF"
          class="flex-1 font-mono bg-transparent border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary uppercase" />
        <button class="copy-btn text-xs text-primary px-2" data-target="hexInput">Copy</button>
      </div>
    </div>
  </div>

  <!-- Bit visualization -->
  <div class="bg-bg-card border border-border rounded-xl p-4 mb-6">
    <div class="flex items-center justify-between mb-3">
      <h3 class="text-sm font-semibold">Bit Visualization</h3>
      <select id="bitWidth" class="bg-bg-card border border-border rounded px-2 py-1 text-xs">
        <option value="8">8-bit</option>
        <option value="16">16-bit</option>
        <option value="32" selected>32-bit</option>
        <option value="64">64-bit</option>
      </select>
    </div>
    <div id="bitViz" class="flex flex-wrap gap-1 font-mono text-xs"></div>
    <div id="byteBreakdown" class="text-xs text-text-muted mt-2 font-mono"></div>
  </div>

  <ToolPageCta />
  <FaqSection faqs={faq} />
</BaseLayout>

<script>
let converting = false;

function parse(val: string, base: number): number|null {
  const n = parseInt(val, base);
  return isNaN(n) ? null : n;
}

function updateAll(source: string, n: number) {
  if (converting) return;
  converting = true;
  const inputs: Record<string,[string,number]> = {
    binInput: ['bin',2], octInput: ['oct',8], decInput: ['dec',10], hexInput: ['hex',16]
  };
  for (const [id, [, base]] of Object.entries(inputs)) {
    if (id !== source) {
      (document.getElementById(id) as HTMLInputElement).value = n.toString(base).toUpperCase();
    }
  }
  updateBits(n);
  converting = false;
}

function updateBits(n: number) {
  const width = parseInt((document.getElementById('bitWidth') as HTMLSelectElement).value);
  const bits = (n >>> 0).toString(2).padStart(Math.max(width, 1), '0').slice(-width);
  const el = document.getElementById('bitViz')!;
  // Group into nibbles (4 bits)
  const groups: string[] = [];
  for (let i = 0; i < bits.length; i += 4) groups.push(bits.slice(i, i+4));
  el.innerHTML = groups.map((g, gi) => `
    <div class="flex gap-0.5 mr-2">
      ${g.split('').map((b, bi) => {
        const pos = bits.length - (gi*4+bi) - 1;
        return `<div title="bit ${pos} (2^${pos})" class="w-6 h-6 flex items-center justify-center rounded text-xs border ${b==='1'?'bg-primary text-white border-primary':'border-border text-text-muted'}">${b}</div>`;
      }).join('')}
    </div>`).join('');
  const bytes = [];
  for (let i = 0; i < bits.length; i += 8) bytes.push(parseInt(bits.slice(i,i+8)||'0', 2));
  (document.getElementById('byteBreakdown') as HTMLElement).textContent = `Bytes: [${bytes.map(b=>'0x'+b.toString(16).toUpperCase().padStart(2,'0')).join(', ')}]`;
}

const configs: [string, number][] = [['binInput',2],['octInput',8],['decInput',10],['hexInput',16]];
for (const [id, base] of configs) {
  document.getElementById(id)?.addEventListener('input', e => {
    const n = parse((e.target as HTMLInputElement).value, base);
    if (n !== null) updateAll(id, n);
  });
}
document.getElementById('bitWidth')?.addEventListener('change', () => {
  const dec = (document.getElementById('decInput') as HTMLInputElement).value;
  const n = parse(dec, 10);
  if (n !== null) updateBits(n);
});

document.querySelectorAll('.copy-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const id = (btn as HTMLElement).dataset.target!;
    navigator.clipboard.writeText((document.getElementById(id) as HTMLInputElement).value);
    (btn as HTMLElement).textContent = '✓';
    setTimeout(() => (btn as HTMLElement).textContent = 'Copy', 1500);
  });
});

// Initialize with 255
(document.getElementById('decInput') as HTMLInputElement).value = '255';
updateAll('decInput', 255);
</script>
