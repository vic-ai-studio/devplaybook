---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Levenshtein distance?", answer: "Levenshtein distance (edit distance) is the minimum number of single-character edits — insertions, deletions, or substitutions — required to transform one string into another. For example, 'kitten' to 'sitting' has a Levenshtein distance of 3 (substitute k→s, substitute e→i, insert g at end). It is named after Soviet mathematician Vladimir Levenshtein who defined it in 1965. Edit distance is used in spell checkers, DNA sequence alignment, and fuzzy string matching." },
  { question: "What is Jaro-Winkler similarity?", answer: "Jaro-Winkler is a string similarity metric that gives extra weight to strings that share a common prefix, making it well-suited for matching names. Jaro similarity measures the number of matching characters (within a threshold) and the number of transpositions. Winkler extends this by boosting scores for strings with a common prefix (up to 4 characters). Scores range from 0 (no similarity) to 1 (identical). Jaro-Winkler works better than Levenshtein for names like 'John' vs 'Jon' or 'Smith' vs 'Smyth'." },
  { question: "What is cosine similarity for text?", answer: "Cosine similarity measures the angle between two text vectors in a word-frequency space. Each text is represented as a vector where each dimension is a word and the value is how often that word appears. The cosine of the angle between the two vectors is the similarity (0 = nothing in common, 1 = identical word distribution). Unlike edit distance (character-level), cosine similarity is word-level and order-independent — 'dog bites man' and 'man bites dog' have high cosine similarity but are semantically different." },
  { question: "Which similarity metric should I use?", answer: "Levenshtein distance: best for typo correction, short strings, and cases where character position matters (password validation, autocorrect). Jaro-Winkler: best for name matching and deduplication (CRM systems, voter rolls). Cosine similarity: best for document-level comparison and duplicate article detection. Hamming distance: only works on equal-length strings, fastest for fixed-format codes. Jaccard similarity: good for comparing sets of words (tag matching, search)." },
];
---

<BaseLayout
  title="Text Similarity — Levenshtein Distance and String Comparison"
  description="Compare two strings with Levenshtein edit distance, Jaro-Winkler similarity, cosine similarity, and Jaccard index. Visualize the character-level diff."
  tool="text similarity checker, Levenshtein distance calculator, Jaro-Winkler similarity, string comparison, fuzzy string match, edit distance"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Text Similarity — Levenshtein Distance and String Comparison",
    "url": "https://devplaybook.cc/tools/text-similarity",
    "description": "Compare two strings with Levenshtein edit distance, Jaro-Winkler, cosine similarity, and Jaccard index.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Text Similarity</h1>
  <p class="text-text-muted mb-6">
    Compare two strings using multiple similarity metrics: <strong>Levenshtein edit distance</strong>,
    Jaro-Winkler similarity, cosine similarity, and Jaccard index. Useful for spell checking, name
    matching, and duplicate detection.
  </p>

  <div class="grid md:grid-cols-2 gap-4 mb-6">
    <div>
      <label class="block text-sm font-medium mb-2">String A</label>
      <textarea
        id="textA"
        class="w-full h-32 bg-bg-card border border-border rounded-xl p-3 text-sm font-mono resize-none focus:outline-none focus:ring-2 focus:ring-primary"
        placeholder="Enter first string..."
      >kitten</textarea>
    </div>
    <div>
      <label class="block text-sm font-medium mb-2">String B</label>
      <textarea
        id="textB"
        class="w-full h-32 bg-bg-card border border-border rounded-xl p-3 text-sm font-mono resize-none focus:outline-none focus:ring-2 focus:ring-primary"
        placeholder="Enter second string..."
      >sitting</textarea>
    </div>
  </div>

  <div id="metrics" class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
      <div id="levenshtein" class="text-2xl font-bold text-primary">—</div>
      <div class="text-xs text-text-muted mt-1">Levenshtein Distance</div>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
      <div id="similarity-pct" class="text-2xl font-bold text-primary">—</div>
      <div class="text-xs text-text-muted mt-1">Normalized Similarity</div>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
      <div id="jaro" class="text-2xl font-bold text-primary">—</div>
      <div class="text-xs text-text-muted mt-1">Jaro-Winkler</div>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
      <div id="jaccard" class="text-2xl font-bold text-primary">—</div>
      <div class="text-xs text-text-muted mt-1">Jaccard (words)</div>
    </div>
  </div>

  <div class="bg-bg-card border border-border rounded-xl p-4 mb-6">
    <h3 class="text-sm font-medium mb-2">Character-Level Diff</h3>
    <div id="diffOutput" class="text-sm font-mono leading-relaxed break-all">
      <span class="text-text-muted text-xs">Type in both fields to see diff</span>
    </div>
    <div class="flex gap-4 mt-3 text-xs text-text-muted">
      <span><span class="bg-green-500/20 text-green-500 px-1 rounded">green</span> = in B only (inserted)</span>
      <span><span class="bg-red-500/20 text-red-500 px-1 rounded">red</span> = in A only (deleted)</span>
    </div>
  </div>

  <ToolPageCta />
  <FaqSection faqs={faq} />
</BaseLayout>

<script>
function levenshtein(a: string, b: string): number {
  const m = a.length, n = b.length;
  const dp: number[][] = Array.from({length: m+1}, (_, i) => Array.from({length: n+1}, (_, j) => i===0?j:j===0?i:0));
  for (let i=1;i<=m;i++) for (let j=1;j<=n;j++)
    dp[i][j] = a[i-1]===b[j-1] ? dp[i-1][j-1] : 1 + Math.min(dp[i-1][j], dp[i][j-1], dp[i-1][j-1]);
  return dp[m][n];
}

function jaro(s1: string, s2: string): number {
  if (s1===s2) return 1;
  const l1=s1.length, l2=s2.length;
  const matchDist = Math.max(Math.floor(Math.max(l1,l2)/2)-1,0);
  const s1m=new Array(l1).fill(false), s2m=new Array(l2).fill(false);
  let matches=0;
  for (let i=0;i<l1;i++) {
    const start=Math.max(0,i-matchDist), end=Math.min(i+matchDist+1,l2);
    for (let j=start;j<end;j++) {
      if (!s2m[j]&&s1[i]===s2[j]) { s1m[i]=s2m[j]=true; matches++; break; }
    }
  }
  if (!matches) return 0;
  let t=0, k=0;
  for (let i=0;i<l1;i++) if (s1m[i]) { while(!s2m[k])k++; if(s1[i]!==s2[k])t++; k++; }
  const j=(matches/l1+matches/l2+(matches-t/2)/matches)/3;
  let prefix=0;
  for (let i=0;i<Math.min(4,Math.min(l1,l2));i++) { if (s1[i]===s2[i]) prefix++; else break; }
  return j + prefix*0.1*(1-j);
}

function jaccard(a: string, b: string): number {
  const setA = new Set(a.toLowerCase().split(/\s+/).filter(Boolean));
  const setB = new Set(b.toLowerCase().split(/\s+/).filter(Boolean));
  const inter = new Set([...setA].filter(x=>setB.has(x)));
  const union = new Set([...setA, ...setB]);
  return union.size === 0 ? 1 : inter.size/union.size;
}

function simpleDiff(a: string, b: string): string {
  const max = 500;
  if (a.length > max || b.length > max) return '<span class="text-text-muted">Diff hidden for long strings (max 500 chars each)</span>';
  // LCS-based diff
  const la=a.split(''), lb=b.split('');
  const m=la.length, n=lb.length;
  const dp=Array.from({length:m+1},()=>new Array(n+1).fill(0));
  for(let i=1;i<=m;i++) for(let j=1;j<=n;j++)
    dp[i][j]=la[i-1]===lb[j-1]?dp[i-1][j-1]+1:Math.max(dp[i-1][j],dp[i][j-1]);
  const parts: {type:string,ch:string}[] = [];
  let i=m,j=n;
  while(i>0||j>0){
    if(i>0&&j>0&&la[i-1]===lb[j-1]){parts.unshift({type:'eq',ch:la[i-1]});i--;j--;}
    else if(j>0&&(i===0||dp[i][j-1]>=dp[i-1][j])){parts.unshift({type:'ins',ch:lb[j-1]});j--;}
    else{parts.unshift({type:'del',ch:la[i-1]});i--;}
  }
  return parts.map(p=>{
    const escaped=p.ch.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    if(p.type==='eq') return escaped;
    if(p.type==='ins') return `<span class="bg-green-500/20 text-green-500 rounded">${escaped}</span>`;
    return `<span class="bg-red-500/20 text-red-500 rounded">${escaped}</span>`;
  }).join('');
}

function update() {
  const a=(document.getElementById('textA') as HTMLTextAreaElement).value;
  const b=(document.getElementById('textB') as HTMLTextAreaElement).value;
  const lev=levenshtein(a,b);
  const maxLen=Math.max(a.length,b.length);
  const sim=maxLen===0?100:Math.round((1-lev/maxLen)*100);
  (document.getElementById('levenshtein') as HTMLElement).textContent=String(lev);
  (document.getElementById('similarity-pct') as HTMLElement).textContent=sim+'%';
  (document.getElementById('jaro') as HTMLElement).textContent=(jaro(a,b)*100).toFixed(1)+'%';
  (document.getElementById('jaccard') as HTMLElement).textContent=(jaccard(a,b)*100).toFixed(1)+'%';
  (document.getElementById('diffOutput') as HTMLElement).innerHTML=simpleDiff(a,b);
}

document.getElementById('textA')?.addEventListener('input',update);
document.getElementById('textB')?.addEventListener('input',update);
update();
</script>
