---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EnvVariablesChecker from '../../components/EnvVariablesChecker.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What does this tool check in my .env file?",
    answer: "It runs 9 checks: valid KEY=VALUE format on every line, duplicate key detection, UPPER_SNAKE_CASE naming convention, empty values, unquoted values with spaces, weak/placeholder secret values (password, changeme, etc.), mismatched quotes, tab characters, and trailing whitespace in values."
  },
  {
    question: "Is my .env file content sent to a server?",
    answer: "No. All validation runs entirely in your browser using JavaScript. Your environment variables — which often contain API keys, database passwords, and other secrets — never leave your machine."
  },
  {
    question: "What is a .env.example file and why do I need one?",
    answer: "A .env.example (or .env.template) is a copy of your .env with all secret values redacted. It's safe to commit to version control and helps teammates know which variables are needed. This tool generates one automatically by keeping non-secret values and clearing sensitive ones."
  },
  {
    question: "Why does it flag lowercase key names?",
    answer: "The convention for environment variable names is UPPER_SNAKE_CASE (e.g. DATABASE_URL, NODE_ENV). While most Unix/Linux shells support lowercase env vars, many tools, frameworks, and CI/CD systems expect uppercase. Using uppercase also makes it visually clear that something is an env var, not a regular variable."
  },
  {
    question: "Why should I quote values with spaces?",
    answer: "Some tools parse .env files differently. Without quotes, a value like APP_NAME=My Awesome App may be parsed as APP_NAME=My with the rest truncated, or cause a parsing error. Wrapping in double quotes (APP_NAME=\"My Awesome App\") is the safest approach for cross-tool compatibility."
  },
  {
    question: "What makes a secret value 'weak'?",
    answer: "The checker flags values that look like placeholders — 'password', 'secret', 'changeme', 'your_key_here', 'abc123', and similar patterns. These are fine for local development but dangerous in production. The tool catches cases where a developer forgets to replace example values before deploying."
  },
];
---

<BaseLayout
  title="Env Variables Checker — Validate .env Files Online"
  description="Paste your .env file and validate it instantly. Checks for duplicate keys, invalid format, weak secrets, unquoted values, naming conventions, and more. Generate a .env.example automatically. Runs 100% in your browser."
  tool="Env Variables Checker, .env file validator, environment variables linter, dotenv checker"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Env Variables Checker",
    "url": "https://devplaybook.cc/tools/env-variables-checker",
    "description": "Validate .env files online. Checks format, duplicate keys, naming conventions, weak secrets, and more. Generates a safe .env.example template. Runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Env Variables Checker</h1>
  <p class="text-text-muted mb-4">
    Paste your <code class="font-mono bg-surface px-1 rounded text-sm">.env</code> file and validate it instantly.
    Catches duplicate keys, missing quotes, weak secrets, naming issues, and more.
    Also generates a safe <code class="font-mono bg-surface px-1 rounded text-sm">.env.example</code> template — nothing is sent to any server.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 9 validation checks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auto-generates .env.example</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No data leaves your browser</span>
  </div>
  <EnvVariablesChecker client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Env Variables Checker" relatedTags={['devops', 'security', 'configuration', 'dotenv', 'developer-tools']} />
</BaseLayout>
