---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SubnetCalculator from '../../components/SubnetCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is CIDR notation?", answer: "CIDR (Classless Inter-Domain Routing) notation combines an IP address with a prefix length to define a network range. For example, 192.168.1.0/24 means a network with a 24-bit subnet mask (255.255.255.0), giving 254 usable host addresses." },
  { question: "How many hosts does a /24 subnet have?", answer: "A /24 subnet has 256 total addresses (2^8 = 256), minus 2 for the network address and broadcast address, leaving 254 usable host addresses." },
  { question: "What is the difference between network address and broadcast address?", answer: "The network address (first address) identifies the subnet itself and cannot be assigned to a host. The broadcast address (last address) is used to send packets to all hosts on the subnet and also cannot be assigned." },
  { question: "What is a subnet mask?", answer: "A subnet mask is a 32-bit number that divides an IP address into network and host portions. /24 corresponds to 255.255.255.0, /16 to 255.255.0.0, and /8 to 255.0.0.0." },
];
---

<BaseLayout
  title="Subnet Calculator — IPv4 CIDR Calculator"
  description="Free IPv4 subnet calculator. Enter a CIDR block to instantly see subnet mask, broadcast address, usable host range, and total hosts. Fast, private, no signup."
  tool="subnet calculator, CIDR calculator, IPv4 subnet, network address calculator, subnet mask calculator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">IPv4 Subnet Calculator</h1>
  <p class="text-text-muted mb-4">Enter an IP address with CIDR notation (e.g., 192.168.1.0/24) to calculate the network address, subnet mask, broadcast address, host range, and total usable hosts. Binary representation included.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Binary breakdown included</span>
  </div>
  <SubnetCalculator client:only="preact" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more free developer tools?</p>
    <a href="/tools" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Browse All Free Tools →</a>
  </div>
  <ToolPageCta currentTool="Subnet Calculator" relatedTags={['network', 'devops', 'linux', 'infrastructure']} />
</BaseLayout>
