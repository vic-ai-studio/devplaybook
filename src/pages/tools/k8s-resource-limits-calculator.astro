---
import BaseLayout from '../../layouts/BaseLayout.astro';
import K8sResourceLimitsCalculator from '../../components/K8sResourceLimitsCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is the difference between CPU requests and CPU limits in Kubernetes?",
    answer: "CPU request is the amount of CPU the scheduler guarantees your container will always have — it is used to decide which node the pod lands on. CPU limit is the maximum CPU a container can consume before Kubernetes throttles it. If a container tries to use more CPU than its limit, the kernel throttles it (reduces its time slice) but does not kill it. Unlike memory, exceeding a CPU limit never causes a pod restart."
  },
  {
    question: "What causes OOMKilled in Kubernetes and how do I prevent it?",
    answer: "OOMKilled (Out Of Memory Killed) happens when a container exceeds its memory limit. The Linux kernel's OOM killer terminates the process, and Kubernetes immediately restarts the container. To prevent it: (1) profile your app's real memory usage with kubectl top or Prometheus, (2) set memory limits at least 1.5×–2× the request, (3) never set memory limits lower than requests. Watch CrashLoopBackOff with exit code 137 — that is always OOMKill."
  },
  {
    question: "What is a ResourceQuota and why should I use one?",
    answer: "A ResourceQuota sets an aggregate cap on all resource consumption within a Kubernetes namespace. Without a ResourceQuota, a single misbehaving workload can exhaust all cluster resources and starve other namespaces. Apply ResourceQuotas to every non-system namespace in production. This calculator adds 20% headroom above your calculated totals so the quota does not immediately block new deployments during scaling events."
  },
  {
    question: "Why does this calculator warn when limits are more than 4× requests?",
    answer: "The 4× ratio is a widely used rule of thumb. A very high limit-to-request ratio means pods are scheduled based on low requests but allowed to consume much more, causing noisy-neighbor problems on the node. For CPU, this triggers excessive throttling spikes. For memory, it risks OOMKill during load spikes. Best practice: CPU limit at 2×–3× request, memory limit at 1.5×–2× request. For latency-sensitive apps, set CPU request = limit (Guaranteed QoS)."
  },
  {
    question: "What is Kubernetes QoS class and how does it affect pod eviction?",
    answer: "Kubernetes assigns a QoS class to every pod based on its resource configuration. Guaranteed (request = limit for all containers) — never evicted under memory pressure. Burstable (at least one request < limit) — evicted when node is under pressure after BestEffort pods. BestEffort (no requests or limits at all) — first to be evicted. For critical production workloads, use Guaranteed QoS by setting memory request equal to memory limit."
  },
];
---

<BaseLayout
  title="Kubernetes Resource Limits Calculator — CPU & Memory Requests/Limits"
  description="Calculate total CPU and memory requests and limits across all replicas. Generate ready-to-apply Kubernetes ResourceQuota and LimitRange YAML with 20% headroom. Free, runs in your browser."
  tool="Kubernetes Resource Calculator, K8s CPU Memory Limits, ResourceQuota Generator, Container Resource Planner, K8s LimitRange Generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Kubernetes Resource Limits Calculator",
    "url": "https://devplaybook.cc/tools/k8s-resource-limits-calculator",
    "description": "Calculate total Kubernetes CPU and memory resource requests and limits across all pod replicas. Generate ResourceQuota and LimitRange YAML with 20% headroom for namespace resource management.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Kubernetes Resource Limits Calculator</h1>
  <p class="text-text-muted mb-4">
    Set CPU and memory requests/limits per container, then specify your replica count and containers per pod.
    The calculator totals your cluster resource footprint and generates ready-to-apply
    <strong>ResourceQuota</strong> and <strong>LimitRange</strong> YAML with 20% headroom.
    Warns on common misconfigurations like limit/request ratios &gt;4× and missing requests.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Millicores & Mi/Gi parsing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> ResourceQuota YAML</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> LimitRange YAML</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Misconfiguration warnings</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 20% quota headroom</span>
  </div>
  <K8sResourceLimitsCalculator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Kubernetes Resource Limits Calculator" relatedTags={['kubernetes', 'devops', 'infrastructure', 'yaml', 'containers', 'calculator']} />
</BaseLayout>
