---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ZodSchemaGenerator from '../../components/ZodSchemaGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Zod?", answer: "Zod is a TypeScript-first schema declaration and validation library. You define a schema once and get TypeScript type inference automatically. It's widely used for validating API inputs, environment variables, form data, and more. Unlike io-ts, Zod has a chainable, ergonomic API — z.string().min(1).email() reads like what it does." },
  { question: "How does z.infer work?", answer: "z.infer<typeof schema> extracts the TypeScript type from a Zod schema. Instead of defining your TypeScript interface separately and keeping it in sync with validation logic, you define the Zod schema once and derive the type from it: const userSchema = z.object({ name: z.string() }); type User = z.infer<typeof userSchema>; — User is automatically { name: string }." },
  { question: "What is the difference between z.string().optional() and z.string().nullable()?", answer: "optional() adds undefined to the type (string | undefined) — useful for optional object keys where the key may be absent. nullable() adds null (string | null) — the key exists but its value can be null. .nullish() combines both (string | null | undefined). Use optional() for missing fields and nullable() for explicitly null values." },
  { question: "How do I validate nested objects with Zod?", answer: "Nest z.object() calls: const addressSchema = z.object({ street: z.string(), zip: z.string() }); const userSchema = z.object({ name: z.string(), address: addressSchema }); Zod deeply validates the nested object and infers the full nested TypeScript type automatically." },
  { question: "Can I use this Zod schema on the backend and frontend?", answer: "Yes — Zod is isomorphic (works in Node.js and browsers). A common pattern is to define schemas in a shared package and import them in both your API (for request validation) and your frontend (for form validation). This eliminates duplicated validation logic and keeps types in sync automatically." },
];
---

<BaseLayout
  title="TypeScript to Zod Schema Generator — Free Online Tool"
  description="Paste a TypeScript interface or type and instantly generate the equivalent Zod schema. Supports string, number, boolean, arrays, optional fields, union types, and nested types. Free, runs in your browser."
  tool="TypeScript to Zod, Zod schema generator, Zod object schema, TypeScript validation schema, zod infer"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Zod Schema Generator</h1>
  <p class="text-text-muted mb-4">
    Paste a TypeScript interface or type and get the equivalent Zod schema with <code class="bg-surface px-1 rounded text-sm">z.infer</code> type export.
    Handles strings, numbers, booleans, arrays, optional fields, nullables, and union types.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript → Zod conversion</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Optional & nullable support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Union types & arrays</span>
  </div>
  <ZodSchemaGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Zod Schema Generator" relatedTags={['typescript', 'zod', 'validation', 'schema', 'types']} />
</BaseLayout>
