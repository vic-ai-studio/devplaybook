---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TotpCodeGenerator from '../../components/TotpCodeGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is TOTP and how does it work?", answer: "TOTP (Time-based One-Time Password) is defined in RFC 6238. It combines a shared secret key with the current Unix timestamp (divided into 30-second windows) and runs them through HMAC-SHA1 to produce a 6-digit code. Because both your app and the server share the same secret and use the same clock, they independently generate the same code at the same time." },
  { question: "What is a Base32 secret key?", answer: "When you set up 2FA in an app, the service gives you a secret key encoded in Base32 — the letters A-Z plus digits 2-7. This key is usually shown as a QR code, but most services also show the raw text version for manual entry. It looks like JBSWY3DPEHPK3PXP." },
  { question: "Is this compatible with Google Authenticator?", answer: "Yes. This tool implements the same TOTP algorithm (RFC 6238, HMAC-SHA1, 6 digits, 30-second period) that Google Authenticator, Authy, Microsoft Authenticator, and 1Password TOTP use." },
  { question: "Is my secret key sent anywhere?", answer: "No. All computation happens in your browser using the Web Crypto API (crypto.subtle). Your secret key is never transmitted to any server." },
  { question: "Why does the code change every 30 seconds?", answer: "The code is derived from the current time window (floor(Unix time / 30)). Every 30 seconds, the window advances and a new counter value produces a new code. This time-bound nature means stolen codes become useless almost immediately." },
  { question: "What does the countdown timer show?", answer: "The ring shows how many seconds are left in the current 30-second window. When it reaches 0, the code regenerates automatically. The 'Next code' preview shows what the next code will be so you can avoid entering a code that will expire in 1-2 seconds." },
];
---

<BaseLayout
  title="TOTP Code Generator — Time-Based OTP for 2FA Testing"
  description="Generate TOTP codes from a Base32 secret key. Compatible with Google Authenticator, Authy, and all TOTP-based 2FA apps. Shows countdown timer, next code preview. Runs in browser — secret never leaves your machine."
  tool="TOTP generator, OTP code generator, time-based OTP, 2FA code generator, TOTP test, Google Authenticator TOTP"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "TOTP Code Generator",
    "url": "https://devplaybook.cc/tools/totp-code-generator",
    "description": "Generate TOTP codes from a Base32 secret key. RFC 6238 compliant, compatible with Google Authenticator, Authy, and Microsoft Authenticator.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">TOTP Code Generator</h1>
  <p class="text-text-muted mb-4">
    Enter a Base32 secret key and generate real-time TOTP codes — exactly like Google Authenticator. Shows a live countdown timer, the current 6-digit code, and a preview of the next code. Uses the Web Crypto API (<code class="font-mono bg-surface px-1 rounded text-sm">crypto.subtle</code>) — your secret never leaves your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> RFC 6238 compliant</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live countdown + next code preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Secret stays in browser</span>
  </div>
  <TotpCodeGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="TOTP Code Generator" relatedTags={['security', 'authentication', '2fa', 'otp', 'developer-tools']} />
</BaseLayout>
