---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the difference between bandwidth and throughput?", answer: "Bandwidth is the theoretical maximum data transfer rate of a connection (e.g., 1 Gbps fiber). Throughput is the actual data transferred over time under real-world conditions — always less than bandwidth due to protocol overhead, TCP congestion control, network latency, error correction, and infrastructure limitations. A 100 Mbps connection might achieve 90 Mbps throughput in ideal conditions. For planning, use 70-80% of rated bandwidth as realistic throughput." },
  { question: "What is the difference between Mbps and MBps?", answer: "Mbps = megabits per second (lowercase 'b' = bits). MBps = megabytes per second (uppercase 'B' = bytes). Since 1 byte = 8 bits, 100 Mbps = 12.5 MBps. ISPs advertise in Mbps (100 Mbps sounds faster than 12.5 MBps). File sizes are measured in bytes (MB, GB). To convert ISP speed to file download speed: divide Mbps by 8 to get MBps. A 100 Mbps internet connection downloads a 100 MB file in about 8 seconds (100 MB ÷ 12.5 MBps = 8s)." },
  { question: "How do I calculate file transfer time?", answer: "Transfer time = File size (bits) ÷ Bandwidth (bits per second). Convert file size to bits by multiplying MB by 8,000,000 (using 1 MB = 1,000,000 bytes for SI units). A 1 GB file over 100 Mbps: 1,000 MB × 8 = 8,000 Mb = 8,000,000,000 bits ÷ 100,000,000 bps = 80 seconds. For practical estimates, apply a 70-80% efficiency factor: 80s ÷ 0.75 ≈ 107 seconds. TCP slow start, protocol headers, and network congestion all reduce real throughput." },
  { question: "What bandwidth do I need for video streaming?", answer: "Recommended bandwidth per stream: SD (480p) = 3-5 Mbps, HD (720p) = 5-8 Mbps, Full HD (1080p) = 10-15 Mbps, 4K HDR = 25-50 Mbps. Netflix recommends 15 Mbps for Full HD. For live streaming uploads: SD = 1-3 Mbps, HD = 3-6 Mbps, 4K = 15-25 Mbps. For video conferencing: standard = 1 Mbps, HD = 2.5 Mbps, 4K = 15 Mbps per participant. For a household with multiple simultaneous streams, add bandwidths and double for headroom." },
];
---

<BaseLayout
  title="Bandwidth Calculator — File Transfer Time and Speed Converter"
  description="Calculate file transfer time from bandwidth and file size. Convert between Mbps, Gbps, MB/s, and GB/s. Estimate download and upload times."
  tool="bandwidth calculator, file transfer time, Mbps to MBps, download time calculator, network speed calculator, bits bytes converter"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Bandwidth Calculator — File Transfer Time and Speed Converter",
    "url": "https://devplaybook.cc/tools/bandwidth-calculator",
    "description": "Calculate file transfer time from bandwidth. Convert between Mbps, Gbps, MB/s, GB/s. Estimate download and upload times.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Bandwidth Calculator</h1>
  <p class="text-text-muted mb-6">
    Calculate <strong>file transfer time</strong> from bandwidth and file size. Convert between network
    speed units. Estimate how long a download or upload will take.
  </p>

  <div class="grid md:grid-cols-2 gap-6 mb-6">
    <!-- Transfer Time Calculator -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h3 class="font-semibold mb-4">File Transfer Time</h3>
      <div class="space-y-3">
        <div class="flex gap-2 items-center">
          <label class="text-sm w-24 text-text-muted">File size</label>
          <input type="number" id="fileSize" value="1" min="0" class="flex-1 bg-bg-card border border-border rounded-lg px-3 py-1.5 text-sm" />
          <select id="fileSizeUnit" class="bg-bg-card border border-border rounded-lg px-2 py-1.5 text-sm">
            <option value="8e6">MB</option>
            <option value="8e9" selected>GB</option>
            <option value="8e12">TB</option>
          </select>
        </div>
        <div class="flex gap-2 items-center">
          <label class="text-sm w-24 text-text-muted">Bandwidth</label>
          <input type="number" id="bandwidth" value="100" min="0" class="flex-1 bg-bg-card border border-border rounded-lg px-3 py-1.5 text-sm" />
          <select id="bandwidthUnit" class="bg-bg-card border border-border rounded-lg px-2 py-1.5 text-sm">
            <option value="1e6">Mbps</option>
            <option value="1e9">Gbps</option>
            <option value="8e6">MB/s</option>
            <option value="8e9">GB/s</option>
          </select>
        </div>
        <div class="flex gap-2 items-center">
          <label class="text-sm w-24 text-text-muted">Efficiency</label>
          <input type="range" id="efficiency" min="10" max="100" value="75" class="flex-1 accent-primary" />
          <span id="efficiencyLabel" class="text-sm w-12 text-right">75%</span>
        </div>
      </div>
      <div id="transferResult" class="mt-4 grid grid-cols-2 gap-3"></div>
    </div>

    <!-- Speed Converter -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h3 class="font-semibold mb-4">Speed Unit Converter</h3>
      <div class="flex gap-2 mb-4">
        <input type="number" id="speedInput" value="100" class="flex-1 bg-bg-card border border-border rounded-lg px-3 py-1.5 text-sm" />
        <select id="speedInputUnit" class="bg-bg-card border border-border rounded-lg px-2 py-1.5 text-sm">
          <option>bps</option>
          <option>Kbps</option>
          <option selected>Mbps</option>
          <option>Gbps</option>
          <option>Tbps</option>
          <option>B/s</option>
          <option>KB/s</option>
          <option>MB/s</option>
          <option>GB/s</option>
        </select>
      </div>
      <div id="speedConversions" class="space-y-1.5 text-sm font-mono"></div>
    </div>
  </div>

  <ToolPageCta />
  <FaqSection faqs={faq} />
</BaseLayout>

<script>
const SPEED_TO_BPS: Record<string, number> = {
  'bps': 1, 'Kbps': 1e3, 'Mbps': 1e6, 'Gbps': 1e9, 'Tbps': 1e12,
  'B/s': 8, 'KB/s': 8e3, 'MB/s': 8e6, 'GB/s': 8e9,
};

function fmtTime(seconds: number): string {
  if (!isFinite(seconds) || seconds < 0) return 'N/A';
  if (seconds < 60) return `${seconds.toFixed(1)}s`;
  if (seconds < 3600) return `${Math.floor(seconds/60)}m ${Math.round(seconds%60)}s`;
  if (seconds < 86400) return `${Math.floor(seconds/3600)}h ${Math.floor((seconds%3600)/60)}m`;
  return `${(seconds/86400).toFixed(1)} days`;
}

function fmtBps(bps: number): string {
  if (bps >= 1e12) return `${(bps/1e12).toFixed(2)} Tbps`;
  if (bps >= 1e9) return `${(bps/1e9).toFixed(2)} Gbps`;
  if (bps >= 1e6) return `${(bps/1e6).toFixed(2)} Mbps`;
  if (bps >= 1e3) return `${(bps/1e3).toFixed(2)} Kbps`;
  return `${bps.toFixed(2)} bps`;
}

function updateTransfer() {
  const size = parseFloat((document.getElementById('fileSize') as HTMLInputElement).value);
  const sizeUnit = parseFloat((document.getElementById('fileSizeUnit') as HTMLSelectElement).value);
  const bw = parseFloat((document.getElementById('bandwidth') as HTMLInputElement).value);
  const bwUnit = parseFloat((document.getElementById('bandwidthUnit') as HTMLSelectElement).value);
  const eff = parseInt((document.getElementById('efficiency') as HTMLInputElement).value) / 100;
  (document.getElementById('efficiencyLabel') as HTMLElement).textContent = `${Math.round(eff*100)}%`;

  const fileBits = size * sizeUnit;
  const bwBps = bw * bwUnit;
  const effectiveBps = bwBps * eff;
  const secs = fileBits / effectiveBps;
  const secsIdeal = fileBits / bwBps;

  const el = document.getElementById('transferResult')!;
  el.innerHTML = [
    { label: 'Transfer time', value: fmtTime(secs) },
    { label: 'Ideal time (100%)', value: fmtTime(secsIdeal) },
    { label: 'Effective speed', value: fmtBps(effectiveBps) },
    { label: 'Data (bits)', value: (fileBits/1e9).toFixed(2) + ' Gb' },
  ].map(c => `<div class="bg-bg-card border border-border rounded-xl p-3 text-center"><div class="font-bold text-primary">${c.value}</div><div class="text-xs text-text-muted mt-1">${c.label}</div></div>`).join('');
}

function updateSpeedConv() {
  const val = parseFloat((document.getElementById('speedInput') as HTMLInputElement).value);
  const unit = (document.getElementById('speedInputUnit') as HTMLSelectElement).value;
  const bps = val * SPEED_TO_BPS[unit];
  const el = document.getElementById('speedConversions')!;
  el.innerHTML = Object.entries(SPEED_TO_BPS).map(([u, factor]) => {
    const converted = bps / factor;
    return `<div class="flex justify-between py-0.5 border-b border-border/30"><span class="text-text-muted">${u}</span><span class="${u===unit?'text-primary font-bold':''}">${converted >= 1e10 ? converted.toExponential(3) : converted.toPrecision(6).replace(/\.?0+$/, '')}</span></div>`;
  }).join('');
}

['fileSize','fileSizeUnit','bandwidth','bandwidthUnit','efficiency'].forEach(id => {
  document.getElementById(id)?.addEventListener('input', updateTransfer);
  document.getElementById(id)?.addEventListener('change', updateTransfer);
});
['speedInput','speedInputUnit'].forEach(id => {
  document.getElementById(id)?.addEventListener('input', updateSpeedConv);
  document.getElementById(id)?.addEventListener('change', updateSpeedConv);
});

updateTransfer(); updateSpeedConv();
</script>
