---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CiCdPipelineGenerator from '../../components/CiCdPipelineGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "Which CI/CD platform should I choose?",
    answer: "GitHub Actions is the default choice for projects hosted on GitHub — it's fully integrated, free for public repos, and has thousands of community actions. GitLab CI is best if you're using GitLab or need self-hosted runners with more control. CircleCI offers fast parallelism and caching, useful for large test suites. For most teams on GitHub, GitHub Actions is the simplest path."
  },
  {
    question: "What is the difference between CI and CD?",
    answer: "CI (Continuous Integration) automatically runs tests and builds every time code is pushed or a PR is opened — catching bugs early. CD (Continuous Deployment/Delivery) automatically deploys passing builds to staging or production. Together they create a pipeline: push code → tests run → build → deploy. This generator creates both stages."
  },
  {
    question: "What does 'needs' or 'depends_on' mean in pipelines?",
    answer: "Job dependencies ensure stages run in order. 'needs: test' means the build job only starts after the test job succeeds. This prevents deploying broken builds. In GitLab CI, 'needs' also enables parallel execution — a job can start as soon as its dependencies pass, without waiting for the entire previous stage to complete."
  },
  {
    question: "How do I add secrets like API keys to my pipeline?",
    answer: "Never hardcode secrets in pipeline config. In GitHub Actions, add secrets via Settings → Secrets and reference them as ${{ secrets.MY_SECRET }}. In GitLab CI, use Settings → CI/CD → Variables. In CircleCI, use Project Settings → Environment Variables. All three encrypt secrets at rest and mask them in logs."
  },
  {
    question: "What is a deployment environment and why use one?",
    answer: "Environments (production, staging) add governance to deployments. GitHub Actions environments can require manual approval, restrict which branches can deploy, and track deployment history. This prevents accidental production deploys and gives you an audit trail. Always gate production deploys behind an environment with protection rules."
  },
  {
    question: "How do I speed up my pipeline with caching?",
    answer: "Cache package manager dependencies (node_modules, pip, go mod) between runs. GitHub Actions caches via actions/cache keyed on your lockfile hash — when the lockfile changes, the cache is invalidated. GitLab CI uses 'cache.key' similarly. Docker layer caching (docker_layer_caching in CircleCI, gha cache type in GitHub Actions) dramatically speeds up image builds."
  },
];
---

<BaseLayout
  title="CI/CD Pipeline Generator — GitHub Actions, GitLab CI, CircleCI"
  description="Generate complete CI/CD pipeline YAML for GitHub Actions, GitLab CI, or CircleCI. Choose Node.js, Python, Docker, or Go. Includes test, build, and deploy stages. Free, runs in your browser."
  tool="CI/CD Pipeline Generator, GitHub Actions YAML, GitLab CI config, CircleCI config, DevOps pipeline template"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "CI/CD Pipeline Generator",
    "url": "https://devplaybook.cc/tools/cicd-pipeline-generator",
    "description": "Generate complete CI/CD pipeline configs for GitHub Actions, GitLab CI, and CircleCI. Supports Node.js, Python, Docker, and Go projects.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">CI/CD Pipeline Generator</h1>
  <p class="text-text-muted mb-4">
    Generate a complete CI/CD pipeline config for your project. Select your platform and project type,
    set your branch name, and get production-ready YAML with test, build, and optional deploy stages.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GitHub Actions / GitLab CI / CircleCI</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Node.js / Python / Docker / Go</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Test + Build + Deploy stages</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Caching, artifacts, environments</span>
  </div>
  <CiCdPipelineGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CI/CD Pipeline Generator" relatedTags={['devops', 'cicd', 'github-actions', 'gitlab', 'automation', 'testing']} />
</BaseLayout>
