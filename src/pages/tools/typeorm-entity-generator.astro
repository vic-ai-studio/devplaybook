---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is TypeORM and what databases does it support?", answer: "TypeORM is a TypeScript ORM that supports Active Record and Data Mapper patterns. It works with PostgreSQL, MySQL, MariaDB, SQLite, Microsoft SQL Server, Oracle, MongoDB, and more. It integrates tightly with TypeScript decorators, making entity definitions readable and type-safe. It's commonly used with NestJS." },
  { question: "What is the difference between @PrimaryGeneratedColumn('increment') and @PrimaryGeneratedColumn('uuid')?", answer: "@PrimaryGeneratedColumn('increment') creates an auto-incrementing integer PK (SERIAL in PostgreSQL, AUTO_INCREMENT in MySQL). @PrimaryGeneratedColumn('uuid') generates a UUID v4 as the PK — better for distributed systems where global uniqueness matters. Use integers for simplicity and performance; UUIDs for distributed or external-facing IDs." },
  { question: "What does @CreateDateColumn and @UpdateDateColumn do?", answer: "@CreateDateColumn automatically sets the column to the current timestamp when the entity is first inserted. @UpdateDateColumn automatically updates to the current timestamp on every save/update. Both are stored as TIMESTAMP (or DATETIME in MySQL) and require no manual handling in your application code." },
  { question: "How does @Column with type 'json' work in TypeORM?", answer: "The json type maps to JSON in MySQL and JSONB in PostgreSQL by default. You can store arbitrary JavaScript objects. Use @Column({ type: 'json', nullable: true }) for optional JSON fields. For PostgreSQL-specific JSONB with full indexing support, use @Column({ type: 'jsonb' }) explicitly." },
  { question: "What is the difference between @Entity('table_name') and @Entity()?", answer: "@Entity() without arguments uses the class name (lowercased) as the table name. @Entity('orders') explicitly sets the table name to 'orders'. Best practice is to always set explicit table names to avoid surprises from class renaming. TypeORM also supports schema-qualified names: @Entity({ schema: 'public', name: 'orders' })." }
];
---

<BaseLayout
  title="TypeORM Entity Generator — Generate TypeORM Entity Classes"
  description="Generate TypeORM entity classes with decorators. Add columns with types, nullable, primary, unique, and default values. Copy ready-to-use TypeScript entity code instantly."
  tool="TypeORM entity generator, TypeORM entity class, TypeORM decorators, TypeORM column generator, NestJS entity generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "TypeORM Entity Generator",
    "url": "https://devplaybook.cc/tools/typeorm-entity-generator",
    "description": "Generate TypeORM entity classes with decorators. Add columns and get TypeScript entity code ready to use.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">TypeORM Entity Generator</h1>
  <p class="text-text-muted mb-4">
    Generate TypeORM entity classes with proper decorators. Define your table name, columns, types, and constraints,
    and get production-ready TypeScript entity code with <code class="text-accent">@Entity</code>, <code class="text-accent">@Column</code>, and relation decorators.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> @Entity, @Column decorators</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> @PrimaryGeneratedColumn types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> @CreateDateColumn / @UpdateDateColumn</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> TypeScript types inferred</span>
  </div>

  <!-- Entity config -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-semibold mb-3">Entity Configuration</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      <div>
        <label class="block text-xs text-text-muted mb-1">Class Name</label>
        <input id="class-name" type="text" value="Order" class="w-full bg-surface border border-border rounded px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Table Name</label>
        <input id="table-name" type="text" value="orders" class="w-full bg-surface border border-border rounded px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Primary Key Type</label>
        <select id="pk-type" class="w-full bg-surface border border-border rounded px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="increment">Auto-increment (integer)</option>
          <option value="uuid">UUID</option>
          <option value="none">No generated PK (manual)</option>
        </select>
      </div>
    </div>
    <div class="flex items-center gap-4 mt-3 flex-wrap">
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <input type="checkbox" id="add-timestamps" checked class="rounded" />
        Add @CreateDateColumn &amp; @UpdateDateColumn
      </label>
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <input type="checkbox" id="add-softdelete" class="rounded" />
        Add @DeleteDateColumn (soft delete)
      </label>
    </div>
  </div>

  <!-- Columns -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-sm font-semibold">Custom Columns</h2>
      <button id="add-col" class="px-3 py-1.5 text-xs border border-dashed border-border rounded hover:border-primary transition-colors text-text-muted">+ Add Column</button>
    </div>
    <div class="mb-1 hidden sm:grid gap-2 text-xs text-text-muted font-semibold px-1" style="grid-template-columns:1fr 110px 80px 38px 38px 38px 100px 48px">
      <span>Column Name</span><span>Type</span><span>TS Type</span><span>null</span><span>uniq</span><span>pk</span><span>Default</span><span></span>
    </div>
    <div id="cols-container" class="space-y-2"></div>
  </div>

  <!-- Output -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <div class="flex items-center justify-between mb-2">
      <h2 class="text-sm font-semibold">Generated Entity</h2>
      <button id="copy-entity" class="px-4 py-1.5 bg-primary text-white rounded text-sm font-medium hover:bg-primary/90 transition-colors">Copy</button>
    </div>
    <pre id="entity-output" class="bg-surface rounded p-3 text-xs font-mono text-foreground/90 overflow-x-auto whitespace-pre min-h-[160px]"></pre>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="TypeORM Entity Generator" relatedTags={["typeorm", "typescript", "database", "orm", "nestjs", "postgresql"]} />
</BaseLayout>

<script is:inline>
(function () {
  var COL_TYPES = ["varchar","int","bigint","float","decimal","boolean","text","json","jsonb","uuid","timestamp","date","enum"];
  var TS_TYPE_MAP = {
    varchar:"string",int:"number",bigint:"bigint",float:"number",decimal:"number",
    boolean:"boolean",text:"string",json:"Record<string, unknown>",jsonb:"Record<string, unknown>",
    uuid:"string",timestamp:"Date",date:"Date",enum:"string"
  };

  var cols = [
    { id:uid(), name:"userId", type:"int", nullable:false, unique:false, isPk:false, default:"" },
    { id:uid(), name:"status", type:"varchar", nullable:false, unique:false, isPk:false, default:"'pending'" },
    { id:uid(), name:"total", type:"decimal", nullable:false, unique:false, isPk:false, default:"0" },
    { id:uid(), name:"notes", type:"text", nullable:true, unique:false, isPk:false, default:"" }
  ];

  function uid(){ return Math.random().toString(36).slice(2,9); }
  function esc(s){ return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;"); }
  function findCol(id){ return cols.find(function(c){ return c.id===id; }); }
  function toPascalCase(s){ return s.charAt(0).toUpperCase()+s.slice(1); }

  function hCol(c){
    var typeOpts = COL_TYPES.map(function(t){ return "<option value='"+t+"'"+(c.type===t?" selected":"")+">"+t+"</option>"; }).join("");
    var tsType = TS_TYPE_MAP[c.type] || "string";
    return "<div class='grid gap-1.5 items-center p-2 bg-surface rounded border border-border' style='grid-template-columns:1fr 110px 80px 38px 38px 38px 100px 48px' data-cid='"+c.id+"'>" +
      "<input type='text' value='"+esc(c.name)+"' class='col-name bg-surface border border-border rounded px-2 py-1 text-xs font-mono focus:outline-none focus:border-primary' data-cid='"+c.id+"' />" +
      "<select class='col-type bg-bg-card border border-border rounded px-1 py-1 text-xs focus:outline-none focus:border-primary' data-cid='"+c.id+"'>"+typeOpts+"</select>" +
      "<div class='text-xs text-text-muted font-mono px-1 truncate' id='ts-type-"+c.id+"'>"+tsType+"</div>" +
      "<label class='flex justify-center cursor-pointer'><input type='checkbox' class='col-null' data-cid='"+c.id+"'"+(c.nullable?" checked":"")+" /></label>" +
      "<label class='flex justify-center cursor-pointer'><input type='checkbox' class='col-uniq' data-cid='"+c.id+"'"+(c.unique?" checked":"")+" /></label>" +
      "<label class='flex justify-center cursor-pointer'><input type='checkbox' class='col-pk' data-cid='"+c.id+"'"+(c.isPk?" checked":"")+" /></label>" +
      "<input type='text' value='"+esc(c.default)+"' placeholder='default' class='col-def bg-surface border border-border rounded px-2 py-1 text-xs font-mono focus:outline-none focus:border-primary' data-cid='"+c.id+"' />" +
      "<button class='del-col text-xs text-red-400 border border-border rounded px-1 py-1 hover:text-red-300 transition-colors' data-cid='"+c.id+"'>Del</button>" +
      "</div>";
  }

  function render(){
    document.getElementById("cols-container").innerHTML = cols.map(hCol).join("");
    attach();
    gen();
  }

  function attach(){
    var c = document.getElementById("cols-container");
    c.querySelectorAll(".col-name").forEach(function(el){ el.oninput=function(e){ var col=findCol(e.target.dataset.cid); if(col){col.name=e.target.value; gen();} }; });
    c.querySelectorAll(".col-type").forEach(function(el){ el.onchange=function(e){
      var col=findCol(e.target.dataset.cid); if(!col) return;
      col.type=e.target.value;
      var tsel=document.getElementById("ts-type-"+e.target.dataset.cid);
      if(tsel) tsel.textContent=TS_TYPE_MAP[e.target.value]||"any";
      gen();
    }; });
    c.querySelectorAll(".col-null").forEach(function(el){ el.onchange=function(e){ var col=findCol(e.target.dataset.cid); if(col){col.nullable=e.target.checked; gen();} }; });
    c.querySelectorAll(".col-uniq").forEach(function(el){ el.onchange=function(e){ var col=findCol(e.target.dataset.cid); if(col){col.unique=e.target.checked; gen();} }; });
    c.querySelectorAll(".col-pk").forEach(function(el){ el.onchange=function(e){ var col=findCol(e.target.dataset.cid); if(col){col.isPk=e.target.checked; gen();} }; });
    c.querySelectorAll(".col-def").forEach(function(el){ el.oninput=function(e){ var col=findCol(e.target.dataset.cid); if(col){col.default=e.target.value; gen();} }; });
    c.querySelectorAll(".del-col").forEach(function(el){ el.onclick=function(e){ cols=cols.filter(function(c){ return c.id!==e.target.dataset.cid; }); render(); }; });
  }

  function gen(){
    var className = document.getElementById("class-name").value.trim() || "Entity";
    var tableName = document.getElementById("table-name").value.trim() || "table";
    var pkType = document.getElementById("pk-type").value;
    var addTs = document.getElementById("add-timestamps").checked;
    var addSd = document.getElementById("add-softdelete").checked;

    var imports = ["Entity", "Column"];
    if(pkType === "increment") imports.push("PrimaryGeneratedColumn");
    else if(pkType === "uuid") imports.push("PrimaryGeneratedColumn");
    if(addTs){ imports.push("CreateDateColumn"); imports.push("UpdateDateColumn"); }
    if(addSd) imports.push("DeleteDateColumn");
    var hasPkCol = cols.some(function(c){ return c.isPk; });
    if(hasPkCol) imports = imports.filter(function(i){ return i !== "PrimaryGeneratedColumn"; }).concat(["PrimaryColumn"]);

    var out = 'import { '+imports.join(", ")+' } from "typeorm";\n\n';
    out += '@Entity("'+tableName+'")\n';
    out += 'export class '+toPascalCase(className)+' {\n';

    // PK
    if(pkType === "increment"){
      out += '  @PrimaryGeneratedColumn()\n  id: number;\n\n';
    } else if(pkType === "uuid"){
      out += '  @PrimaryGeneratedColumn("uuid")\n  id: string;\n\n';
    }

    // Custom columns
    cols.forEach(function(col){
      var tsType = TS_TYPE_MAP[col.type] || "string";
      var decOpts = [];
      decOpts.push('type: "'+col.type+'"');
      if(col.nullable) decOpts.push("nullable: true");
      if(col.unique) decOpts.push("unique: true");
      if(col.default !== "") decOpts.push("default: "+col.default);

      if(col.isPk){
        out += '  @PrimaryColumn({ '+decOpts.join(", ")+' })\n';
      } else {
        out += '  @Column({ '+decOpts.join(", ")+' })\n';
      }
      out += '  '+col.name+': '+tsType+(col.nullable?" | null":"")+';\n\n';
    });

    // Timestamps
    if(addTs){
      out += '  @CreateDateColumn()\n  createdAt: Date;\n\n';
      out += '  @UpdateDateColumn()\n  updatedAt: Date;\n\n';
    }
    if(addSd){
      out += '  @DeleteDateColumn()\n  deletedAt: Date | null;\n\n';
    }

    // Trim trailing newline
    out = out.replace(/\n\n$/, "\n") + "}\n";

    document.getElementById("entity-output").textContent = out;
  }

  document.getElementById("add-col").onclick = function(){
    cols.push({ id:uid(), name:"column"+cols.length, type:"varchar", nullable:false, unique:false, isPk:false, default:"" });
    render();
  };
  document.getElementById("copy-entity").onclick = function(){
    navigator.clipboard.writeText(document.getElementById("entity-output").textContent).then(function(){
      var b=document.getElementById("copy-entity"); b.textContent="Copied!"; setTimeout(function(){b.textContent="Copy";},1500);
    });
  };
  document.getElementById("class-name").oninput = gen;
  document.getElementById("table-name").oninput = gen;
  document.getElementById("pk-type").onchange = gen;
  document.getElementById("add-timestamps").onchange = gen;
  document.getElementById("add-softdelete").onchange = gen;
  render();
})();
</script>
