---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OpenApiPathGenerator from '../../components/OpenApiPathGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is an OpenAPI path definition?",
    answer: "An OpenAPI path definition describes a single HTTP endpoint in your API. It lives under the top-level 'paths' key in your openapi.yaml or openapi.json file and specifies the HTTP method (GET, POST, etc.), input parameters, request body schema, and all possible response codes. The OpenAPI 3.x specification is maintained by the OpenAPI Initiative and is the industry standard for describing REST APIs in a language-agnostic way.",
  },
  {
    question: "What is the difference between OpenAPI 3.0 and 3.1?",
    answer: "OpenAPI 3.1 (released 2021) aligns fully with JSON Schema Draft 2020-12, removing several OpenAPI-specific keywords in favour of standard JSON Schema equivalents. Key changes: 'nullable' is replaced by adding 'null' to the 'type' array (e.g. type: [string, null]), 'exclusiveMinimum'/'exclusiveMaximum' are now numeric values, and 'discriminator' works with any schema combiner. Most tooling (Swagger UI, Redoc, code generators) supports both versions. The output from this tool is compatible with both 3.0 and 3.1.",
  },
  {
    question: "What is an operationId and why does it matter?",
    answer: "The operationId is a unique string identifier for an operation across the entire API. It must be unique within the document. It is used by code generators (openapi-generator, swagger-codegen, Kiota) to name the generated client methods — so 'getUser' becomes client.getUser(). A missing or duplicate operationId breaks most code-gen tools. Best practice: use camelCase, follow the pattern verbResource (e.g. listUsers, createOrder, deleteComment).",
  },
  {
    question: "When should I use 'in: path' vs 'in: query' parameters?",
    answer: "Use 'in: path' for resource identifiers that are part of the URL structure, such as /users/{id} or /orders/{orderId}/items/{itemId}. Path parameters are always required. Use 'in: query' for filtering, sorting, pagination, and optional modifiers: /users?role=admin&page=2&limit=20. Use 'in: header' for technical metadata like API versions (X-API-Version), idempotency keys (Idempotency-Key), or correlation IDs. Never put sensitive data like API keys in path or query params — use 'in: header' or a security scheme.",
  },
  {
    question: "How do I reference reusable schemas instead of inlining them?",
    answer: "OpenAPI supports $ref pointers to avoid repeating schemas. Define shared schemas under components/schemas in your openapi.yaml: components:\n  schemas:\n    User:\n      type: object\n      properties:\n        id: { type: string }\nThen reference them anywhere: $ref: '#/components/schemas/User'. This tool generates inline schemas for quick starts — for production APIs, extract schemas to components/schemas and replace inline definitions with $refs.",
  },
  {
    question: "How do I validate my OpenAPI document?",
    answer: "Several free tools can validate your OpenAPI YAML or JSON: (1) Swagger Editor at editor.swagger.io — paste your document for instant feedback. (2) Redocly CLI: npm install -g @redocly/cli && redocly lint openapi.yaml — strict linting with opinionated rules. (3) Spectral by Stoplight: npm install -g @stoplight/spectral-cli — highly configurable rule sets including custom rules. (4) openapi-generator validate — validates before generating client SDKs. For CI/CD, Redocly and Spectral both support config files and exit codes for pipeline gates.",
  },
];
---

<BaseLayout
  title="OpenAPI Path Generator — Generate OpenAPI 3.x Path Definitions"
  description="Generate OpenAPI 3.x path definition YAML or JSON instantly. Define HTTP method, parameters, request body schema, and response codes. Free developer tool — no signup required."
  tool="OpenAPI path generator, OpenAPI 3 YAML generator, Swagger path definition, REST API documentation generator, OpenAPI spec generator, openapi.yaml builder, API path definition tool"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "OpenAPI Path Generator",
    "url": "https://devplaybook.cc/tools/openapi-path-generator",
    "description": "Generate OpenAPI 3.x path definition YAML or JSON instantly. Define HTTP method, path parameters, query params, request body schema, and all response codes. Copy and paste into your openapi.yaml.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">OpenAPI Path Generator</h1>
  <p class="text-text-muted mb-4">
    Build OpenAPI 3.x path definitions in <code class="font-mono bg-surface px-1 rounded text-sm">YAML</code> or <code class="font-mono bg-surface px-1 rounded text-sm">JSON</code> format.
    Configure HTTP method, path and query parameters, request body schema, and response codes —
    then copy directly into your <code class="font-mono bg-surface px-1 rounded text-sm">openapi.yaml</code>.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GET / POST / PUT / PATCH / DELETE</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Path, query, header &amp; cookie params</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Request body with JSON Schema</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Response code toggles</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> YAML &amp; JSON output</span>
  </div>

  <OpenApiPathGenerator client:only="preact" />

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta
    currentTool="OpenAPI Path Generator"
    relatedTags={['api', 'openapi', 'swagger', 'rest', 'developer-tools']}
  />
</BaseLayout>
