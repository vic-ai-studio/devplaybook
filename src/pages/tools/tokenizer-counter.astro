---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TokenizerCounter from '../../components/TokenizerCounter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "How are tokens different from words?",
    answer: "Tokens are sub-word units used by LLM tokenizers. In English, 1 token ≈ 0.75 words, or ~4 characters. Common words are often single tokens ('hello' = 1 token). Rare or long words may split into multiple tokens ('unbelievable' = 3 tokens). Numbers, punctuation, and code have different tokenization patterns — a string like '2024-03-27' may be 4–5 tokens."
  },
  {
    question: "What tokenizer does GPT-4o use?",
    answer: "GPT-4o uses o200k_base, OpenAI's latest tokenizer with a 200K vocabulary (vs 100K for cl100k_base used by GPT-4). The larger vocabulary means fewer tokens for most text. You can test exact counts with OpenAI's tiktoken library: `import tiktoken; enc = tiktoken.get_encoding('o200k_base'); len(enc.encode(text))`."
  },
  {
    question: "What tokenizer does Claude use?",
    answer: "Anthropic uses a custom BPE tokenizer. Claude's token counts are generally similar to GPT-4's cl100k_base but not identical. For exact Claude token counts, use the Anthropic API's token counting endpoint: `client.messages.count_tokens(model='claude-3-5-sonnet-20241022', messages=[...])`. This tool provides estimates accurate to within ~5-10%."
  },
  {
    question: "How does Gemini tokenize text?",
    answer: "Gemini uses SentencePiece tokenization, which produces slightly different token counts than BPE-based models. For exact Gemini token counts, use the Google Generative AI library: `model = genai.GenerativeModel('gemini-1.5-pro'); model.count_tokens('your text')`. SentencePiece tends to be slightly more efficient (fewer tokens) for many languages."
  },
  {
    question: "How do I reduce token count to lower API costs?",
    answer: "Strategies: (1) Remove redundant whitespace and formatting. (2) Use concise instructions — 'Summarize:' vs 'Please provide a comprehensive summary of the following text:'. (3) Avoid repeating context — use references instead of re-pasting text. (4) Use few-shot examples only when necessary. (5) Compress system prompts — they count toward input tokens on every call. (6) For structured data, JSON is more token-efficient than XML."
  },
  {
    question: "What is the cheapest model for long context tasks?",
    answer: "For very long documents (100K+ tokens), Gemini 1.5 Flash is often most cost-effective at $0.075/M input tokens with a 1M token context. For shorter contexts where quality matters, GPT-4o-mini ($0.15/M) and Claude 3.5 Haiku ($0.80/M) are strong choices. Always compare actual token counts × price per million rather than assuming one model is always cheaper."
  },
];
---

<BaseLayout
  title="Tokenizer Counter — Count Tokens for GPT-4o, Claude, Gemini with Cost Estimate"
  description="Count tokens for any text across OpenAI GPT-4o, Claude Sonnet, and Gemini models. See token count, word count, cost estimate, and context window usage. Compare all models side-by-side. Runs in your browser."
  tool="tokenizer counter, token counter, GPT token count, Claude token count, Gemini token count, LLM token calculator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Tokenizer Counter",
    "url": "https://devplaybook.cc/tools/tokenizer-counter",
    "description": "Count tokens for GPT-4o, Claude, and Gemini models with cost estimates and context window usage. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Tokenizer Counter</h1>
  <p class="text-text-muted mb-4">
    Paste any text and instantly see estimated token counts for GPT-4o, Claude Sonnet, Gemini, and 10+ LLMs.
    Check context window usage, compare input costs across models, and plan your API budget.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 11 models compared</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Cost per call</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Context window gauge</span>
  </div>
  <TokenizerCounter client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Tokenizer Counter" relatedTags={['ai', 'llm', 'openai', 'claude', 'gemini', 'api', 'cost']} />
</BaseLayout>
