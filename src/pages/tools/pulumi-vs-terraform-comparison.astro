  .winner-badge.pulumi {
    background: rgba(59, 130, 246, 0.15);
    color: rgb(147, 197, 253);
    border: 1px solid rgba(59, 130, 246, 0.3);
  }
  .winner-badge.terraform {
    background: rgba(168, 85, 247, 0.15);
    color: rgb(216, 180, 254);
    border: 1px solid rgba(168, 85, 247, 0.3);
  }
  .winner-badge.tie {
    background: rgba(107, 114, 128, 0.15);
    color: rgb(209, 213, 219);
    border: 1px solid rgba(107, 114, 128, 0.3);
  }
  .recommender-item:has(.rec-check:checked) {
    border-color: var(--color-primary, #6366f1);
    background: rgba(99, 102, 241, 0.05);
  }
</style>

<script>
  // Category filter
  const filterBtns = document.querySelectorAll('.filter-btn');
  const tableRows = document.querySelectorAll('#table-body tr[data-cat]');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = (btn as HTMLElement).dataset.cat!;
      filterBtns.forEach(b => {
        b.classList.remove('active', 'border-primary', 'bg-primary/10', 'text-primary');
        b.classList.add('border-border');
      });
      btn.classList.add('active', 'border-primary', 'bg-primary/10', 'text-primary');
      btn.classList.remove('border-border');

      tableRows.forEach(row => {
        const el = row as HTMLElement;
        if (cat === 'all' || el.dataset.cat === cat) {
          el.style.display = '';
        } else {
          el.style.display = 'none';
        }
      });
    });
  });

  // Use case recommender
  const checks = document.querySelectorAll('.rec-check');
  const recResult = document.getElementById('rec-result')!;

  function updateRecommender() {
    let pulumiScore = 0;
    let tfScore = 0;
    let anyChecked = false;

    checks.forEach(cb => {
      const input = cb as HTMLInputElement;
      if (input.checked) {
        anyChecked = true;
        pulumiScore += parseInt((input as HTMLElement).dataset.scorePulumi || '0');
        tfScore += parseInt((input as HTMLElement).dataset.scoreTf || '0');
      }
    });

    if (!anyChecked) {
      recResult.classList.add('hidden');
      return;
    }

    recResult.classList.remove('hidden');
    const pulumiEl = document.getElementById('rec-pulumi-score')!;
    const tfEl = document.getElementById('rec-tf-score')!;
    const toolEl = document.getElementById('rec-tool-name')!;
    const scoreLabel = document.getElementById('rec-score-label')!;
    const reasonEl = document.getElementById('rec-reason')!;

    pulumiEl.textContent = String(pulumiScore);
    tfEl.textContent = String(tfScore);

    if (pulumiScore > tfScore) {
      recResult.className = 'rounded-xl p-4 border border-blue-500/30 bg-blue-500/5';
      toolEl.textContent = 'Recommended: Pulumi';
      toolEl.className = 'text-base font-bold text-blue-400';
      scoreLabel.textContent = `(${pulumiScore} vs ${tfScore})`;
      reasonEl.textContent = 'Your team\'s language preference, need for dynamic infrastructure, or desire for built-in testing and drift detection aligns strongly with Pulumi. The upfront learning curve pays off quickly if your team already writes TypeScript or Python.';
    } else if (tfScore > pulumiScore) {
      recResult.className = 'rounded-xl p-4 border border-purple-500/30 bg-purple-500/5';
      toolEl.textContent = 'Recommended: Terraform (or OpenTofu)';
      toolEl.className = 'text-base font-bold text-purple-400';
      scoreLabel.textContent = `(${tfScore} vs ${pulumiScore})`;
      reasonEl.textContent = 'Your existing Terraform investment, ops team preferences, or need for maximum provider/talent availability points to Terraform. Consider OpenTofu if the BSL license is a concern — it\'s a drop-in replacement that stays fully open-source.';
    } else {
      recResult.className = 'rounded-xl p-4 border border-border';
      toolEl.textContent = 'Either tool works';
      toolEl.className = 'text-base font-bold text-text-muted';
      scoreLabel.textContent = `(tied ${pulumiScore}–${tfScore})`;
      reasonEl.textContent = 'Your requirements are equally met by both tools. If starting fresh, Pulumi gives you a more modern developer experience. If migrating an existing team, Terraform\'s familiarity reduces friction. Both are production-mature in 2026.';
    }
  }

  checks.forEach(cb => cb.addEventListener('change', updateRecommender));

  // Code example tabs
  const tabBtns = document.querySelectorAll('.code-tab-btn');
  const codeExamples = document.querySelectorAll('.code-example');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const example = (btn as HTMLElement).dataset.example!;

      tabBtns.forEach(b => {
        b.classList.remove('active', 'border-primary', 'bg-primary/10', 'text-primary');
        b.classList.add('border-border');
      });
      btn.classList.add('active', 'border-primary', 'bg-primary/10', 'text-primary');
      btn.classList.remove('border-border');

      codeExamples.forEach(ex => {
        const el = ex as HTMLElement;
        if (el.dataset.example === example) {
          el.classList.remove('hidden');
        } else {
          el.classList.add('hidden');
        }
      });
    });
  });

  // Copy buttons
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = (btn as HTMLElement).dataset.target!;
      const el = document.getElementById(target);
      if (!el) return;
      const text = el.innerText || el.textContent || '';
      navigator.clipboard.writeText(text).then(() => {
        const orig = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = orig; }, 1500);
      });
    });
  });
</script>
