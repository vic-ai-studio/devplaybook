---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CssGradientGenerator from '../../components/CssGradientGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the difference between linear, radial, and conic gradients?",
    answer: "Linear gradients transition colors along a straight line at a given angle (e.g. top-to-bottom or left-to-right). Radial gradients radiate outward from a center point in a circular or elliptical shape. Conic gradients sweep colors around a center point like a color wheel or pie chart."
  },
  {
    question: "How do I use the generated CSS in my project?",
    answer: "Copy the output and paste it directly into your CSS file or style attribute. For example: .hero { background: linear-gradient(135deg, #6366f1 0%, #ec4899 100%); }. It works in all modern browsers without any prefix."
  },
  {
    question: "Can I add more than two color stops?",
    answer: "Yes — click '+ Add Stop' to insert additional color stops. Each stop has its own color picker and position slider (0–100%). You can remove any stop (minimum 2 required) using the × button."
  },
  {
    question: "What does the angle control do?",
    answer: "For linear gradients, the angle sets the direction of the color transition: 0° is bottom-to-top, 90° is left-to-right, 135° is diagonal (top-left to bottom-right), and 180° is top-to-bottom. For conic gradients, it sets the starting rotation angle of the sweep."
  },
  {
    question: "Does this tool work in all browsers?",
    answer: "Linear and radial gradients are supported in all modern browsers including Chrome, Firefox, Safari, and Edge with no prefixes needed. Conic gradients are supported in Chrome 69+, Firefox 83+, Safari 12.1+, and Edge 79+. All three types have excellent coverage for modern web development."
  },
  {
    question: "Is my data sent to any server?",
    answer: "No. The CSS Gradient Generator runs entirely in your browser using JavaScript. No data is ever sent to any server. You can even use it offline."
  },
];
---

<BaseLayout
  title="CSS Gradient Generator — Free Online Linear, Radial & Conic Builder"
  description="Build CSS gradients visually. Choose linear, radial, or conic type, add color stops, set angle, and copy the ready-to-use CSS. Supports all modern browsers. Runs 100% in your browser — no signup needed."
  tool="CSS Gradient Generator, Linear Gradient CSS, Radial Gradient Generator, Conic Gradient, CSS Background Gradient, Gradient Color Picker"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "CSS Gradient Generator",
    "url": "https://devplaybook.cc/tools/css-gradient-generator",
    "description": "Build linear, radial, and conic CSS gradients visually. Add color stops, adjust angles, and copy the ready-to-use CSS. Runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">CSS Gradient Generator</h1>
  <p class="text-text-muted mb-4">
    Build <strong>linear</strong>, <strong>radial</strong>, and <strong>conic</strong> CSS gradients visually.
    Add color stops, adjust angles, preview live, and copy the ready-to-use CSS.
    No signup, no server — runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Linear, radial & conic types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multiple color stops</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <CssGradientGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CSS Gradient Generator" relatedTags={['css', 'design', 'frontend', 'color']} />
</BaseLayout>
