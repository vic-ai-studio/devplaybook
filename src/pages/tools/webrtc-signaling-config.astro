---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WebRTCSignalingConfig from '../../components/WebRTCSignalingConfig.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is the difference between STUN and TURN servers?",
    answer: "STUN (Session Traversal Utilities for NAT) helps peers discover their public IP address and port, enabling direct peer-to-peer connections in most cases. TURN (Traversal Using Relays around NAT) is a fallback relay server that proxies all traffic when direct connection fails — typically for peers behind symmetric NAT firewalls. STUN is free and low-cost; TURN requires dedicated server infrastructure and bandwidth.",
  },
  {
    question: "Why do I need a TURN server?",
    answer: "About 10–15% of internet users are behind symmetric NAT (common in corporate networks, some ISPs, and mobile carriers). Without a TURN server, these users cannot establish WebRTC connections at all. If you want >95% connection success rate, a TURN server is essential. The iceTransportPolicy:relay option forces all traffic through TURN, useful for privacy-sensitive applications.",
  },
  {
    question: "What is TURNS (TLS)?",
    answer: "TURNS is TURN over TLS, typically on port 443 (same as HTTPS). It allows WebRTC traffic to pass through firewalls that block UDP and non-standard TCP ports. It's slower than plain TURN but works in the most restrictive network environments like corporate proxies.",
  },
  {
    question: "What does bundlePolicy: max-bundle do?",
    answer: "max-bundle combines all media (audio, video, data) into a single ICE candidate pair, reducing port usage and improving NAT traversal. It's the recommended setting for modern WebRTC. max-compat uses separate candidates per media stream for legacy compatibility. balanced is a middle ground.",
  },
  {
    question: "What is iceCandidatePoolSize?",
    answer: "Pre-allocating ICE candidates (pool > 0) starts gathering candidates before the offer/answer exchange, reducing connection setup latency. However, it uses network resources upfront. For low-latency applications like video calls, a pool of 2–5 is recommended. For background file transfer, leave it at 0.",
  },
  {
    question: "Can I use Google's public STUN servers in production?",
    answer: "Google's public STUN servers (stun.l.google.com) are reliable and widely used, but Google makes no SLA guarantees for third-party use. For production applications, especially with thousands of users, consider running your own STUN/TURN infrastructure using Coturn (open source) or services like Twilio, Xirsys, or Cloudflare Calls.",
  },
];
---

<BaseLayout
  title="WebRTC Signaling Config Generator — STUN/TURN ICE Configuration"
  description="Generate WebRTC RTCPeerConnection configuration with STUN/TURN servers, ICE policies, and bundle settings. Output as JavaScript, JSON, or Python. Browser compatibility table included."
  tool="WebRTC Config Generator, STUN TURN Config, ICE Server Generator, RTCPeerConnection Config, WebRTC Setup"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">WebRTC Signaling Config Generator</h1>
  <p class="text-text-muted mb-4">Generate production-ready <code>RTCPeerConnection</code> configuration with STUN/TURN ICE servers, transport policies, and bundle settings. Outputs JavaScript, JSON, or Python. Includes validation and browser compatibility table.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> STUN + TURN + TURNS/TLS</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Relay-only mode</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> JS / JSON / Python output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Config validation</span>
  </div>
  <WebRTCSignalingConfig client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="WebRTC Signaling Config Generator" relatedTags={['webrtc', 'networking', 'javascript', 'video', 'realtime', 'config']} />
</BaseLayout>
