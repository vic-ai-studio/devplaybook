---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ViewTransitionsGenerator from '../../components/ViewTransitionsGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the View Transitions API?", answer: "The View Transitions API lets you create smooth animated transitions between page states or navigations — without JavaScript animation libraries. Call document.startViewTransition() with a callback that updates the DOM, and the browser automatically captures before/after snapshots and animates between them." },
  { question: "What is view-transition-name?", answer: "view-transition-name is a CSS property that tags an element for a 'shared element transition'. Give the same name to an element on two different pages and the browser will morph one into the other — automatically calculating the position, size, and shape change. Perfect for hero images, cards, and navigation transitions." },
  { question: "What are ::view-transition-old and ::view-transition-new?", answer: "These are CSS pseudo-elements the browser creates during a transition. ::view-transition-old represents a snapshot of the element before the change; ::view-transition-new shows the element after. You can apply any CSS animation to them to customize the effect." },
  { question: "Does the View Transitions API work across pages (MPA)?", answer: "Yes! Chrome 126+ supports cross-document (multi-page) view transitions. Add @view-transition { navigation: auto; } to your CSS and transitions happen automatically on navigation — no JavaScript needed for basic use." },
  { question: "What is the fill mode in animations?", answer: "The fill mode controls what happens before/after an animation. 'both' applies the starting keyframe before the animation and holds the end state after — usually what you want for transitions. 'forwards' only holds the end state; 'backwards' applies the start; 'none' reverts after completion." },
];
---

<BaseLayout
  title="View Transitions API Generator — CSS Page Transitions Code"
  description="Generate CSS View Transitions API code for smooth page transitions. Choose fade, slide, zoom, or morph effects. Get ready-to-use CSS keyframes and JavaScript startViewTransition() code with live preview."
  tool="View Transitions API, CSS Page Transitions, startViewTransition, Shared Element Transitions"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">View Transitions API Generator</h1>
  <p class="text-text-muted mb-4">
    Build smooth page transition animations using the CSS View Transitions API.
    Select a transition type, configure timing, and get ready-to-paste CSS keyframes and JavaScript code.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <ViewTransitionsGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="View Transitions API Generator" relatedTags={['css', 'animation', 'transitions', 'frontend', 'browser-api']} />
</BaseLayout>
