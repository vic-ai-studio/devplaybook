---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HttpMockBuilder from '../../components/HttpMockBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is an HTTP mock response?",
    answer: "An HTTP mock response simulates a real API response for testing or development purposes without hitting an actual server. It lets you define the status code, headers, and body so your frontend code or tests can run against predictable, controlled data — no backend dependency needed."
  },
  {
    question: "What is the difference between a fetch mock and an MSW handler?",
    answer: "A fetch mock replaces the global fetch function in a test file with a jest.fn() that returns a pre-configured Response. It's simple and works for unit tests. An MSW (Mock Service Worker) handler intercepts real network requests at the service worker or Node.js level, making it ideal for integration tests with React Testing Library or Playwright — your app code stays unchanged."
  },
  {
    question: "When should I use a curl command for mocking?",
    answer: "The generated curl command is useful for documenting expected API behavior in runbooks or READMEs, testing how your frontend handles specific response shapes via a local proxy, and sharing a reproducible example with teammates. For actual test mocking, prefer the fetch mock or MSW handler."
  },
  {
    question: "How do I mock a 204 No Content response?",
    answer: "Select status 204 from the presets and set the body format to 'empty'. A 204 response should have no body by spec. The generated fetch mock will set body to null and the MSW handler will return new HttpResponse(null, { status: 204 })."
  },
  {
    question: "How do I add authentication headers to the mock?",
    answer: "Use the Custom Headers section to add headers like Authorization: Bearer fake-token, X-API-Key: test-key, or any other header your app reads. These headers are included in the curl command and the fetch/MSW mocks."
  },
  {
    question: "Can I mock non-JSON responses?",
    answer: "Yes. Select 'text', 'html', or 'xml' from the Body Format options and write your body content. The Content-Type header is automatically set to match — text/plain, text/html, or application/xml respectively."
  },
];
---

<BaseLayout
  title="HTTP Mock Response Builder — curl, fetch mock, MSW handler"
  description="Build mock HTTP responses for testing. Set status code, headers, and body — export as curl, Jest fetch mock, or MSW v2 handler. Free, no signup needed."
  tool="HTTP mock builder, fetch mock generator, MSW handler generator, curl mock command, REST API mock, HTTP response builder"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "HTTP Mock Response Builder",
    "url": "https://devplaybook.cc/tools/http-mock-builder",
    "description": "Build mock HTTP responses for testing. Set status code, headers, and body — generate curl commands, Jest fetch mocks, and MSW v2 handlers. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">HTTP Mock Response Builder</h1>
  <p class="text-text-muted mb-4">
    Build mock HTTP responses for testing and docs. Configure status code, headers, and body —
    then export as a <strong>curl command</strong>, <strong>Jest fetch mock</strong>, or <strong>MSW v2 handler</strong>.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 14 status code presets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> curl + fetch + MSW export</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Custom headers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs in your browser</span>
  </div>
  <HttpMockBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="HTTP Mock Response Builder" relatedTags={['testing', 'api', 'mock', 'http', 'msw', 'jest']} />
</BaseLayout>
