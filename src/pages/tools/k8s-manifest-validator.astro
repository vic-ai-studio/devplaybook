---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a Kubernetes manifest?",
    answer: "A Kubernetes manifest is a YAML (or JSON) file that describes the desired state of a Kubernetes resource — such as a Deployment, Service, ConfigMap, or Pod. kubectl apply -f manifest.yaml submits it to the API server, which reconciles the cluster to match that desired state."
  },
  {
    question: "What fields are required in every Kubernetes resource?",
    answer: "Every Kubernetes resource requires four top-level fields: apiVersion (e.g. apps/v1), kind (e.g. Deployment), metadata (which must contain at least name), and usually spec. Missing any of these will cause kubectl apply to reject the manifest."
  },
  {
    question: "Why should containers always have resource limits?",
    answer: "Without resource limits (resources.limits.cpu and resources.limits.memory), a single misbehaving pod can consume all node resources and evict other workloads. The scheduler also cannot make accurate placement decisions. Setting both requests (soft minimum) and limits (hard cap) is a Kubernetes best practice required for QoS guarantees."
  },
  {
    question: "Why is using the :latest image tag bad practice?",
    answer: "The :latest tag is mutable — it can point to a different image each time it's pulled, making deployments non-reproducible. In production, always pin to an immutable digest or a specific semantic version tag (e.g. nginx:1.25.3) to ensure consistent rollouts and easy rollbacks."
  },
  {
    question: "What are liveness and readiness probes?",
    answer: "A readiness probe tells Kubernetes when a container is ready to accept traffic — failing pods are removed from Service endpoints. A liveness probe tells Kubernetes when a container is unhealthy and should be restarted. Without probes, traffic can reach containers that aren't ready, and stuck containers won't be automatically recovered."
  },
  {
    question: "Can I validate multiple resources in one file?",
    answer: "Yes. Kubernetes manifests support multiple resources separated by --- (YAML document separator). This validator handles multi-document YAML, validating each resource independently and showing results grouped by document."
  }
];
---

<BaseLayout
  title="Kubernetes Manifest Validator — Free K8s YAML Checker"
  description="Validate Kubernetes YAML manifests online. Check required fields, security misconfigurations, missing resource limits, image tags, and best practice violations. Free, runs in your browser."
