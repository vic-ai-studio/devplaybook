---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "How do I install and run webpack-bundle-analyzer?", answer: "Install as a dev dependency: `npm install --save-dev webpack-bundle-analyzer`. Then add it to your webpack config plugins array: `new BundleAnalyzerPlugin()`. Run your build with `npm run build` and the analyzer opens a browser with a treemap visualization. For a JSON report without opening a browser, set `analyzerMode: 'json'` and `reportFilename: 'stats.json'`." },
  { question: "What is the difference between stat size, parsed size, and gzip size?", answer: "Stat size is the raw file size before any webpack transformations (minification, tree-shaking). Parsed size is the size after webpack processes the file (minified, dead code removed). Gzip size is the parsed size after gzip compression — this is what users actually download. Always optimize for gzip size since that's the real network cost. Brotli typically gives 10–15% better compression than gzip for text assets." },
  { question: "What should I look for in the bundle analyzer treemap?", answer: "Look for: (1) Large node_modules taking disproportionate space — candidates for code-splitting or replacement with lighter alternatives. (2) Duplicate packages — multiple versions of lodash, React, etc. (3) Dev-only code included in production (test utilities, mock data). (4) Full libraries when only a few functions are used (e.g., importing all of lodash instead of lodash/pick). (5) Locale/i18n files for all languages when only one is needed (moment.js locale bloat)." },
  { question: "How do I reduce my webpack bundle size?", answer: "Key techniques: (1) Code splitting — use dynamic `import()` for routes/features. (2) Tree shaking — use ES modules and set `sideEffects: false` in package.json. (3) Replace heavy libraries — swap moment.js for day.js (66KB vs 2KB), lodash for lodash-es with tree shaking. (4) Lazy-load non-critical components. (5) Configure `optimization.splitChunks` to extract vendor chunks. (6) Use `webpackPrefetch: true` for routes likely to be visited." },
];
---

<BaseLayout
  title="webpack-bundle-analyzer Guide — Visualize & Reduce Bundle Size"
  description="Use webpack-bundle-analyzer to visualize JavaScript bundle composition, find bloat, split code, and reduce your webpack bundle size with practical techniques."
  tool="webpack-bundle-analyzer, webpack, bundle size, code splitting, tree shaking, JavaScript performance"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "webpack-bundle-analyzer Guide",
    "url": "https://devplaybook.cc/tools/webpack-bundle-analyzer",
    "description": "Visualize your webpack bundle and reduce its size with code splitting, tree shaking, and smart library choices.",
  })} />

  <h1 class="text-3xl font-bold mb-2">webpack-bundle-analyzer Guide</h1>
  <p class="text-text-muted mb-6">
    <strong>webpack-bundle-analyzer</strong> generates an interactive treemap of your JavaScript bundle, showing exactly what's inside each chunk. Use it to find bloated dependencies, duplicate packages, and dead code costing your users download time.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Installation & setup</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Reading the treemap</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Bundle reduction techniques</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CI integration</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Installation & Basic Setup</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">npm install --save-dev webpack-bundle-analyzer</pre>

  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// webpack.config.js
const &#123; BundleAnalyzerPlugin &#125; = require('webpack-bundle-analyzer');

module.exports = &#123;
  // ... other config
  plugins: [
    // Opens browser with interactive treemap
    new BundleAnalyzerPlugin(&#123;
      analyzerMode: 'server',       // 'server' | 'static' | 'json' | 'disabled'
      analyzerPort: 8888,
      openAnalyzer: true,
      generateStatsFile: true,      // also write stats.json
      statsFilename: 'stats.json',
    &#125;),
  ],
&#125;;</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">npm Script Integration</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// package.json — only run analyzer when needed
&#123;
  "scripts": &#123;
    "build": "webpack --mode production",
    "build:analyze": "ANALYZE=true webpack --mode production",
    "analyze": "webpack-bundle-analyzer dist/stats.json"
  &#125;
&#125;

// webpack.config.js — conditional plugin
const &#123; BundleAnalyzerPlugin &#125; = require('webpack-bundle-analyzer');

const plugins = [];
if (process.env.ANALYZE) &#123;
  plugins.push(new BundleAnalyzerPlugin());
&#125;</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Size Metrics Explained</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Size Type</th>
          <th class="border border-border px-3 py-2 text-left">What It Measures</th>
          <th class="border border-border px-3 py-2 text-left">Optimize For?</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2">Stat size</td><td class="border border-border px-3 py-2">Raw input file size before webpack processing</td><td class="border border-border px-3 py-2 text-yellow-400">No</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Parsed size</td><td class="border border-border px-3 py-2">After minification and dead code elimination</td><td class="border border-border px-3 py-2 text-yellow-400">Secondary</td></tr>
        <tr><td class="border border-border px-3 py-2">Gzip size</td><td class="border border-border px-3 py-2">Compressed size — what users actually download</td><td class="border border-border px-3 py-2 text-green-400">Primary</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Common Bundle Bloat & Fixes</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Bloat Source</th>
          <th class="border border-border px-3 py-2 text-left">Before</th>
          <th class="border border-border px-3 py-2 text-left">Fix</th>
          <th class="border border-border px-3 py-2 text-left">After</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2">moment.js</td><td class="border border-border px-3 py-2 text-red-400">66KB gzip</td><td class="border border-border px-3 py-2">Switch to day.js</td><td class="border border-border px-3 py-2 text-green-400">2KB gzip</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Full lodash</td><td class="border border-border px-3 py-2 text-red-400">24KB gzip</td><td class="border border-border px-3 py-2">lodash-es + tree shake</td><td class="border border-border px-3 py-2 text-green-400">1–3KB gzip</td></tr>
        <tr><td class="border border-border px-3 py-2">All locales</td><td class="border border-border px-3 py-2 text-red-400">50KB+ gzip</td><td class="border border-border px-3 py-2">ContextReplacementPlugin</td><td class="border border-border px-3 py-2 text-green-400">2KB gzip</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Unsplit routes</td><td class="border border-border px-3 py-2 text-red-400">500KB+ main</td><td class="border border-border px-3 py-2">Dynamic import()</td><td class="border border-border px-3 py-2 text-green-400">50KB main</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Code Splitting with Dynamic Imports</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// Before: static import bundles everything together
import AdminDashboard from './AdminDashboard';

// After: dynamic import creates separate chunk
const AdminDashboard = React.lazy(() => import('./AdminDashboard'));

// Route-level splitting with React Router
const routes = [
  &#123;
    path: '/dashboard',
    component: React.lazy(() => import('./pages/Dashboard')),
  &#125;,
  &#123;
    path: '/admin',
    component: React.lazy(
      () => import(/* webpackChunkName: "admin" */ './pages/Admin')
    ),
  &#125;,
];

// webpack.config.js: vendor chunk splitting
optimization: &#123;
  splitChunks: &#123;
    chunks: 'all',
    cacheGroups: &#123;
      vendor: &#123;
        test: /[\\/]node_modules[\\/]/,
        name: 'vendors',
        priority: 10,
      &#125;,
      react: &#123;
        test: /[\\/]node_modules[\\/](react|react-dom)[\\/]/,
        name: 'react',
        priority: 20,
      &#125;,
    &#125;,
  &#125;,
&#125;</pre>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="webpack-bundle-analyzer" relatedTags={['webpack', 'performance', 'javascript', 'bundle-size', 'code-splitting']} />
</BaseLayout>
