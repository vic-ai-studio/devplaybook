---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ApiRequestBuilder from '../../components/ApiRequestBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import UsageLimitGate from '../../components/UsageLimitGate.tsx';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How do I test an API endpoint with this tool?", answer: "Enter the URL, select the HTTP method (GET, POST, PUT, PATCH, DELETE), add any headers or request body, and click Send. The tool displays the response status, headers, and body in real time. You can also copy the equivalent cURL command." },
  { question: "Is this a Postman alternative?", answer: "For quick, one-off API tests it serves the same purpose — no download or account required. For complex collections, environments, and team collaboration, a full client like Postman or Insomnia is more appropriate." },
  { question: "Does this tool send requests from my browser?", answer: "Yes. Requests are sent directly from your browser using the Fetch API. This means CORS policies of the target server apply. If a server blocks cross-origin requests, you may see a CORS error — use the DevPlaybook CORS Tester tool to diagnose." },
  { question: "Can I send authenticated requests?", answer: "Yes. Add an Authorization header (e.g., Bearer token, Basic auth, or API key) in the headers section. Your credentials stay in your browser and are never stored on our servers." },
  { question: "What is the daily usage limit?", answer: "Free users get 10 API requests per day. DevPlaybook Pro subscribers have unlimited access. The limit resets at midnight UTC." },
];
---

<BaseLayout
  title="API Request Builder — Free Online HTTP Client & cURL Generator"
  description="Build and test HTTP requests visually. Set method, headers, and body — then generate cURL commands instantly. Free online API testing tool — no signup required."
  tool="API Request Builder, HTTP Client, cURL Generator, REST API Tester, API Debugger, HTTP Request Maker, Postman Alternative"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">API Request Builder</h1>
  <p class="text-text-muted mb-4">Build HTTP requests visually — set the URL, method, headers, and body, then send and inspect the response. Generate cURL commands in one click. <span class="text-xs text-text-muted">(Free: 10 uses/day · Pro: unlimited)</span></p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <ApiRequestBuilder client:load />
  <UsageLimitGate toolName="api-request-builder" client:load />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="API Request Builder" relatedTags={['api-testing', 'rest-api', 'postman', 'cheatsheet']} />
</BaseLayout>
