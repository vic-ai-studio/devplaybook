---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ApiRequestBuilder from '../../components/ApiRequestBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout title="API Request Builder" description="Build and test HTTP requests visually. Generate cURL commands. Free online API testing tool." tool="API Request Builder, HTTP Client, cURL Generator">
  <h1 class="text-3xl font-bold mb-2">API Request Builder</h1>
  <p class="text-text-muted mb-8">Build HTTP requests visually, send them, and get cURL commands instantly.</p>
  <ApiRequestBuilder client:load />
  <ToolPageCta currentTool="API Request Builder" relatedTags={['api-testing', 'rest-api', 'postman', 'cheatsheet']} />
</BaseLayout>
