---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ApiRequestBuilder from '../../components/ApiRequestBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import UsageLimitGate from '../../components/UsageLimitGate.tsx';
---

<BaseLayout title="API Request Builder" description="Build and test HTTP requests visually with any method, headers, and body. Generate cURL commands instantly. Free online API testing tool with Pro unlimited access. No signup required." tool="API Request Builder, HTTP Client, cURL Generator, REST API Tester, API Debugger, HTTP Request Maker">
  <h1 class="text-3xl font-bold mb-2">API Request Builder</h1>
  <p class="text-text-muted mb-8">Build HTTP requests visually, send them, and get cURL commands instantly. <span class="text-xs text-text-muted">(Free: 10 uses/day)</span></p>
  <ApiRequestBuilder client:load />
  <UsageLimitGate toolName="api-request-builder" client:load />
  <ToolPageCta currentTool="API Request Builder" relatedTags={['api-testing', 'rest-api', 'postman', 'cheatsheet']} />
</BaseLayout>
