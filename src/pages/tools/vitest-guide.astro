---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is Vitest and how is it different from Jest?", answer: "Vitest is a Vite-native unit testing framework designed to reuse your Vite configuration for both the build pipeline and the test environment. Unlike Jest (which uses Babel/ts-jest and its own module resolver), Vitest uses Vite's esbuild-powered transform, giving near-instant startup times and full native ESM support. The API is intentionally Jest-compatible so migration is straightforward." },
  { question: "Can I use Vitest without Vite in my project?", answer: "Yes. Vitest works without an existing Vite project — it bundles its own Vite instance. However, the real benefit is for projects already using Vite (Vite + React, Vite + Vue, SvelteKit, Nuxt 3, Astro) because Vitest reuses vite.config.ts directly. For pure Node.js projects without Vite, Jest or Node's built-in test runner may be equally suitable." },
  { question: "How does Vitest handle Hot Module Replacement (HMR) in tests?", answer: "Vitest's watch mode uses Vite's HMR graph to understand which test files are affected by a source change. When you edit a file, only the tests that import it (directly or transitively) are re-run. This is dramatically faster than Jest's watch mode which uses a file-system watcher and runs all affected tests via a more conservative dependency scan." },
  { question: "What is in-source testing in Vitest?", answer: "In-source testing lets you write tests inside the same file as your implementation, similar to Rust's #[cfg(test)] pattern. Import and use import.meta.vitest inside an if (import.meta.vitest) block. When building for production, Vitest's Vite plugin strips these blocks via dead-code elimination, so tests never ship to users. This colocation style is great for small utility functions." },
  { question: "Does Vitest support code coverage?", answer: "Yes. Vitest supports V8 coverage (fast, based on Node.js's built-in) and Istanbul coverage (comprehensive, more accurate for branch coverage). Run vitest run --coverage after installing @vitest/coverage-v8 or @vitest/coverage-istanbul. Output formats include text, HTML, LCOV, and JSON — same as Jest's Istanbul integration. Coverage thresholds can be enforced in vitest.config.ts." },
  { question: "How do I migrate from Jest to Vitest?", answer: "For most projects: install vitest, replace jest.config.ts with vitest.config.ts, change test script from 'jest' to 'vitest run'. The API is nearly identical — describe, it, expect, beforeEach, afterEach, vi.fn() (instead of jest.fn()), vi.mock() etc. The main differences are: import from 'vitest' instead of globals, use vi instead of jest namespace, and ensure your vite.config.ts handles path aliases." },
];
---

<BaseLayout
  title="Vitest Guide — Vite-native JavaScript Testing Reference"
  description="Complete Vitest guide covering setup, Jest-compatible API, HMR watch mode, coverage, in-source testing, and migration from Jest. Compare Vitest vs Jest vs Node test runner. Free reference."
  tool="Vitest guide, Vitest vs Jest, Vitest setup, Vitest coverage, Vitest mocking, Vite testing"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Vitest Guide — Vite-native Testing",
    "url": "https://devplaybook.cc/tools/vitest-guide",
    "description": "Complete guide to Vitest — the fast, Vite-native test runner. Covers setup, API, mocking, coverage, in-source testing, and migration from Jest.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Vitest Guide</h1>
  <p class="text-text-muted mb-6">
    The complete reference for <strong>Vitest</strong> — the blazing-fast, Vite-native test runner with a Jest-compatible API. Covers setup, mocking, coverage, HMR watch mode, and in-source testing.
  </p>

  <div class="flex items-center gap-3 mb-8 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Vite-native speed</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Jest-compatible API</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Native ESM support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> In-source testing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> V8 &amp; Istanbul coverage</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Vitest?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Vitest is a next-generation JavaScript testing framework built on top of Vite. Created by the Vite core team, it solves a fundamental problem: test tooling and build tooling used to be completely separate pipelines with different configuration, different module resolution, and different transform stacks. Vitest unifies them — your <code class="bg-bg-card px-1 rounded text-sm">vite.config.ts</code> is automatically reused by the test runner, including plugins, path aliases, and environment variables.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    The result is dramatically faster test startup and a more consistent development experience. Vitest uses esbuild to transform TypeScript and JSX (the same as Vite's dev server), achieving sub-100ms cold starts on most projects. Its Jest-compatible API means most test suites can be migrated with minimal changes, making adoption low-risk.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Installation &amp; Configuration</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Install Vitest
npm install --save-dev vitest

# Install coverage provider
npm install --save-dev @vitest/coverage-v8

# vitest.config.ts (or extend vite.config.ts)
import { defineConfig } from 'vitest/config';

export default defineConfig({
  test: {
    environment: 'jsdom',      // or 'node', 'happy-dom'
    globals: true,             // use describe/it without imports
    setupFiles: ['./tests/setup.ts'],
    coverage: {
      provider: 'v8',
      reporter: ['text', 'html'],
      thresholds: { lines: 80, branches: 70 },
    },
  },
});</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Basic Test Syntax (Jest-compatible)</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// With globals: true — no imports needed
describe('formatCurrency()', () => {
  it('formats USD correctly', () => {
    expect(formatCurrency(1234.5, 'USD')).toBe('$1,234.50');
  });

  it('handles zero', () => {
    expect(formatCurrency(0, 'EUR')).toBe('€0.00');
  });
});

// Without globals (explicit imports)
import { describe, it, expect, vi } from 'vitest';
import { fetchUser } from './api';

describe('fetchUser()', () => {
  it('returns user object', async () => {
    const user = await fetchUser(1);
    expect(user).toMatchObject({ id: 1, name: expect.any(String) });
  });
});</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Mocking with vi (the Jest-equivalent)</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">import { vi, describe, it, expect, beforeEach } from 'vitest';

// Mock a module
vi.mock('./emailService', () => ({
  sendEmail: vi.fn().mockResolvedValue({ success: true }),
}));

// Spy on a method
const warnSpy = vi.spyOn(console, 'warn').mockImplementation(() => {});

// Mock timers
vi.useFakeTimers();

describe('RetryService', () => {
  beforeEach(() => {
    vi.clearAllMocks();
  });

  it('retries 3 times before failing', async () => {
    const mockFn = vi.fn()
      .mockRejectedValueOnce(new Error('fail'))
      .mockRejectedValueOnce(new Error('fail'))
      .mockResolvedValueOnce('success');

    const result = await retryWithBackoff(mockFn);
    expect(result).toBe('success');
    expect(mockFn).toHaveBeenCalledTimes(3);
  });
});</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">In-Source Testing</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Vitest's unique in-source testing feature lets you colocate tests with your implementation code. The <code class="bg-bg-card px-1 rounded text-sm">import.meta.vitest</code> block is stripped from production builds automatically.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// utils/clamp.ts
export function clamp(value: number, min: number, max: number): number {
  return Math.min(Math.max(value, min), max);
}

// In-source tests — stripped in production builds
if (import.meta.vitest) {
  const { it, expect } = import.meta.vitest;

  it('clamps values within range', () => {
    expect(clamp(5, 0, 10)).toBe(5);
    expect(clamp(-5, 0, 10)).toBe(0);
    expect(clamp(15, 0, 10)).toBe(10);
  });
}</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Running Coverage</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Run tests with coverage
npx vitest run --coverage

# Watch mode (re-runs affected tests on change)
npx vitest

# UI mode (browser-based test explorer)
npx vitest --ui</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Vite-native</strong> — reuses your vite.config.ts, plugins, path aliases, and env vars</li>
    <li><strong>HMR watch mode</strong> — only re-runs tests affected by changed modules</li>
    <li><strong>Native ESM</strong> — full ESM support without experimental flags or Babel transforms</li>
    <li><strong>Concurrent test files</strong> — runs files in parallel worker threads by default</li>
    <li><strong>UI mode</strong> — browser-based test explorer with pass/fail visualization</li>
    <li><strong>Snapshot testing</strong> — fully compatible with Jest snapshot format</li>
    <li><strong>TypeScript first</strong> — no separate ts-jest configuration needed</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Comparison: Vitest vs Alternatives</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse mb-6">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">Vitest</th>
          <th class="border border-border px-3 py-2 text-left">Jest</th>
          <th class="border border-border px-3 py-2 text-left">Node test runner</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-border px-3 py-2">Startup speed</td>
          <td class="border border-border px-3 py-2 text-green-400">Very fast (esbuild)</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Moderate (Babel/tsc)</td>
          <td class="border border-border px-3 py-2 text-green-400">Fast (no transform)</td>
        </tr>
        <tr class="bg-bg-card/50">
          <td class="border border-border px-3 py-2">Native ESM</td>
          <td class="border border-border px-3 py-2 text-green-400">Full</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Partial/tricky</td>
          <td class="border border-border px-3 py-2 text-green-400">Full</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">Mocking built-in</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes (vi.*)</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes (jest.*)</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
        </tr>
        <tr class="bg-bg-card/50">
          <td class="border border-border px-3 py-2">Coverage</td>
          <td class="border border-border px-3 py-2 text-green-400">V8 + Istanbul</td>
          <td class="border border-border px-3 py-2 text-green-400">Istanbul</td>
          <td class="border border-border px-3 py-2 text-yellow-400">V8 only</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">Snapshot testing</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
        </tr>
        <tr class="bg-bg-card/50">
          <td class="border border-border px-3 py-2">UI mode</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes (@vitest/ui)</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">Vite plugin reuse</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pros &amp; Cons</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-green-400 mb-2">Pros</h3>
      <ul class="list-disc list-inside text-text-muted space-y-1 text-sm">
        <li>Near-instant startup with esbuild transforms</li>
        <li>Reuses Vite config — zero extra configuration for Vite projects</li>
        <li>Full native ESM without experimental flags</li>
        <li>Jest-compatible API — minimal migration effort</li>
        <li>UI mode for interactive test exploration</li>
        <li>In-source testing for colocation with implementation</li>
      </ul>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-red-400 mb-2">Cons</h3>
      <ul class="list-disc list-inside text-text-muted space-y-1 text-sm">
        <li>Less mature ecosystem than Jest (fewer plugins)</li>
        <li>Some Jest-specific features require workarounds</li>
        <li>Smaller community and fewer Stack Overflow answers</li>
        <li>Best value only for Vite-based projects</li>
        <li>jsdom environment still not a real browser</li>
      </ul>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Vitest Guide" relatedTags={['vitest', 'vite', 'testing', 'javascript', 'developer-tools']} />
</BaseLayout>
