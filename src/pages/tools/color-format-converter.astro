---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What are HEX, RGB, HSL, and HSV color formats?", answer: "HEX is a 6-digit hexadecimal representation of RGB values (#RRGGBB). Each pair of hex digits (00-FF) represents one color channel (red, green, blue) from 0 to 255. RGB (red, green, blue) uses three integer values 0-255 or percentages. HSL (hue, saturation, lightness) is more intuitive for designers: hue is the color wheel angle (0-360°), saturation is color intensity (0-100%), lightness is brightness (0% = black, 100% = white, 50% = pure color). HSV (hue, saturation, value) is similar but value represents brightness differently — used in photo editing software like Photoshop." },
  { question: "How do you convert HEX to RGB?", answer: "Split the 6-digit hex string into three 2-digit pairs and convert each from hexadecimal to decimal: #FF8C00 → R=FF=255, G=8C=140, B=00=0 → rgb(255, 140, 0). In JavaScript: const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16). For 3-digit shorthand (#F80): expand each digit by doubling it (#FF8800) then convert." },
  { question: "How do you convert RGB to HSL?", answer: "Normalize R, G, B to 0-1. Find max and min values. Lightness L = (max+min)/2. If max=min, S=0 and H=0 (achromatic/gray). Otherwise: S = (max-min)/(1-|2L-1|). H depends on which channel is max: if max=R: H = 60 × ((G-B)/(max-min) mod 6), if max=G: H = 60 × ((B-R)/(max-min) + 2), if max=B: H = 60 × ((R-G)/(max-min) + 4). This formula is used in CSS color functions." },
  { question: "What is the difference between HSL and HSV/HSB?", answer: "Both HSL and HSV have the same Hue component. The difference is in the second two: HSL Lightness=50% is a pure color (like noon sun), Lightness=100% is white, Lightness=0% is black. HSV Value=100% is the brightest pure color, Value=0% is black — there is no way to reach white by changing Value alone (you need to reduce Saturation). Photoshop uses HSB (hue, saturation, brightness — same as HSV). CSS uses HSL. For web design, HSL is more intuitive." },
];
---

<BaseLayout
  title="Color Format Converter — HEX, RGB, HSL, HSV Converter"
  description="Convert colors between HEX, RGB, HSL, and HSV formats instantly. Visual color preview with copy-to-clipboard. Includes CSS color values."
  tool="color format converter, HEX to RGB, RGB to HSL, HSL to HSV, CSS color converter, color code converter, HEX RGB HSL"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Color Format Converter — HEX, RGB, HSL, HSV",
    "url": "https://devplaybook.cc/tools/color-format-converter",
    "description": "Convert colors between HEX, RGB, HSL, and HSV formats with visual preview and CSS values.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Color Format Converter</h1>
  <p class="text-text-muted mb-6">
    Convert colors between <strong>HEX</strong>, <strong>RGB</strong>, <strong>HSL</strong>, and
    <strong>HSV</strong> formats. Click any swatch or use the color picker to set the color.
  </p>

  <div class="flex gap-4 items-start mb-6 flex-wrap">
    <div class="flex flex-col items-center gap-2">
      <label class="text-xs text-text-muted">Color picker</label>
      <input type="color" id="colorPicker" value="#3B82F6"
        class="w-16 h-16 rounded-xl border border-border cursor-pointer bg-bg-card" />
    </div>
    <div id="preview" class="w-24 h-16 rounded-xl border border-border flex-shrink-0 mt-5" style="background:#3B82F6"></div>
  </div>

  <div class="grid md:grid-cols-2 gap-4 mb-6">
    <!-- HEX -->
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-semibold">HEX</span>
        <button class="copy-btn text-xs text-primary hover:underline" data-target="hexVal">Copy</button>
      </div>
      <input id="hexVal" type="text" maxlength="7"
        class="w-full font-mono text-lg bg-transparent focus:outline-none focus:ring-1 focus:ring-primary rounded px-1" />
      <div class="text-xs text-text-muted mt-1">3-digit: <span id="hex3"></span></div>
    </div>

    <!-- RGB -->
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-semibold">RGB</span>
        <button class="copy-btn text-xs text-primary hover:underline" data-target="rgbVal">Copy</button>
      </div>
      <input id="rgbVal" type="text" placeholder="rgb(r, g, b)"
        class="w-full font-mono text-sm bg-transparent focus:outline-none focus:ring-1 focus:ring-primary rounded px-1" />
      <div class="text-xs text-text-muted mt-1">CSS: <span id="rgbCss"></span></div>
    </div>

    <!-- HSL -->
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-semibold">HSL</span>
        <button class="copy-btn text-xs text-primary hover:underline" data-target="hslVal">Copy</button>
      </div>
      <input id="hslVal" type="text" placeholder="hsl(h, s%, l%)"
        class="w-full font-mono text-sm bg-transparent focus:outline-none focus:ring-1 focus:ring-primary rounded px-1" />
    </div>

    <!-- HSV -->
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-semibold">HSV / HSB</span>
        <button class="copy-btn text-xs text-primary hover:underline" data-target="hsvVal">Copy</button>
      </div>
      <input id="hsvVal" type="text" placeholder="hsv(h, s%, v%)"
        class="w-full font-mono text-sm bg-transparent focus:outline-none focus:ring-1 focus:ring-primary rounded px-1" />
    </div>
  </div>

  <!-- Shades -->
  <div class="bg-bg-card border border-border rounded-xl p-4 mb-6">
    <h3 class="text-sm font-semibold mb-3">Tints and Shades</h3>
    <div id="shades" class="flex gap-1 flex-wrap"></div>
  </div>

  <ToolPageCta />
  <FaqSection faqs={faq} />
</BaseLayout>

<script>
function hexToRgb(hex: string): [number,number,number]|null {
  hex = hex.replace(/^#/, '');
  if (hex.length === 3) hex = hex.split('').map(c=>c+c).join('');
  if (hex.length !== 6) return null;
  const n = parseInt(hex, 16);
  return [(n>>16)&255, (n>>8)&255, n&255];
}

function rgbToHex(r: number, g: number, b: number): string {
  return '#' + [r,g,b].map(v=>v.toString(16).padStart(2,'0')).join('').toUpperCase();
}

function rgbToHsl(r: number, g: number, b: number): [number,number,number] {
  r/=255; g/=255; b/=255;
  const max=Math.max(r,g,b), min=Math.min(r,g,b);
  let h=0, s=0;
  const l=(max+min)/2;
  if (max!==min) {
    const d=max-min;
    s=l>0.5?d/(2-max-min):d/(max+min);
    switch(max) {
      case r: h=((g-b)/d + (g<b?6:0))/6; break;
      case g: h=((b-r)/d+2)/6; break;
      case b: h=((r-g)/d+4)/6; break;
    }
  }
  return [Math.round(h*360), Math.round(s*100), Math.round(l*100)];
}

function rgbToHsv(r: number, g: number, b: number): [number,number,number] {
  r/=255; g/=255; b/=255;
  const max=Math.max(r,g,b), min=Math.min(r,g,b), d=max-min;
  let h=0;
  const s=max===0?0:d/max, v=max;
  if (d!==0) {
    switch(max) {
      case r: h=((g-b)/d)%6; break;
      case g: h=(b-r)/d+2; break;
      case b: h=(r-g)/d+4; break;
    }
    h=Math.round(h*60); if(h<0)h+=360;
  }
  return [h, Math.round(s*100), Math.round(v*100)];
}

function hslToRgb(h: number, s: number, l: number): [number,number,number] {
  s/=100; l/=100;
  const c=(1-Math.abs(2*l-1))*s, x=c*(1-Math.abs((h/60)%2-1)), m=l-c/2;
  let r=0,g=0,b=0;
  if(h<60){r=c;g=x;}else if(h<120){r=x;g=c;}else if(h<180){g=c;b=x;}
  else if(h<240){g=x;b=c;}else if(h<300){r=x;b=c;}else{r=c;b=x;}
  return [Math.round((r+m)*255), Math.round((g+m)*255), Math.round((b+m)*255)];
}

function updateFromRgb(r: number, g: number, b: number) {
  const hex = rgbToHex(r,g,b);
  const [h3r,h3g,h3b] = [r,g,b].map(v=>Math.round(v/17));
  const h3 = h3r.toString(16)+h3g.toString(16)+h3b.toString(16);
  const [hh,ss,ll] = rgbToHsl(r,g,b);
  const [hv,sv,vv] = rgbToHsv(r,g,b);

  (document.getElementById('colorPicker') as HTMLInputElement).value = hex;
  (document.getElementById('preview') as HTMLElement).style.background = hex;
  (document.getElementById('hexVal') as HTMLInputElement).value = hex;
  (document.getElementById('hex3') as HTMLElement).textContent = '#'+h3.toUpperCase();
  (document.getElementById('rgbVal') as HTMLInputElement).value = `rgb(${r}, ${g}, ${b})`;
  (document.getElementById('rgbCss') as HTMLElement).textContent = `rgba(${r}, ${g}, ${b}, 1)`;
  (document.getElementById('hslVal') as HTMLInputElement).value = `hsl(${hh}, ${ss}%, ${ll}%)`;
  (document.getElementById('hsvVal') as HTMLInputElement).value = `hsv(${hv}, ${sv}%, ${vv}%)`;

  // shades
  const shadesEl = document.getElementById('shades')!;
  const steps = [10,20,30,40,50,60,70,80,90];
  shadesEl.innerHTML = steps.map(lPct => {
    const [sr,sg,sb] = hslToRgb(hh, ss, lPct);
    const c = rgbToHex(sr,sg,sb);
    return `<div title="${c} (L=${lPct}%)" style="background:${c}" class="w-8 h-8 rounded cursor-pointer border border-border/50 hover:scale-110 transition-transform" onclick="document.getElementById('colorPicker').value='${c}';document.getElementById('colorPicker').dispatchEvent(new Event('input'))"></div>`;
  }).join('');
}

document.getElementById('colorPicker')?.addEventListener('input', e => {
  const rgb = hexToRgb((e.target as HTMLInputElement).value);
  if (rgb) updateFromRgb(...rgb);
});

document.getElementById('hexVal')?.addEventListener('change', e => {
  const rgb = hexToRgb((e.target as HTMLInputElement).value);
  if (rgb) updateFromRgb(...rgb);
});

document.getElementById('hslVal')?.addEventListener('change', e => {
  const m = (e.target as HTMLInputElement).value.match(/(\d+)/g);
  if (m && m.length >= 3) updateFromRgb(...hslToRgb(+m[0],+m[1],+m[2]));
});

document.querySelectorAll('.copy-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const id = (btn as HTMLElement).dataset.target!;
    navigator.clipboard.writeText((document.getElementById(id) as HTMLInputElement).value);
    (btn as HTMLElement).textContent = 'Copied!';
    setTimeout(() => (btn as HTMLElement).textContent = 'Copy', 2000);
  });
});

updateFromRgb(59, 130, 246);
</script>
