---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What are Core Web Vitals and why do they affect SEO?", answer: "Core Web Vitals are Google's standardized set of user experience metrics used as ranking signals: LCP (Largest Contentful Paint) measures loading speed, INP (Interaction to Next Paint, replaced FID in 2024) measures responsiveness to user input, and CLS (Cumulative Layout Shift) measures visual stability. Sites with poor Core Web Vitals can be demoted in search rankings. Google uses field data from Chrome User Experience Report (CrUX) — real user measurements — not lab data from Lighthouse." },
  { question: "What is a good LCP score and how do I improve it?", answer: "Good LCP: under 2.5 seconds. Needs improvement: 2.5-4 seconds. Poor: over 4 seconds. The main LCP element is usually a hero image, above-the-fold heading, or large text block. To improve LCP: add fetchpriority='high' to the LCP image, preload critical images with <link rel=preload>, serve images in WebP/AVIF format, use a CDN to reduce server response time, and eliminate render-blocking resources (unused CSS/JS) that delay LCP element rendering." },
  { question: "How do I diagnose and fix Cumulative Layout Shift (CLS)?", answer: "CLS occurs when elements shift position after the page loads. The most common causes are: images without explicit width/height attributes (reserve space by always setting dimensions), ads and embeds that inject content above existing elements, web fonts causing a Flash of Unstyled Text (FOUT) that shifts layout. To debug: open Chrome DevTools > Performance > record a page load and look for Layout Shift entries. Use the Layout Instability API or the Web Vitals Chrome extension to identify which elements shift." },
  { question: "What is INP and how is it different from FID?", answer: "INP (Interaction to Next Paint) replaced FID (First Input Delay) as a Core Web Vital in March 2024. FID measured only the delay before the browser starts processing the first user interaction. INP measures the full duration from user input to the next visual frame across all interactions during the page lifetime — it's a much more complete measure of responsiveness. Good INP: under 200ms. Poor INP: over 500ms. Long tasks on the main thread are the primary INP culprit." },
  { question: "How do I measure real user Core Web Vitals (field data)?", answer: "Use the web-vitals JavaScript library (npm install web-vitals) to collect metrics from real users and send them to your analytics. Call onLCP, onINP, onCLS, onFCP, onTTFB with a callback that sends the metric to your endpoint. Google Search Console shows aggregated field data from CrUX. PageSpeed Insights shows both lab (Lighthouse) and field data. Field data typically differs from Lighthouse because it reflects real devices, real networks, and real user behavior." },
  { question: "Why does my Lighthouse score look good but field data shows poor Core Web Vitals?", answer: "Lab data (Lighthouse) simulates a mid-tier device with throttled network in a controlled environment. Field data comes from real users on real devices across all connection types. Common gaps: your users are on slow mobile devices (Lighthouse uses a Moto G4 simulation), your JS bundle is large and blocks interaction on low-end hardware, third-party scripts (ads, chat widgets, analytics) add significant weight in production but may be absent in local testing, or your CDN cache is warm in tests but cold for new users." },
];
---

<BaseLayout
  title="Core Web Vitals Debugging Guide — LCP, INP, CLS Optimization"
  description="Complete Core Web Vitals debugging guide: LCP optimization, INP/FID improvement, CLS fixes, field vs lab data differences, web-vitals library integration, and DevTools techniques."
  tool="Core Web Vitals, LCP optimization, INP debugging, CLS fix, web performance, Lighthouse, PageSpeed Insights"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Core Web Vitals Debugging Guide",
    "url": "https://devplaybook.cc/tools/web-vitals-debugging-guide",
    "description": "Complete guide to debugging and optimizing LCP, INP, and CLS Core Web Vitals.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Core Web Vitals Debugging Guide</h1>
  <p class="text-text-muted mb-6">
    Debug and optimize <strong>LCP, INP, and CLS</strong> — Google's Core Web Vitals. Covers Chrome DevTools techniques, the web-vitals library, real user monitoring, and the most impactful fixes.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> LCP / INP / CLS</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Chrome DevTools techniques</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Real User Monitoring</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Actionable fixes</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Core Web Vitals Quick Reference</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Metric</th>
          <th class="border border-border px-3 py-2 text-left">Measures</th>
          <th class="border border-border px-3 py-2 text-left">Good</th>
          <th class="border border-border px-3 py-2 text-left">Poor</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2 font-medium">LCP</td><td class="border border-border px-3 py-2">Largest element renders</td><td class="border border-border px-3 py-2 text-green-400">&lt; 2.5s</td><td class="border border-border px-3 py-2 text-red-400">&gt; 4s</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2 font-medium">INP</td><td class="border border-border px-3 py-2">Interaction responsiveness</td><td class="border border-border px-3 py-2 text-green-400">&lt; 200ms</td><td class="border border-border px-3 py-2 text-red-400">&gt; 500ms</td></tr>
        <tr><td class="border border-border px-3 py-2 font-medium">CLS</td><td class="border border-border px-3 py-2">Layout stability</td><td class="border border-border px-3 py-2 text-green-400">&lt; 0.1</td><td class="border border-border px-3 py-2 text-red-400">&gt; 0.25</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2 font-medium">FCP</td><td class="border border-border px-3 py-2">First content paints</td><td class="border border-border px-3 py-2 text-green-400">&lt; 1.8s</td><td class="border border-border px-3 py-2 text-red-400">&gt; 3s</td></tr>
        <tr><td class="border border-border px-3 py-2 font-medium">TTFB</td><td class="border border-border px-3 py-2">Server response time</td><td class="border border-border px-3 py-2 text-green-400">&lt; 800ms</td><td class="border border-border px-3 py-2 text-red-400">&gt; 1.8s</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Measuring Vitals with the web-vitals Library</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">npm install web-vitals</pre>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// vitals.ts — send metrics to your analytics endpoint
import &#123; onLCP, onINP, onCLS, onFCP, onTTFB &#125; from 'web-vitals';

function sendToAnalytics(metric: object) &#123;
  // Send to your backend, Google Analytics, or Datadog
  navigator.sendBeacon('/api/vitals', JSON.stringify(metric));
&#125;

onLCP(sendToAnalytics);
onINP(sendToAnalytics);
onCLS(sendToAnalytics);
onFCP(sendToAnalytics);
onTTFB(sendToAnalytics);

// Next.js: add to app/layout.tsx or pages/_app.tsx
// export &#123; reportWebVitals &#125; from 'next/dist/pages/_app'
// function reportWebVitals(metric) &#123; sendToAnalytics(metric) &#125;</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">LCP Optimization Techniques</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">&lt;!-- 1. Preload the LCP image --&gt;
&lt;link rel="preload" as="image" href="/hero.webp" fetchpriority="high"&gt;

&lt;!-- 2. Mark the LCP image with fetchpriority --&gt;
&lt;img src="/hero.webp" fetchpriority="high" loading="eager" alt="Hero"
     width="1200" height="600"&gt;

&lt;!-- 3. Avoid lazy-loading above-the-fold images --&gt;
&lt;!-- BAD: --&gt;
&lt;img src="/hero.webp" loading="lazy"&gt;  &lt;!-- NEVER lazy-load LCP --&gt;
&lt;!-- GOOD: --&gt;
&lt;img src="/hero.webp" loading="eager" fetchpriority="high"&gt;</pre>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// Next.js Image component — automatically adds fetchpriority="high"
import Image from 'next/image';

&lt;Image
  src="/hero.webp"
  priority    // ← This is the key prop for LCP images
  width=&#123;1200&#125;
  height=&#123;600&#125;
  alt="Hero"
/&gt;</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">INP Optimization — Reducing Long Tasks</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// Identify long tasks in Chrome DevTools:
// Performance tab → record → look for red triangles on tasks > 50ms

// Pattern 1: Break up long synchronous work with scheduler.yield()
async function processLargeList(items: Item[]) &#123;
  for (let i = 0; i &lt; items.length; i++) &#123;
    processItem(items[i]);
    // Yield every 50 items to avoid blocking the main thread
    if (i % 50 === 0) &#123;
      await scheduler.yield();  // releases main thread briefly
    &#125;
  &#125;
&#125;

// Pattern 2: Defer non-critical work
// BAD: blocking third-party script in &lt;head&gt;
&lt;script src="https://analytics.example.com/script.js"&gt;&lt;/script&gt;

// GOOD: defer + async
&lt;script src="https://analytics.example.com/script.js" defer async&gt;&lt;/script&gt;

// Pattern 3: Use web workers for CPU-heavy computation
const worker = new Worker('/workers/heavy-computation.js');
worker.postMessage(&#123; data: largeDataset &#125;);
worker.onmessage = (e) =&gt; setResult(e.data.result);</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">CLS Fixes</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">&lt;!-- Fix 1: Always specify image dimensions --&gt;
&lt;!-- BAD: no dimensions = layout shift when image loads --&gt;
&lt;img src="/photo.jpg" alt="Photo"&gt;
&lt;!-- GOOD: browser reserves space before image loads --&gt;
&lt;img src="/photo.jpg" alt="Photo" width="800" height="600"&gt;

&lt;!-- Fix 2: Reserve space for ads and embeds --&gt;
&lt;div style="min-height: 250px"&gt;
  &lt;!-- ad loads here without shifting content below --&gt;
  &lt;ins class="adsbygoogle" style="display:block" ...&gt;&lt;/ins&gt;
&lt;/div&gt;

/* Fix 3: Font display swap to prevent FOUT layout shift */
@font-face &#123;
  font-family: 'CustomFont';
  src: url('/fonts/custom.woff2');
  font-display: optional;  /* never causes layout shift */
&#125;

/* Fix 4: Aspect ratio container for responsive media */
.video-wrapper &#123;
  aspect-ratio: 16 / 9;  /* reserves correct space before video loads */
&#125;</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">DevTools Workflow</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Performance tab</strong> → Record page load → look for LCP marker, long tasks (red triangles), layout shifts</li>
    <li><strong>Rendering panel</strong> (⋮ menu → More tools) → Enable "Layout Shift Regions" to see shifting elements highlighted in teal</li>
    <li><strong>Network throttling</strong> → Set to "Slow 3G" or "Fast 3G" to simulate real mobile conditions</li>
    <li><strong>Web Vitals Chrome extension</strong> → Overlays LCP element, INP interactions, and CLS contributors in real time</li>
    <li><strong>PageSpeed Insights</strong> → Combines Lighthouse lab data with real CrUX field data for your URL</li>
  </ul>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Core Web Vitals Debugging Guide" relatedTags={['performance', 'web-vitals', 'lcp', 'cls', 'seo']} />
</BaseLayout>
