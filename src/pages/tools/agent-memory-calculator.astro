---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is agent memory in AI systems?", answer: "Agent memory refers to the mechanisms that allow AI agents to retain and access information across interactions. Types include: in-context memory (tokens in the active window), external memory (vector databases, key-value stores), episodic memory (past conversation logs), and semantic memory (distilled knowledge). Each type has different cost and latency characteristics." },
  { question: "How does context window size affect memory planning?", answer: "The context window is the maximum tokens an LLM can process at once. Larger windows allow more in-context memory but increase cost quadratically for attention computation. For agents that need long-term memory, RAG (retrieval-augmented generation) is often more cost-effective than simply expanding context." },
  { question: "What is RAG and how does it help with memory?", answer: "RAG (Retrieval-Augmented Generation) stores information in a vector database and retrieves only the most relevant chunks at inference time. Instead of keeping all knowledge in the context window, you retrieve top-K chunks (typically 3-10). This reduces token costs dramatically while maintaining access to large knowledge bases." },
  { question: "How much does vector database storage cost?", answer: "Most managed vector databases (Pinecone, Weaviate Cloud, Qdrant Cloud) charge per vector stored and per query. A typical 1536-dimension OpenAI embedding costs ~$0.0001/vector to store monthly on Pinecone. 1M documents might cost $50-100/month in storage plus query costs." },
  { question: "What is the right chunk size for RAG memory?", answer: "Chunk size depends on your content and model. Common sizes: 256 tokens (precise retrieval), 512 tokens (balanced), 1024 tokens (more context per chunk). Smaller chunks = more precise but may miss context. Overlap of 10-20% between chunks helps maintain coherence." },
];
---

<BaseLayout
  title="AI Agent Memory Planner — Context Window & RAG Memory Calculator"
  description="Plan AI agent memory architecture. Calculate context window usage, RAG retrieval costs, vector storage needs, and optimal memory strategy for your AI agent system."
  tool="AI Agent Memory Planner, Context Window Calculator, RAG Memory Planner, Vector Database Cost Estimator, Agent Memory Architecture"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">AI Agent Memory Planner</h1>
  <p class="text-text-muted mb-4">Design your AI agent's memory architecture. Calculate context window budgets, RAG storage requirements, and compare in-context vs retrieval-based memory strategies.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Context window budgeter</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> RAG vs in-context comparison</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Vector storage estimator</span>
  </div>

  <!-- Model Selection -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Model & Context Configuration</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Base Model</label>
        <select id="model-select" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="128000">Claude 3.5 Sonnet (200K tokens)</option>
          <option value="200000" selected>Claude 3 Opus (200K tokens)</option>
          <option value="128000">GPT-4o (128K tokens)</option>
          <option value="32000">GPT-4 Turbo (128K tokens)</option>
          <option value="1000000">Gemini 1.5 Pro (1M tokens)</option>
          <option value="8192">Llama 3 8B (8K tokens)</option>
          <option value="32768">Llama 3 70B (32K tokens)</option>
          <option value="32768">Mistral Large (32K tokens)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Context Window (tokens)</label>
        <input id="context-window" type="number" value="200000" min="1000" max="2000000"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Input cost ($/1M tokens)</label>
        <input id="input-cost" type="number" value="3.00" step="0.01" min="0"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
    </div>
  </div>

  <!-- Context Budget Breakdown -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Context Window Budget</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
      <div class="space-y-3">
        <div>
          <label class="block text-sm font-medium mb-1">System Prompt (tokens)</label>
          <input id="sys-prompt-tokens" type="number" value="500" min="0"
            class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Tool Definitions (tokens)</label>
          <input id="tools-tokens" type="number" value="800" min="0"
            class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Conversation History (tokens)</label>
          <input id="history-tokens" type="number" value="2000" min="0"
            class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Retrieved RAG Context (tokens)</label>
          <input id="rag-tokens" type="number" value="3000" min="0"
            class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">User Message (tokens)</label>
          <input id="user-tokens" type="number" value="200" min="0"
            class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Reserved for Output (tokens)</label>
          <input id="output-tokens" type="number" value="2000" min="0"
            class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
      </div>
      <div>
        <div id="budget-chart" class="space-y-2 mb-4"></div>
        <div id="budget-summary" class="bg-bg-card border border-border rounded-lg p-3 text-sm space-y-1"></div>
      </div>
    </div>
  </div>

  <!-- RAG Memory Estimator -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">RAG Vector Storage Estimator</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium mb-1">Total Documents</label>
        <input id="doc-count" type="number" value="10000" min="1"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Avg tokens per chunk</label>
        <input id="chunk-size" type="number" value="512" min="64" max="4096"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Embedding dimensions</label>
        <select id="embed-dims" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="384">384 (all-MiniLM — free)</option>
          <option value="768">768 (BGE-base)</option>
          <option value="1536" selected>1536 (OpenAI text-embedding-3-small)</option>
          <option value="3072">3072 (OpenAI text-embedding-3-large)</option>
        </select>
      </div>
    </div>
    <div id="rag-results" class="grid grid-cols-1 md:grid-cols-3 gap-3"></div>
  </div>

  <!-- Strategy Comparison -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-3">Memory Strategy Comparison</h2>
    <div id="strategy-table" class="overflow-x-auto"></div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="AI Agent Memory Planner" relatedTags={['ai', 'llm', 'agent', 'rag', 'memory', 'vector', 'context']} />
</BaseLayout>

<script>
  const COLORS = ['bg-blue-500', 'bg-purple-500', 'bg-green-500', 'bg-yellow-500', 'bg-red-500', 'bg-orange-500'];

  function getVal(id: string): number {
    return parseFloat((document.getElementById(id) as HTMLInputElement).value) || 0;
  }

  function calculate() {
    const contextWindow = getVal('context-window');
    const sysPrompt = getVal('sys-prompt-tokens');
    const tools = getVal('tools-tokens');
    const history = getVal('history-tokens');
    const rag = getVal('rag-tokens');
    const user = getVal('user-tokens');
    const output = getVal('output-tokens');
    const inputCost = getVal('input-cost');

    const segments = [
      { label: 'System Prompt', tokens: sysPrompt, color: COLORS[0] },
      { label: 'Tool Definitions', tokens: tools, color: COLORS[1] },
      { label: 'History', tokens: history, color: COLORS[2] },
      { label: 'RAG Context', tokens: rag, color: COLORS[3] },
      { label: 'User Message', tokens: user, color: COLORS[4] },
      { label: 'Output Reserved', tokens: output, color: COLORS[5] },
    ];

    const totalUsed = segments.reduce((s, x) => s + x.tokens, 0);
    const remaining = contextWindow - totalUsed;
    const pctUsed = Math.min((totalUsed / contextWindow) * 100, 100);
    const costPerCall = (totalUsed / 1e6) * inputCost;

    // Budget chart
    const chartEl = document.getElementById('budget-chart')!;
    chartEl.innerHTML = segments.map(s => {
      const pct = contextWindow > 0 ? Math.min((s.tokens / contextWindow) * 100, 100) : 0;
      return `<div>
        <div class="flex justify-between text-xs mb-1">
          <span class="text-text-muted">${s.label}</span>
          <span class="font-mono">${s.tokens.toLocaleString()} tok (${pct.toFixed(1)}%)</span>
        </div>
        <div class="w-full bg-bg-card border border-border rounded-full h-2.5">
          <div class="${s.color} h-full rounded-full" style="width:${pct}%"></div>
        </div>
      </div>`;
    }).join('');

    // Summary
    const summaryEl = document.getElementById('budget-summary')!;
    const statusColor = remaining < 0 ? 'text-red-500' : remaining < contextWindow * 0.1 ? 'text-yellow-500' : 'text-green-500';
    summaryEl.innerHTML = `
      <div class="flex justify-between"><span class="text-text-muted">Total used</span><span class="font-mono font-semibold">${totalUsed.toLocaleString()} / ${contextWindow.toLocaleString()} tokens</span></div>
      <div class="flex justify-between"><span class="text-text-muted">Utilization</span><span class="font-mono font-semibold ${pctUsed > 90 ? 'text-red-500' : 'text-green-500'}">${pctUsed.toFixed(1)}%</span></div>
      <div class="flex justify-between"><span class="text-text-muted">Remaining</span><span class="font-mono font-semibold ${statusColor}">${remaining.toLocaleString()} tokens</span></div>
      <div class="flex justify-between pt-1 border-t border-border mt-1"><span class="text-text-muted">Cost / call</span><span class="font-mono font-semibold">$${costPerCall.toFixed(5)}</span></div>
    `;

    // RAG estimation
    const docCount = getVal('doc-count');
    const chunkSize = getVal('chunk-size');
    const dims = getVal('embed-dims');

    const totalChunks = docCount;
    const storageGB = (totalChunks * dims * 4) / (1024 ** 3);
    const embedCostPer1M = dims >= 3072 ? 0.13 : dims >= 1536 ? 0.02 : 0.0;
    const totalEmbedCost = (totalChunks / 1e6) * embedCostPer1M * (chunkSize / 1000);
    const monthlyStorageCost = storageGB * 0.025 * 1024; // ~$25/GB for managed

    const ragEl = document.getElementById('rag-results')!;
    ragEl.innerHTML = [
      { label: 'Total Chunks', value: totalChunks.toLocaleString() },
      { label: 'Storage (vectors)', value: `${storageGB.toFixed(3)} GB` },
      { label: 'Embedding cost', value: `$${totalEmbedCost.toFixed(3)}` },
    ].map(r => `
      <div class="bg-bg-card border border-border rounded-lg p-3 text-center">
        <div class="text-2xl font-bold text-primary mb-1">${r.value}</div>
        <div class="text-xs text-text-muted">${r.label}</div>
      </div>
    `).join('');

    // Strategy comparison
    const callsPerMonth = 10000;
    const inContextCostPerCall = (totalUsed / 1e6) * inputCost;
    const ragContextCostPerCall = ((sysPrompt + tools + user + rag + output) / 1e6) * inputCost;
    const strategies = [
      { name: 'Full in-context', desc: 'Keep all data in context', tokensPer: totalUsed, costPer: inContextCostPerCall },
      { name: 'RAG-augmented', desc: 'Retrieve top-K chunks only', tokensPer: sysPrompt + tools + user + rag + output, costPer: ragContextCostPerCall },
      { name: 'Minimal context', desc: 'System + user only', tokensPer: sysPrompt + user + output, costPer: ((sysPrompt + user + output) / 1e6) * inputCost },
    ];

    const stratEl = document.getElementById('strategy-table')!;
    stratEl.innerHTML = `<table class="w-full text-sm min-w-[500px]">
      <thead><tr class="text-text-muted text-xs uppercase border-b border-border">
        <th class="text-left pb-2 pr-4">Strategy</th>
        <th class="text-right pb-2 pr-4">Tokens/call</th>
        <th class="text-right pb-2 pr-4">Cost/call</th>
        <th class="text-right pb-2">Monthly (${callsPerMonth.toLocaleString()} calls)</th>
      </tr></thead>
      <tbody class="divide-y divide-border">${strategies.map((s, i) => `
        <tr class="${i === 1 ? 'bg-primary/5' : ''}">
          <td class="py-2.5 pr-4"><div class="font-medium">${s.name}</div><div class="text-xs text-text-muted">${s.desc}</div></td>
          <td class="py-2.5 pr-4 text-right font-mono">${s.tokensPer.toLocaleString()}</td>
          <td class="py-2.5 pr-4 text-right font-mono">$${s.costPer.toFixed(5)}</td>
          <td class="py-2.5 text-right font-mono font-semibold ${i === 2 ? 'text-green-500' : ''}">$${(s.costPer * callsPerMonth).toFixed(2)}</td>
        </tr>`).join('')}
      </tbody>
    </table>`;
  }

  document.getElementById('model-select')!.addEventListener('change', function() {
    const map: Record<string, number> = {
      'Claude 3.5 Sonnet (200K tokens)': 200000,
      'Claude 3 Opus (200K tokens)': 200000,
      'GPT-4o (128K tokens)': 128000,
      'GPT-4 Turbo (128K tokens)': 128000,
      'Gemini 1.5 Pro (1M tokens)': 1000000,
      'Llama 3 8B (8K tokens)': 8192,
      'Llama 3 70B (32K tokens)': 32768,
      'Mistral Large (32K tokens)': 32768,
    };
    const sel = this as HTMLSelectElement;
    const ctx = map[sel.options[sel.selectedIndex].text];
    if (ctx) (document.getElementById('context-window') as HTMLInputElement).value = String(ctx);
    calculate();
  });

  document.querySelectorAll('input, select').forEach(el => {
    if (el.id !== 'model-select') el.addEventListener('input', calculate);
  });

  calculate();
</script>
