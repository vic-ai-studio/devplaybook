---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is a PostgreSQL connection string?", answer: "A connection string (or DSN — Data Source Name) encodes all the parameters needed to connect to a PostgreSQL database: host, port, database name, username, password, and optional parameters like SSL mode. Different drivers use different formats: libpq URI (postgresql://), JDBC (jdbc:postgresql://), and key=value (DSN format)." },
  { question: "What is sslmode and which should I use?", answer: "sslmode controls SSL/TLS behavior: 'disable' — no SSL; 'require' — SSL required, no cert verification (vulnerable to MITM); 'verify-ca' — SSL + verify server CA; 'verify-full' — SSL + verify CA + hostname (most secure). Use 'require' for cloud DBs like Neon/Supabase, 'verify-full' for production databases you control." },
  { question: "What is the PostgreSQL default port?", answer: "PostgreSQL uses port 5432 by default. If your database runs on the default port, you can omit it from the connection string. Cloud providers like Neon use 5432, PgBouncer pools often use 6432." },
  { question: "How do I handle special characters in passwords?", answer: "In URI format, special characters in passwords must be percent-encoded. For example, @ becomes %40, # becomes %23, / becomes %2F. In key=value DSN format, single-quote the value and escape single quotes with \\' — no percent-encoding needed. This tool handles encoding automatically." },
];
---

<BaseLayout
  title="PostgreSQL Connection String Builder — pg, JDBC, psycopg2, Prisma"
  description="Build PostgreSQL connection strings for all drivers: libpq URI, JDBC, psycopg2, node-postgres (pg), Prisma, Drizzle, SQLAlchemy. Handles special characters and SSL settings."
  tool="PostgreSQL Connection String Builder, pg Connection URL, JDBC PostgreSQL, psycopg2 DSN"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">PostgreSQL Connection String Builder</h1>
  <p class="text-text-muted mb-4">Generate connection strings for all major PostgreSQL drivers and ORMs. Handles URL encoding and SSL configuration.</p>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
    <!-- Config -->
    <div class="bg-bg-card border border-border rounded-xl p-5 space-y-3">
      <h2 class="text-base font-semibold">Connection Details</h2>
      <div><label class="block text-xs font-medium mb-1">Host</label>
        <input id="pg-host" type="text" value="localhost" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" /></div>
      <div><label class="block text-xs font-medium mb-1">Port</label>
        <input id="pg-port" type="number" value="5432" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" /></div>
      <div><label class="block text-xs font-medium mb-1">Database</label>
        <input id="pg-db" type="text" value="mydb" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" /></div>
      <div><label class="block text-xs font-medium mb-1">Username</label>
        <input id="pg-user" type="text" value="postgres" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" /></div>
      <div><label class="block text-xs font-medium mb-1">Password</label>
        <input id="pg-pass" type="text" value="" placeholder="(leave empty if none)" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" /></div>
      <div><label class="block text-xs font-medium mb-1">SSL Mode</label>
        <select id="pg-ssl" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="">default (not specified)</option>
          <option value="disable">disable</option>
          <option value="require">require (cloud DBs)</option>
          <option value="verify-ca">verify-ca</option>
          <option value="verify-full">verify-full (most secure)</option>
        </select></div>
      <div><label class="block text-xs font-medium mb-1">Connection Timeout (seconds)</label>
        <input id="pg-timeout" type="number" value="" placeholder="(optional)" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" /></div>

      <div class="flex gap-2 pt-1">
        <button id="load-neon" class="text-xs text-text-muted border border-border px-3 py-1.5 rounded-lg hover:bg-bg">Neon.tech preset</button>
        <button id="load-local" class="text-xs text-text-muted border border-border px-3 py-1.5 rounded-lg hover:bg-bg">Local preset</button>
        <button id="load-supabase" class="text-xs text-text-muted border border-border px-3 py-1.5 rounded-lg hover:bg-bg">Supabase preset</button>
      </div>
    </div>

    <!-- Output -->
    <div class="space-y-3">
      {[
        { id: 'out-libpq', label: 'libpq URI (psql, most drivers)', mono: true },
        { id: 'out-jdbc', label: 'JDBC (Java)', mono: true },
        { id: 'out-node', label: 'node-postgres (pg)', mono: false },
        { id: 'out-prisma', label: 'Prisma / Drizzle (DATABASE_URL)', mono: true },
        { id: 'out-sqlalchemy', label: 'SQLAlchemy (Python)', mono: true },
        { id: 'out-psycopg2', label: 'psycopg2 DSN (key=value)', mono: true },
      ].map(item => (
        <div class="bg-bg-card border border-border rounded-xl p-4">
          <div class="flex items-center justify-between mb-1.5">
            <span class="text-xs font-medium text-text-muted">{item.label}</span>
            <button class="copy-btn text-xs text-text-muted border border-border px-2 py-0.5 rounded hover:bg-bg" data-target={item.id}>Copy</button>
          </div>
          <div id={item.id} class="text-xs font-mono bg-bg rounded-lg px-3 py-2 break-all text-text-muted"></div>
        </div>
      ))}
    </div>
  </div>

  <AdUnit slot="in-content" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="PostgreSQL Connection String Builder" relatedTags={['database', 'postgresql', 'backend', 'devtools']} />
</BaseLayout>

<script>
function sv(id: string) { return (document.getElementById(id) as HTMLInputElement)?.value || ''; }
function encode(s: string) { return encodeURIComponent(s); }

function update() {
  const host = sv('pg-host') || 'localhost';
  const port = sv('pg-port') || '5432';
  const db = sv('pg-db') || 'mydb';
  const user = sv('pg-user') || 'postgres';
  const pass = sv('pg-pass');
  const ssl = sv('pg-ssl');
  const timeout = sv('pg-timeout');

  const auth = user ? (pass ? `${encode(user)}:${encode(pass)}@` : `${encode(user)}@`) : '';
  const portStr = port && port !== '5432' ? `:${port}` : ':5432';

  const params: string[] = [];
  if (ssl) params.push(`sslmode=${ssl}`);
  if (timeout) params.push(`connect_timeout=${timeout}`);
  const query = params.length ? '?' + params.join('&') : '';

  // libpq URI
  document.getElementById('out-libpq')!.textContent = `postgresql://${auth}${host}${portStr}/${db}${query}`;

  // JDBC
  const jdbcParams = [...params];
  if (user) jdbcParams.push(`user=${user}`);
  if (pass) jdbcParams.push(`password=${pass}`);
  document.getElementById('out-jdbc')!.textContent = `jdbc:postgresql://${host}:${port}/${db}${jdbcParams.length ? '?' + jdbcParams.join('&') : ''}`;

  // node-postgres (pg) object config
  const pgConfig: Record<string, unknown> = { host, port: parseInt(port) || 5432, database: db, user };
  if (pass) pgConfig.password = pass;
  if (ssl === 'require') pgConfig.ssl = { rejectUnauthorized: false };
  else if (ssl === 'verify-full' || ssl === 'verify-ca') pgConfig.ssl = true;
  if (timeout) pgConfig.connectionTimeoutMillis = parseInt(timeout) * 1000;
  document.getElementById('out-node')!.textContent = JSON.stringify(pgConfig, null, 2);

  // Prisma / Drizzle DATABASE_URL
  document.getElementById('out-prisma')!.textContent = `DATABASE_URL="${`postgresql://${auth}${host}:${port}/${db}${query}`}"`;

  // SQLAlchemy
  const saPass = pass ? `:${encode(pass)}` : '';
  const saUser = user ? `${encode(user)}${saPass}@` : '';
  const saParams = params.length ? '?' + params.join('&') : '';
  document.getElementById('out-sqlalchemy')!.textContent = `postgresql+psycopg2://${saUser}${host}:${port}/${db}${saParams}`;

  // psycopg2 DSN
  const dsn: string[] = [`host=${host}`, `port=${port}`, `dbname=${db}`];
  if (user) dsn.push(`user=${user}`);
  if (pass) dsn.push(`password='${pass.replace(/'/g, "\\'")}'`);
  if (ssl) dsn.push(`sslmode=${ssl}`);
  if (timeout) dsn.push(`connect_timeout=${timeout}`);
  document.getElementById('out-psycopg2')!.textContent = dsn.join(' ');
}

['pg-host','pg-port','pg-db','pg-user','pg-pass','pg-ssl','pg-timeout'].forEach(id => {
  document.getElementById(id)?.addEventListener('input', update);
  document.getElementById(id)?.addEventListener('change', update);
});

function setPreset(host: string, port: string, db: string, user: string, pass: string, ssl: string) {
  (document.getElementById('pg-host') as HTMLInputElement).value = host;
  (document.getElementById('pg-port') as HTMLInputElement).value = port;
  (document.getElementById('pg-db') as HTMLInputElement).value = db;
  (document.getElementById('pg-user') as HTMLInputElement).value = user;
  (document.getElementById('pg-pass') as HTMLInputElement).value = pass;
  (document.getElementById('pg-ssl') as HTMLSelectElement).value = ssl;
  update();
}

document.getElementById('load-neon')!.addEventListener('click', () =>
  setPreset('ep-cool-name-123456.us-east-2.aws.neon.tech', '5432', 'neondb', 'neondb_owner', 'your_password', 'require'));
document.getElementById('load-local')!.addEventListener('click', () =>
  setPreset('localhost', '5432', 'mydb', 'postgres', '', ''));
document.getElementById('load-supabase')!.addEventListener('click', () =>
  setPreset('db.abcdefgh.supabase.co', '5432', 'postgres', 'postgres', 'your_password', 'require'));

document.querySelectorAll('.copy-btn').forEach(btn => {
  btn.addEventListener('click', (e) => {
    const target = (e.currentTarget as HTMLElement).dataset.target!;
    navigator.clipboard.writeText(document.getElementById(target)!.textContent || '');
  });
});

update();
</script>
