---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What models does the Claude API support in 2026?", answer: "Current Claude models: claude-opus-4-6 (most capable), claude-sonnet-4-6 (balanced speed/quality), claude-haiku-4-5-20251001 (fastest/cheapest). Always use full model IDs to avoid unexpected version changes. Claude 3 models (Opus/Sonnet/Haiku 3.x) are still available for backward compatibility." },
  { question: "What is the difference between system prompt and human turn?", answer: "The system prompt sets Claude's behavior, persona, and constraints before the conversation begins. Human/assistant turns represent the actual dialogue. For best results, put instructions, context, and formatting requirements in the system prompt rather than repeating them in each human message." },
  { question: "How does streaming work with the Claude API?", answer: "Set stream: true in your request. The API returns server-sent events (SSE). Each chunk contains a delta with partial text. In Node.js, use the SDK's stream() method; in Python, use with client.messages.stream() as stream. Streaming reduces time-to-first-token significantly for long outputs." },
  { question: "What are tool use (function calling) best practices?", answer: "Define tools with clear names, descriptions, and JSON Schema for parameters. Claude decides when to call tools based on context. For forced tool use, set tool_choice: {type: 'auto'} or {type: 'tool', name: 'tool_name'}. Always handle tool_use stop_reason and inject tool results in the next human turn." },
  { question: "How do I handle rate limits with Claude API?", answer: "Implement exponential backoff on 429 errors. Use the x-ratelimit-* response headers to monitor limits. For high throughput, use batching (Anthropic Batch API) for non-realtime workloads. Enterprise tier has higher limits. Haiku is the best choice for high-volume use cases." },
];
---

<BaseLayout
  title="Claude API Config Builder — Build Anthropic API Request Configs & Snippets"
  description="Generate ready-to-use Anthropic Claude API request configurations. Configure models, system prompts, tools, sampling parameters, and get code in Python, Node.js, or cURL."
  tool="Claude API Config Builder, Anthropic API Request Generator, Claude API Code Generator, Anthropic SDK Config Builder"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Claude API Config Builder</h1>
  <p class="text-text-muted mb-4">Build complete Anthropic Claude API request configurations with all parameters. Generate production-ready code in your preferred language.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All Claude 4.x models</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Tool use / function calling</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Streaming support</span>
  </div>

  <!-- Model & Basic Config -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Model & Basic Settings</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Model</label>
        <select id="model" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <optgroup label="Claude 4.x (2025-2026)">
            <option value="claude-opus-4-6">claude-opus-4-6 (Most capable)</option>
<!--             <option value="claude-sonnet-4-6" selected>claude-sonnet-4-6 (Balanced)</option> -->
            <option value="claude-haiku-4-5-20251001">claude-haiku-4-5-20251001 (Fastest)</option>
          </optgroup>
          <optgroup label="Claude 3.x (Legacy)">
            <option value="claude-3-5-sonnet-20241022">claude-3-5-sonnet-20241022</option>
            <option value="claude-3-opus-20240229">claude-3-opus-20240229</option>
            <option value="claude-3-haiku-20240307">claude-3-haiku-20240307</option>
          </optgroup>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Max Tokens</label>
        <input id="max-tokens" type="number" value="1024" min="1" max="8192"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Language / SDK</label>
        <select id="lang" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="python">Python (anthropic)</option>
          <option value="node" selected>Node.js (@anthropic-ai/sdk)</option>
          <option value="curl">cURL</option>
        </select>
      </div>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-4">
      <div>
        <label class="block text-xs text-text-muted mb-1">Temperature (0-1)</label>
        <input id="temperature" type="number" value="1.0" step="0.1" min="0" max="1"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Top-P</label>
        <input id="top-p" type="number" value="" step="0.05" min="0" max="1" placeholder="optional"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Top-K</label>
        <input id="top-k" type="number" value="" min="1" max="500" placeholder="optional"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div class="flex flex-col justify-end">
        <label class="flex items-center gap-2 cursor-pointer">
          <input id="stream" type="checkbox" class="rounded" />
          <span class="text-sm font-medium">Enable streaming</span>
        </label>
      </div>
    </div>
  </div>

  <!-- System Prompt -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-3">System Prompt</h2>
    <textarea id="system-prompt" rows="4" placeholder="You are a helpful assistant..."
      class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary resize-y font-mono">You are a helpful assistant. Answer questions clearly and concisely.</textarea>
  </div>

  <!-- Messages -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-3">Messages</h2>
    <div id="messages-list" class="space-y-3 mb-3">
      <div class="flex gap-2 items-start message-row">
        <select class="msg-role bg-bg-card border border-border rounded-lg px-2 py-2 text-sm focus:outline-none focus:border-primary shrink-0">
          <option value="user" selected>user</option>
          <option value="assistant">assistant</option>
        </select>
        <textarea class="msg-content flex-1 bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary resize-y font-mono" rows="2" placeholder="Hello, Claude!">Hello, Claude! What can you do?</textarea>
        <button class="remove-msg text-text-muted hover:text-red-400 text-lg leading-none mt-2 px-1">×</button>
      </div>
    </div>
    <button id="add-msg" class="text-xs text-primary hover:underline">+ Add message</button>
  </div>

  <!-- Tool Use -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <div class="flex items-center gap-3 mb-3">
      <h2 class="text-base font-semibold">Tool Use (Function Calling)</h2>
      <label class="flex items-center gap-2 cursor-pointer ml-auto">
        <input id="enable-tools" type="checkbox" class="rounded" />
        <span class="text-sm">Include tools</span>
      </label>
    </div>
    <div id="tools-config" class="hidden space-y-3">
      <div>
        <label class="block text-xs text-text-muted mb-1">Tool Choice</label>
        <select id="tool-choice" class="bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="auto">auto (Claude decides)</option>
          <option value="any">any (must use a tool)</option>
          <option value="none">none (no tool use)</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Tool Definition (JSON)</label>
        <textarea id="tool-json" rows="10"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-primary resize-y font-mono"></textarea>
      </div>
    </div>
  </div>

  <!-- Generated Code -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-base font-semibold">Generated Code</h2>
      <button id="copy-btn" class="text-xs bg-primary/10 hover:bg-primary/20 text-primary px-3 py-1.5 rounded-lg transition-colors">Copy</button>
    </div>
    <pre id="code-output" class="bg-bg-card border border-border rounded-lg p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text leading-relaxed"></pre>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Claude API Config Builder" relatedTags={['ai', 'claude', 'anthropic', 'api', 'llm', 'config']} />
</BaseLayout>

<script>// placeholder</script>
