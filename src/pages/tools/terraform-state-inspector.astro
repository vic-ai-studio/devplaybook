---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TerraformStateInspector from '../../components/TerraformStateInspector.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a Terraform state file?",
    answer: "Terraform state (terraform.tfstate) is a JSON file that maps your configuration's resources to real-world infrastructure objects. It records the IDs, attributes, and dependencies of every resource Terraform manages. Terraform uses the state to determine what changes are needed (plan), what to create/update/destroy (apply), and to track drift between your config and the actual infrastructure."
  },
  {
    question: "What is infrastructure drift in Terraform?",
    answer: "Drift occurs when the actual cloud infrastructure differs from what Terraform's state file records. This happens when resources are changed manually (AWS Console, CLI), by other tools, or by automatic cloud events (auto-scaling, security group updates). Terraform detects drift with 'terraform plan' — if the plan shows unexpected changes, that's drift. Regular 'terraform plan' runs in CI help catch drift early."
  },
  {
    question: "How do I safely inspect a remote Terraform state?",
    answer: "For S3 backends: 'terraform state pull > state.json'. For Terraform Cloud/Enterprise: use the TFC API or 'terraform state pull'. For Azure Blob or GCS backends, use their respective CLI tools. IMPORTANT: state files may contain secrets (database passwords, API keys) in plaintext. Never paste real state files into public online tools. This tool runs 100% in your browser — no data is sent to any server."
  },
  {
    question: "What does the state serial number mean?",
    answer: "The serial is a monotonically increasing integer that Terraform increments on every state modification. It's used to detect concurrent state modifications — if two Terraform runs try to update state simultaneously, the higher serial wins and the lower is rejected. A very high serial (100+) indicates the state has been modified many times, which can happen with aggressive automation or frequent manual interventions."
  },
  {
    question: "What is the difference between managed and data resources in state?",
    answer: "Managed resources (mode: 'managed') are created and controlled by Terraform — it creates, updates, and destroys them. Data sources (mode: 'data') are read-only references to existing infrastructure that Terraform queries but doesn't manage. Data sources are used to look up existing resources (like an AMI ID, VPC ID, or certificate ARN) to use in your managed resources."
  },
  {
    question: "Why are there resources with 0 instances in my state?",
    answer: "Zero-instance resources indicate a resource block exists in your configuration but no actual infrastructure was created. This happens when count = 0, when an optional resource block evaluates to empty, or when a resource has been tainted (marked for recreation). Run 'terraform plan' to see what action Terraform will take on these resources."
  },
];
---

<BaseLayout
  title="Terraform State Inspector — Parse and Analyze tfstate Files Online"
  description="Parse and inspect Terraform state files online. View resource inventory, provider dependencies, module breakdown, and identify structural issues like drift indicators and empty instances. Runs in your browser."
  tool="terraform state inspector, tfstate viewer, terraform state parser, infrastructure drift checker, terraform state online"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Terraform State Inspector",
    "url": "https://devplaybook.cc/tools/terraform-state-inspector",
    "description": "Parse and inspect Terraform state files. View resource inventory, provider dependencies, module breakdown, and identify structural issues. Runs 100% in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Terraform State Inspector</h1>
  <p class="text-text-muted mb-4">
    Parse and inspect Terraform state files to understand your infrastructure inventory.
    View resource counts by type, provider dependencies, module structure, and detect potential
    drift indicators like zero-instance resources.
    Paste your <code class="font-mono text-sm bg-surface px-1 rounded">terraform.tfstate</code> JSON — everything runs in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Resource inventory</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Provider & module breakdown</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Drift indicators</span>
  </div>
  <TerraformStateInspector client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Terraform State Inspector" relatedTags={['terraform', 'iac', 'devops', 'infrastructure', 'cloud', 'aws', 'gcp', 'azure']} />
</BaseLayout>
