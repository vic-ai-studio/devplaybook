---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WebSocketDebugConsole from '../../components/WebSocketDebugConsole.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the WebSocket protocol and how is it different from HTTP?", answer: "WebSocket is a full-duplex communication protocol over a single TCP connection. Unlike HTTP (request-response), WebSocket keeps the connection open, allowing both client and server to send messages at any time with minimal overhead (~2-10 bytes per frame vs ~500-800 bytes of HTTP headers). It starts with an HTTP handshake (the 'Upgrade' request), then upgrades to the WebSocket protocol. Use WebSocket for real-time features: live chat, gaming, collaborative editing, market data feeds, and live notifications." },
  { question: "What is the difference between ws:// and wss://?", answer: "ws:// is unencrypted WebSocket (analogous to HTTP). wss:// is WebSocket Secure — encrypted with TLS (analogous to HTTPS). Always use wss:// in production for security. Modern browsers block mixed content: if your page is served over HTTPS, it will refuse to open ws:// connections. During local development, ws://localhost is allowed even from HTTPS pages in most browsers." },
  { question: "What are ping/pong frames in WebSocket?", answer: "Ping and Pong are control frames built into the WebSocket protocol (RFC 6455). A ping frame can be sent by either party; the recipient must respond with a pong containing the same payload. They serve as a heartbeat to detect dead connections and prevent idle timeout disconnects from proxies. The browser's WebSocket API does not expose ping/pong frames to JavaScript — the browser handles them automatically. Server-side, most libraries expose ping/pong APIs (e.g., ws.ping() in Node.js). This tool sends a JSON ping message as a proxy when in real-server mode." },
  { question: "Why does WebSocket not have CORS the same way HTTP does?", answer: "WebSocket is not subject to the same-origin policy by design — any origin can initiate a WebSocket connection to any server. However, the server receives the Origin header in the HTTP upgrade request and should validate it server-side. Most frameworks check this automatically. This means you can connect to wss://echo.websocket.events from any origin, but production servers should whitelist allowed origins to prevent cross-site WebSocket hijacking (CSWSH)." },
  { question: "What are common WebSocket reconnection strategies?", answer: "1. Exponential backoff: start with 1s delay, double each attempt (2s, 4s, 8s...) with jitter to prevent thundering herd. 2. Max retries: stop after N attempts and show an error to the user. 3. Visibility-aware: pause reconnection when the tab is backgrounded (document.hidden). 4. Online/offline: listen to navigator.onLine and window online/offline events. 5. Close code check: only auto-reconnect on unexpected closes (code !== 1000, 1001). Libraries like reconnecting-websocket implement all of these patterns." },
  { question: "How do I debug WebSocket connections in Chrome DevTools?", answer: "Open DevTools → Network tab → filter by 'WS'. Click a WebSocket connection to see: the Headers tab (handshake request/response), and the Messages tab (all frames with timestamps, direction, and payload). For binary frames, you'll see the raw bytes. You can also use the Console: const ws = new WebSocket('wss://...'); ws.onmessage = e => console.log(e.data);. The Performance panel can show WebSocket frame timing in the network track." },
];
---

<BaseLayout
  title="WebSocket Debug Console — Test WebSocket Connections in Browser"
  description="Test and debug WebSocket connections in your browser. Send messages, view connection state, and inspect traffic. Demo mode available for testing without a live server. Free."
  tool="websocket debug console, websocket tester, ws debugger, websocket client, websocket connection test, wss tester, websocket echo, websocket inspector"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">WebSocket Debug Console</h1>
  <p class="text-text-muted mb-8">Test and debug WebSocket connections in your browser. Send text, binary, and ping messages, inspect traffic with hex view, filter by direction, and auto-reconnect. Use Demo Mode to explore the interface without a live server.</p>
  <WebSocketDebugConsole client:only="preact" />
  <FaqSection faq={faq} />
  <AffiliateSection category={['backend', 'api']} />
  <ToolPageCta currentTool="WebSocket Debug Console" relatedTags={['websocket', 'debugging', 'api', 'real-time', 'developer-tools', 'network']} />
</BaseLayout>
