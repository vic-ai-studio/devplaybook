---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a vector database?", answer: "A vector database stores high-dimensional numerical vectors (embeddings) and enables fast similarity search. Instead of exact keyword matching, it finds semantically similar items using approximate nearest neighbor (ANN) algorithms. Used in RAG pipelines, semantic search, recommendation systems, and image search." },
  { question: "What is HNSW?", answer: "HNSW (Hierarchical Navigable Small World) is the most popular ANN algorithm. It builds a multi-layer graph structure where each layer contains a subset of nodes connected by edges. Search starts at the top (sparse) layer and navigates down to the bottom (dense) layer. It offers excellent recall (>99%) at high query speeds." },
  { question: "What is the difference between Chroma and Pinecone?", answer: "Chroma is open-source and runs locally — perfect for development, local RAG prototypes, and projects where data privacy is critical. Pinecone is fully managed cloud infrastructure — handles scaling, replication, and uptime automatically, but costs money and requires sending data to a third party." },
  { question: "When should I use pgvector instead of a dedicated vector DB?", answer: "Use pgvector when you already have PostgreSQL and your vector collection is under ~1M rows. It avoids running a separate service and supports transactional guarantees between vector data and relational data. For pure vector workloads at scale (10M+ vectors), dedicated systems like Qdrant or Weaviate offer better performance." },
  { question: "Is Faiss a vector database?", answer: "Faiss (Facebook AI Similarity Search) is a library for efficient similarity search, not a database. It doesn't persist data, support metadata filtering, or provide a server — it's an in-memory search engine. Most production systems wrap Faiss for search but use a traditional database for storage and metadata." },
  { question: "What is RAG?", answer: "Retrieval-Augmented Generation — a technique where relevant documents are retrieved from a vector database and injected into an LLM's context window before it generates a response. This allows LLMs to answer questions about documents that weren't in their training data, and reduces hallucination." },
];

const dbs = [
  {
    name: 'Pinecone',
    openSource: false,
    hosted: 'Fully managed (cloud)',
    maxDims: 20000,
    algorithm: 'HNSW, DiskANN',
    filtering: true,
    metadata: true,
    bestFor: 'Production RAG, enterprise scale',
    selfHost: false,
    scale: 'large',
  },
  {
    name: 'Weaviate',
    openSource: true,
    hosted: 'Self-host + Weaviate Cloud',
    maxDims: 65535,
    algorithm: 'HNSW',
    filtering: true,
    metadata: true,
    bestFor: 'Semantic search, GraphQL queries',
    selfHost: true,
    scale: 'large',
  },
  {
    name: 'Chroma',
    openSource: true,
    hosted: 'Self-host only',
    maxDims: 'Unlimited',
    algorithm: 'HNSW (hnswlib)',
    filtering: true,
    metadata: true,
    bestFor: 'Local dev, RAG prototyping',
    selfHost: true,
    scale: 'small',
  },
  {
    name: 'Qdrant',
    openSource: true,
    hosted: 'Self-host + Qdrant Cloud',
    maxDims: 65535,
    algorithm: 'HNSW',
    filtering: true,
    metadata: true,
    bestFor: 'High-perf RAG, Rust-based reliability',
    selfHost: true,
    scale: 'large',
  },
  {
    name: 'Milvus',
    openSource: true,
    hosted: 'Self-host + Zilliz Cloud',
    maxDims: 32768,
    algorithm: 'IVF, HNSW, DiskANN, ANNOY',
    filtering: true,
    metadata: true,
    bestFor: 'Billion-scale vectors, enterprise',
    selfHost: true,
    scale: 'large',
  },
  {
    name: 'pgvector',
    openSource: true,
    hosted: 'Any managed Postgres (Supabase, Neon, RDS)',
    maxDims: 16000,
    algorithm: 'IVFFlat, HNSW',
    filtering: true,
    metadata: true,
    bestFor: 'Existing Postgres stacks, <1M vectors',
    selfHost: true,
    scale: 'medium',
  },
  {
    name: 'Faiss',
    openSource: true,
    hosted: 'Library only (no server)',
    maxDims: 'Unlimited',
    algorithm: 'IVF, HNSW, PQ, LSH',
    filtering: false,
    metadata: false,
    bestFor: 'Research, custom pipelines',
    selfHost: true,
    scale: 'medium',
  },
];
---

<BaseLayout
  title="Vector Database Selector — Pinecone vs Weaviate vs Qdrant vs Chroma"
  description="Compare vector databases: Pinecone, Weaviate, Chroma, Qdrant, Milvus, pgvector, and Faiss. Interactive recommendation quiz finds the best vector DB for your use case."
  tool="Vector Database Comparison, Pinecone vs Weaviate, Best Vector Database, RAG Database Selector, pgvector vs Pinecone"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Vector Database Selector</h1>
  <p class="text-text-muted mb-4">Compare the top vector databases and get a personalized recommendation based on your scale, hosting preference, and use case.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 7 vector databases</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Side-by-side comparison</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 3-question recommendation quiz</span>
  </div>

  <!-- Recommendation Quiz -->
  <div class="bg-bg-card border border-border rounded-xl p-6 mb-8">
    <h2 class="text-lg font-bold mb-1">Find Your Best Match</h2>
    <p class="text-text-muted text-sm mb-5">Answer 3 questions to get a personalized recommendation.</p>

    <div class="space-y-5">
      <div>
        <p class="text-sm font-medium mb-2">1. What scale are you targeting?</p>
        <div class="flex flex-wrap gap-2">
          <button class="quiz-btn active text-xs px-3 py-2 rounded-lg border border-primary text-primary bg-primary/10 transition-all" data-q="scale" data-v="small">Small (&lt;1M vectors)</button>
          <button class="quiz-btn text-xs px-3 py-2 rounded-lg border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-q="scale" data-v="medium">Medium (1M–50M)</button>
          <button class="quiz-btn text-xs px-3 py-2 rounded-lg border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-q="scale" data-v="large">Large (50M+)</button>
        </div>
      </div>

      <div>
        <p class="text-sm font-medium mb-2">2. Hosting preference?</p>
        <div class="flex flex-wrap gap-2">
          <button class="quiz-btn active text-xs px-3 py-2 rounded-lg border border-primary text-primary bg-primary/10 transition-all" data-q="hosting" data-v="self">Self-hosted / local</button>
          <button class="quiz-btn text-xs px-3 py-2 rounded-lg border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-q="hosting" data-v="cloud">Managed cloud</button>
          <button class="quiz-btn text-xs px-3 py-2 rounded-lg border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-q="hosting" data-v="either">Either works</button>
        </div>
      </div>

      <div>
        <p class="text-sm font-medium mb-2">3. Primary use case?</p>
        <div class="flex flex-wrap gap-2">
          <button class="quiz-btn active text-xs px-3 py-2 rounded-lg border border-primary text-primary bg-primary/10 transition-all" data-q="usecase" data-v="rag">RAG / Document Q&A</button>
          <button class="quiz-btn text-xs px-3 py-2 rounded-lg border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-q="usecase" data-v="search">Semantic Search</button>
          <button class="quiz-btn text-xs px-3 py-2 rounded-lg border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-q="usecase" data-v="recommendations">Recommendations</button>
          <button class="quiz-btn text-xs px-3 py-2 rounded-lg border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-q="usecase" data-v="research">Research / Prototyping</button>
        </div>
      </div>
    </div>

    <div id="quiz-result" class="mt-6 p-4 bg-primary/5 border border-primary/30 rounded-lg hidden">
      <p class="text-xs text-text-muted uppercase tracking-wide mb-1">Recommended</p>
      <p id="quiz-rec-name" class="text-xl font-bold text-primary mb-1">—</p>
      <p id="quiz-rec-reason" class="text-sm text-text-muted">—</p>
    </div>
  </div>

  <!-- Comparison table -->
  <h2 class="text-lg font-bold mb-4">Full Comparison Table</h2>
  <div class="overflow-x-auto mb-8">
    <table class="w-full text-sm min-w-[700px]">
      <thead>
        <tr class="text-text-muted text-xs uppercase border-b border-border">
          <th class="text-left pb-3 pr-3 font-medium">Database</th>
          <th class="text-center pb-3 pr-3 font-medium">Open Source</th>
          <th class="text-left pb-3 pr-3 font-medium">Hosting</th>
          <th class="text-right pb-3 pr-3 font-medium">Max Dims</th>
          <th class="text-left pb-3 pr-3 font-medium">Algorithm</th>
          <th class="text-center pb-3 pr-3 font-medium">Filtering</th>
          <th class="text-center pb-3 pr-3 font-medium">Metadata</th>
          <th class="text-left pb-3 font-medium">Best For</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        {dbs.map(db => (
          <tr class="hover:bg-bg-card/50 transition-colors">
            <td class="py-3 pr-3 font-bold">{db.name}</td>
            <td class="py-3 pr-3 text-center">
              {db.openSource
                ? <span class="text-green-500 font-bold">✓</span>
                : <span class="text-xs px-2 py-0.5 bg-yellow-500/10 text-yellow-500 rounded">Proprietary</span>
              }
            </td>
            <td class="py-3 pr-3 text-xs text-text-muted">{db.hosted}</td>
            <td class="py-3 pr-3 text-right tabular-nums font-medium">{typeof db.maxDims === 'number' ? db.maxDims.toLocaleString() : db.maxDims}</td>
            <td class="py-3 pr-3 text-xs text-text-muted">{db.algorithm}</td>
            <td class="py-3 pr-3 text-center">{db.filtering ? <span class="text-green-500">✓</span> : <span class="text-text-muted">—</span>}</td>
            <td class="py-3 pr-3 text-center">{db.metadata ? <span class="text-green-500">✓</span> : <span class="text-text-muted">—</span>}</td>
            <td class="py-3 text-xs text-text-muted">{db.bestFor}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Quick picks -->
  <h2 class="text-lg font-bold mb-4">Quick Picks by Use Case</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <p class="text-xs text-text-muted uppercase tracking-wide mb-1">Local Development / Prototyping</p>
      <p class="font-bold text-primary mb-1">Chroma</p>
      <p class="text-xs text-text-muted">Zero setup, pure Python, in-process. Perfect for Jupyter notebooks and local RAG demos. Switch to Qdrant or Pinecone when moving to production.</p>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <p class="text-xs text-text-muted uppercase tracking-wide mb-1">Production RAG (No-Ops)</p>
      <p class="font-bold text-primary mb-1">Pinecone</p>
      <p class="text-xs text-text-muted">Fully managed, scales automatically. No infrastructure to maintain. Best choice when you want to focus on the app, not the database.</p>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <p class="text-xs text-text-muted uppercase tracking-wide mb-1">Self-Hosted, Production-Ready</p>
      <p class="font-bold text-primary mb-1">Qdrant</p>
      <p class="text-xs text-text-muted">Written in Rust, single binary, Docker-friendly. Excellent performance and reliability. Great REST + gRPC API. Active open-source community.</p>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <p class="text-xs text-text-muted uppercase tracking-wide mb-1">Existing PostgreSQL Stack</p>
      <p class="font-bold text-primary mb-1">pgvector</p>
      <p class="text-xs text-text-muted">Add vector search without a new service. ACID transactions, join vector + relational data. Available on Supabase, Neon, and AWS RDS. Best for &lt;1M vectors.</p>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Vector Database Selector" relatedTags={['ai', 'vector-db', 'rag', 'embeddings', 'pinecone', 'weaviate', 'llm']} />
</BaseLayout>

<script>
  const answers: Record<string, string> = {
    scale: 'small',
    hosting: 'self',
    usecase: 'rag',
  };

  const recommendations: Record<string, { name: string; reason: string }> = {
    'small-self-rag': { name: 'Chroma', reason: 'Perfect for local RAG: zero setup, in-process Python, no server needed. Swap to Qdrant when going to production.' },
    'small-self-search': { name: 'Chroma', reason: 'Great for local semantic search prototyping. Simple API, runs in your Python process, no infra.' },
    'small-self-recommendations': { name: 'pgvector', reason: 'At small scale, adding pgvector to your existing Postgres lets you do recommendations with full transactional support.' },
    'small-self-research': { name: 'Faiss', reason: 'For research and benchmarking, Faiss gives you the most control over ANN algorithms with no server overhead.' },
    'small-cloud-rag': { name: 'Pinecone', reason: 'Managed, scales automatically, excellent SDK. Free tier available. Best for RAG with minimal infrastructure work.' },
    'small-cloud-search': { name: 'Weaviate Cloud', reason: 'Strong semantic search with GraphQL querying. Managed cloud option available.' },
    'small-cloud-recommendations': { name: 'Pinecone', reason: 'Pinecone\'s managed cloud handles recommendations workloads with low operational overhead.' },
    'small-cloud-research': { name: 'Chroma', reason: 'Even for research, Chroma\'s simplicity wins at small scale. No cloud needed.' },
    'small-either-rag': { name: 'Chroma → Qdrant', reason: 'Start with Chroma locally, migrate to Qdrant Cloud or self-hosted when ready for production.' },
    'medium-self-rag': { name: 'Qdrant', reason: 'Rust-based, high-performance, excellent for medium-scale RAG. Self-hosted with Docker, great REST API.' },
    'medium-self-search': { name: 'Weaviate', reason: 'Excellent semantic search with hybrid search (BM25 + vectors), filters, and a rich query language.' },
    'medium-self-recommendations': { name: 'Qdrant', reason: 'Fast payload filtering + vector search makes Qdrant ideal for recommendation systems at medium scale.' },
    'medium-self-research': { name: 'Milvus', reason: 'Milvus supports the widest range of ANN indexes, good for benchmarking different approaches.' },
    'medium-cloud-rag': { name: 'Pinecone', reason: 'Pinecone scales to medium workloads with no ops. Strong performance on RAG benchmarks.' },
    'medium-cloud-search': { name: 'Weaviate Cloud', reason: 'Weaviate Cloud gives you managed Weaviate with hybrid search capabilities.' },
    'medium-cloud-recommendations': { name: 'Pinecone', reason: 'Managed, metadata filtering, and good performance for recommendation retrieval.' },
    'medium-either-rag': { name: 'Qdrant', reason: 'Best balance: open-source, Qdrant Cloud option, excellent performance, growing community.' },
    'large-self-rag': { name: 'Milvus', reason: 'Built for billion-scale vectors. Distributed architecture, supports multiple ANN algorithms, battle-tested in production.' },
    'large-self-search': { name: 'Milvus', reason: 'Handles large-scale semantic search with distributed architecture, GPU support, and multiple index types.' },
    'large-self-recommendations': { name: 'Milvus', reason: 'Billion-scale recommendations are Milvus\'s core use case. Used at scale by Alibaba, ByteDance, and others.' },
    'large-cloud-rag': { name: 'Pinecone', reason: 'Enterprise Pinecone scales to hundreds of millions of vectors with SLA guarantees. No infra management.' },
    'large-cloud-search': { name: 'Weaviate Cloud', reason: 'Weaviate Enterprise handles large-scale semantic search with managed infrastructure.' },
    'large-cloud-recommendations': { name: 'Pinecone', reason: 'Enterprise plan handles large-scale recommendation retrieval with high availability.' },
    'large-either-rag': { name: 'Milvus / Zilliz Cloud', reason: 'Open-source Milvus for self-hosted, or Zilliz Cloud (managed Milvus) for a fully managed option at billion scale.' },
  };

  function getRecommendation() {
    const key = `${answers.scale}-${answers.hosting}-${answers.usecase}`;
    return recommendations[key] || { name: 'Qdrant', reason: 'A solid general-purpose choice: open-source, high-performance, and available as managed cloud or self-hosted.' };
  }

  function updateQuiz() {
    const rec = getRecommendation();
    const resultEl = document.getElementById('quiz-result')!;
    document.getElementById('quiz-rec-name')!.textContent = rec.name;
    document.getElementById('quiz-rec-reason')!.textContent = rec.reason;
    resultEl.classList.remove('hidden');
  }

  document.querySelectorAll('.quiz-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const q = btn.getAttribute('data-q')!;
      const v = btn.getAttribute('data-v')!;
      answers[q] = v;

      // Update active state for this question group
      document.querySelectorAll(`.quiz-btn[data-q="${q}"]`).forEach(b => {
        b.classList.remove('active', 'border-primary', 'text-primary', 'bg-primary/10');
        b.classList.add('border-border', 'text-text-muted');
      });
      btn.classList.add('active', 'border-primary', 'text-primary', 'bg-primary/10');
      btn.classList.remove('border-border', 'text-text-muted');

      updateQuiz();
    });
  });

  updateQuiz();
</script>
