---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RedisConnectionStringBuilder from '../../components/RedisConnectionStringBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the difference between redis:// and rediss://?",
    answer: "redis:// is the standard scheme for unencrypted connections. rediss:// (double-s) enables TLS/SSL encryption. All managed Redis services (Redis Cloud, Upstash, AWS ElastiCache with TLS, Azure Cache for Redis) require rediss:// for encrypted connections."
  },
  {
    question: "What database index should I use?",
    answer: "Redis supports 16 databases (index 0–15) by default. Most applications use database 0. Most managed Redis services (Redis Cloud, Upstash, Heroku Redis) only expose database 0 and ignore the db parameter in connection strings."
  },
  {
    question: "When do I need a username in the connection string?",
    answer: "Username is only required if you're using Redis ACL (Access Control Lists), introduced in Redis 6. ACL allows creating multiple named users with different permission sets. Older Redis instances use password-only authentication where you can omit the username or use 'default'."
  },
  {
    question: "Does this tool send my credentials to a server?",
    answer: "No — all connection string generation happens entirely in your browser. Your host, password, and other settings never leave your machine."
  },
  {
    question: "What port does Redis use by default?",
    answer: "Redis listens on port 6379 by default. Managed services often use different ports — check your service dashboard. For example, Upstash uses port 6379 but some services use 6380 for TLS-only connections."
  },
];
---

<BaseLayout
  title="Redis Connection String Builder — redis:// URL Generator for redis-py, ioredis, Lettuce"
  description="Build Redis connection strings and URLs from host, port, password, database, and TLS settings. Generate ready-to-use code examples for redis-py (Python), ioredis (Node.js), and Lettuce (Java). Free, runs in your browser."
  tool="Redis URL Builder, Redis Connection String Generator, Redis Connection URL, redis-py connection, ioredis connection string"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Redis Connection String Builder",
    "url": "https://devplaybook.cc/tools/redis-connection-string-builder",
    "description": "Build Redis connection strings and URLs. Generate redis:// or rediss:// URLs and code examples for redis-py, ioredis, and Lettuce from host/port/password/db/TLS settings.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Redis Connection String Builder</h1>
  <p class="text-text-muted mb-4">
    Build a Redis connection URL from your host, port, password, database, and TLS settings.
    Get ready-to-paste code snippets for <strong>redis-py</strong>, <strong>ioredis</strong>, and <strong>Lettuce</strong>.
    Supports ACL username, TLS (<code class="font-mono">rediss://</code>), and all Redis hosting providers.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> redis:// & rediss:// (TLS)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> ACL username support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Python, Node.js & Java examples</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <RedisConnectionStringBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Redis Connection String Builder" relatedTags={['redis', 'database', 'cache', 'connection-string', 'developer-tools']} />
</BaseLayout>
