---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What are ANSI escape codes?",
    answer: "ANSI escape codes are byte sequences that terminals interpret as commands rather than printable characters. They start with ESC (ASCII 27, written as \\033, \\x1b, or \\e) followed by [ and a parameter list. For colors: \\033[31m sets foreground red, \\033[0m resets all attributes. They're standardized by ECMA-48 and supported by virtually every Unix terminal emulator."
  },
  {
    question: "What is the difference between 16, 256, and truecolor?",
    answer: "The 16 standard colors (codes 30–37, 90–97 for fg) are the oldest and most portable. 256-color mode (\\033[38;5;Nm) adds a 6x6x6 color cube plus a 24-step grayscale ramp — supported by xterm, iTerm2, GNOME Terminal, and most modern terminals. Truecolor (\\033[38;2;R;G;Bm) allows any 24-bit RGB value — supported by iTerm2, Kitty, Alacritty, Windows Terminal (v1.10+), and VS Code's integrated terminal."
  },
  {
    question: "How do I use ANSI colors in a bash script?",
    answer: "Define color variables at the top: RED='\\033[31m' and RESET='\\033[0m', then use them with echo -e or printf. Example: echo -e \"${RED}Error: file not found${RESET}\". Use printf for portability: printf '%b' \"${RED}Error${RESET}\\n\". The -e flag tells echo to interpret escape sequences — without it, the literal characters \\033 are printed."
  },
  {
    question: "How do I use terminal colors in Python?",
    answer: "You can use raw escape codes: print('\\033[32mSuccess\\033[0m'). For real projects, use the colorama library (pip install colorama) which handles Windows compatibility: from colorama import Fore, Style; print(Fore.GREEN + 'Success' + Style.RESET_ALL). For 256 colors: print('\\033[38;5;208mOrange text\\033[0m')."
  },
  {
    question: "How do I use terminal colors in Node.js?",
    answer: "Raw escape codes work: console.log('\\x1b[32mSuccess\\x1b[0m'). The chalk library is the standard choice: const chalk = require('chalk'); console.log(chalk.green('Success')). Chalk auto-detects color support, respects NO_COLOR env var, and has a clean chaining API: chalk.bold.red('Error'). For 256 colors: chalk.ansi256(208)('Orange')."
  },
  {
    question: "Why do colors look different in different terminals?",
    answer: "The 16 standard colors have no fixed RGB values — each terminal theme defines its own palette. What is 'red' (code 31) in one theme might be a deep maroon in another. 256-color and truecolor values are more consistent because they specify exact RGB. For maximum consistency across environments, use truecolor (\\033[38;2;R;G;Bm) when you know the terminal supports it, or stick to the 256-color palette."
  }
];
---

<BaseLayout
  title="Terminal Color Picker — ANSI 256-Color Palette with Escape Codes"
  description="Visual 256-color ANSI terminal color palette. Click any color to get the ANSI code, escape sequence, and ready-to-use code for bash, Python, and Node.js. Includes standard 16 colors."
  tool="ANSI color codes, terminal colors, 256 color palette, escape sequences, bash colors, terminal color picker, xterm colors"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Terminal Color Picker</h1>
  <p class="text-text-muted mb-4">Click any color to see its ANSI code, escape sequence, and usage examples for bash, Python, and Node.js. Covers all 256 xterm colors.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All 256 ANSI colors</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> bash / Python / Node.js</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Foreground &amp; background</span>
  </div>

  <!-- Selected color info -->
  <div id="selected-panel" class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <div class="flex flex-col sm:flex-row gap-4">
      <!-- Preview swatch -->
      <div class="shrink-0">
        <div id="swatch-fg" class="w-20 h-20 rounded-xl border-2 border-border flex items-center justify-center text-2xl font-bold" style="background: #808080; color: #000000;">Aa</div>
      </div>
      <!-- Info -->
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-3 mb-2">
          <span id="color-label" class="text-lg font-bold font-mono text-primary">Color 244</span>
          <span id="color-hex-display" class="text-sm text-text-muted font-mono">#808080</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-xs font-mono">
          <div>
            <span class="text-text-muted">Foreground: </span>
            <span id="esc-fg" class="text-text">ESC[38;5;244m</span>
          </div>
          <div>
            <span class="text-text-muted">Background: </span>
            <span id="esc-bg" class="text-text">ESC[48;5;244m</span>
          </div>
          <div>
            <span class="text-text-muted">Reset: </span>
            <span class="text-text">ESC[0m</span>
          </div>
          <div>
            <span class="text-text-muted">Color #: </span>
            <span id="color-num-display" class="text-text">244</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Code snippets -->
    <div class="mt-4 space-y-3">
      <div>
        <div class="flex items-center justify-between mb-1">
          <span class="text-xs text-text-muted">bash / sh</span>
          <button class="copy-code-btn text-xs px-2 py-0.5 bg-bg-card border border-border rounded hover:border-primary text-text-muted hover:text-primary transition-colors" data-target="code-bash">Copy</button>
        </div>
        <pre id="code-bash" class="bg-bg-card border border-border rounded-lg p-3 text-xs font-mono overflow-x-auto whitespace-pre text-text leading-relaxed"></pre>
      </div>
      <div>
        <div class="flex items-center justify-between mb-1">
          <span class="text-xs text-text-muted">Python</span>
          <button class="copy-code-btn text-xs px-2 py-0.5 bg-bg-card border border-border rounded hover:border-primary text-text-muted hover:text-primary transition-colors" data-target="code-python">Copy</button>
        </div>
        <pre id="code-python" class="bg-bg-card border border-border rounded-lg p-3 text-xs font-mono overflow-x-auto whitespace-pre text-text leading-relaxed"></pre>
      </div>
      <div>
        <div class="flex items-center justify-between mb-1">
          <span class="text-xs text-text-muted">Node.js</span>
          <button class="copy-code-btn text-xs px-2 py-0.5 bg-bg-card border border-border rounded hover:border-primary text-text-muted hover:text-primary transition-colors" data-target="code-node">Copy</button>
        </div>
        <pre id="code-node" class="bg-bg-card border border-border rounded-lg p-3 text-xs font-mono overflow-x-auto whitespace-pre text-text leading-relaxed"></pre>
      </div>
    </div>
  </div>

  <!-- Mode toggle -->
  <div class="flex items-center gap-3 mb-4">
    <span class="text-sm font-medium">Preview mode:</span>
    <button id="mode-fg" class="px-3 py-1.5 text-sm rounded-lg border border-primary bg-primary/10 text-primary transition-colors">Foreground</button>
    <button id="mode-bg" class="px-3 py-1.5 text-sm rounded-lg border border-border text-text-muted hover:border-primary transition-colors">Background</button>
  </div>

  <!-- Standard 16 colors -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-3">Standard 16 Colors</h2>
    <div class="mb-2">
      <span class="text-xs text-text-muted">Normal (0–7)</span>
      <div id="palette-16-normal" class="flex flex-wrap gap-1.5 mt-1.5"></div>
    </div>
    <div>
      <span class="text-xs text-text-muted">Bright (8–15)</span>
      <div id="palette-16-bright" class="flex flex-wrap gap-1.5 mt-1.5"></div>
    </div>
  </div>

  <!-- 256-color cube -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-1">256-Color Extended Palette</h2>
    <p class="text-xs text-text-muted mb-3">Colors 16–231 form a 6×6×6 RGB cube. Colors 232–255 are a grayscale ramp.</p>
    <div id="palette-256" class="mb-3"></div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Terminal Color Picker" relatedTags={['terminal', 'ansi', 'bash', 'shell', 'colors', 'cli', 'linux']} />
</BaseLayout>

<script>
(function() {
  // xterm 256-color RGB values
  // Standard 16 are terminal-defined; we use common defaults
  var STANDARD_16 = [
    { n: 0,  hex: '#000000', name: 'Black' },
    { n: 1,  hex: '#800000', name: 'Red' },
    { n: 2,  hex: '#008000', name: 'Green' },
    { n: 3,  hex: '#808000', name: 'Yellow (Olive)' },
    { n: 4,  hex: '#000080', name: 'Blue' },
    { n: 5,  hex: '#800080', name: 'Magenta' },
    { n: 6,  hex: '#008080', name: 'Cyan' },
    { n: 7,  hex: '#c0c0c0', name: 'White (Light Gray)' },
    { n: 8,  hex: '#808080', name: 'Bright Black (Dark Gray)' },
    { n: 9,  hex: '#ff0000', name: 'Bright Red' },
    { n: 10, hex: '#00ff00', name: 'Bright Green' },
    { n: 11, hex: '#ffff00', name: 'Bright Yellow' },
    { n: 12, hex: '#0000ff', name: 'Bright Blue' },
    { n: 13, hex: '#ff00ff', name: 'Bright Magenta' },
    { n: 14, hex: '#00ffff', name: 'Bright Cyan' },
    { n: 15, hex: '#ffffff', name: 'Bright White' },
  ];

  function xterm256Hex(n) {
    if (n < 16) return STANDARD_16[n].hex;
    if (n >= 232) {
      // Grayscale
      var v = 8 + (n - 232) * 10;
      var hex = v.toString(16).padStart(2, '0');
      return '#' + hex + hex + hex;
    }
    // 6x6x6 color cube
    var idx = n - 16;
    var b = idx % 6;
    var g = Math.floor(idx / 6) % 6;
    var r = Math.floor(idx / 36);
    function cubeVal(i) { return i === 0 ? 0 : 55 + i * 40; }
    function toHex(v) { return v.toString(16).padStart(2, '0'); }
    return '#' + toHex(cubeVal(r)) + toHex(cubeVal(g)) + toHex(cubeVal(b));
  }

  function luminance(hex) {
    var c = parseInt(hex.slice(1), 16);
    var r = (c >> 16) & 255, g = (c >> 8) & 255, b = c & 255;
    function lin(v) { v /= 255; return v <= 0.04045 ? v / 12.92 : Math.pow((v + 0.055) / 1.055, 2.4); }
    return 0.2126 * lin(r) + 0.7152 * lin(g) + 0.0722 * lin(b);
  }

  var selectedColor = 244;
  var previewMode = 'fg'; // fg or bg

  function getColorHex(n) {
    return xterm256Hex(n);
  }

  function getColorName(n) {
    if (n < 16) return STANDARD_16[n].name;
    if (n >= 232) return 'Grayscale ramp ' + (n - 232);
    return '6x6x6 cube';
  }

  function selectColor(n) {
    selectedColor = n;
    var hex = getColorHex(n);
    var lum = luminance(hex);
    var textColor = lum > 0.4 ? '#000000' : '#ffffff';

    // Swatch
    var swatch = document.getElementById('swatch-fg');
    if (previewMode === 'fg') {
      swatch.style.background = '#1e1e2e';
      swatch.style.color = hex;
    } else {
      swatch.style.background = hex;
      swatch.style.color = textColor;
    }

    document.getElementById('color-label').textContent = 'Color ' + n;
    document.getElementById('color-hex-display').textContent = hex;
    document.getElementById('color-num-display').textContent = n;

    var fgSeq, bgSeq;
    if (n < 8) {
      fgSeq = '\\033[' + (30 + n) + 'm';
      bgSeq = '\\033[' + (40 + n) + 'm';
    } else if (n < 16) {
      fgSeq = '\\033[' + (90 + n - 8) + 'm';
      bgSeq = '\\033[' + (100 + n - 8) + 'm';
    } else {
      fgSeq = '\\033[38;5;' + n + 'm';
      bgSeq = '\\033[48;5;' + n + 'm';
    }

    document.getElementById('esc-fg').textContent = fgSeq.replace(/\\\\/g, '\\').replace('\\033', 'ESC');
    document.getElementById('esc-bg').textContent = bgSeq.replace(/\\\\/g, '\\').replace('\\033', 'ESC');

    // bash code
    var bashFg = "FG='" + fgSeq + "'\nRESET='\\033[0m'\necho -e \"${FG}Your colored text${RESET}\"";
    var bashBg = "BG='" + bgSeq + "'\nRESET='\\033[0m'\necho -e \"${BG}Your colored text${RESET}\"";
    document.getElementById('code-bash').textContent = bashFg + '\n\n# Background:\n' + bashBg;

    // Python code
    var pyFgCode = n < 8 ? (30 + n) : n < 16 ? (90 + n - 8) : null;
    var pyBgCode = n < 8 ? (40 + n) : n < 16 ? (100 + n - 8) : null;
    var pyFgStr = pyFgCode !== null ? "'\\033[" + pyFgCode + "m'" : "'\\033[38;5;" + n + "m'";
    var pyBgStr = pyBgCode !== null ? "'\\033[" + pyBgCode + "m'" : "'\\033[48;5;" + n + "m'";
    document.getElementById('code-python').textContent =
      'FG = ' + pyFgStr + '\nBG = ' + pyBgStr + "\nRESET = '\\033[0m'\n\nprint(FG + 'Foreground example' + RESET)\nprint(BG + 'Background example' + RESET)";

    // Node.js code
    var nodeFgStr = pyFgCode !== null ? "'\\x1b[" + pyFgCode + "m'" : "'\\x1b[38;5;" + n + "m'";
    var nodeBgStr = pyBgCode !== null ? "'\\x1b[" + pyBgCode + "m'" : "'\\x1b[48;5;" + n + "m'";
    document.getElementById('code-node').textContent =
      'const FG = ' + nodeFgStr + ';\nconst BG = ' + nodeBgStr + ";\nconst RESET = '\\x1b[0m';\n\nconsole.log(FG + 'Foreground example' + RESET);\nconsole.log(BG + 'Background example' + RESET);";

    // Highlight selected swatch
    document.querySelectorAll('.color-swatch').forEach(function(el) {
      el.classList.remove('ring-2', 'ring-primary', 'ring-offset-1', 'ring-offset-bg-card');
    });
    var activeEl = document.querySelector('.color-swatch[data-n="' + n + '"]');
    if (activeEl) {
      activeEl.classList.add('ring-2', 'ring-primary', 'ring-offset-1', 'ring-offset-bg-card');
    }
  }

  function createSwatch(n) {
    var hex = getColorHex(n);
    var lum = luminance(hex);
    var border = lum > 0.9 ? 'border border-border/50' : '';
    var el = document.createElement('button');
    el.className = 'color-swatch w-7 h-7 rounded cursor-pointer hover:scale-110 transition-transform shrink-0 ' + border;
    el.style.backgroundColor = hex;
    el.setAttribute('data-n', n);
    el.setAttribute('title', 'Color ' + n + ' — ' + hex + (n < 16 ? ' (' + STANDARD_16[n].name + ')' : ''));
    el.addEventListener('click', function() { selectColor(n); });
    return el;
  }

  // Build standard 16
  var normal = document.getElementById('palette-16-normal');
  var bright = document.getElementById('palette-16-bright');
  for (var i = 0; i < 8; i++) normal.appendChild(createSwatch(i));
  for (var i = 8; i < 16; i++) bright.appendChild(createSwatch(i));

  // Build 256-color palette
  var pal256 = document.getElementById('palette-256');

  // 6x6x6 cube (16-231) in rows of 36
  var cubeDiv = document.createElement('div');
  cubeDiv.className = 'mb-3';
  var cubeLabel = document.createElement('div');
  cubeLabel.className = 'text-xs text-text-muted mb-1.5';
  cubeLabel.textContent = 'Colors 16–231 (6×6×6 RGB cube)';
  cubeDiv.appendChild(cubeLabel);

  // Group into 6 rows of 36
  for (var row = 0; row < 6; row++) {
    var rowDiv = document.createElement('div');
    rowDiv.className = 'flex gap-0.5 mb-0.5';
    for (var col = 0; col < 36; col++) {
      rowDiv.appendChild(createSwatch(16 + row * 36 + col));
    }
    cubeDiv.appendChild(rowDiv);
  }
  pal256.appendChild(cubeDiv);

  // Grayscale ramp (232-255)
  var grayDiv = document.createElement('div');
  var grayLabel = document.createElement('div');
  grayLabel.className = 'text-xs text-text-muted mb-1.5';
  grayLabel.textContent = 'Colors 232–255 (grayscale ramp)';
  grayDiv.appendChild(grayLabel);
  var grayRow = document.createElement('div');
  grayRow.className = 'flex gap-0.5';
  for (var i = 232; i <= 255; i++) {
    grayRow.appendChild(createSwatch(i));
  }
  grayDiv.appendChild(grayRow);
  pal256.appendChild(grayDiv);

  // Mode toggle
  document.getElementById('mode-fg').addEventListener('click', function() {
    previewMode = 'fg';
    document.getElementById('mode-fg').className = 'px-3 py-1.5 text-sm rounded-lg border border-primary bg-primary/10 text-primary transition-colors';
    document.getElementById('mode-bg').className = 'px-3 py-1.5 text-sm rounded-lg border border-border text-text-muted hover:border-primary transition-colors';
    selectColor(selectedColor);
  });
  document.getElementById('mode-bg').addEventListener('click', function() {
    previewMode = 'bg';
    document.getElementById('mode-bg').className = 'px-3 py-1.5 text-sm rounded-lg border border-primary bg-primary/10 text-primary transition-colors';
    document.getElementById('mode-fg').className = 'px-3 py-1.5 text-sm rounded-lg border border-border text-text-muted hover:border-primary transition-colors';
    selectColor(selectedColor);
  });

  // Copy buttons
  document.querySelectorAll('.copy-code-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var target = btn.getAttribute('data-target');
      var el = document.getElementById(target);
      if (!el) return;
      navigator.clipboard.writeText(el.textContent || '').then(function() {
        var orig = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(function() { btn.textContent = orig; }, 1500);
      });
    });
  });

  // Initial selection
  selectColor(244);
})();
</script>
