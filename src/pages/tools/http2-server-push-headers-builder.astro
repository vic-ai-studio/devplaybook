---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Http2ServerPushHeadersBuilder from '../../components/Http2ServerPushHeadersBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is HTTP/2 server push?",
    answer: "HTTP/2 server push lets a server proactively send resources (CSS, JS, fonts, images) to the client before the browser even requests them. This eliminates a full round-trip for critical assets that the server knows the browser will need."
  },
  {
    question: "What does the Link header do?",
    answer: "The Link preload header instructs the browser (and HTTP/2 intermediaries) to begin fetching the resource immediately. Format: </path/to/resource>; rel=preload; as=<type>. The 'as' attribute tells the browser what kind of resource it is so it can apply the correct content security policy and cache behavior."
  },
  {
    question: "When should I use crossorigin?",
    answer: "Set crossorigin=anonymous for fonts and resources fetched with CORS (cross-origin). If the resource requires credentials, use crossorigin=use-credentials. For same-origin resources like scripts and stylesheets loaded from your own domain, you typically don't need crossorigin."
  },
  {
    question: "Does server push work with HTTP/1.1?",
    answer: "No. Server push is an HTTP/2-only feature. With HTTP/1.1, the Link preload header still tells the browser to preload the resource eagerly, but no push occurs — the browser will make a normal request for it."
  },
  {
    question: "How do I add the Link header in nginx?",
    answer: "In your nginx location block, add: add_header Link \"</style.css>; rel=preload; as=style\"; You can combine multiple resources in one header value by separating them with commas. This tool generates the complete nginx directive for you."
  },
  {
    question: "What is the performance impact?",
    answer: "Server push reduces time-to-interactive for critical resources by eliminating the browser's discovery phase. However, over-pushing can waste bandwidth if the browser already has the resource cached. Consider using Cache-Digest headers or limiting push to first-visit critical path resources only."
  },
];
---

<BaseLayout
  title="HTTP/2 Server Push Headers Builder — Link Preload Header Generator"
  description="Build HTTP/2 Link preload headers for server push. Generate nginx, Apache, and Caddy config snippets for CSS, JS, fonts, and images. Free, browser-based tool."
  tool="HTTP/2 Server Push, Link Header Generator, Preload Headers Builder, nginx Server Push Config"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "HTTP/2 Server Push Headers Builder",
    "url": "https://devplaybook.cc/tools/http2-server-push-headers-builder",
    "description": "Build HTTP/2 Link preload headers for server push. Generate ready-to-use nginx, Apache, and Caddy config snippets.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">HTTP/2 Server Push Headers Builder</h1>
  <p class="text-text-muted mb-4">
    Build <code class="font-mono bg-surface px-1 rounded text-sm">Link</code> preload headers for HTTP/2 server push.
    Add your resources, choose types, and get ready-to-paste nginx, Apache, and Caddy config snippets.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> nginx, Apache & Caddy snippets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> style / script / font / image / fetch</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <Http2ServerPushHeadersBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="HTTP/2 Server Push Headers Builder" relatedTags={['performance', 'http', 'web-server', 'nginx', 'pwa', 'developer-tools']} />
</BaseLayout>
