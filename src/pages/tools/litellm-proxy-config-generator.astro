---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LitellmProxyConfigGenerator from '../../components/LitellmProxyConfigGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is LiteLLM and why use a proxy?",
    answer: "LiteLLM is an open-source library that provides a unified OpenAI-compatible API across 100+ LLM providers (Anthropic, Gemini, Groq, Cohere, etc.). Running it as a proxy means your apps always call one endpoint — the proxy handles routing, fallbacks, retries, and budget tracking. You can swap models without changing application code."
  },
  {
    question: "What routing strategies does LiteLLM support?",
    answer: "LiteLLM supports 4 routing strategies: (1) Simple Shuffle — weighted random selection across providers, (2) Least Busy — route to the provider with fewest active requests, (3) Latency-based — tracks P95 latency and routes to the fastest provider, (4) Cost-based — estimates token cost per provider and routes to the cheapest. Latency-based is best for production latency-sensitive apps."
  },
  {
    question: "How do I set API keys securely?",
    answer: "Use os.environ/KEY_NAME syntax in config.yaml — LiteLLM reads from environment variables at runtime. Never hardcode API keys in config files. For Docker deployments, pass keys via --env-file or Kubernetes secrets. The master_key in general_settings is used to authenticate requests to your proxy itself."
  },
  {
    question: "What does the budget_duration setting do?",
    answer: "budget_duration combined with max_budget defines a spending limit per period. Setting max_budget: 100 with budget_duration: 30d means the proxy will refuse requests after $100 is spent in any 30-day rolling window. You can track spending in the LiteLLM dashboard UI (port 4000 by default) or via /budget/info API."
  },
  {
    question: "Should I use caching in production?",
    answer: "Yes for high-volume, low-variance requests. LiteLLM's Redis caching deduplicates identical prompts — if 100 users ask the same question, only one LLM call is made. Use a TTL of 1-24 hours for stable content. Avoid caching for personalized, real-time, or safety-critical responses. Make sure your Redis instance is in the same region as your proxy for minimal latency."
  },
];
---

<BaseLayout
  title="LiteLLM Proxy Config Generator — Generate config.yaml for LiteLLM"
  description="Generate a complete LiteLLM proxy config.yaml. Configure providers (OpenAI, Anthropic, Gemini, Groq), routing strategy, fallbacks, budget limits, and Redis caching. Download instantly."
  tool="LiteLLM config generator, LiteLLM proxy config, litellm config.yaml, LLM proxy configuration, OpenAI proxy config"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "LiteLLM Proxy Config Generator",
    "url": "https://devplaybook.cc/tools/litellm-proxy-config-generator",
    "description": "Generate LiteLLM proxy config.yaml files with multiple providers, routing strategies, fallbacks, and budget controls.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">LiteLLM Proxy Config Generator</h1>
  <p class="text-text-muted mb-4">
    Generate a complete <code class="font-mono text-sm bg-bg-card px-1 rounded">config.yaml</code> for your LiteLLM proxy. Add providers, configure routing strategy, set budget limits, and enable Redis caching — then download the config.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 8 LLM providers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 4 routing strategies</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Budget & caching config</span>
  </div>
  <LitellmProxyConfigGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="LiteLLM Proxy Config Generator" relatedTags={['ai', 'llm', 'developer-tools', 'devops', 'openai', 'anthropic']} />
</BaseLayout>
