---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Datadog Monitor Config Generator — JSON & Terraform Output"
  description="Generate Datadog monitor configurations in JSON/Terraform format. Configure metric monitors, APM monitors, log monitors with thresholds, notifications, and tags. Runs in your browser."
  tool="Datadog monitor generator, Datadog JSON, Terraform datadog_monitor, metric monitor, APM monitor, log monitor, Datadog alerts, devops monitoring"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Datadog Monitor Config Generator",
    "url": "https://devplaybook.cc/tools/datadog-monitor-config",
    "description": "Generate Datadog monitor configurations in JSON/Terraform format. Configure metric monitors, APM monitors, log monitors with thresholds, notifications, and tags.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Datadog Monitor Config Generator</h1>
  <p class="text-text-muted mb-4">Configure Datadog monitors with thresholds, notifications, and tags. Export ready-to-use JSON (Datadog API format) or Terraform <code class="font-mono text-primary">datadog_monitor</code> resource blocks.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> metric / APM / log / synthetics</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> JSON &amp; Terraform output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> @slack / @pagerduty notifications</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs entirely in your browser</span>
  </div>

  <!-- Form -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
    <div>
      <label class="block text-sm font-medium mb-2">Monitor Name</label>
      <input id="mon-name" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="High CPU Usage on {{host.name}}" value="High CPU Usage on {{host.name}}" />
    </div>
    <div>
      <label class="block text-sm font-medium mb-2">Monitor Type</label>
      <select id="mon-type" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
        <option value="metric alert">metric alert</option>
        <option value="apm alert">apm alert</option>
        <option value="log alert">log alert</option>
        <option value="synthetics alert">synthetics alert</option>
        <option value="service check">service check</option>
        <option value="event alert">event alert</option>
      </select>
    </div>
  </div>

  <div class="mb-4">
    <label class="block text-sm font-medium mb-2">Query</label>
    <textarea id="mon-query" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary resize-none" rows="3" placeholder='avg(last_5m):avg:system.cpu.user{*} by {host} > 90'>avg(last_5m):avg:system.cpu.user{*} by {host} > 90</textarea>
  </div>

  <div class="mb-4">
    <label class="block text-sm font-medium mb-2">Message / Notification</label>
    <textarea id="mon-message" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary resize-none" rows="3" placeholder="CPU is high on {{host.name}}. Value: {{value}}% @slack-alerts @pagerduty">CPU is critically high on {{host.name}}. Value: {{value}}%. Please investigate immediately. @slack-ops @pagerduty-oncall</textarea>
    <p class="text-xs text-text-muted mt-1">Use @slack-channel-name, @pagerduty-service to route alerts.</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4">
    <div>
      <label class="block text-sm font-medium mb-2">Warning Threshold</label>
      <input id="mon-warn" type="number" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="80" value="80" />
    </div>
    <div>
      <label class="block text-sm font-medium mb-2">Critical Threshold</label>
      <input id="mon-crit" type="number" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="90" value="90" />
    </div>
    <div>
      <label class="block text-sm font-medium mb-2">Evaluation Window</label>
      <select id="mon-eval" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
        <option>last_5m</option>
        <option>last_10m</option>
        <option>last_15m</option>
        <option>last_30m</option>
        <option>last_1h</option>
        <option>last_4h</option>
        <option>last_1d</option>
      </select>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
    <div>
      <label class="block text-sm font-medium mb-2">Tags (comma-separated)</label>
      <input id="mon-tags" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="env:production, team:platform" value="env:production, team:platform" />
    </div>
    <div>
      <label class="block text-sm font-medium mb-2">Priority (1=highest, 5=lowest)</label>
      <select id="mon-priority" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
        <option value="1">1 - Highest</option>
        <option value="2" selected>2 - High</option>
        <option value="3">3 - Medium</option>
        <option value="4">4 - Low</option>
        <option value="5">5 - Lowest</option>
      </select>
    </div>
  </div>

  <div class="flex items-center gap-3 mb-6">
    <label class="flex items-center gap-2 text-sm cursor-pointer">
      <input id="mon-notify-no-data" type="checkbox" class="rounded" checked />
      Notify on no data
    </label>
    <label class="flex items-center gap-2 text-sm cursor-pointer">
      <input id="mon-require-full-window" type="checkbox" class="rounded" />
      Require full window
    </label>
    <label class="flex items-center gap-2 text-sm cursor-pointer">
      <input id="mon-notify-audit" type="checkbox" class="rounded" />
      Notify on audit
    </label>
  </div>

  <div class="flex gap-3 mb-6 flex-wrap">
    <button id="btn-generate" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Generate Config</button>
    <button id="btn-load-example" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Load APM Example</button>
    <button id="btn-load-log" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Load Log Example</button>
  </div>

  <!-- Output -->
  <div id="output-section" class="hidden">
    <div class="flex gap-1 mb-4 border-b border-border">
      <button data-fmt="json" class="fmt-tab px-4 py-2 text-sm font-medium border-b-2 border-primary text-primary transition-colors">JSON (API)</button>
      <button data-fmt="terraform" class="fmt-tab px-4 py-2 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-foreground transition-colors">Terraform</button>
    </div>

    <div id="fmt-panel-json" class="fmt-panel bg-bg-card border border-border rounded-lg p-4">
      <div class="flex justify-end mb-2">
        <button class="copy-btn px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-target="output-json">Copy</button>
      </div>
      <pre id="output-json" class="font-mono text-sm whitespace-pre-wrap break-words text-green-300 overflow-x-auto max-h-[500px] overflow-y-auto"></pre>
    </div>
    <div id="fmt-panel-terraform" class="fmt-panel hidden bg-bg-card border border-border rounded-lg p-4">
      <div class="flex justify-end mb-2">
        <button class="copy-btn px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-target="output-terraform">Copy</button>
      </div>
      <pre id="output-terraform" class="font-mono text-sm whitespace-pre-wrap break-words text-blue-300 overflow-x-auto max-h-[500px] overflow-y-auto"></pre>
    </div>
  </div>

  <ToolPageCta />
</BaseLayout>

<script>
let currentFmt = 'json';

function val(id) {
  const el = document.getElementById(id);
  if (!el) return '';
  if (el.type === 'checkbox') return el.checked;
  return (el.value || '').trim();
}

function generateConfig() {
  const name = val('mon-name') || 'My Monitor';
  const type = val('mon-type') || 'metric alert';
  const query = val('mon-query') || 'avg(last_5m):avg:system.cpu.user{*} > 90';
  const message = val('mon-message') || 'Alert triggered.';
  const warnRaw = val('mon-warn');
  const critRaw = val('mon-crit');
  const evalWindow = val('mon-eval') || 'last_5m';
  const tagsRaw = val('mon-tags');
  const priority = parseInt(val('mon-priority') || '2', 10);
  const notifyNoData = val('mon-notify-no-data');
  const requireFullWindow = val('mon-require-full-window');
  const notifyAudit = val('mon-notify-audit');

  const warn = warnRaw !== '' ? parseFloat(warnRaw) : undefined;
  const crit = critRaw !== '' ? parseFloat(critRaw) : undefined;
  const tags = tagsRaw ? tagsRaw.split(',').map(t => t.trim()).filter(Boolean) : [];

  const thresholds = {};
  if (warn !== undefined) thresholds.warning = warn;
  if (crit !== undefined) thresholds.critical = crit;

  // JSON (Datadog API format)
  const jsonObj = {
    name,
    type,
    query,
    message,
    tags,
    priority,
    options: {
      thresholds,
      notify_no_data: notifyNoData,
      require_full_window: requireFullWindow,
      notify_audit: notifyAudit,
      evaluation_delay: null,
      new_host_delay: 300,
      include_tags: true,
      renotify_interval: 0,
      escalation_message: '',
      locked: false
    }
  };

  // Terraform
  const resourceName = name.toLowerCase().replace(/[^a-z0-9]+/g,'_').replace(/^_|_$/g,'');
  const tagsList = tags.map(t => `    "${t}"`).join(',\n');

  let tf = `resource "datadog_monitor" "${resourceName}" {\n`;
  tf += `  name    = "${name.replace(/"/g, '\\"')}"\n`;
  tf += `  type    = "${type}"\n`;
  tf += `  message = <<-EOT\n    ${message.replace(/\n/g, '\n    ')}\n  EOT\n\n`;
  tf += `  query = "${query.replace(/"/g, '\\"')}"\n\n`;
  if (Object.keys(thresholds).length > 0) {
    tf += '  monitor_thresholds {\n';
    if (thresholds.warning !== undefined) tf += `    warning  = ${thresholds.warning}\n`;
    if (thresholds.critical !== undefined) tf += `    critical = ${thresholds.critical}\n`;
    tf += '  }\n\n';
  }
  tf += `  notify_no_data    = ${notifyNoData}\n`;
  tf += `  require_full_window = ${requireFullWindow}\n`;
  tf += `  notify_audit      = ${notifyAudit}\n`;
  tf += `  priority          = ${priority}\n`;
  if (tags.length > 0) {
    tf += `\n  tags = [\n${tagsList}\n  ]\n`;
  }
  tf += '}\n';

  document.getElementById('output-json').textContent = JSON.stringify(jsonObj, null, 2);
  document.getElementById('output-terraform').textContent = tf;
  document.getElementById('output-section').classList.remove('hidden');
  switchFmt(currentFmt);
  setTimeout(() => document.getElementById('output-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
}

function loadApmExample() {
  document.getElementById('mon-name').value = 'High APM Error Rate: payment-service';
  document.getElementById('mon-type').value = 'apm alert';
  document.getElementById('mon-query').value = 'avg(last_5m):sum:trace.rack.request.errors{service:payment-service,resource_name:POST_/v1/charges} / sum:trace.rack.request.hits{service:payment-service,resource_name:POST_/v1/charges} > 0.05';
  document.getElementById('mon-message').value = 'Error rate on payment-service POST /v1/charges is {{value}}%. Threshold: 5%. Check APM traces: https://app.datadoghq.com/apm/traces @slack-payments-oncall @pagerduty-payments';
  document.getElementById('mon-warn').value = '0.03';
  document.getElementById('mon-crit').value = '0.05';
  document.getElementById('mon-tags').value = 'service:payment-service, env:production, team:payments';
  document.getElementById('mon-eval').value = 'last_5m';
  document.getElementById('mon-priority').value = '1';
}

function loadLogExample() {
  document.getElementById('mon-name').value = 'High Error Log Volume: api-gateway';
  document.getElementById('mon-type').value = 'log alert';
  document.getElementById('mon-query').value = 'logs("service:api-gateway status:error").index("*").rollup("count").last("5m") > 100';
  document.getElementById('mon-message').value = 'Error log count on api-gateway is {{value}} in the last 5 minutes (threshold: 100). Review logs at https://app.datadoghq.com/logs @slack-infra-alerts';
  document.getElementById('mon-warn').value = '50';
  document.getElementById('mon-crit').value = '100';
  document.getElementById('mon-tags').value = 'service:api-gateway, env:production, team:platform';
  document.getElementById('mon-eval').value = 'last_5m';
  document.getElementById('mon-priority').value = '2';
}

function switchFmt(fmt) {
  currentFmt = fmt;
  document.querySelectorAll('.fmt-tab').forEach(t => {
    const active = t.dataset.fmt === fmt;
    t.classList.toggle('border-primary', active);
    t.classList.toggle('text-primary', active);
    t.classList.toggle('border-transparent', !active);
    t.classList.toggle('text-text-muted', !active);
  });
  document.querySelectorAll('.fmt-panel').forEach(p => p.classList.add('hidden'));
  document.getElementById(`fmt-panel-${fmt}`)?.classList.remove('hidden');
}

document.getElementById('btn-generate')?.addEventListener('click', generateConfig);
document.getElementById('btn-load-example')?.addEventListener('click', loadApmExample);
document.getElementById('btn-load-log')?.addEventListener('click', loadLogExample);
document.querySelectorAll('.fmt-tab').forEach(t => t.addEventListener('click', () => switchFmt(t.dataset.fmt)));
document.querySelectorAll('.copy-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const el = document.getElementById(btn.dataset.target);
    if (!el) return;
    navigator.clipboard.writeText(el.textContent).then(() => {
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 2000);
    });
  });
});
</script>
