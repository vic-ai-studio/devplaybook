---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="AI Unit Test Generator — Pro Tool | DevPlaybook"
  description="Paste your code and get instant, comprehensive unit tests — happy paths, edge cases, and error cases. DevPlaybook Pro feature."
  tool="AI Test Generator, Unit Test Generator, Code Testing"
>
  <!-- Pro Gate loading -->
  <div id="pro-loading" class="max-w-2xl mx-auto py-16 text-center text-text-muted">
    Checking your account...
  </div>

  <!-- Not Pro: Upgrade Gate -->
  <div id="pro-gate" class="hidden max-w-2xl mx-auto py-16 px-4 text-center">
    <div class="text-6xl mb-6">🧪</div>
    <h1 class="text-3xl font-bold mb-3">AI Test Generator is a <span class="text-primary">Pro</span> feature</h1>
    <p class="text-text-muted text-lg mb-8">
      Stop writing boilerplate tests by hand. Paste any function and get complete unit tests — edge cases included.
    </p>
    <div class="bg-bg-card border border-border rounded-2xl p-8 mb-8 text-left">
      <h2 class="font-semibold mb-4">Pro includes:</h2>
      <ul class="space-y-2 text-text-muted text-sm">
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> AI Test Generator (this tool)</li>
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> AI Code Review</li>
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> AI Error Explainer</li>
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> AI Doc Generator, SQL Builder & more</li>
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> 7-day free trial, cancel anytime</li>
      </ul>
    </div>
    <a href="/pricing" class="inline-block bg-primary hover:bg-primary-dark text-white font-bold px-10 py-4 rounded-xl transition-colors text-lg">
      Start Free Trial — $9/mo
    </a>
    <p class="text-text-muted text-sm mt-4">
      Already subscribed? <a href="/signin" class="text-primary hover:underline">Sign in</a>
    </p>
  </div>

  <!-- Pro Tool UI -->
  <div id="pro-tool" class="hidden">
    <div class="flex items-center gap-3 mb-2">
      <h1 class="text-3xl font-bold">AI Test Generator</h1>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-primary/20 text-primary border border-primary/30">PRO</span>
    </div>
    <p class="text-text-muted mb-8">Paste your function or class and get complete unit tests — happy paths, edge cases, and error handling.</p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Input panel -->
      <div class="flex flex-col gap-4">
        <div>
          <label class="block text-sm font-medium mb-2" for="code-input">Your Code</label>
          <div class="flex gap-2 mb-2">
            <select id="language-select" class="flex-1 px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-primary transition-colors">
              <option value="auto-detect">Auto-detect language</option>
              <option value="JavaScript">JavaScript</option>
              <option value="TypeScript">TypeScript</option>
              <option value="Python">Python</option>
              <option value="Go">Go</option>
              <option value="Rust">Rust</option>
              <option value="Java">Java</option>
              <option value="C#">C#</option>
              <option value="PHP">PHP</option>
              <option value="Ruby">Ruby</option>
            </select>
            <select id="framework-select" class="flex-1 px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-primary transition-colors">
              <option value="auto">Auto-select framework</option>
              <option value="Jest">Jest</option>
              <option value="Vitest">Vitest</option>
              <option value="Mocha">Mocha</option>
              <option value="pytest">pytest</option>
              <option value="Go testing">Go testing</option>
              <option value="JUnit">JUnit</option>
              <option value="RSpec">RSpec</option>
            </select>
          </div>
          <textarea
            id="code-input"
            rows="18"
            placeholder="Paste your function, class, or module here..."
            class="w-full px-4 py-3 rounded-xl bg-bg border border-border text-text placeholder:text-text-muted focus:outline-none focus:border-primary transition-colors font-mono text-sm resize-y"
          ></textarea>
        </div>
        <button
          id="generate-btn"
          class="w-full py-3 px-6 rounded-xl bg-primary hover:bg-primary-dark text-white font-bold transition-colors duration-200 disabled:opacity-50"
        >
          Generate Tests
        </button>
        <p id="generate-error" class="text-xs text-red-400 hidden"></p>
      </div>

      <!-- Output panel -->
      <div class="flex flex-col gap-4">
        <div class="flex items-center justify-between">
          <label class="block text-sm font-medium">Generated Tests</label>
          <button id="copy-btn" class="text-xs text-text-muted hover:text-primary transition-colors hidden">Copy</button>
        </div>
        <div
          id="output-placeholder"
          class="flex-1 min-h-[420px] rounded-xl bg-bg border border-border flex items-center justify-center text-text-muted text-sm"
        >
          Your unit tests will appear here
        </div>
        <div
          id="output-loading"
          class="hidden flex-1 min-h-[420px] rounded-xl bg-bg border border-border flex items-center justify-center text-text-muted text-sm"
        >
          <div class="text-center">
            <div class="animate-pulse text-3xl mb-3">🧪</div>
            <p>Generating tests...</p>
          </div>
        </div>
        <pre
          id="output-code"
          class="hidden flex-1 min-h-[420px] rounded-xl bg-bg border border-border p-5 text-sm overflow-auto font-mono whitespace-pre-wrap"
        ></pre>
      </div>
    </div>

    <div class="mt-8 p-4 bg-bg-card border border-border rounded-xl text-xs text-text-muted">
      <strong>Pro tip:</strong> For best results, include the full function or class — including any type annotations or JSDoc. The AI generates more accurate tests with complete context.
    </div>
  </div>

  <ToolPageCta currentTool="AI Test Generator" relatedTags={['ai', 'testing', 'development']} />
</BaseLayout>

<script is:inline>
  async function init() {
    let session;
    try {
      const res = await fetch('/api/auth/session');
      session = await res.json();
    } catch {
      session = { loggedIn: false };
    }

    document.getElementById('pro-loading').classList.add('hidden');

    if (!session.loggedIn || !session.isPro) {
      document.getElementById('pro-gate').classList.remove('hidden');
      return;
    }

    document.getElementById('pro-tool').classList.remove('hidden');

    const btn = document.getElementById('generate-btn');
    const codeInput = document.getElementById('code-input');
    const langSelect = document.getElementById('language-select');
    const fwSelect = document.getElementById('framework-select');
    const errorMsg = document.getElementById('generate-error');
    const placeholder = document.getElementById('output-placeholder');
    const loading = document.getElementById('output-loading');
    const outputCode = document.getElementById('output-code');
    const copyBtn = document.getElementById('copy-btn');

    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(outputCode.textContent).then(() => {
        copyBtn.textContent = 'Copied!';
        setTimeout(() => { copyBtn.textContent = 'Copy'; }, 2000);
      });
    });

    btn.addEventListener('click', async () => {
      const code = codeInput.value.trim();
      if (!code) { errorMsg.textContent = 'Please paste some code first.'; errorMsg.classList.remove('hidden'); return; }
      errorMsg.classList.add('hidden');

      btn.disabled = true;
      btn.textContent = 'Generating...';
      placeholder.classList.add('hidden');
      outputCode.classList.add('hidden');
      loading.classList.remove('hidden');
      copyBtn.classList.add('hidden');

      try {
        const res = await fetch('/api/ai/test-generator', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code, language: langSelect.value, framework: fwSelect.value }),
        });
        const data = await res.json();

        if (!res.ok) {
          if (res.status === 403) {
            errorMsg.textContent = 'Pro subscription required. Refresh to check your status.';
          } else if (res.status === 401) {
            errorMsg.textContent = 'Session expired — please sign in again.';
          } else {
            errorMsg.textContent = data.error || 'Something went wrong.';
          }
          errorMsg.classList.remove('hidden');
          loading.classList.add('hidden');
          placeholder.classList.remove('hidden');
        } else {
          // Strip markdown code fences if the AI wrapped in them
          let tests = data.tests || '';
          tests = tests.replace(/^```[\w]*\n?/, '').replace(/\n?```$/, '').trim();
          outputCode.textContent = tests;
          loading.classList.add('hidden');
          outputCode.classList.remove('hidden');
          copyBtn.classList.remove('hidden');
        }
      } catch {
        errorMsg.textContent = 'Network error — please try again.';
        errorMsg.classList.remove('hidden');
        loading.classList.add('hidden');
        placeholder.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Generate Tests';
      }
    });
  }

  init();
</script>
