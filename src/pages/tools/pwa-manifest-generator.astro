---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PwaManifestGenerator from '../../components/PwaManifestGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a Web App Manifest?",
    answer: "A Web App Manifest is a JSON file that tells the browser about your Progressive Web App (PWA) — its name, icons, colors, and how it should behave when installed on a device. It enables features like 'Add to Home Screen', splash screens, and standalone display mode without browser UI."
  },
  {
    question: "What is the difference between 'name' and 'short_name'?",
    answer: "The 'name' field is the full app name shown in the install prompt and app store listings. The 'short_name' is used on the home screen icon label, the app switcher, and anywhere space is limited. Keep short_name to 12 characters or fewer to avoid truncation on most devices."
  },
  {
    question: "Which display mode should I use?",
    answer: "Use 'standalone' for most PWAs — it hides the browser UI and makes the app feel native. Use 'fullscreen' for games or immersive experiences. Use 'minimal-ui' to show a minimal browser toolbar (back/forward, refresh). Use 'browser' to run in a regular browser tab with no PWA chrome."
  },
  {
    question: "What icon sizes do I need?",
    answer: "At minimum, provide 192x192 (used by Android for the home screen icon) and 512x512 (used for install banners and splash screens). For broader coverage, add 144x144 (Android legacy) and 152x152 (iOS). Mark icons as 'maskable' so Android can apply the adaptive icon shape to them."
  },
  {
    question: "What does 'theme_color' control?",
    answer: "The theme_color sets the color of the browser toolbar and the task switcher tile on Android. It should match your app's primary brand color. The 'background_color' is shown on the splash screen while the app loads — it should match your app's initial background to avoid a flash of white."
  },
  {
    question: "How do I link the manifest in my HTML?",
    answer: "Add <link rel=\"manifest\" href=\"/manifest.json\"> in your <head>. Also add <meta name=\"theme-color\" content=\"#your-color\"> for iOS Safari, which does not support theme_color in the manifest. For iOS icons, add <link rel=\"apple-touch-icon\" href=\"/icons/icon-192x192.png\">."
  },
];
---

<BaseLayout
  title="PWA Manifest Generator — Build Web App Manifest JSON"
  description="Generate a valid Web App Manifest (manifest.json) for your Progressive Web App. Configure name, icons, display mode, theme colors, and orientation. Download ready-to-use JSON."
  tool="PWA Manifest Generator, Web App Manifest, manifest.json generator, Progressive Web App, PWA builder"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "PWA Manifest Generator",
    "url": "https://devplaybook.cc/tools/pwa-manifest-generator",
    "description": "Generate a valid Web App Manifest JSON for your Progressive Web App. Configure icons, display mode, theme colors, and download ready-to-use manifest.json.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">PWA Manifest Generator</h1>
  <p class="text-text-muted mb-4">
    Build a valid <code class="font-mono bg-surface px-1 rounded text-sm">manifest.json</code> for your Progressive Web App.
    Configure app metadata, icons, display mode, and theme colors — download or copy the ready-to-use JSON.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Downloadable manifest.json</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 8 icon size options</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs in your browser</span>
  </div>
  <PwaManifestGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="PWA Manifest Generator" relatedTags={['pwa', 'frontend', 'web', 'performance', 'mobile']} />
</BaseLayout>
