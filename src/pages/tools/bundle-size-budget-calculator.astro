---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a performance budget and why does it matter?", answer: "A performance budget sets maximum thresholds for page weight metrics — JS bundle size, CSS size, total page weight, number of requests. Budgets make performance a first-class constraint in development. Google recommends keeping total page weight under 500KB for fast-loading pages, with JavaScript under 200KB compressed. Exceeding budgets should trigger a review before merging code. Tools like Lighthouse, bundlesize, and size-limit can automate budget enforcement in CI." },
  { question: "What is the recommended maximum JavaScript bundle size?", answer: "The commonly cited guideline is 200KB compressed (gzip/brotli) for the initial JavaScript payload on mobile networks. This equates to roughly 800KB–1MB uncompressed, which can take 3–15 seconds to parse on a mid-range Android device. For Total Blocking Time (TBT) to stay below 300ms, you should keep all long tasks under 50ms. HTTP Archive data shows top-performing sites keep JS under 150KB; median sites ship 450KB+." },
  { question: "How does parse time relate to bundle size?", answer: "Every KB of JavaScript must be parsed and compiled by the browser's JS engine before it can execute. Parse time depends on CPU speed, not network speed — a 200KB JS bundle that downloads in 0.1s on 5G still takes ~500ms to parse on a low-end Android phone. This is why bundle size matters even on fast connections. Use code splitting, tree shaking, and dynamic imports to reduce the initial parse cost. Prefer smaller, lazily-loaded chunks." },
  { question: "What is the difference between compressed and uncompressed size?", answer: "Uncompressed size is the raw file size on disk. Compressed size (gzip or brotli) is what gets transferred over the network — typically 60–80% smaller. JavaScript and CSS compress very well; images do not (they're already compressed). Always check compressed sizes for performance budgets, since that's what users actually download. Brotli compresses 10–25% better than gzip and is supported by all modern browsers and CDNs." },
  { question: "How do I enforce bundle size budgets in CI?", answer: "Several tools automate this: size-limit (npm) — define budgets in package.json and fail CI if exceeded. bundlesize — similar, supports glob patterns. Lighthouse CI — runs Lighthouse in CI and fails on budget violations. Webpack Performance Hints — built into webpack with maxAssetSize and maxEntrypointSize. GitHub Actions + bundlestats-action — posts size diffs on every PR. A common workflow: run bundle analysis on every PR and post a size report as a PR comment." },
];
---

<BaseLayout
  title="Bundle Size Budget Calculator — JS, CSS & Page Weight Performance Budgets"
  description="Enter your JavaScript, CSS, image, and font sizes to check against recommended performance budgets. See estimated parse times, network transfer for 3G/4G/5G, and budget pass/fail status."
  tool="bundle size budget calculator, JavaScript bundle size checker, performance budget tool, JS CSS page weight calculator, parse time estimator, 3G 4G 5G transfer time"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Bundle Size Budget Calculator",
    "url": "https://devplaybook.cc/tools/bundle-size-budget-calculator",
    "description": "Calculate JS, CSS, image, and font sizes against performance budgets. See parse times and network transfer estimates for 3G/4G/5G.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Bundle Size Budget Calculator</h1>
  <p class="text-text-muted mb-4">Enter your asset sizes to compare against recommended performance budgets. Get estimated parse times, network transfer speeds for 3G/4G/5G, and pass/fail budget status for each asset type.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> JS / CSS / Image / Font</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Parse time estimate</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 3G / 4G / 5G transfer</span>
  </div>

  <div class="space-y-5">
    <!-- Inputs -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="font-semibold mb-4">Asset Sizes (KB, uncompressed)</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-text-muted mb-1" for="bs-js">JavaScript (KB)</label>
          <input id="bs-js" type="number" min="0" step="1" value="320"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          <div class="text-xs text-text-muted mt-1">Initial bundle only (not lazy chunks)</div>
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-1" for="bs-css">CSS (KB)</label>
          <input id="bs-css" type="number" min="0" step="1" value="80"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          <div class="text-xs text-text-muted mt-1">Above-the-fold stylesheets</div>
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-1" for="bs-img">Images (KB)</label>
          <input id="bs-img" type="number" min="0" step="1" value="500"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          <div class="text-xs text-text-muted mt-1">Total initial image weight</div>
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-1" for="bs-font">Fonts (KB)</label>
          <input id="bs-font" type="number" min="0" step="1" value="60"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          <div class="text-xs text-text-muted mt-1">Loaded web font files</div>
        </div>
      </div>

      <!-- Presets -->
      <div class="mt-4">
        <div class="text-xs text-text-muted mb-2 font-medium uppercase tracking-wide">Site Presets</div>
        <div class="flex flex-wrap gap-2" id="bs-presets"></div>
      </div>

      <button id="bs-calc-btn" class="mt-4 bg-primary text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-primary/80 transition-colors">
        Calculate Budget
      </button>
    </div>

    <!-- Results -->
    <div id="bs-results" class="hidden space-y-4">
      <!-- Summary row -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4" id="bs-summary"></div>

      <!-- Budget breakdown -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold mb-4">Budget Breakdown</h2>
        <div class="space-y-3" id="bs-breakdown"></div>
      </div>

      <!-- Network transfer table -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold mb-4">Network Transfer Times (compressed)</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-text-muted text-xs uppercase tracking-wide border-b border-border">
                <th class="text-left py-2 pr-4">Network</th>
                <th class="text-right py-2 pr-4">Speed</th>
                <th class="text-right py-2 pr-4">Transfer Size</th>
                <th class="text-right py-2">Load Time</th>
              </tr>
            </thead>
            <tbody id="bs-network-table" class="divide-y divide-border"></tbody>
          </table>
        </div>
      </div>

      <!-- Tips -->
      <div class="bg-bg-card border border-border rounded-xl p-5" id="bs-tips-section">
        <h2 class="font-semibold mb-3">Optimization Tips</h2>
        <ul id="bs-tips" class="space-y-2 text-sm text-text-muted"></ul>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Bundle Size Budget Calculator" relatedTags={['performance', 'javascript', 'bundle', 'webpack', 'vite', 'web-vitals']} />
</BaseLayout>

<script is:inline>
(function () {
  var BUDGETS = {
    js:   { label: 'JavaScript', budget: 200,  unit: 'KB', compress: 0.3,  parsePerKB: 0.5 },
    css:  { label: 'CSS',        budget: 50,   unit: 'KB', compress: 0.25, parsePerKB: 0.1 },
    img:  { label: 'Images',     budget: 500,  unit: 'KB', compress: 0.9,  parsePerKB: 0 },
    font: { label: 'Fonts',      budget: 100,  unit: 'KB', compress: 0.8,  parsePerKB: 0 },
  };

  var NETWORKS = [
    { name: '3G Slow',   speed: 400  },
    { name: '3G Fast',   speed: 1500 },
    { name: '4G LTE',    speed: 12000 },
    { name: '5G',        speed: 100000 },
  ];

  var PRESETS = [
    { label: 'Lean SPA', js: 150, css: 30, img: 200, font: 40 },
    { label: 'Typical React', js: 450, css: 80, img: 600, font: 80 },
    { label: 'Heavy E-commerce', js: 900, css: 200, img: 2000, font: 120 },
    { label: 'Static blog', js: 50, css: 20, img: 300, font: 60 },
  ];

  var presetsEl = document.getElementById('bs-presets');
  PRESETS.forEach(function (p) {
    var btn = document.createElement('button');
    btn.className = 'px-3 py-1 text-xs rounded-lg border border-border bg-bg hover:bg-primary/10 hover:border-primary/40 transition-colors';
    btn.textContent = p.label;
    btn.addEventListener('click', function () {
      document.getElementById('bs-js').value = p.js;
      document.getElementById('bs-css').value = p.css;
      document.getElementById('bs-img').value = p.img;
      document.getElementById('bs-font').value = p.font;
      calculate();
    });
    presetsEl.appendChild(btn);
  });

  function statusColor(pct) {
    if (pct <= 1) return 'text-green-400';
    if (pct <= 1.5) return 'text-yellow-400';
    return 'text-red-400';
  }

  function statusLabel(pct) {
    if (pct <= 1) return { label: 'Within budget', color: 'text-green-400', bg: 'bg-green-500/10' };
    if (pct <= 1.5) return { label: 'Over budget', color: 'text-yellow-400', bg: 'bg-yellow-500/10' };
    return { label: 'Far over budget', color: 'text-red-400', bg: 'bg-red-500/10' };
  }

  function calculate() {
    var values = {
      js:   parseFloat(document.getElementById('bs-js').value) || 0,
      css:  parseFloat(document.getElementById('bs-css').value) || 0,
      img:  parseFloat(document.getElementById('bs-img').value) || 0,
      font: parseFloat(document.getElementById('bs-font').value) || 0,
    };

    var totalUncompressed = values.js + values.css + values.img + values.font;
    var totalCompressed = 0;
    var totalParseMs = 0;
    Object.keys(BUDGETS).forEach(function (k) {
      var b = BUDGETS[k];
      totalCompressed += values[k] * b.compress;
      totalParseMs += values[k] * b.parsePerKB;
    });

    var jsOverBudget = values.js > BUDGETS.js.budget;

    // Summary
    var summary = document.getElementById('bs-summary');
    summary.innerHTML = '';
    var summaryItems = [
      { label: 'Total Page Weight', value: totalUncompressed.toFixed(0) + ' KB', sub: 'uncompressed', color: totalUncompressed > 1500 ? 'text-red-400' : totalUncompressed > 800 ? 'text-yellow-400' : 'text-green-400' },
      { label: 'Compressed Transfer', value: totalCompressed.toFixed(0) + ' KB', sub: 'gzip estimate', color: totalCompressed > 500 ? 'text-yellow-400' : 'text-green-400' },
      { label: 'JS Parse Time', value: totalParseMs.toFixed(0) + ' ms', sub: 'mid-range mobile', color: totalParseMs > 800 ? 'text-red-400' : totalParseMs > 400 ? 'text-yellow-400' : 'text-green-400' },
      { label: 'JS Budget', value: values.js + ' KB', sub: 'budget: 200 KB', color: jsOverBudget ? 'text-red-400' : 'text-green-400' },
    ];
    summaryItems.forEach(function (item) {
      var card = document.createElement('div');
      card.className = 'bg-bg-card border border-border rounded-xl p-4';
      card.innerHTML = '<div class="text-xs text-text-muted mb-1">' + item.label + '</div>'
        + '<div class="text-xl font-bold ' + item.color + '">' + item.value + '</div>'
        + '<div class="text-xs text-text-muted">' + item.sub + '</div>';
      summary.appendChild(card);
    });

    // Breakdown bars
    var breakdown = document.getElementById('bs-breakdown');
    breakdown.innerHTML = '';
    Object.keys(BUDGETS).forEach(function (k) {
      var b = BUDGETS[k];
      var val = values[k];
      var pct = val / b.budget;
      var st = statusLabel(pct);
      var barPct = Math.min(pct * 100, 100);
      var overBudgetPct = pct > 1 ? Math.min((pct - 1) * 100, 50) : 0;
      var row = document.createElement('div');
      row.innerHTML = '<div class="flex items-center justify-between mb-1">'
        + '<span class="text-sm font-medium">' + b.label + '</span>'
        + '<div class="flex items-center gap-3 text-sm">'
        + '<span class="font-mono text-text-muted">' + val + ' KB</span>'
        + '<span class="text-xs text-text-muted">budget: ' + b.budget + ' KB</span>'
        + '<span class="text-xs ' + st.color + ' font-medium">' + st.label + '</span>'
        + '</div></div>'
        + '<div class="relative h-4 bg-bg rounded-full overflow-hidden">'
        + '<div class="absolute left-0 top-0 h-full rounded-full transition-all ' + (pct <= 1 ? 'bg-primary/60' : pct <= 1.5 ? 'bg-yellow-500/60' : 'bg-red-500/60') + '" style="width:' + Math.min(barPct, 100) + '%"></div>'
        + '<div class="absolute top-0 h-full border-l-2 border-white/30" style="left:' + Math.min(100 / pct * 100, 100) + '%"></div>'
        + '</div>';
      breakdown.appendChild(row);
    });

    // Network table
    var networkTable = document.getElementById('bs-network-table');
    networkTable.innerHTML = '';
    NETWORKS.forEach(function (n) {
      var loadMs = (totalCompressed * 8) / n.speed * 1000;
      var loadStr = loadMs < 1000 ? loadMs.toFixed(0) + ' ms' : (loadMs / 1000).toFixed(1) + ' s';
      var tr = document.createElement('tr');
      tr.innerHTML = '<td class="py-2.5 pr-4 font-medium">' + n.name + '</td>'
        + '<td class="py-2.5 pr-4 text-right text-text-muted font-mono text-xs">' + (n.speed >= 1000 ? (n.speed / 1000).toFixed(0) + ' Mbps' : n.speed + ' Kbps') + '</td>'
        + '<td class="py-2.5 pr-4 text-right font-mono">' + totalCompressed.toFixed(0) + ' KB</td>'
        + '<td class="py-2.5 text-right font-mono font-semibold ' + (loadMs > 3000 ? 'text-red-400' : loadMs > 1000 ? 'text-yellow-400' : 'text-green-400') + '">' + loadStr + '</td>';
      networkTable.appendChild(tr);
    });

    // Tips
    var tips = document.getElementById('bs-tips');
    tips.innerHTML = '';
    var tipsList = [];
    if (values.js > BUDGETS.js.budget) tipsList.push('JavaScript (' + values.js + ' KB) exceeds the 200 KB budget. Use code splitting, tree shaking, and dynamic imports to reduce initial bundle size.');
    if (values.css > BUDGETS.css.budget) tipsList.push('CSS (' + values.css + ' KB) exceeds the 50 KB budget. Remove unused styles with PurgeCSS/Tailwind purge, and split critical from non-critical CSS.');
    if (values.img > 800) tipsList.push('Images (' + values.img + ' KB) are large. Convert to WebP/AVIF, use responsive srcset, and lazy-load below-fold images.');
    if (values.font > BUDGETS.font.budget) tipsList.push('Fonts (' + values.font + ' KB) are heavy. Use subsetting (only load characters you need), prefer system fonts for body text, and use font-display: swap or optional.');
    if (totalParseMs > 500) tipsList.push('Estimated JS parse time (' + totalParseMs.toFixed(0) + ' ms) will cause noticeable delays on mobile. Reduce JS bundle size or defer parsing with async/defer.');
    if (tipsList.length === 0) tipsList.push('All budgets look good! Keep monitoring bundle sizes with size-limit or bundlesize in your CI pipeline.');

    tipsList.forEach(function (t) {
      var li = document.createElement('li');
      li.className = 'flex gap-2';
      li.innerHTML = '<span class="text-primary shrink-0 mt-0.5">→</span><span>' + t + '</span>';
      tips.appendChild(li);
    });

    document.getElementById('bs-results').classList.remove('hidden');
    document.getElementById('bs-results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  document.getElementById('bs-calc-btn').addEventListener('click', calculate);
  calculate();
})();
</script>
