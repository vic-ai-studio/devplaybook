---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RateLimiterTester from '../../components/RateLimiterTester.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is rate limiting?", answer: "Rate limiting restricts how many requests a client can make in a given time window. It protects APIs from abuse, prevents DDoS attacks, ensures fair usage among clients, and controls infrastructure costs. Common limits: 100 req/min for public APIs, 1000 req/min for authenticated users." },
  { question: "What is the token bucket algorithm?", answer: "Token bucket maintains a bucket of tokens that refills at a constant rate (e.g., 10 tokens/min). Each request consumes one token. If the bucket is empty, the request is rejected. The bucket has a max capacity (burst size) that limits sudden spikes. It allows short bursts while enforcing a long-term average rate." },
  { question: "What is the sliding window algorithm?", answer: "Sliding window tracks request timestamps within a rolling time window. Unlike fixed window, it doesn't reset at a set clock time — the window slides forward with each request. This prevents the boundary spike problem where clients double their rate by sending requests just before and after a window reset." },
  { question: "What is the fixed window algorithm?", answer: "Fixed window divides time into discrete windows (e.g., each minute from :00 to :59). It counts requests in the current window and resets the counter at the window boundary. Simple to implement but vulnerable to boundary spikes: a client can send max_requests at :59 and again at :00 for 2x the intended rate." },
  { question: "What HTTP status code does rate limiting return?", answer: "429 Too Many Requests is the standard HTTP status code for rate limiting. APIs also typically include Retry-After header (seconds until the rate limit resets), X-RateLimit-Limit (max requests), X-RateLimit-Remaining (requests left in current window), and X-RateLimit-Reset (Unix timestamp of window reset)." },
];
---

<BaseLayout
  title="Rate Limiter Tester — Simulate Token Bucket, Sliding Window & Fixed Window"
  description="Interactively test rate limiting algorithms in your browser. Simulate token bucket, sliding window, and fixed window rate limits. Send single requests, flood with 10 at once, or run auto-fire mode. See which requests are allowed or throttled (429) in real time."
  tool="Rate Limiter Tester, Token Bucket Simulator, Sliding Window Rate Limiter, Fixed Window Rate Limiter, API Throttle Tester"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Rate Limiter Tester</h1>
  <p class="text-text-muted mb-4">
    Simulate rate limiting algorithms directly in your browser — no server required.
    Choose between <strong>Token Bucket</strong>, <strong>Sliding Window</strong>, and <strong>Fixed Window</strong>,
    configure your limits, then fire requests manually or use flood/auto mode to see exactly when throttling kicks in.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All 3 major algorithms</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live token/window gauge</span>
  </div>
  <RateLimiterTester client:load />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Rate Limiter Tester" relatedTags={['api', 'rate-limiting', 'throttle', 'backend', 'http', 'developer-tools']} />
</BaseLayout>
