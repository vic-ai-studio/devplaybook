---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CronGenerator from '../../components/CronGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Cron Expression Generator — Free Online Tool"
  description="Build and validate cron expressions online with a visual interface. See the next 5 run times in plain English. Presets for common schedules like every hour, daily, and weekly. Free, no signup."
  tool="Cron Generator, Cron Expression Builder, Cron Schedule Generator, Cron Validator"
>
  <h1 class="text-3xl font-bold mb-2">Cron Expression Generator</h1>
  <p class="text-text-muted mb-8">Build cron expressions visually and see the next run times in plain English. Choose from common presets — every minute, hourly, daily, weekly — or build a custom schedule for any automation task.</p>
  <CronGenerator client:load />
  <ToolPageCta currentTool="Cron Expression Generator" relatedTags={['automation', 'devops', 'ci-cd', 'bash']} />
</BaseLayout>
