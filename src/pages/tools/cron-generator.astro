---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CronGenerator from '../../components/CronGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout title="Cron Expression Generator" description="Generate and validate cron expressions with a visual interface. See next run times and usage examples." tool="Cron Generator, Cron Validator, Cron Schedule Builder">
  <h1 class="text-3xl font-bold mb-2">Cron Expression Generator</h1>
  <p class="text-text-muted mb-8">Build cron expressions visually with real-time descriptions and next run previews.</p>
  <CronGenerator client:load />
  <ToolPageCta currentTool="Cron Expression Generator" relatedTags={['automation', 'devops', 'ci-cd', 'bash']} />
</BaseLayout>
