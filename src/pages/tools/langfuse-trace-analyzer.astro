---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is LangFuse?", answer: "LangFuse is an open-source LLM observability and analytics platform. It provides tracing for LLM calls, RAG pipelines, and agent workflows — giving you visibility into latency, token usage, cost, and quality scores. It supports the OpenTelemetry standard and integrates with LangChain, OpenAI SDK, Anthropic, and custom code." },
  { question: "What is the difference between a trace, span, and observation in LangFuse?", answer: "A Trace is the top-level container representing a single user request or workflow run. Spans are time-bounded operations within a trace (e.g., a database lookup). Observations are LLM-specific spans: Generation (an LLM call with input/output/tokens) or Event (a discrete non-LLM action like a cache hit). Spans can nest to show call hierarchy." },
  { question: "How do I add LangFuse tracing to existing code?", answer: "Option 1: Use the LangFuse SDK directly (langfuse.trace(), langfuse.generation()). Option 2: Use @observe() decorator in Python for automatic tracing. Option 3: Use integration wrappers for LangChain or OpenAI (observe_openai()). Option 4: Use the OpenTelemetry exporter for standard OTEL instrumentation." },
  { question: "What is a LangFuse score and how does it work?", answer: "Scores let you attach quality metrics to traces. Types: manual (human labels), model-based (LLM-as-judge), and custom (from your app). Common scores: relevance (0-1), faithfulness (0-1), toxicity (bool). Use scores to track quality over time, filter for bad traces, and train feedback loops." },
  { question: "Can I use LangFuse self-hosted?", answer: "Yes — LangFuse is fully open-source (MIT license). Self-host with Docker Compose or Kubernetes. The cloud version (cloud.langfuse.com) has a free tier. Self-hosted gives you full data control and no per-event pricing. Use environment variables LANGFUSE_SECRET_KEY, LANGFUSE_PUBLIC_KEY, and LANGFUSE_HOST to configure." },
];
---

<BaseLayout
  title="LangFuse Trace Analyzer — Build LLM Trace & Observation Schemas for Debugging"
  description="Build LangFuse trace and observation schemas for LLM debugging. Generate tracing code for Python, Node.js with generations, spans, scores, and session tracking."
  tool="LangFuse Trace Builder, LLM Trace Schema Generator, LangFuse Observation Builder, LLM Debugging Tool, LangFuse Integration Code Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">LangFuse Trace Analyzer</h1>
  <p class="text-text-muted mb-4">Build LangFuse trace and observation schemas for LLM debugging. Generate ready-to-use tracing code with generations, spans, scores, and session tracking.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Trace & generation builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Score tracking</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Session support</span>
  </div>

  <!-- Trace Config -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Trace Configuration</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Language</label>
        <select id="lang" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="python" selected>Python</option>
          <option value="node">Node.js</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Trace Name</label>
        <input id="trace-name" type="text" value="chat-completion"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">User ID</label>
        <input id="user-id" type="text" value="user_123"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Session ID</label>
        <input id="session-id" type="text" value="sess_abc456"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Environment</label>
        <select id="environment" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="production">production</option>
          <option value="staging">staging</option>
          <option value="development" selected>development</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">LangFuse Host</label>
        <input id="host" type="text" value="https://cloud.langfuse.com"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Custom Tags (comma-separated)</label>
        <input id="tags" type="text" value="chat,gpt4o,production"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Input (user message summary)</label>
        <input id="trace-input" type="text" value="How do I use Python async/await?"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
    </div>
  </div>

  <!-- Generation (LLM Call) -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Generation (LLM Call)</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Model</label>
        <input id="model" type="text" value="gpt-4o"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Generation Name</label>
        <input id="gen-name" type="text" value="llm-response"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Input Tokens</label>
        <input id="input-tokens" type="number" value="512" min="0"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Output Tokens</label>
        <input id="output-tokens" type="number" value="256" min="0"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mt-3">
      <label class="flex items-center gap-2 cursor-pointer">
        <input id="opt-system" type="checkbox" checked class="rounded" />
        <span class="text-sm">System prompt</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer">
        <input id="opt-completion" type="checkbox" checked class="rounded" />
        <span class="text-sm">Completion output</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer">
        <input id="opt-latency" type="checkbox" checked class="rounded" />
        <span class="text-sm">Latency tracking</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer">
        <input id="opt-cost" type="checkbox" checked class="rounded" />
        <span class="text-sm">Cost tracking</span>
      </label>
    </div>
  </div>

  <!-- Scores -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <div class="flex items-center gap-3 mb-3">
      <h2 class="text-base font-semibold">Quality Scores</h2>
      <label class="flex items-center gap-2 cursor-pointer ml-auto">
        <input id="opt-scores" type="checkbox" checked class="rounded" />
        <span class="text-sm">Include scores</span>
      </label>
    </div>
    <div id="scores-config" class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <label class="flex items-center gap-2 cursor-pointer p-2 border border-border rounded-lg">
        <input type="checkbox" class="score-check rounded" data-score="relevance" checked />
        <span class="text-sm">Relevance (0-1)</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer p-2 border border-border rounded-lg">
        <input type="checkbox" class="score-check rounded" data-score="faithfulness" />
        <span class="text-sm">Faithfulness (0-1)</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer p-2 border border-border rounded-lg">
        <input type="checkbox" class="score-check rounded" data-score="toxicity" />
        <span class="text-sm">Toxicity (bool)</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer p-2 border border-border rounded-lg">
        <input type="checkbox" class="score-check rounded" data-score="user_feedback" />
        <span class="text-sm">User Feedback</span>
      </label>
    </div>
  </div>

  <!-- Generated Code -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-base font-semibold">Generated Tracing Code</h2>
      <button id="copy-btn" class="text-xs bg-primary/10 hover:bg-primary/20 text-primary px-3 py-1.5 rounded-lg transition-colors">Copy</button>
    </div>
    <pre id="code-output" class="bg-bg-card border border-border rounded-lg p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text leading-relaxed"></pre>
  </div>

  <!-- Schema Visualization -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-3">Trace Hierarchy</h2>
    <div id="schema-viz" class="text-sm font-mono space-y-1"></div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="LangFuse Trace Analyzer" relatedTags={['langfuse', 'observability', 'llm', 'tracing', 'debugging', 'monitoring']} />
</BaseLayout>

<script>
  function getVal(id: string): string {
    return (document.getElementById(id) as HTMLInputElement).value;
  }
  function isChecked(id: string): boolean {
    return (document.getElementById(id) as HTMLInputElement).checked;
  }
  function getScores(): string[] {
    return Array.from(document.querySelectorAll('.score-check'))
      .filter(el => (el as HTMLInputElement).checked)
      .map(el => (el as HTMLInputElement).getAttribute('data-score') || '');
  }

  function generatePython(): string {
    const traceName = getVal('trace-name');
    const userId = getVal('user-id');
    const sessionId = getVal('session-id');
    const environment = getVal('environment');
    const host = getVal('host');
    const tags = getVal('tags').split(',').map(t => t.trim()).filter(Boolean);
    const traceInput = getVal('trace-input');
    const model = getVal('model');
    const genName = getVal('gen-name');
    const inputTokens = getVal('input-tokens');
    const outputTokens = getVal('output-tokens');
    const hasSystem = isChecked('opt-system');
    const hasCompletion = isChecked('opt-completion');
    const hasLatency = isChecked('opt-latency');
    const hasCost = isChecked('opt-cost');
    const hasScores = isChecked('opt-scores');
    const scores = getScores();

    const genFields: string[] = [
      `        name="${genName}",`,
      `        model="${model}",`,
      `        input=messages,`,
    ];
    if (hasSystem) genFields.push(`        model_parameters={"system": SYSTEM_PROMPT, "temperature": 0.7},`);
    if (hasCompletion) genFields.push(`        output=response.choices[0].message.content,`);
    genFields.push(`        usage={`);
    genFields.push(`            "input": ${inputTokens},`);
    genFields.push(`            "output": ${outputTokens},`);
    genFields.push(`            "total": ${parseInt(inputTokens) + parseInt(outputTokens)},`);
    if (hasCost) genFields.push(`            "unit": "TOKENS",`);
    genFields.push(`        },`);

    const scoreLines: string[] = [];
    if (hasScores && scores.length) {
      scores.forEach(score => {
        const isNum = score !== 'toxicity';
        const val = score === 'relevance' ? '0.85' : score === 'faithfulness' ? '0.90' : '0';
        const comment = isNum ? '# 0.0 - 1.0' : '# 0 = false, 1 = true';
        scoreLines.push(`    langfuse.score(`);
        scoreLines.push(`        trace_id=trace.id,`);
        scoreLines.push(`        name="${score}",`);
        scoreLines.push(`        value=${val},  ${comment}`);
        scoreLines.push(`        data_type="${isNum ? 'NUMERIC' : 'BOOLEAN'}",`);
        scoreLines.push(`    )`);
      });
    }

    return `import os
import time
from langfuse import Langfuse
from openai import OpenAI

# Initialize LangFuse
langfuse = Langfuse(
    secret_key=os.environ["LANGFUSE_SECRET_KEY"],
    public_key=os.environ["LANGFUSE_PUBLIC_KEY"],
    host="${host}",
)

openai_client = OpenAI()
SYSTEM_PROMPT = "You are a helpful assistant."
${hasLatency ? '\nstart_time = time.time()' : ''}
# Create trace
trace = langfuse.trace(
    name="${traceName}",
    user_id="${userId}",
    session_id="${sessionId}",
    input="${traceInput.replace(/"/g, '\\"')}",
    tags=${JSON.stringify(tags)},
    metadata={"environment": "${environment}"},
)

messages = [
    {"role": "system", "content": SYSTEM_PROMPT},
    {"role": "user", "content": "${traceInput.replace(/"/g, '\\"')}"},
]

# LLM call
response = openai_client.chat.completions.create(
    model="${model}",
    messages=messages,
)
${hasLatency ? '\nlatency_ms = (time.time() - start_time) * 1000' : ''}
# Log generation
generation = trace.generation(
${genFields.join('\n')}${hasLatency ? '\n        metadata={"latency_ms": round(latency_ms, 2)},' : ''}
)
generation.end()

trace.update(output=response.choices[0].message.content)
${scoreLines.length ? '\n# Add quality scores\n' + scoreLines.join('\n') : ''}
# Flush before exit (important in serverless!)
langfuse.flush()

print("Trace ID:", trace.id)
print("View at: ${host}/trace/" + trace.id)`;
  }

  function generateNode(): string {
    const traceName = getVal('trace-name');
    const userId = getVal('user-id');
    const sessionId = getVal('session-id');
    const environment = getVal('environment');
    const host = getVal('host');
    const tags = getVal('tags').split(',').map(t => t.trim()).filter(Boolean);
    const traceInput = getVal('trace-input');
    const model = getVal('model');
    const genName = getVal('gen-name');
    const inputTokens = getVal('input-tokens');
    const outputTokens = getVal('output-tokens');
    const hasLatency = isChecked('opt-latency');
    const hasCost = isChecked('opt-cost');
    const hasScores = isChecked('opt-scores');
    const scores = getScores();

    const scoreLines: string[] = [];
    if (hasScores && scores.length) {
      scores.forEach(score => {
        const val = score === 'relevance' ? 0.85 : score === 'faithfulness' ? 0.90 : 0;
        scoreLines.push(`  await langfuse.score({`);
        scoreLines.push(`    traceId: trace.id,`);
        scoreLines.push(`    name: '${score}',`);
        scoreLines.push(`    value: ${val},`);
        scoreLines.push(`    dataType: '${score === 'toxicity' ? 'BOOLEAN' : 'NUMERIC'}',`);
        scoreLines.push(`  });`);
      });
    }

    return `import { Langfuse } from 'langfuse';
import OpenAI from 'openai';

const langfuse = new Langfuse({
  secretKey: process.env.LANGFUSE_SECRET_KEY!,
  publicKey: process.env.LANGFUSE_PUBLIC_KEY!,
  baseUrl: '${host}',
});

const openai = new OpenAI();

async function tracedRequest() {
  ${hasLatency ? 'const startTime = Date.now();\n  ' : ''}const trace = langfuse.trace({
    name: '${traceName}',
    userId: '${userId}',
    sessionId: '${sessionId}',
    input: '${traceInput.replace(/'/g, "\\'")}',
    tags: ${JSON.stringify(tags)},
    metadata: { environment: '${environment}' },
  });

  const messages = [
    { role: 'system' as const, content: 'You are a helpful assistant.' },
    { role: 'user' as const, content: '${traceInput.replace(/'/g, "\\'")}' },
  ];

  const generation = trace.generation({
    name: '${genName}',
    model: '${model}',
    input: messages,
  });

  const response = await openai.chat.completions.create({
    model: '${model}',
    messages,
  });

  const output = response.choices[0].message.content;
  ${hasLatency ? 'const latencyMs = Date.now() - startTime;\n  ' : ''}
  generation.end({
    output,
    usage: { input: ${inputTokens}, output: ${outputTokens}, total: ${parseInt(inputTokens) + parseInt(outputTokens)} },${hasCost ? "\n    metadata: { model_params: { temperature: 0.7 } }," : ''}${hasLatency ? '\n    metadata: { latencyMs },' : ''}
  });

  trace.update({ output });
${scoreLines.length ? '\n' + scoreLines.join('\n') + '\n' : ''}
  // Flush before Lambda/Edge exit
  await langfuse.flushAsync();

  console.log('Trace ID:', trace.id);
  console.log('View at: ${host}/trace/' + trace.id);
  return output;
}

tracedRequest().catch(console.error);`;
  }

  function generateSchemaViz(): string {
    const traceName = getVal('trace-name');
    const genName = getVal('gen-name');
    const model = getVal('model');
    const hasScores = isChecked('opt-scores');
    const scores = getScores();

    const lines = [
      `<span class="text-blue-400">Trace</span>: <span class="text-text">${traceName}</span>`,
      `<span class="text-text-muted">  ├─ user_id: ${getVal('user-id')}</span>`,
      `<span class="text-text-muted">  ├─ session_id: ${getVal('session-id')}</span>`,
      `<span class="text-text-muted">  ├─ tags: [${getVal('tags')}]</span>`,
      `<span class="text-green-400">  └─ Generation</span>: <span class="text-text">${genName}</span>`,
      `<span class="text-text-muted">       ├─ model: ${model}</span>`,
      `<span class="text-text-muted">       ├─ usage: ${getVal('input-tokens')} in + ${getVal('output-tokens')} out</span>`,
    ];
    if (hasScores && scores.length) {
      scores.forEach((s, i) => {
        const prefix = i < scores.length - 1 ? '├─' : '└─';
        lines.push(`<span class="text-yellow-400">       ${prefix} Score</span>: <span class="text-text">${s}</span>`);
      });
    }
    return lines.join('\n');
  }

  function update() {
    const lang = getVal('lang');
    document.getElementById('code-output')!.textContent = lang === 'python' ? generatePython() : generateNode();
    document.getElementById('schema-viz')!.innerHTML = generateSchemaViz();
  }

  document.getElementById('copy-btn')!.addEventListener('click', () => {
    const code = (document.getElementById('code-output') as HTMLPreElement).textContent || '';
    navigator.clipboard.writeText(code).then(() => {
      const btn = document.getElementById('copy-btn')!;
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 1500);
    });
  });

  document.querySelectorAll('input, select').forEach(el => el.addEventListener('input', update));
  update();
</script>
