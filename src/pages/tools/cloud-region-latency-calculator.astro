          class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div class="flex-1">
        <label class="block text-sm font-medium mb-1.5">Common Distances</label>
        <div class="flex flex-wrap gap-2" id="distance-presets">
          <!-- Filled by JS -->
        </div>
      </div>
    </div>
    <div id="sol-result" class="mt-4 p-4 bg-bg-surface border border-border rounded-lg hidden">
