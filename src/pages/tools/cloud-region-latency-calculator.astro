        <div>
          <div class="text-2xl font-bold text-primary" id="sol-min-rtt">—</div>
          <div class="text-xs text-text-muted mt-1">Theoretical Min RTT</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-yellow-400" id="sol-typical-rtt">—</div>
          <div class="text-xs text-text-muted mt-1">Typical Real-World RTT</div>
        </div>
        <div>
          <div class="text-2xl font-bold" id="sol-distance">—</div>
          <div class="text-xs text-text-muted mt-1">Distance</div>
        </div>
        <div>
          <div class="text-2xl font-bold" id="sol-fiber-speed">200,000 km/s</div>
          <div class="text-xs text-text-muted mt-1">Fiber Speed</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Multi-region strategy -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-3">Multi-Region Deployment Strategy</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <!-- Active-Active -->
      <div class="bg-bg-surface border border-border rounded-lg p-4">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-green-400 text-lg">⬡</span>
          <h3 class="font-semibold text-sm">Active-Active</h3>
          <span class="text-xs px-2 py-0.5 bg-green-500/15 text-green-400 rounded-full border border-green-500/30">Best latency</span>
        </div>
        <ul class="text-xs text-text-muted space-y-1.5">
          <li class="flex items-start gap-1.5"><span class="text-green-500 shrink-0 mt-0.5">✓</span> All regions accept reads and writes simultaneously</li>
          <li class="flex items-start gap-1.5"><span class="text-green-500 shrink-0 mt-0.5">✓</span> Users routed to nearest region — lowest possible RTT</li>
          <li class="flex items-start gap-1.5"><span class="text-green-500 shrink-0 mt-0.5">✓</span> No single region is the bottleneck</li>
          <li class="flex items-start gap-1.5"><span class="text-yellow-500 shrink-0 mt-0.5">△</span> Requires conflict resolution for concurrent writes</li>
          <li class="flex items-start gap-1.5"><span class="text-yellow-500 shrink-0 mt-0.5">△</span> Needs a globally distributed database (CockroachDB, Spanner)</li>
          <li class="flex items-start gap-1.5"><span class="text-red-400 shrink-0 mt-0.5">✗</span> High operational complexity — best for 50k+ RPS</li>
        </ul>
      </div>
      <!-- Active-Passive -->
      <div class="bg-bg-surface border border-border rounded-lg p-4">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-blue-400 text-lg">⬡</span>
          <h3 class="font-semibold text-sm">Active-Passive</h3>
          <span class="text-xs px-2 py-0.5 bg-blue-500/15 text-blue-400 rounded-full border border-blue-500/30">Simpler to operate</span>
        </div>
        <ul class="text-xs text-text-muted space-y-1.5">
          <li class="flex items-start gap-1.5"><span class="text-green-500 shrink-0 mt-0.5">✓</span> One primary region handles all writes</li>
          <li class="flex items-start gap-1.5"><span class="text-green-500 shrink-0 mt-0.5">✓</span> Read replicas in other regions for local read latency</li>
          <li class="flex items-start gap-1.5"><span class="text-green-500 shrink-0 mt-0.5">✓</span> Standard replication, no conflict resolution needed</li>
          <li class="flex items-start gap-1.5"><span class="text-green-500 shrink-0 mt-0.5">✓</span> Failover to passive region if primary goes down</li>
          <li class="flex items-start gap-1.5"><span class="text-yellow-500 shrink-0 mt-0.5">△</span> Write latency is high for users far from primary</li>
          <li class="flex items-start gap-1.5"><span class="text-yellow-500 shrink-0 mt-0.5">△</span> Read replicas may serve slightly stale data</li>
        </ul>
      </div>
    </div>
    <!-- CDN considerations -->
    <div class="mt-4 bg-bg-surface border border-primary/20 rounded-lg p-4">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-primary text-lg">◈</span>
        <h3 class="font-semibold text-sm text-primary">CDN Considerations</h3>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 text-xs text-text-muted">
        <div>
          <div class="font-medium text-white mb-1">Use CDN for</div>
          <ul class="space-y-0.5">
            <li>• Static assets (JS/CSS/images)</li>
            <li>• Cacheable API responses</li>
            <li>• HTML pages (ISR/SSG)</li>
            <li>• Video and large files</li>
          </ul>
        </div>
        <div>
          <div class="font-medium text-white mb-1">Skip CDN for</div>
          <ul class="space-y-0.5">
            <li>• Personalized API responses</li>
            <li>• Real-time writes / mutations</li>
            <li>• Auth-gated dynamic content</li>
            <li>• WebSocket connections</li>
          </ul>
        </div>
        <div>
          <div class="font-medium text-white mb-1">Edge compute options</div>
          <ul class="space-y-0.5">
            <li>• Cloudflare Workers (&lt;1ms)</li>
            <li>• Fastly Compute@Edge</li>
            <li>• AWS Lambda@Edge</li>
            <li>• Vercel Edge Functions</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Multi-Cloud Region Latency Calculator" relatedTags={['cloud', 'aws', 'gcp', 'azure', 'performance', 'devops', 'networking']} />
</BaseLayout>

