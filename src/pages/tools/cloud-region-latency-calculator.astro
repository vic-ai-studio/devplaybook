  var DISTANCE_PRESETS = [
    { label: 'NYC → London', km: 5570 },
    { label: 'NYC → Tokyo',  km: 10838 },
    { label: 'LA → Singapore', km: 14100 },
    { label: 'London → Singapore', km: 10840 },
    { label: 'NYC → São Paulo', km: 7695 },
    { label: 'Frankfurt → Mumbai', km: 6200 },
  ];

  // ─── Helpers ───────────────────────────────────────────────────────────────

  var RAD = Math.PI / 180;

  function haversine(lat1, lon1, lat2, lon2) {
    var dLat = (lat2 - lat1) * RAD;
    var dLon = (lon2 - lon1) * RAD;
    var a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
      Math.cos(lat1 * RAD) * Math.cos(lat2 * RAD) *
      Math.sin(dLon / 2) * Math.sin(dLon / 2);
    return 6371 * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  }

  function estimateRTT(distKm) {
    // Fiber speed ~200,000 km/s → propagation delay one-way = dist/200000 * 1000 ms
    // RTT = 2x one-way + processing overhead (min 2ms) + routing overhead (~30% of propagation)
    var propagation = (distKm / 200000) * 1000; // one-way ms
    var rtt = propagation * 2 * 1.3 + 2; // 1.3x for routing + 2ms floor
    return Math.max(2, Math.round(rtt));
  }

  function latencyColor(ms) {
    if (ms < 50) return { bg: 'bg-green-500/15', border: 'border-green-500/50', text: 'text-green-400' };
    if (ms < 150) return { bg: 'bg-yellow-500/10', border: 'border-yellow-500/40', text: 'text-yellow-400' };
    return { bg: 'bg-red-500/10', border: 'border-red-500/40', text: 'text-red-400' };
  }

  function providerBadgeClass(p) {
    if (p === 'aws') return 'text-orange-400 bg-orange-500/10 border-orange-500/30';
    if (p === 'gcp') return 'text-blue-400 bg-blue-500/10 border-blue-500/30';
    return 'text-cyan-400 bg-cyan-500/10 border-cyan-500/30';
  }

  function providerLabel(p) {
    if (p === 'aws') return 'AWS';
    if (p === 'gcp') return 'GCP';
    return 'Azure';
  }

  // ─── DOM refs ──────────────────────────────────────────────────────────────

  var sourceSelect = document.getElementById('source-select');
  var resultsContainer = document.getElementById('results-container');
  var noProviderMsg = document.getElementById('no-provider-msg');
  var recoPanel = document.getElementById('recommendations-panel');
  var recoUnder50List = document.getElementById('reco-under50-list');
  var recoUnder150List = document.getElementById('reco-under150-list');
  var recoPrimaryText = document.getElementById('reco-primary-text');
  var distanceInput = document.getElementById('distance-input');
  var solResult = document.getElementById('sol-result');
  var solMinRtt = document.getElementById('sol-min-rtt');
  var solTypicalRtt = document.getElementById('sol-typical-rtt');
  var solDistance = document.getElementById('sol-distance');

  // ─── Populate source select ────────────────────────────────────────────────

  SOURCE_REGIONS.forEach(function(r) {
    var opt = document.createElement('option');
    opt.value = r.id;
    opt.textContent = r.label;
    sourceSelect.appendChild(opt);
  });

  // ─── Populate distance presets ────────────────────────────────────────────

  var presetsEl = document.getElementById('distance-presets');
  DISTANCE_PRESETS.forEach(function(p) {
    var btn = document.createElement('button');
    btn.className = 'text-xs px-2.5 py-1 bg-bg-surface border border-border rounded-lg hover:border-primary text-text-muted hover:text-primary transition-colors';
    btn.textContent = p.label + ' (' + p.km.toLocaleString() + ' km)';
    btn.addEventListener('click', function() {
      distanceInput.value = p.km;
      calcSOL();
    });
    presetsEl.appendChild(btn);
  });

  // ─── Speed of light calculator ────────────────────────────────────────────

  function calcSOL() {
    var km = parseFloat(distanceInput.value);
    if (!km || km <= 0) { solResult.classList.add('hidden'); return; }
    var minRtt = Math.round((km / 200000) * 2 * 1000 * 10) / 10;
    var typicalRtt = Math.round(minRtt * 1.5);
    solMinRtt.textContent = minRtt.toFixed(1) + ' ms';
    solTypicalRtt.textContent = typicalRtt + ' ms';
    solDistance.textContent = km.toLocaleString() + ' km';
    solResult.classList.remove('hidden');
  }

  distanceInput.addEventListener('input', calcSOL);
  calcSOL();

  // ─── Main render ──────────────────────────────────────────────────────────

  function render() {
    var sourceId = sourceSelect.value;
    var source = SOURCE_REGIONS.find(function(r) { return r.id === sourceId; });
    if (!source) return;

    var showAws = document.getElementById('toggle-aws').checked;
    var showGcp = document.getElementById('toggle-gcp').checked;
    var showAzure = document.getElementById('toggle-azure').checked;

    var anySelected = showAws || showGcp || showAzure;

    if (!anySelected) {
      resultsContainer.innerHTML = '';
      noProviderMsg.classList.remove('hidden');
      recoPanel.classList.add('hidden');
      return;
    }
    noProviderMsg.classList.add('hidden');

    // Filter and compute
    var results = CLOUD_REGIONS
      .filter(function(r) {
        if (r.provider === 'aws' && !showAws) return false;
        if (r.provider === 'gcp' && !showGcp) return false;
        if (r.provider === 'azure' && !showAzure) return false;
        return true;
      })
      .map(function(r) {
        var dist = haversine(source.lat, source.lon, r.lat, r.lon);
        var rtt = estimateRTT(dist);
        return Object.assign({}, r, { dist: Math.round(dist), rtt: rtt });
      })
      .sort(function(a, b) { return a.rtt - b.rtt; });

    // Render cards
    resultsContainer.innerHTML = results.map(function(r) {
      var c = latencyColor(r.rtt);
      var badge = providerBadgeClass(r.provider);
      return '<div class="' + c.bg + ' border ' + c.border + ' rounded-lg p-3 flex flex-col gap-1.5">' +
        '<div class="flex items-start justify-between gap-2">' +
          '<div class="min-w-0">' +
            '<div class="text-sm font-medium leading-snug truncate">' + r.name + '</div>' +
            '<div class="text-xs text-text-muted truncate">' + r.location + '</div>' +
          '</div>' +
          '<span class="text-xs px-2 py-0.5 rounded-full border font-medium shrink-0 ' + badge + '">' + providerLabel(r.provider) + '</span>' +
        '</div>' +
        '<div class="flex items-end justify-between mt-1">' +
          '<div class="text-xs text-text-muted font-mono">' + r.dist.toLocaleString() + ' km</div>' +
          '<div class="text-xl font-bold ' + c.text + '">' + r.rtt + '<span class="text-xs font-normal ml-0.5">ms</span></div>' +
        '</div>' +
        '<div class="text-xs font-mono text-text-muted opacity-70">' + r.id + '</div>' +
      '</div>';
    }).join('');

    // Recommendations
    var under50 = results.filter(function(r) { return r.rtt < 50; });
    var under150 = results.filter(function(r) { return r.rtt >= 50 && r.rtt < 150; });

    recoPanel.classList.remove('hidden');

    if (under50.length === 0) {
      recoUnder50List.innerHTML = '<span class="text-text-muted text-xs">No regions under 50ms from this source</span>';
    } else {
      recoUnder50List.innerHTML = under50.slice(0, 6).map(function(r) {
        return '<div class="flex items-center justify-between gap-2">' +
          '<span class="text-xs truncate">' + r.name + '</span>' +
          '<span class="text-xs font-bold text-green-400 shrink-0">' + r.rtt + 'ms</span>' +
        '</div>';
      }).join('');
    }

    if (under150.length === 0) {
      recoUnder150List.innerHTML = '<span class="text-text-muted text-xs">All nearby regions are under 50ms</span>';
    } else {
      recoUnder150List.innerHTML = under150.slice(0, 6).map(function(r) {
        return '<div class="flex items-center justify-between gap-2">' +
          '<span class="text-xs truncate">' + r.name + '</span>' +
          '<span class="text-xs font-bold text-yellow-400 shrink-0">' + r.rtt + 'ms</span>' +
        '</div>';
      }).join('');
    }

    var best = results[0];
    var bestProvider = providerLabel(best.provider);
    recoPrimaryText.innerHTML =
      '<div class="font-semibold text-white">' + best.name + '</div>' +
      '<div class="text-text-muted text-xs mt-0.5">' + best.location + '</div>' +
      '<div class="mt-2 text-xs">' +
        '<span class="font-bold text-primary">' + best.rtt + 'ms</span>' +
        ' estimated RTT &nbsp;·&nbsp; ' +
        '<span class="px-1.5 py-0.5 rounded border text-xs font-medium ' + providerBadgeClass(best.provider) + '">' + bestProvider + '</span>' +
      '</div>' +
      '<div class="text-xs text-text-muted mt-2">' + best.dist.toLocaleString() + ' km from your source location</div>';
  }

  sourceSelect.addEventListener('change', render);
  document.getElementById('toggle-aws').addEventListener('change', render);
  document.getElementById('toggle-gcp').addEventListener('change', render);
  document.getElementById('toggle-azure').addEventListener('change', render);

  render();
</script>
