---
import BaseLayout from '../../layouts/BaseLayout.astro';
import YamlToJsonConverter from '../../components/YamlToJsonConverter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is YAML and why convert it to JSON?", answer: "YAML is a human-readable format popular for config files (Docker Compose, Kubernetes, GitHub Actions). JSON is the standard for APIs and data interchange. Converting between them is a daily task for developers working across multiple ecosystems." },
  { question: "Does this tool support multi-document YAML?", answer: "Yes. Separate multiple YAML documents with --- on its own line. Each document is converted independently and labeled in the output. This is common in Kubernetes manifests and Ansible playbooks." },
  { question: "How do I convert JSON back to YAML?", answer: "Click the 'JSON → YAML' button to switch direction. Paste your JSON and the tool converts it to clean, indented YAML with proper scalar quoting." },
  { question: "What YAML types are supported?", answer: "The converter handles strings, numbers, booleans (true/false/yes/no/on/off), null (~), nested objects, arrays, and block scalars (| and >). Inline JSON arrays/objects inside YAML are also parsed." },
  { question: "Is my data sent to any server?", answer: "No. All conversion happens entirely in your browser with JavaScript. Your YAML and JSON data never leaves your machine — safe to use with sensitive config files and secrets." },
  { question: "What is the difference between pretty print and minified JSON?", answer: "Pretty print formats JSON with indentation and line breaks for human readability. Minified JSON removes all whitespace, producing the most compact representation — ideal for network transmission and storage. This tool outputs pretty-printed JSON by default." },
];
---

<BaseLayout
  title="YAML to JSON Converter — Free Online Tool | Multi-Document & Error Handling"
  description="Convert YAML to JSON or JSON to YAML instantly in your browser. Supports multi-document YAML (---), nested objects, arrays, all scalar types, syntax highlighting, error messages, and pretty-print. 100% private — nothing sent to servers."
  tool="YAML to JSON converter, JSON to YAML, YAML parser online, convert YAML JSON, multi-document YAML, Kubernetes YAML converter, YAML formatter"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "YAML to JSON Converter",
    "url": "https://devplaybook.cc/tools/yaml-to-json-converter",
    "description": "Convert YAML to JSON or JSON to YAML instantly. Supports multi-document YAML, nested structures, arrays, and all scalar types. Runs 100% in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">YAML ↔ JSON Converter</h1>
  <p class="text-text-muted mb-4">
    Convert YAML to JSON or JSON to YAML instantly. Supports multi-document YAML (separated by <code class="bg-bg-secondary px-1 rounded text-sm">---</code>), nested objects, arrays, all scalar types, and pretty-print. Everything runs in your browser — no data sent to servers.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multi-document YAML support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Syntax error highlighting</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <YamlToJsonConverter client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="YAML to JSON Converter" relatedTags={['yaml', 'json', 'converter', 'config', 'devops']} />
</BaseLayout>
