---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is the main difference between Ansible, Chef, and Puppet?", answer: "The core difference is architecture and philosophy. Ansible is agentless and push-based — it connects over SSH and runs tasks imperatively, making it easy to start with. It's great for ad-hoc automation and simple configuration management. Chef and Puppet are agent-based and pull-based — agents on each node check in with a central server and apply the desired state. Chef uses Ruby DSL and thinks in 'recipes' and 'cookbooks'; Puppet uses its own declarative language (Puppet DSL) and a catalog-based model. Ansible wins on simplicity; Chef/Puppet win on scale and idempotency guarantees for large fleets." },
  { question: "Should I use Ansible or Terraform for infrastructure management?", answer: "They solve different problems. Terraform manages infrastructure state — it creates, modifies, and destroys cloud resources like VMs, networks, and databases. It's declarative and tracks state in a .tfstate file. Ansible configures what's already running — it installs packages, writes config files, manages services, and deploys applications. Use them together: Terraform provisions the infrastructure, Ansible configures it. Don't use Ansible to create cloud resources (it can, but state tracking is weak). Don't use Terraform to manage application configuration inside VMs (it's not designed for that)." },
  { question: "Is Ansible still relevant in a Kubernetes-first world?", answer: "Yes, for several use cases. Kubernetes manages containerized workloads, but you still need to configure the nodes themselves, bootstrap the cluster, manage secrets, configure monitoring agents, and handle non-containerized legacy systems. Ansible is also widely used for network device configuration (routers, switches via Ansible Network), Windows configuration management, and simple deployment pipelines where Kubernetes is overkill. Many teams use Ansible for the 'layer below' Kubernetes — OS hardening, node configuration, and the initial cluster bootstrap. Ansible is also the simplest path for small teams without Kubernetes expertise." },
  { question: "What is the learning curve for each tool?", answer: "Ansible is the easiest to learn — YAML syntax, no agents, and you can write your first working playbook in an hour. It has the largest community and most modules. Chef has the steepest learning curve — Ruby DSL requires Ruby knowledge, and the Chef ecosystem (workstations, Chef Server, Berkshelf, Test Kitchen) has many moving parts. Puppet is in between — the Puppet DSL is custom and declarative, which some find intuitive and others find frustrating. Puppet also has PuppetDB, Hiera, and Puppet Server to manage. For teams without a dedicated DevOps person, Ansible is strongly preferred. For large enterprises with dedicated infrastructure engineers, Puppet or Chef provide stronger guarantees." },
];
---

<BaseLayout
  title="Ansible vs Chef vs Puppet — Configuration Management Comparison 2026"
  description="Compare Ansible, Chef, and Puppet for configuration management in 2026. Feature comparison table, example playbook and recipe, when to choose each, and vs Terraform analysis."
  tool="Ansible vs Chef vs Puppet, configuration management, Ansible playbook, Chef recipe, Puppet manifest, infrastructure automation"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Ansible vs Chef vs Puppet Comparison 2026",
    "url": "https://devplaybook.cc/tools/ansible-vs-chef-vs-puppet",
    "description": "Feature-by-feature comparison of Ansible, Chef, and Puppet configuration management tools with examples and decision guide.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Ansible vs Chef vs Puppet (2026)</h1>
  <p class="text-text-muted mb-6">
    Choose the right <strong>configuration management tool</strong> for your infrastructure. Compare Ansible, Chef, and Puppet across architecture, learning curve, scalability, and ecosystem — with real examples.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Feature comparison table</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Example playbook &amp; recipe</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> When to choose each</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> vs Terraform</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Feature Comparison</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 font-semibold">Feature</th>
          <th class="text-left py-2 pr-4 font-semibold">Ansible</th>
          <th class="text-left py-2 pr-4 font-semibold">Chef</th>
          <th class="text-left py-2 font-semibold">Puppet</th>
        </tr>
      </thead>
      <tbody class="text-text-muted">
        <tr class="border-b border-border"><td class="py-2 pr-4">Architecture</td><td class="py-2 pr-4">Agentless, push</td><td class="py-2 pr-4">Agent + server, pull</td><td class="py-2">Agent + server, pull</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Language</td><td class="py-2 pr-4">YAML</td><td class="py-2 pr-4">Ruby DSL</td><td class="py-2">Puppet DSL</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Learning curve</td><td class="py-2 pr-4">Low</td><td class="py-2 pr-4">High</td><td class="py-2">Medium</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Idempotency</td><td class="py-2 pr-4">Module-dependent</td><td class="py-2 pr-4">Strong</td><td class="py-2">Strong</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Scale (nodes)</td><td class="py-2 pr-4">100s–1000s</td><td class="py-2 pr-4">10,000s</td><td class="py-2">10,000s</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Windows support</td><td class="py-2 pr-4">Good (WinRM)</td><td class="py-2 pr-4">Good</td><td class="py-2">Good</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Community modules</td><td class="py-2 pr-4">5,000+ Galaxy</td><td class="py-2 pr-4">4,000+ Supermarket</td><td class="py-2">6,000+ Forge</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Testing framework</td><td class="py-2 pr-4">Molecule</td><td class="py-2 pr-4">Test Kitchen + InSpec</td><td class="py-2">Puppet RSpec / Litmus</td></tr>
        <tr><td class="py-2 pr-4">Commercial support</td><td class="py-2 pr-4">Red Hat Ansible</td><td class="py-2 pr-4">Progress Chef</td><td class="py-2">Perforce Puppet</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Ansible — Example Playbook</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># playbooks/nginx.yml — Install and configure Nginx
---
- name: Configure web servers
  hosts: webservers
  become: true
  vars:
    nginx_port: 443
    server_name: app.example.com

  tasks:
    - name: Install Nginx
      ansible.builtin.package:
        name: nginx
        state: present

    - name: Configure Nginx
      ansible.builtin.template:
        src: templates/nginx.conf.j2
        dest: /etc/nginx/nginx.conf
        owner: root
        group: root
        mode: '0644'
      notify: Restart Nginx

    - name: Open firewall port
      ansible.posix.firewalld:
        port: "&#123;&#123; nginx_port &#125;&#125;/tcp"
        permanent: true
        state: enabled

    - name: Ensure Nginx is running
      ansible.builtin.service:
        name: nginx
        state: started
        enabled: true

  handlers:
    - name: Restart Nginx
      ansible.builtin.service:
        name: nginx
        state: restarted</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Chef — Example Recipe</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># cookbooks/webserver/recipes/default.rb
package 'nginx' do
  action :install
end

template '/etc/nginx/nginx.conf' do
  source 'nginx.conf.erb'
  owner 'root'
  group 'root'
  mode '0644'
  variables(
    port: node['webserver']['port'],
    server_name: node['webserver']['server_name']
  )
  notifies :restart, 'service[nginx]', :delayed
end

firewalld_port "&#123;node['webserver']['port']&#125;/tcp" do
  action :add
  zone 'public'
  permanent true
end

service 'nginx' do
  action [:enable, :start]
end</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Puppet — Example Manifest</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># modules/webserver/manifests/init.pp
class webserver (
  Integer $port        = 443,
  String  $server_name = 'app.example.com',
) &#123;
  package &#123; 'nginx':
    ensure =&gt; installed,
  &#125;

  file &#123; '/etc/nginx/nginx.conf':
    ensure  =&gt; file,
    owner   =&gt; 'root',
    group   =&gt; 'root',
    mode    =&gt; '0644',
    content =&gt; epp('webserver/nginx.conf.epp', &#123;
      'port'        =&gt; $port,
      'server_name' =&gt; $server_name,
    &#125;),
    require =&gt; Package['nginx'],
    notify  =&gt; Service['nginx'],
  &#125;

  service &#123; 'nginx':
    ensure  =&gt; running,
    enable  =&gt; true,
    require =&gt; Package['nginx'],
  &#125;
&#125;</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">When to Choose Each Tool</h2>
  <ul class="list-disc pl-6 text-text-muted space-y-2 mb-6">
    <li><strong>Choose Ansible</strong> when: small to medium fleet (&lt;500 nodes), team without Ruby/DSL expertise, ad-hoc automation needs, mixed Windows/Linux environments, simple deployments and orchestration tasks.</li>
    <li><strong>Choose Chef</strong> when: large scale (&gt;1,000 nodes), strong compliance testing requirements (InSpec), team has Ruby experience, complex dependency graphs in cookbooks, enterprise compliance with Chef Automate.</li>
    <li><strong>Choose Puppet</strong> when: very large fleet (10,000+ nodes), strong idempotency guarantees needed, declarative model preferred, Puppet Forge module coverage is critical, or existing Puppet investment.</li>
    <li><strong>Use Terraform alongside all three</strong> for cloud resource provisioning — configuration management tools should not manage cloud API resources.</li>
  </ul>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="ansible-vs-chef-vs-puppet" relatedTags={["ansible", "devops", "infrastructure", "configuration-management", "terraform"]} />
</BaseLayout>
