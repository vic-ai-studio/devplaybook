---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ResumeAnalyzer from '../../components/ResumeAnalyzer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Developer Resume Analyzer — Free Resume Score Tool"
  description="Paste your developer resume and get an instant score with actionable suggestions. Checks contact info, experience bullet quality, skills keywords, metrics, and more. 100% client-side."
  tool="developer resume analyzer, resume score, resume checker, CV review tool, tech resume"
>
  <h1 class="text-3xl font-bold mb-2">Developer Resume Analyzer</h1>
  <p class="text-text-muted mb-8">Paste your resume text and get an instant score with specific feedback. Checks contact info, action verbs, quantified achievements, technical keywords, and structure — all in your browser.</p>
  <ResumeAnalyzer client:only="preact" />
  <ToolPageCta currentTool="Developer Resume Analyzer" relatedTags={['resume', 'career', 'job', 'developer', 'interview']} />
</BaseLayout>
