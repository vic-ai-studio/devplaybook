---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OpenAITokenizer from '../../components/OpenAITokenizer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "How are tokens counted for GPT-4o vs GPT-3.5?",
    answer: "GPT-4o uses the o200k_base tokenizer, which has a larger vocabulary (~200K tokens) and produces slightly fewer tokens for the same text compared to cl100k_base (used by GPT-4 Turbo and GPT-3.5). This tool estimates tokens using character-to-token ratios (~4.2 chars/token for o200k, ~4.0 for cl100k) plus punctuation adjustments. For exact counts, use OpenAI's tiktoken library."
  },
  {
    question: "What is cl100k_base vs o200k_base?",
    answer: "cl100k_base is the BPE tokenizer used by GPT-4 Turbo, GPT-3.5 Turbo, and embedding models. It has 100,277 tokens in its vocabulary. o200k_base is the newer tokenizer used by GPT-4o and GPT-4o mini, with roughly 200K tokens. The larger vocabulary means more common subwords get their own token, resulting in slightly more efficient tokenization for many languages."
  },
  {
    question: "Why does my token count differ from the OpenAI playground?",
    answer: "This tool uses a heuristic estimation (character count / 4 ± punctuation adjustments), not the actual tiktoken library. Real tokenization considers the full BPE merge rules, which can produce different counts for words with unusual characters, code snippets, or non-English text. Expect ±5–10% variance. For exact production counts, use tiktoken directly: pip install tiktoken."
  },
  {
    question: "How do I reduce token count to lower costs?",
    answer: "Common strategies include: (1) shortening system prompts — replace verbose instructions with concise directives, (2) removing redundant context — only include relevant conversation history, (3) using numbered/bulleted lists instead of prose, (4) switching to GPT-4o mini for tasks that don't require full GPT-4o capability, and (5) compressing repeated content with references."
  },
  {
    question: "What context window should I use for production prompts?",
    answer: "Always leave 20–30% of the context window free for the model's output. For GPT-4o (128K context), keep input tokens under 90K. For GPT-3.5 Turbo (16K context), keep input under 12K. Exceeding the context window causes an API error. If you need longer context, consider GPT-4o or switch to Claude (200K) or Gemini 1.5 Pro (1M)."
  },
  {
    question: "Does this tool send my prompt to any server?",
    answer: "No. All token estimation runs entirely in your browser with JavaScript. Your prompts are never sent to any server or third party. This tool works offline once the page is loaded."
  },
];
---

<BaseLayout
  title="OpenAI Token Counter — GPT-4o, GPT-3.5, GPT-4 Turbo"
  description="Count tokens for GPT-4o, GPT-4, and GPT-3.5 prompts. Uses cl100k_base / o200k_base estimation. Shows token count, character count, word count, and API cost estimate."
  tool="openai tokenizer, token counter, gpt token count, prompt token calculator, cl100k tokenizer"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "OpenAI Token Counter",
    "url": "https://devplaybook.cc/tools/openai-tokenizer",
    "description": "Count tokens for GPT-4o, GPT-4 Turbo, and GPT-3.5 Turbo prompts. Uses cl100k_base and o200k_base estimation with cost calculation.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">OpenAI Token Counter</h1>
  <p class="text-text-muted mb-4">
    Estimate token counts for <code class="font-mono bg-bg-card px-1 rounded text-sm">GPT-4o</code>,
    <code class="font-mono bg-bg-card px-1 rounded text-sm">GPT-4 Turbo</code>, and
    <code class="font-mono bg-bg-card px-1 rounded text-sm">GPT-3.5 Turbo</code> prompts.
    Uses <strong class="text-text">o200k_base</strong> and <strong class="text-text">cl100k_base</strong> heuristics
    to estimate token counts, API cost, and context window usage.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live token estimate</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> API cost calculator</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Context window usage bar</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs in your browser</span>
  </div>
  <OpenAITokenizer client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="OpenAI Token Counter" relatedTags={['ai', 'llm', 'openai', 'gpt', 'tokens', 'prompts', 'cost']} />
</BaseLayout>
