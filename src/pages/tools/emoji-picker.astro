---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmojiPicker from '../../components/EmojiPicker.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a Unicode code point?", answer: "A Unicode code point is the unique number assigned to every character in the Unicode standard, written as U+XXXX in hexadecimal. For example, 😀 is U+1F600. The Unicode standard covers over 140,000 characters across 159 scripts, plus symbols, emoji, and special characters. Code points range from U+0000 to U+10FFFF." },
  { question: "How do I use an emoji in HTML?", answer: "Use the HTML entity format: &#x1F600; for 😀. You can also use decimal: &#128512;. Modern HTML5 documents with UTF-8 charset can include emoji directly. In CSS content property, use the backslash format: content: '\\1F600'. In JavaScript, you can use String.fromCodePoint(0x1F600) or directly paste the emoji." },
  { question: "Why do some emoji look different on different devices?", answer: "Emoji rendering is controlled by the operating system's emoji font — Apple Color Emoji on iOS/macOS, Noto Color Emoji on Android/Linux, Segoe UI Emoji on Windows. Each vendor designs their own visual interpretation of Unicode emoji. The character (code point) is the same, but the glyph appearance varies. This is by design — Unicode defines the meaning, not the visual." },
  { question: "What are ZWJ sequences?", answer: "ZWJ (Zero Width Joiner, U+200D) sequences combine multiple emoji into one composite emoji. For example: 👨 + ZWJ + 💻 = 👨‍💻 (man technologist). Family emoji like 👨‍👩‍👧‍👦 are sequences of 4 emoji joined by 3 ZWJs. Not all platforms render all ZWJ sequences — they fall back to the individual emoji if unsupported." },
  { question: "What is the CSS content trick for emoji?", answer: "The CSS content property lets you insert emoji via ::before / ::after pseudo-elements: .icon::before { content: '\\1F680'; }. This keeps emoji in CSS rather than HTML markup. Note: this is useful for decorative icons, but avoid for meaningful content (screen readers handle inline emoji better). The backslash-hex format is the CSS encoding for Unicode code points." },
];
---

<BaseLayout
  title="Emoji Picker & Unicode Info — Copy Emoji & Code Points — Free Tool"
  description="Browse and search 300+ emoji by name and category. Click to copy emoji, Unicode code point (U+1F600), HTML entity, or CSS content value. Free, runs 100% in your browser."
  tool="emoji picker, emoji unicode code point, emoji copy paste, emoji HTML entity, emoji CSS content, emoji search"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Emoji Picker & Unicode Info</h1>
  <p class="text-text-muted mb-4">
    Browse 300+ emoji by name and category. Click any emoji to see its Unicode code point, HTML entity, and CSS content value — all copyable with one click.
    Runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 300+ emoji across 7 categories</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Unicode code points (U+XXXX)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> HTML entity & CSS content values</span>
  </div>
  <EmojiPicker client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Emoji Picker" relatedTags={['unicode', 'emoji', 'html', 'css', 'design']} />
</BaseLayout>
