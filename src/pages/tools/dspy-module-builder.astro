---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is DSPy and why use it?", answer: "DSPy (Declarative Self-improving Python) is a framework from Stanford that replaces hand-crafted prompts with learnable modules. Instead of writing brittle prompt strings, you define typed Signatures that describe what you want, then let DSPy compile and optimize those prompts automatically using your examples and a chosen metric." },
  { question: "What is a DSPy Signature?", answer: "A Signature is a declarative spec of a module's I/O contract. It subclasses dspy.Signature and defines input/output fields as class attributes using dspy.InputField() and dspy.OutputField(). The docstring acts as the task instruction. DSPy compiles this into an optimal prompt under the hood." },
  { question: "When should I use ChainOfThought vs Predict?", answer: "Use dspy.Predict for fast, direct tasks where reasoning is not needed (e.g. classification, extraction). Use dspy.ChainOfThought when the task benefits from step-by-step reasoning, such as math problems or multi-hop QA. ChainOfThought adds an intermediate 'rationale' field that guides the model." },
  { question: "What is dspy.ReAct used for?", answer: "dspy.ReAct implements the Reasoning + Acting loop. It interleaves LLM reasoning steps with external tool calls (search, code execution, APIs). Use it when your pipeline needs to query databases, call APIs, or interact with external services to answer questions." },
  { question: "How do I optimize a DSPy module?", answer: "After defining your module, collect a small labeled dataset and pick an optimizer like dspy.BootstrapFewShot or dspy.MIPROv2. Call optimizer.compile(module, trainset=your_data) and DSPy will automatically search for the best prompts and few-shot examples, saving you manual prompt engineering effort." },
];
---

<BaseLayout
  title="DSPy Module Builder — Generate DSPy Signature & Module Code"
  description="Generate DSPy Signature and Module class definitions for LLM pipelines. Define typed I/O fields, choose module type (Predict/ChainOfThought/ReAct), and get production-ready Python code."
  tool="DSPy Module Builder, DSPy Signature Generator, DSPy Pipeline Code, LLM Pipeline Builder"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">DSPy Module Builder</h1>
  <p class="text-text-muted mb-4">Generate typed DSPy Signature and Module class definitions for LLM pipelines. Define inputs, outputs, and module type — get ready-to-paste Python code.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Signature class generator</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Predict / CoT / ReAct / PoT</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> One-click copy</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-5">
    <!-- Left: Inputs -->
    <div class="space-y-5">
      <!-- Basic Config -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Module Configuration</h2>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium mb-1.5">Module Name</label>
            <input id="module-name" type="text" value="QuestionAnswerer"
              class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5">Module Type</label>
            <select id="module-type" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="Predict">dspy.Predict — Direct prediction</option>
              <option value="ChainOfThought" selected>dspy.ChainOfThought — Step-by-step reasoning</option>
              <option value="ReAct">dspy.ReAct — Reasoning + tool use</option>
              <option value="ProgramOfThought">dspy.ProgramOfThought — Code generation reasoning</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5">Docstring (task instruction)</label>
            <input id="docstring" type="text" value="Answer the question given the context."
              class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
          </div>
        </div>
      </div>

      <!-- Input Fields -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-base font-semibold">Input Fields</h2>
          <button id="add-input" class="text-xs bg-primary text-white px-3 py-1.5 rounded-lg hover:opacity-90">+ Add Field</button>
        </div>
        <div id="input-fields" class="space-y-2"></div>
      </div>

      <!-- Output Fields -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-base font-semibold">Output Fields</h2>
          <button id="add-output" class="text-xs bg-primary text-white px-3 py-1.5 rounded-lg hover:opacity-90">+ Add Field</button>
        </div>
        <div id="output-fields" class="space-y-2"></div>
      </div>
    </div>

    <!-- Right: Output -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-base font-semibold">Generated Python Code</h2>
        <button id="copy-btn"
          class="text-xs bg-primary text-white px-3 py-1.5 rounded-lg hover:opacity-90 flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
          <span id="copy-label">Copy</span>
        </button>
      </div>
      <pre id="code-output" class="text-xs font-mono bg-black/20 rounded-lg p-4 overflow-auto whitespace-pre min-h-[420px] text-green-400 leading-relaxed"></pre>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="DSPy Module Builder" relatedTags={['ai', 'llm', 'python', 'dspy', 'pipeline', 'agent']} />
</BaseLayout>

<script is:inline>
  const TYPES = ['str', 'int', 'float', 'bool', 'list[str]', 'dict', 'Optional[str]'];

  function makeFieldRow(containerId, name, type, desc) {
    const row = document.createElement('div');
    row.className = 'flex gap-2 items-center';
    row.innerHTML = `
      <input type="text" placeholder="field_name" value="${name}"
        class="flex-1 bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs font-mono focus:outline-none focus:border-primary field-name" />
      <select class="bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:border-primary field-type">
        ${TYPES.map(t => `<option${t === type ? ' selected' : ''}>${t}</option>`).join('')}
      </select>
      <input type="text" placeholder="description" value="${desc}"
        class="flex-1 bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:border-primary field-desc" />
      <button class="remove-field text-red-400 hover:text-red-600 text-base leading-none px-1">×</button>
    `;
    row.querySelector('.remove-field').addEventListener('click', () => { row.remove(); generate(); });
    row.querySelectorAll('input, select').forEach(el => el.addEventListener('input', generate));
    document.getElementById(containerId).appendChild(row);
  }

  function getFields(containerId) {
    const rows = document.getElementById(containerId).querySelectorAll('.flex.gap-2');
    return Array.from(rows).map(row => ({
      name: row.querySelector('.field-name').value.trim() || 'field',
      type: row.querySelector('.field-type').value,
      desc: row.querySelector('.field-desc').value.trim(),
    }));
  }

  function generate() {
    const modName = document.getElementById('module-name').value.trim() || 'MyModule';
    const modType = document.getElementById('module-type').value;
    const docstring = document.getElementById('docstring').value.trim() || 'Perform the task.';
    const inputs = getFields('input-fields');
    const outputs = getFields('output-fields');
    const sigName = modName + 'Signature';

    const inputLines = inputs.map(f =>
      `    ${f.name}: ${f.type} = dspy.InputField(desc="${f.desc || f.name}")`
    ).join('\n');
    const outputLines = outputs.map(f =>
      `    ${f.name}: ${f.type} = dspy.OutputField(desc="${f.desc || f.name}")`
    ).join('\n');

    let moduleBody = '';
    if (modType === 'Predict') {
      moduleBody = `    def __init__(self):
        super().__init__()
        self.predict = dspy.Predict(${sigName})

    def forward(self, ${inputs.map(f => f.name).join(', ')}):
        return self.predict(${inputs.map(f => `${f.name}=${f.name}`).join(', ')})`;
    } else if (modType === 'ChainOfThought') {
      moduleBody = `    def __init__(self):
        super().__init__()
        self.cot = dspy.ChainOfThought(${sigName})

    def forward(self, ${inputs.map(f => f.name).join(', ')}):
        return self.cot(${inputs.map(f => `${f.name}=${f.name}`).join(', ')})`;
    } else if (modType === 'ReAct') {
      moduleBody = `    def __init__(self, tools: list):
        super().__init__()
        self.react = dspy.ReAct(${sigName}, tools=tools)

    def forward(self, ${inputs.map(f => f.name).join(', ')}):
        return self.react(${inputs.map(f => `${f.name}=${f.name}`).join(', ')})`;
    } else if (modType === 'ProgramOfThought') {
      moduleBody = `    def __init__(self):
        super().__init__()
        self.pot = dspy.ProgramOfThought(${sigName})

    def forward(self, ${inputs.map(f => f.name).join(', ')}):
        return self.pot(${inputs.map(f => `${f.name}=${f.name}`).join(', ')})`;
    }

    const code = `import dspy


# ── Signature ────────────────────────────────────────────────
class ${sigName}(dspy.Signature):
    """${docstring}"""

${inputLines || '    # (no input fields defined)'}

${outputLines || '    # (no output fields defined)'}


# ── Module ───────────────────────────────────────────────────
class ${modName}(dspy.Module):
${moduleBody}


# ── Usage ────────────────────────────────────────────────────
if __name__ == "__main__":
    # Configure LM
    lm = dspy.LM("openai/gpt-4o-mini")
    dspy.configure(lm=lm)

    module = ${modName}(${modType === 'ReAct' ? 'tools=[]' : ''})
    result = module(${inputs.map(f => `${f.name}="example"`).join(', ')})
    print(result)
`;

    document.getElementById('code-output').textContent = code;
  }

  document.getElementById('add-input').addEventListener('click', () => {
    makeFieldRow('input-fields', '', 'str', '');
    generate();
  });
  document.getElementById('add-output').addEventListener('click', () => {
    makeFieldRow('output-fields', '', 'str', '');
    generate();
  });
  document.getElementById('module-name').addEventListener('input', generate);
  document.getElementById('module-type').addEventListener('change', generate);
  document.getElementById('docstring').addEventListener('input', generate);

  document.getElementById('copy-btn').addEventListener('click', () => {
    const code = document.getElementById('code-output').textContent;
    navigator.clipboard.writeText(code).then(() => {
      const lbl = document.getElementById('copy-label');
      lbl.textContent = 'Copied!';
      setTimeout(() => lbl.textContent = 'Copy', 2000);
    });
  });

  // Seed defaults
  makeFieldRow('input-fields', 'context', 'str', 'background context for answering');
  makeFieldRow('input-fields', 'question', 'str', 'question to answer');
  makeFieldRow('output-fields', 'answer', 'str', 'concise factual answer');
  generate();
</script>
