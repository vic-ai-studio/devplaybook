---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GraphQLQueryBuilder from '../../components/GraphQLQueryBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is a GraphQL query builder?",
    answer: "A GraphQL query builder is a visual tool that helps you construct GraphQL queries without writing them from scratch. You paste your schema (SDL), select a root field (query or mutation), then click to choose which fields you want in the response. The tool generates the correct GraphQL syntax for you. This is especially useful when learning GraphQL or working with an unfamiliar schema.",
  },
  {
    question: "What is SDL (Schema Definition Language)?",
    answer: "SDL is the syntax used to define GraphQL types and operations. It describes the shape of your API — what queries and mutations exist, what types are returned, and what fields each type has. Most GraphQL APIs expose their SDL via introspection or as a schema.graphql file. Paste your SDL into the Schema tab to use your own types in the builder.",
  },
  {
    question: "What is a root field in GraphQL?",
    answer: "Root fields are the entry points of your GraphQL API — they're defined under the Query, Mutation, or Subscription types. For example, a Query type might have a posts root field that returns a list of Post objects. You select a root field first, then choose which sub-fields of the returned type to include in your query.",
  },
  {
    question: "How do I use my own schema?",
    answer: "Switch to the 'Schema (SDL)' tab and paste your GraphQL schema. The builder parses the SDL in real time and updates the available types and fields. You can get your schema from your API's schema.graphql file, generate it from your codebase using graphql-codegen, or export it from your GraphQL IDE (Apollo Studio, GraphiQL). Make sure you include the Query, Mutation, or Subscription root types.",
  },
  {
    question: "What's the difference between query, mutation, and subscription?",
    answer: "Query is for reading data — equivalent to GET in REST. Mutation is for writing data (create, update, delete) — equivalent to POST/PUT/DELETE. Subscription is for real-time updates via WebSocket — the server pushes data to the client when events occur. Most APIs start with queries and mutations; subscriptions require WebSocket infrastructure.",
  },
  {
    question: "How do I add arguments to a query?",
    answer: "When you select a root field that has arguments (like posts(limit: Int, offset: Int)), the Arguments input appears below the field selector. Arguments are listed in the format argName: 'value'. Edit the values directly in the input — string values need quotes, integers and booleans don't. For example: limit: 10, offset: 0. The generated query wraps these in parentheses automatically.",
  },
];
---

<BaseLayout
  title="GraphQL Query Builder — Visual GraphQL Query Constructor from Schema"
  description="Build GraphQL queries visually from schema SDL. Pick fields, add arguments, and generate query, mutation, or subscription strings. Free, runs in browser."
  tool="GraphQL Query Builder, Visual GraphQL Query Constructor, GraphQL Schema Explorer, GraphQL Query Generator, Build GraphQL Queries"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "GraphQL Query Builder",
    "url": "https://devplaybook.cc/tools/graphql-query-builder",
    "description": "Build GraphQL queries visually from your schema SDL. Select root fields, pick sub-fields, add arguments, and generate query/mutation/subscription strings instantly.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">GraphQL Query Builder</h1>
  <p class="text-text-muted mb-4">
    Build <strong>GraphQL queries visually</strong> from your schema. Paste your SDL, select a root field, click the fields you want, and get a ready-to-use <strong>query / mutation / subscription</strong> string. Supports nested types and arguments.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Schema-driven field selection</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Query, mutation & subscription</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Nested type support</span>
  </div>
  <GraphQLQueryBuilder client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="GraphQL Query Builder" relatedTags={['graphql', 'api', 'query', 'schema', 'developer-tools']} />
</BaseLayout>
