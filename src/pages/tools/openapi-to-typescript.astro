---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OpenapiToTypescript from '../../components/OpenapiToTypescript.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What OpenAPI versions does this tool support?",
    answer: "This tool supports OpenAPI 3.x specs (which use components.schemas) and Swagger 2.x specs (which use definitions). Both YAML and JSON input formats are accepted. For OpenAPI 3.x, paste the full spec or just the components section. The generator reads the schemas section and produces a TypeScript interface for each object schema. Schemas referencing external files ($ref with http:// or file paths) are not resolved — only internal #/components/schemas/Name references work."
  },
  {
    question: "How are $ref references handled?",
    answer: "$ref values like '#/components/schemas/Pet' are converted to direct TypeScript type references. If Pet is defined as an interface, your field will be typed as Pet (not inlined). This means the generated interfaces reference each other by name, which is how TypeScript expects it — you get a clean, composable set of interfaces rather than deeply nested anonymous types. Circular references (Schema A referencing Schema B which references Schema A) will generate valid TypeScript since interfaces are just type declarations."
  },
  {
    question: "How do required fields and optional fields map to TypeScript?",
    answer: "In OpenAPI, the required array at the object level lists which properties are mandatory. This tool maps required properties to TypeScript required fields (field: Type) and non-required properties to optional fields (field?: Type). This matches the TypeScript convention where ? means the property may be absent. Note that OpenAPI's nullable: true is separate from required — a field can be required but nullable (must be present, but its value may be null), which maps to field: Type | null."
  },
  {
    question: "Can I use the generated TypeScript types directly in my project?",
    answer: "Yes — copy the output and paste it into a .ts or .d.ts file in your project. The generated code uses only built-in TypeScript syntax with no imports required. For a better long-term workflow, consider tools like openapi-typescript (npm package) for CI/CD integration that keeps your types in sync as your API spec evolves. This browser tool is ideal for quick one-off conversions, prototyping, or when you don't want to add a build step. The output is compatible with TypeScript 4.x and 5.x."
  },
];
---

<BaseLayout
  title="OpenAPI to TypeScript Generator — Convert Swagger Schemas to TypeScript Interfaces"
  description="Convert OpenAPI 3.x and Swagger schemas to TypeScript interfaces. Handles $ref, nullable, enums, arrays, and nested objects. Paste your spec and get interfaces instantly."
  tool="openapi typescript, swagger to typescript, openapi generator, typescript interfaces, api types generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "OpenAPI to TypeScript Generator",
    "url": "https://devplaybook.cc/tools/openapi-to-typescript",
    "description": "Convert OpenAPI 3.x and Swagger schemas to TypeScript interfaces. Handles $ref, nullable, enums, arrays, and nested objects.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">OpenAPI to TypeScript Generator</h1>
  <p class="text-text-muted mb-4">
    Paste an <strong>OpenAPI 3.x or Swagger YAML/JSON spec</strong> and get TypeScript interfaces instantly. Handles <code class="font-mono text-sm bg-surface-alt px-1.5 py-0.5 rounded">$ref</code> references, <code class="font-mono text-sm bg-surface-alt px-1.5 py-0.5 rounded">nullable</code>, enums, arrays, and required vs optional fields. Runs entirely in your browser — no data is sent to any server.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> YAML &amp; JSON input</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> $ref resolution</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> nullable → T | null</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> enum → union type</span>
  </div>
  <OpenapiToTypescript client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="OpenAPI to TypeScript Generator" relatedTags={['typescript', 'openapi', 'swagger', 'api', 'developer-tools']} />
</BaseLayout>
