---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OpenApiToPostman from '../../components/OpenApiToPostman.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What OpenAPI versions does this tool support?",
    answer: "OpenAPI 3.0.x and Swagger 2.0, both as JSON. YAML inputs are parsed with a minimal inline parser — for complex YAML with anchors, arrays of request bodies, or $ref resolution, convert to JSON first using a tool like js-yaml."
  },
  {
    question: "What does the Postman Collection v2.1 format include?",
    answer: "The generated collection includes: all HTTP endpoints (GET, POST, PUT, PATCH, DELETE), request headers (Content-Type, Accept, auth headers), sample request bodies derived from schema properties, bearer token and API key auth from OpenAPI security schemes, and a collection-level info block with a UUID."
  },
  {
    question: "How do I import the collection into Postman?",
    answer: "Download the .json file. In Postman, click 'Import' → 'Upload Files' → select the file. The collection appears in your sidebar with all endpoints ready to test. Set environment variables like {{token}} or {{apiKey}} in a Postman environment."
  },
  {
    question: "Why does my complex spec not convert fully?",
    answer: "This tool handles the core fields from spec paths: methods, summaries, request body schemas, and security schemes. Deeply nested $ref pointers, allOf/oneOf schema composition, and multi-file specs are not resolved. For full fidelity, use the official openapi-to-postmanv2 npm package locally."
  },
  {
    question: "Is my API spec sent to a server?",
    answer: "No. All conversion runs entirely in your browser using JavaScript. Your spec — which may contain endpoint paths, auth schemes, and internal service names — never leaves your machine."
  },
  {
    question: "What is the difference between OpenAPI and Swagger?",
    answer: "Swagger 2.0 is the predecessor to OpenAPI 3.0. The OpenAPI Initiative adopted and renamed the spec starting with version 3.0. Structurally: Swagger uses 'host' + 'basePath' for the base URL, while OpenAPI 3.0 uses a 'servers' array. OpenAPI 3.0 also separates request body from parameters and adds a richer component/schema system."
  },
];
---

<BaseLayout
  title="OpenAPI to Postman Converter — Convert OpenAPI 3.0 / Swagger 2.0 to Postman Collection"
  description="Paste your OpenAPI 3.0 or Swagger 2.0 JSON spec and convert it to a Postman Collection v2.1 JSON file. Preserves endpoints, methods, request bodies, and auth schemes. Runs 100% in your browser."
  tool="OpenAPI to Postman, Swagger to Postman, API collection converter, OpenAPI converter, Postman collection generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "OpenAPI to Postman Converter",
    "url": "https://devplaybook.cc/tools/openapi-to-postman",
    "description": "Convert OpenAPI 3.0 or Swagger 2.0 JSON specs to Postman Collection v2.1. Runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">OpenAPI to Postman Converter</h1>
  <p class="text-text-muted mb-4">
    Paste your OpenAPI 3.0 or Swagger 2.0 JSON spec and generate a ready-to-import
    Postman Collection v2.1 JSON file. Preserves all endpoints, HTTP methods, request bodies,
    auth headers, and security schemes. Runs 100% in your browser — nothing is sent to any server.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> OpenAPI 3.0 + Swagger 2.0</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auth & headers preserved</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Download as .json</span>
  </div>
  <OpenApiToPostman client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="OpenAPI to Postman Converter" relatedTags={['api', 'openapi', 'swagger', 'postman', 'developer-tools', 'testing']} />
</BaseLayout>
