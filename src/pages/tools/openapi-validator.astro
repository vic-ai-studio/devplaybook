---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OpenApiValidator from '../../components/OpenApiValidator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What OpenAPI versions does this validator support?", answer: "This tool targets OpenAPI 3.x (3.0.x and 3.1.x). It validates required fields, checks for structural issues, and reports common mistakes in OpenAPI 3 specs. It accepts both YAML and JSON format." },
  { question: "What does the validator check?", answer: "It checks for required fields (openapi, info.title, info.version), validates all paths start with /, detects duplicate paths, finds missing operationIds, flags operations without responses, checks path parameter definitions, and warns about missing descriptions and server definitions." },
  { question: "Does it support YAML input?", answer: "Yes — you can paste YAML or JSON. The built-in parser handles standard OpenAPI YAML structures including nested objects and arrays. Very complex YAML (anchors, aliases, multi-line strings) may need to be converted to JSON first." },
  { question: "What is an operationId and why does it matter?", answer: "An operationId is a unique string identifying each API operation. It's required by many API client generators (like openapi-generator) and documentation tools. Missing or duplicate operationIds will cause issues when generating SDKs or documentation." },
  { question: "Is my API spec sent to any server?", answer: "No — all validation runs entirely in your browser using JavaScript. Your OpenAPI spec never leaves your machine." },
  { question: "What's the difference between errors and warnings?", answer: "Errors are issues that violate the OpenAPI specification and will likely cause problems with tooling (missing required fields, duplicate operationIds, undefined path parameters). Warnings are best-practice issues that won't break things but may cause poor documentation or SDK generation. Info items are suggestions for improvement." },
];
---

<BaseLayout
  title="OpenAPI Validator — Validate OpenAPI 3.x YAML or JSON Spec"
  description="Validate OpenAPI 3.x specs in YAML or JSON. Catch missing required fields, duplicate paths, and missing operationIds with line-level error messages. Runs in browser."
  tool="OpenAPI Validator, OpenAPI 3.x Validation, Swagger Validator, OpenAPI Linter, API Spec Checker"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">OpenAPI Validator</h1>
  <p class="text-text-muted mb-4">Paste your <strong>OpenAPI 3.x spec</strong> (YAML or JSON) to validate its structure. Catches missing required fields, undefined path parameters, duplicate paths, missing operationIds, and more — with <strong>error / warning / info</strong> severity levels and path references. Runs entirely in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> YAML & JSON input</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Error · Warning · Info levels</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Path references for each issue</span>
  </div>
  <OpenApiValidator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="OpenAPI Validator" relatedTags={['api', 'openapi', 'swagger', 'validation', 'backend', 'rest-api']} />
</BaseLayout>
