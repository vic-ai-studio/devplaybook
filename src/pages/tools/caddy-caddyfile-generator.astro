---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaddyfileGenerator from '../../components/CaddyfileGenerator.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Caddy?", answer: "Caddy is a modern, open-source web server written in Go. Its killer feature is automatic HTTPS — it automatically obtains and renews TLS certificates from Let's Encrypt with zero configuration. It's simpler than nginx for most use cases, with a human-readable Caddyfile config format, HTTP/2 and HTTP/3 support, and a powerful plugin ecosystem." },
  { question: "How does Caddy automatic HTTPS work?", answer: "When you specify a real domain in the Caddyfile (e.g., 'example.com {}'), Caddy automatically requests a TLS certificate from Let's Encrypt via ACME. It handles domain validation, certificate renewal (60 days before expiry), and reloads automatically. No certbot, no cron jobs. Works for any publicly reachable domain pointing to your server." },
  { question: "What is the difference between Caddy and nginx?", answer: "Caddy's strengths: automatic HTTPS (zero config), simpler config syntax, built-in HTTP/3 (QUIC), auto-reload on config change, and a JSON API for dynamic config. nginx's strengths: lower memory use, more fine-grained tuning, decades of production battle-testing, wider hosting panel support. For new projects, Caddy is often faster to set up. For high-performance tuning, nginx gives more knobs." },
  { question: "How do I reverse proxy with Caddy?", answer: "Minimal Caddyfile: 'example.com { reverse_proxy localhost:3000 }'. That's it — Caddy handles HTTPS automatically. For health checks: 'reverse_proxy localhost:3000 { health_uri /health; health_interval 10s }'. For load balancing multiple backends: 'reverse_proxy localhost:3000 localhost:3001 localhost:3002'. Default balancing is round-robin." },
  { question: "How do I run Caddy?", answer: "Install: on Ubuntu, 'sudo apt install caddy'. Place your Caddyfile in /etc/caddy/Caddyfile. Start: 'sudo systemctl start caddy'. Test config: 'caddy validate --config /etc/caddy/Caddyfile'. Apply without restart: 'caddy reload --config /etc/caddy/Caddyfile'. For Docker: 'docker run -p 80:80 -p 443:443 -v $PWD/Caddyfile:/etc/caddy/Caddyfile caddy'." },
  { question: "How do I add plugins to Caddy?", answer: "Caddy plugins are compiled in. Use the official builder: xcaddy (go install github.com/caddyserver/xcaddy/cmd/xcaddy@latest). Build with plugins: 'xcaddy build --with github.com/mholt/caddy-ratelimit'. Or use the web builder at caddyserver.com/download to download a custom binary. Common plugins: caddy-ratelimit, caddy-crowdsec-bouncer, caddy-dns/* for DNS challenges." },
];
---

<BaseLayout
  title="Caddy Caddyfile Generator — Automatic HTTPS Config — Free Online Tool"
  description="Generate Caddyfile configurations for static sites, reverse proxies, PHP, and API gateways. Caddy handles automatic HTTPS via Let's Encrypt. Includes compression, security headers, rate limiting, and basic auth options."
  tool="caddy caddyfile generator, caddy config generator, caddy reverse proxy, caddy automatic https, caddy web server config, caddyfile example"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Caddy Caddyfile Generator</h1>
  <p class="text-text-muted mb-4">
    Generate a production-ready <code class="bg-surface px-1 rounded text-sm">Caddyfile</code> for your server.
    Caddy automatically provisions and renews HTTPS certificates — no certbot needed.
    Supports static sites, reverse proxies, PHP-FPM, and API gateways.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Automatic HTTPS</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Reverse proxy + health checks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Security headers built-in</span>
  </div>
  <CaddyfileGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <AffiliateSection category={['hosting', 'devops']} />
  <ToolPageCta currentTool="Caddy Caddyfile Generator" relatedTags={['caddy', 'web-server', 'ssl', 'devops', 'reverse-proxy']} />
</BaseLayout>
