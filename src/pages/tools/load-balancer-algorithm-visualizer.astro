---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LoadBalancerVisualizer from '../../components/LoadBalancerVisualizer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is a load balancer and why is it important?",
    answer: "A load balancer distributes incoming network requests across multiple backend servers so no single server becomes a bottleneck. It improves availability (if one server fails, others take over), scalability (add servers to handle more traffic), and performance (requests go to the least-busy or fastest server). Almost every production web service with more than one server uses a load balancer.",
  },
  {
    question: "When should I use Round Robin load balancing?",
    answer: "Round Robin is the right default when all your servers have similar hardware specs and your requests are roughly uniform in cost (e.g. serving static files or lightweight API calls). It requires no state tracking and has near-zero overhead, making it ideal for high-throughput scenarios where simplicity matters. Avoid it when requests vary widely in processing time, as a slow request will monopolise a server while others sit idle.",
  },
  {
    question: "What is the difference between Least Connections and Least Response Time?",
    answer: "Least Connections picks the server with the fewest active connections at the moment of routing. Least Response Time goes further by factoring in average response latency—it favours a server that is fast even if it has more connections, over a slow server with few connections. Use Least Connections for CPU-bound workloads; use Least Response Time for I/O-bound or variable-latency services.",
  },
  {
    question: "Why would I choose IP Hash over Round Robin?",
    answer: "IP Hash routes each client IP to the same backend server every time (session affinity / sticky sessions). This is essential when server-side session state is stored in memory and not shared across instances—for example, legacy PHP or Node apps that store login sessions locally. If your app stores sessions in Redis or a database, you do not need IP Hash and can use any stateless algorithm.",
  },
  {
    question: "How does Weighted Round Robin work in practice?",
    answer: "You assign each server a weight (e.g. 1, 2, 4). The load balancer expands this into a request pool proportional to weights, then cycles through it. A server with weight 4 gets four requests for every one sent to a weight-1 server. This is useful in mixed-hardware environments—for example, if Server A has twice the CPU cores of Server B, give it weight 2 to utilise its extra capacity.",
  },
  {
    question: "What does the 'Uniformity Score' in this visualizer measure?",
    answer: "The Uniformity Score (0–100%) measures how evenly requests are spread across all servers, using the coefficient of variation of per-server request counts. A score of 100% means every server received exactly the same number of requests (perfect distribution). Scores below 80% indicate meaningful imbalance, which may signal that an algorithm is a poor fit for the simulated workload or server configuration.",
  },
];
---

<BaseLayout
  title="Load Balancer Algorithm Visualizer — Round Robin, Least Connections & More"
  description="Interactively visualize how Round Robin, Least Connections, IP Hash, Weighted Round Robin, Random, and Least Response Time load balancing algorithms distribute requests across servers. Free, browser-based."
  tool="Load Balancer Algorithm Visualizer, Round Robin Visualizer, Least Connections Demo, Weighted Round Robin, Load Balancing Simulation"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Load Balancer Algorithm Visualizer</h1>
  <p class="text-text-muted mb-4">
    Simulate six real-world load balancing algorithms and watch requests distribute across servers in real time.
    Toggle server health, adjust weights, and compare distribution uniformity to understand which algorithm fits your architecture.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 6 algorithms side-by-side</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>

  <LoadBalancerVisualizer client:only="preact" />

  <AdUnit slot="auto" format="auto" label="Advertisement" />

  <div class="mt-8 p-5 bg-bg-card border border-border rounded-xl space-y-3">
    <h2 class="text-lg font-semibold">Choosing the Right Load Balancing Algorithm</h2>
    <p class="text-sm text-text-muted leading-relaxed">
      The best algorithm depends on your server homogeneity, request variance, and statefulness requirements.
      <strong class="text-text">Round Robin</strong> is the simplest starting point for uniform servers.
      <strong class="text-text">Least Connections</strong> handles variable-length requests better.
      <strong class="text-text">IP Hash</strong> is necessary when sessions are pinned to a specific backend.
      <strong class="text-text">Weighted Round Robin</strong> makes mixed-hardware fleets more efficient.
      <strong class="text-text">Least Response Time</strong> is best for latency-sensitive APIs.
      <strong class="text-text">Random</strong> scales well under very high traffic with no coordination overhead.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 pt-1">
      <div class="bg-bg border border-border rounded-lg p-3">
        <p class="text-xs font-semibold text-primary mb-1">Stateless workloads</p>
        <p class="text-xs text-text-muted">Round Robin or Random — zero overhead, deterministic or probabilistic distribution across identical nodes.</p>
      </div>
      <div class="bg-bg border border-border rounded-lg p-3">
        <p class="text-xs font-semibold text-primary mb-1">Long-running requests</p>
        <p class="text-xs text-text-muted">Least Connections or Least Response Time — avoids piling new work onto already-busy servers.</p>
      </div>
      <div class="bg-bg border border-border rounded-lg p-3">
        <p class="text-xs font-semibold text-primary mb-1">Session-based apps</p>
        <p class="text-xs text-text-muted">IP Hash — ensures the same client always hits the same server without an external session store.</p>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />

  <ToolPageCta currentTool="Load Balancer Algorithm Visualizer" relatedTags={['networking', 'devops', 'backend', 'architecture', 'system-design']} />
</BaseLayout>
