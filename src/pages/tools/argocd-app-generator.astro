---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is ArgoCD?", answer: "ArgoCD is a declarative GitOps continuous delivery tool for Kubernetes. It syncs Kubernetes manifests from a Git repository to a cluster, ensuring the cluster state matches the desired state in Git. Supports Helm, Kustomize, Jsonnet, and plain YAML. Provides a web UI, CLI, and Kubernetes CRDs for application management." },
  { question: "What is a GitOps workflow?", answer: "GitOps uses Git as the single source of truth for infrastructure and application configuration. Changes are made via pull requests to a Git repo; an agent (like ArgoCD) detects changes and applies them to the cluster. This provides auditability (all changes are in Git), easy rollback (revert the commit), and drift detection (cluster state vs Git state)." },
  { question: "What is an ArgoCD Application?", answer: "An Application is a Kubernetes CRD (Custom Resource Definition) that defines: the source (Git repo URL, path, revision), the destination (cluster server, namespace), and sync policy. ArgoCD monitors the source and syncs the destination to match. Applications can be created via YAML, the CLI (`argocd app create`), or the web UI." },
  { question: "What is automated sync in ArgoCD?", answer: "When automated sync is enabled, ArgoCD automatically applies changes from Git to the cluster without manual intervention. You can also enable `selfHeal: true` to revert manual changes to the cluster (drift correction), and `prune: true` to remove resources not in Git. Automated sync is common for non-production environments; production may require manual approval." },
  { question: "How do ArgoCD ApplicationSets work?", answer: "ApplicationSets allow you to generate multiple Application resources from a template. Generators include: list (explicit list of clusters), cluster (all registered clusters), git (subdirectory per app), and matrix (combinations). Example: deploy one Application per cluster in your fleet from a single ApplicationSet definition." },
];
---

<BaseLayout
  title="ArgoCD Application Generator — GitOps Kubernetes App YAML Builder"
  description="Generate ArgoCD Application manifest YAML from form inputs. Configure Git source, Kubernetes destination, Helm/Kustomize settings, sync policy, and health checks for GitOps deployments."
  tool="ArgoCD Application Generator, GitOps Kubernetes YAML Builder, ArgoCD App Manifest Creator, ArgoCD Helm App Generator, Kubernetes GitOps Tool"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">ArgoCD Application Generator</h1>
  <p class="text-text-muted mb-4">Generate ArgoCD Application manifests for GitOps deployments. Configure Git source, destination cluster, Helm/Kustomize settings, and sync policies.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Helm + Kustomize + plain YAML</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Sync policy builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multi-cluster support</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <!-- Form -->
    <div class="space-y-4">
      <!-- App metadata -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Application Metadata</h2>
        <div class="space-y-3">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium mb-1">App Name</label>
              <input id="app-name" type="text" value="my-app"
                class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Project</label>
              <input id="app-project" type="text" value="default"
                class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
            </div>
          </div>
        </div>
      </div>

      <!-- Source -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Source (Git)</h2>
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium mb-1">Repository URL</label>
            <input id="src-repo" type="text" value="https://github.com/myorg/my-app.git"
              class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium mb-1">Target Revision</label>
              <input id="src-revision" type="text" value="HEAD"
                class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Path</label>
              <input id="src-path" type="text" value="k8s/"
                class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Source Type</label>
            <select id="src-type" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="helm">Helm Chart</option>
              <option value="kustomize">Kustomize</option>
              <option value="directory">Directory (plain YAML)</option>
            </select>
          </div>
          <div id="helm-options" class="space-y-2">
            <div>
              <label class="block text-sm font-medium mb-1">Helm Values Files</label>
              <input id="helm-values" type="text" value="values.yaml,values-prod.yaml"
                class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Helm Release Name</label>
              <input id="helm-release" type="text" value="my-app"
                class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
            </div>
          </div>
        </div>
      </div>

      <!-- Destination -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Destination</h2>
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium mb-1">Server URL</label>
            <select id="dest-server" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="https://kubernetes.default.svc">Local cluster (in-cluster)</option>
              <option value="custom">Custom URL...</option>
            </select>
          </div>
          <div id="custom-server-wrap" class="hidden">
            <input id="dest-server-custom" type="text" placeholder="https://my-cluster.example.com"
              class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Namespace</label>
            <input id="dest-ns" type="text" value="production"
              class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
          </div>
        </div>
      </div>

      <!-- Sync policy -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">Sync Policy</h2>
        <div class="space-y-2">
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="sync-auto" /> Enable automated sync
          </label>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="sync-prune" /> Prune resources (delete removed resources)
          </label>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="sync-selfheal" /> Self-heal (revert manual changes)
          </label>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="sync-create-ns" checked /> Create namespace if not exists
          </label>
        </div>
      </div>
    </div>

    <!-- Output -->
    <div>
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-sm font-semibold">Generated YAML</h2>
        <div class="flex gap-2">
          <button class="argo-view text-xs px-2 py-1 border border-border text-text-muted rounded hover:border-primary" data-view="app">Application</button>
          <button class="argo-view text-xs px-2 py-1 border border-border text-text-muted rounded hover:border-primary" data-view="cli">CLI</button>
          <button id="copy-argo" class="text-xs px-2 py-1 bg-primary text-white rounded hover:bg-primary/80">Copy</button>
        </div>
      </div>
      <pre id="argo-output" class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre-wrap min-h-[500px] max-h-[700px] overflow-y-auto"></pre>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="ArgoCD Application Generator" relatedTags={['argocd', 'gitops', 'kubernetes', 'k8s', 'devops', 'helm', 'cd']} />
</BaseLayout>

<script>
  let argoView = 'app';

  function getVal(id: string): string {
    return (document.getElementById(id) as HTMLInputElement | HTMLSelectElement)?.value || '';
  }
  function getChecked(id: string): boolean {
    return (document.getElementById(id) as HTMLInputElement)?.checked ?? false;
  }

  function generate() {
    const appName = getVal('app-name');
    const project = getVal('app-project');
    const repo = getVal('src-repo');
    const revision = getVal('src-revision');
    const path = getVal('src-path');
    const srcType = getVal('src-type');
    const helmValues = getVal('helm-values');
    const helmRelease = getVal('helm-release');
    const destServerSel = getVal('dest-server');
    const destServerCustom = getVal('dest-server-custom');
    const destServer = destServerSel === 'custom' ? destServerCustom : destServerSel;
    const destNs = getVal('dest-ns');
    const syncAuto = getChecked('sync-auto');
    const syncPrune = getChecked('sync-prune');
    const selfHeal = getChecked('sync-selfheal');
    const createNs = getChecked('sync-create-ns');

    // Source block
    let sourceBlock = '';
    if (srcType === 'helm') {
      const valuesFiles = helmValues.split(',').map(v => `        - ${v.trim()}`).join('\n');
      sourceBlock = `  source:
    repoURL: ${repo}
    targetRevision: ${revision}
    path: ${path}
    helm:
      releaseName: ${helmRelease}
      valueFiles:
${valuesFiles}`;
    } else if (srcType === 'kustomize') {
      sourceBlock = `  source:
    repoURL: ${repo}
    targetRevision: ${revision}
    path: ${path}
    kustomize:
      namePrefix: ${appName}-`;
    } else {
      sourceBlock = `  source:
    repoURL: ${repo}
    targetRevision: ${revision}
    path: ${path}`;
    }

    // Sync policy
    let syncBlock = `  syncPolicy:
    syncOptions:
      - Validate=false
      - CreateNamespace=${createNs}`;
    if (syncAuto) {
      syncBlock += `
    automated:
      prune: ${syncPrune}
      selfHeal: ${selfHeal}`;
    }

    let output = '';
    if (argoView === 'app') {
      output = `apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: ${appName}
  namespace: argocd
  labels:
    app.kubernetes.io/name: ${appName}
spec:
  project: ${project}
${sourceBlock}
  destination:
    server: ${destServer}
    namespace: ${destNs}
${syncBlock}
  revisionHistoryLimit: 10`;
    } else {
      const autoFlag = syncAuto ? ' --sync-policy automated' : '';
      const pruneFlag = syncPrune ? ' --auto-prune' : '';
      const selfHealFlag = selfHeal ? ' --self-heal' : '';
      const helmFlags = srcType === 'helm' ? ` --helm-set-string image.tag=latest` : '';
      output = `# ArgoCD CLI commands for ${appName}

# 1. Login to ArgoCD
argocd login <argocd-server> --username admin --password <password>

# 2. Add Git repository (if not already added)
argocd repo add ${repo} --username <user> --password <token>

# 3. Create the application
argocd app create ${appName} \\
  --project ${project} \\
  --repo ${repo} \\
  --path ${path} \\
  --revision ${revision} \\
  --dest-server ${destServer} \\
  --dest-namespace ${destNs}${autoFlag}${pruneFlag}${selfHealFlag} \\
  --sync-option CreateNamespace=${createNs}${helmFlags}

# 4. Sync the application
argocd app sync ${appName}

# 5. Watch sync status
argocd app wait ${appName}

# 6. View application
argocd app get ${appName}`;
    }

    document.getElementById('argo-output')!.textContent = output;
  }

  document.getElementById('src-type')!.addEventListener('change', () => {
    const srcType = (document.getElementById('src-type') as HTMLSelectElement).value;
    (document.getElementById('helm-options') as HTMLElement).style.display = srcType === 'helm' ? 'block' : 'none';
    generate();
  });

  document.getElementById('dest-server')!.addEventListener('change', () => {
    const isCustom = (document.getElementById('dest-server') as HTMLSelectElement).value === 'custom';
    (document.getElementById('custom-server-wrap') as HTMLElement).classList.toggle('hidden', !isCustom);
    generate();
  });

  document.querySelectorAll('.argo-view').forEach(btn => {
    btn.addEventListener('click', () => {
      argoView = btn.getAttribute('data-view')!;
      document.querySelectorAll('.argo-view').forEach(b => {
        b.classList.remove('bg-primary', 'text-white');
        b.classList.add('border', 'border-border', 'text-text-muted');
      });
      btn.classList.add('bg-primary', 'text-white');
      btn.classList.remove('border', 'border-border', 'text-text-muted');
      generate();
    });
  });

  document.getElementById('copy-argo')!.addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('argo-output')!.textContent || '');
    const btn = document.getElementById('copy-argo')!; btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = 'Copy', 2000);
  });

  document.querySelectorAll('input, select').forEach(el => {
    el.addEventListener('input', generate);
    el.addEventListener('change', generate);
  });

  generate();
</script>
