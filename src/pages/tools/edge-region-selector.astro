---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What are edge function regions and why do they matter?", answer: "Edge functions run in data centers close to your users, reducing network latency by 50-200ms compared to a single centralized region. For APIs serving users globally, deploying to multiple edge regions can significantly improve response times. Cloudflare Workers deploy to 300+ locations globally by default; AWS Lambda@Edge deploys to CloudFront PoPs." },
  { question: "Which edge regions should I prioritize for a US-focused app?", answer: "For US-focused traffic: US East (N. Virginia / Ohio) and US West (Oregon / N. California) cover 95%+ of US users with under 50ms latency. Add US Central (Iowa) for Midwest coverage. For a US-only audience, 2-3 US regions cover the vast majority of users adequately." },
  { question: "How do I select edge regions for a global audience?", answer: "For global coverage: prioritize US East, EU West (Ireland/Frankfurt), and AP Southeast (Singapore/Tokyo). These three regions cover the largest concentrations of internet users and developers. Add US West, AP South (Mumbai), and SA East (São Paulo) for comprehensive global coverage. Cloudflare Workers handles this automatically." },
  { question: "What is the difference between Cloudflare Workers edge and AWS Lambda@Edge?", answer: "Cloudflare Workers deploy to all 300+ Cloudflare PoPs globally with zero configuration — no region selection needed. AWS Lambda@Edge deploys to CloudFront edge locations (~450 globally) but requires origin Lambda in a specific region. Vercel Edge Functions deploy to Vercel's network (powered by Cloudflare). For most use cases, Cloudflare Workers provides the best global coverage automatically." },
  { question: "How should I weight regions for cost optimization?", answer: "Weight regions by your actual user traffic distribution. If 60% of users are in the US, 25% in EU, and 15% in Asia, deploy proportionally. Use your analytics (Cloudflare Analytics, Google Analytics, or CDN logs) to determine actual geographic traffic distribution. Over-deploying to low-traffic regions adds cost without meaningful latency improvement." },
];
---

<BaseLayout
  title="Edge Function Region Selector — Choose Optimal Edge Regions by Geography"
  description="Select optimal edge function regions based on your user geography. Set user traffic percentages by location and get recommended deployment regions for Cloudflare Workers, Lambda@Edge, and Vercel. Free tool."
  tool="edge function region selector, cloudflare workers regions, lambda edge regions, vercel edge regions, edge computing region optimizer, serverless region selector"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Edge Function Region Selector",
    "url": "https://devplaybook.cc/tools/edge-region-selector",
    "description": "Select optimal edge regions based on user geography for Cloudflare Workers, Lambda@Edge, and Vercel.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Edge Function Region Selector</h1>
  <p class="text-text-muted mb-4">Set your user geography distribution and get recommended edge deployment regions for Cloudflare Workers, AWS Lambda@Edge, and Vercel. Includes estimated latency and coverage scores.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Geography-based recommendations</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Cloudflare / Lambda@Edge / Vercel</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Coverage score</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs in browser</span>
  </div>

  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-semibold mb-3">User Traffic Distribution <span class="text-xs text-text-muted font-normal">(adjust sliders — total should sum to 100%)</span></h2>
    <div id="geoSliders" class="space-y-3"></div>
    <div class="flex justify-between items-center mt-3 pt-3 border-t border-border">
      <span class="text-xs text-text-muted">Total traffic</span>
      <span id="totalPct" class="text-sm font-bold text-primary">0%</span>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4" id="platforms"></div>

  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-semibold mb-3">Recommendation</h2>
    <div id="recommendation" class="text-sm text-text-muted"></div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Edge Region Selector" relatedTags={['cloudflare', 'aws', 'vercel', 'edge', 'serverless', 'latency']} />
</BaseLayout>

<script is:inline>
(function() {
  const GEOS = [
    { id: 'us_east',    label: 'US East',         default: 35, regions: { cf: 'Automatic (US East PoPs)', lambda: 'us-east-1 (N. Virginia)', vercel: 'iad1 (Washington D.C.)' } },
    { id: 'us_west',    label: 'US West',          default: 15, regions: { cf: 'Automatic (US West PoPs)', lambda: 'us-west-2 (Oregon)',       vercel: 'sfo1 (San Francisco)' } },
    { id: 'eu_west',    label: 'EU West',          default: 20, regions: { cf: 'Automatic (EU PoPs)',     lambda: 'eu-west-1 (Ireland)',       vercel: 'cdg1 (Paris)' } },
    { id: 'eu_central', label: 'EU Central',       default: 8,  regions: { cf: 'Automatic (EU PoPs)',     lambda: 'eu-central-1 (Frankfurt)', vercel: 'fra1 (Frankfurt)' } },
    { id: 'ap_east',    label: 'AP East (Tokyo)',  default: 7,  regions: { cf: 'Automatic (AP PoPs)',     lambda: 'ap-northeast-1 (Tokyo)',   vercel: 'hnd1 (Tokyo)' } },
    { id: 'ap_se',      label: 'AP SE (Singapore)',default: 5,  regions: { cf: 'Automatic (AP PoPs)',     lambda: 'ap-southeast-1 (Singapore)',vercel: 'sin1 (Singapore)' } },
    { id: 'ap_south',   label: 'South Asia',       default: 5,  regions: { cf: 'Automatic (AP PoPs)',     lambda: 'ap-south-1 (Mumbai)',      vercel: 'bom1 (Mumbai)' } },
    { id: 'sa',         label: 'South America',    default: 3,  regions: { cf: 'Automatic (SA PoPs)',     lambda: 'sa-east-1 (São Paulo)',    vercel: 'gru1 (São Paulo)' } },
    { id: 'other',      label: 'Other / Rest',     default: 2,  regions: { cf: 'Automatic (global)',      lambda: 'Multi-region replication', vercel: 'Global Edge Network' } },
  ];

  // Build sliders
  const slidersEl = document.getElementById('geoSliders');
  GEOS.forEach(g => {
    slidersEl.innerHTML += `
      <div class="flex items-center gap-3">
        <label class="text-xs w-36 shrink-0 text-text-muted">${g.label}</label>
        <input type="range" id="geo_${g.id}" min="0" max="100" value="${g.default}" class="flex-1 accent-primary" />
        <span class="text-xs w-10 text-right font-mono" id="geo_${g.id}_val">${g.default}%</span>
      </div>`;
  });

  function getValues() {
    const vals = {};
    GEOS.forEach(g => { vals[g.id] = parseInt(document.getElementById('geo_' + g.id).value); });
    return vals;
  }

  function update() {
    const vals = getValues();
    const total = Object.values(vals).reduce((s, v) => s + v, 0);
    const totalEl = document.getElementById('totalPct');
    totalEl.textContent = total + '%';
    totalEl.className = 'text-sm font-bold ' + (total === 100 ? 'text-green-400' : total > 100 ? 'text-red-400' : 'text-yellow-400');

    // Sorted by traffic
    const sorted = GEOS.map(g => ({ ...g, pct: vals[g.id] })).sort((a, b) => b.pct - a.pct);
    const covered = sorted.filter(g => g.pct > 0);
    const topRegions = covered.slice(0, 5);
    const coveragePct = topRegions.reduce((s, g) => s + g.pct, 0);

    const platforms = [
      {
        name: 'Cloudflare Workers',
        color: 'text-orange-400',
        border: 'border-orange-500/30',
        note: '300+ global PoPs — no region selection needed',
        score: 98,
        regions: topRegions.map(g => ({ label: g.label, pct: g.pct, region: g.regions.cf })),
        tip: 'Workers automatically deploy globally — focus on CPU time budget, not region selection.',
      },
      {
        name: 'AWS Lambda@Edge',
        color: 'text-yellow-400',
        border: 'border-yellow-500/30',
        note: 'Deploy origin + CloudFront distribution',
        score: Math.round(coveragePct * 0.95),
        regions: topRegions.map(g => ({ label: g.label, pct: g.pct, region: g.regions.lambda })),
        tip: 'Set CloudFront to cache at all edge locations. Origin Lambda in us-east-1 for best global propagation.',
      },
      {
        name: 'Vercel Edge',
        color: 'text-blue-400',
        border: 'border-blue-500/30',
        note: 'Deploys to Vercel global edge automatically',
        score: 95,
        regions: topRegions.map(g => ({ label: g.label, pct: g.pct, region: g.regions.vercel })),
        tip: 'Vercel deploys edge functions globally. Use `export const config = { runtime: "edge" }` in Next.js.',
      },
    ];

    document.getElementById('platforms').innerHTML = platforms.map(p => `
      <div class="bg-bg-card border ${p.border} rounded-lg p-4">
        <div class="flex justify-between items-center mb-2">
          <h3 class="text-sm font-semibold ${p.color}">${p.name}</h3>
          <span class="text-xs font-bold text-primary">${p.score}% coverage</span>
        </div>
        <p class="text-xs text-text-muted mb-3">${p.note}</p>
        <div class="space-y-1.5 mb-3">
          ${p.regions.slice(0, 4).map(r => `
            <div class="flex items-start gap-2 text-xs">
              <span class="text-text-muted w-4 shrink-0">${r.pct}%</span>
              <div>
                <span class="text-text font-medium">${r.label}</span>
                <span class="text-text-muted"> → ${r.region}</span>
              </div>
            </div>`).join('')}
        </div>
        <p class="text-xs text-accent italic">${p.tip}</p>
      </div>`).join('');

    const topGeo = sorted[0];
    document.getElementById('recommendation').innerHTML = `
      <p class="mb-2">Based on your traffic distribution (${total}% accounted for):</p>
      <ul class="space-y-1 list-disc list-inside text-xs">
        <li>Your largest user base is in <strong>${topGeo.label}</strong> (${topGeo.pct}%) — prioritize low latency there</li>
        <li>Top ${topRegions.length} regions cover <strong>${coveragePct}%</strong> of your users</li>
        ${topGeo.pct > 60 ? '<li>High concentration in one region — a single-region deployment may be sufficient if latency requirements are relaxed</li>' : ''}
        <li><strong>Cloudflare Workers</strong> is the simplest global deployment (no region config needed)</li>
        <li>For Lambda@Edge, deploy to <strong>${topRegions[0]?.regions.lambda}</strong> as origin with global CloudFront</li>
      </ul>`;
  }

  GEOS.forEach(g => {
    const el = document.getElementById('geo_' + g.id);
    el.addEventListener('input', () => {
      document.getElementById('geo_' + g.id + '_val').textContent = el.value + '%';
      update();
    });
  });

  update();
})();
</script>
