---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What are SQL window functions?", answer: "Window functions perform calculations across a set of rows related to the current row, without collapsing rows like GROUP BY does. They use an OVER() clause to define the 'window' of rows. Common window functions: ROW_NUMBER(), RANK(), DENSE_RANK(), LAG(), LEAD(), SUM() OVER(), AVG() OVER(), FIRST_VALUE(), LAST_VALUE(), NTILE()." },
  { question: "What is PARTITION BY?", answer: "PARTITION BY divides the result set into groups (partitions) and applies the window function independently to each group. Like GROUP BY but doesn't collapse rows. Example: ROW_NUMBER() OVER (PARTITION BY department_id ORDER BY salary DESC) assigns row numbers within each department." },
  { question: "What is the difference between RANK and DENSE_RANK?", answer: "RANK() leaves gaps after ties. If two rows tie at position 1, the next rank is 3. DENSE_RANK() has no gaps — after a tie at rank 1, the next rank is 2. ROW_NUMBER() always assigns unique sequential numbers regardless of ties." },
  { question: "What are LAG and LEAD?", answer: "LAG(column, offset, default) accesses a value from a previous row (offset rows back). LEAD(column, offset, default) accesses a future row. Common use case: calculate the difference from the previous period — LAG(revenue) subtracted from the current revenue gives period-over-period change." },
];
---

<BaseLayout
  title="SQL Window Functions Builder — ROW_NUMBER, RANK, LAG, LEAD, OVER"
  description="Build SQL window functions with an interactive guide. Configure OVER, PARTITION BY, ORDER BY, and frame clauses for ROW_NUMBER, RANK, DENSE_RANK, LAG, LEAD, and aggregate windows."
  tool="SQL Window Functions Builder, OVER Clause Builder, SQL PARTITION BY, ROW_NUMBER RANK DENSE_RANK"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">SQL Window Functions Builder</h1>
  <p class="text-text-muted mb-4">Build window function queries interactively. Configure OVER, PARTITION BY, ORDER BY, and frames for all major window functions.</p>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
    <!-- Config -->
    <div class="space-y-4">
      <div class="bg-bg-card border border-border rounded-xl p-5 space-y-3">
        <h2 class="text-base font-semibold">Window Function</h2>
        <div>
          <label class="block text-xs font-medium mb-1">Function</label>
          <select id="wf-func" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
            <optgroup label="Ranking">
              <option value="ROW_NUMBER()">ROW_NUMBER() — unique row number</option>
              <option value="RANK()">RANK() — rank with gaps</option>
              <option value="DENSE_RANK()">DENSE_RANK() — rank without gaps</option>
              <option value="NTILE(4)">NTILE(n) — divide into n buckets</option>
              <option value="PERCENT_RANK()">PERCENT_RANK() — relative rank 0..1</option>
              <option value="CUME_DIST()">CUME_DIST() — cumulative distribution</option>
            </optgroup>
            <optgroup label="Lag / Lead">
              <option value="LAG">LAG(col, offset, default) — previous row</option>
              <option value="LEAD">LEAD(col, offset, default) — next row</option>
              <option value="FIRST_VALUE">FIRST_VALUE(col) — first in window</option>
              <option value="LAST_VALUE">LAST_VALUE(col) — last in window</option>
              <option value="NTH_VALUE">NTH_VALUE(col, n) — nth in window</option>
            </optgroup>
            <optgroup label="Aggregate">
              <option value="SUM">SUM(col) OVER — running/grouped sum</option>
              <option value="AVG">AVG(col) OVER — running/grouped avg</option>
              <option value="COUNT">COUNT(*) OVER — running count</option>
              <option value="MIN">MIN(col) OVER — window minimum</option>
              <option value="MAX">MAX(col) OVER — window maximum</option>
            </optgroup>
          </select>
        </div>

        <div id="col-row">
          <label class="block text-xs font-medium mb-1">Column Name</label>
          <input id="wf-col" type="text" value="salary" placeholder="column_name" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>

        <div id="offset-row" class="hidden">
          <label class="block text-xs font-medium mb-1">Offset / N</label>
          <input id="wf-offset" type="number" value="1" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>

        <div id="default-row" class="hidden">
          <label class="block text-xs font-medium mb-1">Default value (when no row)</label>
          <input id="wf-default" type="text" value="0" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>

        <div>
          <label class="block text-xs font-medium mb-1">Alias (AS)</label>
          <input id="wf-alias" type="text" value="window_result" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5 space-y-3">
        <h2 class="text-base font-semibold">OVER Clause</h2>
        <div>
          <label class="block text-xs font-medium mb-1">PARTITION BY (comma-separated, optional)</label>
          <input id="wf-partition" type="text" value="department_id" placeholder="col1, col2" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-xs font-medium mb-1">ORDER BY</label>
          <input id="wf-order" type="text" value="salary DESC" placeholder="col1 ASC, col2 DESC" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-xs font-medium mb-1">Frame (optional, for aggregates)</label>
          <select id="wf-frame" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
            <option value="">No frame (default)</option>
            <option value="ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW">Running total (ROWS UNBOUNDED PRECEDING → CURRENT)</option>
            <option value="ROWS BETWEEN 2 PRECEDING AND CURRENT ROW">Moving avg 3 rows (2 PRECEDING → CURRENT)</option>
            <option value="ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING">From current to end</option>
            <option value="ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING">Entire partition</option>
            <option value="RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW">RANGE (include ties)</option>
          </select>
        </div>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5 space-y-3">
        <h2 class="text-base font-semibold">Full Query</h2>
        <div>
          <label class="block text-xs font-medium mb-1">Table name</label>
          <input id="wf-table" type="text" value="employees" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-xs font-medium mb-1">Other SELECT columns</label>
          <input id="wf-other-cols" type="text" value="id, name, department_id, salary" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>
      </div>
    </div>

    <!-- Output -->
    <div class="space-y-4">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold">Generated SQL</h2>
          <button id="copy-sql" class="text-xs text-text-muted border border-border px-2 py-1 rounded hover:bg-bg">Copy</button>
        </div>
        <pre id="sql-out" class="text-sm font-mono bg-bg rounded-lg p-3 overflow-auto text-text-muted whitespace-pre"></pre>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold mb-3">Function Reference</h2>
        <div id="func-ref" class="text-xs text-text-muted space-y-2 leading-relaxed"></div>
      </div>
    </div>
  </div>

  <AdUnit slot="in-content" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SQL Window Functions Builder" relatedTags={['database', 'sql', 'postgresql', 'mysql', 'analytics']} />
</BaseLayout>

<script>
const refs: Record<string, string> = {
  'ROW_NUMBER()': 'Assigns a unique sequential integer to each row within the partition. No ties — every row gets a distinct number.',
  'RANK()': 'Assigns rank within the partition. Tied rows get the same rank, and subsequent ranks skip numbers (1, 1, 3, 4…).',
  'DENSE_RANK()': 'Like RANK() but no gaps. Tied rows get the same rank, and the next rank is one higher (1, 1, 2, 3…).',
  'NTILE(4)': 'Divides rows in the partition into n roughly equal groups (buckets). Returns the bucket number (1 through n).',
  'PERCENT_RANK()': 'Returns the relative rank as a value between 0 and 1. Formula: (rank - 1) / (total rows - 1).',
  'CUME_DIST()': 'Returns the cumulative distribution — fraction of rows ≤ current row. Value between 0 (exclusive) and 1 (inclusive).',
  'LAG': 'Returns a value from a previous row. offset defaults to 1. default value used when there is no previous row.',
  'LEAD': 'Returns a value from a subsequent row. offset defaults to 1. default value used when there is no next row.',
  'FIRST_VALUE': 'Returns the first value in the window frame. Use RANGE BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING to get first value in the full partition.',
  'LAST_VALUE': 'Returns the last value in the window frame. Default frame ends at current row — add ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING to get true last value.',
  'NTH_VALUE': 'Returns the nth value in the window frame (1-indexed).',
  'SUM': 'Running or grouped sum depending on the frame. With ROWS UNBOUNDED PRECEDING produces a cumulative sum.',
  'AVG': 'Running or grouped average. With a sliding frame produces a moving average.',
  'COUNT': 'Running count within the window. COUNT(*) counts all rows, COUNT(col) ignores NULLs.',
  'MIN': 'Minimum value within the window frame.',
  'MAX': 'Maximum value within the window frame.',
};

function sv(id: string) { return (document.getElementById(id) as HTMLInputElement)?.value?.trim() || ''; }

function build() {
  const funcSel = sv('wf-func');
  const col = sv('wf-col') || 'salary';
  const offset = sv('wf-offset') || '1';
  const def = sv('wf-default') || '0';
  const alias = sv('wf-alias') || 'window_result';
  const partition = sv('wf-partition');
  const order = sv('wf-order');
  const frame = sv('wf-frame');
  const table = sv('wf-table') || 'employees';
  const otherCols = sv('wf-other-cols');

  // Show/hide config rows
  const needsCol = !['ROW_NUMBER()','RANK()','DENSE_RANK()','PERCENT_RANK()','CUME_DIST()'].includes(funcSel);
  const needsOffset = ['LAG','LEAD','NTILE(4)','NTH_VALUE'].includes(funcSel);
  const needsDefault = ['LAG','LEAD'].includes(funcSel);
  document.getElementById('col-row')!.classList.toggle('hidden', !needsCol);
  document.getElementById('offset-row')!.classList.toggle('hidden', !needsOffset);
  document.getElementById('default-row')!.classList.toggle('hidden', !needsDefault);

  // Build function expression
  let funcExpr = '';
  switch (funcSel) {
    case 'LAG': funcExpr = `LAG(${col}, ${offset}, ${def})`; break;
    case 'LEAD': funcExpr = `LEAD(${col}, ${offset}, ${def})`; break;
    case 'FIRST_VALUE': funcExpr = `FIRST_VALUE(${col})`; break;
    case 'LAST_VALUE': funcExpr = `LAST_VALUE(${col})`; break;
    case 'NTH_VALUE': funcExpr = `NTH_VALUE(${col}, ${offset})`; break;
    case 'SUM': funcExpr = `SUM(${col})`; break;
    case 'AVG': funcExpr = `AVG(${col})`; break;
    case 'COUNT': funcExpr = `COUNT(*)`; break;
    case 'MIN': funcExpr = `MIN(${col})`; break;
    case 'MAX': funcExpr = `MAX(${col})`; break;
    default: funcExpr = funcSel;
  }

  // Build OVER clause
  const overParts: string[] = [];
  if (partition) overParts.push(`PARTITION BY ${partition}`);
  if (order) overParts.push(`ORDER BY ${order}`);
  if (frame) overParts.push(frame);

  const overClause = overParts.length
    ? `OVER (\n        ${overParts.join('\n        ')}\n    )`
    : 'OVER ()';

  const windowExpr = `${funcExpr} ${overClause} AS ${alias}`;

  const selectCols = otherCols ? `${otherCols},\n    ${windowExpr}` : windowExpr;
  const sql = `SELECT\n    ${selectCols}\nFROM ${table};`;

  document.getElementById('sql-out')!.textContent = sql;
  document.getElementById('func-ref')!.textContent = refs[funcSel] || '';
}

['wf-func','wf-col','wf-offset','wf-default','wf-alias','wf-partition','wf-order','wf-frame','wf-table','wf-other-cols'].forEach(id => {
  document.getElementById(id)?.addEventListener('input', build);
  document.getElementById(id)?.addEventListener('change', build);
});

document.getElementById('copy-sql')!.addEventListener('click', () => {
  navigator.clipboard.writeText(document.getElementById('sql-out')!.textContent || '');
});

build();
</script>
