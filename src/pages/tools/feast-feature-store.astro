            <th class="text-left pb-2 pr-4">Feast</th>
            <th class="text-left pb-2 pr-4">Tecton</th>
            <th class="text-left pb-2 pr-4">Hopsworks</th>
            <th class="text-left pb-2">Vertex FS</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border text-text-muted">
          <tr><td class="py-2 pr-4 font-medium text-text">Open-source</td><td class="py-2 pr-4 text-green-500">Yes (Apache 2.0)</td><td class="py-2 pr-4">No (SaaS)</td><td class="py-2 pr-4 text-green-500">Yes (AGPL)</td><td class="py-2">No (GCP-managed)</td></tr>
          <tr><td class="py-2 pr-4 font-medium text-text">Real-time features</td><td class="py-2 pr-4">Stream FeatureView</td><td class="py-2 pr-4 text-green-500">Native streaming</td><td class="py-2 pr-4 text-green-500">Spark Streaming</td><td class="py-2">Dataflow-based</td></tr>
          <tr><td class="py-2 pr-4 font-medium text-text">Point-in-time joins</td><td class="py-2 pr-4 text-green-500">Built-in</td><td class="py-2 pr-4 text-green-500">Built-in</td><td class="py-2 pr-4 text-green-500">Built-in</td><td class="py-2 text-green-500">Built-in</td></tr>
          <tr><td class="py-2 pr-4 font-medium text-text">Cloud agnostic</td><td class="py-2 pr-4 text-green-500">Yes (any cloud)</td><td class="py-2 pr-4">AWS-focused</td><td class="py-2 pr-4 text-green-500">Any cloud / on-prem</td><td class="py-2">GCP only</td></tr>
          <tr><td class="py-2 pr-4 font-medium text-text">Managed service</td><td class="py-2 pr-4">Self-managed</td><td class="py-2 pr-4 text-green-500">Fully managed</td><td class="py-2 pr-4">Self / managed</td><td class="py-2 text-green-500">Fully managed</td></tr>
          <tr><td class="py-2 pr-4 font-medium text-text">Best for</td><td class="py-2 pr-4">Self-hosted, flexible</td><td class="py-2 pr-4">Enterprise AWS</td><td class="py-2 pr-4">Full platform</td><td class="py-2">GCP users</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <FaqSection faq={faq} />
</BaseLayout>
