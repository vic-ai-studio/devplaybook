---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TriggerdevJobCreator from '../../components/TriggerdevJobCreator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Trigger.dev and how does it differ from Inngest?",
    answer: "Trigger.dev is an open-source background job platform with self-hosting support. Like Inngest, it provides durable execution with step-level retries and event triggers. Key differences: Trigger.dev v3 uses dedicated machines (configurable CPU/RAM per job), supports longer runs (up to 1 hour on free tier), offers Bun runtime support, and has a strong self-hosted story via Docker. Inngest focuses more on event-driven architecture with tight fan-in/fan-out patterns."
  },
  {
    question: "What is task.run and how does step durability work?",
    answer: "task.run wraps a block of code in a named, durable step. If your job crashes mid-execution, Trigger.dev replays it from the last completed step — not from the beginning. Each step result is cached, so retries skip successfully-completed steps. This makes long-running jobs with external API calls safe to retry without causing duplicate side effects in completed steps."
  },
  {
    question: "What machine type should I choose?",
    answer: "Machine type determines CPU and RAM allocated to your job run. Use 'micro' (0.25 vCPU, 256MB) for lightweight jobs like sending a single email or webhooks. Use 'small-1x' to 'small-2x' for moderate workloads like data transformation or image processing. Use 'medium-1x' or 'large-1x' for CPU-intensive work like video processing, ML inference, or large database operations. Higher tiers cost more credits per second."
  },
  {
    question: "How does wait.forEvent work?",
    answer: "wait.forEvent pauses a running job until a matching event arrives or a timeout expires. This enables human-in-the-loop workflows: start a job on 'user.signup', send a confirmation email, then pause with wait.forEvent for 'user.email.confirmed' with a 24h timeout. If the user clicks within 24 hours, the job resumes with the event payload. If the timeout expires, you get a null result and can handle the unconfirmed case."
  },
  {
    question: "When should I use subtasks vs sequential task.run steps?",
    answer: "Use subtasks (triggerAndWait or batchTriggerAndWait) when work can be parallelized across multiple independent job runs — for example, processing 1000 user records by splitting into 10 subtasks of 100 each. Each subtask gets its own machine and retry count. Use sequential task.run steps when work is inherently linear or when passing data between steps — the output of step 1 feeds into step 2."
  },
  {
    question: "Does this tool send my job configuration to a server?",
    answer: "No. All code generation runs entirely in your browser using JavaScript. Your job IDs, event names, and step configurations never leave your machine."
  },
];
---

<BaseLayout
  title="Trigger.dev Job Creator — Background Job Definition Builder"
  description="Build Trigger.dev background jobs visually. Configure event/cron triggers, task.run steps, subtasks, wait.forEvent, machine types, and retry policies. Generates Node.js, Bun, or Python code. Free, runs in your browser."
  tool="Trigger.dev job creator, Trigger.dev job builder, Trigger.dev background job generator, Trigger.dev Node.js Bun Python, Trigger.dev task creator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Trigger.dev Job Creator",
    "url": "https://devplaybook.cc/tools/triggerdev-job-creator",
    "description": "Build Trigger.dev background jobs visually. Configure triggers, task.run steps, subtasks, wait.forEvent, machine types, queues, and retry policies. Generate Node.js, Bun, or Python code.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Trigger.dev Job Creator</h1>
  <p class="text-text-muted mb-4">
    Build <a href="https://trigger.dev" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">Trigger.dev</a> background jobs visually.
    Configure event triggers or cron schedules, add task.run steps, subtasks, wait.forEvent pauses, and delay steps.
    Set machine type, queue, max duration, and retry policy.
    Generates Node.js, Bun, or Python code ready to copy into your project.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Node.js, Bun, Python</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 task types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Machine type selector</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Queue & retry config</span>
  </div>
  <TriggerdevJobCreator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Trigger.dev Job Creator" relatedTags={['trigger-dev', 'background-jobs', 'typescript', 'bun', 'nodejs', 'python', 'queues', 'serverless']} />
</BaseLayout>
