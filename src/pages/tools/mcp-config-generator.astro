---
import BaseLayout from '../../layouts/BaseLayout.astro';
import McpConfigGenerator from '../../components/McpConfigGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is MCP (Model Context Protocol)?",
    answer: "MCP is an open protocol developed by Anthropic that lets AI assistants like Claude connect to external tools, data sources, and services. Instead of hard-coding integrations, MCP defines a standard way for a host application (Claude Desktop, Cursor, Cline) to spawn local server processes that expose tools and resources to the AI. Examples include a filesystem server that lets Claude read and write files, a GitHub server for repository access, or a database server for SQL queries."
  },
  {
    question: "How do I add an MCP server to Claude Desktop?",
    answer: "Generate your config using this tool, then open claude_desktop_config.json (macOS: ~/Library/Application Support/Claude/claude_desktop_config.json, Windows: %APPDATA%\\Claude\\claude_desktop_config.json). Paste the mcpServers block into that file (merge with any existing entries), save, and restart Claude Desktop. The servers will appear in the Claude interface under the tools icon. Make sure Node.js is installed if using npx-based servers, or Python/uv for uvx-based servers."
  },
  {
    question: "How do environment variables work in MCP configs?",
    answer: "Environment variables in an MCP server entry are passed to the server process when it starts. They are not exposed to Claude directly — they configure the server itself (API keys, base URLs, credentials). For example, a GitHub MCP server needs GITHUB_PERSONAL_ACCESS_TOKEN so it can make authenticated API calls. Never commit a config file with real secrets to source control. Instead, use a secrets manager or reference variables from your shell environment by omitting them from the JSON and relying on the process.env fallback."
  },
  {
    question: "What are some common MCP servers I can use?",
    answer: "Popular official servers from Anthropic's MCP repo include: @modelcontextprotocol/server-filesystem (read/write local files), @modelcontextprotocol/server-fetch (HTTP requests), @modelcontextprotocol/server-github (GitHub API), @modelcontextprotocol/server-postgres (PostgreSQL), @modelcontextprotocol/server-brave-search (Brave Search API), and @modelcontextprotocol/server-slack (Slack). The community also maintains servers for databases, web scraping, and developer tools. All installable via npx without a global install step."
  },
];
---

<BaseLayout
  title="MCP Config Generator — Build Claude Desktop & Cursor MCP Configuration"
  description="Generate MCP server configuration JSON for Claude Desktop, Cursor, and Cline. Add server entries with commands, args, and environment variables. Get ready-to-paste config instantly."
  tool="MCP Config Generator, Claude Desktop MCP Config, Cursor MCP Configuration, Model Context Protocol, Claude MCP Servers, Cline MCP Setup"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "MCP Config Generator",
    "url": "https://devplaybook.cc/tools/mcp-config-generator",
    "description": "Generate MCP server configuration JSON for Claude Desktop, Cursor, and Cline. Add server entries with commands, args, and environment variables.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">MCP Config Generator</h1>
  <p class="text-text-muted mb-4">
    Build your
    <code class="font-mono bg-surface px-1 rounded text-sm">claude_desktop_config.json</code> or
    <code class="font-mono bg-surface px-1 rounded text-sm">.cursor/mcp.json</code>
    by adding MCP server entries with commands, args, and env vars. Copy the ready-to-paste JSON and drop it into your config file.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Claude Desktop &amp; Cursor/Cline</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> npx / node / uvx / python</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Env var support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <McpConfigGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="MCP Config Generator" relatedTags={['ai', 'claude', 'mcp', 'cursor', 'developer-tools', 'config']} />
</BaseLayout>
