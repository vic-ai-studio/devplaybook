---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JwtDecoder from '../../components/JwtDecoder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="JWT Decoder — Free Online Tool"
  description="Decode and inspect JWT tokens instantly. View header, payload, and signature. Check expiry, iat, sub, iss claims. Runs in your browser — no data sent to any server."
  tool="JWT Decoder, JSON Web Token Inspector, JWT Parser"
>
  <h1 class="text-3xl font-bold mb-2">JWT Decoder</h1>
  <p class="text-text-muted mb-8">Decode any JWT token to inspect its header, payload, and claims. Validates structure and checks expiry — all in your browser, completely private.</p>
  <JwtDecoder client:only="preact" />
  <ToolPageCta currentTool="JWT Decoder" relatedTags={['jwt', 'auth', 'security', 'tokens', 'api']} />
</BaseLayout>
