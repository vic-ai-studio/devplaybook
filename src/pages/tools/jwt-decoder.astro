---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JwtDecoder from '../../components/JwtDecoder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How do I decode a JWT token?", answer: "Paste the full JWT string (three Base64-encoded parts separated by dots) into the input field. The tool instantly splits it into header, payload, and signature sections and displays all claims in a readable format." },
  { question: "Is it safe to decode JWT tokens online?", answer: "Yes, with this tool. Everything runs in your browser — the JWT is never sent to any server. However, avoid pasting production tokens into tools that send data to a backend, as JWTs may contain sensitive claims." },
  { question: "What are the common JWT claims (iat, exp, sub)?", answer: "iat (Issued At) is when the token was created. exp (Expiration Time) is when it expires. sub (Subject) identifies the user. iss (Issuer) identifies who created the token. aud (Audience) specifies who the token is intended for." },
  { question: "Can I verify a JWT signature with this tool?", answer: "This tool decodes and inspects JWT tokens but does not verify signatures, as that requires the secret key or public key. For signature verification, use your backend or a library like jsonwebtoken (Node.js) or PyJWT (Python)." },
  { question: "What is the difference between JWT, JWS, and JWE?", answer: "JWT (JSON Web Token) is the general concept. JWS (JSON Web Signature) is a signed JWT — the most common type, with a verifiable signature. JWE (JSON Web Encryption) is an encrypted JWT where the payload is hidden. Most 'JWT tokens' you encounter are JWS." },
];
---

<BaseLayout
  title="JWT Decoder — Free Online Tool"
  description="Free JWT decoder. Inspect any JSON Web Token's header, payload, and claims (iat, exp, sub, iss, aud). Checks expiry status in real time. Pro: batch decode multiple JWTs and export as JSON. Runs in your browser — no tokens sent to any server."
  tool="JWT Decoder, JSON Web Token Inspector, JWT Parser, JWT Claims Viewer, JWT Expiry Check, Decode JWT Online, JWT Header Payload Signature"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">JWT Decoder</h1>
  <p class="text-text-muted mb-4">Decode any JWT token to inspect its header, payload, and claims. Validates structure, checks expiry, and explains <code class="font-mono text-sm">iat</code>, <code class="font-mono text-sm">exp</code>, <code class="font-mono text-sm">sub</code>, and <code class="font-mono text-sm">iss</code> — all in your browser, completely private. Pro: batch decode multiple tokens and export as JSON.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <JwtDecoder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="JWT Decoder" relatedTags={['jwt', 'auth', 'security', 'tokens', 'api']} />
</BaseLayout>
