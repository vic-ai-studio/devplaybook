---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RedisCommandReference from '../../components/RedisCommandReference.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is the difference between SET with EX and SETEX?",
    answer: "Both do the same thing — set a key with an expiration in seconds — but SET with EX is the preferred modern form (Redis 2.6.12+). SETEX is an older command that predates the option flags. Use SET key value EX 60 in new code. SETEX will not be removed, but the SET options are more flexible since you can also combine NX (only set if not exists) with EX in a single atomic command: SET lock:resource 1 EX 30 NX."
  },
  {
    question: "When should I use HSET vs individual string keys like user:42:name?",
    answer: "Use HSET when you have an object with many fields (users, sessions, config). It's more memory-efficient because Redis uses a compact ziplist encoding for small hashes (fewer than 128 fields under 64 bytes each). Individual string keys like user:42:name are fine for a few fields but multiply key overhead quickly at scale. As a rule: if you'd GROUP these in a struct in your code, use a hash in Redis."
  },
  {
    question: "Why is KEYS dangerous in production?",
    answer: "KEYS pattern is a blocking O(N) operation that scans the entire keyspace. On a large database with millions of keys, this can block Redis for seconds, freezing all other clients. Use SCAN key cursor [MATCH pattern] [COUNT count] instead — it iterates in non-blocking increments. The tradeoff is that SCAN may return duplicate keys and doesn't guarantee snapshot consistency, but it won't cause latency spikes."
  },
  {
    question: "What is the best data structure for a rate limiter in Redis?",
    answer: "For simple fixed-window rate limiting, use INCR + EXPIRE: INCR requests:user:42, then EXPIRE it to your window duration on the first hit. For a sliding window, use a Sorted Set: ZADD with the current timestamp as score, then ZREMRANGEBYSCORE to remove old entries and ZCARD to count current requests. The sorted set approach is more accurate but uses more memory. For very high throughput, a Lua script with EVAL ensures atomicity."
  },
  {
    question: "How does SETNX relate to distributed locking?",
    answer: "SETNX (set if not exists) is the foundation of distributed locks in Redis. The canonical pattern is: SET lock:resource unique-id EX 30 NX — this atomically acquires the lock only if it's free, with a built-in expiration to prevent deadlocks. When done, check that the value still matches your unique ID before deleting (use a Lua EVAL for atomic check-and-delete). The Redlock algorithm extends this to multiple Redis nodes for stronger guarantees."
  },
];
---

<BaseLayout
  title="Redis Command Reference — Complete Redis Commands with Examples"
  description="Browse 60+ Redis commands with syntax, examples, time complexity, and return values. Filter by category: Strings, Hashes, Lists, Sets, Sorted Sets, Pub-Sub, Server, and more. Free, runs in your browser."
  tool="Redis Command Reference, Redis Commands, Redis Cheatsheet, Redis Data Structures, Redis Syntax, Redis Examples"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Redis Command Reference",
    "url": "https://devplaybook.cc/tools/redis-command-reference",
    "description": "Interactive reference for 60+ Redis commands with syntax, examples, and time complexity. Filter by category and search instantly.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Redis Command Reference</h1>
  <p class="text-text-muted mb-4">
    Browse and search 60+ Redis commands across all data structures — Strings, Hashes, Lists, Sets, Sorted Sets,
    Pub-Sub, Scripting, HyperLogLog, and Server commands. Each entry includes syntax, a real-world example,
    return type, and time complexity.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60+ commands, 10 categories</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Syntax + live examples</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Time complexity for every command</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Redis 7.x reference</span>
  </div>
  <RedisCommandReference client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Redis Command Reference" relatedTags={['redis', 'database', 'caching', 'developer-tools']} />
</BaseLayout>
