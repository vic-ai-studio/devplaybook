---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UuidGenerator from '../../components/UuidGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is UUID v7?", answer: "UUID v7 (RFC 9562) is a timestamp-ordered UUID format. The first 48 bits encode the current Unix timestamp in milliseconds, followed by random bits. This makes UUID v7s sortable by creation time — critical for database index performance with distributed systems." },
  { question: "Why use UUID v7 over UUID v4?", answer: "UUID v4 is completely random, causing random index insertions that fragment B-tree indexes over time. UUID v7 is monotonically increasing within a millisecond, so new UUIDs are always appended to the end of an index — like an auto-incrementing ID but without a central sequence." },
  { question: "How do I extract the timestamp from a UUID v7?", answer: "Use the 'Extract Timestamp' section. Paste any UUID v7 and the tool extracts the embedded Unix timestamp and displays it as ISO 8601 and local time. The first 12 hex characters of a UUID v7 encode the millisecond-precision timestamp." },
  { question: "Does UUID v7 replace UUID v4?", answer: "For database primary keys and any time ordering matters, UUID v7 is the better choice. For API keys, tokens, and cases where non-guessability is important (and ordering is not needed), UUID v4 remains the standard." },
  { question: "Is UUID v7 available in programming languages?", answer: "Yes. UUID v7 support is now built into Ruby 7.2+, .NET 9+, PostgreSQL 17+, and MySQL 9+. JavaScript libraries like 'uuid' (v10+) and 'uuidv7' provide UUID v7. The format is finalized in RFC 9562 (May 2024)." },
  { question: "Can I bulk generate UUID v7?", answer: "Yes. In the Count field, enter up to 10 (free) or 100 (Pro) UUIDs. All generated UUIDs will be sortable because they embed monotonically increasing timestamps." },
];
---

<BaseLayout
  title="UUID v7 Generator — Sortable UUIDs (RFC 9562) | Free Online Tool"
  description="Generate UUID v7 — the timestamp-ordered UUID format from RFC 9562. Sortable, database-friendly, and ideal for distributed systems. Extract timestamps from UUID v7. Also generates UUID v4, v1, ULID, and nanoid. Free, runs in your browser."
  tool="UUID v7 generator, sortable UUID, RFC 9562, timestamp UUID, UUID v7 online, ULID generator, nanoid generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">UUID v7 Generator</h1>
  <p class="text-text-muted mb-4">Generate UUID v7 — the timestamp-ordered UUID format from RFC 9562. UUID v7 embeds a millisecond-precision Unix timestamp, making it sortable and ideal as a database primary key in distributed systems. Also generate UUID v4, v1, ULID, and nanoid.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> UUID v7 (RFC 9562 — sortable)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Timestamp extraction</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <UuidGenerator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="UUID v7 Generator" relatedTags={['uuid', 'guid', 'id-generation', 'database', 'distributed-systems']} />
</BaseLayout>
