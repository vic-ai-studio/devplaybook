---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the difference between Zapier, Make, and n8n?",
    answer: "All three are automation platforms that connect apps and automate workflows. Zapier is the most beginner-friendly — it uses a simple linear 'trigger → action' model and has the widest app catalog (6,000+ integrations). Make (formerly Integromat) uses a visual canvas with branching, loops, and iterators, making it better for complex data transformations. n8n is open-source and self-hostable, with a developer-friendly node graph that supports custom JavaScript code nodes and can run on your own server for free."
  },
  {
    question: "Is n8n free to use?",
    answer: "n8n's Community Edition is completely free and open-source (fair-code license). You can self-host it on any server, VPS, Docker, or Raspberry Pi at no cost, with unlimited workflows and executions. n8n Cloud starts at $20/month for a hosted version. The self-hosted version is free forever and is a popular choice for developers and small teams who want full control without per-execution pricing. The fair-code license means it's free for most uses, but commercial redistribution has restrictions."
  },
  {
    question: "How does Zapier pricing compare to Make?",
    answer: "Zapier's free tier allows 100 tasks/month and 5 Zaps (single-step). Paid plans start at $19.99/month (Starter, 750 tasks). Make's free tier offers 1,000 operations/month with up to 2 active scenarios. Make's Core plan starts at $9/month for 10,000 operations — significantly more generous than Zapier for data-heavy workflows. Make also counts each API call as one operation, while Zapier counts each action step as a 'task'. For high-volume automations, Make is almost always cheaper than Zapier."
  },
  {
    question: "Which automation tool is best for developers?",
    answer: "n8n is the top choice for developers. It supports JavaScript code nodes, Python code execution, HTTP request nodes, webhook triggers, and complex data transformations. You can write actual code inside workflows, use npm packages in custom nodes, and self-host it with full access to the underlying database. Make is a good second choice for complex logic without self-hosting. Zapier is great for non-technical users and business teams, but developers often find its limited customization frustrating."
  }
];
---

<BaseLayout
  title="Zapier vs Make vs n8n: Automation Tool Picker 2026"
  description="Interactive decision quiz to find the best automation tool for your needs. Compare Zapier, Make (Integromat), and n8n on pricing, features, complexity, and developer-friendliness."
  tool="Zapier vs Make vs n8n, Automation Tool Comparison, Best Automation Platform 2026, Zapier Alternative, n8n vs Zapier"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Zapier vs Make vs n8n: Automation Tool Picker 2026</h1>
  <p class="text-text-muted mb-4">
    Automation tools let you connect apps, trigger actions, and run workflows without writing glue code.
    Zapier is the household name — simple, powerful, and expensive at scale. Make (formerly Integromat) offers a visual canvas for complex workflows at a lower price.
    n8n is the open-source, self-hostable option built for developers who want full control. Answer 5 quick questions to get a personalized recommendation.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5-question decision quiz</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Feature comparison table</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Pricing tier breakdown</span>
  </div>

  <!-- Decision Quiz -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-1">5-Question Automation Tool Quiz</h2>
    <p class="text-text-muted text-sm mb-5">Answer each question to find your best fit.</p>

    <div class="space-y-5" id="quiz-form">
      <!-- Q1 -->
      <div class="quiz-question">
        <div class="text-sm font-medium mb-2">1. How technical is your team?</div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
          <label class="quiz-option cursor-pointer flex items-center gap-2 border border-border rounded-lg p-2.5 text-sm hover:border-primary transition-colors">
            <input type="radio" name="q1" value="non-tech" class="accent-primary"> Non-technical (business users)
          </label>
          <label class="quiz-option cursor-pointer flex items-center gap-2 border border-border rounded-lg p-2.5 text-sm hover:border-primary transition-colors">
            <input type="radio" name="q1" value="mixed"> Mixed (some devs, some not)
          </label>
          <label class="quiz-option cursor-pointer flex items-center gap-2 border border-border rounded-lg p-2.5 text-sm hover:border-primary transition-colors">
            <input type="radio" name="q1" value="dev"> Developers / technical team
          </label>
        </div>
      </div>

      <!-- Q2 -->
      <div class="quiz-question">
        <div class="text-sm font-medium mb-2">2. How many automations/operations do you expect monthly?</div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
          <label class="quiz-option cursor-pointer flex items-center gap-2 border border-border rounded-lg p-2.5 text-sm hover:border-primary transition-colors">
            <input type="radio" name="q2" value="low" class="accent-primary"> Low (&lt;1,000 tasks)
          </label>
          <label class="quiz-option cursor-pointer flex items-center gap-2 border border-border rounded-lg p-2.5 text-sm hover:border-primary transition-colors">
            <input type="radio" name="q2" value="medium"> Medium (1K–50K)
          </label>
          <label class="quiz-option cursor-pointer flex items-center gap-2 border border-border rounded-lg p-2.5 text-sm hover:border-primary transition-colors">
            <input type="radio" name="q2" value="high"> High (50K+)
          </label>
        </div>
      </div>

      <!-- Q3 -->
      <div class="quiz-question">
        <div class="text-sm font-medium mb-2">3. Do you need to self-host for data compliance or cost?</div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
          <label class="quiz-option cursor-pointer flex items-center gap-2 border border-border rounded-lg p-2.5 text-sm hover:border-primary transition-colors">
            <input type="radio" name="q3" value="no" class="accent-primary"> No, cloud SaaS is fine
          </label>
          <label class="quiz-option cursor-pointer flex items-center gap-2 border border-border rounded-lg p-2.5 text-sm hover:border-primary transition-colors">
            <input type="radio" name="q3" value="maybe"> Maybe, preferred if possible
          </label>
          <label class="quiz-option cursor-pointer flex items-center gap-2 border border-border rounded-lg p-2.5 text-sm hover:border-primary transition-colors">
            <input type="radio" name="q3" value="yes"> Yes, must self-host
          </label>
        </div>
      </div>

      <!-- Q4 -->
      <div class="quiz-question">
        <div class="text-sm font-medium mb-2">4. How complex are your workflow logic requirements?</div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
          <label class="quiz-option cursor-pointer flex items-center gap-2 border border-border rounded-lg p-2.5 text-sm hover:border-primary transition-colors">
            <input type="radio" name="q4" value="simple" class="accent-primary"> Simple (trigger → send email)
          </label>
          <label class="quiz-option cursor-pointer flex items-center gap-2 border border-border rounded-lg p-2.5 text-sm hover:border-primary transition-colors">
            <input type="radio" name="q4" value="moderate"> Moderate (branches, loops, filters)
          </label>
          <label class="quiz-option cursor-pointer flex items-center gap-2 border border-border rounded-lg p-2.5 text-sm hover:border-primary transition-colors">
            <input type="radio" name="q4" value="complex"> Complex (code, sub-workflows, APIs)
          </label>
        </div>
      </div>

      <!-- Q5 -->
      <div class="quiz-question">
        <div class="text-sm font-medium mb-2">5. Which app ecosystem matters most to you?</div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
          <label class="quiz-option cursor-pointer flex items-center gap-2 border border-border rounded-lg p-2.5 text-sm hover:border-primary transition-colors">
            <input type="radio" name="q5" value="breadth" class="accent-primary"> Widest app catalog (6,000+)
          </label>
          <label class="quiz-option cursor-pointer flex items-center gap-2 border border-border rounded-lg p-2.5 text-sm hover:border-primary transition-colors">
            <input type="radio" name="q5" value="flexibility"> Flexible visual builder
          </label>
          <label class="quiz-option cursor-pointer flex items-center gap-2 border border-border rounded-lg p-2.5 text-sm hover:border-primary transition-colors">
            <input type="radio" name="q5" value="customcode"> Custom code + REST APIs
          </label>
        </div>
      </div>
    </div>

    <button id="quiz-submit" class="w-full mt-5 py-2 bg-primary text-white text-sm rounded-lg hover:bg-primary/80 transition-colors">Get My Recommendation</button>
    <div id="quiz-result" class="mt-4 hidden"></div>
  </div>

  <!-- Feature Comparison -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6 overflow-x-auto">
    <h2 class="text-base font-semibold mb-4">Feature Comparison Table</h2>
    <table class="w-full text-sm border-collapse min-w-[580px]">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 text-text-muted font-medium w-44">Feature</th>
          <th class="text-center py-2 px-3 text-orange-400 font-semibold">Zapier</th>
          <th class="text-center py-2 px-3 text-purple-400 font-semibold">Make</th>
          <th class="text-center py-2 px-3 text-green-400 font-semibold">n8n</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <tr><td class="py-2.5 pr-4 text-text-muted">App integrations</td><td class="text-center py-2.5 px-3 text-green-500">6,000+</td><td class="text-center py-2.5 px-3 text-yellow-500">1,500+</td><td class="text-center py-2.5 px-3 text-yellow-500">400+ native</td></tr>
        <tr><td class="py-2.5 pr-4 text-text-muted">Free tier</td><td class="text-center py-2.5 px-3">100 tasks/mo</td><td class="text-center py-2.5 px-3 text-green-500">1,000 ops/mo</td><td class="text-center py-2.5 px-3 text-green-500">Unlimited (self-host)</td></tr>
        <tr><td class="py-2.5 pr-4 text-text-muted">Paid entry price</td><td class="text-center py-2.5 px-3 text-red-400">$19.99/mo</td><td class="text-center py-2.5 px-3 text-green-500">$9/mo</td><td class="text-center py-2.5 px-3 text-green-500">$20/mo (cloud)</td></tr>
        <tr><td class="py-2.5 pr-4 text-text-muted">Self-host</td><td class="text-center py-2.5 px-3 text-red-400">No</td><td class="text-center py-2.5 px-3 text-red-400">No</td><td class="text-center py-2.5 px-3 text-green-500">Yes (free)</td></tr>
        <tr><td class="py-2.5 pr-4 text-text-muted">Visual workflow canvas</td><td class="text-center py-2.5 px-3 text-yellow-500">Linear only</td><td class="text-center py-2.5 px-3 text-green-500">Full canvas</td><td class="text-center py-2.5 px-3 text-green-500">Node graph</td></tr>
        <tr><td class="py-2.5 pr-4 text-text-muted">Custom code support</td><td class="text-center py-2.5 px-3 text-red-400">Limited</td><td class="text-center py-2.5 px-3 text-yellow-500">Moderate (JS)</td><td class="text-center py-2.5 px-3 text-green-500">Full JS + Python</td></tr>
        <tr><td class="py-2.5 pr-4 text-text-muted">Ease of use</td><td class="text-center py-2.5 px-3 text-green-500">Very easy</td><td class="text-center py-2.5 px-3 text-yellow-500">Moderate</td><td class="text-center py-2.5 px-3 text-yellow-500">Dev-friendly</td></tr>
        <tr><td class="py-2.5 pr-4 text-text-muted">Loop / iterator support</td><td class="text-center py-2.5 px-3 text-yellow-500">Basic</td><td class="text-center py-2.5 px-3 text-green-500">Excellent</td><td class="text-center py-2.5 px-3 text-green-500">Yes</td></tr>
        <tr><td class="py-2.5 pr-4 text-text-muted">Error handling</td><td class="text-center py-2.5 px-3 text-yellow-500">Basic</td><td class="text-center py-2.5 px-3 text-green-500">Advanced</td><td class="text-center py-2.5 px-3 text-green-500">Advanced</td></tr>
        <tr><td class="py-2.5 pr-4 text-text-muted">Open source</td><td class="text-center py-2.5 px-3 text-red-400">No</td><td class="text-center py-2.5 px-3 text-red-400">No</td><td class="text-center py-2.5 px-3 text-green-500">Yes (fair-code)</td></tr>
      </tbody>
    </table>
  </div>

  <!-- Pricing Tier Breakdown -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-4">Pricing Tier Breakdown</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-sm">
      <div class="border border-orange-400/30 rounded-lg p-4">
        <div class="font-semibold text-orange-400 mb-2">Zapier</div>
        <div class="space-y-1.5 text-text-muted">
          <div><span class="text-white font-medium">Free:</span> 100 tasks/mo, 5 Zaps</div>
          <div><span class="text-white font-medium">Starter $19.99:</span> 750 tasks, multi-step</div>
          <div><span class="text-white font-medium">Professional $49:</span> 2,000 tasks, paths</div>
          <div><span class="text-white font-medium">Team $69:</span> 2,000 tasks, shared workspace</div>
        </div>
        <div class="mt-3 text-xs text-text-muted border-t border-border pt-2">Each action step = 1 task consumed</div>
      </div>
      <div class="border border-purple-400/30 rounded-lg p-4">
        <div class="font-semibold text-purple-400 mb-2">Make (Integromat)</div>
        <div class="space-y-1.5 text-text-muted">
          <div><span class="text-white font-medium">Free:</span> 1,000 ops/mo, 2 active</div>
          <div><span class="text-white font-medium">Core $9:</span> 10,000 ops, unlimited</div>
          <div><span class="text-white font-medium">Pro $16:</span> 10,000 ops, full-speed</div>
          <div><span class="text-white font-medium">Teams $29:</span> 10,000 ops, shared</div>
        </div>
        <div class="mt-3 text-xs text-text-muted border-t border-border pt-2">Each API call or module run = 1 operation</div>
      </div>
      <div class="border border-green-400/30 rounded-lg p-4">
        <div class="font-semibold text-green-400 mb-2">n8n</div>
        <div class="space-y-1.5 text-text-muted">
          <div><span class="text-white font-medium">Self-host:</span> Free forever, unlimited</div>
          <div><span class="text-white font-medium">Cloud Starter $20:</span> 2,500 runs/mo</div>
          <div><span class="text-white font-medium">Cloud Pro $50:</span> 10,000 runs/mo</div>
          <div><span class="text-white font-medium">Enterprise:</span> Custom, air-gapped OK</div>
        </div>
        <div class="mt-3 text-xs text-text-muted border-t border-border pt-2">Self-hosted is free with no execution limits</div>
      </div>
    </div>
  </div>

  <!-- Pro CTA -->
  <div class="bg-bg-card border border-primary/30 rounded-xl p-5 mb-6">
    <div class="flex items-start gap-4">
      <div class="flex-1">
        <h3 class="font-semibold mb-1">DevPlaybook Pro — $9/month</h3>
        <p class="text-text-muted text-sm">Automation templates, workflow patterns, n8n self-host guides, and 500+ developer tools. Build workflows that actually scale.</p>
      </div>
      <a href="https://gumroad.com/l/devplaybook-pro" target="_blank" rel="noopener" class="flex-shrink-0 px-4 py-2 bg-primary text-white text-sm rounded-lg hover:bg-primary/80 transition-colors">Get Pro</a>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Zapier vs Make vs n8n" relatedTags={['zapier', 'make', 'n8n', 'automation', 'workflow', 'integromat', 'no-code']} />
</BaseLayout>

<script is:inline>
  document.getElementById('quiz-submit').addEventListener('click', () => {
    const answers = {};
    ['q1','q2','q3','q4','q5'].forEach(q => {
      const checked = document.querySelector('input[name="' + q + '"]:checked');
      answers[q] = checked ? checked.value : null;
    });

    if (Object.values(answers).some(v => !v)) {
      const result = document.getElementById('quiz-result');
      result.innerHTML = '<p class="text-yellow-500 text-sm">Please answer all 5 questions first.</p>';
      result.classList.remove('hidden');
      return;
    }

    // Scoring: zapier / make / n8n
    let scores = { zapier: 0, make: 0, n8n: 0 };

    // Q1: technical level
    if (answers.q1 === 'non-tech')  { scores.zapier += 5; scores.make += 2; scores.n8n += 0; }
    if (answers.q1 === 'mixed')     { scores.zapier += 3; scores.make += 4; scores.n8n += 2; }
    if (answers.q1 === 'dev')       { scores.zapier += 1; scores.make += 3; scores.n8n += 5; }

    // Q2: volume
    if (answers.q2 === 'low')       { scores.zapier += 4; scores.make += 3; scores.n8n += 2; }
    if (answers.q2 === 'medium')    { scores.zapier += 2; scores.make += 5; scores.n8n += 4; }
    if (answers.q2 === 'high')      { scores.zapier += 0; scores.make += 4; scores.n8n += 5; }

    // Q3: self-host
    if (answers.q3 === 'no')        { scores.zapier += 4; scores.make += 4; scores.n8n += 2; }
    if (answers.q3 === 'maybe')     { scores.zapier += 2; scores.make += 3; scores.n8n += 4; }
    if (answers.q3 === 'yes')       { scores.zapier += 0; scores.make += 0; scores.n8n += 5; }

    // Q4: complexity
    if (answers.q4 === 'simple')    { scores.zapier += 5; scores.make += 3; scores.n8n += 2; }
    if (answers.q4 === 'moderate')  { scores.zapier += 2; scores.make += 5; scores.n8n += 4; }
    if (answers.q4 === 'complex')   { scores.zapier += 1; scores.make += 3; scores.n8n += 5; }

    // Q5: ecosystem priority
    if (answers.q5 === 'breadth')    { scores.zapier += 5; scores.make += 2; scores.n8n += 1; }
    if (answers.q5 === 'flexibility') { scores.zapier += 2; scores.make += 5; scores.n8n += 3; }
    if (answers.q5 === 'customcode') { scores.zapier += 0; scores.make += 2; scores.n8n += 5; }

    const total = 25; // max 5 per question × 5 questions
    const pcts = {
      zapier: Math.round((scores.zapier / total) * 100),
      make: Math.round((scores.make / total) * 100),
      n8n: Math.round((scores.n8n / total) * 100),
    };

    const winner = Object.keys(pcts).reduce((a, b) => pcts[a] >= pcts[b] ? a : b);
    const names = { zapier: 'Zapier', make: 'Make', n8n: 'n8n' };
    const colors = { zapier: 'border-orange-500/40 bg-orange-500/5 text-orange-400', make: 'border-purple-500/40 bg-purple-500/5 text-purple-400', n8n: 'border-green-500/40 bg-green-500/5 text-green-400' };
    const explanations = {
      zapier: `<strong>Zapier</strong> fits you best. Your workflow needs are straightforward, you value the widest app catalog, and ease of use matters. At your usage level, Zapier's premium is justified by the time saved.`,
      make: `<strong>Make</strong> fits you best. You need visual complexity — branches, iterators, and data transformation — without writing code. Make's canvas-based editor and generous operation pricing make it a strong choice.`,
      n8n: `<strong>n8n</strong> fits you best. You want developer control, custom code execution, high volume without per-execution fees, or must self-host. n8n's open-source self-hosted edition is free and handles complex workflows with full JS support.`,
    };

    const result = document.getElementById('quiz-result');
    result.innerHTML = `
      <div class="border rounded-lg p-4 ${colors[winner]}">
        <div class="flex flex-wrap gap-4 mb-3 text-sm">
          <div><span class="text-orange-400 font-semibold">Zapier:</span> <span>${pcts.zapier}%</span></div>
          <div><span class="text-purple-400 font-semibold">Make:</span> <span>${pcts.make}%</span></div>
          <div><span class="text-green-400 font-semibold">n8n:</span> <span>${pcts.n8n}%</span></div>
        </div>
        <p class="text-sm">${explanations[winner]}</p>
      </div>
    `;
    result.classList.remove('hidden');
  });
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Zapier vs Make vs n8n Automation Tool Picker",
  "description": "Decision quiz and feature comparison for Zapier, Make, and n8n automation platforms. Find the best workflow automation tool for your team in 2026.",
  "url": "https://devplaybook.cc/tools/zapier-vs-make-automation",
  "applicationCategory": "DeveloperApplication",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
}
</script>
