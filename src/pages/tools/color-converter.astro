---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ColorConverter from '../../components/ColorConverter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Color Converter — HEX, RGB, HSL — Free Online Tool"
  description="Convert colors between HEX, RGB, and HSL formats instantly. Type any color value and get all other formats in one click. Visual color picker included. Runs entirely in your browser."
  tool="HEX to RGB, RGB to HSL, Color Format Converter, CSS Color Converter"
>
  <h1 class="text-3xl font-bold mb-2">Color Format Converter</h1>
  <p class="text-text-muted mb-8">Convert between HEX, RGB, and HSL color formats instantly. Type any value in any field — all other formats update automatically. Use the color picker for visual selection or pick from presets.</p>
  <ColorConverter client:only="preact" />
  <ToolPageCta currentTool="Color Format Converter" relatedTags={['color', 'css', 'design', 'hex', 'rgb', 'hsl']} />
</BaseLayout>
