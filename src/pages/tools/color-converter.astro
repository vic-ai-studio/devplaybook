---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ColorConverter from '../../components/ColorConverter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What color formats can I convert?", answer: "This tool converts between HEX (e.g. #ff6b6b), RGB (e.g. rgb(255, 107, 107)), and HSL (e.g. hsl(0, 100%, 71%)) formats. All fields update automatically when you type in any one of them." },
  { question: "How do I convert HEX to RGB?", answer: "Paste your HEX value (with or without the # prefix) into the HEX field. The RGB and HSL values update instantly. No button to click — it's real-time conversion." },
  { question: "What is the difference between RGB and HSL?", answer: "RGB (Red, Green, Blue) defines colors by mixing light channels with values 0–255. HSL (Hue, Saturation, Lightness) is more intuitive for designers — Hue is the color angle (0–360°), Saturation is intensity (0–100%), and Lightness is brightness (0–100%)." },
  { question: "Does this tool work with CSS color values?", answer: "Yes. The HEX, RGB, and HSL outputs are valid CSS color values you can paste directly into your stylesheets. For example: color: #ff6b6b or background: hsl(0, 100%, 71%)." },
  { question: "Is the color picker accurate for web colors?", answer: "Yes. The visual color picker uses your browser's native color input, which produces precise HEX values. All converted outputs are mathematically accurate and browser-safe." },
];
---

<BaseLayout
  title="Color Converter — HEX, RGB, HSL — Free Online Tool"
  description="Convert colors between HEX, RGB, and HSL formats instantly. Paste any CSS color value and get all other formats in real-time — perfect for design-to-code handoffs, Tailwind CSS customization, and Figma color token extraction. Visual color picker and preset palette included. Runs entirely in your browser, no signup needed."
  tool="HEX to RGB, RGB to HSL, Color Format Converter, CSS Color Converter, HEX to HSL, RGB to HEX"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Color Format Converter</h1>
  <p class="text-text-muted mb-4">Convert between HEX, RGB, and HSL color formats instantly. Type any value in any field — all other formats update automatically. Use the color picker for visual selection or pick from presets.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <ColorConverter client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />

  <!-- Real-World Use Cases -->
  <section class="mt-12 mb-8">
    <h2 class="text-2xl font-bold mb-6">Real-World Use Cases</h2>

    <div class="space-y-6">
      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">1. Figma-to-CSS Design Handoff</h3>
        <p class="text-text-muted mb-3">Your designer exports brand colors from Figma as HEX. You need HSL values for CSS custom properties to build light/dark theme variants by adjusting lightness.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Input (from Figma)</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">#6366F1</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Converted Formats</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`RGB: rgb(99, 102, 241)\nHSL: hsl(239, 84%, 67%)\n\nDark variant: hsl(239, 84%, 45%)\nLight variant: hsl(239, 84%, 85%)`}</pre>
          </div>
        </div>
      </div>

      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">2. Tailwind CSS Custom Color Configuration</h3>
        <p class="text-text-muted mb-3">You want to add a brand color to your <code class="font-mono text-sm bg-bg-card px-1 rounded">tailwind.config.js</code>. Convert the designer's RGB value to HEX for the config file.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Input (from design spec)</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">rgb(16, 185, 129)</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">For tailwind.config.js</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`HEX: #10B981\n\n// tailwind.config.js\ncolors: {\n  brand: '#10B981'\n}`}</pre>
          </div>
        </div>
      </div>

      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">3. Accessibility Contrast Debugging</h3>
        <p class="text-text-muted mb-3">WCAG requires a 4.5:1 contrast ratio for text. Convert your background and text colors to RGB to calculate the ratio, or adjust the HSL lightness until contrast passes.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Background Color</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`#F3F4F6 → rgb(243, 244, 246)\n         hsl(220, 14%, 96%)`}</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Text Color (adjust lightness)</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`#6B7280 → hsl(220, 9%, 46%)\n\nContrast: 4.6:1 WCAG AA pass\nDarken to hsl(220, 9%, 35%)\nfor AAA compliance (7:1).`}</pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Step-by-Step Guide -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">How to Use — Step by Step</h2>
    <ol class="list-decimal list-inside space-y-3 text-text-muted">
      <li><strong>Enter any color value</strong> — Paste a HEX code (e.g. <code class="font-mono text-sm bg-bg-card px-1 rounded">#6366F1</code>), RGB value (e.g. <code class="font-mono text-sm bg-bg-card px-1 rounded">rgb(99,102,241)</code>), or HSL value into any input field.</li>
      <li><strong>See instant conversion</strong> — All other format fields update automatically. No button needed — conversion happens as you type.</li>
      <li><strong>Use the color picker</strong> — Click the visual picker to select a color visually, then read off the HEX, RGB, and HSL values.</li>
      <li><strong>Try presets</strong> — Click any preset color to load its values instantly. Great for exploring Tailwind or Material Design palettes.</li>
      <li><strong>Copy to clipboard</strong> — Click the copy icon next to the format you need and paste directly into your CSS, Tailwind config, or design token file.</li>
    </ol>
  </section>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Color Format Converter" relatedTags={['color', 'css', 'design', 'hex', 'rgb', 'hsl']} />
</BaseLayout>
