---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TerraformResourceGenerator from '../../components/TerraformResourceGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Terraform HCL?", answer: "HCL (HashiCorp Configuration Language) is the configuration syntax used by Terraform. It describes infrastructure as code — declaring what resources you want (VMs, databases, buckets) and Terraform handles creating, updating, and destroying them to match that desired state." },
  { question: "Which cloud providers are supported?", answer: "This generator supports AWS (EC2, S3, RDS, Security Groups), GCP (Compute Engine, Cloud Storage), and Azure (Virtual Machines, Storage Accounts). Each provider has its own Terraform provider plugin you must configure separately." },
  { question: "How do I use the generated HCL?", answer: "Copy the output into a .tf file in your Terraform project directory. Run 'terraform init' to download the required provider plugins, 'terraform plan' to preview changes, then 'terraform apply' to create the resources. Always review the plan before applying." },
  { question: "What is a Terraform resource name?", answer: "The resource name (the string after the resource type) is a local identifier used within your Terraform configuration. It's not the same as the actual resource name in the cloud. For example, resource \"aws_instance\" \"main\" creates an EC2 instance referenced as aws_instance.main in HCL." },
  { question: "Should I commit Terraform state files?", answer: "No — never commit terraform.tfstate to version control. It may contain sensitive data. Use a remote backend (S3, Terraform Cloud, GCS) to store state securely and enable team collaboration. Add *.tfstate and *.tfstate.backup to .gitignore." },
  { question: "What are Terraform variables?", answer: "Variables (var.*) let you parameterize configurations. Sensitive values like passwords should always be passed as variables rather than hardcoded in HCL. Use a terraform.tfvars file or environment variables (TF_VAR_name) to supply values." },
];
---

<BaseLayout
  title="Terraform Resource Generator — AWS / GCP / Azure HCL Builder"
  description="Free Terraform HCL generator for AWS, GCP, and Azure resources. Build EC2, S3, RDS, Compute Engine, Cloud Storage, and Azure VM configurations visually. Copy-ready HCL output."
  tool="Terraform resource generator, Terraform HCL builder, AWS Terraform, GCP Terraform, Azure Terraform, Infrastructure as Code generator, Terraform template"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Terraform Resource Generator</h1>
  <p class="text-text-muted mb-4">Generate Terraform HCL resource blocks for AWS, GCP, and Azure. Select a cloud provider, pick a resource type, fill in the fields, and copy production-ready Terraform code — no sign-up required.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> AWS · GCP · Azure supported</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-ready HCL output</span>
  </div>
  <TerraformResourceGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Terraform Resource Generator" relatedTags={['terraform', 'aws', 'gcp', 'azure', 'cloud', 'devops', 'infrastructure', 'iac']} />
</BaseLayout>
