---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What image format should I use for web images?", answer: "For photographs: AVIF is best (50%+ smaller than JPEG), followed by WebP (25–35% smaller). Fall back to JPEG. For graphics, logos, icons: WebP with transparency or SVG. For animations: WebP or AVIF (both support animation, much smaller than GIF). PNG for lossless screenshots. Use the HTML picture element with multiple source elements to serve the best format each browser supports, with JPEG/PNG as fallback." },
  { question: "What is the difference between lossy and lossless compression?", answer: "Lossy compression (JPEG, WebP lossy, AVIF) permanently discards some image data to achieve smaller files. The quality setting controls the trade-off: lower quality = smaller file but more artifacts. Quality 75–85 is usually the sweet spot for photos — visually indistinguishable from the original. Lossless compression (PNG, WebP lossless) preserves all data but achieves less compression. Use lossy for photos, lossless for screenshots, UI elements, and images with text." },
  { question: "How do I implement responsive images with srcset?", answer: "Use the srcset attribute with width descriptors: <img srcset='img-400.webp 400w, img-800.webp 800w, img-1200.webp 1200w' sizes='(max-width: 600px) 400px, (max-width: 1024px) 800px, 1200px' src='img-800.webp' alt='...' width='1200' height='600'>. The browser picks the most appropriate size based on device width and pixel density. Always include the sizes attribute so the browser can calculate the correct source before layout." },
  { question: "What does lazy loading do and when should I use it?", answer: "Lazy loading (loading='lazy') defers image loading until the image is about to enter the viewport. This reduces initial page weight and speeds up LCP for above-the-fold content. Use it on all below-the-fold images. Never use it on the LCP image (hero image) — that would delay your most important metric. Modern browsers support native lazy loading; no JavaScript needed. For older browser support, use an Intersection Observer-based library as fallback." },
  { question: "What is Image CDN and how does it help performance?", answer: "An Image CDN (Cloudinary, Imgix, Cloudflare Images, Vercel Image Optimization) automatically resizes, compresses, and converts images to the optimal format based on the requesting device. Instead of serving a 2MB 4K photo to a mobile phone, the CDN serves a 50KB WebP at the appropriate resolution. URL-based transformations: ?w=800&f=webp&q=80. This eliminates manual image processing, saves bandwidth, and dramatically improves LCP. Most modern hosting platforms include image optimization." },
];
---

<BaseLayout
  title="Image Optimization Calculator — File Size, Format & Loading Impact Estimator"
  description="Estimate image optimization savings by format (JPEG, WebP, AVIF), quality setting, and dimensions. See potential file size reduction, LCP impact, and recommended HTML attributes."
  tool="image optimization calculator, WebP AVIF size estimator, image compression savings, responsive image srcset generator, lazy loading performance"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Image Optimization Calculator",
    "url": "https://devplaybook.cc/tools/image-optimization-calculator",
    "description": "Estimate savings from converting images to WebP/AVIF, changing quality settings, and adding responsive srcset. See LCP impact and HTML recommendations.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Image Optimization Calculator</h1>
  <p class="text-text-muted mb-4">Enter your image details to estimate optimization savings, compare formats, and get recommended HTML attributes for performance. See how format changes and quality tuning affect file size and LCP.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> JPEG / WebP / AVIF comparison</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> LCP impact estimate</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> HTML snippet generator</span>
  </div>

  <div class="space-y-5">
    <!-- Inputs -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="font-semibold mb-4">Image Details</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-text-muted mb-1" for="img-size">Current File Size (KB)</label>
          <input id="img-size" type="number" min="1" step="10" value="800"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-1" for="img-format-orig">Current Format</label>
          <select id="img-format-orig" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40">
            <option value="jpeg">JPEG</option>
            <option value="png">PNG</option>
            <option value="gif">GIF</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-1" for="img-width">Display Width (px)</label>
          <input id="img-width" type="number" min="1" step="10" value="1200"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-1" for="img-height">Display Height (px)</label>
          <input id="img-height" type="number" min="1" step="10" value="600"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-1" for="img-is-lcp">Is this the LCP image?</label>
          <select id="img-is-lcp" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40">
            <option value="yes">Yes — hero/above-the-fold</option>
            <option value="no">No — below the fold</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-1" for="img-quality">Target Quality (1–100)</label>
          <input id="img-quality" type="number" min="1" max="100" step="5" value="80"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          <div class="text-xs text-text-muted mt-1">75–85 recommended for photos</div>
        </div>
      </div>

      <div class="mt-4">
        <div class="text-xs text-text-muted mb-2 font-medium uppercase tracking-wide">Quick Scenarios</div>
        <div class="flex flex-wrap gap-2" id="img-presets"></div>
      </div>

      <button id="img-calc-btn" class="mt-4 bg-primary text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-primary/80 transition-colors">
        Calculate Savings
      </button>
    </div>

    <!-- Results -->
    <div id="img-results" class="hidden space-y-4">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4" id="img-summary"></div>

      <!-- Format comparison -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold mb-4">Format Comparison</h2>
        <div class="space-y-3" id="img-formats"></div>
      </div>

      <!-- HTML recommendations -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-semibold">Recommended HTML</h2>
          <button id="copy-img-html-btn" class="text-xs text-primary border border-primary/30 px-3 py-1 rounded-lg hover:text-primary/80 transition-colors">Copy</button>
        </div>
        <pre id="img-html-output" class="bg-bg rounded-lg p-4 text-sm font-mono text-text-muted overflow-x-auto whitespace-pre-wrap break-all"></pre>
      </div>

      <!-- Tips -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold mb-3">Optimization Tips</h2>
        <ul id="img-tips" class="space-y-2 text-sm text-text-muted"></ul>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Image Optimization Calculator" relatedTags={['performance', 'images', 'webp', 'avif', 'lcp', 'web-vitals']} />
</BaseLayout>

<script is:inline>
(function () {
  // Compression ratios relative to JPEG at quality 85
  var FORMAT_RATIOS = {
    jpeg: { webp: 0.70, avif: 0.45 },
    png:  { webp: 0.50, avif: 0.35 },
    gif:  { webp: 0.60, avif: 0.40 },
  };

  var PRESETS = [
    { label: 'Hero JPEG (1200px)', size: 800, format: 'jpeg', w: 1200, h: 600, lcp: 'yes', quality: 80 },
    { label: 'Product photo', size: 400, format: 'jpeg', w: 800, h: 800, lcp: 'no', quality: 82 },
    { label: 'PNG logo', size: 120, format: 'png', w: 400, h: 100, lcp: 'no', quality: 85 },
    { label: 'Blog header', size: 1500, format: 'jpeg', w: 1600, h: 900, lcp: 'yes', quality: 78 },
  ];

  var presetsEl = document.getElementById('img-presets');
  PRESETS.forEach(function (p) {
    var btn = document.createElement('button');
    btn.className = 'px-3 py-1 text-xs rounded-lg border border-border bg-bg hover:bg-primary/10 hover:border-primary/40 transition-colors';
    btn.textContent = p.label;
    btn.addEventListener('click', function () {
      document.getElementById('img-size').value = p.size;
      document.getElementById('img-format-orig').value = p.format;
      document.getElementById('img-width').value = p.w;
      document.getElementById('img-height').value = p.h;
      document.getElementById('img-is-lcp').value = p.lcp;
      document.getElementById('img-quality').value = p.quality;
      calculate();
    });
    presetsEl.appendChild(btn);
  });

  function qualityFactor(q) {
    // Higher quality = larger file relative to baseline (q=85)
    if (q >= 95) return 1.5;
    if (q >= 90) return 1.25;
    if (q >= 85) return 1.0;
    if (q >= 80) return 0.85;
    if (q >= 75) return 0.72;
    if (q >= 70) return 0.60;
    return 0.50;
  }

  function calculate() {
    var origKB = parseFloat(document.getElementById('img-size').value) || 0;
    var origFmt = document.getElementById('img-format-orig').value;
    var width = parseInt(document.getElementById('img-width').value) || 800;
    var height = parseInt(document.getElementById('img-height').value) || 600;
    var isLcp = document.getElementById('img-is-lcp').value === 'yes';
    var quality = parseInt(document.getElementById('img-quality').value) || 80;

    var qFactor = qualityFactor(quality);
    var ratios = FORMAT_RATIOS[origFmt] || FORMAT_RATIOS.jpeg;

    var webpKB = Math.round(origKB * ratios.webp * qFactor);
    var avifKB = Math.round(origKB * ratios.avif * qFactor);
    var optimizedOrigKB = Math.round(origKB * qFactor);
    var bestSavingPct = Math.round((1 - avifKB / origKB) * 100);

    // Summary
    var summary = document.getElementById('img-summary');
    summary.innerHTML = '';
    var items = [
      { label: 'Original Size', value: origKB + ' KB', color: 'text-text-muted' },
      { label: 'WebP Estimate', value: webpKB + ' KB', color: 'text-blue-400' },
      { label: 'AVIF Estimate', value: avifKB + ' KB', color: 'text-green-400' },
      { label: 'Max Savings', value: bestSavingPct + '%', color: 'text-primary' },
    ];
    items.forEach(function (item) {
      var card = document.createElement('div');
      card.className = 'bg-bg-card border border-border rounded-xl p-4';
      card.innerHTML = '<div class="text-xs text-text-muted mb-1">' + item.label + '</div>'
        + '<div class="text-xl font-bold ' + item.color + '">' + item.value + '</div>';
      summary.appendChild(card);
    });

    // Format comparison bars
    var formatsEl = document.getElementById('img-formats');
    formatsEl.innerHTML = '';
    var formats = [
      { label: origFmt.toUpperCase() + ' (original)', kb: origKB, color: 'bg-red-500/50' },
      { label: origFmt.toUpperCase() + ' (q=' + quality + ')', kb: optimizedOrigKB, color: 'bg-yellow-500/50' },
      { label: 'WebP (q=' + quality + ')', kb: webpKB, color: 'bg-blue-500/60' },
      { label: 'AVIF (q=' + quality + ')', kb: avifKB, color: 'bg-green-500/60' },
    ];
    formats.forEach(function (f) {
      var pct = (f.kb / origKB) * 100;
      var savingPct = Math.round((1 - f.kb / origKB) * 100);
      var row = document.createElement('div');
      row.innerHTML = '<div class="flex items-center justify-between mb-1">'
        + '<span class="text-sm">' + f.label + '</span>'
        + '<div class="flex gap-3 text-sm">'
        + '<span class="font-mono">' + f.kb + ' KB</span>'
        + (savingPct > 0 ? '<span class="text-green-400 text-xs">-' + savingPct + '%</span>' : '<span class="text-text-muted text-xs">baseline</span>')
        + '</div></div>'
        + '<div class="h-4 bg-bg rounded-full overflow-hidden">'
        + '<div class="h-full rounded-full ' + f.color + '" style="width:' + Math.min(pct, 100) + '%"></div>'
        + '</div>';
      formatsEl.appendChild(row);
    });

    // HTML recommendations
    var isLcpStr = isLcp ? 'yes' : 'no';
    var lazyAttr = isLcp ? '' : ' loading="lazy"';
    var preloadLine = isLcp ? '\n<!-- Preload the LCP image in <head> -->\n<link rel="preload" as="image" href="/images/hero.avif" type="image/avif">\n' : '';
    var halfW = Math.round(width / 2);
    var htmlSnippet = preloadLine
      + '<picture>\n'
      + '  <source\n'
      + '    type="image/avif"\n'
      + '    srcset="/images/hero.avif ' + width + 'w, /images/hero-' + halfW + '.avif ' + halfW + 'w"\n'
      + '    sizes="(max-width: 768px) ' + halfW + 'px, ' + width + 'px"\n'
      + '  />\n'
      + '  <source\n'
      + '    type="image/webp"\n'
      + '    srcset="/images/hero.webp ' + width + 'w, /images/hero-' + halfW + '.webp ' + halfW + 'w"\n'
      + '    sizes="(max-width: 768px) ' + halfW + 'px, ' + width + 'px"\n'
      + '  />\n'
      + '  <img\n'
      + '    src="/images/hero.' + origFmt + '"\n'
      + '    width="' + width + '"\n'
      + '    height="' + height + '"\n'
      + '    alt="Descriptive alt text"'
      + lazyAttr + '\n'
      + (isLcp ? '    fetchpriority="high"\n' : '')
      + '  />\n'
      + '</picture>';

    document.getElementById('img-html-output').textContent = htmlSnippet;

    // Tips
    var tips = document.getElementById('img-tips');
    tips.innerHTML = '';
    var tipsList = [];
    if (origFmt !== 'avif') tipsList.push('Convert to AVIF for the best compression (~' + bestSavingPct + '% smaller). Use the <picture> element to serve AVIF with JPEG fallback.');
    if (isLcp) tipsList.push('This is your LCP image — add <link rel="preload" as="image"> in <head> and fetchpriority="high" on the img tag to prioritize loading.');
    if (!isLcp) tipsList.push('Add loading="lazy" to defer this image until it\'s near the viewport, reducing initial page weight.');
    if (quality > 85) tipsList.push('Quality ' + quality + ' is high. Try 78–82 for photos — most users cannot see the difference, but file size drops significantly.');
    if (origKB > 500) tipsList.push('File is large (' + origKB + ' KB). Consider serving different resolutions via srcset: a 600px mobile version alongside the full-size desktop version.');
    tipsList.push('Use an Image CDN (Cloudinary, Imgix, Cloudflare Images) to automate format conversion, resizing, and quality optimization on-the-fly.');

    tipsList.forEach(function (t) {
      var li = document.createElement('li');
      li.className = 'flex gap-2';
      li.innerHTML = '<span class="text-primary shrink-0 mt-0.5">→</span><span>' + t + '</span>';
      tips.appendChild(li);
    });

    document.getElementById('img-results').classList.remove('hidden');
    document.getElementById('img-results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  document.getElementById('img-calc-btn').addEventListener('click', calculate);

  document.getElementById('copy-img-html-btn').addEventListener('click', function () {
    var text = document.getElementById('img-html-output').textContent;
    navigator.clipboard.writeText(text).then(function () {
      var btn = document.getElementById('copy-img-html-btn');
      btn.textContent = 'Copied!';
      setTimeout(function () { btn.textContent = 'Copy'; }, 2000);
    });
  });

  calculate();
})();
</script>
