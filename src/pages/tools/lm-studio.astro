---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is LM Studio and what makes it different?", answer: "LM Studio is a free desktop application for running GGUF-format LLMs locally on macOS, Windows, and Linux. Unlike CLI tools like Ollama, LM Studio provides a graphical chat interface, an in-app model browser connected to HuggingFace, and a visual local server panel — all in one app. It's ideal for users who want to experiment with local AI without touching a terminal." },
  { question: "What hardware do I need for LM Studio?", answer: "Minimum: 8 GB RAM for 7B models, 16 GB for 13B models, 32 GB+ for 30B+ models. GPU acceleration is optional but strongly recommended: NVIDIA GPUs use CUDA (4 GB+ VRAM for 7B), Apple Silicon uses Metal (M1/M2/M3/M4 are excellent). Without a GPU, LM Studio falls back to CPU inference — functional but slow (1–5 tokens/sec for 7B models)." },
  { question: "What is GGUF format?", answer: "GGUF (GPT-Generated Unified Format) is the standard file format for quantized LLMs used by llama.cpp and tools built on it (including LM Studio and Ollama). Quantization reduces model precision (e.g., Q4_K_M = 4-bit quantization) to shrink file size and RAM usage at minimal quality loss. A 7B model at Q4_K_M is about 4.1 GB vs ~14 GB for the full-precision version." },
  { question: "How do I use LM Studio as an OpenAI-compatible API?", answer: "In LM Studio, go to the 'Local Server' tab, load a model, and click 'Start Server'. It runs on http://localhost:1234/v1 by default and implements the OpenAI Chat Completions API. Point any OpenAI SDK at this URL with api_key='lm-studio'. This lets your existing apps, LangChain pipelines, or custom scripts use local models without code changes." },
  { question: "Can LM Studio run multiple models simultaneously?", answer: "LM Studio supports loading multiple models and switching between them, but running them truly in parallel requires enough RAM/VRAM to hold all models. In practice, most users run one model at a time. The local server can serve one active model at a time. For true multi-model routing, tools like LocalAI or a custom proxy layer are better suited." },
  { question: "LM Studio vs Ollama — which should I use?", answer: "Choose LM Studio if you want a GUI, built-in chat, and easy model browsing without using a terminal. Choose Ollama if you're a developer who wants a scriptable CLI, headless server mode, and easy integration into apps via its API. Both support GGUF models and OpenAI-compatible APIs. Many developers use Ollama for production app integration and LM Studio for quick model testing." },
];
---

<BaseLayout
  title="LM Studio: Run Local LLMs with a Desktop GUI (2026 Guide)"
  description="LM Studio lets you download GGUF models from HuggingFace, chat locally, and run an OpenAI-compatible API server on your desktop. Complete setup guide for Mac, Windows, and Linux."
  tool="LM Studio, local LLM GUI, GGUF models, offline AI, desktop AI app, run AI locally, private LLM"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"LM Studio: Run Local LLMs with a Desktop GUI","url":"https://devplaybook.cc/tools/lm-studio","description":"Complete guide to LM Studio — download GGUF models, chat locally, and run an OpenAI-compatible local API server in 2026."})} />

  <h1 class="text-3xl font-bold mb-2">LM Studio: Run Local LLMs with a Desktop GUI</h1>
  <p class="text-text-muted mb-6">LM Studio is the most user-friendly way to run powerful AI models entirely offline. Browse and download models from HuggingFace, chat in a polished interface, and spin up a local OpenAI-compatible API server — all without touching a terminal.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Visual model browser (HuggingFace)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Built-in chat interface</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> OpenAI-compatible local server</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No terminal required</span>
  </div>

  <ToolPageCta />

  <!-- Installation -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Installation &amp; Setup</h2>
    <p class="text-text-muted text-sm mb-4">LM Studio is distributed as a standalone desktop app. Download from <strong>lmstudio.ai</strong> — no package manager needed. It's available for macOS (Apple Silicon + Intel), Windows, and Linux (AppImage).</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-3"><code># macOS (Homebrew Cask)
brew install --cask lm-studio

# Or download directly from https://lmstudio.ai

# Linux AppImage
chmod +x LM_Studio-*.AppImage
./LM_Studio-*.AppImage

# Verify installation — check version in Help > About
# Default model storage: ~/Library/Application Support/LM-Studio/models (macOS)
# Windows: C:\Users\&lt;user&gt;\.lmstudio\models</code></pre>
  </div>

  <!-- Downloading models -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Downloading GGUF Models</h2>
    <p class="text-text-muted text-sm mb-4">LM Studio's model browser connects to HuggingFace and filters for GGUF-compatible files. Search for a model name, choose a quantization level, and click Download. Key quantization levels and their trade-offs:</p>
    <div class="overflow-x-auto mb-4">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-text-muted text-xs uppercase border-b border-border">
            <th class="text-left pb-2 pr-4">Quantization</th>
            <th class="text-left pb-2 pr-4">7B File Size</th>
            <th class="text-left pb-2 pr-4">RAM Needed</th>
            <th class="text-left pb-2">Quality</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border text-xs">
          <tr><td class="py-2 pr-4 font-mono">Q2_K</td><td class="py-2 pr-4">~2.7 GB</td><td class="py-2 pr-4">~5 GB</td><td class="py-2 text-yellow-500">Reduced</td></tr>
          <tr><td class="py-2 pr-4 font-mono">Q4_K_M</td><td class="py-2 pr-4">~4.1 GB</td><td class="py-2 pr-4">~6 GB</td><td class="py-2 text-green-500">Good (recommended)</td></tr>
          <tr><td class="py-2 pr-4 font-mono">Q5_K_M</td><td class="py-2 pr-4">~5.0 GB</td><td class="py-2 pr-4">~7 GB</td><td class="py-2 text-green-500">Very good</td></tr>
          <tr><td class="py-2 pr-4 font-mono">Q8_0</td><td class="py-2 pr-4">~7.7 GB</td><td class="py-2 pr-4">~10 GB</td><td class="py-2 text-green-500">Near lossless</td></tr>
        </tbody>
      </table>
    </div>
    <p class="text-text-muted text-sm">For most users, <strong>Q4_K_M</strong> is the sweet spot — great quality at half the file size of Q8. If you have plenty of RAM/VRAM, go for Q5_K_M or Q8_0.</p>
  </div>

  <!-- Local Server -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Running the Local API Server</h2>
    <p class="text-text-muted text-sm mb-4">LM Studio's local server is a drop-in replacement for the OpenAI API. Navigate to the <strong>Local Server</strong> tab, load a model, set your port (default: 1234), and click Start Server.</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># Test the server with curl
curl http://localhost:1234/v1/chat/completions \
  -H "Content-Type: application/json" \
  -d '&#123;
    "model": "local-model",
    "messages": [
      &#123;"role": "system", "content": "You are a helpful assistant."&#125;,
      &#123;"role": "user", "content": "What is a neural network?"&#125;
    ],
    "temperature": 0.7,
    "max_tokens": 512
  &#125;'

# Python integration using openai SDK
import openai
client = openai.OpenAI(
    base_url="http://localhost:1234/v1",
    api_key="lm-studio"  # any string works
)
response = client.chat.completions.create(
    model="local-model",
    messages=[&#123;"role": "user", "content": "Explain REST APIs"&#125;]
)
print(response.choices[0].message.content)</code></pre>
    <p class="text-text-muted text-sm">The server also exposes <code class="bg-bg-card border border-border rounded px-1.5 py-0.5 text-xs font-mono">/v1/models</code> and <code class="bg-bg-card border border-border rounded px-1.5 py-0.5 text-xs font-mono">/v1/completions</code> endpoints for legacy apps.</p>
  </div>

  <!-- Hardware requirements -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Hardware Requirements by Model Size</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-text-muted text-xs uppercase border-b border-border">
            <th class="text-left pb-2 pr-4">Model Size</th>
            <th class="text-left pb-2 pr-4">Min RAM</th>
            <th class="text-left pb-2 pr-4">Recommended</th>
            <th class="text-left pb-2">GPU VRAM</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border text-xs">
          <tr><td class="py-2 pr-4 font-medium">1B–3B</td><td class="py-2 pr-4">4 GB</td><td class="py-2 pr-4">8 GB</td><td class="py-2">2 GB+</td></tr>
          <tr><td class="py-2 pr-4 font-medium">7B</td><td class="py-2 pr-4">8 GB</td><td class="py-2 pr-4">16 GB</td><td class="py-2">4 GB+</td></tr>
          <tr><td class="py-2 pr-4 font-medium">13B</td><td class="py-2 pr-4">16 GB</td><td class="py-2 pr-4">24 GB</td><td class="py-2">8 GB+</td></tr>
          <tr><td class="py-2 pr-4 font-medium">30B–34B</td><td class="py-2 pr-4">32 GB</td><td class="py-2 pr-4">48 GB</td><td class="py-2">16 GB+</td></tr>
          <tr><td class="py-2 pr-4 font-medium">70B+</td><td class="py-2 pr-4">64 GB</td><td class="py-2 pr-4">96 GB</td><td class="py-2">48 GB+ or multi-GPU</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Comparison -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-4">LM Studio vs Ollama vs Jan</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-text-muted text-xs uppercase border-b border-border">
            <th class="text-left pb-2 pr-4">Feature</th>
            <th class="text-left pb-2 pr-4">LM Studio</th>
            <th class="text-left pb-2 pr-4">Ollama</th>
            <th class="text-left pb-2">Jan</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border text-xs">
          <tr><td class="py-2 pr-4 font-medium">GUI chat</td><td class="py-2 pr-4 text-green-500">Built-in</td><td class="py-2 pr-4 text-yellow-500">Via third party</td><td class="py-2 text-green-500">Built-in</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Model browser</td><td class="py-2 pr-4 text-green-500">HuggingFace</td><td class="py-2 pr-4 text-green-500">ollama.com</td><td class="py-2 text-green-500">Jan Hub</td></tr>
          <tr><td class="py-2 pr-4 font-medium">CLI / scripting</td><td class="py-2 pr-4 text-red-400">Limited</td><td class="py-2 pr-4 text-green-500">Excellent</td><td class="py-2 text-yellow-500">Basic</td></tr>
          <tr><td class="py-2 pr-4 font-medium">OpenAI API</td><td class="py-2 pr-4 text-green-500">Yes (port 1234)</td><td class="py-2 pr-4 text-green-500">Yes (port 11434)</td><td class="py-2 text-green-500">Yes (port 1337)</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Extensions</td><td class="py-2 pr-4 text-red-400">No</td><td class="py-2 pr-4 text-red-400">No</td><td class="py-2 text-green-500">Yes</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Best for</td><td class="py-2 pr-4">GUI experimentation</td><td class="py-2 pr-4">Developer integration</td><td class="py-2">Privacy + extensions</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="LM Studio" relatedTags={['ai', 'llm', 'local-ai', 'gguf', 'private-ai', 'desktop']} />
</BaseLayout>
