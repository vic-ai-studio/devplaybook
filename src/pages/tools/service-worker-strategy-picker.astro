---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is a Service Worker and what does it enable?",
    answer: "A Service Worker is a JavaScript file that runs in the background, separate from the main browser thread. It acts as a programmable network proxy between your web app and the internet. Key capabilities: offline functionality (intercept and cache network requests), push notifications, background sync, and performance optimization via smart caching. Service Workers are the foundation of Progressive Web Apps (PWAs). They run only on HTTPS (except localhost) and have no DOM access."
  },
  {
    question: "What is the difference between CacheFirst and NetworkFirst strategies?",
    answer: "CacheFirst: Check cache first; if found, return cached response. If not found, fetch from network and cache it. Best for static assets (CSS, fonts, images) that rarely change. NetworkFirst: Try the network first; on success, cache and return the response. On failure (offline), return cached version. Best for HTML pages and dynamic content where freshness matters but offline fallback is needed. CacheFirst is faster; NetworkFirst is fresher."
  },
  {
    question: "When should I use StaleWhileRevalidate?",
    answer: "StaleWhileRevalidate returns the cached response immediately (fast) while simultaneously fetching a fresh version in the background to update the cache for next time. Best for: news feeds, social content, non-critical data where showing slightly stale content is acceptable but eventual freshness is desired. It provides fast load times while keeping cache reasonably fresh. Avoid for financial data, real-time prices, or any content where stale values cause problems."
  },
  {
    question: "What is Workbox and do I need to use it?",
    answer: "Workbox is a Google library that wraps raw Service Worker APIs with higher-level caching strategies, background sync, and precaching. You don't need Workbox — you can write raw Service Worker code — but Workbox handles edge cases like cache quota management, request matching, cache versioning, and strategy composition. Most production PWAs use Workbox. With build tools like Vite (vite-plugin-pwa) or webpack (workbox-webpack-plugin), Workbox configuration is minimal."
  },
  {
    question: "How do I update a Service Worker when I deploy new code?",
    answer: "Browsers check for Service Worker updates on every navigation. A new SW file (even 1 byte different) triggers the update flow: new SW installs → waits until all tabs using the old SW are closed → new SW activates. To force immediate activation: call self.skipWaiting() in the install event and clients.claim() in activate. For user-friendly updates, show a 'New version available — refresh' toast. Workbox's workbox-broadcast-update sends a message when cached responses change."
  }
];
---

<BaseLayout
  title="Service Worker Strategy Picker — Workbox Caching Strategy Selector"
  description="Pick the right Workbox caching strategy for your resource type. Get CacheFirst, NetworkFirst, StaleWhileRevalidate recommendations with explanations and ready-to-use Workbox code. Free browser tool."
  tool="workbox strategy picker, service worker caching strategy, cache first network first, stale while revalidate, pwa caching strategy"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Service Worker Strategy Picker",
    "url": "https://devplaybook.cc/tools/service-worker-strategy-picker",
    "description": "Pick the right Workbox caching strategy for your resource type. Get recommendations with explanations and ready-to-use Workbox code snippets.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Service Worker Strategy Picker</h1>
  <p class="text-text-muted mb-4">
    Answer three questions about your resource and get the recommended Workbox caching strategy
    with a full code snippet and explanation.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 caching strategies</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Decision tree logic</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Workbox code snippet</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Raw SW code alternative</span>
  </div>

  <!-- Questions -->
  <div class="space-y-4 mb-6">
    <!-- Q1 -->
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <label class="block text-sm font-medium mb-3">1. What type of resource is this?</label>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-2" id="resource-grid">
        <button class="resource-btn q1-btn px-3 py-2.5 bg-primary text-white rounded-lg text-sm font-medium transition-colors text-center" data-val="html">HTML pages</button>
        <button class="resource-btn q1-btn px-3 py-2.5 bg-surface border border-border rounded-lg text-sm text-text-muted hover:border-primary transition-colors text-center" data-val="css">CSS / JS</button>
        <button class="resource-btn q1-btn px-3 py-2.5 bg-surface border border-border rounded-lg text-sm text-text-muted hover:border-primary transition-colors text-center" data-val="images">Images</button>
        <button class="resource-btn q1-btn px-3 py-2.5 bg-surface border border-border rounded-lg text-sm text-text-muted hover:border-primary transition-colors text-center" data-val="fonts">Fonts</button>
        <button class="resource-btn q1-btn px-3 py-2.5 bg-surface border border-border rounded-lg text-sm text-text-muted hover:border-primary transition-colors text-center" data-val="api">API calls</button>
        <button class="resource-btn q1-btn px-3 py-2.5 bg-surface border border-border rounded-lg text-sm text-text-muted hover:border-primary transition-colors text-center" data-val="other">Other</button>
      </div>
    </div>

    <!-- Q2 -->
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <label class="block text-sm font-medium mb-3">2. Offline requirement?</label>
      <div class="flex flex-wrap gap-2">
        <button class="offline-btn q2-btn px-4 py-2 bg-primary text-white rounded-lg text-sm font-medium transition-colors" data-val="required">Must work offline</button>
        <button class="offline-btn q2-btn px-4 py-2 bg-surface border border-border rounded-lg text-sm text-text-muted hover:border-primary transition-colors" data-val="nice">Nice to have</button>
        <button class="offline-btn q2-btn px-4 py-2 bg-surface border border-border rounded-lg text-sm text-text-muted hover:border-primary transition-colors" data-val="none">No offline needed</button>
      </div>
    </div>

    <!-- Q3 -->
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <label class="block text-sm font-medium mb-3">3. Freshness priority?</label>
      <div class="flex flex-wrap gap-2">
        <button class="fresh-btn q3-btn px-4 py-2 bg-surface border border-border rounded-lg text-sm text-text-muted hover:border-primary transition-colors" data-val="high">High — always fresh</button>
        <button class="fresh-btn q3-btn px-4 py-2 bg-primary text-white rounded-lg text-sm font-medium transition-colors" data-val="medium">Medium — stale OK</button>
        <button class="fresh-btn q3-btn px-4 py-2 bg-surface border border-border rounded-lg text-sm text-text-muted hover:border-primary transition-colors" data-val="low">Low — rarely changes</button>
      </div>
    </div>
  </div>

  <!-- Result -->
  <div id="result-card" class="bg-bg-card border-2 border-primary rounded-lg p-5 mb-4">
    <div class="flex items-center gap-3 mb-3">
      <div id="strategy-badge" class="px-3 py-1 bg-primary text-white rounded-full text-sm font-bold"></div>
      <h2 id="strategy-name" class="text-lg font-bold"></h2>
    </div>
    <p id="strategy-desc" class="text-sm text-text-muted mb-4"></p>
    <div class="flex gap-2 flex-wrap mb-2">
      <span id="perf-badge" class="text-xs px-2 py-1 rounded-full border"></span>
      <span id="fresh-badge" class="text-xs px-2 py-1 rounded-full border"></span>
      <span id="offline-badge" class="text-xs px-2 py-1 rounded-full border"></span>
    </div>
  </div>

  <!-- Code -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-medium">Workbox snippet</h2>
        <button id="copy-workbox" class="px-3 py-1.5 bg-primary text-white rounded text-xs font-medium hover:bg-primary/90 transition-colors">Copy</button>
      </div>
      <pre id="workbox-code" class="bg-surface rounded p-3 text-xs font-mono text-foreground/90 overflow-x-auto whitespace-pre"></pre>
    </div>
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-medium">Raw Service Worker</h2>
        <button id="copy-raw" class="px-3 py-1.5 bg-primary text-white rounded text-xs font-medium hover:bg-primary/90 transition-colors">Copy</button>
      </div>
      <pre id="raw-code" class="bg-surface rounded p-3 text-xs font-mono text-foreground/90 overflow-x-auto whitespace-pre"></pre>
    </div>
  </div>

  <!-- Strategy comparison -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-medium mb-3">All Strategies at a Glance</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-xs">
        <thead>
          <tr class="text-text-muted border-b border-border">
            <th class="text-left py-2 pr-3 font-medium">Strategy</th>
            <th class="text-center py-2 pr-3 font-medium">Speed</th>
            <th class="text-center py-2 pr-3 font-medium">Freshness</th>
            <th class="text-center py-2 pr-3 font-medium">Offline</th>
            <th class="text-left py-2 font-medium">Best for</th>
          </tr>
        </thead>
        <tbody class="space-y-1">
          <tr class="border-b border-border/50"><td class="py-2 pr-3 font-medium text-accent">CacheFirst</td><td class="text-center py-2 pr-3 text-green-400">Fast</td><td class="text-center py-2 pr-3 text-red-400">Low</td><td class="text-center py-2 pr-3 text-green-400">Yes</td><td class="py-2 text-text-muted">Fonts, images, versioned assets</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-3 font-medium text-accent">NetworkFirst</td><td class="text-center py-2 pr-3 text-yellow-400">Slower</td><td class="text-center py-2 pr-3 text-green-400">High</td><td class="text-center py-2 pr-3 text-yellow-400">Fallback</td><td class="py-2 text-text-muted">HTML pages, API with offline fallback</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-3 font-medium text-accent">StaleWhileRevalidate</td><td class="text-center py-2 pr-3 text-green-400">Fast</td><td class="text-center py-2 pr-3 text-yellow-400">Medium</td><td class="text-center py-2 pr-3 text-yellow-400">Stale</td><td class="py-2 text-text-muted">News, feeds, non-critical data</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-3 font-medium text-accent">NetworkOnly</td><td class="text-center py-2 pr-3 text-red-400">Network</td><td class="text-center py-2 pr-3 text-green-400">Always</td><td class="text-center py-2 pr-3 text-red-400">No</td><td class="py-2 text-text-muted">Real-time data, analytics</td></tr>
          <tr><td class="py-2 pr-3 font-medium text-accent">CacheOnly</td><td class="text-center py-2 pr-3 text-green-400">Instant</td><td class="text-center py-2 pr-3 text-red-400">Static</td><td class="text-center py-2 pr-3 text-green-400">Always</td><td class="py-2 text-text-muted">Precached app shell</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Service Worker Strategy Picker" relatedTags={['pwa', 'service-worker', 'workbox', 'caching', 'offline', 'performance']} />
</BaseLayout>

<script is:inline>
(function() {
  var state = { resource: 'html', offline: 'required', freshness: 'medium' };

  var STRATEGIES = {
    CacheFirst: {
      name: 'CacheFirst',
      desc: 'Serve from cache first. Only hit the network if the resource is not cached. On network success, update the cache. Best for resources that rarely change.',
      perf: { label: 'Very Fast', class: 'border-green-500 text-green-400' },
      fresh: { label: 'Low Freshness', class: 'border-red-500 text-red-400' },
      offline: { label: 'Works Offline', class: 'border-green-500 text-green-400' },
    },
    NetworkFirst: {
      name: 'NetworkFirst',
      desc: 'Try the network first. On success, cache and serve the response. On failure (offline), serve from cache as a fallback.',
      perf: { label: 'Slower (network dependent)', class: 'border-yellow-500 text-yellow-400' },
      fresh: { label: 'High Freshness', class: 'border-green-500 text-green-400' },
      offline: { label: 'Offline Fallback', class: 'border-yellow-500 text-yellow-400' },
    },
    StaleWhileRevalidate: {
      name: 'StaleWhileRevalidate',
      desc: 'Serve from cache immediately (stale) while fetching a fresh version in the background for next time. Balances speed and freshness.',
      perf: { label: 'Fast (cache instant)', class: 'border-green-500 text-green-400' },
      fresh: { label: 'Medium Freshness', class: 'border-yellow-500 text-yellow-400' },
      offline: { label: 'Stale offline only', class: 'border-yellow-500 text-yellow-400' },
    },
    NetworkOnly: {
      name: 'NetworkOnly',
      desc: 'Always fetch from the network. No caching. Use for real-time data, analytics, or requests that must never be served stale.',
      perf: { label: 'Network Speed', class: 'border-red-500 text-red-400' },
      fresh: { label: 'Always Fresh', class: 'border-green-500 text-green-400' },
      offline: { label: 'No Offline', class: 'border-red-500 text-red-400' },
    },
    CacheOnly: {
      name: 'CacheOnly',
      desc: 'Serve exclusively from cache. Never hits the network. Only works if the resource has been precached. Use for app shell resources.',
      perf: { label: 'Instant', class: 'border-green-500 text-green-400' },
      fresh: { label: 'Static (precache)', class: 'border-red-500 text-red-400' },
      offline: { label: 'Always Offline', class: 'border-green-500 text-green-400' },
    },
  };

  function recommend() {
    var r = state.resource, o = state.offline, f = state.freshness;

    if (r === 'fonts') return 'CacheFirst';
    if (r === 'images') return f === 'low' ? 'CacheFirst' : 'StaleWhileRevalidate';
    if (r === 'css') return f === 'low' ? 'CacheFirst' : 'StaleWhileRevalidate';
    if (r === 'api') {
      if (o === 'none' && f === 'high') return 'NetworkOnly';
      if (f === 'high') return 'NetworkFirst';
      if (o === 'required') return 'NetworkFirst';
      return 'StaleWhileRevalidate';
    }
    if (r === 'html') {
      if (o === 'required') return 'NetworkFirst';
      if (f === 'high') return 'NetworkFirst';
      return 'StaleWhileRevalidate';
    }
    // other
    if (o === 'none' && f === 'high') return 'NetworkOnly';
    if (f === 'low' && o !== 'none') return 'CacheFirst';
    if (f === 'high') return 'NetworkFirst';
    return 'StaleWhileRevalidate';
  }

  var WORKBOX_SNIPPETS = {
    CacheFirst: `import { registerRoute } from 'workbox-routing';
import { CacheFirst } from 'workbox-strategies';
import { ExpirationPlugin } from 'workbox-expiration';

registerRoute(
  // Match your resource URL pattern
  ({ request }) => request.destination === 'font',
  new CacheFirst({
    cacheName: 'fonts-cache',
    plugins: [
      new ExpirationPlugin({
        maxEntries: 60,
        maxAgeSeconds: 30 * 24 * 60 * 60, // 30 days
        purgeOnQuotaError: true,
      }),
    ],
  })
);`,
    NetworkFirst: `import { registerRoute } from 'workbox-routing';
import { NetworkFirst } from 'workbox-strategies';
import { ExpirationPlugin } from 'workbox-expiration';

registerRoute(
  ({ request }) => request.mode === 'navigate',
  new NetworkFirst({
    cacheName: 'pages-cache',
    networkTimeoutSeconds: 3,
    plugins: [
      new ExpirationPlugin({
        maxEntries: 50,
        maxAgeSeconds: 24 * 60 * 60, // 1 day
      }),
    ],
  })
);`,
    StaleWhileRevalidate: `import { registerRoute } from 'workbox-routing';
import { StaleWhileRevalidate } from 'workbox-strategies';
import { CacheableResponsePlugin } from 'workbox-cacheable-response';

registerRoute(
  ({ url }) => url.pathname.startsWith('/api/'),
  new StaleWhileRevalidate({
    cacheName: 'api-cache',
    plugins: [
      new CacheableResponsePlugin({ statuses: [0, 200] }),
    ],
  })
);`,
    NetworkOnly: `import { registerRoute } from 'workbox-routing';
import { NetworkOnly } from 'workbox-strategies';

// Analytics and real-time endpoints — never cache
registerRoute(
  ({ url }) => url.pathname.startsWith('/api/analytics') ||
               url.pathname.startsWith('/api/realtime'),
  new NetworkOnly()
);`,
    CacheOnly: `import { registerRoute } from 'workbox-routing';
import { CacheOnly } from 'workbox-strategies';

// Precache these assets during SW install
import { precacheAndRoute } from 'workbox-precaching';
precacheAndRoute(self.__WB_MANIFEST);

// Then serve from cache only
registerRoute(
  ({ url }) => url.pathname.startsWith('/app-shell/'),
  new CacheOnly({ cacheName: 'app-shell-cache' })
);`,
  };

  var RAW_SNIPPETS = {
    CacheFirst: `// service-worker.js — CacheFirst
const CACHE_NAME = 'my-cache-v1';

self.addEventListener('fetch', (event) => {
  event.respondWith(
    caches.match(event.request).then((cached) => {
      if (cached) return cached;
      return fetch(event.request).then((response) => {
        const cloned = response.clone();
        caches.open(CACHE_NAME).then((cache) => {
          cache.put(event.request, cloned);
        });
        return response;
      });
    })
  );
});`,
    NetworkFirst: `// service-worker.js — NetworkFirst
const CACHE_NAME = 'pages-cache-v1';
const TIMEOUT_MS = 3000;

self.addEventListener('fetch', (event) => {
  event.respondWith(
    Promise.race([
      fetch(event.request).then((response) => {
        const cloned = response.clone();
        caches.open(CACHE_NAME).then((c) => c.put(event.request, cloned));
        return response;
      }),
      new Promise((_, reject) => setTimeout(() => reject(new Error('timeout')), TIMEOUT_MS))
    ]).catch(() => caches.match(event.request))
  );
});`,
    StaleWhileRevalidate: `// service-worker.js — StaleWhileRevalidate
const CACHE_NAME = 'swr-cache-v1';

self.addEventListener('fetch', (event) => {
  event.respondWith(
    caches.open(CACHE_NAME).then((cache) => {
      return cache.match(event.request).then((cached) => {
        const fetchPromise = fetch(event.request).then((response) => {
          cache.put(event.request, response.clone());
          return response;
        });
        // Return cached immediately, update in background
        return cached || fetchPromise;
      });
    })
  );
});`,
    NetworkOnly: `// service-worker.js — NetworkOnly
self.addEventListener('fetch', (event) => {
  // Pass through to network, no caching
  event.respondWith(fetch(event.request));
});`,
    CacheOnly: `// service-worker.js — CacheOnly
const CACHE_NAME = 'precache-v1';
const PRECACHE_URLS = [
  '/',
  '/index.html',
  '/styles/main.css',
  '/scripts/app.js',
  '/offline.html',
];

self.addEventListener('install', (event) => {
  event.waitUntil(
    caches.open(CACHE_NAME).then((cache) => cache.addAll(PRECACHE_URLS))
  );
  self.skipWaiting();
});

self.addEventListener('fetch', (event) => {
  event.respondWith(caches.match(event.request));
});`,
  };

  function update() {
    var strat = recommend();
    var info = STRATEGIES[strat];

    document.getElementById('strategy-badge').textContent = strat;
    document.getElementById('strategy-name').textContent = info.name + ' Strategy';
    document.getElementById('strategy-desc').textContent = info.desc;

    var perfBadge = document.getElementById('perf-badge');
    perfBadge.textContent = info.perf.label;
    perfBadge.className = 'text-xs px-2 py-1 rounded-full border ' + info.perf.class;

    var freshBadge = document.getElementById('fresh-badge');
    freshBadge.textContent = info.fresh.label;
    freshBadge.className = 'text-xs px-2 py-1 rounded-full border ' + info.fresh.class;

    var offlineBadge = document.getElementById('offline-badge');
    offlineBadge.textContent = info.offline.label;
    offlineBadge.className = 'text-xs px-2 py-1 rounded-full border ' + info.offline.class;

    document.getElementById('workbox-code').textContent = WORKBOX_SNIPPETS[strat];
    document.getElementById('raw-code').textContent = RAW_SNIPPETS[strat];
  }

  function setQ(group, val) {
    state[group] = val;
    document.querySelectorAll('.' + group + '-btn').forEach(function(btn) {
      var active = btn.dataset.val === val;
      btn.className = btn.className.replace(/bg-primary text-white font-medium|bg-surface border border-border text-text-muted hover:border-primary/g, '').trim();
      if (active) {
        btn.className += ' bg-primary text-white font-medium';
      } else {
        btn.className += ' bg-surface border border-border text-text-muted hover:border-primary';
      }
    });
    update();
  }

  // Init button listeners
  document.querySelectorAll('.q1-btn').forEach(function(btn) {
    btn.addEventListener('click', function() { setQ('resource', btn.dataset.val); });
  });
  document.querySelectorAll('.q2-btn').forEach(function(btn) {
    btn.addEventListener('click', function() { setQ('offline', btn.dataset.val); });
  });
  document.querySelectorAll('.q3-btn').forEach(function(btn) {
    btn.addEventListener('click', function() { setQ('freshness', btn.dataset.val); });
  });

  function copyEl(btnId, srcId) {
    navigator.clipboard.writeText(document.getElementById(srcId).textContent).then(function() {
      var btn = document.getElementById(btnId);
      var orig = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(function() { btn.textContent = orig; }, 1500);
    });
  }

  document.getElementById('copy-workbox').addEventListener('click', function() { copyEl('copy-workbox', 'workbox-code'); });
  document.getElementById('copy-raw').addEventListener('click', function() { copyEl('copy-raw', 'raw-code'); });

  update();
})();
</script>
