---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AgeCalculator from '../../components/AgeCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How is the exact age calculated?", answer: "The calculator computes the difference between today's date and your birthdate accounting for varying month lengths and leap years. It gives exact years, months, and remaining days — not just a rounded number. For example, if you were born on March 15 and today is May 3, you are X years, 1 month, and 18 days old." },
  { question: "How accurate is the next birthday countdown?", answer: "The countdown shows the exact number of days remaining until your next birthday in the current calendar year. If your birthday has already passed this year, it counts to next year. If today is your birthday, it shows a celebration message." },
  { question: "How is the Chinese zodiac sign determined?", answer: "This calculator uses a simplified Gregorian year-based calculation for the Chinese zodiac. The traditional Chinese zodiac follows the lunar calendar, so people born in January or February may technically belong to the previous year's sign. For precise lunar-based results, consult a dedicated lunar calendar tool." },
  { question: "What is the Western (tropical) zodiac?", answer: "The Western zodiac divides the year into 12 signs based on the position of the Sun relative to constellations. Each sign covers approximately 30 days. Your sign is determined by your month and day of birth, regardless of the year. This calculator uses the standard tropical zodiac date ranges." },
  { question: "Can I calculate someone else's age?", answer: "Yes — enter any birthdate and the calculator instantly computes the exact age for that date. It works for any historical date after the Gregorian calendar was adopted and before today." },
];
---

<BaseLayout
  title="Age Calculator — Exact Age in Years, Months & Days"
  description="Free age calculator. Enter your birthdate to get your exact age in years, months, and days. Also shows total days lived, next birthday countdown, day of the week born, Chinese zodiac, and Western zodiac sign. Runs in your browser."
  tool="Age Calculator, Birthday Calculator, How Old Am I, Exact Age Calculator, Years Months Days, Next Birthday Countdown, Chinese Zodiac Calculator, Western Zodiac Sign"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Age Calculator</h1>
  <p class="text-text-muted mb-4">Calculate your exact age in years, months, and days. See total days and weeks lived, your next birthday countdown, the day of the week you were born, and your Chinese and Western zodiac signs. Instant, runs in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Exact years + months + days</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Zodiac + birthday countdown</span>
  </div>
  <AgeCalculator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Age Calculator" relatedTags={['utilities', 'datetime', 'calculator', 'birthday']} />
</BaseLayout>
