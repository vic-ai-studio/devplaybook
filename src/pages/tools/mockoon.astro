---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const cliExample = `# Install Mockoon CLI globally
npm install -g @mockoon/cli

# Start a mock server from a Mockoon environment file
mockoon-cli start --data ./my-api.json --port 3001

# Run with Docker
docker run -v /path/to/data:/data \\
  mockoon/cli:latest \\
  --data /data/my-api.json --port 3001

# Start multiple environments simultaneously
mockoon-cli start --data ./api1.json --port 3001
mockoon-cli start --data ./api2.json --port 3002`;

const responseTemplateExample = `// Mockoon response body with Handlebars templating
{
  "id": "{{faker 'number.int' min=1 max=9999}}",
  "name": "{{faker 'person.fullName'}}",
  "email": "{{faker 'internet.email'}}",
  "createdAt": "{{now 'YYYY-MM-DDTHH:mm:ssZ'}}",
  "status": "{{oneOf (array 'active' 'inactive' 'pending')}}"
}`;

const faq = [
  { question: "What is Mockoon and what problem does it solve?", answer: "Mockoon is a free desktop application that lets you create local mock HTTP servers in seconds. The problem it solves is frontend-backend coupling: when a frontend team is building a feature but the backend API is not yet implemented, development blocks. Mockoon lets you define the API contract (routes, response shapes, status codes) and run a real local HTTP server immediately — so frontend development and API testing can proceed without waiting for the real backend. It also helps with third-party API dependencies: if you depend on a paid or rate-limited external API, you can mock it locally." },
  { question: "How does Mockoon compare to WireMock?", answer: "WireMock is a Java-based mock server typically used in backend integration testing, configured via JSON stub files or Java code. It is powerful for complex scenarios but requires Java, has steeper configuration, and is more complex to set up for quick frontend development. Mockoon is a desktop GUI application with a visual drag-and-drop interface — no code required to define routes. It also has a CLI (mockoon-cli) for CI/CD use. Mockoon is better suited for frontend developers who want a quick visual tool; WireMock is better for Java backend teams doing programmatic test automation." },
  { question: "How do I use Mockoon CLI in CI/CD?", answer: "Install the CLI with npm install -g @mockoon/cli. Export your environment from the Mockoon Desktop app as a JSON file and commit it to your repository. In your CI pipeline, run mockoon-cli start --data my-api.json --port 3001 before your tests. The process stays running so your tests can make real HTTP requests to localhost:3001. After tests complete, stop the process. The Mockoon CLI supports Docker — the official image is mockoon/cli — which is ideal for containerized CI environments." },
  { question: "What are Mockoon response rules and how do they work?", answer: "Response rules let you serve different responses for the same route based on request properties like headers, body content, query parameters, or route parameters. For example, you can return a 200 response when a header X-User-Role is admin, and a 403 response otherwise. Rules are evaluated in order, and the first matching rule wins. This makes it possible to simulate different API behaviors (authenticated vs unauthenticated, found vs not found) without creating separate routes." },
  { question: "What is a Mockoon data bucket?", answer: "Data buckets are reusable, in-memory data stores in Mockoon. You define a named bucket with an initial JSON value (which can use Handlebars/Faker templating). Routes can read from and write to buckets using the dataRaw and setData helpers, simulating a stateful API. This means you can mock a full CRUD API: a POST creates an item in the bucket, a GET reads from it, a DELETE removes it — and the data persists across requests during the server session. Data buckets reset to their initial values when the server restarts." },
  { question: "Does Mockoon support HTTPS and custom certificates?", answer: "Yes. Mockoon supports TLS/HTTPS for mock servers. In the environment settings you can enable HTTPS, and Mockoon will generate a self-signed certificate automatically. You can also provide your own certificate and key files. This is useful when your application code enforces HTTPS-only requests or when you need to test TLS-specific behavior. In the CLI, pass --https to enable it. Remember to configure your HTTP client to trust the self-signed cert (or disable cert verification in development)." },
];
---

<BaseLayout
  title="Mockoon — Free Desktop Mock Server for API Development"
  description="Mockoon is a free desktop application for creating local mock HTTP servers without coding. Visual route builder, response templates with Faker data, response rules, data buckets, and CLI for CI/CD."
  tool="Mockoon, API mock server, mock REST API, Mockoon CLI, WireMock alternative, local API mocking, fake API server"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Mockoon — Free Desktop Mock Server for API Development",
    "url": "https://devplaybook.cc/tools/mockoon",
    "description": "Mockoon is a free desktop application for creating local mock HTTP servers without coding. Visual route builder, response templates, response rules, data buckets, and CLI.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Mockoon — Free Desktop Mock Server</h1>
  <p class="text-text-muted mb-6">
    <strong>Mockoon</strong> is a free, open-source desktop application for creating local mock HTTP servers in seconds — no code required. Define your API routes visually, generate realistic fake data with Handlebars and Faker.js templates, and start a real localhost server your frontend or tests can call immediately.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Visual route builder, no code needed</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Faker.js response templating</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Response rules and data buckets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CLI for CI/CD pipelines</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Free and open source</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Mockoon?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Mockoon was created by Guillaume Monnet and released as open source under the MIT license. It runs as a native desktop application on macOS, Windows, and Linux, providing a visual interface for defining mock API routes and their responses. Each mock server configuration is saved as a JSON file that can be committed to Git and shared with your team.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    The core use case is decoupling frontend development from backend readiness. When your team agrees on an API contract (routes, request/response shapes), a developer can define those routes in Mockoon, run them locally, and the frontend team can integrate immediately — no waiting for the backend to be implemented. Mockoon also makes it easy to mock third-party dependencies (payment APIs, email services, weather data) without making real requests during development.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Visual UI</strong> — drag-and-drop route creation with no configuration files to write manually</li>
    <li><strong>Multiple environments</strong> — run several independent mock servers simultaneously on different ports</li>
    <li><strong>Response templates</strong> — Handlebars helpers and Faker.js integration for dynamic, realistic fake data</li>
    <li><strong>Response rules</strong> — serve different responses based on headers, body, query params, or route params</li>
    <li><strong>Data buckets</strong> — in-memory stores that simulate stateful CRUD behavior across requests</li>
    <li><strong>Mockoon CLI</strong> — headless server for CI/CD pipelines, supports Docker</li>
    <li><strong>HTTPS</strong> — auto-generated or custom TLS certificates for mock servers</li>
    <li><strong>Proxy mode</strong> — forward unmatched requests to a real API and record responses</li>
    <li><strong>OpenAPI import</strong> — generate mock routes automatically from an OpenAPI 3.x spec</li>
    <li><strong>Latency simulation</strong> — add artificial delays to simulate slow networks or rate limits</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Installation</h2>
  <div class="bg-bg-card border border-border rounded-xl p-4 mb-4">
    <p class="text-xs text-text-muted uppercase font-semibold mb-2">Desktop App (macOS / Windows / Linux)</p>
    <pre class="text-sm font-mono text-text">Download from mockoon.com/download</pre>
  </div>
  <div class="bg-bg-card border border-border rounded-xl p-4 mb-4">
    <p class="text-xs text-text-muted uppercase font-semibold mb-2">macOS (Homebrew)</p>
    <pre class="text-sm font-mono text-text">brew install --cask mockoon</pre>
  </div>
  <div class="bg-bg-card border border-border rounded-xl p-4 mb-6">
    <p class="text-xs text-text-muted uppercase font-semibold mb-2">Mockoon CLI</p>
    <pre class="text-sm font-mono text-text" set:html={cliExample}></pre>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Response Templating with Faker.js</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={responseTemplateExample}></pre>
  <p class="text-text-muted mb-4">
    Mockoon uses Handlebars syntax extended with Faker.js helpers. <code class="font-mono bg-surface px-1 rounded text-sm">faker 'person.fullName'</code> generates a random name; <code class="font-mono bg-surface px-1 rounded text-sm">oneOf</code> picks a random value from an array; <code class="font-mono bg-surface px-1 rounded text-sm">now</code> inserts the current timestamp. Each request gets a freshly generated response.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Mockoon vs WireMock vs MSW</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">Mockoon</th>
          <th class="border border-border px-3 py-2 text-left">WireMock</th>
          <th class="border border-border px-3 py-2 text-left">MSW (Mock Service Worker)</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-border px-3 py-2">Interface</td>
          <td class="border border-border px-3 py-2">Desktop GUI</td>
          <td class="border border-border px-3 py-2">Config files / Java API</td>
          <td class="border border-border px-3 py-2">JavaScript code</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Language required</td>
          <td class="border border-border px-3 py-2 text-green-400">None (visual)</td>
          <td class="border border-border px-3 py-2">Java / JSON</td>
          <td class="border border-border px-3 py-2">JavaScript / TypeScript</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">Runs as</td>
          <td class="border border-border px-3 py-2">Real HTTP server</td>
          <td class="border border-border px-3 py-2">Real HTTP server</td>
          <td class="border border-border px-3 py-2">Service Worker (browser)</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Best for</td>
          <td class="border border-border px-3 py-2">Frontend teams, quick setup</td>
          <td class="border border-border px-3 py-2">Java integration tests</td>
          <td class="border border-border px-3 py-2">React / frontend unit tests</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">CI/CD CLI</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes (mockoon-cli)</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes (JAR or Docker)</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes (Node.js server mode)</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Stateful mocking</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes (data buckets)</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Via stateful scenarios</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Via custom handlers</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Use Cases</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li>Frontend development against an agreed API contract before backend is ready</li>
    <li>Mocking third-party APIs (Stripe, SendGrid, Twilio) to avoid real API calls in development</li>
    <li>Integration testing in CI/CD with mockoon-cli running as a Docker container</li>
    <li>Simulating error conditions (500, 503, slow responses) to test error handling</li>
    <li>Prototyping and demoing mobile apps without a real backend</li>
    <li>Rapid API prototyping to validate an API design before implementation</li>
  </ul>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Mockoon Mock Server" relatedTags={['api', 'mock', 'rest', 'testing', 'developer-tools', 'http', 'frontend']} />
</BaseLayout>
