---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TsvToJson from '../../components/TsvToJson.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is TSV format?", answer: "TSV (Tab-Separated Values) is a plain-text format where each record is on its own line and fields are separated by tab characters. It's widely used to export data from spreadsheets (Excel, Google Sheets), databases, and command-line tools. Unlike CSV, TSV doesn't need quoting for commas in values, making it simpler to parse." },
  { question: "How do I copy TSV data from Excel or Google Sheets?", answer: "Select the cells you want to convert in Excel or Google Sheets, then copy (Ctrl+C / Cmd+C). When you paste into a text area, the data will automatically be in TSV format with tabs between columns. Paste it directly into the input area of this tool and click Convert." },
  { question: "What does the 'Number Coerce' option do?", answer: "When enabled, the tool automatically converts numeric strings to JSON numbers. For example, '42' becomes 42 (not '42') and 'true'/'false' become boolean values. This produces cleaner JSON for data that will be consumed by APIs or analytics tools. Disable it to keep all values as strings." },
  { question: "How does the tool handle rows with different column counts?", answer: "When a row has a different number of columns than the header row, the tool logs a warning but still processes the row. Missing values are filled with empty strings, and extra values are ignored. Warnings are displayed above the output so you can identify and fix data quality issues." },
  { question: "Can I download the JSON output?", answer: "Yes. Click the 'Download' button to save the JSON output as a .json file. You can also copy to clipboard with the 'Copy JSON' button. Use the indent dropdown to choose between minified (compact) and pretty-printed (2 or 4 spaces) output." },
  { question: "What if my TSV has no header row?", answer: "Uncheck the 'Has Headers' option. The tool will generate column names automatically (column_1, column_2, etc.) and treat all rows as data. You can rename these keys afterwards in the JSON editor of your choice." },
];
---

<BaseLayout
  title="TSV to JSON Converter — Free Online Tool | Tab-Separated to JSON"
  description="Convert TSV (tab-separated values) to JSON online. Auto-detect headers, preview table output, number coercion, and download results. Paste from Excel or Google Sheets. Runs 100% in your browser."
  tool="TSV to JSON, Tab Separated to JSON, Excel to JSON, Spreadsheet to JSON, TSV Converter, CSV to JSON"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "TSV to JSON Converter",
    "url": "https://devplaybook.cc/tools/tsv-to-json",
    "description": "Convert tab-separated values to JSON. Auto-detects headers, supports number coercion, previews as table, and exports. Paste from Excel or Google Sheets. Runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">TSV to JSON Converter</h1>
  <p class="text-text-muted mb-4">Convert tab-separated values (TSV) to JSON instantly. Paste data directly from <strong>Excel</strong> or <strong>Google Sheets</strong>, auto-detect column headers, preview as a table, and download or copy the JSON output. Supports number coercion, empty row skipping, and configurable indentation. Runs entirely in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Paste from Excel & Google Sheets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Table preview + JSON output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <TsvToJson client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="TSV to JSON Converter" relatedTags={['data', 'json', 'csv', 'utilities', 'spreadsheet']} />
</BaseLayout>
