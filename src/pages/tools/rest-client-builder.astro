---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="REST Client Builder — HTTP Request Builder with cURL Output"
  description="Build HTTP requests visually and export as curl, fetch, axios, or HTTPie. Add headers, query params, and request bodies. Supports GET, POST, PUT, PATCH, DELETE, OPTIONS."
  tool="REST client builder, curl generator, HTTP request builder, API request generator, fetch code generator, axios generator"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "REST Client Builder",
    "url": "https://devplaybook.cc/tools/rest-client-builder",
    "description": "Build HTTP requests visually and export as curl, fetch, axios, HTTPie, or Python requests. Supports all HTTP methods, headers, query params, auth, and request bodies.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">REST Client Builder</h1>
  <p class="text-text-muted mb-4">Build HTTP requests visually — method, URL, query params, headers, auth, and body — then export as cURL, JavaScript fetch, axios, HTTPie, or Python requests. No install required. Runs entirely in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GET / POST / PUT / PATCH / DELETE / HEAD / OPTIONS</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Bearer / Basic / API Key auth</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 output formats</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <!-- Method + URL bar -->
  <div class="flex gap-2 mb-4 items-end">
    <div class="shrink-0">
      <label class="block text-sm font-medium mb-1.5" for="rc-method">Method</label>
      <select id="rc-method" class="bg-bg-card border border-border rounded-lg p-3 text-sm font-semibold focus:outline-none focus:border-primary w-32">
        <option value="GET">GET</option>
        <option value="POST">POST</option>
        <option value="PUT">PUT</option>
        <option value="PATCH">PATCH</option>
        <option value="DELETE">DELETE</option>
        <option value="HEAD">HEAD</option>
        <option value="OPTIONS">OPTIONS</option>
      </select>
    </div>
    <div class="flex-1">
      <label class="block text-sm font-medium mb-1.5" for="rc-url">URL</label>
      <input id="rc-url" type="text" placeholder="https://api.example.com/v1/users" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary font-mono" />
    </div>
  </div>

  <!-- URL Preview -->
  <div class="mb-4 text-xs text-text-muted flex items-center gap-2">
    <span class="font-medium">Full URL:</span>
    <code id="url-preview" class="font-mono bg-surface px-2 py-1 rounded text-xs break-all">https://api.example.com/v1/users</code>
  </div>

  <!-- Load Examples -->
  <div class="flex items-center gap-2 mb-5 flex-wrap">
    <span class="text-sm text-text-muted font-medium">Load example:</span>
    <button class="load-example px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors" data-example="get-user">GET User</button>
    <button class="load-example px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors" data-example="post-create">POST Create</button>
    <button class="load-example px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors" data-example="auth-request">Auth Request</button>
  </div>

  <!-- Tabs: Params / Headers / Body / Auth -->
  <div class="flex gap-0 mb-0 border-b border-border">
    <button class="section-tab px-4 py-2.5 text-sm font-medium border-b-2 border-primary text-primary" data-section="params">Query Params</button>
    <button class="section-tab px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-text" data-section="headers">Headers</button>
    <button class="section-tab px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-text" data-section="body">Body</button>
    <button class="section-tab px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-text" data-section="auth">Auth</button>
  </div>

  <!-- Params section -->
  <div id="section-params" class="bg-bg-card border border-x border-b border-border rounded-b-lg p-4 mb-4">
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs text-text-muted">Key / Value pairs are appended to the URL as query string.</span>
      <button id="add-param-btn" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">+ Add Param</button>
    </div>
    <div id="params-list" class="flex flex-col gap-2"></div>
  </div>

  <!-- Headers section -->
  <div id="section-headers" class="hidden bg-bg-card border border-x border-b border-border rounded-b-lg p-4 mb-4">
    <div class="flex items-center justify-between mb-2 flex-wrap gap-2">
      <div class="flex gap-2 flex-wrap">
        <button class="header-preset px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-key="Authorization" data-val="Bearer YOUR_TOKEN">+ Auth Bearer</button>
        <button class="header-preset px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-key="Content-Type" data-val="application/json">+ Content-Type JSON</button>
        <button class="header-preset px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-key="Accept" data-val="application/json">+ Accept JSON</button>
      </div>
      <button id="add-header-btn" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">+ Add Header</button>
    </div>
    <div id="headers-list" class="flex flex-col gap-2"></div>
  </div>

  <!-- Body section -->
  <div id="section-body" class="hidden bg-bg-card border border-x border-b border-border rounded-b-lg p-4 mb-4">
    <div id="body-unavailable" class="text-sm text-text-muted">Body is not available for GET, HEAD, or OPTIONS requests.</div>
    <div id="body-editor" class="hidden">
      <div class="flex items-center gap-3 mb-3 flex-wrap">
        <label class="text-sm font-medium">Body type:</label>
        <select id="body-type" class="bg-bg-card border border-border rounded-lg p-2.5 text-sm focus:outline-none focus:border-primary">
          <option value="json">JSON</option>
          <option value="form">Form Data</option>
          <option value="text">Plain Text</option>
          <option value="xml">XML</option>
        </select>
        <button id="format-body-btn" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Format JSON</button>
      </div>
      <textarea id="rc-body" rows="8" placeholder='{"name": "John Doe", "email": "john@example.com"}' class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary font-mono resize-y"></textarea>
    </div>
  </div>

  <!-- Auth section -->
  <div id="section-auth" class="hidden bg-bg-card border border-x border-b border-border rounded-b-lg p-4 mb-4">
    <div class="flex items-center gap-3 mb-4 flex-wrap">
      <label class="text-sm font-medium">Auth type:</label>
      <select id="auth-type" class="bg-bg-card border border-border rounded-lg p-2.5 text-sm focus:outline-none focus:border-primary">
        <option value="none">None</option>
        <option value="bearer">Bearer Token</option>
        <option value="basic">Basic Auth</option>
        <option value="apikey">API Key</option>
      </select>
    </div>
    <div id="auth-bearer" class="hidden">
      <label class="block text-sm font-medium mb-1.5" for="auth-token">Token</label>
      <input id="auth-token" type="text" placeholder="YOUR_TOKEN_HERE" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary font-mono" />
    </div>
    <div id="auth-basic" class="hidden flex flex-col gap-2">
      <div>
        <label class="block text-sm font-medium mb-1.5" for="auth-username">Username</label>
        <input id="auth-username" type="text" placeholder="username" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5" for="auth-password">Password</label>
        <input id="auth-password" type="password" placeholder="password" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
      </div>
    </div>
    <div id="auth-apikey" class="hidden flex flex-col gap-2">
      <div class="flex gap-2">
        <div class="flex-1">
          <label class="block text-sm font-medium mb-1.5" for="apikey-name">Header Name</label>
          <input id="apikey-name" type="text" value="X-API-Key" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div class="flex-[2]">
          <label class="block text-sm font-medium mb-1.5" for="apikey-value">Key Value</label>
          <input id="apikey-value" type="text" placeholder="your-api-key-here" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary font-mono" />
        </div>
      </div>
    </div>
  </div>

  <!-- Generate -->
  <button id="generate-btn" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 mb-6">Generate Code</button>

  <!-- Output tabs -->
  <div id="output-section" class="hidden">
    <div class="flex gap-1 mb-0 border-b border-border">
      <button class="output-tab px-4 py-2 text-sm font-medium border-b-2 border-primary text-primary" data-tab="curl">cURL</button>
      <button class="output-tab px-4 py-2 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-text" data-tab="fetch">fetch()</button>
      <button class="output-tab px-4 py-2 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-text" data-tab="axios">axios</button>
      <button class="output-tab px-4 py-2 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-text" data-tab="httpie">HTTPie</button>
      <button class="output-tab px-4 py-2 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-text" data-tab="python">Python</button>
    </div>
    <div class="relative">
      <pre id="output-pre" class="bg-bg-card border border-x border-b border-border rounded-b-lg p-4 text-sm font-mono overflow-x-auto whitespace-pre-wrap mb-4"></pre>
      <button id="copy-btn" class="absolute top-3 right-3 px-3 py-1.5 bg-bg-card border border-border rounded-md text-xs hover:border-primary transition-colors">Copy</button>
    </div>
  </div>

  <ToolPageCta currentTool="REST Client Builder" relatedTags={['http', 'api', 'curl', 'rest', 'fetch', 'axios', 'developer-tools']} />
</BaseLayout>

<script is:inline>
(function () {
  var methodEl = document.getElementById('rc-method');
  var urlEl = document.getElementById('rc-url');
  var urlPreview = document.getElementById('url-preview');
  var paramsList = document.getElementById('params-list');
  var headersList = document.getElementById('headers-list');
  var bodyTypeEl = document.getElementById('body-type');
  var bodyEl = document.getElementById('rc-body');
  var authTypeEl = document.getElementById('auth-type');
  var outputSection = document.getElementById('output-section');
  var outputPre = document.getElementById('output-pre');

  var currentTab = 'curl';
  var lastOutputs = {};

  // ---- Examples ----
  var EXAMPLES = {
    'get-user': {
      method: 'GET',
      url: 'https://api.example.com/v1/users',
      params: [['id', '123', true], ['include', 'profile', true]],
      headers: [['Accept', 'application/json', true]],
      bodyType: 'json',
      body: '',
      authType: 'bearer',
      authToken: 'YOUR_ACCESS_TOKEN'
    },
    'post-create': {
      method: 'POST',
      url: 'https://api.example.com/v1/users',
      params: [],
      headers: [['Content-Type', 'application/json', true], ['Accept', 'application/json', true]],
      bodyType: 'json',
      body: '{\n  "name": "John Doe",\n  "email": "john@example.com",\n  "role": "user"\n}',
      authType: 'bearer',
      authToken: 'YOUR_ACCESS_TOKEN'
    },
    'auth-request': {
      method: 'GET',
      url: 'https://api.example.com/v1/me',
      params: [],
      headers: [['Accept', 'application/json', true]],
      bodyType: 'json',
      body: '',
      authType: 'basic',
      authUser: 'admin',
      authPass: 'secret123'
    }
  };

  // ---- Escape ----
  function escAttr(s) {
    return String(s).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;');
  }

  // ---- Dynamic rows ----
  function makeParamRow(key, val, enabled) {
    var row = document.createElement('div');
    row.className = 'flex items-center gap-2 param-row';
    var chk = enabled !== false ? 'checked' : '';
    row.innerHTML =
      '<input type="checkbox" ' + chk + ' class="param-enabled w-4 h-4 accent-primary shrink-0" />' +
      '<input type="text" placeholder="param" value="' + escAttr(key) + '" class="flex-1 bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary param-key" />' +
      '<input type="text" placeholder="value" value="' + escAttr(val) + '" class="flex-[2] bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary param-val" />' +
      '<button class="remove-param px-3 py-2.5 bg-bg-card border border-border rounded-lg text-sm text-text-muted hover:border-red-400 hover:text-red-400 transition-colors">✕</button>';
    row.querySelector('.remove-param').addEventListener('click', function () { row.remove(); updateUrlPreview(); });
    row.querySelector('.param-key').addEventListener('input', updateUrlPreview);
    row.querySelector('.param-val').addEventListener('input', updateUrlPreview);
    row.querySelector('.param-enabled').addEventListener('change', updateUrlPreview);
    return row;
  }

  function makeHeaderRow(key, val, enabled) {
    var row = document.createElement('div');
    row.className = 'flex items-center gap-2 header-row';
    var chk = enabled !== false ? 'checked' : '';
    row.innerHTML =
      '<input type="checkbox" ' + chk + ' class="header-enabled w-4 h-4 accent-primary shrink-0" />' +
      '<input type="text" placeholder="Header name" value="' + escAttr(key) + '" class="flex-1 bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary header-key" />' +
      '<input type="text" placeholder="Value" value="' + escAttr(val) + '" class="flex-[2] bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary header-val" />' +
      '<button class="remove-header px-3 py-2.5 bg-bg-card border border-border rounded-lg text-sm text-text-muted hover:border-red-400 hover:text-red-400 transition-colors">✕</button>';
    row.querySelector('.remove-header').addEventListener('click', function () { row.remove(); });
    return row;
  }

  function setParams(pairs) {
    paramsList.innerHTML = '';
    (pairs || []).forEach(function (p) { paramsList.appendChild(makeParamRow(p[0], p[1], p[2] !== false)); });
  }

  function setHeaders(pairs) {
    headersList.innerHTML = '';
    (pairs || []).forEach(function (p) { headersList.appendChild(makeHeaderRow(p[0], p[1], p[2] !== false)); });
  }

  function getParams() {
    var out = [];
    paramsList.querySelectorAll('.param-row').forEach(function (r) {
      var enabled = r.querySelector('.param-enabled').checked;
      var k = r.querySelector('.param-key').value.trim();
      var v = r.querySelector('.param-val').value.trim();
      if (k) out.push({ key: k, val: v, enabled: enabled });
    });
    return out;
  }

  function getHeaders() {
    var out = [];
    headersList.querySelectorAll('.header-row').forEach(function (r) {
      var enabled = r.querySelector('.header-enabled').checked;
      var k = r.querySelector('.header-key').value.trim();
      var v = r.querySelector('.header-val').value.trim();
      if (k) out.push({ key: k, val: v, enabled: enabled });
    });
    return out;
  }

  function updateUrlPreview() {
    var base = urlEl.value.trim() || 'https://api.example.com';
    var params = getParams().filter(function (p) { return p.enabled; });
    if (params.length) {
      base += '?' + params.map(function (p) {
        return encodeURIComponent(p.key) + '=' + encodeURIComponent(p.val);
      }).join('&');
    }
    urlPreview.textContent = base;
  }

  urlEl.addEventListener('input', updateUrlPreview);

  // ---- Section tabs ----
  var sections = ['params', 'headers', 'body', 'auth'];
  document.querySelectorAll('.section-tab').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var sec = btn.dataset.section;
      sections.forEach(function (s) {
        document.getElementById('section-' + s).classList.add('hidden');
      });
      document.getElementById('section-' + sec).classList.remove('hidden');
      document.querySelectorAll('.section-tab').forEach(function (b) {
        var active = b.dataset.section === sec;
        b.className = 'section-tab px-4 py-2.5 text-sm font-medium border-b-2 ' +
          (active ? 'border-primary text-primary' : 'border-transparent text-text-muted hover:text-text');
      });
    });
  });

  // ---- Method change (toggle body) ----
  var BODY_METHODS = ['POST', 'PUT', 'PATCH'];
  function updateBodyVisibility() {
    var m = methodEl.value;
    var hasBody = BODY_METHODS.indexOf(m) !== -1;
    document.getElementById('body-unavailable').classList.toggle('hidden', hasBody);
    document.getElementById('body-editor').classList.toggle('hidden', !hasBody);
    document.getElementById('format-body-btn').classList.toggle('hidden', bodyTypeEl.value !== 'json');
  }
  methodEl.addEventListener('change', function () { updateBodyVisibility(); updateUrlPreview(); });
  bodyTypeEl.addEventListener('change', function () {
    document.getElementById('format-body-btn').classList.toggle('hidden', bodyTypeEl.value !== 'json');
  });

  // ---- Auth type ----
  authTypeEl.addEventListener('change', function () {
    document.getElementById('auth-bearer').classList.add('hidden');
    document.getElementById('auth-basic').classList.add('hidden');
    document.getElementById('auth-apikey').classList.add('hidden');
    var t = authTypeEl.value;
    if (t === 'bearer') document.getElementById('auth-bearer').classList.remove('hidden');
    else if (t === 'basic') document.getElementById('auth-basic').classList.remove('hidden');
    else if (t === 'apikey') document.getElementById('auth-apikey').classList.remove('hidden');
  });

  // ---- Add row buttons ----
  document.getElementById('add-param-btn').addEventListener('click', function () {
    paramsList.appendChild(makeParamRow('', '', true));
  });
  document.getElementById('add-header-btn').addEventListener('click', function () {
    headersList.appendChild(makeHeaderRow('', '', true));
  });

  // ---- Header presets ----
  document.querySelectorAll('.header-preset').forEach(function (btn) {
    btn.addEventListener('click', function () {
      headersList.appendChild(makeHeaderRow(btn.dataset.key, btn.dataset.val, true));
    });
  });

  // ---- Format body ----
  document.getElementById('format-body-btn').addEventListener('click', function () {
    try {
      bodyEl.value = JSON.stringify(JSON.parse(bodyEl.value), null, 2);
    } catch (e) {
      alert('Invalid JSON: ' + e.message);
    }
  });

  // ---- Load examples ----
  document.querySelectorAll('.load-example').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var ex = EXAMPLES[btn.dataset.example];
      if (!ex) return;
      methodEl.value = ex.method;
      urlEl.value = ex.url;
      setParams(ex.params || []);
      setHeaders(ex.headers || []);
      bodyTypeEl.value = ex.bodyType || 'json';
      bodyEl.value = ex.body || '';
      authTypeEl.value = ex.authType || 'none';
      // Trigger auth UI
      authTypeEl.dispatchEvent(new Event('change'));
      if (ex.authToken) document.getElementById('auth-token').value = ex.authToken;
      if (ex.authUser) document.getElementById('auth-username').value = ex.authUser;
      if (ex.authPass) document.getElementById('auth-password').value = ex.authPass;
      if (ex.authKey) document.getElementById('apikey-name').value = ex.authKey;
      if (ex.authKeyVal) document.getElementById('apikey-value').value = ex.authKeyVal;
      updateBodyVisibility();
      updateUrlPreview();
      outputSection.classList.add('hidden');
    });
  });

  // ---- Collect auth headers ----
  function getAuthHeaders() {
    var t = authTypeEl.value;
    if (t === 'bearer') {
      var tok = document.getElementById('auth-token').value.trim();
      if (tok) return [{ key: 'Authorization', val: 'Bearer ' + tok }];
    } else if (t === 'basic') {
      var u = document.getElementById('auth-username').value;
      var p = document.getElementById('auth-password').value;
      if (u || p) {
        var encoded = btoa(u + ':' + p);
        return [{ key: 'Authorization', val: 'Basic ' + encoded }];
      }
    } else if (t === 'apikey') {
      var kn = document.getElementById('apikey-name').value.trim();
      var kv = document.getElementById('apikey-value').value.trim();
      if (kn && kv) return [{ key: kn, val: kv }];
    }
    return [];
  }

  // ---- Build outputs ----
  function buildOutputs(method, baseUrl, params, allHeaders, body, bodyType) {
    var qs = params.filter(function (p) { return p.enabled; }).map(function (p) {
      return encodeURIComponent(p.key) + '=' + encodeURIComponent(p.val);
    }).join('&');
    var fullUrl = baseUrl + (qs ? '?' + qs : '');
    var hdrs = allHeaders.filter(function (h) { return h.enabled; });
    var hasBody = BODY_METHODS.indexOf(method) !== -1 && body;
    var contentType = bodyType === 'json' ? 'application/json'
      : bodyType === 'form' ? 'application/x-www-form-urlencoded'
      : bodyType === 'xml' ? 'application/xml'
      : 'text/plain';

    // cURL
    var curlParts = ['curl -X ' + method + ' \\\n  "' + fullUrl + '"'];
    hdrs.forEach(function (h) { curlParts.push('  -H "' + h.key + ': ' + h.val + '"'); });
    if (hasBody) {
      if (bodyType === 'json') {
        curlParts.push('  -H "Content-Type: application/json"');
      }
      curlParts.push('  -d \'' + body.replace(/'/g, "'\\''") + '\'');
    }
    var curl = curlParts.join(' \\\n');

    // fetch
    var fHeaders = {};
    hdrs.forEach(function (h) { fHeaders[h.key] = h.val; });
    if (hasBody && bodyType === 'json') fHeaders['Content-Type'] = contentType;
    var fHeadersStr = JSON.stringify(fHeaders, null, 4).split('\n').map(function (l, i) {
      return i === 0 ? l : '    ' + l;
    }).join('\n');
    var fetchCode = 'const response = await fetch("' + fullUrl + '", {\n' +
      '  method: "' + method + '",\n' +
      '  headers: ' + fHeadersStr + (hasBody ? ',\n  body: ' + (bodyType === 'json' ? 'JSON.stringify(' + body + ')' : '"' + body.replace(/"/g, '\\"') + '"') : '') + '\n' +
      '});\nconst data = await response.json();\nconsole.log(data);';

    // axios
    var axiosConfig = '{\n  method: "' + method.toLowerCase() + '",\n  url: "' + fullUrl + '"';
    if (hdrs.length || (hasBody && bodyType === 'json')) {
      var axHdrs = {};
      hdrs.forEach(function (h) { axHdrs[h.key] = h.val; });
      if (hasBody && bodyType === 'json') axHdrs['Content-Type'] = contentType;
      axiosConfig += ',\n  headers: ' + JSON.stringify(axHdrs, null, 4).split('\n').map(function (l, i) {
        return i === 0 ? l : '  ' + l;
      }).join('\n');
    }
    if (hasBody) axiosConfig += ',\n  data: ' + (bodyType === 'json' ? body : '"' + body.replace(/"/g, '\\"') + '"');
    axiosConfig += '\n}';
    var axiosCode = 'const { data } = await axios(' + axiosConfig + ');\nconsole.log(data);';

    // HTTPie
    var httpieParts = ['http ' + method + ' "' + fullUrl + '"'];
    hdrs.forEach(function (h) { httpieParts.push('"' + h.key + ': ' + h.val + '"'); });
    if (hasBody) {
      if (bodyType === 'json') {
        httpieParts.push("<<<'" + body.replace(/'/g, "'\\''") + "'");
      } else {
        httpieParts.push("body='" + body.replace(/'/g, "'\\''") + "'");
      }
    }
    var httpie = httpieParts.join(' \\\n  ');

    // Python requests
    var pyParts = ['import requests\n'];
    pyParts.push('headers = ' + JSON.stringify(
      (function () { var o = {}; hdrs.forEach(function (h) { o[h.key] = h.val; }); return o; })(),
      null, 4
    ));
    if (hasBody) {
      pyParts.push('\npayload = ' + (bodyType === 'json' ? body : '"' + body.replace(/"/g, '\\"') + '"'));
      pyParts.push('\nresponse = requests.' + method.toLowerCase() + '(\n    "' + fullUrl + '",\n    headers=headers,\n    ' + (bodyType === 'json' ? 'json=payload' : 'data=payload') + '\n)');
    } else {
      pyParts.push('\nresponse = requests.' + method.toLowerCase() + '(\n    "' + fullUrl + '",\n    headers=headers\n)');
    }
    pyParts.push('\nprint(response.json())');
    var python = pyParts.join('\n');

    return { curl: curl, fetch: fetchCode, axios: axiosCode, httpie: httpie, python: python };
  }

  document.getElementById('generate-btn').addEventListener('click', function () {
    var method = methodEl.value;
    var base = urlEl.value.trim() || 'https://api.example.com';
    var params = getParams();
    var headers = getHeaders();
    var authHdrs = getAuthHeaders().map(function (h) { return { key: h.key, val: h.val, enabled: true }; });
    var allHeaders = headers.concat(authHdrs);
    var body = BODY_METHODS.indexOf(method) !== -1 ? (bodyEl.value.trim() || '') : '';
    var bodyType = bodyTypeEl.value;

    lastOutputs = buildOutputs(method, base, params, allHeaders, body, bodyType);
    renderTab(currentTab);
    outputSection.classList.remove('hidden');
  });

  // ---- Output tabs ----
  function renderTab(tab) {
    outputPre.textContent = lastOutputs[tab] || '';
    document.querySelectorAll('.output-tab').forEach(function (btn) {
      var active = btn.dataset.tab === tab;
      btn.className = 'output-tab px-4 py-2 text-sm font-medium border-b-2 ' +
        (active ? 'border-primary text-primary' : 'border-transparent text-text-muted hover:text-text');
    });
  }

  document.querySelectorAll('.output-tab').forEach(function (btn) {
    btn.addEventListener('click', function () {
      currentTab = btn.dataset.tab;
      renderTab(currentTab);
    });
  });

  // ---- Copy ----
  document.getElementById('copy-btn').addEventListener('click', function () {
    var text = outputPre.textContent;
    var btn = document.getElementById('copy-btn');
    if (navigator.clipboard) {
      navigator.clipboard.writeText(text).then(function () {
        btn.textContent = 'Copied!';
        setTimeout(function () { btn.textContent = 'Copy'; }, 2000);
      });
    } else {
      var ta = document.createElement('textarea');
      ta.value = text;
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      btn.textContent = 'Copied!';
      setTimeout(function () { btn.textContent = 'Copy'; }, 2000);
    }
  });

  // ---- Init ----
  updateBodyVisibility();
  updateUrlPreview();
})();
</script>
