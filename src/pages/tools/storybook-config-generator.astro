---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StorybookConfigGenerator from '../../components/StorybookConfigGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Storybook and who is it for?",
    answer: "Storybook is an open-source tool for building UI components in isolation, outside your main app. It provides a sandbox where you can develop, test, and document components independently. It's used by frontend developers working with React, Vue, Svelte, Angular, Web Components, and more. Teams use it for component-driven development, design system documentation, and visual regression testing."
  },
  {
    question: "What does main.ts configure in Storybook 8?",
    answer: "main.ts (or main.js) is the core Storybook configuration file. It tells Storybook where to find your story files (stories glob), which addons to load, and which framework/builder to use. In Storybook 8, the framework field replaces the separate builder field — for example, '@storybook/react-vite' means the React renderer with the Vite builder."
  },
  {
    question: "What does preview.ts configure?",
    answer: "preview.ts (or preview.js) controls the rendering environment for all stories. It sets global parameters (like controls matchers for color/date pickers), global decorators that wrap every story, and global args (default args available to all stories). It runs in the browser context, unlike main.ts which runs in Node."
  },
  {
    question: "What are Storybook addons?",
    answer: "Addons extend Storybook's functionality. The 'essentials' addon bundle includes Controls (interactive arg editor), Actions (event logging), Docs (MDX documentation), Viewport (responsive testing), and Backgrounds. The a11y addon runs axe-core accessibility checks on every story. Chromatic adds visual regression testing by capturing screenshots and comparing them on each commit."
  },
  {
    question: "What is the 'autodocs' tag in stories?",
    answer: "Adding 'autodocs' to a story's tags array tells Storybook to automatically generate a documentation page for that component. It combines the component's JSDoc/TSDoc comments, prop types (from TypeScript or PropTypes), and all the named stories into a readable API reference page. This is part of the Storybook Docs addon."
  },
  {
    question: "What is the difference between a Vite and Webpack builder?",
    answer: "Storybook 8 defaults to Vite for most frameworks because it's significantly faster — both for initial startup and HMR (hot module replacement). The framework packages like '@storybook/react-vite' and '@storybook/vue3-vite' bundle Vite as the builder. Angular uses its own CLI-based builder. If you have a Webpack-based project, you can still use '@storybook/react-webpack5', but the Vite builder is recommended for greenfield projects."
  },
];
---

<BaseLayout
  title="Storybook Config Generator — Generate main.ts & preview.ts for Storybook 8"
  description="Generate Storybook 8.x configuration files for React, Vue 3, Svelte, Angular, Preact, and Web Components. Choose framework, addons, and TypeScript support, then download main.ts and preview.ts with a story template."
  tool="Storybook config generator, Storybook 8 setup, main.ts generator, preview.ts, Storybook React Vue Svelte Angular"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Storybook Config Generator",
    "url": "https://devplaybook.cc/tools/storybook-config-generator",
    "description": "Generate Storybook 8.x configuration files (main.ts, preview.ts) for React, Vue 3, Svelte, Angular, Preact, and Web Components. Select addons and download your config.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Storybook Config Generator</h1>
  <p class="text-text-muted mb-4">
    Generate <a href="https://storybook.js.org" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">Storybook 8.x</a> configuration files for your framework.
    Select your framework (React, Vue 3, Svelte, Angular, Preact, or Web Components), choose addons,
    toggle TypeScript, and get ready-to-use <code class="font-mono bg-surface px-1 rounded text-sm">.storybook/main.ts</code>,
    <code class="font-mono bg-surface px-1 rounded text-sm">preview.ts</code>, and a story template.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 6 frameworks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 8 addons</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript & JS</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Storybook 8.x</span>
  </div>
  <StorybookConfigGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Storybook Config Generator" relatedTags={['storybook', 'react', 'vue', 'frontend', 'components', 'testing', 'developer-tools']} />
</BaseLayout>
