---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a system prompt and why does it matter?", answer: "A system prompt is a set of instructions given to an LLM before the user conversation begins. It defines the AI's persona, capabilities, constraints, and expected output format. A well-crafted system prompt dramatically improves response quality and consistency — models like GPT-4o and Claude 3.5 Sonnet follow system prompt instructions with high fidelity, making it the primary lever for customizing AI behavior in production." },
  { question: "What sections should a good system prompt include?", answer: "Effective system prompts typically include: (1) Role — who the AI is, (2) Context — background knowledge or domain, (3) Task — what the AI should do, (4) Output Format — how responses should be structured, (5) Constraints — explicit restrictions (what NOT to do), and (6) Tone — communication style. Not all sections are required for every use case, but explicit instructions in each area reduce ambiguous outputs." },
  { question: "How long should a system prompt be?", answer: "There is no universal answer, but a common best practice is to be as concise as possible while being unambiguous. Very short prompts (1-2 sentences) often miss important edge cases. Very long prompts (1000+ tokens) can confuse the model or dilute key instructions. A good system prompt is usually 100-400 tokens. Use bullet points and clear headers for complex instructions — models parse structured text better than prose." },
  { question: "Do system prompts work the same across all models?", answer: "No. Each model follows system prompt instructions with different fidelity. GPT-4o and Claude 3.5 Sonnet are highly instruction-following. Older GPT-3.5 models sometimes ignore complex constraints. Open-source models (Llama, Mistral) vary widely. Always test your system prompt against the specific model and version you are deploying to production, as behavior can change between model updates." },
];
---

<BaseLayout
  title="System Prompt Builder — Build Structured AI System Prompts"
  description="Build structured system prompts with Role, Context, Task, Output Format, Constraints, and Tone sections. Preview and copy your prompt instantly. Free, browser-based."
  tool="system prompt builder, AI system prompt, GPT system prompt generator, prompt engineering tool, LLM prompt template"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "System Prompt Builder",
    "url": "https://devplaybook.cc/tools/system-prompt-builder",
    "description": "Build structured system prompts for GPT-4o, Claude, and other LLMs. Fill in Role, Context, Task, Output Format, Constraints, and Tone to generate a complete system prompt.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">System Prompt Builder</h1>
  <p class="text-text-muted mb-4">
    Build well-structured system prompts for GPT-4o, Claude, Gemini, and other LLMs.
    Fill in each section to generate a clear, professional system prompt.
    Runs entirely in your browser — nothing is sent to a server.
  </p>
  <div class="flex items-center gap-3 mb-8 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Role, Context, Task, Format</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Constraints &amp; Tone control</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live preview as you type</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> One-click copy</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <!-- Left: form inputs -->
    <div class="space-y-4">

      <!-- Role -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <label class="block font-semibold text-sm mb-1" for="sp-role">
          Role <span class="text-text-muted font-normal">— Who is the AI?</span>
        </label>
        <input id="sp-role" type="text"
          placeholder="e.g. You are a senior TypeScript engineer specializing in React and Next.js."
          class="w-full bg-bg border border-border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40" />
      </div>

      <!-- Context -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <label class="block font-semibold text-sm mb-1" for="sp-context">
          Context <span class="text-text-muted font-normal">— Background information</span>
        </label>
        <textarea id="sp-context" rows="3"
          placeholder="e.g. You are working with a Next.js 14 App Router codebase. The team follows strict TypeScript and prefers functional components with hooks."
          class="w-full bg-bg border border-border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40 resize-y"></textarea>
      </div>

      <!-- Task -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <label class="block font-semibold text-sm mb-1" for="sp-task">
          Task <span class="text-text-muted font-normal">— What should the AI do?</span>
        </label>
        <textarea id="sp-task" rows="3"
          placeholder="e.g. Help the user write, review, and debug TypeScript/React code. Explain your reasoning and suggest improvements."
          class="w-full bg-bg border border-border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40 resize-y"></textarea>
      </div>

      <!-- Output Format -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <label class="block font-semibold text-sm mb-1" for="sp-format">
          Output Format <span class="text-text-muted font-normal">— How to respond</span>
        </label>
        <textarea id="sp-format" rows="3"
          placeholder="e.g. Always respond with: 1) A brief explanation, 2) Code snippet in a fenced code block, 3) Any caveats or alternatives."
          class="w-full bg-bg border border-border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40 resize-y"></textarea>
      </div>

      <!-- Constraints -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <label class="block font-semibold text-sm mb-1" for="sp-constraints">
          Constraints <span class="text-text-muted font-normal">— What NOT to do</span>
        </label>
        <textarea id="sp-constraints" rows="3"
          placeholder="e.g. Do not use class components. Do not suggest jQuery or outdated libraries. Do not write code without type annotations."
          class="w-full bg-bg border border-border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40 resize-y"></textarea>
      </div>

      <!-- Tone -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <label class="block font-semibold text-sm mb-2" for="sp-tone">
          Tone <span class="text-text-muted font-normal">— Communication style</span>
        </label>
        <div class="flex flex-wrap gap-2 mb-3" id="tone-presets">
          <button class="tone-btn text-xs px-3 py-1.5 rounded-full border border-border hover:border-primary hover:text-primary transition-colors" data-tone="Professional and concise">Professional</button>
          <button class="tone-btn text-xs px-3 py-1.5 rounded-full border border-border hover:border-primary hover:text-primary transition-colors" data-tone="Casual and friendly, like a helpful colleague">Casual</button>
          <button class="tone-btn text-xs px-3 py-1.5 rounded-full border border-border hover:border-primary hover:text-primary transition-colors" data-tone="Technical and precise, using domain-specific terminology">Technical</button>
          <button class="tone-btn text-xs px-3 py-1.5 rounded-full border border-border hover:border-primary hover:text-primary transition-colors" data-tone="Patient and educational, suitable for beginners">Educational</button>
          <button class="tone-btn text-xs px-3 py-1.5 rounded-full border border-border hover:border-primary hover:text-primary transition-colors" data-tone="Direct and brief, no unnecessary explanations">Direct</button>
        </div>
        <input id="sp-tone" type="text"
          placeholder="e.g. Professional and concise, with clear examples"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40" />
      </div>

      <div class="flex gap-3">
        <button id="sp-example" class="text-sm text-primary hover:underline">Load example</button>
        <button id="sp-clear" class="text-sm text-text-muted hover:text-red-400 transition-colors">Clear all</button>
      </div>
    </div>

    <!-- Right: preview -->
    <div class="flex flex-col">
      <div class="bg-bg-card border border-border rounded-xl p-5 flex-1 flex flex-col">
        <div class="flex items-center justify-between mb-3">
          <span class="font-semibold text-sm">Generated System Prompt</span>
          <div class="flex items-center gap-3">
            <span id="sp-token-count" class="text-xs text-text-muted"></span>
            <button id="sp-copy" class="text-xs text-primary hover:underline">Copy</button>
          </div>
        </div>
        <div id="sp-empty" class="flex-1 flex items-center justify-center text-sm text-text-muted text-center py-8">
          Fill in the fields on the left to generate your system prompt.
        </div>
        <textarea id="sp-output" rows="28" readonly
          class="hidden w-full flex-1 bg-bg border border-border rounded-lg px-3 py-3 text-sm font-mono resize-none focus:outline-none"></textarea>
      </div>
    </div>
  </div>

  <AffiliateSection />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="System Prompt Builder" relatedTags={['llm', 'prompt-engineering', 'gpt', 'claude', 'ai']} />
</BaseLayout>

<script is:inline>
(function () {
  var FIELDS = [
    { id: 'sp-role',        label: 'ROLE',          prefix: 'You are ' },
    { id: 'sp-context',     label: 'CONTEXT',       prefix: '' },
    { id: 'sp-task',        label: 'TASK',          prefix: '' },
    { id: 'sp-format',      label: 'OUTPUT FORMAT', prefix: '' },
    { id: 'sp-constraints', label: 'CONSTRAINTS',   prefix: '' },
    { id: 'sp-tone',        label: 'TONE',          prefix: 'Communicate in a ' },
  ];

  function buildPrompt() {
    var parts = [];
    FIELDS.forEach(function (f) {
      var el = document.getElementById(f.id);
      var val = el.tagName === 'TEXTAREA' ? el.value.trim() : el.value.trim();
      if (!val) return;
      var roleCheck = f.id === 'sp-role' && !val.toLowerCase().startsWith('you ') && !val.toLowerCase().startsWith('you\'');
      var text = roleCheck ? ('You are ' + val) : val;
      parts.push('## ' + f.label + '\n' + text);
    });
    return parts.join('\n\n');
  }

  function estimateTokens(text) {
    return Math.ceil(text.length / 4);
  }

  function update() {
    var prompt = buildPrompt();
    var outputEl = document.getElementById('sp-output');
    var emptyEl = document.getElementById('sp-empty');
    var tokenEl = document.getElementById('sp-token-count');

    if (!prompt) {
      outputEl.classList.add('hidden');
      emptyEl.classList.remove('hidden');
      tokenEl.textContent = '';
    } else {
      outputEl.value = prompt;
      outputEl.classList.remove('hidden');
      emptyEl.classList.add('hidden');
      var tokens = estimateTokens(prompt);
      tokenEl.textContent = '~' + tokens + ' tokens';
    }
  }

  // Listen to all inputs
  FIELDS.forEach(function (f) {
    document.getElementById(f.id).addEventListener('input', update);
  });

  // Tone presets
  document.getElementById('tone-presets').addEventListener('click', function (e) {
    var btn = e.target.closest('.tone-btn');
    if (!btn) return;
    document.getElementById('sp-tone').value = btn.dataset.tone;
    document.querySelectorAll('.tone-btn').forEach(function (b) {
      b.classList.remove('border-primary', 'text-primary');
    });
    btn.classList.add('border-primary', 'text-primary');
    update();
  });

  // Copy
  document.getElementById('sp-copy').addEventListener('click', function () {
    var val = document.getElementById('sp-output').value;
    if (!val) return;
    navigator.clipboard && navigator.clipboard.writeText(val);
    this.textContent = 'Copied!';
    var btn = this;
    setTimeout(function () { btn.textContent = 'Copy'; }, 2000);
  });

  // Example
  var EXAMPLE = {
    'sp-role': 'a senior full-stack engineer specializing in TypeScript, React, and Node.js',
    'sp-context': 'You are working with a Next.js 14 App Router codebase. The team uses TypeScript strictly, Tailwind CSS for styling, and Prisma for database access. All components should be React Server Components by default unless client interactivity is required.',
    'sp-task': 'Help the user write, review, and refactor TypeScript and React code. Identify bugs, suggest performance improvements, and explain trade-offs between different approaches.',
    'sp-format': 'Structure your responses as:\n1. Brief explanation (2-3 sentences max)\n2. Code snippet in a fenced code block with language tag\n3. Key caveats or alternatives (if any)',
    'sp-constraints': 'Do not use class components. Do not suggest jQuery or non-TypeScript libraries without type definitions. Never write code without proper TypeScript type annotations. Do not over-explain basic concepts.',
    'sp-tone': 'Technical and precise, like a senior peer reviewer',
  };

  document.getElementById('sp-example').addEventListener('click', function () {
    Object.keys(EXAMPLE).forEach(function (id) {
      var el = document.getElementById(id);
      if (el) el.value = EXAMPLE[id];
    });
    update();
  });

  document.getElementById('sp-clear').addEventListener('click', function () {
    FIELDS.forEach(function (f) {
      var el = document.getElementById(f.id);
      if (el) el.value = '';
    });
    document.querySelectorAll('.tone-btn').forEach(function (b) {
      b.classList.remove('border-primary', 'text-primary');
    });
    update();
  });

  update();
})();
</script>
