---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="AI Error Explainer — Pro Tool | DevPlaybook"
  description="Paste any stack trace or error message and get a plain-English explanation plus step-by-step fix instructions. Works for JS, Python, Go, Java, and more."
  tool="AI Error Explainer, Stack Trace Debugger, Error Analyzer"
>
  <!-- Pro Gate loading -->
  <div id="pro-loading" class="max-w-2xl mx-auto py-16 text-center text-text-muted">
    Checking your account...
  </div>

  <!-- Not Pro: Upgrade Gate -->
  <div id="pro-gate" class="hidden max-w-2xl mx-auto py-16 px-4 text-center">
    <div class="text-6xl mb-6">🔍</div>
    <h1 class="text-3xl font-bold mb-3">AI Error Explainer is a <span class="text-primary">Pro</span> feature</h1>
    <p class="text-text-muted text-lg mb-8">
      Stop Googling cryptic stack traces. Get a plain-English explanation and exact fix steps in seconds.
    </p>
    <div class="bg-bg-card border border-border rounded-2xl p-8 mb-8 text-left">
      <h2 class="font-semibold mb-4">Pro includes:</h2>
      <ul class="space-y-2 text-text-muted text-sm">
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> AI Error Explainer (this tool)</li>
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> AI Code Review</li>
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> AI Test Generator</li>
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> AI Doc Generator, SQL Builder & more</li>
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> 7-day free trial, cancel anytime</li>
      </ul>
    </div>
    <a href="/pricing" class="inline-block bg-primary hover:bg-primary-dark text-white font-bold px-10 py-4 rounded-xl transition-colors text-lg">
      Start Free Trial — $9/mo
    </a>
    <p class="text-text-muted text-sm mt-4">
      Already subscribed? <a href="/signin" class="text-primary hover:underline">Sign in</a>
    </p>
  </div>

  <!-- Pro Tool UI -->
  <div id="pro-tool" class="hidden">
    <div class="flex items-center gap-3 mb-2">
      <h1 class="text-3xl font-bold">AI Error Explainer</h1>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-primary/20 text-primary border border-primary/30">PRO</span>
    </div>
    <p class="text-text-muted mb-8">Paste any error message or stack trace. Get a plain-English explanation and a step-by-step fix.</p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Input panel -->
      <div class="flex flex-col gap-4">
        <div>
          <label class="block text-sm font-medium mb-2" for="error-input">Error / Stack Trace</label>
          <select id="language-select" class="w-full mb-2 px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-primary transition-colors">
            <option value="auto-detect">Auto-detect language / runtime</option>
            <option value="JavaScript / Node.js">JavaScript / Node.js</option>
            <option value="TypeScript">TypeScript</option>
            <option value="Python">Python</option>
            <option value="Go">Go</option>
            <option value="Rust">Rust</option>
            <option value="Java">Java</option>
            <option value="C#">C#</option>
            <option value="PHP">PHP</option>
            <option value="Ruby">Ruby</option>
            <option value="Bash / Shell">Bash / Shell</option>
            <option value="SQL">SQL / Database</option>
            <option value="Docker">Docker / Container</option>
          </select>
          <textarea
            id="error-input"
            rows="14"
            placeholder="Paste your error message, exception, or stack trace here..."
            class="w-full px-4 py-3 rounded-xl bg-bg border border-border text-text placeholder:text-text-muted focus:outline-none focus:border-primary transition-colors font-mono text-sm resize-y"
          ></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium mb-2" for="context-input">Context (optional)</label>
          <textarea
            id="context-input"
            rows="3"
            placeholder="What were you doing when this error occurred? Any relevant context..."
            class="w-full px-4 py-3 rounded-xl bg-bg border border-border text-text placeholder:text-text-muted focus:outline-none focus:border-primary transition-colors text-sm resize-y"
          ></textarea>
        </div>
        <button
          id="explain-btn"
          class="w-full py-3 px-6 rounded-xl bg-primary hover:bg-primary-dark text-white font-bold transition-colors duration-200 disabled:opacity-50"
        >
          Explain Error
        </button>
        <p id="explain-error" class="text-xs text-red-400 hidden"></p>
      </div>

      <!-- Output panel -->
      <div class="flex flex-col gap-4">
        <div class="flex items-center justify-between">
          <label class="block text-sm font-medium">Explanation & Fix</label>
          <button id="copy-btn" class="text-xs text-text-muted hover:text-primary transition-colors hidden">Copy</button>
        </div>
        <div
          id="output-placeholder"
          class="flex-1 min-h-[420px] rounded-xl bg-bg border border-border flex items-center justify-center text-text-muted text-sm"
        >
          Your explanation will appear here
        </div>
        <div
          id="output-loading"
          class="hidden flex-1 min-h-[420px] rounded-xl bg-bg border border-border flex items-center justify-center text-text-muted text-sm"
        >
          <div class="text-center">
            <div class="animate-pulse text-3xl mb-3">🔍</div>
            <p>Analyzing your error...</p>
          </div>
        </div>
        <div
          id="output-content"
          class="hidden flex-1 min-h-[420px] rounded-xl bg-bg border border-border p-5 text-sm overflow-y-auto prose prose-invert prose-sm max-w-none"
        ></div>
      </div>
    </div>

    <div class="mt-8 p-4 bg-bg-card border border-border rounded-xl text-xs text-text-muted">
      <strong>Pro tip:</strong> Include the full stack trace, not just the error message line. The AI can pinpoint the exact call in your code that caused the issue.
    </div>
  </div>

  <ToolPageCta currentTool="AI Error Explainer" relatedTags={['ai', 'debugging', 'development']} />
</BaseLayout>

<script is:inline>
  function renderMarkdown(md) {
    return md
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
      .replace(/^### (.+)$/gm, '<h3 class="font-semibold text-base mt-4 mb-1">$1</h3>')
      .replace(/^## (.+)$/gm, '<h2 class="font-bold text-lg mt-5 mb-2">$1</h2>')
      .replace(/^# (.+)$/gm, '<h1 class="font-bold text-xl mt-5 mb-2">$1</h1>')
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/`([^`]+)`/g, '<code class="bg-bg-card px-1 rounded text-primary font-mono">$1</code>')
      .replace(/^```[\w]*\n([\s\S]*?)```/gm, '<pre class="bg-bg-card border border-border rounded-lg p-3 overflow-auto font-mono text-xs my-2"><code>$1</code></pre>')
      .replace(/^[-*] (.+)$/gm, '<li class="ml-4 list-disc">$1</li>')
      .replace(/(<li[^>]*>.*<\/li>\n?)+/g, (m) => `<ul class="space-y-1 my-2">${m}</ul>`)
      .replace(/\n\n/g, '</p><p class="mb-2">')
      .replace(/^(?!<[hul])(.+)$/gm, (m) => m.trim() ? m : '')
      .trim();
  }

  async function init() {
    let session;
    try {
      const res = await fetch('/api/auth/session');
      session = await res.json();
    } catch {
      session = { loggedIn: false };
    }

    document.getElementById('pro-loading').classList.add('hidden');

    if (!session.loggedIn || !session.isPro) {
      document.getElementById('pro-gate').classList.remove('hidden');
      return;
    }

    document.getElementById('pro-tool').classList.remove('hidden');

    const btn = document.getElementById('explain-btn');
    const errorInput = document.getElementById('error-input');
    const contextInput = document.getElementById('context-input');
    const langSelect = document.getElementById('language-select');
    const errorMsg = document.getElementById('explain-error');
    const placeholder = document.getElementById('output-placeholder');
    const loading = document.getElementById('output-loading');
    const outputContent = document.getElementById('output-content');
    const copyBtn = document.getElementById('copy-btn');

    let lastExplanation = '';

    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(lastExplanation).then(() => {
        copyBtn.textContent = 'Copied!';
        setTimeout(() => { copyBtn.textContent = 'Copy'; }, 2000);
      });
    });

    btn.addEventListener('click', async () => {
      const error = errorInput.value.trim();
      if (!error) { errorMsg.textContent = 'Please paste an error or stack trace first.'; errorMsg.classList.remove('hidden'); return; }
      errorMsg.classList.add('hidden');

      btn.disabled = true;
      btn.textContent = 'Analyzing...';
      placeholder.classList.add('hidden');
      outputContent.classList.add('hidden');
      loading.classList.remove('hidden');
      copyBtn.classList.add('hidden');

      try {
        const res = await fetch('/api/ai/error-explainer', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ error, language: langSelect.value, context: contextInput.value.trim() }),
        });
        const data = await res.json();

        if (!res.ok) {
          if (res.status === 403) {
            errorMsg.textContent = 'Pro subscription required. Refresh to check your status.';
          } else if (res.status === 401) {
            errorMsg.textContent = 'Session expired — please sign in again.';
          } else {
            errorMsg.textContent = data.error || 'Something went wrong.';
          }
          errorMsg.classList.remove('hidden');
          loading.classList.add('hidden');
          placeholder.classList.remove('hidden');
        } else {
          lastExplanation = data.explanation;
          outputContent.innerHTML = '<p class="mb-2">' + renderMarkdown(data.explanation) + '</p>';
          loading.classList.add('hidden');
          outputContent.classList.remove('hidden');
          copyBtn.classList.remove('hidden');
        }
      } catch {
        errorMsg.textContent = 'Network error — please try again.';
        errorMsg.classList.remove('hidden');
        loading.classList.add('hidden');
        placeholder.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Explain Error';
      }
    });
  }

  init();
</script>
