---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DeveloperPortfolioChecklist from '../../components/DeveloperPortfolioChecklist.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Developer Portfolio Checklist — 40+ Items to Land Your Next Job"
  description="Interactive checklist of 40+ must-have items for a software engineer portfolio that gets you hired. Covers foundation, projects, GitHub, SEO, skills, and contact. Track your progress."
  tool="Developer Portfolio Checklist, Software Engineer Portfolio, Portfolio Review, GitHub Portfolio, Developer Job Search"
>
  <h1 class="text-3xl font-bold mb-2">Developer Portfolio Checklist</h1>
  <p class="text-text-muted mb-8">40+ actionable items to build a software engineer portfolio that gets noticed. From custom domains to GitHub optimization to SEO. Check items off as you complete them — progress is saved in your browser.</p>
  <DeveloperPortfolioChecklist client:only="preact" />
  <ToolPageCta currentTool="Developer Portfolio Checklist" relatedTags={['career', 'portfolio', 'job', 'github']} />
</BaseLayout>
