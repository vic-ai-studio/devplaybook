---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RegexTesterPcre from '../../components/RegexTesterPcre.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What languages are supported?",
    answer: "This tool supports JavaScript (RegExp), Python (re module), Go (regexp/RE2), and Ruby (Oniguruma). Each language has its own flag set and syntax conventions. The tool uses the browser's JavaScript engine for matching, but generates code snippets in the selected language and adapts named group syntax (?P<name> for Python/Go → (?<name> for JS).",
  },
  {
    question: "What are named capture groups and how do they differ between languages?",
    answer: "Named groups let you reference captures by name instead of number. JavaScript uses (?<name>...) and $<name> in replacements. Python uses (?P<name>...) and \\g<name>. Go uses (?P<name>...) and re.SubexpNames(). Ruby uses (?<name>...) and m[:name]. This tool normalizes all formats and shows named group values in the output.",
  },
  {
    question: "Does Go's RE2 support lookahead or lookbehind?",
    answer: "No. Go uses the RE2 engine which deliberately excludes lookahead (?=...), negative lookahead (?!...), lookbehind (?<=...), and negative lookbehind (?<!...) because they can't be matched in linear time. If your pattern uses these features, it won't work in Go. The Lookahead preset will show matches in JS/Python/Ruby but is incompatible with Go.",
  },
  {
    question: "What does the 's' (dot-all) flag do?",
    answer: "By default, the dot (.) in a regex matches any character except newline (\\n). With the s flag (called DOTALL in Python or (?s) in Go), dot also matches newline characters. This is essential for patterns that span multiple lines. JavaScript added the s flag in ES2018.",
  },
  {
    question: "How does the replace mode work?",
    answer: "Replace mode runs your pattern against all test lines and applies the replacement string. Use $1, $2 for numbered groups and $<name> (JS/Ruby) or \\g<name> (Python) for named groups. The output shows the full replaced string. This is equivalent to String.prototype.replace() in JS, re.sub() in Python, gsub() in Ruby, or regexp.ReplaceAllString() in Go.",
  },
  {
    question: "What is the 'x' flag (extended mode) in Python and Ruby?",
    answer: "The x flag allows whitespace and comments inside the pattern, making complex regex readable. Whitespace is ignored (use \\s or [ ] for literal spaces), and # starts a comment to end of line. This is only available in Python and Ruby — JavaScript does not support it natively.",
  },
];
---

<BaseLayout
  title="Regex Tester PCRE — Multi-Language JavaScript, Python, Go, Ruby"
  description="Test regex patterns across JavaScript, Python, Go, and Ruby. See highlighted matches, named capture groups, and replacement output. Generate code snippets instantly. Free, no backend."
  tool="Regex Tester, PCRE Tester, Multi-Language Regex, Named Groups, Capture Groups, Regex Replace"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Regex Tester — Multi-Language (JS / Python / Go / Ruby)</h1>
  <p class="text-text-muted mb-4">Test regular expressions against multi-line text with live highlighted matches. Switch between JavaScript, Python, Go (RE2), and Ruby to see syntax differences. Supports named capture groups, replace mode, and instant code snippet generation.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> JS / Python / Go / Ruby</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Named + numbered groups</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Replace mode</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Code snippet generation</span>
  </div>
  <RegexTesterPcre client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Regex Tester PCRE Multi-Language" relatedTags={['regex', 'javascript', 'python', 'go', 'ruby', 'pcre', 'string', 'testing']} />
</BaseLayout>
