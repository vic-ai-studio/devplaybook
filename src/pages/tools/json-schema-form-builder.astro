---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonSchemaFormBuilder from '../../components/JsonSchemaFormBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a JSON Schema Form Builder?", answer: "A JSON Schema Form Builder takes a JSON Schema definition and renders a live HTML form based on the schema's structure. You define your form using the JSON Schema standard (fields, types, validations) and the tool instantly generates and validates a corresponding UI form. This is useful for rapid prototyping, API documentation, and testing form behavior against your schema." },
  { question: "What JSON Schema features does this tool support?", answer: "This tool supports: string, number, integer, boolean, enum types; required fields; format validation (email, URL, date); string constraints (minLength, maxLength, pattern); number constraints (minimum, maximum); titles and descriptions; and nested object properties (one level). Arrays are displayed as text fields in this prototype view." },
  { question: "What is the difference between type: integer and type: number in JSON Schema?", answer: "In JSON Schema, integer means a whole number with no fractional part (e.g. 42), while number includes both integers and floating-point values (e.g. 3.14). Use integer for fields like age, count, or quantity. Use number for prices, coordinates, or measurements. Both support minimum and maximum constraints." },
  { question: "How does JSON Schema validation work?", answer: "JSON Schema validation checks that a value conforms to the schema's constraints: required fields are present, types are correct, strings match minLength/maxLength/pattern/format, numbers are within minimum/maximum bounds, and enum values are from the allowed list. This tool implements a browser-side subset of JSON Schema Draft-07 validation." },
  { question: "Can I use this to generate forms for my API?", answer: "Yes — JSON Schema is the industry standard for describing API request/response bodies (used in OpenAPI/Swagger specs). You can paste your API's request body schema here to instantly see what form it would render, test validation logic, and verify field constraints before writing frontend code." },
];
---

<BaseLayout
  title="JSON Schema Form Builder — Live Form from JSON Schema"
  description="Paste any JSON Schema and instantly render a live HTML form with real-time validation. Supports type, required, enum, format, minLength, maxLength, minimum, maximum. Split view editor. Free, runs in browser."
  tool="JSON Schema form builder, JSON Schema to form, JSON Schema validator, live form generator, JSON Schema Draft-07"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "JSON Schema Form Builder",
    "url": "https://devplaybook.cc/tools/json-schema-form-builder",
    "description": "Paste a JSON Schema and get a live rendered HTML form with real-time validation. Supports Draft-07 constraints: required, enum, format, minLength, maxLength, minimum, maximum.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">JSON Schema Form Builder</h1>
  <p class="text-text-muted mb-4">Paste a JSON Schema on the left and see a live HTML form rendered on the right. Edit the schema and the form updates instantly. Validates required fields, types, formats, and constraints in real-time. Supports JSON Schema Draft-07.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Split view editor + live form</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Real-time schema validation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Export schema as JSON</span>
  </div>
  <JsonSchemaFormBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="JSON Schema Form Builder" relatedTags={['json', 'schema', 'validation', 'api', 'forms', 'typescript']} />
</BaseLayout>
