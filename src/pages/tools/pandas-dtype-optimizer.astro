const faq = [
  {
    question: "How much memory can dtype optimization actually save in Pandas?",
    answer: "In practice, dtype optimization routinely reduces DataFrame memory by 50–80%. The biggest wins come from converting int64 to int8/int16/int32 (up to 8x reduction), float64 to float32 (2x), and object columns with low cardinality to category (often 10–50x). A DataFrame that occupies 2 GB can shrink to under 500 MB with careful dtype tuning, allowing you to process it in memory without chunking."
  },
  {
    question: "What is the difference between pd.to_numeric with downcast and astype?",
    answer: "pd.to_numeric(series, downcast='integer') automatically finds the smallest integer type that can hold the data without overflow — it scans the actual values and picks int8, int16, int32, or int64. astype() is explicit — you specify the exact dtype and Pandas will cast unconditionally, which can silently overflow if your values exceed the target type's range. Use downcast for safe automatic optimization and astype when you have already verified the value range."
  },
  {
    question: "When should I use the category dtype vs string/object?",
    answer: "Use category when a column has low cardinality — typically fewer than 5–10% unique values relative to total rows. Examples: country, status, product_type, day_of_week. The category dtype stores values as integer codes internally and keeps a small lookup table, so 1 million rows of 'Monday'/'Tuesday'/... becomes 1 million int8 codes + 7 strings instead of 1 million 64-bit pointers. Avoid category for high-cardinality columns like UUIDs or free-text — it will use more memory than object."
  },
  {
    question: "How do I check DataFrame memory usage accurately?",
    answer: "Use df.memory_usage(deep=True).sum() to get accurate memory in bytes including the actual string data in object columns. The default df.memory_usage() without deep=True only measures the pointer size for object columns (8 bytes per element regardless of string length), which dramatically underestimates real memory. Divide by 1024**2 to convert to MB: df.memory_usage(deep=True).sum() / 1024**2. You can also call df.info(memory_usage='deep') for a per-column breakdown."
  },
  {
    question: "What are sparse arrays in Pandas and when are they useful?",
    answer: "Sparse arrays store only non-zero (or non-null) values, skipping storage for the fill value. They are ideal for datasets with many zeros or NaNs — for example, a user-item interaction matrix or a one-hot encoded feature matrix. Convert with df['col'].astype(pd.SparseDtype('float32', fill_value=0)). The compression ratio equals the density of non-fill values. A column that is 95% zeros will use roughly 5% of the memory of a dense array. Note that most Pandas operations work on sparse arrays but some functions require densification first."
  },
  {
    question: "How do I optimize memory when reading large CSV files?",
    answer: "Pass the dtype parameter to pd.read_csv() with a dict mapping column names to types: pd.read_csv('data.csv', dtype={'age': 'int8', 'score': 'float32', 'status': 'category'}). For files larger than available RAM, use chunksize to process in batches: for chunk in pd.read_csv('data.csv', chunksize=100_000): process(chunk). Combine both: specify dtypes in the chunked reader to minimize peak memory per chunk. Also use usecols to load only needed columns and parse_dates to avoid loading dates as strings."
  }
];

const memoryCheckExample = `import pandas as pd
import numpy as np

# Create a sample DataFrame
df = pd.DataFrame({
    'user_id': np.random.randint(0, 1_000_000, size=1_000_000),
    'age': np.random.randint(18, 90, size=1_000_000),
    'score': np.random.uniform(0, 100, size=1_000_000),
    'country': np.random.choice(['US', 'UK', 'DE', 'FR', 'JP'], size=1_000_000),
    'active': np.random.choice([True, False], size=1_000_000),
})

# Check memory usage (inaccurate for object columns)
print(df.memory_usage())

# Accurate memory check (includes actual string data)
total_mb = df.memory_usage(deep=True).sum() / 1024**2
print(f"Total memory: {total_mb:.2f} MB")

# Per-column breakdown
print(df.memory_usage(deep=True) / 1024**2)

# Full info with types and memory
df.info(memory_usage='deep')`;

const downcastingExample = `import pandas as pd
import numpy as np

def optimize_dtypes(df: pd.DataFrame) -> pd.DataFrame:
    """Automatically downcast numeric columns to save memory."""
    df = df.copy()

    for col in df.select_dtypes(include=['int64']).columns:
        df[col] = pd.to_numeric(df[col], downcast='integer')

    for col in df.select_dtypes(include=['float64']).columns:
        df[col] = pd.to_numeric(df[col], downcast='float')

    return df

# Before
df_original = pd.DataFrame({
    'user_id': np.random.randint(0, 1000, size=500_000).astype('int64'),
    'age': np.random.randint(18, 90, size=500_000).astype('int64'),
    'score': np.random.uniform(0, 1, size=500_000).astype('float64'),
})

before_mb = df_original.memory_usage(deep=True).sum() / 1024**2
print(f"Before: {before_mb:.2f} MB")
print(df_original.dtypes)

# After
df_optimized = optimize_dtypes(df_original)
after_mb = df_optimized.memory_usage(deep=True).sum() / 1024**2
print(f"After:  {after_mb:.2f} MB")
print(df_optimized.dtypes)
print(f"Reduction: {(1 - after_mb/before_mb)*100:.1f}%")`;

const categoryExample = `import pandas as pd
import numpy as np

# High-cardinality column: bad candidate for category
df = pd.DataFrame({
    'user_id': [f'user_{i}' for i in range(100_000)],   # 100k unique -> stay object
    'country': np.random.choice(['US', 'UK', 'DE', 'FR'], 100_000),  # 4 unique -> category
    'status':  np.random.choice(['active', 'inactive', 'pending'], 100_000),  # 3 -> category
    'day':     np.random.choice(['Mon','Tue','Wed','Thu','Fri'], 100_000),     # 5 -> category
})

print("Before:")
print(df.memory_usage(deep=True) / 1024)  # KB per column

# Convert low-cardinality columns
for col in ['country', 'status', 'day']:
    n_unique = df[col].nunique()
    n_total = len(df[col])
    if n_unique / n_total < 0.05:  # less than 5% unique
        df[col] = df[col].astype('category')

print("\\nAfter:")
print(df.memory_usage(deep=True) / 1024)

# Access category codes and categories
print(df['country'].cat.categories)
print(df['country'].cat.codes.head())`;

const chunkedReaderExample = `import pandas as pd
from pathlib import Path

def read_optimized_csv(filepath: str, chunksize: int = 100_000) -> pd.DataFrame:
    """Read large CSV in chunks with dtype optimization."""
    dtype_map = {
        'user_id':   'int32',
        'age':       'int8',
        'score':     'float32',
        'country':   'category',
        'status':    'category',
        'active':    'bool',
    }

    chunks = []
    for chunk in pd.read_csv(
        filepath,
        dtype=dtype_map,
        usecols=list(dtype_map.keys()),
        chunksize=chunksize,
        parse_dates=['created_at'],
    ):
        chunks.append(chunk)

    df = pd.concat(chunks, ignore_index=True)
    return df

# For very large files: process chunk by chunk without concat
def process_large_csv(filepath: str) -> dict:
    results = {'total_rows': 0, 'mean_score': 0.0}
    score_sum = 0.0

    for chunk in pd.read_csv(filepath, dtype={'score': 'float32'}, chunksize=100_000):
        results['total_rows'] += len(chunk)
        score_sum += chunk['score'].sum()

    results['mean_score'] = score_sum / results['total_rows']
    return results`;
