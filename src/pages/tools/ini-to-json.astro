---
import BaseLayout from '../../layouts/BaseLayout.astro';
import IniToJson from '../../components/IniToJson.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is INI format?", answer: "INI is a simple configuration file format used by many applications (Python's configparser, Windows .ini files, PHP, Git config, etc.). It organizes settings into named sections with key=value pairs, and supports ; or # line comments." },
  { question: "Does the converter support sections?", answer: "Yes. Sections like [database] become nested JSON objects. Keys outside any section are placed at the root level of the JSON output." },
  { question: "Are booleans and numbers coerced?", answer: "Yes. Values like true, false, yes, no, on, off become JSON booleans. Integer and float values are converted to JSON numbers. Quoted strings remain strings." },
  { question: "What happens with multi-line values?", answer: "Values ending with a backslash (\\) are joined with the next line — standard INI multi-line syntax used by some parsers like Python's configparser." },
  { question: "Are inline comments supported?", answer: "Yes. Inline comments after a value (separated by whitespace) using ; or # are stripped during parsing, so only the actual value is preserved." },
];
---

<BaseLayout
  title="INI to JSON Converter — Free Online Tool"
  description="Convert INI config files to JSON online. Supports sections, comments, boolean and number coercion, multi-line values. Free, client-side — nothing sent to any server."
  tool="INI to JSON, INI converter, config file converter, ini parser, INI to JSON online, configparser JSON"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">INI to JSON Converter</h1>
  <p class="text-text-muted mb-4">Paste your INI configuration file and convert it to JSON instantly. Supports sections, comments, multi-line values, and automatic type coercion for booleans and numbers. Runs entirely in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Download as .json</span>
  </div>
  <IniToJson client:only="preact" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more free developer tools?</p>
    <a href="/tools" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Browse All Free Tools →</a>
  </div>
  <ToolPageCta currentTool="INI to JSON Converter" relatedTags={['ini', 'json', 'converter', 'config', 'data']} />
</BaseLayout>
