---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tools = [
  { name: 'HTTP Headers Inspector', desc: 'Inspect HTTP response headers for any URL. See security headers, cache directives, CORS settings with plain-English explanations.', href: '/tools/http-headers-inspector', icon: '📡' },
  { name: 'Color Picker & Palette', desc: 'Pick a color and instantly get HEX, RGB, HSL values. WCAG contrast checker and 5-shade palette generator.', href: '/tools/color-picker', icon: '🎨' },
  { name: 'Image to Base64', desc: 'Convert PNG, JPG, SVG, WebP images to Base64. Get the data URL or CSS background-image value. Drag-and-drop.', href: '/tools/image-to-base64', icon: '🖼️' },
  { name: 'Unix Timestamp Converter', desc: 'Convert between Unix timestamps and human-readable dates. Live clock, timezone support, and instant copy.', href: '/tools/unix-timestamp', icon: '⏱️' },
  { name: 'IP Geolocation Lookup', desc: 'Look up the geographic location of any IP address — city, country, timezone, ISP, and coordinates. Or detect your own IP.', href: '/tools/ip-geolocation', icon: '🌍' },
  { name: 'QR Code Generator', desc: 'Generate QR codes for URLs, WiFi, email, phone, and more. Custom colors, error correction levels, PNG download.', href: '/tools/qr-code-generator', icon: '📱' },
  { name: 'DNS Lookup Tool', desc: 'Look up A, AAAA, CNAME, MX, TXT, NS, and PTR records for any domain using Cloudflare DNS-over-HTTPS.', href: '/tools/dns-lookup', icon: '🌍' },
  { name: 'Cron Expression Generator', desc: 'Build and validate cron expressions visually. See next 5 run times in plain English with common presets.', href: '/tools/cron-generator', icon: '⏰' },
  { name: 'Hash Generator', desc: 'Generate MD5, SHA-1, SHA-256, and SHA-512 hashes instantly. All hashing runs in your browser.', href: '/tools/hash-generator', icon: '🔒' },
  { name: 'Base64 Encoder Pro', desc: 'Advanced Base64 encoder/decoder supporting text, images, and any file. URL-safe mode, data URI generation. Runs 100% in your browser.', href: '/tools/base64-encoder', icon: '🔤' },
  { name: 'UUID Generator', desc: 'Generate UUID v1, v4, and v5 in bulk. Multiple formats: standard, uppercase, no-hyphens, braces.', href: '/tools/uuid-generator', icon: '🔑' },
  { name: 'Password Generator', desc: 'Generate cryptographically secure random passwords with custom length and character sets.', href: '/tools/password-generator', icon: '🔑' },
  { name: 'JWT Decoder', desc: 'Decode JWT tokens — inspect header, payload, and claims. Check expiry and iat/sub/iss fields instantly.', href: '/tools/jwt-decoder', icon: '🔐' },
  { name: 'Color Format Converter', desc: 'Convert colors between HEX, RGB, and HSL formats instantly. Visual picker, presets, and CSS snippet output.', href: '/tools/color-converter', icon: '🔄' },
];
---

<BaseLayout
  title="Free Developer Utility Tools — devplaybook.cc"
  description="12 free developer utilities: HTTP headers inspector, color picker, image to Base64, timestamp converter, IP lookup, QR code generator, DNS lookup, hash generator, and more."
  tool="Developer Utilities, HTTP Headers, Color Picker, QR Code, IP Lookup, Hash Generator, Timestamp Converter"
>
  <div class="mb-8">
    <nav class="text-sm text-text-muted mb-4">
      <a href="/tools" class="hover:text-primary transition-colors">All Tools</a>
      <span class="mx-2">→</span>
      <span class="text-text">Developer Utilities</span>
    </nav>
    <h1 class="text-4xl font-bold mb-3">Developer <span class="text-primary">Utilities</span></h1>
    <p class="text-text-muted text-lg max-w-2xl">Free utility tools for everyday developer tasks. HTTP inspection, color palettes, QR codes, IP lookup, hashing, timestamps, and more — all client-side.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mb-12">
    {tools.map(tool => (
      <a href={tool.href} class="block bg-bg-card rounded-xl p-6 border border-border hover:border-primary transition-colors group">
        <div class="text-3xl mb-3">{tool.icon}</div>
        <h2 class="text-lg font-semibold mb-2 group-hover:text-primary transition-colors">{tool.name}</h2>
        <p class="text-text-muted text-sm">{tool.desc}</p>
      </a>
    ))}
  </div>

  <div class="flex flex-wrap gap-3 justify-center">
    <a href="/tools/text" class="bg-bg-card border border-border hover:border-primary px-4 py-2 rounded-lg text-sm transition-colors">📝 Text Tools</a>
    <a href="/tools/code" class="bg-bg-card border border-border hover:border-primary px-4 py-2 rounded-lg text-sm transition-colors">💻 Code Tools</a>
    <a href="/tools" class="bg-bg-card border border-border hover:border-primary px-4 py-2 rounded-lg text-sm transition-colors">🛠️ All Tools</a>
  </div>
</BaseLayout>
