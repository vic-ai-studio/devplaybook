---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrpcRouterGenerator from '../../components/TrpcRouterGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is tRPC?", answer: "tRPC is a TypeScript library that lets you build fully type-safe APIs without a schema or code generation step. You define your server procedures in TypeScript, and your client gets automatic type inference — including input validation, return types, and error types — all end-to-end." },
  { question: "What is a tRPC router?", answer: "A router is a collection of procedures (think: API endpoints) grouped together. You compose routers hierarchically: an appRouter might include a userRouter, postRouter, and authRouter. Each sub-router is created with router() and combined at the top level." },
  { question: "What's the difference between query and mutation in tRPC?", answer: "Queries are for reading data — they use GET semantics, support caching, and can be called with useQuery() on the client. Mutations are for writes and side effects — they're called imperatively with useMutation().mutate() and are never cached. Use query for fetching, mutation for creating/updating/deleting." },
  { question: "What is Zod and why does tRPC use it?", answer: "Zod is a TypeScript-first schema validation library. tRPC uses Zod schemas for .input() and .output() validation — input schemas automatically validate incoming data (throwing a TRPCError on invalid input), and output schemas validate return types. The schemas also drive full TypeScript inference on both server and client." },
  { question: "How do I add authentication to tRPC procedures?", answer: "Create a protected procedure by wrapping the base procedure with middleware that checks auth context. In the generated code, use protectedProcedure instead of publicProcedure. Your middleware should throw a TRPCError({ code: 'UNAUTHORIZED' }) if the session is missing." },
  { question: "What is a tRPC server-side caller?", answer: "A caller lets you call tRPC procedures directly on the server — useful in getServerSideProps, API routes, or server components. Create one with createCallerFactory(appRouter)(ctx) and call procedures like regular async functions without HTTP overhead." },
];
---

<BaseLayout
  title="tRPC Router Generator — Type-Safe API Boilerplate"
  description="Generate tRPC v11 router boilerplate instantly. Add query, mutation, and subscription procedures with Zod input/output schemas. Get router definition, client hooks, and server-side caller code."
  tool="tRPC Router Generator, tRPC v11, Type-Safe API, tRPC Boilerplate"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">tRPC Router Generator</h1>
  <p class="text-text-muted mb-4">
    Generate tRPC v11 router boilerplate with Zod validation. Add procedures, configure input/output schemas,
    and get ready-to-use router definitions, React client hooks, and server-side caller code.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <TrpcRouterGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="tRPC Router Generator" relatedTags={['trpc', 'typescript', 'api', 'fullstack', 'zod', 'type-safe']} />
</BaseLayout>
