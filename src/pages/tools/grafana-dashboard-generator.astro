---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Grafana panel JSON?", answer: "Every Grafana dashboard is stored as JSON. Each panel inside the dashboard has its own JSON object that defines the panel type, data source, queries, display options, thresholds, and unit formatting. You can export/import panels using this JSON to version-control your dashboards." },
  { question: "What data sources does Grafana support?", answer: "Grafana supports 50+ data sources including Prometheus (time-series metrics), Loki (logs), Tempo (traces), InfluxDB, Graphite, Elasticsearch, MySQL, PostgreSQL, and cloud sources (CloudWatch, Azure Monitor, Google Cloud Monitoring). Each data source has its own query language." },
  { question: "What panel types are available?", answer: "Core panel types: Time series (line/bar charts over time), Stat (single value with sparkline), Gauge (circular or bar gauge), Bar chart (categorical comparison), Table (data grid), Logs (Loki log streams), Heatmap, Histogram, Candlestick, and XY Chart. Plugins add more types." },
  { question: "How do Grafana thresholds work?", answer: "Thresholds define color bands for stat, gauge, and bar chart panels. You define a base color and then add threshold values with their colors. For example: base green (0+), yellow at 80, red at 95. Values below the first threshold get the base color; above each threshold they switch to the corresponding color." },
  { question: "How do I use this generated JSON in Grafana?", answer: "In your Grafana dashboard, click the + Add panel button or Edit an existing panel. Switch to the JSON view tab (the curly braces icon). Paste the generated panel JSON. Click Apply. The panel will populate with your configuration. You may need to adjust data source references." },
];
---

<BaseLayout
  title="Grafana Dashboard Template Generator — Generate Panel JSON Configs"
  description="Generate Grafana panel JSON configurations visually. Choose panel type, data source, metrics, thresholds, and units. Get ready-to-paste panel JSON for your Grafana dashboards."
  tool="Grafana Dashboard Generator, Grafana Panel JSON, Grafana Config Generator, Grafana Template"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Grafana Dashboard Template Generator</h1>
  <p class="text-text-muted mb-4">Configure a Grafana panel visually and generate ready-to-use panel JSON. Paste the output directly into Grafana's JSON panel editor.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 6 panel types supported</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Prometheus / Loki / Tempo / InfluxDB</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Thresholds & unit formatting</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-to-clipboard output</span>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="text-base font-semibold mb-4">Panel Configuration</h2>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium mb-1.5">Dashboard Title</label>
          <input id="dash-title" type="text" value="Service Health Dashboard"
            class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5">Panel Title</label>
          <input id="panel-title" type="text" value="HTTP Request Rate"
            class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5">Data Source</label>
          <select id="datasource" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
            <option value="Prometheus">Prometheus</option>
            <option value="Loki">Loki</option>
            <option value="Tempo">Tempo</option>
            <option value="InfluxDB">InfluxDB</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5">Panel Type</label>
          <select id="panel-type" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
            <option value="timeseries">Time Series</option>
            <option value="stat">Stat</option>
            <option value="gauge">Gauge</option>
            <option value="barchart">Bar Chart</option>
            <option value="table">Table</option>
            <option value="logs">Logs</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5">Metric / Query</label>
          <input id="metric-query" type="text" value="rate(http_requests_total[5m])"
            class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5">Unit</label>
          <select id="unit" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
            <option value="reqps">requests/sec</option>
            <option value="ms">milliseconds (ms)</option>
            <option value="s">seconds (s)</option>
            <option value="bytes">bytes</option>
            <option value="percent">percent (0-100)</option>
            <option value="percentunit">percent (0-1)</option>
            <option value="short">short (auto)</option>
          </select>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium mb-1.5">Warning Threshold</label>
            <input id="warn-threshold" type="number" value="80"
              class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5">Critical Threshold</label>
            <input id="crit-threshold" type="number" value="95"
              class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
          </div>
        </div>
      </div>
    </div>

    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="text-base font-semibold mb-3">Panel Preview</h2>
      <div id="panel-preview" class="border border-border rounded-lg p-4 mb-4 bg-black/10 min-h-[120px]"></div>
      <h2 class="text-base font-semibold mb-2">Quick-select Metrics</h2>
      <div class="flex flex-wrap gap-2" id="quick-metrics">
        <button data-metric="rate(http_requests_total[5m])" class="quick-metric text-xs bg-black/20 border border-border px-2.5 py-1 rounded-lg hover:border-primary transition-colors">http_requests_total</button>
        <button data-metric="histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))" class="quick-metric text-xs bg-black/20 border border-border px-2.5 py-1 rounded-lg hover:border-primary transition-colors">p95 latency</button>
        <button data-metric="rate(container_cpu_usage_seconds_total[5m])" class="quick-metric text-xs bg-black/20 border border-border px-2.5 py-1 rounded-lg hover:border-primary transition-colors">container_cpu</button>
        <button data-metric="container_memory_usage_bytes" class="quick-metric text-xs bg-black/20 border border-border px-2.5 py-1 rounded-lg hover:border-primary transition-colors">container_memory</button>
        <button data-metric="up" class="quick-metric text-xs bg-black/20 border border-border px-2.5 py-1 rounded-lg hover:border-primary transition-colors">up (availability)</button>
        <button data-metric="rate(process_cpu_seconds_total[5m])" class="quick-metric text-xs bg-black/20 border border-border px-2.5 py-1 rounded-lg hover:border-primary transition-colors">process_cpu</button>
      </div>
    </div>
  </div>

  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-base font-semibold">Generated Grafana Panel JSON</h2>
      <button id="copy-btn" class="text-xs bg-primary text-white px-3 py-1.5 rounded-lg hover:opacity-90">Copy JSON</button>
    </div>
    <pre id="json-output" class="bg-black/20 rounded-lg p-4 text-xs font-mono overflow-x-auto whitespace-pre text-green-300 max-h-[400px] overflow-y-auto"></pre>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Grafana Dashboard Template Generator" relatedTags={['grafana', 'monitoring', 'observability', 'prometheus', 'devops', 'metrics']} />
</BaseLayout>

<script is:inline>
  var UNITS = { reqps: "reqps", ms: "ms", s: "s", bytes: "bytes", percent: "percent", percentunit: "percentunit", short: "short" };

  function buildPanelJSON() {
    var title = document.getElementById("dash-title").value || "Dashboard";
    var panelTitle = document.getElementById("panel-title").value || "Panel";
    var ds = document.getElementById("datasource").value;
    var ptype = document.getElementById("panel-type").value;
    var query = document.getElementById("metric-query").value;
    var unit = document.getElementById("unit").value;
    var warn = parseFloat(document.getElementById("warn-threshold").value) || 80;
    var crit = parseFloat(document.getElementById("crit-threshold").value) || 95;

    var thresholds = { mode: "absolute", steps: [{ color: "green", value: null }, { color: "yellow", value: warn }, { color: "red", value: crit }] };

    var refId = "A";
    var targets = [];
    if (ds === "Prometheus" || ds === "Tempo") {
      targets = [{ datasource: { type: "prometheus", uid: "prometheus" }, expr: query, refId: refId, interval: "", legendFormat: "{{job}}" }];
    } else if (ds === "Loki") {
      targets = [{ datasource: { type: "loki", uid: "loki" }, expr: query, refId: refId }];
    } else {
      targets = [{ datasource: { type: "influxdb", uid: "influxdb" }, query: query, refId: refId }];
    }

    var options = {};
    if (ptype === "timeseries") {
      options = { tooltip: { mode: "multi", sort: "none" }, legend: { displayMode: "list", placement: "bottom" } };
    } else if (ptype === "stat") {
      options = { reduceOptions: { calcs: ["lastNotNull"], fields: "", values: false }, orientation: "auto", textMode: "auto", colorMode: "background", graphMode: "area" };
    } else if (ptype === "gauge") {
      options = { reduceOptions: { calcs: ["lastNotNull"], fields: "", values: false }, orientation: "auto", showThresholdLabels: false, showThresholdMarkers: true };
    } else if (ptype === "barchart") {
      options = { orientation: "auto", groupWidth: 0.7, barWidth: 0.97, stacking: "none", fillOpacity: 80 };
    } else if (ptype === "table") {
      options = { frameIndex: 0, showHeader: true };
    } else if (ptype === "logs") {
      options = { dedupStrategy: "none", enableLogDetails: true, prettifyLogMessage: false, showCommonLabels: false, showLabels: false, showTime: false, sortOrder: "Descending", wrapLogMessage: false };
    }

    var panel = {
      id: 1,
      title: panelTitle,
      type: ptype,
      datasource: { type: ds.toLowerCase(), uid: ds.toLowerCase() },
      targets: targets,
      fieldConfig: {
        defaults: {
          unit: UNITS[unit] || unit,
          thresholds: thresholds,
          custom: ptype === "timeseries" ? { drawStyle: "line", lineInterpolation: "linear", barAlignment: 0, lineWidth: 1, fillOpacity: 10, gradientMode: "none", spanNulls: false, pointSize: 5, stacking: { mode: "none", group: "A" } } : {}
        },
        overrides: []
      },
      options: options,
      gridPos: { h: 8, w: 12, x: 0, y: 0 },
      _dashboard: { title: title, uid: "auto-generated-" + Date.now() }
    };

    return JSON.stringify(panel, null, 2);
  }

  function updatePreview() {
    var ptype = document.getElementById("panel-type").value;
    var panelTitle = document.getElementById("panel-title").value || "Panel";
    var ds = document.getElementById("datasource").value;
    var query = document.getElementById("metric-query").value;
    var warn = document.getElementById("warn-threshold").value;
    var crit = document.getElementById("crit-threshold").value;
    var icons = { timeseries: "📈", stat: "🔢", gauge: "⏱", barchart: "📊", table: "📋", logs: "📜" };
    var icon = icons[ptype] || "📊";
    document.getElementById("panel-preview").innerHTML =
      "<div class=\"text-sm font-semibold mb-2\">" + icon + " " + panelTitle + "</div>" +
      "<div class=\"text-xs text-text-muted space-y-1\">" +
      "<div><span class=\"text-text-muted\">Type:</span> <span class=\"text-primary font-medium\">" + ptype + "</span></div>" +
      "<div><span class=\"text-text-muted\">Data source:</span> " + ds + "</div>" +
      "<div><span class=\"text-text-muted\">Query:</span> <code class=\"bg-black/20 px-1 rounded\">" + query.substring(0,60) + (query.length>60?"...":"") + "</code></div>" +
      "<div class=\"flex gap-4 mt-2\"><span class=\"text-yellow-400\">⚠ Warn: " + warn + "</span><span class=\"text-red-400\">✕ Crit: " + crit + "</span></div>" +
      "</div>";

    document.getElementById("json-output").textContent = buildPanelJSON();
  }

  document.querySelectorAll("input, select").forEach(function(el) { el.addEventListener("input", updatePreview); });

  document.querySelectorAll(".quick-metric").forEach(function(btn) {
    btn.addEventListener("click", function() {
      document.getElementById("metric-query").value = btn.getAttribute("data-metric");
      updatePreview();
    });
  });

  document.getElementById("copy-btn").addEventListener("click", function() {
    var text = document.getElementById("json-output").textContent;
    navigator.clipboard.writeText(text).then(function() {
      var btn = document.getElementById("copy-btn");
      btn.textContent = "Copied!";
      setTimeout(function(){ btn.textContent = "Copy JSON"; }, 2000);
    }).catch(function() {
      var ta = document.createElement("textarea");
      ta.value = text; document.body.appendChild(ta); ta.select(); document.execCommand("copy"); document.body.removeChild(ta);
      var btn = document.getElementById("copy-btn");
      btn.textContent = "Copied!"; setTimeout(function(){ btn.textContent = "Copy JSON"; }, 2000);
    });
  });

  updatePreview();
</script>
