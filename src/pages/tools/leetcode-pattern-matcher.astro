<BaseLayout
  title="LeetCode Pattern Matcher — Find the Right Algorithm for Any Problem"
  description="Describe your coding interview problem and instantly identify the right algorithm pattern: two pointers, sliding window, BFS, DP, heap, and more. Includes code templates. Free."
  tool="LeetCode Pattern Matcher, Coding Interview Patterns, Algorithm Pattern Finder, LeetCode Patterns, Coding Interview Prep"
>
  <h1 class="text-3xl font-bold mb-2">LeetCode Pattern Matcher</h1>
  <p class="text-text-muted mb-8">Describe your coding problem and instantly surface the matching algorithm pattern — with classic examples and a ready-to-use code template. Covers Two Pointers, Sliding Window, BFS, DP, Heap, Trie, Union-Find, and more.</p>
  <LeetcodePatternMatcher client:only="preact" />
  <ToolPageCta currentTool="LeetCode Pattern Matcher" relatedTags={['algorithms', 'interview', 'coding', 'leetcode']} />
</BaseLayout>
