---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FaviconGenerator from '../../components/FaviconGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What sizes should a favicon be?", answer: "Modern browsers need at minimum a 16×16 and 32×32 PNG. For Apple devices, provide a 180×180 apple-touch-icon. For PWA/Android, include 192×192 and 512×512. This tool exports all standard sizes at once." },
  { question: "What format should a favicon use?", answer: "ICO format is legacy but still needed for IE11. Modern browsers support PNG, SVG, and WebP. The safest approach is to provide a PNG favicon at multiple sizes and optionally an SVG for scalability. For simplicity, PNG at 32×32 covers most cases." },
  { question: "How do I add a favicon to my website?", answer: "Place the PNG files in your project root or a /public directory, then add link tags in your HTML <head>: <link rel='icon' type='image/png' sizes='32x32' href='/favicon-32.png'>. Use the HTML tags section in this tool to copy ready-to-paste code." },
  { question: "What is an apple-touch-icon?", answer: "The apple-touch-icon is the image displayed when a user adds your website to their iOS home screen. It should be 180×180 pixels (PNG, no transparency). Without it, Apple will use a screenshot of your page instead." },
  { question: "Can I use an emoji as a favicon?", answer: "Yes! Modern browsers support SVG favicons with embedded emoji: <link rel='icon' href='data:image/svg+xml,<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 100 100\"><text y=\".9em\" font-size=\"90\">🚀</text></svg>'>. This generator also accepts emoji as text input and renders them to PNG." },
];
---

<BaseLayout
  title="Favicon Generator — Free Online Tool | Generate Favicon PNG"
  description="Design a custom favicon online. Pick colors, shape, and text, then download PNG at all standard sizes (16, 32, 48, 180, 192, 512px). Copy HTML meta tags instantly. Runs entirely in your browser."
  tool="Favicon Generator, Favicon Creator, Favicon Maker, HTML Favicon, Apple Touch Icon, PWA Icon Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Favicon Generator</h1>
  <p class="text-text-muted mb-4">Design a favicon with custom colors, text, and shape. Preview at all standard sizes and download PNG exports. Includes ready-to-paste HTML meta tags for your <code class="font-mono text-sm">&lt;head&gt;</code>. Everything runs in your browser — nothing uploaded to any server.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <FaviconGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Favicon Generator" relatedTags={['design', 'css', 'html', 'browser', 'image']} />
</BaseLayout>
