---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is TOML and why convert it to JSON?", answer: "TOML (Tom's Obvious, Minimal Language) is a config file format used by Rust (Cargo.toml), Python (pyproject.toml), and Hugo. JSON is the standard for APIs and web services. Converting between them is a common task when bridging tooling ecosystems or reading config data programmatically." },
  { question: "Can I convert JSON back to TOML?", answer: "Yes. Click 'JSON → TOML' to switch direction. Paste your JSON object and get clean TOML output with proper sections for nested objects and correct value types." },
  { question: "What TOML features are supported?", answer: "The converter supports [section] headers (mapped to nested JSON objects), key = value pairs, strings (double and single quoted), integers, floats, booleans (true/false), and inline arrays. Multi-line strings and inline tables have limited support." },
  { question: "Is my data sent to any server?", answer: "No. All conversion runs entirely in your browser using JavaScript. Your TOML or JSON data never leaves your machine — safe for sensitive config files, API keys, and secrets." },
  { question: "What projects use TOML?", answer: "TOML is the standard config format for Rust (Cargo.toml), Python packaging (pyproject.toml), the Hugo static site generator, Gitea, and many modern CLI tools. If you work in Rust or Python, you likely encounter TOML daily." },
  { question: "How is the TOML to JSON converter different from the original tool?", answer: "This URL (/tools/toml-to-json-converter) is a canonical alias for the same tool available at /tools/toml-to-json. It provides identical bidirectional TOML ↔ JSON conversion with the same feature set, running 100% in your browser." },
];
---

<BaseLayout
  title="TOML to JSON Converter — Free Online TOML to JSON Tool"
  description="Convert TOML to JSON or JSON to TOML instantly. Supports [sections], key-value pairs, arrays, booleans, and all scalar types. Free, runs 100% in your browser — no data sent to any server."
  tool="TOML to JSON converter, JSON to TOML, TOML parser online, Cargo.toml to JSON, pyproject.toml converter, convert TOML JSON"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "TOML to JSON Converter",
    "url": "https://devplaybook.cc/tools/toml-to-json-converter",
    "description": "Convert TOML to JSON or JSON to TOML online. Supports sections, key-value pairs, arrays, booleans, and all scalar types.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">TOML to JSON Converter</h1>
  <p class="text-text-muted mb-4">
    Convert TOML to JSON or JSON to TOML instantly. Supports <code class="bg-bg-secondary px-1 rounded text-sm">[sections]</code>,
    key-value pairs, strings, integers, floats, booleans, and arrays.
    Useful for Cargo.toml, pyproject.toml, and any TOML config file. Everything runs in your browser.
  </p>
  <div class="flex items-center gap-3 mb-8 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TOML → JSON and JSON → TOML</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> [sections] → nested objects</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Type-safe conversion</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <!-- Direction toggle -->
  <div class="flex gap-2 mb-4">
    <button id="btn-toml-to-json" class="bg-primary text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors">TOML → JSON</button>
    <button id="btn-json-to-toml" class="bg-bg-card border border-border text-text px-4 py-2 rounded-lg text-sm font-semibold hover:bg-bg-secondary transition-colors">JSON → TOML</button>
  </div>

  <!-- Converter -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
    <!-- Input -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <label id="input-label" class="font-semibold text-sm" for="input-area">TOML Input</label>
        <button id="load-example" class="text-xs text-primary hover:underline">Load example</button>
      </div>
      <textarea id="input-area" rows="18"
        placeholder="[package]&#10;name = &quot;my-app&quot;&#10;version = &quot;0.1.0&quot;&#10;&#10;[dependencies]&#10;tokio = &quot;1.0&quot;"
        class="w-full bg-bg border border-border rounded-lg px-3 py-3 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40 resize-y"></textarea>
    </div>
    <!-- Output -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <span id="output-label" class="font-semibold text-sm">JSON Output</span>
        <button id="copy-btn" class="text-xs text-primary hover:underline hidden">Copy</button>
      </div>
      <div id="convert-error" class="hidden mb-3 p-3 bg-red-500/10 border border-red-500/20 rounded-lg text-sm text-red-400"></div>
      <textarea id="output-area" rows="18" readonly
        placeholder="Output will appear here..."
        class="w-full bg-bg border border-border rounded-lg px-3 py-3 text-sm font-mono resize-y text-text-muted focus:outline-none"></textarea>
    </div>
  </div>

  <div class="flex gap-3 mb-8">
    <button id="convert-btn" class="bg-primary text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-primary/80 transition-colors">
      Convert
    </button>
    <button id="clear-btn" class="text-sm text-text-muted hover:text-red-400 transition-colors">Clear</button>
  </div>

  <!-- Reference table -->
  <div class="bg-bg-card border border-border rounded-xl p-6 mb-8">
    <h2 class="font-bold text-sm uppercase tracking-wide text-text-muted mb-4">TOML → JSON Type Mapping</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border">
            <th class="text-left py-2 pr-4 text-text-muted font-medium">Type</th>
            <th class="text-left py-2 pr-4 text-text-muted font-medium">TOML</th>
            <th class="text-left py-2 text-text-muted font-medium">JSON</th>
          </tr>
        </thead>
        <tbody class="font-mono text-xs text-text-muted">
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-sans text-text">String</td><td class="pr-4">name = "hello"</td><td>"name": "hello"</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-sans text-text">Integer</td><td class="pr-4">count = 42</td><td>"count": 42</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-sans text-text">Float</td><td class="pr-4">pi = 3.14</td><td>"pi": 3.14</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-sans text-text">Boolean</td><td class="pr-4">debug = true</td><td>"debug": true</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-sans text-text">Array</td><td class="pr-4">tags = ["a", "b"]</td><td>"tags": ["a", "b"]</td></tr>
          <tr><td class="py-2 pr-4 font-sans text-text">Section</td><td class="pr-4">[database]<br>host = "localhost"</td><td>"database": &#123;<br>&nbsp;&nbsp;"host": "localhost"<br>&#125;</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <AffiliateSection />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="TOML to JSON Converter" relatedTags={['toml', 'json', 'converter', 'config', 'rust', 'python']} />
</BaseLayout>

<script is:inline>
(function () {
  var mode = 'toml-to-json'; // or 'json-to-toml'

  // ── TOML parser ───────────────────────────────────────────────────────────────
  function parseToml(raw) {
    var lines = raw.split('\n');
    var result = {};
    var current = result;
    var currentPath = [];

    function getOrCreate(obj, keys) {
      var ref = obj;
      for (var i = 0; i < keys.length; i++) {
        if (ref[keys[i]] === undefined) ref[keys[i]] = {};
        ref = ref[keys[i]];
      }
      return ref;
    }

    for (var i = 0; i < lines.length; i++) {
      var line = lines[i].trim();
      if (!line || line.startsWith('#')) continue;

      // Array of tables [[section]]
      var arrMatch = line.match(/^\[\[([^\]]+)\]\]$/);
      if (arrMatch) {
        var arrKey = arrMatch[1].trim();
        var parts = arrKey.split('.');
        var parentPath = parts.slice(0, -1);
        var lastKey = parts[parts.length - 1];
        var parent = parentPath.length ? getOrCreate(result, parentPath) : result;
        if (!Array.isArray(parent[lastKey])) parent[lastKey] = [];
        var newItem = {};
        parent[lastKey].push(newItem);
        currentPath = parts;
        current = newItem;
        continue;
      }

      // Table [section]
      var tableMatch = line.match(/^\[([^\]]+)\]$/);
      if (tableMatch) {
        var tKey = tableMatch[1].trim();
        currentPath = tKey.split('.');
        current = getOrCreate(result, currentPath);
        continue;
      }

      // Key = value
      var eqIdx = line.indexOf('=');
      if (eqIdx === -1) continue;
      var key = line.substring(0, eqIdx).trim();
      var valRaw = line.substring(eqIdx + 1).trim();
      current[key] = parseTomlValue(valRaw);
    }
    return result;
  }

  function parseTomlValue(raw) {
    if (raw === 'true') return true;
    if (raw === 'false') return false;
    if (raw === 'null') return null;
    // Double-quoted string
    if (raw.startsWith('"') && raw.endsWith('"'))
      return raw.slice(1, -1).replace(/\\n/g, '\n').replace(/\\t/g, '\t').replace(/\\"/g, '"').replace(/\\\\/g, '\\');
    // Single-quoted string
    if (raw.startsWith("'") && raw.endsWith("'"))
      return raw.slice(1, -1);
    // Array
    if (raw.startsWith('[') && raw.endsWith(']')) {
      var inner = raw.slice(1, -1).trim();
      if (!inner) return [];
      var items = splitTomlArray(inner);
      return items.map(function(item) { return parseTomlValue(item.trim()); });
    }
    // Number
    if (/^-?\d+\.\d+$/.test(raw)) return parseFloat(raw);
    if (/^-?\d+$/.test(raw)) return parseInt(raw, 10);
    return raw;
  }

  function splitTomlArray(s) {
    var items = [];
    var depth = 0;
    var inStr = false;
    var strChar = '';
    var start = 0;
    for (var i = 0; i < s.length; i++) {
      var c = s[i];
      if (inStr) {
        if (c === '\\') { i++; continue; }
        if (c === strChar) inStr = false;
      } else if (c === '"' || c === "'") {
        inStr = true; strChar = c;
      } else if (c === '[') {
        depth++;
      } else if (c === ']') {
        depth--;
      } else if (c === ',' && depth === 0) {
        items.push(s.slice(start, i).trim());
        start = i + 1;
      }
    }
    var last = s.slice(start).trim();
    if (last) items.push(last);
    return items;
  }

  // ── JSON to TOML serializer ───────────────────────────────────────────────────
  function toTomlValue(v) {
    if (v === null) return '"null"';
    if (typeof v === 'boolean') return v ? 'true' : 'false';
    if (typeof v === 'number') return String(v);
    if (typeof v === 'string') return '"' + v.replace(/\\/g, '\\\\').replace(/"/g, '\\"').replace(/\n/g, '\\n').replace(/\t/g, '\\t') + '"';
    if (Array.isArray(v)) {
      var allScalar = v.every(function(x) { return typeof x !== 'object' || x === null; });
      if (allScalar) return '[' + v.map(toTomlValue).join(', ') + ']';
      return null;
    }
    return null;
  }

  function serializeToml(obj, prefix) {
    var lines = [];
    var tables = [];
    Object.keys(obj).forEach(function(key) {
      var v = obj[key];
      var fullKey = prefix ? prefix + '.' + key : key;
      if (v === null || typeof v !== 'object') {
        lines.push(key + ' = ' + toTomlValue(v));
      } else if (Array.isArray(v)) {
        var allScalar = v.every(function(x) { return typeof x !== 'object' || x === null; });
        if (allScalar) {
          lines.push(key + ' = ' + toTomlValue(v));
        } else {
          v.forEach(function(item) {
            tables.push('');
            tables.push('[[' + fullKey + ']]');
            if (item && typeof item === 'object' && !Array.isArray(item)) {
              var inner = serializeToml(item, '');
              inner.split('\n').forEach(function(l) { if (l) tables.push(l); });
            }
          });
        }
      } else {
        tables.push('');
        tables.push('[' + fullKey + ']');
        var inner = serializeToml(v, fullKey);
        inner.split('\n').forEach(function(l) { if (l) tables.push(l); });
      }
    });
    return lines.concat(tables).join('\n');
  }

  // ── Examples ─────────────────────────────────────────────────────────────────
  var TOML_EXAMPLE = [
    '[package]',
    'name = "my-app"',
    'version = "0.1.0"',
    'edition = "2021"',
    '',
    '[dependencies]',
    'tokio = "1.0"',
    'serde = "1.0"',
    '',
    '[profile.release]',
    'opt-level = 3',
    'debug = false',
    '',
    'features = ["logging", "metrics"]',
  ].join('\n');

  var JSON_EXAMPLE = JSON.stringify({
    "package": { "name": "my-app", "version": "0.1.0", "edition": "2021" },
    "dependencies": { "tokio": "1.0", "serde": "1.0" },
    "profile": { "release": { "opt-level": 3, "debug": false } },
    "features": ["logging", "metrics"]
  }, null, 2);

  // ── UI logic ─────────────────────────────────────────────────────────────────
  function setMode(newMode) {
    mode = newMode;
    var isTomlToJson = mode === 'toml-to-json';
    document.getElementById('input-label').textContent = isTomlToJson ? 'TOML Input' : 'JSON Input';
    document.getElementById('output-label').textContent = isTomlToJson ? 'JSON Output' : 'TOML Output';
    document.getElementById('input-area').placeholder = isTomlToJson
      ? '[package]\nname = "my-app"\nversion = "0.1.0"'
      : '{\n  "package": {\n    "name": "my-app"\n  }\n}';
    document.getElementById('output-area').placeholder = isTomlToJson ? 'JSON output will appear here...' : 'TOML output will appear here...';
    document.getElementById('input-area').value = '';
    document.getElementById('output-area').value = '';
    document.getElementById('convert-error').classList.add('hidden');
    document.getElementById('copy-btn').classList.add('hidden');

    document.getElementById('btn-toml-to-json').className = isTomlToJson
      ? 'bg-primary text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors'
      : 'bg-bg-card border border-border text-text px-4 py-2 rounded-lg text-sm font-semibold hover:bg-bg-secondary transition-colors';
    document.getElementById('btn-json-to-toml').className = !isTomlToJson
      ? 'bg-primary text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors'
      : 'bg-bg-card border border-border text-text px-4 py-2 rounded-lg text-sm font-semibold hover:bg-bg-secondary transition-colors';
  }

  document.getElementById('btn-toml-to-json').addEventListener('click', function() { setMode('toml-to-json'); });
  document.getElementById('btn-json-to-toml').addEventListener('click', function() { setMode('json-to-toml'); });

  document.getElementById('load-example').addEventListener('click', function() {
    document.getElementById('input-area').value = mode === 'toml-to-json' ? TOML_EXAMPLE : JSON_EXAMPLE;
  });

  document.getElementById('clear-btn').addEventListener('click', function() {
    document.getElementById('input-area').value = '';
    document.getElementById('output-area').value = '';
    document.getElementById('convert-error').classList.add('hidden');
    document.getElementById('copy-btn').classList.add('hidden');
  });

  document.getElementById('convert-btn').addEventListener('click', function() {
    var raw = document.getElementById('input-area').value.trim();
    var errEl = document.getElementById('convert-error');
    var outEl = document.getElementById('output-area');
    var copyBtn = document.getElementById('copy-btn');

    errEl.classList.add('hidden');
    outEl.value = '';
    copyBtn.classList.add('hidden');

    if (!raw) {
      errEl.textContent = 'Please paste some input first.';
      errEl.classList.remove('hidden');
      return;
    }

    try {
      var result;
      if (mode === 'toml-to-json') {
        var parsed = parseToml(raw);
        result = JSON.stringify(parsed, null, 2);
      } else {
        var jsonObj = JSON.parse(raw);
        if (typeof jsonObj !== 'object' || Array.isArray(jsonObj)) throw new Error('JSON must be an object at the top level.');
        result = serializeToml(jsonObj, '').trim();
      }
      outEl.value = result;
      copyBtn.classList.remove('hidden');
    } catch (e) {
      errEl.textContent = 'Error: ' + (e.message || String(e));
      errEl.classList.remove('hidden');
    }
  });

  document.getElementById('copy-btn').addEventListener('click', function() {
    var val = document.getElementById('output-area').value;
    if (val) navigator.clipboard && navigator.clipboard.writeText(val);
    this.textContent = 'Copied!';
    var btn = this;
    setTimeout(function() { btn.textContent = 'Copy'; }, 2000);
  });
})();
</script>
