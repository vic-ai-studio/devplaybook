---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="SOPS Config Generator — Generate Mozilla SOPS .sops.yaml Configuration"
  description="Generate Mozilla SOPS configuration files for encrypting secrets with AWS KMS, GCP KMS, Azure Key Vault, age, or PGP. Configure creation rules, path globs, and key groups. Free, runs in browser."
  tool="SOPS config generator, Mozilla SOPS, .sops.yaml, secrets encryption, AWS KMS SOPS, age encryption, GitOps secrets"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "SOPS Config Generator",
    "url": "https://devplaybook.cc/tools/sops-config-generator",
    "description": "Generate .sops.yaml configuration files for Mozilla SOPS secrets encryption with AWS KMS, GCP KMS, Azure Key Vault, age, and PGP.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">SOPS Config Generator</h1>
  <p class="text-text-muted mb-4">
    Generate <a href="https://github.com/getsops/sops" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">Mozilla SOPS</a> <code class="text-accent">.sops.yaml</code> configuration files.
    Configure creation rules, key providers (AWS KMS, GCP KMS, Azure Key Vault, age, PGP), and path-based encryption policies for GitOps workflows. Runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> AWS / GCP / Azure KMS support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> age + PGP key support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multiple creation rules</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Key groups with Shamir's Secret Sharing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> sops CLI command reference</span>
  </div>

  <!-- Presets -->
  <div class="flex gap-2 mb-6 flex-wrap">
    <span class="text-sm text-text-muted self-center">Presets:</span>
    <button data-preset="aws" class="preset-btn px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">AWS KMS</button>
    <button data-preset="gcp" class="preset-btn px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">GCP KMS</button>
    <button data-preset="age" class="preset-btn px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">age</button>
    <button data-preset="multi" class="preset-btn px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">Multi-Provider</button>
    <button data-preset="gitops" class="preset-btn px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">GitOps (Flux/ArgoCD)</button>
  </div>

  <!-- Rules builder -->
  <div id="rules-container" class="space-y-4 mb-4">
    <!-- Rules added here -->
  </div>

  <button id="btn-add-rule" class="flex items-center gap-2 px-4 py-2 bg-bg-card border border-dashed border-border rounded-lg text-sm text-text-muted hover:border-primary hover:text-foreground transition-colors mb-6">
    <span class="text-lg leading-none">+</span> Add Creation Rule
  </button>

  <!-- Global settings -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-6">
    <h3 class="text-sm font-semibold mb-3">Global Settings</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-xs text-text-muted mb-1">Encrypted regex (optional)</label>
        <input id="global-encrypted-regex" type="text" placeholder="^(data|stringData)$" class="w-full bg-bg border border-border rounded p-2 text-sm focus:outline-none focus:border-primary" />
        <p class="text-xs text-text-muted mt-1">Only encrypt matching keys</p>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Unencrypted suffix (optional)</label>
        <input id="global-unencrypted-suffix" type="text" placeholder="_unencrypted" class="w-full bg-bg border border-border rounded p-2 text-sm focus:outline-none focus:border-primary" />
        <p class="text-xs text-text-muted mt-1">Keys with this suffix are not encrypted</p>
      </div>
    </div>
  </div>

  <button id="btn-generate" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors mb-6">Generate .sops.yaml</button>

  <div id="output-section" class="hidden space-y-4">
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <div class="flex justify-between items-center mb-3">
        <span class="text-sm font-medium text-text-muted">.sops.yaml</span>
        <button id="copy-sops-btn" class="px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">Copy</button>
      </div>
      <pre id="sops-output" class="font-mono text-sm whitespace-pre-wrap break-words overflow-x-auto max-h-[500px] overflow-y-auto text-foreground"></pre>
    </div>
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <h3 class="text-sm font-semibold mb-3">Common SOPS Commands</h3>
      <pre id="cmds-output" class="font-mono text-xs whitespace-pre-wrap break-words overflow-x-auto text-text-muted max-h-[300px] overflow-y-auto"></pre>
    </div>
  </div>

  <ToolPageCta currentTool="SOPS Config Generator" relatedTags={['security', 'secrets', 'gitops', 'kubernetes', 'devops', 'encryption']} />
</BaseLayout>

<script is:inline>
  let ruleCount = 0;

  const PRESETS = {
    aws: {
      rules: [{
        pathRegex: '.*.yaml$',
        provider: 'aws',
        awsArn: 'arn:aws:kms:us-east-1:111122223333:key/mrk-1234abcd12ab34cd56ef1234567890ab',
        awsRole: 'arn:aws:iam::111122223333:role/sops-role',
      }]
    },
    gcp: {
      rules: [{
        pathRegex: '.*.yaml$',
        provider: 'gcp',
        gcpResourceId: 'projects/my-project/locations/global/keyRings/my-keyring/cryptoKeys/my-key',
      }]
    },
    age: {
      rules: [{
        pathRegex: '.*.yaml$',
        provider: 'age',
        ageRecipients: 'age1ql3z7hjy54pw3hyww5ayyfg7zqgvc7w3j2elw8zmrj2kg5sfn9aqmcac8p',
      }]
    },
    multi: {
      rules: [
        {
          pathRegex: 'secrets/prod/.*',
          provider: 'aws',
          awsArn: 'arn:aws:kms:us-east-1:111122223333:key/prod-key-id',
          awsRole: 'arn:aws:iam::111122223333:role/prod-sops-role',
        },
        {
          pathRegex: 'secrets/dev/.*',
          provider: 'age',
          ageRecipients: 'age1ql3z7hjy54pw3hyww5ayyfg7zqgvc7w3j2elw8zmrj2kg5sfn9aqmcac8p',
        },
        {
          pathRegex: '.*.yaml$',
          provider: 'pgp',
          pgpFingerprints: 'FBC7B9E2A4F9289AC0C1D4843D16CEE4A27381B4',
        }
      ]
    },
    gitops: {
      rules: [
        {
          pathRegex: 'clusters/.*/secrets/.*',
          provider: 'aws',
          awsArn: 'arn:aws:kms:us-east-1:111122223333:key/flux-key-id',
          encryptedRegex: '^(data|stringData)$',
        },
        {
          pathRegex: '.*.yaml$',
          provider: 'age',
          ageRecipients: 'age1ql3z7hjy54pw3hyww5ayyfg7zqgvc7w3j2elw8zmrj2kg5sfn9aqmcac8p',
          encryptedRegex: '^(data|stringData)$',
        }
      ]
    }
  };

  function addRule(data = {}) {
    ruleCount++;
    const id = ruleCount;
    const container = document.getElementById('rules-container');
    const div = document.createElement('div');
    div.id = `rule-${id}`;
    div.className = 'bg-bg-card border border-border rounded-lg p-4';

    div.innerHTML = `
      <div class="flex justify-between items-center mb-3">
        <span class="text-sm font-semibold">Rule #${id}</span>
        <button onclick="removeRule(${id})" class="text-xs text-text-muted hover:text-red-400 transition-colors">Remove</button>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div>
          <label class="block text-xs text-text-muted mb-1">Path regex</label>
          <input type="text" id="rule-${id}-path" value="${data.pathRegex || '.*.yaml$'}"
            class="w-full bg-bg border border-border rounded p-2 text-sm focus:outline-none focus:border-primary" placeholder=".*.yaml$" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">Key Provider</label>
          <select id="rule-${id}-provider" onchange="updateRuleFields(${id})"
            class="w-full bg-bg border border-border rounded p-2 text-sm focus:outline-none focus:border-primary">
            <option value="aws" ${(data.provider||'aws')==='aws'?'selected':''}>AWS KMS</option>
            <option value="gcp" ${data.provider==='gcp'?'selected':''}>GCP KMS</option>
            <option value="azure" ${data.provider==='azure'?'selected':''}>Azure Key Vault</option>
            <option value="age" ${data.provider==='age'?'selected':''}>age</option>
            <option value="pgp" ${data.provider==='pgp'?'selected':''}>PGP</option>
          </select>
        </div>
        <div id="rule-${id}-encrypted-regex-wrap">
          <label class="block text-xs text-text-muted mb-1">Encrypted regex (optional)</label>
          <input type="text" id="rule-${id}-encrypted-regex" value="${data.encryptedRegex || ''}"
            class="w-full bg-bg border border-border rounded p-2 text-sm focus:outline-none focus:border-primary" placeholder="^(data|stringData)$" />
        </div>
      </div>
      <div id="rule-${id}-provider-fields" class="mt-3"></div>
    `;
    container.appendChild(div);

    // Set initial data attrs
    if (data.awsArn) document.getElementById(`rule-${id}-provider`)._initData = data;

    updateRuleFields(id, data);
  }

  function updateRuleFields(id, data) {
    const provider = document.getElementById(`rule-${id}-provider`).value;
    const container = document.getElementById(`rule-${id}-provider-fields`);
    const d = data || document.getElementById(`rule-${id}-provider`)._initData || {};

    let html = '<div class="grid grid-cols-1 sm:grid-cols-2 gap-3">';

    if (provider === 'aws') {
      html += `
        <div>
          <label class="block text-xs text-text-muted mb-1">KMS ARN</label>
          <input type="text" id="rule-${id}-aws-arn" value="${d.awsArn || ''}"
            class="w-full bg-bg border border-border rounded p-2 text-sm focus:outline-none focus:border-primary font-mono"
            placeholder="arn:aws:kms:us-east-1:123456789012:key/..." />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">Role ARN (optional)</label>
          <input type="text" id="rule-${id}-aws-role" value="${d.awsRole || ''}"
            class="w-full bg-bg border border-border rounded p-2 text-sm focus:outline-none focus:border-primary font-mono"
            placeholder="arn:aws:iam::123456789012:role/sops-role" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">AWS Region</label>
          <input type="text" id="rule-${id}-aws-region" value="${d.awsRegion || 'us-east-1'}"
            class="w-full bg-bg border border-border rounded p-2 text-sm focus:outline-none focus:border-primary" />
        </div>`;
    } else if (provider === 'gcp') {
      html += `
        <div class="sm:col-span-2">
          <label class="block text-xs text-text-muted mb-1">Resource ID</label>
          <input type="text" id="rule-${id}-gcp-id" value="${d.gcpResourceId || ''}"
            class="w-full bg-bg border border-border rounded p-2 text-sm focus:outline-none focus:border-primary font-mono"
            placeholder="projects/my-project/locations/global/keyRings/my-ring/cryptoKeys/my-key" />
        </div>`;
    } else if (provider === 'azure') {
      html += `
        <div class="sm:col-span-2">
          <label class="block text-xs text-text-muted mb-1">Azure Key Vault URL</label>
          <input type="text" id="rule-${id}-azure-url" value="${d.azureUrl || ''}"
            class="w-full bg-bg border border-border rounded p-2 text-sm focus:outline-none focus:border-primary font-mono"
            placeholder="https://my-vault.vault.azure.net/keys/my-key/version" />
        </div>`;
    } else if (provider === 'age') {
      html += `
        <div class="sm:col-span-2">
          <label class="block text-xs text-text-muted mb-1">age Recipients (comma-separated public keys)</label>
          <input type="text" id="rule-${id}-age" value="${d.ageRecipients || ''}"
            class="w-full bg-bg border border-border rounded p-2 text-sm focus:outline-none focus:border-primary font-mono"
            placeholder="age1ql3z7hjy54pw3hyww5ayyfg7zqgvc7w3j2elw8zmrj2kg5sfn9aqmcac8p" />
        </div>`;
    } else if (provider === 'pgp') {
      html += `
        <div class="sm:col-span-2">
          <label class="block text-xs text-text-muted mb-1">PGP Fingerprints (comma-separated)</label>
          <input type="text" id="rule-${id}-pgp" value="${d.pgpFingerprints || ''}"
            class="w-full bg-bg border border-border rounded p-2 text-sm focus:outline-none focus:border-primary font-mono"
            placeholder="FBC7B9E2A4F9289AC0C1D4843D16CEE4A27381B4" />
        </div>`;
    }

    html += '</div>';
    container.innerHTML = html;
  }

  function removeRule(id) {
    const el = document.getElementById(`rule-${id}`);
    if (el) el.remove();
  }

  document.getElementById('btn-add-rule').addEventListener('click', () => addRule());

  document.querySelectorAll('.preset-btn').forEach(btn => {
    btn.addEventListener('click', function () {
      const p = PRESETS[this.dataset.preset];
      if (!p) return;
      document.getElementById('rules-container').innerHTML = '';
      ruleCount = 0;
      p.rules.forEach(r => addRule(r));
      document.getElementById('output-section').classList.add('hidden');
    });
  });

  document.getElementById('btn-generate').addEventListener('click', () => {
    const encryptedRegexGlobal = document.getElementById('global-encrypted-regex').value.trim();
    const unencryptedSuffix = document.getElementById('global-unencrypted-suffix').value.trim();

    let yaml = 'creation_rules:\n';

    const ruleEls = document.querySelectorAll('[id^="rule-"][id$="-path"]');
    if (ruleEls.length === 0) {
      alert('Please add at least one creation rule.');
      return;
    }

    for (const el of ruleEls) {
      const id = el.id.replace('rule-', '').replace('-path', '');
      const path = el.value.trim() || '.*.yaml$';
      const provider = document.getElementById(`rule-${id}-provider`).value;
      const encRegex = document.getElementById(`rule-${id}-encrypted-regex`)?.value?.trim() || '';

      yaml += `  - path_regex: ${path}\n`;

      if (encRegex) yaml += `    encrypted_regex: '${encRegex}'\n`;

      if (provider === 'aws') {
        const arn = document.getElementById(`rule-${id}-aws-arn`)?.value?.trim() || '';
        const role = document.getElementById(`rule-${id}-aws-role`)?.value?.trim() || '';
        const region = document.getElementById(`rule-${id}-aws-region`)?.value?.trim() || 'us-east-1';
        if (arn) {
          yaml += `    kms:\n      - arn: ${arn}\n        aws_profile: default\n`;
          if (role) yaml += `        role: ${role}\n`;
          yaml += `        aws_profile: default\n`;
        }
      } else if (provider === 'gcp') {
        const rid = document.getElementById(`rule-${id}-gcp-id`)?.value?.trim() || '';
        if (rid) yaml += `    gcp_kms:\n      - resource_id: ${rid}\n`;
      } else if (provider === 'azure') {
        const url = document.getElementById(`rule-${id}-azure-url`)?.value?.trim() || '';
        if (url) yaml += `    azure_kv:\n      - vaultUrl: ${url.split('/keys')[0]}\n        name: ${url.split('/keys/')[1]?.split('/')[0] || 'my-key'}\n        version: ${url.split('/').pop() || ''}\n`;
      } else if (provider === 'age') {
        const recipients = document.getElementById(`rule-${id}-age`)?.value?.trim() || '';
        if (recipients) {
          yaml += `    age:\n`;
          recipients.split(',').forEach(r => { if (r.trim()) yaml += `      - ${r.trim()}\n`; });
        }
      } else if (provider === 'pgp') {
        const fps = document.getElementById(`rule-${id}-pgp`)?.value?.trim() || '';
        if (fps) {
          yaml += `    pgp:\n`;
          fps.split(',').forEach(fp => { if (fp.trim()) yaml += `      - ${fp.trim()}\n`; });
        }
      }

      yaml += '\n';
    }

    if (encryptedRegexGlobal) yaml += `\n# Global encrypted regex override\n# encrypted_regex: '${encryptedRegexGlobal}'\n`;
    if (unencryptedSuffix) yaml += `\n# Global unencrypted suffix override\n# unencrypted_suffix: '${unencryptedSuffix}'\n`;

    document.getElementById('sops-output').textContent = yaml.trim();

    const cmds = `# Encrypt a file using .sops.yaml config
sops --encrypt secrets.yaml > secrets.enc.yaml

# Decrypt a file
sops --decrypt secrets.enc.yaml

# Edit encrypted file in-place
sops secrets.enc.yaml

# Encrypt only specific keys (Kubernetes Secret)
sops --encrypt --encrypted-regex '^(data|stringData)$' k8s-secret.yaml > k8s-secret.enc.yaml

# Rotate keys (re-encrypt with new keys)
sops --rotate secrets.enc.yaml

# Generate age key pair
age-keygen -o key.txt

# List encryption metadata
sops --show-master-keys secrets.enc.yaml

# Use with kubectl
kubectl create secret generic my-secret \\
  --from-literal=password=\$(sops -d secrets.yaml | yq .password) \\
  --dry-run=client -o yaml | sops --encrypt -`;

    document.getElementById('cmds-output').textContent = cmds;
    document.getElementById('output-section').classList.remove('hidden');
    document.getElementById('output-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  document.getElementById('copy-sops-btn').addEventListener('click', function () {
    navigator.clipboard.writeText(document.getElementById('sops-output').textContent).then(() => {
      this.textContent = 'Copied!'; setTimeout(() => { this.textContent = 'Copy'; }, 2000);
    });
  });

  // Initialize with AWS preset
  const initPreset = PRESETS.aws;
  initPreset.rules.forEach(r => addRule(r));
</script>
