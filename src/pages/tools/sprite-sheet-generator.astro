---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SpriteSheetGenerator from '../../components/SpriteSheetGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is a sprite sheet and why use one?", answer: "A sprite sheet (or texture atlas) packs multiple images into a single file. Instead of loading 50 separate images, you load one and use CSS background-position or canvas drawImage offsets to show specific parts. This reduces HTTP requests, improves load times, and allows the GPU to batch draw calls efficiently — critical for games and interactive UIs with many animated elements." },
  { question: "What is the difference between spacing and padding?", answer: "Padding is the gap between the sheet edge and the first sprite (also called 'margin'). Spacing (also called 'extrude' or 'inner padding') is the gap between adjacent sprites. Spacing prevents texture bleeding — when GPU bilinear filtering samples pixels from a neighboring sprite causing color artifacts at sprite edges. 1-2px spacing is enough for most cases." },
  { question: "What is texture bleeding and how does spacing fix it?", answer: "Texture bleeding occurs when GPU filtering reads texels (texture pixels) from adjacent sprites. At exact pixel boundaries with bilinear filtering, the GPU averages 2-4 neighboring pixels — including pixels from the wrong sprite. Adding 1-2px spacing (empty pixels between sprites) or 1px extrude (duplicating the sprite edge outward) prevents this sampling from crossing into neighboring sprites." },
  { question: "How does CSS background-position work with sprite sheets?", answer: "Set the element's background-image to the sprite sheet URL and background-size to the sheet dimensions. Then use background-position: -Xpx -Ypx to 'shift' the sheet so the desired sprite aligns to the element. Negative values move the sheet left/up, revealing the sprite at position (X, Y). Set the element width/height to the sprite dimensions." },
  { question: "What is JSON TexturePacker format?", answer: "TexturePacker is a popular sprite sheet tool. Its JSON format is widely supported by Phaser, PixiJS, Cocos2d, and other game engines. Each frame entry contains: frame (x, y, w, h — the source rect in the sheet), sourceSize (original image dimensions), rotated, and trimmed flags. Engines load this JSON alongside the sheet image to know where each named frame lives." },
  { question: "How do I use sprite sheets in Phaser 3?", answer: "Use this.load.spritesheet() in preload to load a uniformly-gridded sheet (all frames same size, optional spacing and margin). Use this.load.atlas() with a JSON file for irregular/packed sheets. Access frames with this.add.sprite(x, y, 'key', frameIndex). Create animations with this.anims.create() specifying frame ranges. Phaser calculates offsets automatically from your config." },
];
---

<BaseLayout
  title="Sprite Sheet Coordinate Generator — CSS, Phaser, Canvas & JSON Output"
  description="Generate sprite sheet coordinates from sheet dimensions and sprite size. Outputs CSS background-position, JavaScript objects, JSON TexturePacker format, Phaser 3 config, and Canvas drawImage code."
  tool="Sprite Sheet Generator, CSS Sprite Coordinates, Phaser Spritesheet Config, TexturePacker JSON, Canvas Sprite Sheet"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Sprite Sheet Coordinate Generator</h1>
  <p class="text-text-muted mb-4">Enter your sprite sheet dimensions and sprite size to auto-calculate every sprite's pixel coordinates. Preview the grid layout and export CSS, JS object, JSON, Phaser 3, or Canvas code.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Visual grid preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CSS / JS / JSON / Phaser / Canvas output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Spacing & padding support</span>
  </div>
  <SpriteSheetGenerator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Sprite Sheet Coordinate Generator" relatedTags={['game-dev', 'css', 'canvas', 'graphics', 'animation']} />
</BaseLayout>
