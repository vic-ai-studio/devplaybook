---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CodeSnippetShare from '../../components/CodeSnippetShare.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Code Snippet Share — Create Shareable Code URLs"
  description="Paste any code snippet and get a shareable URL instantly. No server, no sign-up, no expiry — the snippet is stored in the URL itself. Supports 20+ languages."
  tool="code snippet share, share code URL, code pastebin, code share tool"
>
  <h1 class="text-3xl font-bold mb-2">Code Snippet Share</h1>
  <p class="text-text-muted mb-8">Paste your code and generate a shareable URL instantly. The snippet is encoded directly in the URL — no server, no database, no account needed. Works offline. Share on Slack, Discord, email, or anywhere.</p>
  <CodeSnippetShare client:only="preact" />
  <ToolPageCta currentTool="Code Snippet Share" relatedTags={['share', 'code', 'snippet', 'pastebin', 'url']} />
</BaseLayout>
