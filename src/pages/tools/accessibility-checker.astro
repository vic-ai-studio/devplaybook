---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What WCAG issues does this tool check for?", answer: "This tool checks for structural and semantic HTML accessibility issues: missing alt attributes on images, missing aria-label on interactive elements, unlabeled form inputs, missing lang attribute on the <html> element, broken heading hierarchy (e.g. jumping from h1 to h4), and non-descriptive link text like 'click here' or 'read more'. It does not check color contrast — use the separate Accessibility Color Contrast Checker for that." },
  { question: "What is WCAG and which level should I target?", answer: "WCAG (Web Content Accessibility Guidelines) is the international standard for web accessibility published by the W3C. Level A covers the most critical barriers. Level AA is the most widely required standard (mandated by ADA, EN 301 549, AODA). Level AAA is the highest and not required for most sites. Unless you have a specific legal requirement for AAA, target AA compliance as your baseline." },
  { question: "Why do images need alt attributes?", answer: "Screen readers announce images by reading their alt text to visually impaired users. An image without an alt attribute causes screen readers to read out the file name instead (e.g. 'img_banner_v3_final_FINAL2.jpg'), which is disorienting. If an image is purely decorative, use alt='' (empty string) to tell screen readers to skip it entirely. Never omit the attribute altogether." },
  { question: "What is an aria-label and when do I need one?", answer: "The aria-label attribute provides an accessible name for elements that lack visible text — most commonly icon buttons, hamburger menus, and social media links. For example, a button that only contains an SVG icon should have aria-label='Open navigation menu' so screen reader users know what it does. Without it, the button is announced as just 'button', which is useless." },
  { question: "Why does heading hierarchy matter for accessibility?", answer: "Screen reader users often navigate pages by jumping between headings, similar to how sighted users scan visually. Skipping heading levels (e.g. going from h1 straight to h3) breaks this navigation and creates confusion about the page structure. Each page should have exactly one h1, and headings should nest logically: h1 > h2 > h3. Never choose heading levels for their visual size — use CSS for styling instead." },
  { question: "What makes a good accessible link?", answer: "Link text should describe the destination or action when read out of context. Phrases like 'click here', 'read more', 'learn more', or 'this link' are inaccessible because screen reader users can pull up a list of all links on the page — and a list of 'click here, click here, click here' conveys nothing. Instead use descriptive text like 'Read our accessibility guide' or 'Download the 2026 report'." },
];
---

<BaseLayout
  title="HTML Accessibility Checker — WCAG A11y Hints & Issues Detector"
  description="Paste any HTML snippet to check for accessibility issues: missing alt text, aria labels, form labels, heading hierarchy, link text, and lang attribute. Get WCAG fix suggestions."
  tool="HTML Accessibility Checker, WCAG Checker, A11y HTML Validator, Missing Alt Text Detector, Aria Label Checker, Heading Hierarchy Checker"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">HTML Accessibility Checker</h1>
  <p class="text-text-muted mb-4">Paste an HTML snippet to check for WCAG accessibility issues. Detects missing alt text, aria labels, form labels, heading hierarchy problems, non-descriptive links, and more.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> WCAG 2.1 checks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Error / warning / info severity</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Fix suggestions per issue</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No data sent to server</span>
  </div>

  <!-- Input -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-base font-semibold">HTML Snippet</h2>
      <div class="flex gap-2">
        <button id="load-example" class="text-xs px-3 py-1.5 bg-bg-surface border border-border rounded-lg hover:border-primary hover:text-primary transition-colors">Load Example</button>
        <button id="clear-btn" class="text-xs px-3 py-1.5 bg-bg-surface border border-border rounded-lg hover:border-primary hover:text-primary transition-colors">Clear</button>
      </div>
    </div>
    <textarea
      id="html-input"
      class="w-full h-52 bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary resize-y"
      placeholder="Paste your HTML here — e.g. a page section, navigation, form, or article..."
      spellcheck="false"
    ></textarea>
    <button id="check-btn" class="mt-3 bg-primary text-white px-5 py-2 rounded-lg hover:bg-primary/90 transition-colors text-sm font-medium">
      Check Accessibility
    </button>
  </div>

  <!-- Results -->
  <div id="results-container" class="hidden">
    <!-- Summary bar -->
    <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
      <div class="flex flex-wrap items-center gap-4">
        <h2 class="text-base font-semibold">Results</h2>
        <div class="flex gap-3 text-sm ml-auto">
          <span id="count-error" class="flex items-center gap-1.5 px-3 py-1 rounded-lg bg-red-500/10 text-red-500 font-medium">0 Errors</span>
          <span id="count-warning" class="flex items-center gap-1.5 px-3 py-1 rounded-lg bg-yellow-500/10 text-yellow-500 font-medium">0 Warnings</span>
          <span id="count-info" class="flex items-center gap-1.5 px-3 py-1 rounded-lg bg-blue-500/10 text-blue-500 font-medium">0 Info</span>
        </div>
      </div>
    </div>

    <!-- Issue list -->
    <div id="issues-list" class="space-y-3 mb-5"></div>

    <!-- All-clear message -->
    <div id="all-clear" class="hidden bg-green-500/10 border border-green-500/30 rounded-xl p-5 mb-5 text-center">
      <div class="text-2xl mb-2">✓</div>
      <p class="text-green-500 font-semibold">No accessibility issues detected!</p>
      <p class="text-text-muted text-sm mt-1">This snippet passes all checks in this tool. Remember to also test with a real screen reader and check color contrast separately.</p>
    </div>

    <!-- Export -->
    <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-base font-semibold">Issue Summary (text)</h2>
        <button id="copy-report" class="text-xs px-3 py-1.5 bg-bg-surface border border-border rounded-lg hover:border-primary hover:text-primary transition-colors">Copy Report</button>
      </div>
      <pre id="report-text" class="font-mono text-sm bg-bg-surface rounded-lg p-4 overflow-x-auto text-text-muted whitespace-pre-wrap"></pre>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="accessibility-checker" relatedTags={['accessibility', 'wcag', 'a11y', 'html', 'frontend']} />
</BaseLayout>

<script>
const EXAMPLE_HTML = `<!DOCTYPE html>
<html>
<head><title>Example Page</title></head>
<body>
  <nav>
    <button><svg viewBox="0 0 24 24"><path d="M3 12h18"/></svg></button>
    <a href="/about">About</a>
    <a href="/blog">Click here</a>
  </nav>
  <main>
    <h1>Welcome to Our Site</h1>
    <img src="hero.jpg">
    <h4>Our Features</h4>
    <ul>
      <li><a href="/more">Read more</a></li>
    </ul>
    <form>
      <input type="email" placeholder="Enter email">
      <input type="text" placeholder="Your name">
      <button type="submit">Submit</button>
    </form>
    <img src="decorative-wave.svg" alt="">
  </main>
</body>
</html>`;

const BAD_LINK_TEXT = ['click here', 'read more', 'here', 'more', 'this', 'link', 'this link', 'learn more', 'click', 'go', 'continue'];

function runChecks(htmlString) {
  const issues = [];
  const parser = new DOMParser();
  const doc = parser.parseFromString(htmlString, 'text/html');

  // 1. lang attribute on <html>
  const htmlEl = doc.querySelector('html');
  if (!htmlEl || !htmlEl.hasAttribute('lang') || htmlEl.getAttribute('lang').trim() === '') {
    issues.push({
      severity: 'error',
      rule: 'WCAG 3.1.1',
      title: 'Missing lang attribute on <html>',
      detail: 'The <html> element must have a lang attribute so screen readers can use the correct language and pronunciation engine.',
      fix: 'Add lang="en" (or the appropriate language code) to your <html> tag: <html lang="en">',
    });
  }

  // 2. Images missing alt
  doc.querySelectorAll('img').forEach(img => {
    if (!img.hasAttribute('alt')) {
      const src = img.getAttribute('src') || '(no src)';
      issues.push({
        severity: 'error',
        rule: 'WCAG 1.1.1',
        title: 'Image missing alt attribute',
        detail: `<img src="${src.slice(0, 60)}"> has no alt attribute. Screen readers will read out the filename instead.`,
        fix: 'Add alt="description of image" for informational images, or alt="" (empty) for decorative ones.',
      });
    }
  });

  // 3. Buttons with no accessible name
  doc.querySelectorAll('button, [role="button"]').forEach(btn => {
    const text = btn.textContent.trim();
    const ariaLabel = btn.getAttribute('aria-label') || '';
    const ariaLabelledBy = btn.getAttribute('aria-labelledby') || '';
    const title = btn.getAttribute('title') || '';
    if (!text && !ariaLabel && !ariaLabelledBy && !title) {
      issues.push({
        severity: 'error',
        rule: 'WCAG 4.1.2',
        title: 'Button has no accessible name',
        detail: 'A button contains no text and no aria-label. Screen readers will announce it as just "button" with no context.',
        fix: 'Add aria-label="Describe the action" to the button, e.g. aria-label="Open navigation menu".',
      });
    }
  });

  // 4. Form inputs missing labels
  doc.querySelectorAll('input:not([type="hidden"]):not([type="submit"]):not([type="button"]):not([type="reset"]), textarea, select').forEach(input => {
    const id = input.getAttribute('id') || '';
    const ariaLabel = input.getAttribute('aria-label') || '';
    const ariaLabelledBy = input.getAttribute('aria-labelledby') || '';
    const title = input.getAttribute('title') || '';
    const hasLabel = id && doc.querySelector(`label[for="${id}"]`);
    const isWrapped = input.closest('label');
    if (!hasLabel && !isWrapped && !ariaLabel && !ariaLabelledBy && !title) {
      const type = input.tagName.toLowerCase() === 'input' ? `input[type="${input.getAttribute('type') || 'text'}"]` : input.tagName.toLowerCase();
      issues.push({
        severity: 'error',
        rule: 'WCAG 1.3.1 / 3.3.2',
        title: `Form field (${type}) has no label`,
        detail: `A form field with placeholder="${input.getAttribute('placeholder') || ''}" has no associated <label>. Placeholder text is not a substitute for a label.`,
        fix: 'Add a <label for="inputId">Label text</label> and matching id="inputId" on the input, or wrap the input inside a <label>.',
      });
    }
  });

  // 5. Non-descriptive link text
  doc.querySelectorAll('a[href]').forEach(a => {
    const text = a.textContent.trim().toLowerCase();
    const ariaLabel = (a.getAttribute('aria-label') || '').trim();
    if (!ariaLabel && BAD_LINK_TEXT.includes(text)) {
      issues.push({
        severity: 'warning',
        rule: 'WCAG 2.4.4',
        title: `Non-descriptive link text: "${a.textContent.trim()}"`,
        detail: `Links with text like "${a.textContent.trim()}" are meaningless when read out of context by screen readers that list all page links.`,
        fix: `Replace with descriptive text, e.g. "Read our accessibility guide" or add aria-label="Read our accessibility guide" to the <a> tag.`,
      });
    }
  });

  // 6. Heading hierarchy
  const headings = Array.from(doc.querySelectorAll('h1,h2,h3,h4,h5,h6'));
  const h1Count = headings.filter(h => h.tagName === 'H1').length;
  if (h1Count === 0 && headings.length > 0) {
    issues.push({
      severity: 'warning',
      rule: 'WCAG 1.3.1',
      title: 'No <h1> heading found',
      detail: 'Every page should have exactly one <h1> that describes the main topic. It is the top of the heading hierarchy.',
      fix: 'Add an <h1> that describes the main content of this page or section.',
    });
  }
  if (h1Count > 1) {
    issues.push({
      severity: 'warning',
      rule: 'WCAG 1.3.1',
      title: `Multiple <h1> headings (${h1Count} found)`,
      detail: 'There should be exactly one <h1> per page. Multiple h1s confuse the document structure for screen readers.',
      fix: 'Keep one <h1> for the main page title and convert the others to <h2> or lower.',
    });
  }
  let prevLevel = 0;
  headings.forEach(h => {
    const level = parseInt(h.tagName[1]);
    if (prevLevel > 0 && level > prevLevel + 1) {
      issues.push({
        severity: 'warning',
        rule: 'WCAG 1.3.1',
        title: `Heading level skipped: <h${prevLevel}> → <h${level}>`,
        detail: `Jumping from h${prevLevel} to h${level} skips a level. Screen reader users navigating by heading will miss structural context.`,
        fix: `Change <h${level}> to <h${prevLevel + 1}>, or add intermediate headings to bridge the hierarchy.`,
      });
    }
    prevLevel = level;
  });

  // 7. Links with no href or javascript:void
  doc.querySelectorAll('a').forEach(a => {
    const href = a.getAttribute('href') || '';
    if (!href || href === '#' || href.startsWith('javascript:')) {
      issues.push({
        severity: 'info',
        rule: 'WCAG 2.1.1',
        title: `Link with non-navigational href: "${href || '(empty)'}"`,
        detail: 'Links with href="#" or javascript:void(0) behave like buttons but are announced as links. This confuses keyboard and screen reader users.',
        fix: 'If this element triggers an action, change it to a <button>. If it navigates, provide a real URL.',
      });
    }
  });

  return issues;
}

function severityColor(s) {
  if (s === 'error') return { bg: 'bg-red-500/10', border: 'border-red-500/30', badge: 'bg-red-500 text-white', text: 'text-red-500' };
  if (s === 'warning') return { bg: 'bg-yellow-500/10', border: 'border-yellow-500/30', badge: 'bg-yellow-500 text-white', text: 'text-yellow-500' };
  return { bg: 'bg-blue-500/10', border: 'border-blue-500/30', badge: 'bg-blue-500 text-white', text: 'text-blue-500' };
}

function renderIssues(issues) {
  const container = document.getElementById('results-container');
  const list = document.getElementById('issues-list');
  const allClear = document.getElementById('all-clear');
  container.classList.remove('hidden');

  const errors = issues.filter(i => i.severity === 'error').length;
  const warnings = issues.filter(i => i.severity === 'warning').length;
  const infos = issues.filter(i => i.severity === 'info').length;

  document.getElementById('count-error').textContent = `${errors} Error${errors !== 1 ? 's' : ''}`;
  document.getElementById('count-warning').textContent = `${warnings} Warning${warnings !== 1 ? 's' : ''}`;
  document.getElementById('count-info').textContent = `${infos} Info`;

  if (issues.length === 0) {
    list.innerHTML = '';
    allClear.classList.remove('hidden');
  } else {
    allClear.classList.add('hidden');
    list.innerHTML = issues.map(issue => {
      const c = severityColor(issue.severity);
      return `
        <div class="${c.bg} border ${c.border} rounded-xl p-4">
          <div class="flex items-start gap-3">
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold ${c.badge} shrink-0 mt-0.5">${issue.severity.toUpperCase()}</span>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="font-medium text-sm">${issue.title}</span>
                <span class="text-xs text-text-muted">${issue.rule}</span>
              </div>
              <p class="text-sm text-text-muted mt-1">${issue.detail}</p>
              <p class="text-sm mt-2"><span class="font-medium">Fix:</span> ${issue.fix}</p>
            </div>
          </div>
        </div>
      `;
    }).join('');
  }

  const reportLines = issues.length === 0
    ? ['No accessibility issues found.']
    : issues.map((i, idx) => `${idx + 1}. [${i.severity.toUpperCase()}] ${i.rule} — ${i.title}\n   Detail: ${i.detail}\n   Fix: ${i.fix}`);
  document.getElementById('report-text').textContent = reportLines.join('\n\n');
}

document.getElementById('check-btn').addEventListener('click', () => {
  const html = document.getElementById('html-input').value.trim();
  if (!html) return;
  const issues = runChecks(html);
  renderIssues(issues);
});

document.getElementById('load-example').addEventListener('click', () => {
  document.getElementById('html-input').value = EXAMPLE_HTML;
});

document.getElementById('clear-btn').addEventListener('click', () => {
  document.getElementById('html-input').value = '';
  document.getElementById('results-container').classList.add('hidden');
});

document.getElementById('copy-report').addEventListener('click', () => {
  const text = document.getElementById('report-text').textContent;
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.getElementById('copy-report');
    const orig = btn.textContent;
    btn.textContent = 'Copied!';
    btn.classList.add('text-green-500', 'border-green-500');
    setTimeout(() => { btn.textContent = orig; btn.classList.remove('text-green-500', 'border-green-500'); }, 1500);
  });
});
</script>
