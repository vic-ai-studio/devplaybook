---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CursorRulesGenerator from '../../components/CursorRulesGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a .cursorrules file?",
    answer: ".cursorrules is a configuration file for Cursor IDE that tells the AI assistant how to behave in your project. It defines coding conventions, language rules, testing expectations, and project-specific behaviors. When present in your project root, Cursor automatically applies these rules to every AI interaction in the project."
  },
  {
    question: "Where should I place the .cursorrules file?",
    answer: "Place .cursorrules in the root of your project (same directory as package.json, go.mod, or Cargo.toml). Cursor automatically detects and applies it. For monorepos, you can place separate .cursorrules files in each package directory — Cursor uses the nearest one."
  },
  {
    question: "What's the difference between global and project-level rules?",
    answer: "Global rules (set in Cursor Settings → AI → Custom Instructions) apply to every project. Project-level .cursorrules only apply when Cursor is opened in that specific project directory. Project rules take precedence and are ideal for framework-specific conventions, while global rules are good for universal preferences like response language or verbosity."
  },
  {
    question: "How do I test if my .cursorrules is working?",
    answer: "Open Cursor's AI panel and ask a question about your codebase. The AI should reflect your rules in its suggestions. You can also check Cursor Settings → AI to see if the file is being detected. If rules aren't applying, make sure the file is named exactly .cursorrules (dot prefix, no extension) and is in the project root."
  },
  {
    question: "Can I use .cursorrules with Claude or GPT-4?",
    answer: "Yes — .cursorrules works across all AI models available in Cursor (GPT-4, Claude 3.5 Sonnet, Gemini, etc.). The rules are injected as system context regardless of which model you select. Some rules may be more reliably followed by larger models."
  },
];
---

<BaseLayout
  title="Cursor Rules Generator — Generate .cursorrules for Your Project"
  description="Generate a .cursorrules file for Cursor IDE instantly. Select your project type (Next.js, Python, Go, Rust), coding style, and testing framework. Download or copy the config directly."
  tool="Cursor Rules Generator, .cursorrules file generator, Cursor IDE config, AI coding rules, cursorrules template"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Cursor Rules Generator",
    "url": "https://devplaybook.cc/tools/cursor-rules-generator",
    "description": "Generate .cursorrules configuration files for Cursor IDE. Select project type, coding style, and AI behavior preferences.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Cursor Rules Generator</h1>
  <p class="text-text-muted mb-4">
    Generate a <code class="font-mono text-sm bg-bg-card px-1 rounded">.cursorrules</code> file for Cursor IDE. Configure project type, coding style, testing framework, and custom AI behavior rules — then download the file directly to your project root.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 8 project types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Custom AI behaviors</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Download-ready .cursorrules</span>
  </div>
  <CursorRulesGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Cursor Rules Generator" relatedTags={['ai', 'cursor', 'developer-tools', 'productivity', 'llm']} />
</BaseLayout>
