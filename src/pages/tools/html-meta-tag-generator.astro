---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What are Open Graph meta tags?", answer: "Open Graph (OG) tags are meta tags that control how your page looks when shared on social networks like Facebook, LinkedIn, and Slack. They define the title, description, image, and URL shown in link previews. They were created by Facebook but are now widely adopted across the web. The most important are og:title, og:description, og:image, and og:url." },
  { question: "What is the difference between Twitter Cards and Open Graph?", answer: "Twitter has its own card system (twitter:card, twitter:title, etc.) but it falls back to Open Graph tags if Twitter-specific tags aren't present. Twitter supports four card types: summary (small image), summary_large_image (wide banner image), app (app store links), and player (video/audio). Use summary_large_image for most content pages for maximum visual impact." },
  { question: "What size should my OG image be?", answer: "For Open Graph: 1200×630 pixels at a 1.91:1 ratio is the recommended size. This works on Facebook, LinkedIn, and most platforms. Minimum is 600×315px. For Twitter summary_large_image, 1200×600px works well. Always use HTTPS for image URLs. Keep images under 8MB (Facebook) or 5MB (Twitter)." },
  { question: "Do I need canonical tags too?", answer: "Yes — the canonical link tag (<link rel=\"canonical\" href=\"...\"/>) tells search engines which URL is the authoritative version of a page, preventing duplicate content issues. It's separate from meta tags but equally important for SEO. This generator includes the og:url tag which serves a similar purpose for social sharing." },
  { question: "What is the robots meta tag?", answer: "The robots meta tag controls how search engine crawlers index your page. Common values: 'index, follow' (default — crawl and follow links), 'noindex, follow' (don't index this page but follow links), 'noindex, nofollow' (block completely), 'index, nofollow' (index but don't follow links). Use noindex for staging pages, thank-you pages, and duplicate content." },
  { question: "How do I test my meta tags?", answer: "Use these tools to preview and validate: Facebook Sharing Debugger (developers.facebook.com/tools/debug/), Twitter Card Validator (cards-dev.twitter.com/validator), LinkedIn Post Inspector (linkedin.com/post-inspector/), and Google Rich Results Test (search.google.com/test/rich-results). Always clear the cache in these tools after updating your tags." },
];
---

<BaseLayout
  title="HTML Meta Tag Generator — OG, Twitter Card, SEO Meta Tags"
  description="Generate complete HTML head meta tags including Open Graph, Twitter Card, SEO, robots, and canonical tags. Fill in your details and copy the full head snippet instantly."
  tool="HTML Meta Tag Generator, Open Graph Generator, Twitter Card Generator, SEO Meta Tags, OG Tag Generator, Social Media Meta Tags"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "HTML Meta Tag Generator",
    "description": "Generate HTML meta tags for SEO, Open Graph, and Twitter Cards instantly.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">HTML Meta Tag Generator</h1>
  <p class="text-text-muted mb-4">Generate a complete HTML <code class="font-mono text-sm">&lt;head&gt;</code> snippet with SEO meta tags, Open Graph, Twitter Card, robots directives, and canonical URLs — all in one click.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Open Graph (OG)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Twitter Cards</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> SEO + robots</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Canonical URL</span>
  </div>

  <!-- Form -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-5">
    <!-- Basic SEO -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="text-base font-semibold mb-4">Page Information</h2>
      <div class="space-y-3">
        <div>
          <label class="block text-sm font-medium mb-1.5" for="meta-title">Page Title <span class="text-text-muted font-normal text-xs">(50-60 chars ideal)</span></label>
          <input id="meta-title" type="text" placeholder="My Awesome Page Title"
            value="My Page Title"
            class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
          <div class="text-xs text-text-muted mt-1"><span id="title-count">14</span> characters</div>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5" for="meta-desc">Description <span class="text-text-muted font-normal text-xs">(150-160 chars ideal)</span></label>
          <textarea id="meta-desc" rows="3" placeholder="A concise description of this page for search engines and social sharing."
            class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary resize-none">A concise description of this page for search engines and social sharing.</textarea>
          <div class="text-xs text-text-muted mt-1"><span id="desc-count">71</span> characters</div>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5" for="meta-url">Canonical URL</label>
          <input id="meta-url" type="url" placeholder="https://example.com/page"
            value="https://example.com/page"
            class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5" for="meta-keywords">Keywords <span class="text-text-muted font-normal text-xs">(comma-separated, optional)</span></label>
          <input id="meta-keywords" type="text" placeholder="keyword1, keyword2, keyword3"
            class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5" for="meta-robots">Robots</label>
          <select id="meta-robots" class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
            <option value="index, follow" selected>index, follow (default)</option>
            <option value="noindex, follow">noindex, follow</option>
            <option value="index, nofollow">index, nofollow</option>
            <option value="noindex, nofollow">noindex, nofollow (block)</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5" for="meta-author">Author <span class="text-text-muted font-normal text-xs">(optional)</span></label>
          <input id="meta-author" type="text" placeholder="Your Name or Brand"
            class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
      </div>
    </div>

    <!-- OG + Twitter -->
    <div class="space-y-4">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Open Graph + Social</h2>
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium mb-1.5" for="og-image">Image URL <span class="text-text-muted font-normal text-xs">(1200×630px recommended)</span></label>
            <input id="og-image" type="url" placeholder="https://example.com/og-image.jpg"
              value="https://example.com/og-image.jpg"
              class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5" for="og-type">OG Type</label>
            <select id="og-type" class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="website" selected>website</option>
              <option value="article">article</option>
              <option value="product">product</option>
              <option value="profile">profile</option>
              <option value="video.other">video</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5" for="og-site-name">Site Name</label>
            <input id="og-site-name" type="text" placeholder="My Website"
              value="My Website"
              class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5" for="og-locale">Locale</label>
            <select id="og-locale" class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="en_US" selected>en_US</option>
              <option value="en_GB">en_GB</option>
              <option value="zh_TW">zh_TW</option>
              <option value="zh_CN">zh_CN</option>
              <option value="ja_JP">ja_JP</option>
              <option value="ko_KR">ko_KR</option>
              <option value="fr_FR">fr_FR</option>
              <option value="de_DE">de_DE</option>
              <option value="es_ES">es_ES</option>
            </select>
          </div>
        </div>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Twitter Card</h2>
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium mb-1.5" for="tw-card">Card Type</label>
            <select id="tw-card" class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="summary_large_image" selected>summary_large_image (recommended)</option>
              <option value="summary">summary</option>
              <option value="app">app</option>
              <option value="player">player</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5" for="tw-site">Twitter @site <span class="text-text-muted font-normal text-xs">(optional)</span></label>
            <input id="tw-site" type="text" placeholder="@yoursite"
              class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5" for="tw-creator">Twitter @creator <span class="text-text-muted font-normal text-xs">(optional)</span></label>
            <input id="tw-creator" type="text" placeholder="@author"
              class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Options toggles -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-3">Include Sections</h2>
    <div class="flex flex-wrap gap-4">
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <input id="inc-charset" type="checkbox" checked class="w-4 h-4 accent-primary" /> charset + viewport
      </label>
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <input id="inc-og" type="checkbox" checked class="w-4 h-4 accent-primary" /> Open Graph
      </label>
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <input id="inc-tw" type="checkbox" checked class="w-4 h-4 accent-primary" /> Twitter Card
      </label>
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <input id="inc-canonical" type="checkbox" checked class="w-4 h-4 accent-primary" /> Canonical link
      </label>
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <input id="inc-robots" type="checkbox" checked class="w-4 h-4 accent-primary" /> Robots
      </label>
    </div>
  </div>

  <!-- Output -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-base font-semibold">Generated HTML</h2>
      <button id="copy-html-btn" class="text-xs px-3 py-1.5 bg-bg-surface border border-border rounded-lg hover:border-primary hover:text-primary transition-colors">Copy HTML</button>
    </div>
    <pre id="html-output" class="font-mono text-sm bg-bg-surface rounded-lg p-4 overflow-x-auto text-text-muted whitespace-pre"></pre>
  </div>

  <!-- Social Preview -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-3">Social Preview</h2>
    <div class="max-w-sm border border-border rounded-xl overflow-hidden">
      <div id="preview-img-wrap" class="w-full h-40 bg-bg-surface flex items-center justify-center text-text-muted text-xs">
        <span>Image preview</span>
      </div>
      <div class="p-3 bg-bg-surface border-t border-border">
        <div id="preview-site" class="text-xs text-text-muted uppercase mb-1">example.com</div>
        <div id="preview-title" class="text-sm font-semibold leading-snug mb-1">My Page Title</div>
        <div id="preview-desc" class="text-xs text-text-muted leading-relaxed line-clamp-2">A concise description of this page...</div>
      </div>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="HTML Meta Tag Generator" relatedTags={['html', 'seo', 'meta-tags', 'og', 'twitter-card', 'frontend']} />
</BaseLayout>

<script>
  function esc(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function raw(s) { return s.replace(/"/g,'&quot;'); }
  function gv(id) { return document.getElementById(id).value.trim(); }
  function gc(id) { return document.getElementById(id).checked; }

  function getHostname(url) {
    try { return new URL(url).hostname; } catch(e) { return url; }
  }

  function generate() {
    var title = gv('meta-title');
    var desc = gv('meta-desc');
    var url = gv('meta-url');
    var keywords = gv('meta-keywords');
    var robots = gv('meta-robots');
    var author = gv('meta-author');
    var ogImage = gv('og-image');
    var ogType = gv('og-type');
    var ogSiteName = gv('og-site-name');
    var ogLocale = gv('og-locale');
    var twCard = gv('tw-card');
    var twSite = gv('tw-site');
    var twCreator = gv('tw-creator');

    var incCharset = gc('inc-charset');
    var incOg = gc('inc-og');
    var incTw = gc('inc-tw');
    var incCanonical = gc('inc-canonical');
    var incRobots = gc('inc-robots');

    var lines = [];

    if (incCharset) {
      lines.push('<meta charset="UTF-8">');
      lines.push('<meta name="viewport" content="width=device-width, initial-scale=1.0">');
      lines.push('');
    }

    // Basic SEO
    lines.push('<!-- Primary Meta Tags -->');
    if (title) lines.push('<title>' + esc(title) + '</title>');
    if (title) lines.push('<meta name="title" content="' + raw(title) + '">');
    if (desc) lines.push('<meta name="description" content="' + raw(desc) + '">');
    if (keywords) lines.push('<meta name="keywords" content="' + raw(keywords) + '">');
    if (author) lines.push('<meta name="author" content="' + raw(author) + '">');
    if (incRobots && robots !== 'index, follow') {
      lines.push('<meta name="robots" content="' + raw(robots) + '">');
    } else if (incRobots) {
      lines.push('<meta name="robots" content="index, follow">');
    }
    if (incCanonical && url) {
      lines.push('<link rel="canonical" href="' + raw(url) + '">');
    }

    if (incOg) {
      lines.push('');
      lines.push('<!-- Open Graph / Facebook -->');
      lines.push('<meta property="og:type" content="' + ogType + '">');
      if (url) lines.push('<meta property="og:url" content="' + raw(url) + '">');
      if (title) lines.push('<meta property="og:title" content="' + raw(title) + '">');
      if (desc) lines.push('<meta property="og:description" content="' + raw(desc) + '">');
      if (ogImage) lines.push('<meta property="og:image" content="' + raw(ogImage) + '">');
      if (ogSiteName) lines.push('<meta property="og:site_name" content="' + raw(ogSiteName) + '">');
      if (ogLocale) lines.push('<meta property="og:locale" content="' + ogLocale + '">');
    }

    if (incTw) {
      lines.push('');
      lines.push('<!-- Twitter -->');
      lines.push('<meta name="twitter:card" content="' + twCard + '">');
      if (url) lines.push('<meta name="twitter:url" content="' + raw(url) + '">');
      if (title) lines.push('<meta name="twitter:title" content="' + raw(title) + '">');
      if (desc) lines.push('<meta name="twitter:description" content="' + raw(desc) + '">');
      if (ogImage) lines.push('<meta name="twitter:image" content="' + raw(ogImage) + '">');
      if (twSite) lines.push('<meta name="twitter:site" content="' + raw(twSite) + '">');
      if (twCreator) lines.push('<meta name="twitter:creator" content="' + raw(twCreator) + '">');
    }

    document.getElementById('html-output').textContent = lines.join('\n');

    // Preview
    document.getElementById('preview-site').textContent = url ? getHostname(url) : 'example.com';
    document.getElementById('preview-title').textContent = title || 'Page Title';
    document.getElementById('preview-desc').textContent = desc || '';
    var imgWrap = document.getElementById('preview-img-wrap');
    if (ogImage) {
      imgWrap.innerHTML = '<img src="' + raw(ogImage) + '" alt="OG preview" class="w-full h-full object-cover" onerror="this.parentElement.innerHTML=\'<span class=text-xs text-text-muted>Image not accessible in preview</span>\'" />';
    } else {
      imgWrap.innerHTML = '<span class="text-xs text-text-muted">No image URL</span>';
    }
  }

  // Character counters
  document.getElementById('meta-title').addEventListener('input', function() {
    document.getElementById('title-count').textContent = this.value.length;
    generate();
  });
  document.getElementById('meta-desc').addEventListener('input', function() {
    document.getElementById('desc-count').textContent = this.value.length;
    generate();
  });

  var inputIds = ['meta-url','meta-keywords','meta-robots','meta-author','og-image','og-type','og-site-name','og-locale','tw-card','tw-site','tw-creator'];
  inputIds.forEach(function(id) {
    document.getElementById(id).addEventListener('input', generate);
    document.getElementById(id).addEventListener('change', generate);
  });

  var checkIds = ['inc-charset','inc-og','inc-tw','inc-canonical','inc-robots'];
  checkIds.forEach(function(id) {
    document.getElementById(id).addEventListener('change', generate);
  });

  document.getElementById('copy-html-btn').addEventListener('click', function() {
    var text = document.getElementById('html-output').textContent;
    navigator.clipboard.writeText(text).then(function() {
      document.getElementById('copy-html-btn').textContent = 'Copied!';
      setTimeout(function() { document.getElementById('copy-html-btn').textContent = 'Copy HTML'; }, 2000);
    });
  });

  generate();
</script>
