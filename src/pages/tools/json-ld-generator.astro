---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonLdGenerator from '../../components/JsonLdGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is JSON-LD and why does it matter for SEO?",
    answer: "JSON-LD (JavaScript Object Notation for Linked Data) is Google's preferred format for structured data markup. It tells search engines what your content is about — enabling rich results like star ratings, FAQ dropdowns, breadcrumb trails, and product pricing directly in search results. Rich results can significantly increase click-through rates (CTR)."
  },
  {
    question: "Where do I place the JSON-LD script tag?",
    answer: "Place the <script type=\"application/ld+json\"> tag inside the <head> section of your HTML page. Google can also read it in the <body>, but <head> is the best practice. You can have multiple JSON-LD blocks on a single page for different schema types."
  },
  {
    question: "Which schema type should I use?",
    answer: "Article: for blog posts and news articles. Product: for e-commerce pages with pricing and reviews. Organization: for your company homepage. FAQPage: for any page with Q&A content — enables FAQ rich results in search. BreadcrumbList: for navigation hierarchy — shows the full path in Google search results."
  },
  {
    question: "How do I test if my structured data is valid?",
    answer: "Use Google's Rich Results Test (search.google.com/test/rich-results) — paste your URL or HTML to see if Google can parse the markup and which rich result types are eligible. The Schema Markup Validator (validator.schema.org) checks for schema.org compliance. Google Search Console also reports structured data errors."
  },
  {
    question: "Does structured data directly affect rankings?",
    answer: "Not directly. Structured data does not change your page's ranking position. However, it enables rich results (star ratings, FAQ dropdowns, etc.) which can dramatically improve CTR — more clicks means more traffic without ranking changes. For some verticals like recipes, products, and events, appearing in carousels requires structured data."
  },
  {
    question: "Can I have multiple schema types on one page?",
    answer: "Yes. Many pages benefit from combining types — a blog post can have Article + BreadcrumbList + FAQPage. Use separate <script type=\"application/ld+json\"> blocks for each type, or combine them into an array: [{\"@type\": \"Article\", ...}, {\"@type\": \"BreadcrumbList\", ...}]. Google handles both approaches."
  },
];
---

<BaseLayout
  title="JSON-LD Schema Generator — Structured Data Markup for SEO"
  description="Generate valid JSON-LD structured data for SEO. Supports Article, Product, Organization, FAQPage, and BreadcrumbList schema types. Visual form with live JSON-LD preview and copy-ready script tag. No sign-up required."
  tool="JSON-LD Generator, Structured Data Generator, Schema Markup Tool, SEO Schema Generator, Rich Snippets Generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "JSON-LD Schema Generator",
    "url": "https://devplaybook.cc/tools/json-ld-generator",
    "description": "Generate valid JSON-LD structured data markup for SEO. Supports Article, Product, Organization, FAQPage, and BreadcrumbList schema types.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">JSON-LD Schema Generator</h1>
  <p class="text-text-muted mb-4">
    Generate structured data markup to unlock Google rich results — star ratings, FAQ dropdowns, breadcrumbs, and more.
    Fill in the form, get a valid <code class="font-mono bg-surface px-1 rounded text-sm">application/ld+json</code> block ready to paste into your <code class="font-mono bg-surface px-1 rounded text-sm">&lt;head&gt;</code>.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 schema types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live JSON-LD preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-ready &lt;script&gt; tag</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Google Rich Results ready</span>
  </div>
  <JsonLdGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="JSON-LD Schema Generator" relatedTags={['seo', 'structured-data', 'schema', 'json', 'google']} />
</BaseLayout>
