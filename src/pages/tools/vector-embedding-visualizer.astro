---
import BaseLayout from '../../layouts/BaseLayout.astro';
import VectorEmbeddingVisualizer from '../../components/VectorEmbeddingVisualizer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What are text embeddings?",
    answer: "Text embeddings are dense numerical vectors that represent the semantic meaning of text. Each word or sentence is mapped to a point in high-dimensional space (e.g., 1536 dimensions for OpenAI text-embedding-3-small) where semantically similar texts cluster together. 'King' and 'monarch' have similar vectors even though they share no characters. This tool uses TF-IDF vectors as a browser-side approximation."
  },
  {
    question: "What is PCA and why use it for visualization?",
    answer: "PCA (Principal Component Analysis) is a dimensionality reduction technique that finds the 2 directions of maximum variance in high-dimensional data and projects all points onto those axes. This preserves as much of the original structure as possible in 2D. Points that are close in the original high-dimensional space tend to be close in the PCA projection. Other methods like t-SNE and UMAP often reveal more cluster structure but require more computation."
  },
  {
    question: "What is cosine similarity?",
    answer: "Cosine similarity measures the angle between two vectors, ignoring their magnitude. A score of 1.0 means vectors point in the same direction (identical semantic content). A score of 0.0 means they're perpendicular (unrelated topics). Unlike Euclidean distance, cosine similarity is length-invariant — a short tweet and a long article about the same topic can have high similarity. Scores above 0.5 typically indicate meaningful semantic overlap."
  },
  {
    question: "How does TF-IDF differ from neural embeddings?",
    answer: "TF-IDF (Term Frequency-Inverse Document Frequency) creates sparse vectors based on word frequency, weighted by how rare the word is across all documents. It's fast and runs in your browser, but it only detects shared vocabulary — it cannot understand synonyms, context, or language nuances. Neural embeddings from models like OpenAI text-embedding-3-large or Sentence Transformers capture these deeper relationships using transformer architectures trained on billions of documents."
  },
  {
    question: "How do I use real neural embeddings?",
    answer: "For production use: (1) OpenAI: POST to /v1/embeddings with model='text-embedding-3-small' or 'text-embedding-3-large', (2) Anthropic: use the /v1/embeddings endpoint, (3) HuggingFace: use sentence-transformers (all-MiniLM-L6-v2 is a popular small model), (4) Google: use the text-embedding-gecko model via Vertex AI. For visualization, use UMAP or t-SNE after getting real embeddings."
  },
  {
    question: "What is a good use case for embedding visualization?",
    answer: "1) Detecting duplicate or near-duplicate content in a document collection. 2) Exploring topic clusters in a corpus before building a classifier. 3) Debugging RAG (Retrieval-Augmented Generation) systems — understanding why certain chunks are retrieved. 4) Evaluating dataset quality — checking that training examples span the intended distribution. 5) Finding outliers in a labeled dataset."
  },
];
---

<BaseLayout
  title="Vector Embedding Visualizer — 2D PCA Plot + Cosine Similarity"
  description="Visualize text embeddings in 2D using PCA projection. Compare semantic similarity across sentences with cosine similarity scores. Browser-side TF-IDF embeddings — no API key required."
  tool="Vector Embedding Visualizer, Text Embedding Visualizer, Semantic Similarity, PCA Projection, Cosine Similarity Calculator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Vector Embedding Visualizer",
    "url": "https://devplaybook.cc/tools/vector-embedding-visualizer",
    "description": "Visualize text embeddings in 2D using PCA dimensionality reduction. Compare cosine similarity between sentences and explore semantic clustering. Runs entirely in the browser using TF-IDF.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Vector Embedding Visualizer</h1>
  <p class="text-text-muted mb-4">
    Enter a set of sentences to visualize their semantic relationships in 2D space. Uses PCA-reduced TF-IDF vectors — no API key needed, runs entirely in your browser. Explore cosine similarity rankings and see which texts cluster together.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 2D PCA scatter plot</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Cosine similarity ranking</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 3 preset datasets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No API key required</span>
  </div>
  <VectorEmbeddingVisualizer client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Vector Embedding Visualizer" relatedTags={['ai', 'embeddings', 'nlp', 'vectors', 'semantic-similarity', 'machine-learning']} />
</BaseLayout>
