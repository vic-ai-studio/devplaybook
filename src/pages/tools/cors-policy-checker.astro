---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CorsPolicyChecker from '../../components/CorsPolicyChecker.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is CORS and why do browsers enforce it?",
    answer: "CORS (Cross-Origin Resource Sharing) is a security mechanism enforced by browsers that controls which origins (domain + protocol + port combinations) can read responses from a different origin. Without CORS, a malicious site could silently make authenticated requests to your bank or API using your cookies. CORS does NOT affect server-to-server requests — only browser-initiated ones. curl and Postman ignore CORS entirely.",
  },
  {
    question: "What is a CORS preflight request?",
    answer: "A preflight is an automatic OPTIONS request the browser sends before a 'non-simple' cross-origin request. Non-simple requests include any method other than GET/HEAD/POST, custom headers like Authorization, or Content-Type values other than form types. The browser checks the OPTIONS response for Access-Control-Allow-Methods and Access-Control-Allow-Headers before sending the actual request. If the preflight fails, the real request is never sent. Use Access-Control-Max-Age to cache preflight results and avoid repeated OPTIONS round-trips.",
  },
  {
    question: "What does Access-Control-Allow-Origin: * mean, and when should I avoid it?",
    answer: "The wildcard (*) allows any origin to read the response. It is appropriate for fully public APIs that return no user-specific data — for example, a public weather API or open data endpoint. You must NOT use * when: (1) the endpoint returns sensitive or user-specific data, (2) the client sends credentials (cookies or Authorization headers) — browsers will reject wildcard + credentials as invalid, or (3) you want to restrict access to known partners. In those cases, explicitly list trusted origins and reflect the matching one in the response.",
  },
  {
    question: "Can I use Access-Control-Allow-Credentials: true with Access-Control-Allow-Origin: *?",
    answer: "No — this combination is explicitly invalid per the CORS specification and all modern browsers will block the response with an error. When credentials mode is enabled (fetch with credentials: 'include', or XMLHttpRequest with withCredentials: true), the server must respond with an explicit origin (e.g. Access-Control-Allow-Origin: https://yourapp.com) rather than *. The server must also set Access-Control-Allow-Credentials: true. This prevents credential-bearing requests from being silently accepted by every site on the internet.",
  },
  {
    question: "What is the difference between CORS and CSRF?",
    answer: "CORS and CSRF (Cross-Site Request Forgery) are complementary but different protections. CORS controls whether a browser allows a script to READ a cross-origin response. CSRF protects against a malicious site WRITING (sending requests) on behalf of a logged-in user without their consent. CORS does not prevent CSRF — simple GET/POST requests that don't read responses can still be CSRF attacks. You need CSRF tokens or SameSite cookie attributes to defend against CSRF. Together, both protections provide layered defense for cross-origin interactions.",
  },
  {
    question: "Why does my API work in Postman or curl but fail in the browser?",
    answer: "CORS is a browser-only enforcement mechanism. curl, Postman, server-side Node.js, Python scripts, and all non-browser HTTP clients never check or enforce CORS headers — they always send and receive responses regardless. This is why testing with curl may succeed while your frontend React or Vue app gets blocked. The fix is always on the server side: add the correct Access-Control headers to your API responses. The browser reads those headers and decides whether to expose the response to your JavaScript code.",
  },
];
---

<BaseLayout
  title="CORS Policy Checker — Test & Fix Cross-Origin Request Headers"
  description="Check CORS headers for any URL, analyze Access-Control headers, and generate CORS configuration for Nginx, Express, Apache, and CloudFront. Free, runs in browser."
  tool="cors, http, security, api, headers, web-development, cors checker, cors tester, access-control-allow-origin"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">CORS Policy Checker</h1>
  <p class="text-text-muted mb-4">
    Test any URL for CORS headers, analyze <code class="bg-surface-alt px-1 py-0.5 rounded text-sm font-mono">Access-Control-*</code> response headers with plain-English explanations, and generate ready-to-copy CORS configuration for Nginx, Express, Apache, CloudFront, and Fastify.
  </p>
  <div class="flex flex-wrap items-center gap-3 mb-6 text-sm text-text-muted">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Real browser CORS check</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Header simulator (paste from curl)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auto-generates server configs</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <CorsPolicyChecker client:only="preact" />

  <FaqSection faq={faq} />

  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more free developer tools?</p>
    <a href="/tools" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Browse All Free Tools →</a>
  </div>

  <ToolPageCta currentTool="CORS Policy Checker" relatedTags={['cors', 'http', 'security', 'api', 'headers', 'web-development']} />
</BaseLayout>
