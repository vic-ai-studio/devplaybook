---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ConvexSchemaBuilder from '../../components/ConvexSchemaBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is Convex?", answer: "Convex is a reactive backend platform for building full-stack applications. It provides a real-time database, serverless functions, and automatic type safety — all in one package. The schema defined in convex/schema.ts enforces your data model and generates TypeScript types automatically." },
  { question: "How does defineSchema work in Convex?", answer: "defineSchema wraps your table definitions and tells Convex the shape of your data. Each table is defined with defineTable() and a validator object using the v.* validators. Convex uses this to enforce data integrity and generate TypeScript types for your queries and mutations." },
  { question: "What validator types are available in Convex?", answer: "Convex provides: v.string() for text, v.number() for numbers, v.boolean() for booleans, v.id('tableName') for references to other tables, v.array(v.string()) for arrays, v.object({...}) for nested objects, v.optional(v.string()) for optional fields, v.null() for null values, and v.union(...) for union types." },
  { question: "What is v.id() used for?", answer: "v.id('tableName') creates a reference to another table's document. It stores the document's unique ID (_id field) which Convex uses to join data across tables. For example, v.id('users') on a posts table means each post references a user document. Use db.get(post.authorId) in a query to fetch the referenced document." },
  { question: "How do indexes work in Convex schemas?", answer: "Add .index('by_fieldName', ['fieldName']) to a defineTable() call to create a searchable index. Convex indexes are used in db.query('tableName').withIndex('by_fieldName', q => q.eq('fieldName', value)). Compound indexes on multiple fields support range queries. Indexes are required for efficient filtered queries — full table scans are not supported in production." },
  { question: "Should I commit my schema file to Git?", answer: "Yes. convex/schema.ts should always be committed to your repository. It is the source of truth for your data model and is required for Convex to enforce types and generate TypeScript definitions. Running npx convex dev will validate your schema against the deployed state and warn you of breaking changes." },
];
---

<BaseLayout
  title="Convex Schema Builder — Visual TypeScript Schema Generator"
  description="Build Convex database schemas visually. Define tables, fields, and validators — get TypeScript schema code ready to drop into convex/schema.ts. Free, runs in your browser."
  tool="Convex Schema Builder, Convex Database, defineSchema, defineTable, Convex TypeScript, reactive database"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Convex Schema Builder",
    "url": "https://devplaybook.cc/tools/convex-schema-builder",
    "description": "Build Convex database schemas visually. Define tables with typed fields and validators, then copy the generated TypeScript schema code directly into your convex/schema.ts file.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Convex Schema Builder</h1>
  <p class="text-text-muted mb-4">Build <strong>Convex database schemas</strong> visually. Define tables, add typed fields with <code class="text-accent font-mono">v.*</code> validators, and copy the generated TypeScript directly into <code class="text-accent font-mono">convex/schema.ts</code>.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All Convex validator types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Add/remove tables & fields</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <ConvexSchemaBuilder client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Convex Schema Builder" relatedTags={['database', 'typescript', 'backend', 'fullstack', 'convex', 'schema']} />
</BaseLayout>
