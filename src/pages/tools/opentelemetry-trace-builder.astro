---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is OpenTelemetry?", answer: "OpenTelemetry (OTel) is a vendor-neutral observability framework for generating, collecting, and exporting telemetry data (traces, metrics, logs). It is the merger of OpenTracing and OpenCensus and is now the industry standard for instrumentation. Backends like Jaeger, Zipkin, Datadog, and Honeycomb all accept OTel data." },
  { question: "What is a span in distributed tracing?", answer: "A span represents a single unit of work — a function call, HTTP request, or database query. Spans have a name, start/end timestamps, attributes (key-value metadata), events (timestamped logs within a span), and a status (ok/error). Spans are organized into traces via parent-child relationships through trace context propagated in headers." },
  { question: "What is the difference between traces, metrics, and logs?", answer: "Traces track a single request's journey through distributed services — useful for understanding latency and finding bottlenecks. Metrics are aggregated measurements over time (request rate, p99 latency, error rate) — useful for dashboards and alerting. Logs are discrete text records of events — useful for debugging specific errors." },
  { question: "What is OTLP?", answer: "OTLP (OpenTelemetry Protocol) is the native wire protocol for OpenTelemetry, supporting gRPC and HTTP/protobuf transport. It is the recommended way to export telemetry from your SDK to a collector or backend. Most backends (Datadog, New Relic, Grafana Tempo) now accept OTLP directly." },
  { question: "Should I use auto-instrumentation or manual instrumentation?", answer: "Auto-instrumentation (via @opentelemetry/auto-instrumentations-node) instruments popular libraries (Express, HTTP, pg, Redis) with zero code changes — great for getting started. Manual instrumentation lets you add custom spans and attributes for business logic. Use both: auto for infrastructure, manual for domain-specific operations." },
];
---

<BaseLayout
  title="OpenTelemetry Trace Builder — Build OTel Spans & Export Config Visually"
  description="Build OpenTelemetry trace spans visually. Configure span names, attributes, status, and generate Node.js SDK setup code with OTLP, Jaeger, or Zipkin exporter. Free online tool."
  tool="OpenTelemetry Trace Builder, OTel span builder, OTLP config generator, OpenTelemetry Node.js setup, distributed tracing tool"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "OpenTelemetry Trace Builder",
    "url": "https://devplaybook.cc/tools/opentelemetry-trace-builder",
    "description": "Build OpenTelemetry trace spans and export configs visually. Generate Node.js SDK setup with OTLP, Jaeger, or Zipkin exporter.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">OpenTelemetry Trace Builder</h1>
  <p class="text-text-muted mb-4">Build OpenTelemetry spans visually and generate ready-to-use Node.js SDK setup code with your chosen exporter — OTLP, Jaeger, or Zipkin.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Span attributes and events</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> OTLP / Jaeger / Zipkin</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auto-instrumentation setup</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript output</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <div class="space-y-4">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold mb-4">Service and Exporter</h2>
        <div class="space-y-3">
          <div>
            <label class="block text-xs text-text-muted mb-1">Service Name</label>
            <input type="text" id="service-name" value="my-service" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="block text-xs text-text-muted mb-1">Exporter</label>
            <select id="exporter" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="otlp-grpc">OTLP gRPC (recommended)</option>
              <option value="otlp-http">OTLP HTTP/JSON</option>
              <option value="jaeger">Jaeger</option>
              <option value="zipkin">Zipkin</option>
              <option value="console">Console (dev only)</option>
            </select>
          </div>
          <div id="endpoint-row">
            <label class="block text-xs text-text-muted mb-1">Collector Endpoint</label>
            <input type="text" id="endpoint" value="http://localhost:4317" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
          </div>
          <div class="flex items-center gap-2">
            <input type="checkbox" id="auto-instr" checked class="accent-primary" />
            <span class="text-sm">Include auto-instrumentation (HTTP, Express, pg)</span>
          </div>
          <div class="flex items-center gap-2">
            <input type="checkbox" id="batch-processor" checked class="accent-primary" />
            <span class="text-sm">Use BatchSpanProcessor (production)</span>
          </div>
        </div>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold mb-3">Custom Span</h2>
        <div class="space-y-2">
          <div>
            <label class="block text-xs text-text-muted mb-1">Span Name</label>
            <input type="text" id="span-name" value="process-order" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="block text-xs text-text-muted mb-1">Attributes (key=value, one per line)</label>
            <textarea id="span-attrs" rows="3" class="w-full bg-bg-card border border-border rounded-lg p-3 text-xs font-mono focus:outline-none focus:border-primary resize-none">order.id=12345
order.total=99.99
customer.tier=premium</textarea>
          </div>
          <div>
            <label class="block text-xs text-text-muted mb-1">Status</label>
            <select id="span-status" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="ok">OK</option>
              <option value="error">Error</option>
              <option value="unset">Unset</option>
            </select>
          </div>
        </div>
      </div>

      <button id="gen-btn" class="w-full py-2.5 bg-primary text-white font-medium rounded-lg hover:bg-primary/80 transition-colors">Generate Code</button>
    </div>

    <div class="space-y-4">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold">instrumentation.ts</h2>
          <button id="copy-setup" class="text-xs border border-border text-text-muted rounded px-2 py-0.5 hover:border-primary hover:text-primary">Copy</button>
        </div>
        <pre id="setup-output" class="font-mono text-xs bg-bg rounded p-3 border border-border overflow-auto min-h-32 whitespace-pre text-text"></pre>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold">Custom span usage</h2>
          <button id="copy-span" class="text-xs border border-border text-text-muted rounded px-2 py-0.5 hover:border-primary hover:text-primary">Copy</button>
        </div>
        <pre id="span-output" class="font-mono text-xs bg-bg rounded p-3 border border-border overflow-auto whitespace-pre text-text"></pre>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold mb-2">Install</h2>
        <pre id="install-output" class="font-mono text-xs bg-bg rounded p-3 border border-border overflow-auto whitespace-pre text-primary"></pre>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="OpenTelemetry Trace Builder" relatedTags={['observability', 'opentelemetry', 'tracing', 'monitoring', 'distributed-systems', 'nodejs']} />
</BaseLayout>

<script>
  const endpointDefaults: Record<string, string> = {
    'otlp-grpc': 'http://localhost:4317',
    'otlp-http': 'http://localhost:4318',
    'jaeger': 'http://localhost:14268/api/traces',
    'zipkin': 'http://localhost:9411/api/v2/spans',
    'console': '',
  };

  document.getElementById('exporter')!.addEventListener('change', (e) => {
    const val = (e.target as HTMLSelectElement).value;
    const row = document.getElementById('endpoint-row') as HTMLElement;
    const ep = document.getElementById('endpoint') as HTMLInputElement;
    row.style.display = val === 'console' ? 'none' : '';
    if (endpointDefaults[val]) ep.value = endpointDefaults[val];
  });

  function generate() {
    const svc = (document.getElementById('service-name') as HTMLInputElement).value || 'my-service';
    const exp = (document.getElementById('exporter') as HTMLSelectElement).value;
    const ep = (document.getElementById('endpoint') as HTMLInputElement).value;
    const autoInstr = (document.getElementById('auto-instr') as HTMLInputElement).checked;
    const batch = (document.getElementById('batch-processor') as HTMLInputElement).checked;
    const spanName = (document.getElementById('span-name') as HTMLInputElement).value || 'my-span';
    const attrsRaw = (document.getElementById('span-attrs') as HTMLTextAreaElement).value;
    const status = (document.getElementById('span-status') as HTMLSelectElement).value;

    const exporterMap: Record<string, { pkg: string; import: string; init: string }> = {
      'otlp-grpc': { pkg: '@opentelemetry/exporter-trace-otlp-grpc', import: "import { OTLPTraceExporter } from '@opentelemetry/exporter-trace-otlp-grpc';", init: `new OTLPTraceExporter({ url: '${ep}' })` },
      'otlp-http': { pkg: '@opentelemetry/exporter-trace-otlp-http', import: "import { OTLPTraceExporter } from '@opentelemetry/exporter-trace-otlp-http';", init: `new OTLPTraceExporter({ url: '${ep}' })` },
      'jaeger': { pkg: '@opentelemetry/exporter-jaeger', import: "import { JaegerExporter } from '@opentelemetry/exporter-jaeger';", init: `new JaegerExporter({ endpoint: '${ep}' })` },
      'zipkin': { pkg: '@opentelemetry/exporter-zipkin', import: "import { ZipkinExporter } from '@opentelemetry/exporter-zipkin';", init: `new ZipkinExporter({ url: '${ep}' })` },
      'console': { pkg: '', import: "import { ConsoleSpanExporter } from '@opentelemetry/sdk-trace-base';", init: 'new ConsoleSpanExporter()' },
    };
    const expInfo = exporterMap[exp];

    const setupLines = [
      "import { NodeSDK } from '@opentelemetry/sdk-node';",
      "import { Resource } from '@opentelemetry/resources';",
      "import { SemanticResourceAttributes } from '@opentelemetry/semantic-conventions';",
      batch ? "import { BatchSpanProcessor } from '@opentelemetry/sdk-trace-base';" : '',
      expInfo.import,
      autoInstr ? "import { getNodeAutoInstrumentations } from '@opentelemetry/auto-instrumentations-node';" : '',
      '',
      'const sdk = new NodeSDK({',
      '  resource: new Resource({',
      `    [SemanticResourceAttributes.SERVICE_NAME]: '${svc}',`,
      '  }),',
      batch ? `  spanProcessor: new BatchSpanProcessor(${expInfo.init}),` : `  traceExporter: ${expInfo.init},`,
      autoInstr ? '  instrumentations: [getNodeAutoInstrumentations()],' : '',
      '});',
      '',
      'sdk.start();',
      '',
      "process.on('SIGTERM', () => { sdk.shutdown(); });",
    ].filter(l => l !== undefined && l !== null) as string[];

    (document.getElementById('setup-output') as HTMLPreElement).textContent = setupLines.filter(Boolean).join('\n');

    const attrs = attrsRaw.split('\n').filter(l => l.includes('=')).map(l => {
      const [k, ...rest] = l.split('=');
      const v = rest.join('=').trim();
      const num = Number(v);
      return `    span.setAttribute('${k.trim()}', ${isNaN(num) ? `'${v}'` : v});`;
    });

    const statusLine = status === 'error'
      ? "    span.setStatus({ code: SpanStatusCode.ERROR, message: 'Something went wrong' });"
      : status === 'ok' ? '    span.setStatus({ code: SpanStatusCode.OK });' : '';

    const fnName = spanName.replace(/-/g, '_').replace(/\s+/g, '_');
    const spanLines = [
      "import { trace, SpanStatusCode } from '@opentelemetry/api';",
      '',
      `const tracer = trace.getTracer('${svc}');`,
      '',
      `async function ${fnName}() {`,
      `  const span = tracer.startSpan('${spanName}');`,
      ...attrs,
      statusLine,
      '  try {',
      '    // ... your logic here',
      '  } catch (err) {',
      '    span.recordException(err as Error);',
      '    span.setStatus({ code: SpanStatusCode.ERROR });',
      '    throw err;',
      '  } finally {',
      '    span.end();',
      '  }',
      '}',
    ];
    (document.getElementById('span-output') as HTMLPreElement).textContent = spanLines.join('\n');

    const pkgs = ['@opentelemetry/sdk-node', '@opentelemetry/resources', '@opentelemetry/semantic-conventions', '@opentelemetry/api', '@opentelemetry/sdk-trace-base'];
    if (expInfo.pkg) pkgs.push(expInfo.pkg);
    if (autoInstr) pkgs.push('@opentelemetry/auto-instrumentations-node');
    (document.getElementById('install-output') as HTMLPreElement).textContent = `npm install ${pkgs.join(' ')}`;
  }

  document.getElementById('gen-btn')!.addEventListener('click', generate);

  ['copy-setup', 'copy-span'].forEach(btnId => {
    const srcId = btnId.replace('copy-', '') + '-output';
    document.getElementById(btnId)!.addEventListener('click', () => {
      navigator.clipboard.writeText((document.getElementById(srcId) as HTMLPreElement).textContent || '');
      const btn = document.getElementById(btnId) as HTMLButtonElement;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
    });
  });

  generate();
</script>
