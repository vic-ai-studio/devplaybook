---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SqlErdGenerator from '../../components/SqlErdGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What SQL dialects are supported?", answer: "The ERD generator supports standard SQL CREATE TABLE syntax including PostgreSQL, MySQL, and SQLite. It parses column definitions, PRIMARY KEY constraints (both inline and table-level), and FOREIGN KEY references." },
  { question: "How do I add foreign key relationships?", answer: "Use FOREIGN KEY syntax in your CREATE TABLE: `FOREIGN KEY (column_name) REFERENCES other_table(column_name)`. The diagram will draw a connecting line between the two tables." },
  { question: "Can I export the diagram?", answer: "Yes — use the Copy SVG button to get the raw SVG markup, which you can paste into a vector editor (Inkscape, Figma, Illustrator) or embed directly in documentation." },
  { question: "What is an ERD used for?", answer: "Entity-Relationship Diagrams show database structure visually. They help developers understand table relationships, onboard new team members to existing schemas, and document database designs in technical specifications." },
  { question: "How are primary keys shown?", answer: "Primary key columns are marked with a key icon (🔑) and bold text in the table diagram. Foreign key columns that reference another table are marked with a link icon (🔗)." },
];
---

<BaseLayout
  title="SQL ERD Diagram Generator — Visualize Database Schema"
  description="Paste SQL CREATE TABLE statements to instantly generate an interactive entity-relationship diagram. Shows tables, columns, primary keys, foreign keys, and relationships. Runs in your browser."
  tool="SQL ERD generator, entity relationship diagram, database schema visualizer, CREATE TABLE diagram, SQL diagram tool, database ERD"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">SQL ERD Diagram Generator</h1>
  <p class="text-text-muted mb-4">Paste your SQL CREATE TABLE statements to instantly visualize your database schema as an entity-relationship diagram. Shows tables, column types, primary keys, foreign keys, and relationships between tables.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No SQL sent to any server</span>
  </div>
  <SqlErdGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SQL ERD Diagram Generator" relatedTags={['sql', 'database', 'diagram', 'postgresql', 'mysql', 'schema']} />
</BaseLayout>
