---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What are the Google thresholds for Core Web Vitals?", answer: "Google defines three tiers for each metric. LCP (Largest Contentful Paint): Good ≤ 2500ms, Needs Improvement 2500–4000ms, Poor > 4000ms. INP (Interaction to Next Paint): Good ≤ 200ms, Needs Improvement 200–500ms, Poor > 500ms. CLS (Cumulative Layout Shift): Good ≤ 0.1, Needs Improvement 0.1–0.25, Poor > 0.25. All three must be in the 'Good' range to pass the Core Web Vitals assessment." },
  { question: "What is LCP and how do I improve it?", answer: "LCP (Largest Contentful Paint) measures how long it takes for the largest visible element (hero image, headline, video thumbnail) to fully render. To improve it: 1) Preload the LCP image with <link rel='preload'>. 2) Use a CDN to reduce server response time. 3) Avoid lazy-loading the LCP element. 4) Use modern image formats (WebP/AVIF) with appropriate sizes. 5) Inline critical CSS to eliminate render-blocking. Target: < 2500ms for at least 75% of page loads." },
  { question: "What is INP and how does it replace FID?", answer: "INP (Interaction to Next Paint) replaced FID as an official Core Web Vital in March 2024. Unlike FID (which measured only the input delay of the first interaction), INP captures the full latency of all interactions — tap, click, or key press — and reports the worst one. To improve INP: break up long tasks with setTimeout/scheduler.yield, reduce JavaScript execution time, use web workers for heavy computation, and defer non-critical scripts." },
  { question: "What is CLS and what causes layout shifts?", answer: "CLS (Cumulative Layout Shift) measures how much page content unexpectedly moves during load. A score of 0 means no shifting; higher is worse. Common causes: images/videos without explicit width and height attributes, ads or embeds injecting content above existing text, web fonts causing FOIT/FOUT reflow, and dynamically inserted banners. Fix: always declare image dimensions, use CSS aspect-ratio, and load fonts with font-display: optional." },
  { question: "How does Google use Core Web Vitals for ranking?", answer: "Google uses Core Web Vitals as part of its 'Page Experience' ranking signal. The signal is based on field data from the Chrome User Experience Report (CrUX), which aggregates real user measurements. A page passes Core Web Vitals if at least 75% of visits achieve 'Good' scores on all three metrics. Failing doesn't cause a ranking penalty per se, but passing can give a small positive signal when other ranking factors are equal." },
];
---

<BaseLayout
  title="Core Web Vitals Budget Calculator — LCP, INP & CLS Pass/Fail Checker"
  description="Enter your LCP, INP, and CLS targets to instantly check pass/fail status against Google thresholds, get a performance score estimate, and see actionable tips for each metric."
  tool="Core Web Vitals budget calculator, LCP INP CLS pass fail checker, Google PageSpeed thresholds, web performance budget tool, Core Web Vitals score"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Core Web Vitals Budget Calculator",
    "url": "https://devplaybook.cc/tools/core-web-vitals-budget-calculator",
    "description": "Check your LCP, INP, and CLS values against Google's official thresholds. Get pass/fail status, a performance score, and optimization tips.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Core Web Vitals Budget Calculator</h1>
  <p class="text-text-muted mb-4">Enter your LCP, INP, and CLS measurements to instantly check pass/fail status against Google's official thresholds, get an estimated performance score, and see tips for each metric.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Google 2024 thresholds</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> LCP / INP / CLS</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Optimization tips</span>
  </div>

  <div class="space-y-5">
    <!-- Inputs -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="font-semibold mb-4">Enter Your Metrics</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label class="block text-sm font-medium text-text-muted mb-1" for="lcp-input">LCP (ms)</label>
          <input id="lcp-input" type="number" min="0" step="50" value="2200"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          <div class="text-xs text-text-muted mt-1">Largest Contentful Paint</div>
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-1" for="inp-input">INP (ms)</label>
          <input id="inp-input" type="number" min="0" step="10" value="180"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          <div class="text-xs text-text-muted mt-1">Interaction to Next Paint</div>
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-1" for="cls-input">CLS (score)</label>
          <input id="cls-input" type="number" min="0" max="1" step="0.01" value="0.05"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          <div class="text-xs text-text-muted mt-1">Cumulative Layout Shift</div>
        </div>
      </div>

      <!-- Presets -->
      <div class="mt-4">
        <div class="text-xs text-text-muted mb-2 font-medium uppercase tracking-wide">Quick Presets</div>
        <div class="flex flex-wrap gap-2" id="cwv-presets"></div>
      </div>

      <button id="check-btn" class="mt-4 bg-primary text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-primary/80 transition-colors">
        Check Budget
      </button>
    </div>

    <!-- Results -->
    <div id="cwv-results" class="hidden space-y-4">
      <!-- Score cards -->
      <div class="grid grid-cols-1 sm:grid-cols-4 gap-4" id="cwv-summary"></div>

      <!-- Metric details -->
      <div class="space-y-3" id="cwv-details"></div>

      <!-- Thresholds reference -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold mb-3">Google Thresholds Reference</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-text-muted text-xs uppercase tracking-wide border-b border-border">
                <th class="text-left py-2 pr-4">Metric</th>
                <th class="text-center py-2 pr-4 text-green-400">Good</th>
                <th class="text-center py-2 pr-4 text-yellow-400">Needs Improvement</th>
                <th class="text-center py-2 text-red-400">Poor</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border text-sm">
              <tr>
                <td class="py-2.5 pr-4 font-medium">LCP</td>
                <td class="py-2.5 pr-4 text-center text-green-400 font-mono">≤ 2500ms</td>
                <td class="py-2.5 pr-4 text-center text-yellow-400 font-mono">2500–4000ms</td>
                <td class="py-2.5 text-center text-red-400 font-mono">&gt; 4000ms</td>
              </tr>
              <tr>
                <td class="py-2.5 pr-4 font-medium">INP</td>
                <td class="py-2.5 pr-4 text-center text-green-400 font-mono">≤ 200ms</td>
                <td class="py-2.5 pr-4 text-center text-yellow-400 font-mono">200–500ms</td>
                <td class="py-2.5 text-center text-red-400 font-mono">&gt; 500ms</td>
              </tr>
              <tr>
                <td class="py-2.5 pr-4 font-medium">CLS</td>
                <td class="py-2.5 pr-4 text-center text-green-400 font-mono">≤ 0.1</td>
                <td class="py-2.5 pr-4 text-center text-yellow-400 font-mono">0.1–0.25</td>
                <td class="py-2.5 text-center text-red-400 font-mono">&gt; 0.25</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Core Web Vitals Budget Calculator" relatedTags={['performance', 'web-vitals', 'lcp', 'inp', 'cls', 'seo', 'google']} />
</BaseLayout>

<script is:inline>
(function () {
  var METRICS = {
    lcp: {
      name: 'LCP',
      full: 'Largest Contentful Paint',
      unit: 'ms',
      good: 2500,
      poor: 4000,
      tips: {
        good: 'Excellent! Your LCP is within the Good range. Maintain by preloading LCP images and using a CDN.',
        ni: 'Needs work. Preload your LCP image with <link rel="preload">, use a CDN, avoid lazy-loading the LCP element, and inline critical CSS.',
        poor: 'Poor LCP. Major improvements needed: eliminate render-blocking resources, compress and properly size the LCP image, use WebP/AVIF format, and reduce server response time (TTFB < 800ms).'
      }
    },
    inp: {
      name: 'INP',
      full: 'Interaction to Next Paint',
      unit: 'ms',
      good: 200,
      poor: 500,
      tips: {
        good: 'Great responsiveness! Keep long tasks under 50ms and avoid heavy JS in event handlers.',
        ni: 'Needs improvement. Break up long JavaScript tasks, defer non-critical scripts, and avoid blocking the main thread during interactions.',
        poor: 'Poor responsiveness. Audit long tasks in Chrome DevTools, use web workers for heavy computation, implement virtualization for long lists, and reduce third-party script impact.'
      }
    },
    cls: {
      name: 'CLS',
      full: 'Cumulative Layout Shift',
      unit: '',
      good: 0.1,
      poor: 0.25,
      tips: {
        good: 'Stable layout! Keep declaring explicit image dimensions and avoid injecting content above existing elements.',
        ni: 'Some layout instability. Set explicit width/height on images and iframes, use CSS aspect-ratio, and ensure ads have reserved space.',
        poor: 'High layout shift. Always declare image/video dimensions, avoid inserting content above existing elements after load, and use font-display: optional to prevent font-swap shifts.'
      }
    }
  };

  var PRESETS = [
    { label: 'Excellent site', lcp: 1200, inp: 80, cls: 0.02 },
    { label: 'Average site', lcp: 3200, inp: 250, cls: 0.12 },
    { label: 'Slow site', lcp: 5500, inp: 600, cls: 0.35 },
    { label: 'Mobile (3G)', lcp: 4200, inp: 300, cls: 0.08 },
  ];

  var presetsEl = document.getElementById('cwv-presets');
  PRESETS.forEach(function (p) {
    var btn = document.createElement('button');
    btn.className = 'px-3 py-1 text-xs rounded-lg border border-border bg-bg hover:bg-primary/10 hover:border-primary/40 transition-colors';
    btn.textContent = p.label;
    btn.addEventListener('click', function () {
      document.getElementById('lcp-input').value = p.lcp;
      document.getElementById('inp-input').value = p.inp;
      document.getElementById('cls-input').value = p.cls;
      check();
    });
    presetsEl.appendChild(btn);
  });

  function getStatus(key, val) {
    var m = METRICS[key];
    if (val <= m.good) return 'good';
    if (val <= m.poor) return 'ni';
    return 'poor';
  }

  function statusLabel(s) {
    if (s === 'good') return { label: 'Good', color: 'text-green-400', bg: 'bg-green-500/10 border-green-500/30', icon: '✓' };
    if (s === 'ni') return { label: 'Needs Improvement', color: 'text-yellow-400', bg: 'bg-yellow-500/10 border-yellow-500/30', icon: '!' };
    return { label: 'Poor', color: 'text-red-400', bg: 'bg-red-500/10 border-red-500/30', icon: '✗' };
  }

  function calcScore(lcpStatus, inpStatus, clsStatus) {
    var scores = { good: 100, ni: 60, poor: 20 };
    return Math.round((scores[lcpStatus] * 0.4 + scores[inpStatus] * 0.35 + scores[clsStatus] * 0.25));
  }

  function check() {
    var lcp = parseFloat(document.getElementById('lcp-input').value);
    var inp = parseFloat(document.getElementById('inp-input').value);
    var cls = parseFloat(document.getElementById('cls-input').value);

    if (isNaN(lcp) || isNaN(inp) || isNaN(cls)) {
      alert('Please enter valid values for all three metrics.');
      return;
    }

    var lcpS = getStatus('lcp', lcp);
    var inpS = getStatus('inp', inp);
    var clsS = getStatus('cls', cls);
    var allPass = lcpS === 'good' && inpS === 'good' && clsS === 'good';
    var score = calcScore(lcpS, inpS, clsS);

    // Summary cards
    var summary = document.getElementById('cwv-summary');
    summary.innerHTML = '';
    var overallSt = statusLabel(allPass ? 'good' : (score >= 60 ? 'ni' : 'poor'));
    var cards = [
      { label: 'Overall Assessment', value: allPass ? 'PASS' : 'FAIL', color: allPass ? 'text-green-400' : 'text-red-400' },
      { label: 'Performance Score', value: score + '/100', color: score >= 90 ? 'text-green-400' : score >= 60 ? 'text-yellow-400' : 'text-red-400' },
      { label: 'LCP', value: lcp + 'ms', color: statusLabel(lcpS).color },
      { label: 'INP / CLS', value: inp + 'ms / ' + cls, color: (inpS === 'good' && clsS === 'good') ? 'text-green-400' : 'text-yellow-400' },
    ];
    cards.forEach(function (c) {
      var card = document.createElement('div');
      card.className = 'bg-bg-card border border-border rounded-xl p-4';
      card.innerHTML = '<div class="text-xs text-text-muted mb-1">' + c.label + '</div>'
        + '<div class="text-xl font-bold ' + c.color + '">' + c.value + '</div>';
      summary.appendChild(card);
    });

    // Metric detail cards
    var details = document.getElementById('cwv-details');
    details.innerHTML = '';
    var metricValues = { lcp: lcp, inp: inp, cls: cls };
    ['lcp', 'inp', 'cls'].forEach(function (key) {
      var m = METRICS[key];
      var val = metricValues[key];
      var s = getStatus(key, val);
      var st = statusLabel(s);
      var card = document.createElement('div');
      card.className = 'bg-bg-card border ' + st.bg + ' rounded-xl p-5';
      card.innerHTML = '<div class="flex items-start justify-between mb-3">'
        + '<div><div class="font-semibold">' + m.name + ' — ' + m.full + '</div>'
        + '<div class="text-2xl font-bold mt-1 ' + st.color + '">' + val + (m.unit ? ' ' + m.unit : '') + '</div></div>'
        + '<div class="flex items-center gap-1.5 px-3 py-1 rounded-full border ' + st.bg + ' ' + st.color + ' font-semibold text-sm">'
        + '<span>' + st.icon + '</span><span>' + st.label + '</span></div>'
        + '</div>'
        + '<p class="text-sm text-text-muted">' + m.tips[s] + '</p>';
      details.appendChild(card);
    });

    document.getElementById('cwv-results').classList.remove('hidden');
    document.getElementById('cwv-results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  document.getElementById('check-btn').addEventListener('click', check);
  check();
})();
</script>
