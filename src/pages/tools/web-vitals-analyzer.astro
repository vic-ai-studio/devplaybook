---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WebVitalsAnalyzer from '../../components/WebVitalsAnalyzer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What are Core Web Vitals and why do they matter for SEO?",
    answer: "Core Web Vitals are Google's standardized page experience metrics: LCP (loading), INP (interactivity), and CLS (visual stability). Since the Page Experience update, they're a ranking signal. Poor Core Web Vitals can hurt rankings and significantly impact user engagement — a 0.1s improvement in LCP correlates with 8% more conversions for eCommerce. Google uses field data (real users via CrUX) rather than lab data for ranking, so real-world performance matters."
  },
  {
    question: "What is the difference between lab data and field data?",
    answer: "Lab data comes from controlled test environments (Lighthouse, WebPageTest) with simulated network and device conditions. It's reproducible and useful for development. Field data comes from real users via the Chrome UX Report (CrUX) — it captures actual device diversity, network conditions, and user behaviors. Google uses field data (75th percentile) for ranking. A page can score well in Lighthouse but poorly in field data if real users have slow devices or connections."
  },
  {
    question: "What replaced FID as a Core Web Vital?",
    answer: "INP (Interaction to Next Paint) replaced FID as a Core Web Vital in March 2024. FID only measured the first interaction delay; INP measures all interactions throughout the page lifecycle — clicks, taps, and keyboard input — and reports the slowest 98th percentile interaction. INP is stricter: a page can have a fast FID but poor INP if it has heavy event handlers that fire late in the session, like after dynamic content loads."
  },
  {
    question: "How do I measure Core Web Vitals on my site?",
    answer: "Multiple tools: PageSpeed Insights (pagespeed.web.dev) shows both lab and field data. Chrome DevTools → Lighthouse runs lab tests. Chrome DevTools → Performance recorder for INP debugging. Chrome UX Report (CrUX) API for programmatic field data. web-vitals npm package to measure in your app: import { onLCP, onINP, onCLS } from 'web-vitals' and send to your analytics. Search Console's Core Web Vitals report shows real-world data aggregated by URL group."
  },
  {
    question: "Why is my CLS high and how do I fix it?",
    answer: "CLS (Cumulative Layout Shift) is caused by content moving unexpectedly. Top causes: images without explicit dimensions (add width/height attributes), dynamically injected content above existing content (ads, banners, cookie notices), web fonts causing FOUT/FOIT (add font-display: swap and preload critical fonts), lazy-loaded embeds without reserved space (use aspect-ratio CSS). Use the Layout Shift Regions visualization in Chrome DevTools to identify which elements are shifting."
  },
  {
    question: "What is a good LCP score and how do I optimize it?",
    answer: "Good LCP is under 2.5 seconds. The LCP element is usually a hero image, background image, or above-the-fold text block. To optimize: preload the LCP image with <link rel='preload' as='image'>, use a CDN to serve images from edge locations, convert images to WebP/AVIF, add fetchpriority='high' to the LCP image element, remove render-blocking scripts and stylesheets, and consider streaming SSR to send HTML faster."
  },
];
---

<BaseLayout
  title="Web Vitals Analyzer — Score LCP, INP, CLS, TTFB, FCP"
  description="Analyze and score your Core Web Vitals. Enter LCP, INP, CLS, TTFB, and FCP values to get good/needs improvement/poor ratings with actionable tips. Free, runs in your browser."
  tool="web vitals analyzer, core web vitals checker, lcp score, inp score, cls score, ttfb analyzer, web performance checker"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Web Vitals Analyzer",
    "url": "https://devplaybook.cc/tools/web-vitals-analyzer",
    "description": "Analyze and score Core Web Vitals. Enter LCP, INP, CLS, TTFB, and FCP values to get good/needs improvement/poor ratings with optimization tips.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Web Vitals Analyzer</h1>
  <p class="text-text-muted mb-4">
    Enter your <strong>Core Web Vitals</strong> metrics to score performance. Input LCP, INP, CLS, TTFB, and FCP values to see good/needs improvement/poor ratings with actionable optimization tips per metric.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> LCP, INP, CLS, TTFB, FCP</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Google thresholds</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Optimization tips</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Overall grade</span>
  </div>
  <WebVitalsAnalyzer client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Web Vitals Analyzer" relatedTags={['performance', 'seo', 'web-vitals', 'javascript', 'lighthouse', 'developer-tools']} />
</BaseLayout>
