---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DockerComposeGenerator from '../../components/DockerComposeGenerator.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How do I generate a docker-compose.yml file?", answer: "Click 'Add Service' to create a new container definition. Configure its image, ports, volumes, environment variables, and network. The tool generates valid YAML in real time — copy it or download the file when you're done." },
  { question: "Does this support Docker Compose v2 syntax?", answer: "Yes. The generated YAML follows the Compose Specification (v2+) which is compatible with both 'docker compose' (v2 CLI plugin) and the legacy 'docker-compose' command. No version key is needed for modern Docker." },
  { question: "Can I add multiple services and networks?", answer: "Absolutely. Add as many services as you need — each with its own image, ports, volumes, depends_on, and restart policy. You can also define custom networks and link services to them." },
  { question: "Is the generated YAML production-ready?", answer: "The output is valid, well-structured YAML suitable for development and staging. For production, review resource limits, secrets management, and logging configuration based on your deployment environment." },
  { question: "Does this tool store my configuration?", answer: "No. Everything runs in your browser. Your service definitions and generated YAML never leave your machine — there is no server-side processing or storage." },
];
---

<BaseLayout
  title="Docker Compose Generator — Visual YAML Builder Free Online"
  description="Generate docker-compose.yml configurations visually in your browser. Add services, ports, volumes, environment variables, networks, and depends_on. Export production-ready YAML instantly. Free Docker Compose tool — no signup required."
  tool="Docker Compose Generator, Docker YAML Builder, docker-compose.yml Generator, Docker Container Orchestration, DevOps Tool, Docker Compose v2"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Docker Compose Generator</h1>
  <p class="text-text-muted mb-4">Build <code class="font-mono text-sm">docker-compose.yml</code> configurations visually — add services, map ports, mount volumes, set environment variables, and define networks. Copy or download production-ready YAML in one click.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <DockerComposeGenerator client:load />
  <AffiliateSection category={['deployment', 'database']} />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Docker Compose Generator" relatedTags={['devops', 'automation', 'ci-cd', 'boilerplate']} />
</BaseLayout>
