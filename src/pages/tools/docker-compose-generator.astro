---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DockerComposeGenerator from '../../components/DockerComposeGenerator.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout title="Docker Compose Generator" description="Generate docker-compose.yml configurations visually in your browser. Add services, ports, volumes, environment variables, and networks. Export production-ready YAML instantly. Free Docker tool." tool="Docker Compose Generator, Docker YAML Builder, docker-compose.yml Generator, Docker Container Orchestration, DevOps Tool"
  <h1 class="text-3xl font-bold mb-2">Docker Compose Generator</h1>
  <p class="text-text-muted mb-8">Build docker-compose.yml configurations visually with templates and service management.</p>
  <DockerComposeGenerator client:load />
  <AffiliateSection category={['deployment', 'database']} />
  <ToolPageCta currentTool="Docker Compose Generator" relatedTags={['devops', 'automation', 'ci-cd', 'boilerplate']} />
</BaseLayout>
