---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CronValidator from '../../components/CronValidator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Cron Expression Validator"
  description="Validate cron expressions and see human-readable schedules with the next 5 run times. Supports all standard cron fields with field-by-field breakdown and presets."
  tool="Cron Validator, Cron Expression Checker, Cron Schedule Tester"
>
  <h1 class="text-3xl font-bold mb-2">Cron Expression Validator</h1>
  <p class="text-text-muted mb-8">Enter a cron expression to validate it, see a plain-English description, and preview the next 5 scheduled run times.</p>
  <CronValidator client:load />
  <ToolPageCta currentTool="Cron Expression Validator" relatedTags={['automation', 'devops', 'ci-cd', 'bash', 'scheduling']} />
</BaseLayout>
