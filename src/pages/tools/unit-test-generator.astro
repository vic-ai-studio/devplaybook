---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const defaultFn = `export function calculateDiscount(price: number, discountPercent: number): number {\n  if (price < 0) throw new Error('Price must be non-negative');\n  if (discountPercent < 0 || discountPercent > 100) throw new Error('Discount must be between 0 and 100');\n  return price * (1 - discountPercent / 100);\n}`;

const faq = [
  {
    question: "What testing frameworks does this generator support?",
    answer: "The unit test generator produces tests for both Jest and Vitest. Both use the same describe/it/expect API, so the generated tests are compatible with either framework. Jest is the most widely used JavaScript testing framework. Vitest is the modern Vite-native alternative that is faster and has better TypeScript support out of the box.",
  },
  {
    question: "What types of functions work best with this generator?",
    answer: "Pure functions — those with no side effects, that return the same output for the same input — produce the best generated tests. The generator handles: simple return values, error throwing, null/undefined handling, array operations, and object transformations. Functions with database calls, network requests, or global state need manual mocking setup not covered by this generator.",
  },
  {
    question: "How do I run the generated tests?",
    answer: "For Jest: install jest and @types/jest, then run npx jest. For Vitest: install vitest, add 'test' script to package.json (vitest run), then npm run test. Both support TypeScript natively with minimal config. The generated test file should be placed alongside your source file with a .test.ts or .spec.ts extension.",
  },
  {
    question: "What is the difference between describe, it, and test blocks?",
    answer: "describe() groups related tests into a suite — typically one describe per function or module. it() and test() are identical — both define a single test case. Convention: use describe('functionName') and it('returns X when given Y') for readable test output. The generated tests follow this convention.",
  },
  {
    question: "What is test-driven development (TDD) and should I use it?",
    answer: "TDD means writing tests before implementing the function: write a failing test, implement enough code to pass it, then refactor. It produces better-designed, more testable code and catches requirements early. This generator works for both TDD (generate from a spec) and traditional testing (generate from existing code). TDD is recommended for new features; this generator is most useful for adding coverage to existing code.",
  },
];
---

<BaseLayout
  title="Unit Test Generator — Generate Jest & Vitest Tests from Your Code"
  description="Paste JavaScript or TypeScript functions and instantly generate Jest or Vitest unit tests. Creates describe blocks, happy path tests, edge cases, and error handling. Free, runs in your browser."
  tool="Unit Test Generator, Jest Test Generator, Vitest Test Generator, JavaScript Unit Tests, TypeScript Test Generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Unit Test Generator",
    "url": "https://devplaybook.cc/tools/unit-test-generator",
    "description": "Generate Jest and Vitest unit tests from JavaScript or TypeScript functions. Covers happy path, edge cases, null handling, and error throwing.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Unit Test Generator</h1>
  <p class="text-text-muted mb-4">
    Paste a JavaScript or TypeScript function and generate ready-to-run
    <strong class="text-text">Jest</strong> or <strong class="text-text">Vitest</strong> unit tests.
    Covers happy path, edge cases, null/undefined inputs, and error handling.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Jest & Vitest compatible</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Edge cases & error tests</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs in your browser</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Input -->
    <div class="flex flex-col gap-4">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Your Function</h2>
          <div class="flex gap-2">
            <button id="btn-jest" class="px-3 py-1 rounded text-xs bg-accent text-white transition-colors">Jest</button>
            <button id="btn-vitest" class="px-3 py-1 rounded text-xs bg-bg border border-border text-text-muted transition-colors">Vitest</button>
          </div>
        </div>
        <textarea
          id="fn-input"
          class="w-full h-72 px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm font-mono focus:outline-none focus:border-accent transition-colors resize-none"
          spellcheck="false"
          placeholder="// Paste your function here..."
          set:text={defaultFn}
        />
        <button id="generate-btn" class="mt-3 w-full py-2 px-4 bg-accent hover:bg-accent/90 text-white rounded-lg text-sm font-medium transition-colors">
          Generate Tests
        </button>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted mb-3">Options</h2>
        <div class="flex flex-col gap-3">
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="opt-edge" checked class="rounded border-border" />
            <span>Generate edge case tests (null, 0, empty)</span>
          </label>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="opt-errors" checked class="rounded border-border" />
            <span>Generate error/exception tests</span>
          </label>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="opt-typescript" checked class="rounded border-border" />
            <span>Include TypeScript types</span>
          </label>
        </div>
      </div>
    </div>

    <!-- Output -->
    <div class="bg-bg-card border border-border rounded-xl p-5 flex flex-col">
      <div class="flex items-center justify-between mb-3">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Generated Tests</h2>
        <button id="copy-btn" class="px-3 py-1 rounded text-xs bg-bg border border-border text-text-muted hover:text-text transition-colors">Copy</button>
      </div>
      <pre id="test-output" class="flex-1 text-xs font-mono bg-bg rounded-lg p-3 overflow-auto min-h-[400px] text-text whitespace-pre-wrap"></pre>
    </div>
  </div>

  <script>
    type Framework = 'jest' | 'vitest';
    let framework: Framework = 'jest';

    function parseFunctionSignature(code: string): { name: string; params: string[]; isAsync: boolean; throws: boolean } | null {
      // Match: function name, arrow function, method
      const patterns = [
        /(?:export\s+)?(?:async\s+)?function\s+(\w+)\s*\(([^)]*)\)/,
        /(?:export\s+)?(?:const|let|var)\s+(\w+)\s*=\s*(?:async\s*)?\(([^)]*)\)\s*(?::\s*\S+\s*)?=>/,
        /(?:async\s+)?(\w+)\s*\(([^)]*)\)\s*(?::\s*\S+)?\s*\{/,
      ];

      for (const pat of patterns) {
        const match = code.match(pat);
        if (match) {
          const name = match[1];
          const rawParams = match[2].trim();
          const params = rawParams
            ? rawParams.split(',').map(p => p.trim().split(':')[0].trim().replace(/[=\s].*$/, '').trim()).filter(Boolean)
            : [];
          const isAsync = code.includes('async');
          const throws = code.includes('throw');
          return { name, params, isAsync, throws };
        }
      }
      return null;
    }

    function inferParamValues(params: string[]): Record<string, { normal: string; edge: string }> {
      const map: Record<string, { normal: string; edge: string }> = {};
      for (const p of params) {
        const lower = p.toLowerCase();
        if (lower.includes('price') || lower.includes('amount') || lower.includes('cost')) {
          map[p] = { normal: '100', edge: '0' };
        } else if (lower.includes('percent') || lower.includes('rate') || lower.includes('ratio')) {
          map[p] = { normal: '20', edge: '0' };
        } else if (lower.includes('str') || lower.includes('name') || lower.includes('text') || lower.includes('input')) {
          map[p] = { normal: '"hello"', edge: '""' };
        } else if (lower.includes('arr') || lower.includes('list') || lower.includes('items')) {
          map[p] = { normal: '[1, 2, 3]', edge: '[]' };
        } else if (lower.includes('obj') || lower.includes('data') || lower.includes('config')) {
          map[p] = { normal: '{}', edge: 'null' };
        } else if (lower.includes('flag') || lower.includes('enable') || lower.includes('is') || lower.includes('has')) {
          map[p] = { normal: 'true', edge: 'false' };
        } else {
          map[p] = { normal: '42', edge: '0' };
        }
      }
      return map;
    }

    function generateTests(code: string): string {
      const parsed = parseFunctionSignature(code);
      const includeEdge = (document.getElementById('opt-edge') as HTMLInputElement).checked;
      const includeErrors = (document.getElementById('opt-errors') as HTMLInputElement).checked;
      const useTs = (document.getElementById('opt-typescript') as HTMLInputElement).checked;

      if (!parsed) {
        return `// Could not parse function signature.\n// Make sure your function follows standard syntax.\n// Example:\n// function myFunction(param1, param2) { ... }`;
      }

      const { name, params, isAsync, throws } = parsed;
      const paramVals = inferParamValues(params);
      const normalArgs = params.map(p => paramVals[p]?.normal ?? '42').join(', ');
      const awaitStr = isAsync ? 'await ' : '';
      const imp = framework === 'jest'
        ? `import { ${name} } from './${name}';\n`
        : `import { describe, it, expect } from 'vitest';\nimport { ${name} } from './${name}';\n`;

      let out = imp + '\n';
      out += `describe('${name}', () => {\n`;

      // Happy path
      out += `  it('returns expected result for valid inputs', ${isAsync ? 'async ' : ''}() => {\n`;
      out += `    const result = ${awaitStr}${name}(${normalArgs});\n`;
      out += `    expect(result).toBeDefined();\n`;
      out += `    // TODO: replace with actual expected value\n`;
      out += `    // expect(result).toBe(expectedValue);\n`;
      out += `  });\n\n`;

      // Edge cases
      if (includeEdge && params.length > 0) {
        for (const p of params) {
          const edgeVal = paramVals[p]?.edge ?? '0';
          const otherArgs = params.map(op => op === p ? edgeVal : (paramVals[op]?.normal ?? '42')).join(', ');
          out += `  it('handles edge case: ${p} = ${edgeVal}', ${isAsync ? 'async ' : ''}() => {\n`;
          out += `    const result = ${awaitStr}${name}(${otherArgs});\n`;
          out += `    expect(result).toBeDefined();\n`;
          out += `  });\n\n`;
        }

        // Null/undefined
        if (params.length > 0) {
          out += `  it('handles null input gracefully', ${isAsync ? 'async ' : ''}() => {\n`;
          const nullArgs = params.map(() => 'null as any').join(', ');
          if (throws) {
            out += `    expect(() => ${name}(${nullArgs})).toThrow();\n`;
          } else {
            out += `    // Decide: should null input throw, return null, or return a default?\n`;
            out += `    const result = ${awaitStr}${name}(${nullArgs});\n`;
            out += `    expect(result).toBeNull(); // or toBeDefined(), or toThrow()\n`;
          }
          out += `  });\n\n`;
        }
      }

      // Error tests
      if (includeErrors && throws) {
        out += `  it('throws an error for invalid inputs', () => {\n`;
        const invalidArgs = params.map(p => {
          const lower = p.toLowerCase();
          if (lower.includes('price') || lower.includes('amount')) return '-1';
          if (lower.includes('percent') || lower.includes('rate')) return '150';
          return '-999';
        }).join(', ');
        out += `    expect(() => ${name}(${invalidArgs})).toThrow();\n`;
        out += `  });\n\n`;

        out += `  it('throws with correct error message', () => {\n`;
        out += `    expect(() => ${name}(${invalidArgs})).toThrow(Error);\n`;
        out += `    // expect(() => ${name}(${invalidArgs})).toThrow('specific message');\n`;
        out += `  });\n\n`;
      }

      // Return type consistency
      out += `  it('returns consistent output type', ${isAsync ? 'async ' : ''}() => {\n`;
      out += `    const result1 = ${awaitStr}${name}(${normalArgs});\n`;
      out += `    const result2 = ${awaitStr}${name}(${normalArgs});\n`;
      out += `    expect(typeof result1).toBe(typeof result2);\n`;
      out += `  });\n`;

      out += `});\n`;
      return out;
    }

    function render() {
      const code = (document.getElementById('fn-input') as HTMLTextAreaElement).value;
      const output = generateTests(code);
      (document.getElementById('test-output') as HTMLPreElement).textContent = output;
    }

    document.getElementById('generate-btn')!.addEventListener('click', render);

    document.getElementById('btn-jest')!.addEventListener('click', () => {
      framework = 'jest';
      document.getElementById('btn-jest')!.className = 'px-3 py-1 rounded text-xs bg-accent text-white transition-colors';
      document.getElementById('btn-vitest')!.className = 'px-3 py-1 rounded text-xs bg-bg border border-border text-text-muted transition-colors';
      render();
    });

    document.getElementById('btn-vitest')!.addEventListener('click', () => {
      framework = 'vitest';
      document.getElementById('btn-vitest')!.className = 'px-3 py-1 rounded text-xs bg-accent text-white transition-colors';
      document.getElementById('btn-jest')!.className = 'px-3 py-1 rounded text-xs bg-bg border border-border text-text-muted transition-colors';
      render();
    });

    document.getElementById('copy-btn')!.addEventListener('click', () => {
      const text = (document.getElementById('test-output') as HTMLPreElement).textContent || '';
      navigator.clipboard.writeText(text).then(() => {
        const btn = document.getElementById('copy-btn') as HTMLButtonElement;
        btn.textContent = 'Copied!';
        setTimeout(() => btn.textContent = 'Copy', 2000);
      });
    });

    render();
  </script>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Unit Test Generator" relatedTags={['testing', 'jest', 'vitest', 'unit-testing', 'developer-tools']} />
</BaseLayout>
