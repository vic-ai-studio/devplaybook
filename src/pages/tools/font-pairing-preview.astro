---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FontPairingPreview from '../../components/FontPairingPreview.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What makes a good font pairing?",
    answer: "Good font pairings balance contrast and harmony. The classic rule: pair a serif with a sans-serif (e.g. Playfair Display heading + Open Sans body). For contrast, use different weights and x-heights. For harmony, choose fonts with similar proportions or from the same designer. Avoid pairing two decorative or two very similar fonts -- the result is either muddy or monotonous."
  },
  {
    question: "Should my heading font be serif or sans-serif?",
    answer: "Either works -- it depends on your brand personality. Serif headings (Playfair Display, Lora, Garamond) feel editorial, trustworthy, and elegant -- good for blogs, news, luxury brands. Sans-serif headings (Montserrat, Poppins, Oswald) feel modern, clean, and tech-forward -- good for SaaS, startups, and apps. Mixing (serif heading + sans body) is the most versatile combination."
  },
  {
    question: "Are Google Fonts free for commercial use?",
    answer: "Yes. All fonts on Google Fonts are licensed under open-source licenses (OFL, Apache 2.0, or Ubuntu Font License). They are free to use on any website, commercial or personal, without attribution required. The fonts are served from Google's CDN (fonts.googleapis.com) or can be self-hosted."
  },
  {
    question: "How do I use Google Fonts in a Next.js or Astro project?",
    answer: "In Next.js 13+, use next/font/google: import { Playfair_Display } from 'next/font/google'. This optimizes fonts at build time, prevents layout shift, and avoids external network requests. In Astro, add a <link rel=preconnect href=https://fonts.googleapis.com> and your @import in the <head>. Both approaches are fine; next/font gives better performance in Next.js apps."
  },
  {
    question: "What font size and line height should I use for body text?",
    answer: "Body text: 16-18px font size, 1.5-1.7 line height. This gives comfortable reading at typical screen viewing distances. For headings: 1.2-1.4 line height. On mobile, 16px is the minimum to avoid automatic zoom in iOS. Use clamp() for fluid type scales: clamp(1rem, 2.5vw, 1.25rem) scales smoothly between viewport sizes."
  },
];
---

<BaseLayout
  title="Font Pairing Preview — 20+ Curated Google Font Combinations"
  description="Browse 20+ hand-curated Google Font pairings with live heading and body text preview. Filter by style, copy the CSS @import code. Free, runs in your browser."
  tool="font pairing tool, Google Fonts pairing, heading body font combinations, font preview tool, typography pairing guide"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Font Pairing Preview",
    "url": "https://devplaybook.cc/tools/font-pairing-preview",
    "description": "Browse 20+ curated Google Font heading and body text pairings with live preview. Copy the CSS @import code for any pair.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Font Pairing Preview</h1>
  <p class="text-text-muted mb-4">
    Browse 20+ hand-curated Google Font heading and body text pairings with live preview. Filter by style, search by font name, and copy the CSS <code class="font-mono bg-surface px-1 rounded text-sm">@import</code> code for any combination.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 20+ curated pairings</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live font preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy CSS @import</span>
  </div>
  <FontPairingPreview client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Font Pairing Preview" relatedTags={['typography', 'fonts', 'design', 'css', 'google-fonts', 'web']} />
</BaseLayout>
