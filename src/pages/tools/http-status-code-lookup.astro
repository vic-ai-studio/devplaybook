---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HttpStatusCodeLookup from '../../components/HttpStatusCodeLookup.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the difference between 401 and 403?",
    answer: "401 Unauthorized means the client is not authenticated — the server doesn't know who you are. Include a WWW-Authenticate header so the client knows how to authenticate. 403 Forbidden means the client is authenticated but lacks permission — the server knows who you are but you're not allowed to access this resource."
  },
  {
    question: "When should I use 404 vs 403?",
    answer: "Use 404 when a resource doesn't exist. Use 403 when it exists but the user lacks permission. However, returning 404 for a resource that exists (but is forbidden) is a common security practice to avoid leaking information about the existence of private resources — sometimes called 'security through obscurity'."
  },
  {
    question: "What is the difference between 301 and 308?",
    answer: "Both are permanent redirects, but 301 allows browsers to change the HTTP method (typically converting POST to GET), while 308 requires the client to use the same HTTP method as the original request. Use 308 when you're permanently moving a POST endpoint and need the method preserved."
  },
  {
    question: "When should I use 422 instead of 400?",
    answer: "Use 400 Bad Request for syntactically malformed requests (invalid JSON, missing required headers). Use 422 Unprocessable Entity for requests that are syntactically valid but fail semantic/business validation (e.g., end date before start date, invalid email format, value out of allowed range)."
  },
  {
    question: "What does 429 Too Many Requests require?",
    answer: "When returning 429, you should include a Retry-After header indicating when the client can retry — either as a number of seconds (Retry-After: 60) or an HTTP date. Also consider including X-RateLimit-Limit, X-RateLimit-Remaining, and X-RateLimit-Reset headers for better developer experience."
  },
  {
    question: "What is the difference between 502, 503, and 504?",
    answer: "502 Bad Gateway: your gateway/proxy received an invalid response from an upstream server. 503 Service Unavailable: the server itself is temporarily unavailable (overloaded, maintenance). 504 Gateway Timeout: your gateway/proxy didn't receive a timely response from an upstream server. All three indicate server-side problems and clients may retry."
  },
];
---

<BaseLayout
  title="HTTP Status Code Lookup — Complete Reference for 1xx–5xx Codes"
  description="Browse and search all HTTP status codes (1xx–5xx). Get the name, description, common causes, and when to use each code. Covers 200 OK, 201 Created, 301, 302, 400, 401, 403, 404, 422, 429, 500, 502, 503, 504 and more."
  tool="HTTP Status Codes, HTTP Response Codes Reference, REST API Status Codes, HTTP 404, HTTP 500, HTTP Error Codes"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "HTTP Status Code Lookup",
    "url": "https://devplaybook.cc/tools/http-status-code-lookup",
    "description": "Browse and search all HTTP status codes from 1xx to 5xx. Descriptions, common causes, and usage guidance for every code.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">HTTP Status Code Lookup</h1>
  <p class="text-text-muted mb-4">
    Browse or search all HTTP status codes — 1xx Informational, 2xx Success, 3xx Redirection,
    4xx Client Error, and 5xx Server Error. Click any code to see description, common causes,
    and when to use it in your API.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All 1xx–5xx codes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Search by code or name</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Causes & usage guidance</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Filter by category</span>
  </div>
  <HttpStatusCodeLookup client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="HTTP Status Code Lookup" relatedTags={['http', 'api', 'rest-api', 'web', 'developer-tools']} />
</BaseLayout>
