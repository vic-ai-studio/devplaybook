---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Helm?", answer: "Helm is the package manager for Kubernetes. Charts (packages) contain templated Kubernetes manifests. A `values.yaml` file provides default configuration; users override values during install. Helm manages releases, upgrades, and rollbacks. It's the standard way to distribute and manage complex Kubernetes applications." },
  { question: "What is values.yaml in Helm?", answer: "values.yaml is the default configuration file for a Helm chart. It defines all configurable parameters for the chart. Users can override values at install time with `--set key=value` or by providing a custom values file with `-f myvalues.yaml`. Values are accessed in templates via `.Values.key`." },
  { question: "What are common Helm values mistakes?", answer: "Common issues: (1) Wrong indentation — YAML is indentation-sensitive. (2) Quoting numbers when strings are expected (or vice versa). (3) Missing required fields that have no defaults. (4) Nested key conflicts — setting both `service.type` and `service: ClusterIP`. (5) Wrong resource limit format — CPU should be 'cpu: 100m', not 'cpu: 0.1'." },
  { question: "How do I validate Helm values without deploying?", answer: "Use `helm template . -f values.yaml` to render templates locally and check for errors. `helm lint` checks the chart structure. For runtime validation, `helm install --dry-run --debug` shows what would be deployed. Use JSON Schema in `values.schema.json` to validate values structure before any rendering." },
  { question: "What is helm values schema validation?", answer: "Helm supports JSON Schema validation via `values.schema.json` in the chart root. When you run `helm install/upgrade/lint`, Helm validates your values against the schema. This catches type errors, missing required fields, and invalid values before deployment. Strongly recommended for shared charts to provide clear error messages." },
];
---

<BaseLayout
  title="Helm Values Validator — Kubernetes Helm Chart Values YAML Checker"
  description="Validate Helm chart values.yaml files. Check YAML syntax, find common misconfigurations, validate resource formats, flag missing required fields, and suggest best practices."
  tool="Helm Values Validator, Kubernetes Helm Chart Linter, Helm YAML Checker, Helm Values Best Practices, Helm Chart Configuration Validator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Helm Values Validator</h1>
  <p class="text-text-muted mb-4">Paste your Helm values.yaml and get instant validation: YAML syntax, common misconfigurations, resource format issues, and best practice suggestions.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> YAML syntax validation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Resource format checks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Best practice suggestions</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <!-- Input -->
    <div class="space-y-4">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-base font-semibold">values.yaml Input</h2>
          <div class="flex gap-2">
            <button class="helm-example text-xs text-primary hover:underline" data-ex="good">Good example</button>
            <button class="helm-example text-xs text-primary hover:underline" data-ex="bad">With issues</button>
          </div>
        </div>
        <textarea id="helm-input" rows="20"
          class="w-full bg-bg-card border border-border rounded-lg p-3 text-xs focus:outline-none focus:border-primary font-mono resize-none"
          placeholder="Paste your values.yaml here..."></textarea>
      </div>
      <button id="validate-helm" class="w-full py-2 bg-primary text-white text-sm rounded-lg hover:bg-primary/80 transition-colors">Validate</button>
    </div>

    <!-- Results -->
    <div class="space-y-4">
      <div id="helm-score" class="bg-bg-card border border-border rounded-xl p-5 text-center hidden">
        <div id="score-circle" class="text-5xl font-bold mb-2">—</div>
        <div class="text-sm text-text-muted">Health Score</div>
      </div>

      <div id="helm-results" class="space-y-3"></div>

      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold mb-3">Helm Best Practices Checklist</h2>
        <div class="space-y-2 text-xs text-text-muted">
          {[
            'Set resource limits (cpu/memory) on all containers',
            'Define readinessProbe and livenessProbe',
            'Use imagePullPolicy: IfNotPresent (not Always in prod)',
            'Avoid latest image tag — use specific versions',
            'Set replicaCount > 1 for production',
            'Define PodDisruptionBudget for HA',
            'Use secrets for sensitive values (not plaintext)',
          ].map(item => `<div class="flex items-start gap-2"><span class="text-text-muted mt-0.5">□</span><span>${item}</span></div>`).join('')}
        </div>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Helm Values Validator" relatedTags={['helm', 'kubernetes', 'k8s', 'devops', 'yaml', 'chart']} />
</BaseLayout>

<script>
  const EXAMPLES: Record<string, string> = {
    good: `replicaCount: 2

image:
  repository: nginx
  tag: "1.25.3"
  pullPolicy: IfNotPresent

service:
  type: ClusterIP
  port: 80

resources:
  limits:
    cpu: 500m
    memory: 256Mi
  requests:
    cpu: 100m
    memory: 128Mi

livenessProbe:
  httpGet:
    path: /healthz
    port: http
  initialDelaySeconds: 30
  periodSeconds: 10

readinessProbe:
  httpGet:
    path: /ready
    port: http
  initialDelaySeconds: 5
  periodSeconds: 5

autoscaling:
  enabled: true
  minReplicas: 2
  maxReplicas: 10
  targetCPUUtilizationPercentage: 70`,

    bad: `replicaCount: 1

image:
  repository: nginx
  tag: latest
  pullPolicy: Always

service:
  type: ClusterIP
  port: 80

resources: {}

env:
  DB_PASSWORD: mypassword123
  API_KEY: sk-prod-supersecret`,
  };

  interface CheckResult {
    severity: 'error' | 'warning' | 'info';
    message: string;
    line?: number;
  }

  function simpleYamlParse(yaml: string): { valid: boolean; obj: Record<string, unknown> | null; error?: string } {
    try {
      // Very basic YAML parser for validation purposes
      const lines = yaml.split('\n');
      const errors: string[] = [];

      // Check indentation consistency
      lines.forEach((line, i) => {
        if (line.trim() === '' || line.trim().startsWith('#')) return;
        const indent = line.match(/^(\s*)/)?.[1].length || 0;
        if (indent % 2 !== 0) errors.push(`Line ${i + 1}: Odd indentation (${indent} spaces)`);
      });

      // Check for tabs
      lines.forEach((line, i) => {
        if (line.includes('\t')) errors.push(`Line ${i + 1}: Tab character found (use spaces)`);
      });

      if (errors.length > 0) return { valid: false, obj: null, error: errors[0] };

      // Build a simple object from the YAML (very limited but good enough for checks)
      const obj: Record<string, unknown> = {};
      lines.forEach(line => {
        const match = line.match(/^(\w[\w.-]*):\s*(.*)$/);
        if (match) obj[match[1]] = match[2].trim();
      });

      return { valid: true, obj };
    } catch (e) {
      return { valid: false, obj: null, error: String(e) };
    }
  }

  function validateHelm(yaml: string): CheckResult[] {
    const results: CheckResult[] = [];
    const lines = yaml.split('\n');

    // YAML structural checks
    lines.forEach((line, i) => {
      const trimmed = line.trim();
      if (!trimmed || trimmed.startsWith('#')) return;

      // Tab check
      if (line.includes('\t')) {
        results.push({ severity: 'error', message: `Line ${i+1}: Tab character detected — use spaces`, line: i+1 });
      }

      // Trailing colon with no value might be intentional for objects
      // Check for duplicate keys (simple)
    });

    // Semantic checks
    const text = yaml.toLowerCase();

    // Resources check
    if (!text.includes('resources:') || text.includes('resources: {}')) {
      results.push({ severity: 'warning', message: 'No resource limits defined — containers may consume unlimited CPU/memory' });
    } else {
      if (!text.includes('limits:')) {
        results.push({ severity: 'warning', message: 'Resource requests found but no limits — add cpu/memory limits' });
      }
      if (!text.includes('requests:')) {
        results.push({ severity: 'info', message: 'Resource limits found but no requests — add cpu/memory requests for scheduling' });
      }
    }

    // Image tag
    if (text.includes('tag: latest') || text.includes("tag: 'latest'") || text.includes('tag: "latest"')) {
      results.push({ severity: 'error', message: 'Using "latest" image tag — not reproducible in production, use a specific version' });
    }

    // Pull policy
    if (text.includes('pullpolicy: always')) {
      results.push({ severity: 'warning', message: 'imagePullPolicy: Always — causes unnecessary registry pulls, use IfNotPresent in production' });
    }

    // Replica count
    const rcMatch = yaml.match(/replicaCount:\s*(\d+)/);
    if (rcMatch && parseInt(rcMatch[1]) < 2) {
      results.push({ severity: 'warning', message: `replicaCount: ${rcMatch[1]} — use 2+ replicas for production availability` });
    }

    // Probes
    if (!text.includes('livenessprobe:') && !text.includes('liveness_probe:')) {
      results.push({ severity: 'warning', message: 'No livenessProbe defined — Kubernetes cannot auto-restart stuck containers' });
    }
    if (!text.includes('readinessprobe:') && !text.includes('readiness_probe:')) {
      results.push({ severity: 'warning', message: 'No readinessProbe defined — traffic may be sent before the app is ready' });
    }

    // Security: plaintext secrets
    const secretPatterns = ['password:', 'secret:', 'api_key:', 'apikey:', 'token:', 'private_key:'];
    secretPatterns.forEach(pattern => {
      const idx = text.indexOf(pattern);
      if (idx >= 0) {
        const lineNum = text.substring(0, idx).split('\n').length;
        const value = yaml.split('\n')[lineNum - 1];
        if (value && !value.includes('secretKeyRef') && !value.includes('valueFrom') && !value.trim().endsWith(':')) {
          results.push({ severity: 'error', message: `Line ~${lineNum}: Possible plaintext secret in "${pattern.replace(':', '')}" — use Kubernetes Secrets or Vault` });
        }
      }
    });

    // CPU format check
    const cpuMatch = yaml.match(/cpu:\s*([0-9.]+)(?!\s*m)/);
    if (cpuMatch && parseFloat(cpuMatch[1]) <= 10) {
      results.push({ severity: 'info', message: `CPU value "${cpuMatch[1]}" may be in cores — use millicores (e.g., "500m" for 0.5 cores)` });
    }

    // Memory format
    if (text.match(/memory:\s*\d+(?!mi|gi|m|g|k)/)) {
      results.push({ severity: 'warning', message: 'Memory value missing unit — add Mi, Gi, M, or G (e.g., "256Mi")' });
    }

    return results;
  }

  document.querySelectorAll('.helm-example').forEach(btn => {
    btn.addEventListener('click', () => {
      (document.getElementById('helm-input') as HTMLTextAreaElement).value = EXAMPLES[btn.getAttribute('data-ex')!];
    });
  });

  document.getElementById('validate-helm')!.addEventListener('click', () => {
    const yaml = (document.getElementById('helm-input') as HTMLTextAreaElement).value.trim();
    if (!yaml) return;

    const results = validateHelm(yaml);
    const errors = results.filter(r => r.severity === 'error').length;
    const warnings = results.filter(r => r.severity === 'warning').length;
    const score = Math.max(0, 100 - errors * 20 - warnings * 10);

    const scoreEl = document.getElementById('helm-score')!;
    scoreEl.classList.remove('hidden');
    const circle = document.getElementById('score-circle')!;
    circle.textContent = score.toString();
    circle.className = `text-5xl font-bold mb-2 ${score >= 80 ? 'text-green-500' : score >= 60 ? 'text-yellow-500' : 'text-red-500'}`;

    const resultsEl = document.getElementById('helm-results')!;
    if (results.length === 0) {
      resultsEl.innerHTML = '<div class="bg-green-500/10 border border-green-500/30 rounded-xl p-4 text-green-500 text-sm">✓ No issues found! Your values.yaml looks good.</div>';
    } else {
      resultsEl.innerHTML = `<div class="text-xs text-text-muted mb-2">${errors} error(s), ${warnings} warning(s)</div>` +
        results.map(r => `
          <div class="bg-bg-card border ${r.severity === 'error' ? 'border-red-500/30' : r.severity === 'warning' ? 'border-yellow-500/30' : 'border-border'} rounded-lg p-3">
            <div class="flex items-start gap-2 text-sm">
              <span class="${r.severity === 'error' ? 'text-red-500' : r.severity === 'warning' ? 'text-yellow-500' : 'text-blue-400'} font-semibold flex-shrink-0">${r.severity.toUpperCase()}</span>
              <span>${r.message}</span>
            </div>
          </div>
        `).join('');
    }
  });

  (document.getElementById('helm-input') as HTMLTextAreaElement).value = EXAMPLES.good;
</script>
