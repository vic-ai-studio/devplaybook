---
import BaseLayout from '../../layouts/BaseLayout.astro';
import KubernetesResourceQuotaCalculator from '../../components/KubernetesResourceQuotaCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What are CPU requests vs limits in Kubernetes?",
    answer: "CPU request is the amount of CPU guaranteed to your container — the scheduler uses this to place pods on nodes. CPU limit is the maximum CPU a container can use before being throttled. Limits can be higher than requests to allow bursting. If a container exceeds its CPU limit, it is throttled (not killed)."
  },
  {
    question: "What happens if a container exceeds its memory limit?",
    answer: "Unlike CPU throttling, exceeding the memory limit causes the container to be OOMKilled (Out of Memory killed) and restarted. Always set memory limits conservatively and monitor actual usage with kubectl top or Prometheus."
  },
  {
    question: "What is the difference between ResourceQuota and LimitRange?",
    answer: "ResourceQuota sets aggregate limits on total resource consumption across all pods in a namespace. LimitRange sets default request/limit values on individual containers when none are specified in the pod spec. Use both together: ResourceQuota to cap total namespace usage, LimitRange to ensure all containers have sensible defaults."
  },
  {
    question: "What CPU and memory units does Kubernetes use?",
    answer: "CPU is specified in cores (1, 0.5) or millicores (500m = 0.5 cores, 100m = 0.1 cores). Memory uses binary suffixes: Ki (kibibytes), Mi (mebibytes), Gi (gibibytes). Always prefer binary units (Mi, Gi) over decimal (M, G) to avoid ambiguity."
  },
  {
    question: "How do I apply a ResourceQuota to my namespace?",
    answer: "Copy the generated YAML and run: kubectl apply -f quota.yaml -n <namespace>. To view current usage: kubectl describe resourcequota -n <namespace>."
  },
];
---

<BaseLayout
  title="Kubernetes Resource Quota Calculator — Generate ResourceQuota & LimitRange YAML"
  description="Calculate total CPU and memory requests and limits across multiple containers. Generate ready-to-apply Kubernetes ResourceQuota and LimitRange YAML for namespace resource management. Free, runs in your browser."
  tool="Kubernetes Resource Calculator, K8s ResourceQuota Generator, Kubernetes LimitRange, Pod Resource Calculator, K8s CPU Memory Calculator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Kubernetes Resource Quota Calculator",
    "url": "https://devplaybook.cc/tools/kubernetes-resource-quota-calculator",
    "description": "Calculate total Kubernetes CPU and memory requests and limits across containers. Generate ResourceQuota and LimitRange YAML for namespace resource management.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Kubernetes Resource Quota Calculator</h1>
  <p class="text-text-muted mb-4">
    Enter CPU and memory requests/limits for each container in your pod. Calculate totals and generate
    ready-to-apply <strong>ResourceQuota</strong> and <strong>LimitRange</strong> YAML for your namespace.
    Supports millicores (<code class="font-mono">m</code>), Mi, and Gi units.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multi-container support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> ResourceQuota YAML</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> LimitRange YAML</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> m / Mi / Gi units</span>
  </div>
  <KubernetesResourceQuotaCalculator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Kubernetes Resource Quota Calculator" relatedTags={['kubernetes', 'devops', 'infrastructure', 'yaml', 'developer-tools']} />
</BaseLayout>
