---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GraphQLPlayground from '../../components/GraphQLPlayground.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is the GraphQL Playground?",
    answer: "The GraphQL Playground is a browser-based tool for writing and executing GraphQL queries against any public GraphQL API. Enter your endpoint URL, write a query, set variables, and click Run — results appear instantly with syntax highlighting.",
  },
  {
    question: "Which GraphQL APIs can I query?",
    answer: "Any public GraphQL API that allows CORS from browsers. The playground ships with three example queries against the free Countries GraphQL API. You can replace the endpoint with any other public GraphQL API URL.",
  },
  {
    question: "Why do I get a CORS error with my API?",
    answer: "Browsers block cross-origin requests unless the target server sets CORS headers. Private or internal APIs typically don't allow browser requests. Use this playground with public GraphQL APIs, or enable CORS on your dev server for local testing.",
  },
  {
    question: "How do I pass variables to a query?",
    answer: "Click the Variables tab in the editor panel and enter a JSON object with your variable values (e.g., { \"code\": \"US\" }). Declare the variable types in your query using the standard GraphQL syntax ($code: ID!).",
  },
  {
    question: "What does the response time indicator show?",
    answer: "The green millisecond counter next to 'Response' shows the round-trip time for your GraphQL request, measured from when you clicked Run to when the full response was received. Useful for quick performance checks.",
  },
  {
    question: "Can I use this with GraphQL mutations?",
    answer: "Yes. Paste any valid GraphQL operation into the Query tab — queries, mutations, and subscriptions (where supported by the API). The tool sends a standard HTTP POST to the endpoint with your operation and variables.",
  },
];
---

<BaseLayout
  title="GraphQL Playground — Online Query Editor with Syntax Highlighting"
  description="Run GraphQL queries and mutations against any API. Split editor, query/variables tabs, syntax-highlighted responses, and response timing. No install needed."
  tool="GraphQL Playground, GraphQL Editor Online, GraphQL Query Tool, GraphQL Tester, GraphQL API Explorer"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">GraphQL Playground</h1>
  <p class="text-text-muted mb-4">
    Execute GraphQL queries and mutations against any public API endpoint directly in your browser. Write queries with variables, see syntax-highlighted JSON responses, and measure response times — no install or signup required.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Query + Variables editor</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Syntax-highlighted response</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Response time tracking</span>
  </div>
  <GraphQLPlayground client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="GraphQL Playground" relatedTags={['graphql', 'api', 'api-testing', 'developer-tools', 'http']} />
</BaseLayout>
