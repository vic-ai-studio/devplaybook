---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReadmeGenerator from '../../components/ReadmeGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What sections does the generated README include?", answer: "The generated README.md includes a project title with badges, description, table of contents, features list, installation instructions, usage examples, tech stack, contributing guide, license, and contact information. All sections are optional — include only what your project needs." },
  { question: "What badge types are supported?", answer: "You can add badges for license (MIT, Apache, GPL), build status, npm version, GitHub stars, and more. Badges use shields.io URLs and update automatically. They add professionalism and at-a-glance project status to your README." },
  { question: "Can I download the README as a file?", answer: "Yes. Click the download button to save the generated content as a README.md file. You can also copy the raw Markdown to your clipboard and paste it directly into your GitHub repository." },
  { question: "Does this work for private/enterprise repositories?", answer: "Yes. The generator creates standard Markdown that works on GitHub, GitLab, Bitbucket, and any platform that renders Markdown. No data is sent to any server — everything runs in your browser, safe for private and enterprise projects." },
  { question: "How should I write a good project description?", answer: "Start with what your project does in one sentence. Then explain why someone would use it — the problem it solves. Keep it under 3 sentences. Avoid jargon unless your audience is technical. A good description improves discoverability on GitHub and npm." },
];
---

<BaseLayout
  title="README Generator — Generate a Complete README.md in Seconds"
  description="Fill in your project details and generate a complete, professional README.md with badges, table of contents, features, installation, usage, and contributing guide. Download or copy instantly. Free, no signup."
  tool="README Generator, README.md Generator, GitHub README Builder, Open Source README Template"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">README Generator</h1>
  <p class="text-text-muted mb-4">Fill in your project details — name, description, tech stack, features, and installation steps — and get a professional README.md in seconds. Includes badges, table of contents, contributing guide, and license section. Download as <code class="font-mono text-sm bg-bg-card px-1 rounded">README.md</code> or copy to clipboard.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <ReadmeGenerator client:load />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="README Generator" relatedTags={['readme', 'github', 'open-source', 'documentation']} />
</BaseLayout>
