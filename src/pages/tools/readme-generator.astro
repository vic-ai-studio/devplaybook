---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReadmeGenerator from '../../components/ReadmeGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="README Generator — Generate a Complete README.md in Seconds"
  description="Fill in your project details and generate a complete, professional README.md with badges, table of contents, features, installation, usage, and contributing guide. Download or copy instantly."
  tool="README Generator, README.md Generator, GitHub README Builder, Open Source README Template"
>
  <h1 class="text-3xl font-bold mb-2">README Generator</h1>
  <p class="text-text-muted mb-8">Fill in your project details — name, description, tech stack, features, and installation steps — and get a professional README.md in seconds. Includes badges, table of contents, contributing guide, and license section. Download as <code class="font-mono text-sm bg-bg-card px-1 rounded">README.md</code> or copy to clipboard.</p>
  <ReadmeGenerator client:load />
  <ToolPageCta currentTool="README Generator" relatedTags={['readme', 'github', 'open-source', 'documentation']} />
</BaseLayout>
