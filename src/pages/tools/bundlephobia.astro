---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const usageExample = `# No installation needed — just visit:
# https://bundlephobia.com/

# Search for any npm package by name in the search bar, e.g.:
#   moment
#   lodash
#   date-fns
#   axios
#   react-query

# Or navigate directly to a package result:
# https://bundlephobia.com/package/lodash
# https://bundlephobia.com/package/date-fns
# https://bundlephobia.com/package/axios@1.6.0

# To check a specific version, append @version to the package name in the URL.`;

const apiExample = `# BundlePhobia also exposes a public JSON API — no API key required.

# Get bundle size info for a package
curl "https://bundlephobia.com/api/size?package=lodash"

# Response (abbreviated):
# {
#   "name": "lodash",
#   "version": "4.17.21",
#   "description": "Lodash modular utilities.",
#   "size": 531614,
#   "gzip": 71655,
#   "dependencyCount": 0,
#   "hasSideEffects": true,
#   "hasJSModule": false,
#   "hasJSNext": false,
#   "isModuleType": false
# }

# Get size for a specific version
curl "https://bundlephobia.com/api/size?package=lodash@4.17.21"

# Get size history across all versions
curl "https://bundlephobia.com/api/size-history?package=axios"`;

const workflowExample = `# Example workflow: evaluating a date library before adding it as a dependency

# Step 1: Visit bundlephobia.com and search for "moment"
# Result: moment@2.30.1 — 72.1 kB (minified) / 18.2 kB (gzip)
# Warning: hasSideEffects: true (cannot tree-shake)
# Shows: download time ~364 ms on slow 3G

# Step 2: Search for alternatives Bundlephobia suggests: "date-fns"
# Result: date-fns@3.6.0 — 2.28 kB for a single import (tree-shakeable!)
# The full package is 500+ kB but you only pay for what you import.

# Step 3: Check "dayjs"
# Result: dayjs@1.11.11 — 6.96 kB (minified) / 2.77 kB (gzip)
# hasSideEffects: false (tree-shakeable)

# Conclusion: moment costs 18.2 kB gzipped on every load.
# date-fns or dayjs are 4-8x smaller for equivalent functionality.`;

const compositionExample = `# Understanding what BundlePhobia shows you

# For each package, BundlePhobia displays:
#
# 1. MINIFIED SIZE — after removing whitespace and comments
#    Example: lodash = 531 kB minified
#
# 2. GZIPPED SIZE — what the browser actually downloads
#    Example: lodash = 71.7 kB gzipped
#
# 3. VERSION HISTORY — a chart of size changes across versions
#    Useful for spotting when a package ballooned in size
#
# 4. DOWNLOAD TIME ESTIMATES — slow 3G / 4G / emerging markets
#    Example: lodash 71 kB = ~1.4 s on slow 3G
#
# 5. SIMILAR PACKAGES — smaller alternatives with size comparison
#    lodash → alternatives: lodash-es, just, remeda, radash
#
# 6. DUPLICATE DETECTION — warns if the package brings in a dependency
#    you already have (e.g. a package bundling its own copy of React)
#
# 7. SIDE EFFECTS FLAG — whether tree shaking can remove unused exports
#    hasSideEffects: false = safe to tree shake
#    hasSideEffects: true  = entire package loads regardless of imports`;

const integrationExample = `# Using Bundlephobia data in your workflow

# 1. Browser extension (unofficial) — shows package size inline on
#    npmjs.com and github.com package listings

# 2. VS Code extension — bundlephobia-vscode shows import sizes inline
#    in your editor as you type import statements:
#    import { format } from 'date-fns';  // 17 B

# 3. Package.json audit — manually cross-check your top dependencies:
#    cat package.json | grep -E '"[^"]+": "\^' | while read line; do
#      pkg=$(echo "$line" | cut -d'"' -f2)
#      echo "Checking: $pkg"
#      curl -s "https://bundlephobia.com/api/size?package=$pkg" |
#        python3 -c "import sys,json; d=json.load(sys.stdin);
#          print(d['name'], d['gzip'], 'bytes gzipped')"
#    done`;

const faq = [
  {
    question: "What is BundlePhobia?",
    answer: "BundlePhobia is a free public web tool that lets you look up the bundle size cost of any npm package before installing it. You search for a package by name and BundlePhobia shows you the minified size, gzipped size, download time estimate, version history, whether the package is tree-shakeable, and suggestions for smaller alternatives. It is designed to help developers make informed decisions about which dependencies to add to their projects."
  },
  {
    question: "How does BundlePhobia calculate bundle size?",
    answer: "BundlePhobia installs the npm package in an isolated environment, bundles it with Webpack using a minimal entry point, applies minification, and then compresses the result with gzip. This gives a realistic estimate of what a browser would download when the package is imported. The result may differ slightly from your real-world bundle because BundlePhobia does not know which parts of the package your app actually uses — for tree-shakeable packages the real cost is usually lower."
  },
  {
    question: "Does BundlePhobia support tree shaking?",
    answer: "BundlePhobia measures the full package size by default, but it shows a hasSideEffects flag indicating whether the package can be tree-shaken. When hasSideEffects is false, your bundler can eliminate unused exports, so the actual cost in your app may be much smaller than the total package size. For tree-shakeable packages like date-fns, you pay only for the functions you import — BundlePhobia notes this distinction in the results."
  },
  {
    question: "Can I use BundlePhobia programmatically?",
    answer: "Yes. BundlePhobia exposes a public JSON API at bundlephobia.com/api/size that accepts a package query parameter. You can pass package=lodash or package=lodash@4.17.21 for a specific version. The response includes name, version, minified size, gzipped size, dependency count, and the hasSideEffects flag. No API key is required. There is also a size-history endpoint for fetching size trends across all published versions of a package."
  },
  {
    question: "What does 'side effects' mean in BundlePhobia?",
    answer: "The sideEffects field comes from the package.json of the npm package itself. When a package author sets sideEffects: false, they are declaring that importing from the package will not execute any code with observable side effects (like modifying globals or registering event listeners). This tells bundlers it is safe to remove unused exports through tree shaking. When hasSideEffects is true, the entire package is included in your bundle regardless of which parts you import."
  },
  {
    question: "How do I compare packages on BundlePhobia?",
    answer: "BundlePhobia automatically suggests similar packages with a size comparison at the bottom of each result page. You can also use the comparison URL format: bundlephobia.com/package/moment,date-fns,dayjs to see all three side by side. The comparison view shows minified and gzipped sizes, download times, and weekly npm download counts so you can balance size against popularity when choosing between alternatives."
  },
];
---

<BaseLayout
  title="BundlePhobia — Check npm Package Bundle Cost Online"
  description="BundlePhobia is a free online tool that shows the minified and gzipped bundle size of any npm package, version history, tree-shaking support, and smaller alternatives — no install needed."
  tool="bundlephobia, bundle size, npm, package size, performance, dependency analysis, tree shaking, online tool"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "BundlePhobia — Check npm Package Bundle Cost Online",
    "url": "https://devplaybook.cc/tools/bundlephobia",
    "description": "BundlePhobia shows the minified and gzipped bundle size of any npm package, version history, tree-shaking support, download time estimates, and smaller alternatives.",
  })} />

  <h1 class="text-3xl font-bold mb-2">BundlePhobia</h1>
  <p class="text-text-muted mb-6">
    Free online tool that shows the real minified and gzipped bundle cost of any npm package.
    Check size over version history, identify tree-shakeable packages, find smaller alternatives,
    and estimate download times — all before writing a single <code class="bg-bg-card px-1 rounded text-xs">npm install</code>.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Minified + gzipped size</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Version history chart</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Tree-shaking detection</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Download time estimate</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Smaller alternatives</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No install needed</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is BundlePhobia?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    BundlePhobia is a free public web tool created by Paskal Rao that answers the question every developer should ask before installing a dependency: <em>how much does this package actually cost?</em> You type in any npm package name, and BundlePhobia builds it in isolation, measures the output, and presents a clear breakdown of the minified size, gzipped size, download time on various connection speeds, and whether the package supports tree shaking.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    The tool is especially valuable when choosing between competing libraries. A quick search for <code class="bg-bg-card px-1 rounded text-xs">moment</code> versus <code class="bg-bg-card px-1 rounded text-xs">date-fns</code> versus <code class="bg-bg-card px-1 rounded text-xs">dayjs</code> immediately shows that moment ships 18 kB gzipped with no tree shaking, while dayjs delivers the same core API for 2.8 kB. That is the kind of information that should drive dependency decisions, and BundlePhobia surfaces it in seconds without requiring any local setup.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Minified + gzipped size</strong> — reports both the post-minification size and the compressed size that browsers actually download</li>
    <li><strong>Version history</strong> — a chart showing how package size has changed across every published version, highlighting when a package bloated</li>
    <li><strong>Tree-shaking flag</strong> — shows whether the package declares <code class="bg-bg-card px-1 rounded text-xs">sideEffects: false</code>, meaning unused exports can be removed by bundlers</li>
    <li><strong>Download time estimates</strong> — projected download time on slow 3G, 4G, and other connection profiles for real-world context</li>
    <li><strong>Smaller alternatives</strong> — automatically suggests lighter packages with similar functionality for common dependencies</li>
    <li><strong>Duplicate dependency detection</strong> — warns if a package bundles a dependency you already have, signaling potential size duplication</li>
    <li><strong>Public JSON API</strong> — a free REST endpoint for programmatic size lookups, no API key required</li>
    <li><strong>No install needed</strong> — entirely online, works from any browser, nothing to configure locally</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">How to Use BundlePhobia</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={usageExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Understanding the Results</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Each result page shows multiple signals. Understanding what each number means helps you make the right decision about whether to add, replace, or avoid a package.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={compositionExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Practical Example: Choosing a Date Library</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    BundlePhobia excels at comparative evaluations. Here is a real-world workflow for choosing a date handling library.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={workflowExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Using the Public API</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    BundlePhobia exposes a free JSON API for programmatic lookups. Useful for automated dependency audits or custom tooling.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={apiExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Editor and Workflow Integrations</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Beyond the website, BundlePhobia data is available through editor extensions and can be queried via the API to build custom auditing workflows.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={integrationExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">BundlePhobia vs Size Limit vs Bundlewatch</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">BundlePhobia</th>
          <th class="border border-border px-3 py-2 text-left">Size Limit</th>
          <th class="border border-border px-3 py-2 text-left">Bundlewatch</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2">Check npm packages</td><td class="border border-border px-3 py-2 text-green-400">Yes</td><td class="border border-border px-3 py-2">No</td><td class="border border-border px-3 py-2">No</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Enforce your output size</td><td class="border border-border px-3 py-2">No</td><td class="border border-border px-3 py-2 text-green-400">Yes</td><td class="border border-border px-3 py-2 text-green-400">Yes</td></tr>
        <tr><td class="border border-border px-3 py-2">No install / online tool</td><td class="border border-border px-3 py-2 text-green-400">Yes</td><td class="border border-border px-3 py-2">No</td><td class="border border-border px-3 py-2">No</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Version history chart</td><td class="border border-border px-3 py-2 text-green-400">Yes</td><td class="border border-border px-3 py-2">No</td><td class="border border-border px-3 py-2">No</td></tr>
        <tr><td class="border border-border px-3 py-2">Suggests alternatives</td><td class="border border-border px-3 py-2 text-green-400">Yes</td><td class="border border-border px-3 py-2">No</td><td class="border border-border px-3 py-2">No</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">CI pipeline integration</td><td class="border border-border px-3 py-2">API only</td><td class="border border-border px-3 py-2 text-green-400">Yes (GitHub Action)</td><td class="border border-border px-3 py-2 text-green-400">Yes</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pros and Cons</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-green-400 mb-2">Pros</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✓ Zero setup — open a browser tab and search, nothing to install</li>
        <li>✓ Version history makes it easy to spot when a package grew significantly</li>
        <li>✓ Suggests lighter alternatives automatically — great for discovery</li>
        <li>✓ Shows real gzip size, not misleading raw file size</li>
        <li>✓ Free public API enables custom tooling and automated audits</li>
        <li>✓ Tree-shaking flag helps you understand the true cost for your app</li>
      </ul>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-red-400 mb-2">Cons</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✗ Cannot enforce size budgets on your own output (use Size Limit for that)</li>
        <li>✗ Measures full package; actual import cost may be lower for tree-shakeable packages</li>
        <li>✗ Occasional cache lag — very new package versions may not appear immediately</li>
        <li>✗ No CI blocking capability — it is a research tool, not a gating tool</li>
        <li>✗ API has no rate limit documentation; may throttle heavy automated use</li>
      </ul>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="bundlephobia" relatedTags={['bundle-size', 'npm', 'performance', 'dependency-analysis', 'online-tool']} />
</BaseLayout>
