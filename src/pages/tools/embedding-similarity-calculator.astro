---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is cosine similarity?", answer: "Cosine similarity measures the angle between two vectors, regardless of their magnitude. It returns a value between -1 and 1: 1 means identical direction (semantically very similar), 0 means orthogonal (unrelated), and -1 means opposite directions. For embeddings, scores above 0.8 typically indicate strong similarity; 0.5–0.8 is moderate; below 0.5 is weak." },
  { question: "What is the difference between cosine similarity and dot product?", answer: "Dot product measures both direction and magnitude, while cosine similarity normalizes the vectors first (making it magnitude-invariant). For normalized embedding vectors (which most models produce), dot product and cosine similarity give the same ranking. OpenAI embeddings are normalized by default, so either metric works equally for ranking." },
  { question: "What do embedding vectors represent?", answer: "Embeddings are high-dimensional (typically 768–3072 dimensions) numeric representations of text. Similar texts produce vectors that are close together in this high-dimensional space. They're generated by models like text-embedding-3-small (OpenAI), all-mpnet-base-v2 (Sentence Transformers), or Cohere Embed. Vector databases like Pinecone, Weaviate, and pgvector store and query these efficiently." },
  { question: "How do I get embedding vectors from OpenAI?", answer: "Use the Embeddings API: client.embeddings.create(model='text-embedding-3-small', input='your text'). The response includes a 1536-dimension float array. text-embedding-3-small is cost-effective ($0.02/1M tokens); text-embedding-3-large (3072 dims) provides higher accuracy for RAG and semantic search. Never use completion models (GPT-4o) for embeddings — use dedicated embedding models." },
  { question: "What similarity score is 'good' for RAG retrieval?", answer: "For RAG retrieval thresholds: >0.85 is very high confidence (near-identical content), 0.70–0.85 is relevant (good retrieval candidate), 0.50–0.70 is loosely related (use with caution), <0.50 is likely irrelevant. These thresholds vary by embedding model — newer models (text-embedding-3) tend to have tighter score distributions than older ones. Always tune thresholds empirically on your dataset." },
];
---

<BaseLayout
  title="Embedding Similarity Calculator — Cosine Similarity for AI Embeddings"
  description="Calculate cosine similarity, dot product, and Euclidean distance between two embedding vectors. Paste vectors to instantly measure semantic similarity for RAG and vector search."
  tool="embedding similarity calculator, cosine similarity, vector similarity, semantic similarity, RAG threshold, text embedding distance"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Embedding Similarity Calculator</h1>
  <p class="text-text-muted mb-4">Paste two embedding vectors to calculate cosine similarity, dot product, and Euclidean distance. Essential for tuning RAG retrieval thresholds.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Cosine similarity</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Dot product + L2 distance</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Relevance interpretation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Random test vectors</span>
  </div>

  <div class="space-y-5">
    <!-- Vector inputs -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-2">
          <h2 class="font-semibold">Vector A</h2>
          <span class="text-xs text-text-muted" id="dim-a">— dims</span>
        </div>
        <textarea id="vec-a" rows="8"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2.5 text-xs font-mono focus:outline-none focus:ring-2 focus:ring-primary/40 resize-y"
          placeholder="Paste embedding vector here&#10;[0.123, -0.456, 0.789, ...]&#10;or comma-separated values"></textarea>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-2">
          <h2 class="font-semibold">Vector B</h2>
          <span class="text-xs text-text-muted" id="dim-b">— dims</span>
        </div>
        <textarea id="vec-b" rows="8"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2.5 text-xs font-mono focus:outline-none focus:ring-2 focus:ring-primary/40 resize-y"
          placeholder="Paste embedding vector here&#10;[0.321, -0.654, 0.987, ...]&#10;or comma-separated values"></textarea>
      </div>
    </div>

    <!-- Actions -->
    <div class="flex flex-wrap gap-3">
      <button id="calc-btn" class="bg-primary text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-primary/80 transition-colors">Calculate Similarity</button>
      <button id="gen-similar-btn" class="bg-bg border border-border px-4 py-2.5 rounded-lg text-sm hover:border-primary hover:text-primary transition-colors">Generate Similar Vectors</button>
      <button id="gen-different-btn" class="bg-bg border border-border px-4 py-2.5 rounded-lg text-sm hover:border-primary hover:text-primary transition-colors">Generate Different Vectors</button>
    </div>

    <!-- Results -->
    <div id="results" class="hidden space-y-4">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
          <div class="text-xs text-text-muted mb-1 uppercase tracking-wide">Cosine Similarity</div>
          <div class="text-4xl font-bold my-2" id="cosine-val">—</div>
          <div class="text-xs font-medium rounded-full px-3 py-1 inline-block" id="cosine-label">—</div>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
          <div class="text-xs text-text-muted mb-1 uppercase tracking-wide">Dot Product</div>
          <div class="text-4xl font-bold text-primary my-2" id="dot-val">—</div>
          <div class="text-xs text-text-muted">magnitude-sensitive</div>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
          <div class="text-xs text-text-muted mb-1 uppercase tracking-wide">Euclidean Distance</div>
          <div class="text-4xl font-bold text-primary my-2" id="l2-val">—</div>
          <div class="text-xs text-text-muted">smaller = more similar</div>
        </div>
      </div>

      <!-- Similarity gauge -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold mb-3">Similarity Scale</h2>
        <div class="relative h-6 rounded-full overflow-hidden bg-gradient-to-r from-red-500 via-yellow-500 to-green-500 mb-2">
          <div id="gauge-marker" class="absolute top-0 w-1 h-6 bg-white shadow-lg transition-all" style="left:50%"></div>
        </div>
        <div class="flex justify-between text-xs text-text-muted">
          <span>-1 (opposite)</span>
          <span>0 (unrelated)</span>
          <span>+1 (identical)</span>
        </div>
        <div class="mt-3 p-3 bg-bg border border-border rounded-lg">
          <div class="text-sm font-medium" id="interpretation">—</div>
        </div>
      </div>

      <!-- RAG threshold guide -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold mb-3">RAG Threshold Reference</h2>
        <div class="space-y-2" id="threshold-table"></div>
      </div>

      <!-- Python code -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold mb-3">Python Code</h2>
        <pre class="bg-bg rounded-lg p-4 text-xs font-mono overflow-x-auto text-green-400" id="py-code"></pre>
      </div>
    </div>

    <div id="error-msg" class="hidden bg-red-500/10 border border-red-500/30 rounded-xl p-4 text-sm text-red-400"></div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Embedding Similarity Calculator" relatedTags={['ai', 'embedding', 'rag', 'vector-database', 'semantic-search', 'llm']} />
</BaseLayout>

<script is:inline>
(function () {
  var vecA = document.getElementById('vec-a');
  var vecB = document.getElementById('vec-b');
  var dimA = document.getElementById('dim-a');
  var dimB = document.getElementById('dim-b');
  var calcBtn = document.getElementById('calc-btn');
  var genSimilar = document.getElementById('gen-similar-btn');
  var genDifferent = document.getElementById('gen-different-btn');
  var results = document.getElementById('results');
  var errorMsg = document.getElementById('error-msg');
  var cosineVal = document.getElementById('cosine-val');
  var cosineLabel = document.getElementById('cosine-label');
  var dotVal = document.getElementById('dot-val');
  var l2Val = document.getElementById('l2-val');
  var gaugeMarker = document.getElementById('gauge-marker');
  var interpretation = document.getElementById('interpretation');
  var thresholdTable = document.getElementById('threshold-table');
  var pyCode = document.getElementById('py-code');

  function parseVector(str) {
    str = str.trim().replace(/^\[|\]$/g, '');
    if (!str) return null;
    var parts = str.split(/[\s,]+/).filter(function (s) { return s !== ''; });
    var nums = parts.map(Number);
    if (nums.some(isNaN)) return null;
    return nums;
  }

  function cosineSim(a, b) {
    var dot = 0, magA = 0, magB = 0;
    for (var i = 0; i < a.length; i++) { dot += a[i] * b[i]; magA += a[i] * a[i]; magB += b[i] * b[i]; }
    if (magA === 0 || magB === 0) return 0;
    return dot / (Math.sqrt(magA) * Math.sqrt(magB));
  }

  function dotProduct(a, b) {
    var d = 0; for (var i = 0; i < a.length; i++) d += a[i] * b[i]; return d;
  }

  function l2Distance(a, b) {
    var s = 0; for (var i = 0; i < a.length; i++) { var d = a[i] - b[i]; s += d * d; } return Math.sqrt(s);
  }

  function randVec(dim) {
    var v = []; for (var i = 0; i < dim; i++) v.push((Math.random() * 2 - 1).toFixed(6));
    return v;
  }

  function normalize(v) {
    var mag = Math.sqrt(v.reduce(function (s, x) { return s + x * x; }, 0));
    return mag === 0 ? v : v.map(function (x) { return x / mag; });
  }

  vecA.addEventListener('input', function () {
    var v = parseVector(vecA.value);
    dimA.textContent = v ? v.length + ' dims' : 'invalid';
  });
  vecB.addEventListener('input', function () {
    var v = parseVector(vecB.value);
    dimB.textContent = v ? v.length + ' dims' : 'invalid';
  });

  calcBtn.addEventListener('click', function () {
    errorMsg.classList.add('hidden');
    var a = parseVector(vecA.value);
    var b = parseVector(vecB.value);
    if (!a || !b) { errorMsg.textContent = 'Invalid vector format. Use comma-separated numbers or [x, y, z, ...] format.'; errorMsg.classList.remove('hidden'); return; }
    if (a.length !== b.length) { errorMsg.textContent = 'Vectors must have the same dimensions. A: ' + a.length + 'd, B: ' + b.length + 'd.'; errorMsg.classList.remove('hidden'); return; }

    var cs = cosineSim(a, b);
    var dp = dotProduct(a, b);
    var l2 = l2Distance(a, b);

    cosineVal.textContent = cs.toFixed(4);
    dotVal.textContent = dp.toFixed(4);
    l2Val.textContent = l2.toFixed(4);

    var pct = ((cs + 1) / 2) * 100;
    gaugeMarker.style.left = pct + '%';

    var labelMap;
    if (cs >= 0.95) labelMap = { text: 'Nearly Identical', cls: 'bg-green-500/20 text-green-400' };
    else if (cs >= 0.85) labelMap = { text: 'Very High', cls: 'bg-green-500/20 text-green-400' };
    else if (cs >= 0.70) labelMap = { text: 'High — Good RAG Match', cls: 'bg-emerald-500/20 text-emerald-400' };
    else if (cs >= 0.50) labelMap = { text: 'Moderate', cls: 'bg-yellow-500/20 text-yellow-400' };
    else if (cs >= 0.25) labelMap = { text: 'Low', cls: 'bg-orange-500/20 text-orange-400' };
    else if (cs >= 0) labelMap = { text: 'Very Low', cls: 'bg-red-500/20 text-red-400' };
    else labelMap = { text: 'Negative (Dissimilar)', cls: 'bg-red-500/20 text-red-400' };

    cosineVal.className = 'text-4xl font-bold my-2 ' + labelMap.cls.split(' ')[1];
    cosineLabel.textContent = labelMap.text;
    cosineLabel.className = 'text-xs font-medium rounded-full px-3 py-1 inline-block ' + labelMap.cls;

    var interpMap = [
      [0.95, 'The vectors are nearly identical. The two texts likely have the same or very similar meaning.'],
      [0.85, 'Very high similarity. These texts are semantically very close — strong RAG retrieval match.'],
      [0.70, 'High similarity. Good candidate for RAG retrieval. Texts share significant semantic overlap.'],
      [0.50, 'Moderate similarity. Some semantic overlap but distinct topics. Use with caution in RAG.'],
      [0.25, 'Low similarity. The texts cover different topics with little semantic overlap.'],
      [0.0, 'Very low similarity. The texts are largely unrelated.'],
      [-2, 'Negative similarity. The vectors point in opposite directions — semantically dissimilar or contradictory content.'],
    ];
    for (var i = 0; i < interpMap.length; i++) {
      if (cs >= interpMap[i][0]) { interpretation.textContent = interpMap[i][1]; break; }
    }

    thresholdTable.innerHTML = [
      ['>0.95', 'Exact/Near-duplicate', 'Deduplication, cache hits', 'bg-green-500/20 text-green-400'],
      ['0.85–0.95', 'Very high', 'Primary RAG results', 'bg-green-500/20 text-green-400'],
      ['0.70–0.85', 'High', 'Secondary RAG results', 'bg-emerald-500/20 text-emerald-400'],
      ['0.50–0.70', 'Moderate', 'Broad topic matching', 'bg-yellow-500/20 text-yellow-400'],
      ['0.25–0.50', 'Low', 'Weak relation, likely irrelevant', 'bg-orange-500/20 text-orange-400'],
      ['<0.25', 'Very low / Negative', 'Not relevant, filter out', 'bg-red-500/20 text-red-400'],
    ].map(function (row) {
      var isActive = (row[0] === '>0.95' && cs >= 0.95) ||
        (row[0] === '0.85–0.95' && cs >= 0.85 && cs < 0.95) ||
        (row[0] === '0.70–0.85' && cs >= 0.70 && cs < 0.85) ||
        (row[0] === '0.50–0.70' && cs >= 0.50 && cs < 0.70) ||
        (row[0] === '0.25–0.50' && cs >= 0.25 && cs < 0.50) ||
        (row[0] === '<0.25' && cs < 0.25);
      return '<div class="flex items-center gap-3 text-sm py-1.5 ' + (isActive ? 'font-bold' : 'text-text-muted') + '">' +
        '<span class="font-mono w-20 text-xs ' + row[3] + ' rounded px-2 py-0.5 text-center">' + row[0] + '</span>' +
        '<span class="w-28">' + row[1] + '</span>' +
        '<span class="text-xs">' + row[2] + '</span>' +
        (isActive ? ' <span class="ml-auto text-xs text-primary">← your score</span>' : '') +
        '</div>';
    }).join('');

    pyCode.textContent =
      'import numpy as np\n\n' +
      'vec_a = np.array([' + a.slice(0, 5).join(', ') + (a.length > 5 ? ', ...' : '') + '])  # ' + a.length + 'd\n' +
      'vec_b = np.array([' + b.slice(0, 5).join(', ') + (b.length > 5 ? ', ...' : '') + '])  # ' + b.length + 'd\n\n' +
      '# Cosine similarity\ncosine_sim = np.dot(vec_a, vec_b) / (np.linalg.norm(vec_a) * np.linalg.norm(vec_b))\n' +
      '# Result: ' + cs.toFixed(6) + '\n\n' +
      '# Dot product\ndot = np.dot(vec_a, vec_b)  # ' + dp.toFixed(6) + '\n\n' +
      '# Euclidean distance\nl2 = np.linalg.norm(vec_a - vec_b)  # ' + l2.toFixed(6) + '\n\n' +
      '# For OpenAI embeddings (already normalized):\nfrom openai import OpenAI\nclient = OpenAI()\n' +
      'emb = client.embeddings.create(model="text-embedding-3-small", input=["text A", "text B"])\n' +
      'a_vec = np.array(emb.data[0].embedding)\nb_vec = np.array(emb.data[1].embedding)\n' +
      'sim = np.dot(a_vec, b_vec)  # already normalized, dot == cosine sim';

    results.classList.remove('hidden');
  });

  function genVectors(similar) {
    var dim = 16;
    var base = normalize(randVec(dim).map(Number));
    var noise = similar ? 0.05 : 1.0;
    var bArr = base.map(function (x) { return x + (Math.random() * 2 - 1) * noise; });
    var bNorm = normalize(bArr);
    vecA.value = '[' + base.map(function (x) { return x.toFixed(6); }).join(', ') + ']';
    vecB.value = '[' + bNorm.map(function (x) { return x.toFixed(6); }).join(', ') + ']';
    dimA.textContent = dim + ' dims';
    dimB.textContent = dim + ' dims';
    calcBtn.click();
  }

  genSimilar.addEventListener('click', function () { genVectors(true); });
  genDifferent.addEventListener('click', function () { genVectors(false); });

  // Auto-load example
  genVectors(true);
})();
</script>
