---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What are the four standard code coverage metrics?",
    answer: "Line coverage: percentage of source lines executed during tests. Branch coverage: percentage of decision paths taken (both true/false for if/else). Function coverage: percentage of functions/methods that were called. Statement coverage: percentage of individual statements executed (finer-grained than line coverage). Branch coverage is generally the most meaningful because it catches logic gaps that line coverage misses.",
  },
  {
    question: "What coverage percentage should I aim for?",
    answer: "80% is the widely accepted industry standard for most production projects. Google's engineering guidelines suggest 60% as acceptable, 75% as good, and 90%+ as exemplary. However, raw percentages can be misleading — 100% line coverage doesn't guarantee correct behavior. Aim for 80% as a starting point, focus on critical paths, and use meaningful assertions rather than just maximizing coverage numbers.",
  },
  {
    question: "How do I input lines, branches, and functions for calculation?",
    answer: "You need two numbers for each metric: total (how many exist in your codebase) and covered (how many were executed during your test suite). Jest and Vitest print these numbers when you run with --coverage: e.g., 'Lines: 450/600' means 450 covered out of 600 total. Enter these numbers directly into the calculator to see your percentage and pass/fail status.",
  },
  {
    question: "How do I set coverage thresholds in Jest or Vitest?",
    answer: "In jest.config.js: add coverageThreshold: { global: { lines: 80, functions: 80, branches: 70, statements: 80 } }. In vitest.config.ts: add coverage: { thresholds: { lines: 80, functions: 80, branches: 70 } } inside the test block. The build will fail if any metric falls below its threshold — perfect for CI enforcement. This calculator generates the config snippet based on your entered values.",
  },
  {
    question: "Why is branch coverage often lower than line coverage?",
    answer: "Because a line can be 'covered' even if only one branch was taken. For example, if (condition) { doA() } else { doB() } — if your tests only trigger the true branch, line coverage shows the if-statement as covered, but branch coverage shows 50% (one of two paths). Branch coverage is stricter and catches gaps in conditional logic that line coverage misses.",
  },
  {
    question: "What is the difference between v8 and istanbul coverage providers?",
    answer: "v8 uses Node.js's built-in V8 engine coverage data — it's fast, no code instrumentation needed, and works with source maps. Istanbul instruments your code by injecting counters at compile time — it's slower but generally more accurate for complex code, especially around branches in minified or transpiled code. For most TypeScript projects, v8 is sufficient and recommended. Use istanbul if you notice v8 misreporting edge cases.",
  },
];
---

<BaseLayout
  title="Test Coverage Calculator — Calculate Line, Branch & Function Coverage %"
  description="Calculate code coverage percentages for lines, branches, functions, and statements. Enter covered/total counts, see pass/fail against thresholds, and generate Jest/Vitest coverage config. Free, runs in your browser."
  tool="Test Coverage Calculator, Code Coverage Percentage, Jest Coverage Threshold, Vitest Coverage Calculator, Branch Line Function Coverage"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Test Coverage Calculator",
    "url": "https://devplaybook.cc/tools/test-coverage-calculator",
    "description": "Calculate line, branch, function, and statement code coverage percentages. Set thresholds, check pass/fail status, and generate Jest/Vitest config snippets.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Test Coverage Calculator</h1>
  <p class="text-text-muted mb-4">
    Enter covered and total counts for lines, branches, functions, and statements.
    See your coverage percentages, pass/fail status against thresholds, and get a
    ready-to-use <code class="text-primary font-mono">jest.config.js</code> /
    <code class="text-primary font-mono">vitest.config.ts</code> threshold snippet.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Lines, branches, functions, statements</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Configurable thresholds</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Pass / Fail status</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Jest & Vitest config output</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Inputs -->
    <div class="flex flex-col gap-4">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted mb-4">Coverage Counts</h2>
        <div class="grid grid-cols-3 gap-2 text-sm font-medium text-text-muted mb-2 px-1">
          <span>Metric</span><span class="text-center">Covered</span><span class="text-center">Total</span>
        </div>
        {['lines', 'branches', 'functions', 'statements'].map(metric => (
          <div class="grid grid-cols-3 gap-2 items-center mb-3">
            <label class="text-sm font-medium capitalize">{metric}</label>
            <input id={`${metric}-covered`} type="number" value={metric === 'lines' ? '450' : metric === 'branches' ? '180' : metric === 'functions' ? '95' : '460'} min="0" class="px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm text-center focus:outline-none focus:border-accent transition-colors" />
            <input id={`${metric}-total`} type="number" value={metric === 'lines' ? '600' : metric === 'branches' ? '250' : metric === 'functions' ? '110' : '620'} min="1" class="px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm text-center focus:outline-none focus:border-accent transition-colors" />
          </div>
        ))}
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted mb-4">Thresholds (%)</h2>
        <div class="grid grid-cols-2 gap-3">
          {['lines', 'branches', 'functions', 'statements'].map(metric => (
            <div>
              <label class="block text-sm font-medium capitalize mb-1" for={`${metric}-threshold`}>{metric}</label>
              <input id={`${metric}-threshold`} type="number" value={metric === 'branches' ? '70' : '80'} min="0" max="100" step="5" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Results -->
    <div class="flex flex-col gap-4">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted mb-4">Results</h2>
        <div id="results-grid" class="flex flex-col gap-3"></div>
        <div id="overall-status" class="mt-4 p-3 rounded-lg text-sm font-medium text-center"></div>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Config Snippet</h2>
          <div class="flex gap-2">
            <button id="fmt-jest" class="px-3 py-1 rounded text-xs bg-accent text-white transition-colors">Jest</button>
            <button id="fmt-vitest" class="px-3 py-1 rounded text-xs bg-bg border border-border text-text-muted transition-colors">Vitest</button>
            <button id="copy-config" class="px-3 py-1 rounded text-xs bg-bg border border-border text-text-muted hover:text-text transition-colors">Copy</button>
          </div>
        </div>
        <pre id="config-output" class="text-xs font-mono bg-bg rounded-lg p-3 overflow-auto max-h-48 text-text"></pre>
      </div>
    </div>
  </div>

  <script>
    let configFormat = 'jest';

    const metrics = ['lines', 'branches', 'functions', 'statements'];

    function pct(covered: number, total: number): number {
      if (total === 0) return 100;
      return Math.round((covered / total) * 1000) / 10;
    }

    function calculate() {
      const values = metrics.map(m => {
        const covered = parseFloat((document.getElementById(`${m}-covered`) as HTMLInputElement).value) || 0;
        const total = parseFloat((document.getElementById(`${m}-total`) as HTMLInputElement).value) || 1;
        const threshold = parseFloat((document.getElementById(`${m}-threshold`) as HTMLInputElement).value) || 0;
        const percentage = pct(covered, total);
        const pass = percentage >= threshold;
        return { metric: m, covered, total, percentage, threshold, pass };
      });

      // Render results
      const grid = document.getElementById('results-grid') as HTMLElement;
      grid.innerHTML = values.map(v => `
        <div class="flex items-center gap-3">
          <span class="w-24 text-sm font-medium capitalize">${v.metric}</span>
          <div class="flex-1 bg-bg rounded-full h-2 overflow-hidden">
            <div class="h-full rounded-full transition-all ${v.pass ? 'bg-green-500' : 'bg-red-500'}" style="width: ${Math.min(v.percentage, 100)}%"></div>
          </div>
          <span class="w-14 text-right text-sm font-mono font-semibold ${v.pass ? 'text-green-400' : 'text-red-400'}">${v.percentage}%</span>
          <span class="w-6 text-center">${v.pass ? '✓' : '✗'}</span>
        </div>
      `).join('');

      const allPass = values.every(v => v.pass);
      const overall = document.getElementById('overall-status') as HTMLElement;
      overall.textContent = allPass ? '✓ All coverage thresholds passed' : '✗ One or more thresholds not met';
      overall.className = `mt-4 p-3 rounded-lg text-sm font-medium text-center ${allPass ? 'bg-green-500/10 text-green-400 border border-green-500/30' : 'bg-red-500/10 text-red-400 border border-red-500/30'}`;

      renderConfig(values);
    }

    function renderConfig(values: { metric: string; threshold: number }[]) {
      const thresholds = Object.fromEntries(values.map(v => [v.metric, v.threshold]));
      let config = '';

      if (configFormat === 'jest') {
        config = `// jest.config.js
module.exports = {
  coverageThreshold: {
    global: {
      lines: ${thresholds.lines},
      branches: ${thresholds.branches},
      functions: ${thresholds.functions},
      statements: ${thresholds.statements},
    },
  },
  coverageReporters: ['text', 'lcov', 'html'],
  collectCoverageFrom: ['src/**/*.{ts,tsx}', '!src/**/*.d.ts'],
};`;
      } else {
        config = `// vitest.config.ts
import { defineConfig } from 'vitest/config'

export default defineConfig({
  test: {
    coverage: {
      provider: 'v8',
      reporter: ['text', 'lcov', 'html'],
      include: ['src/**/*.{ts,tsx}'],
      exclude: ['src/**/*.d.ts'],
      thresholds: {
        lines: ${thresholds.lines},
        branches: ${thresholds.branches},
        functions: ${thresholds.functions},
        statements: ${thresholds.statements},
      },
    },
  },
})`;
      }

      (document.getElementById('config-output') as HTMLPreElement).textContent = config;
    }

    document.getElementById('fmt-jest')!.addEventListener('click', () => {
      configFormat = 'jest';
      document.getElementById('fmt-jest')!.className = 'px-3 py-1 rounded text-xs bg-accent text-white transition-colors';
      document.getElementById('fmt-vitest')!.className = 'px-3 py-1 rounded text-xs bg-bg border border-border text-text-muted transition-colors';
      calculate();
    });

    document.getElementById('fmt-vitest')!.addEventListener('click', () => {
      configFormat = 'vitest';
      document.getElementById('fmt-vitest')!.className = 'px-3 py-1 rounded text-xs bg-accent text-white transition-colors';
      document.getElementById('fmt-jest')!.className = 'px-3 py-1 rounded text-xs bg-bg border border-border text-text-muted transition-colors';
      calculate();
    });

    document.getElementById('copy-config')!.addEventListener('click', () => {
      const text = (document.getElementById('config-output') as HTMLPreElement).textContent || '';
      navigator.clipboard.writeText(text).then(() => {
        const btn = document.getElementById('copy-config') as HTMLButtonElement;
        btn.textContent = 'Copied!';
        setTimeout(() => btn.textContent = 'Copy', 2000);
      });
    });

    // Listen to all inputs
    [...metrics.map(m => `${m}-covered`), ...metrics.map(m => `${m}-total`), ...metrics.map(m => `${m}-threshold`)]
      .forEach(id => {
        document.getElementById(id)!.addEventListener('input', calculate);
      });

    calculate();
  </script>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Test Coverage Calculator" relatedTags={['testing', 'jest', 'vitest', 'coverage', 'developer-tools']} />
</BaseLayout>
