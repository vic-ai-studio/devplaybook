---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is k6 and why use it for load testing?", answer: "k6 is an open-source load testing tool built for developer workflows. It uses JavaScript/TypeScript for test scripts, integrates with CI/CD pipelines, and outputs structured metrics (p95, p99 latency, error rate, throughput). Unlike JMeter, k6 has a low resource footprint — a single k6 instance can simulate thousands of VUs. It's cloud-friendly and integrates natively with Grafana dashboards." },
  { question: "What are the different load test types?", answer: "Smoke test: Minimal load (1-2 VUs) to verify the test script works. Load test: Expected normal load to validate baseline performance. Stress test: Gradually increase beyond normal capacity to find the breaking point. Spike test: Sudden massive increase to simulate flash crowd events. Soak test: Sustained normal load for extended periods (hours) to detect memory leaks and resource exhaustion." },
  { question: "What is a Virtual User (VU) in k6?", answer: "A Virtual User (VU) in k6 represents a simulated user executing your test script in a continuous loop. Each VU runs independently and maintains its own state (cookies, session). The number of concurrent VUs is the primary load parameter. Note: VUs are not the same as requests per second — the RPS depends on iteration duration which includes response time and think time." },
  { question: "What should my p95 and p99 latency targets be?", answer: "Common latency SLO targets: API endpoints: p95 < 200ms, p99 < 500ms. Database queries: p95 < 50ms, p99 < 100ms. Page loads: p95 < 2s, p99 < 4s. For k6 thresholds, typically: http_req_duration p95 < 500, error_rate < 0.01 (1%). These are starting points — adjust based on your specific SLAs and user expectations." },
  { question: "How do I interpret load test results?", answer: "Key metrics to analyze: (1) http_req_duration — latency percentiles (p50, p95, p99). (2) http_req_failed — error rate, should stay below 1% under normal load. (3) iterations — total completed test iterations. (4) vus — concurrent virtual users at peak. Look for the knee point where latency spikes and errors appear — that is your system's capacity limit. Compare p99 against your SLA targets." },
];
---

<BaseLayout
  title="k6 Load Test Config Builder — Smoke, Load, Stress, Spike, Soak Test Generator"
  description="Generate k6 load test scripts with ramp-up profiles, thresholds, and think times. Supports smoke, load, stress, spike, and soak test patterns. Copy-ready JavaScript config."
  tool="k6 Load Test Generator, Load Test Config Builder, Stress Test Script Generator, k6 Script Builder, Performance Test Config"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">k6 Load Test Config Builder</h1>
  <p class="text-text-muted mb-4">Generate production-ready k6 load test scripts with proper ramp-up profiles, thresholds, and think times. Supports all major test patterns — just configure and copy.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 test type profiles</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auto-generated thresholds</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-ready k6 script</span>
  </div>

  <!-- Configuration -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Test Configuration</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <div class="md:col-span-2 lg:col-span-3">
        <label class="block text-sm font-medium mb-1.5">Target URL</label>
        <input id="target-url" type="text" value="https://api.example.com/endpoint"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Test Type</label>
        <select id="test-type" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="smoke">Smoke — Minimal (1-2 VUs)</option>
          <option value="load" selected>Load — Normal traffic</option>
          <option value="stress">Stress — Beyond capacity</option>
          <option value="spike">Spike — Flash crowd</option>
          <option value="soak">Soak — Endurance test</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Target VUs</label>
        <input id="target-vus" type="number" value="50" min="1" max="10000"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Ramp-Up Time (minutes)</label>
        <input id="ramp-up" type="number" value="5" min="0" max="60"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Sustained Duration (minutes)</label>
        <input id="sustained-duration" type="number" value="10" min="1" max="480"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Think Time (ms)</label>
        <input id="think-time" type="number" value="1000" min="0" max="30000"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">p95 Latency Threshold (ms)</label>
        <input id="p95-threshold" type="number" value="500" min="50"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Test Summary</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <div class="bg-bg-card border border-border rounded-lg p-3 text-center">
        <div id="summary-vus" class="text-2xl font-bold text-primary mb-1">50</div>
        <div class="text-xs text-text-muted">Peak VUs</div>
      </div>
      <div class="bg-bg-card border border-border rounded-lg p-3 text-center">
        <div id="summary-duration" class="text-2xl font-bold text-primary mb-1">20m</div>
        <div class="text-xs text-text-muted">Total Duration</div>
      </div>
      <div class="bg-bg-card border border-border rounded-lg p-3 text-center">
        <div id="summary-est-rps" class="text-2xl font-bold text-primary mb-1">~47</div>
        <div class="text-xs text-text-muted">Est. Peak RPS</div>
      </div>
      <div class="bg-bg-card border border-border rounded-lg p-3 text-center">
        <div id="summary-type" class="text-2xl font-bold text-primary mb-1">Load</div>
        <div class="text-xs text-text-muted">Test Type</div>
      </div>
    </div>
  </div>

  <!-- Generated Config -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-base font-semibold">Generated k6 Script</h2>
      <button onclick="copyConfig()" id="copy-btn"
        class="text-xs px-3 py-1.5 rounded-lg border border-border hover:border-primary text-text-muted hover:text-primary transition-colors">Copy Script</button>
    </div>
    <pre id="config-output" class="text-xs font-mono bg-bg-card border border-border rounded-lg p-4 overflow-x-auto whitespace-pre text-text-muted leading-relaxed"></pre>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="k6 Load Test Config Builder" relatedTags={['devops', 'performance', 'k6', 'load-testing', 'sre']} />
</BaseLayout>

<script>
  function getVal(id: string): number {
    return parseFloat((document.getElementById(id) as HTMLInputElement).value) || 0;
  }
  function getStr(id: string): string {
    return (document.getElementById(id) as HTMLInputElement).value.trim();
  }
  function getSel(id: string): string {
    return (document.getElementById(id) as HTMLSelectElement).value;
  }

  function buildScenario(type: string, vus: number, rampUpMin: number, sustainedMin: number): string {
    const rampUp = `${rampUpMin}m`;
    const sustained = `${sustainedMin}m`;
    const rampDown = `${Math.max(1, Math.floor(rampUpMin / 2))}m`;

    switch (type) {
      case 'smoke':
        return `  stages: [
    { duration: '1m', target: 2 },    // Ramp up to 2 VUs
    { duration: '3m', target: 2 },    // Stay at 2 VUs
    { duration: '1m', target: 0 },    // Ramp down to 0
  ],`;
      case 'load':
        return `  stages: [
    { duration: '${rampUp}', target: ${vus} },    // Ramp up to ${vus} VUs
    { duration: '${sustained}', target: ${vus} },  // Sustain at ${vus} VUs
    { duration: '${rampDown}', target: 0 },         // Ramp down to 0
  ],`;
      case 'stress':
        const step = Math.floor(vus / 4);
        return `  stages: [
    { duration: '${Math.ceil(rampUpMin / 4)}m', target: ${step} },    // Ramp to 25%
    { duration: '${Math.ceil(rampUpMin / 4)}m', target: ${step * 2} }, // Ramp to 50%
    { duration: '${Math.ceil(rampUpMin / 4)}m', target: ${step * 3} }, // Ramp to 75%
    { duration: '${Math.ceil(rampUpMin / 4)}m', target: ${vus} },      // Ramp to 100% (${vus} VUs)
    { duration: '${sustained}', target: ${vus} },                       // Sustain at peak
    { duration: '${rampDown}', target: 0 },                              // Ramp down
  ],`;
      case 'spike':
        return `  stages: [
    { duration: '1m', target: Math.floor(${vus} * 0.1) },  // Baseline (${Math.floor(vus * 0.1)} VUs)
    { duration: '2m', target: ${vus} },                      // Spike to ${vus} VUs instantly
    { duration: '${sustained}', target: ${vus} },            // Hold spike
    { duration: '2m', target: Math.floor(${vus} * 0.1) },  // Drop back to baseline
    { duration: '3m', target: 0 },                           // Ramp down
  ],`.replace(/Math\.floor\(\d+\s*\*\s*0\.1\)/g, String(Math.floor(vus * 0.1)));
      case 'soak':
        return `  stages: [
    { duration: '${rampUp}', target: ${vus} },    // Ramp up
    { duration: '${sustainedMin * 60}s', target: ${vus} },  // Soak for ${sustained} — watch for memory leaks
    { duration: '${rampDown}', target: 0 },        // Ramp down
  ],`;
      default:
        return '';
    }
  }

  function calculate() {
    const url = getStr('target-url') || 'https://api.example.com/endpoint';
    const type = getSel('test-type');
    const vus = Math.max(1, getVal('target-vus'));
    const rampUp = getVal('ramp-up');
    const sustained = getVal('sustained-duration');
    const thinkTime = getVal('think-time');
    const p95 = getVal('p95-threshold');

    const typeLabels: Record<string, string> = {
      smoke: 'Smoke', load: 'Load', stress: 'Stress', spike: 'Spike', soak: 'Soak'
    };

    // Estimate RPS: VUs / (avg response time + think time in seconds)
    const avgResponseSec = p95 / 1000 * 0.6; // rough estimate: p95 * 0.6 ≈ p50
    const iterSec = avgResponseSec + thinkTime / 1000;
    const estRps = iterSec > 0 ? Math.round(vus / iterSec) : vus;
    const totalDuration = rampUp + sustained + Math.max(1, Math.floor(rampUp / 2));

    document.getElementById('summary-vus')!.textContent = String(vus);
    document.getElementById('summary-duration')!.textContent = `${totalDuration}m`;
    document.getElementById('summary-est-rps')!.textContent = `~${estRps}`;
    document.getElementById('summary-type')!.textContent = typeLabels[type] || type;

    const thinkTimeCode = thinkTime > 0
      ? `\n  sleep(${(thinkTime / 1000).toFixed(2)});  // Think time: ${thinkTime}ms`
      : '';

    const scenario = buildScenario(type, vus, rampUp, sustained);

    const script = `import http from 'k6/http';
import { sleep, check } from 'k6';
import { Rate } from 'k6/metrics';

// Custom metrics
const errorRate = new Rate('errors');

// Test configuration — generated by DevPlaybook k6 Builder
// Type: ${typeLabels[type]} | Target VUs: ${vus} | URL: ${url}
export const options = {
${scenario}

  thresholds: {
    // Response time thresholds
    http_req_duration: ['p(95)<${p95}', 'p(99)<${Math.round(p95 * 2)}'],

    // Error rate must stay below 1%
    errors: ['rate<0.01'],

    // All requests must complete
    http_req_failed: ['rate<0.01'],
  },
};

const BASE_URL = '${url}';

export default function () {
  const params = {
    headers: {
      'Content-Type': 'application/json',
      'Accept': 'application/json',
      // Add auth headers here:
      // 'Authorization': \`Bearer \${__ENV.API_TOKEN}\`,
    },
  };

  // --- Main request ---
  const res = http.get(BASE_URL, params);

  // Validate response
  const success = check(res, {
    'status is 200': (r) => r.status === 200,
    'response time < ${p95}ms': (r) => r.timings.duration < ${p95},
    'response has body': (r) => r.body !== null && r.body!.length > 0,
  });

  errorRate.add(!success);
${thinkTimeCode}
}

// Optional: teardown function runs once after all VUs finish
export function teardown() {
  console.log('Load test complete.');
}
`;

    document.getElementById('config-output')!.textContent = script;
  }

  (window as any).copyConfig = function() {
    const code = (document.getElementById('config-output') as HTMLPreElement).textContent || '';
    navigator.clipboard.writeText(code).then(() => {
      const btn = document.getElementById('copy-btn')!;
      const orig = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = orig; }, 1500);
    });
  };

  document.querySelectorAll('input, select').forEach(el => el.addEventListener('input', calculate));
  calculate();
</script>
