---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is esbuild and why is it so fast?",
    answer: "esbuild is a JavaScript bundler and minifier written in Go. It's 10-100x faster than webpack or Rollup because Go compiles to native machine code (vs JavaScript interpreters), leverages Go's parallelism via goroutines, and uses efficient data structures throughout. Vite uses esbuild for dependency pre-bundling and TypeScript transpilation."
  },
  {
    question: "What is the difference between bundle: true and false?",
    answer: "With bundle: true, esbuild recursively follows all import/require statements and combines everything into a single output file (or a few chunks). With bundle: false (the default), esbuild only transforms each file individually without following imports — useful for TypeScript-to-JS transpilation without bundling."
  },
  {
    question: "What do the format options iife, cjs, and esm mean?",
    answer: "iife (Immediately Invoked Function Expression) wraps code in a function — ideal for browser <script> tags. cjs (CommonJS) uses module.exports — the standard for Node.js. esm (ECMAScript Modules) uses import/export — works natively in modern browsers and Node.js 12+. Choose based on your target environment."
  },
  {
    question: "What are external packages and when should I use them?",
    answer: "External packages tell esbuild NOT to bundle those modules, leaving the import/require statement in the output. Use this for Node.js built-ins (fs, path, etc.) when targeting Node, or for peer dependencies like React that will be provided by the host environment, or for large libraries you load via CDN."
  },
  {
    question: "What is the 'target' option for?",
    answer: "The target option tells esbuild which JavaScript syntax features to use in the output. 'es2015' transpiles modern syntax to ES5-compatible code for older browsers. 'esnext' outputs the most modern syntax with no downleveling. Targets can also be specific browsers like 'chrome90,firefox88' or Node versions like 'node16'."
  },
  {
    question: "How do source maps help with debugging minified code?",
    answer: "Source maps are .map files that map minified/bundled code back to the original source. When you open DevTools with source maps, you see your original TypeScript/JSX files instead of minified output. Inline source maps embed the map in the output file (larger but simpler), external source maps create separate .map files."
  }
];
---

<BaseLayout
  title="esbuild Config Generator — Visual Builder for esbuild Options"
  description="Generate esbuild build scripts and CLI commands visually. Configure entry points, output, bundling, minification, targets, formats, and external packages with live preview."
  tool="esbuild config generator, esbuild build script, esbuild CLI command, esbuild options, JavaScript bundler config, esbuild setup"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "esbuild Config Generator",
    "url": "https://devplaybook.cc/tools/esbuild-config-generator",
    "description": "Generate esbuild build scripts and CLI commands visually. Configure all esbuild options and get instant output.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">esbuild Config Generator</h1>
  <p class="text-text-muted mb-4">Configure all esbuild options visually and get instant output as both a <code class="bg-bg-card px-1 rounded text-sm">build.js</code> Node script and an equivalent CLI command. No more digging through docs.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All major options covered</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> JS script + CLI output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> External packages list</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy to clipboard</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <!-- Left column: entries & output -->
    <div class="space-y-4">
      <div>
        <div class="flex items-center justify-between mb-2">
          <label class="text-sm font-medium">Entry Points</label>
          <button id="btn-add-entry" class="text-xs text-primary hover:underline">+ Add</button>
        </div>
        <div id="entry-list" class="space-y-2"></div>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1">Output Directory</label>
        <input id="out-dir" type="text" value="dist" class="w-full bg-bg-card border border-border rounded-lg p-2.5 text-sm font-mono focus:outline-none focus:border-primary" placeholder="dist" />
      </div>

      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-sm font-medium mb-1">Format</label>
          <select id="opt-format" class="w-full bg-bg-card border border-border rounded-lg p-2.5 text-sm focus:outline-none focus:border-primary">
            <option value="esm">esm</option>
            <option value="cjs">cjs</option>
            <option value="iife">iife</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Platform</label>
          <select id="opt-platform" class="w-full bg-bg-card border border-border rounded-lg p-2.5 text-sm focus:outline-none focus:border-primary">
            <option value="browser">browser</option>
            <option value="node">node</option>
            <option value="neutral">neutral</option>
          </select>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1">Target</label>
        <select id="opt-target" class="w-full bg-bg-card border border-border rounded-lg p-2.5 text-sm focus:outline-none focus:border-primary">
          <option value="esnext">esnext</option>
          <option value="es2022">es2022</option>
          <option value="es2020" selected>es2020</option>
          <option value="es2017">es2017</option>
          <option value="es2015">es2015</option>
          <option value="node18">node18</option>
          <option value="node16">node16</option>
        </select>
      </div>

      <div class="space-y-2">
        <label class="block text-sm font-medium mb-1">Options</label>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="opt-bundle" class="accent-primary" checked /> Bundle (follow imports)
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="opt-minify" class="accent-primary" checked /> Minify output
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="opt-sourcemap" class="accent-primary" /> Source maps (external)
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="opt-splitting" class="accent-primary" /> Code splitting (esm only)
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="opt-metafile" class="accent-primary" /> Metafile (bundle analysis)
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="opt-tree-shaking" class="accent-primary" checked /> Tree shaking
        </label>
      </div>

      <div>
        <div class="flex items-center justify-between mb-2">
          <label class="text-sm font-medium">External Packages</label>
          <button id="btn-add-ext" class="text-xs text-primary hover:underline">+ Add</button>
        </div>
        <div id="ext-list" class="space-y-2"></div>
      </div>
    </div>

    <!-- Right column: output -->
    <div>
      <div class="flex gap-1 mb-3 border-b border-border">
        <button data-eout="js" class="eout-tab px-4 py-2 text-sm font-medium border-b-2 border-primary text-primary transition-colors">JS Script</button>
        <button data-eout="cli" class="eout-tab px-4 py-2 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-foreground transition-colors">CLI Command</button>
      </div>

      <div id="eout-js" class="eout-panel">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs text-text-muted font-mono">build.mjs</span>
          <button id="copy-js" class="px-2 py-1 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">Copy</button>
        </div>
        <pre id="js-output" class="bg-bg-card border border-border rounded-lg p-4 text-xs font-mono text-green-300 whitespace-pre overflow-x-auto" style="min-height:320px"></pre>
      </div>

      <div id="eout-cli" class="eout-panel hidden">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs text-text-muted font-mono">Terminal</span>
          <button id="copy-cli" class="px-2 py-1 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">Copy</button>
        </div>
        <pre id="cli-output" class="bg-bg-card border border-border rounded-lg p-4 text-xs font-mono text-yellow-300 whitespace-pre-wrap overflow-x-auto" style="min-height:320px"></pre>
      </div>
    </div>
  </div>

  <ToolPageCta />
  <FaqSection faq={faq} />
</BaseLayout>

<script>
(function() {
  function addEntry(val = '') {
    const row = document.createElement('div');
    row.className = 'flex gap-2 items-center';
    row.innerHTML = `
      <input type="text" class="entry-input flex-1 bg-surface border border-border rounded p-2 text-sm font-mono focus:outline-none focus:border-primary" placeholder="src/index.ts" value="${val}" />
      <button class="btn-rm text-red-400 hover:text-red-300 text-xs px-2">✕</button>
    `;
    document.getElementById('entry-list').appendChild(row);
    row.querySelector('.btn-rm').addEventListener('click', () => { row.remove(); generate(); });
    row.querySelector('.entry-input').addEventListener('input', generate);
    generate();
  }

  function addExternal(val = '') {
    const row = document.createElement('div');
    row.className = 'flex gap-2 items-center';
    row.innerHTML = `
      <input type="text" class="ext-input flex-1 bg-surface border border-border rounded p-2 text-sm font-mono focus:outline-none focus:border-primary" placeholder="react" value="${val}" />
      <button class="btn-rm text-red-400 hover:text-red-300 text-xs px-2">✕</button>
    `;
    document.getElementById('ext-list').appendChild(row);
    row.querySelector('.btn-rm').addEventListener('click', () => { row.remove(); generate(); });
    row.querySelector('.ext-input').addEventListener('input', generate);
    generate();
  }

  function getValues(selector) {
    return Array.from(document.querySelectorAll(selector)).map(i => i.value.trim()).filter(Boolean);
  }

  function generate() {
    const entries = getValues('.entry-input');
    const outDir = document.getElementById('out-dir').value.trim() || 'dist';
    const format = document.getElementById('opt-format').value;
    const platform = document.getElementById('opt-platform').value;
    const target = document.getElementById('opt-target').value;
    const bundle = document.getElementById('opt-bundle').checked;
    const minify = document.getElementById('opt-minify').checked;
    const sourcemap = document.getElementById('opt-sourcemap').checked;
    const splitting = document.getElementById('opt-splitting').checked;
    const metafile = document.getElementById('opt-metafile').checked;
    const treeShaking = document.getElementById('opt-tree-shaking').checked;
    const externals = getValues('.ext-input');

    const entryList = entries.length > 0 ? entries : ['src/index.ts'];

    const opts = {};
    opts.entryPoints = entryList;
    opts.outdir = outDir;
    opts.bundle = bundle;
    opts.minify = minify;
    opts.sourcemap = sourcemap || undefined;
    opts.splitting = splitting || undefined;
    opts.metafile = metafile || undefined;
    opts.treeShaking = treeShaking || undefined;
    opts.format = format;
    opts.platform = platform;
    opts.target = target;
    if (externals.length > 0) opts.external = externals;

    // Remove falsy optional keys
    Object.keys(opts).forEach(k => {
      if (opts[k] === undefined || opts[k] === false) delete opts[k];
    });

    // JS script
    let js = `import * as esbuild from 'esbuild'\n\nawait esbuild.build({\n`;
    for (const [k, v] of Object.entries(opts)) {
      if (Array.isArray(v)) {
        js += `  ${k}: ${JSON.stringify(v)},\n`;
      } else if (typeof v === 'boolean') {
        js += `  ${k}: ${v},\n`;
      } else {
        js += `  ${k}: '${v}',\n`;
      }
    }
    js += `})\n`;
    document.getElementById('js-output').textContent = js;

    // CLI command
    let cli = `npx esbuild ${entryList.join(' ')}`;
    if (bundle) cli += ' --bundle';
    cli += ` --outdir=${outDir}`;
    cli += ` --format=${format}`;
    cli += ` --platform=${platform}`;
    cli += ` --target=${target}`;
    if (minify) cli += ' --minify';
    if (sourcemap) cli += ' --sourcemap';
    if (splitting) cli += ' --splitting';
    if (metafile) cli += ' --metafile=meta.json';
    if (!treeShaking) cli += ' --tree-shaking=false';
    if (externals.length > 0) cli += ' ' + externals.map(e => `--external:${e}`).join(' ');
    document.getElementById('cli-output').textContent = cli;
  }

  // Tab switching
  document.querySelectorAll('.eout-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.dataset.eout;
      document.querySelectorAll('.eout-tab').forEach(b => {
        b.classList.toggle('border-primary', b.dataset.eout === tab);
        b.classList.toggle('text-primary', b.dataset.eout === tab);
        b.classList.toggle('border-transparent', b.dataset.eout !== tab);
        b.classList.toggle('text-text-muted', b.dataset.eout !== tab);
      });
      document.querySelectorAll('.eout-panel').forEach(p => p.classList.add('hidden'));
      document.getElementById(`eout-${tab}`).classList.remove('hidden');
    });
  });

  document.getElementById('btn-add-entry').addEventListener('click', () => addEntry());
  document.getElementById('btn-add-ext').addEventListener('click', () => addExternal());

  ['out-dir','opt-format','opt-platform','opt-target',
   'opt-bundle','opt-minify','opt-sourcemap','opt-splitting','opt-metafile','opt-tree-shaking'].forEach(id => {
    const el = document.getElementById(id);
    if (el) { el.addEventListener('change', generate); el.addEventListener('input', generate); }
  });

  document.getElementById('copy-js').addEventListener('click', function() {
    navigator.clipboard.writeText(document.getElementById('js-output').textContent || '');
    this.textContent = 'Copied!'; setTimeout(() => { this.textContent = 'Copy'; }, 2000);
  });
  document.getElementById('copy-cli').addEventListener('click', function() {
    navigator.clipboard.writeText(document.getElementById('cli-output').textContent || '');
    this.textContent = 'Copied!'; setTimeout(() => { this.textContent = 'Copy'; }, 2000);
  });

  // Preload
  addEntry('src/index.ts');
  addExternal('react');
  addExternal('react-dom');
  generate();
})();
</script>
