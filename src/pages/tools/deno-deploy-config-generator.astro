---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is Deno Deploy and how does it differ from Node.js hosting?", answer: "Deno Deploy is a globally distributed JavaScript/TypeScript runtime built on V8 Isolates, similar to Cloudflare Workers. Unlike Node.js hosting, Deno Deploy runs code at the edge with zero cold starts, has no file system access, uses Web APIs (fetch, Request, Response) natively, and supports TypeScript without compilation. Deploy time is under 1 second globally." },
  { question: "What is deno.json and what does it configure?", answer: "deno.json is Deno's project configuration file (equivalent to package.json + tsconfig.json combined). It configures: imports (import maps for dependency aliases), tasks (scripts like npm scripts), compilerOptions (TypeScript settings), lint rules, format rules, and test options. It replaces the need for node_modules and package-lock.json." },
  { question: "How do import maps work in Deno?", answer: "Import maps in Deno let you alias module specifiers. For example, mapping 'hono' to 'https://deno.land/x/hono@v4/mod.ts' lets you write `import { Hono } from 'hono'` instead of the full URL. Define them in deno.json under the `imports` key. Deno 1.28+ supports import maps natively without any flag." },
  { question: "Does Deno Deploy support npm packages?", answer: "Yes, since Deno 1.28 and Deno Deploy support npm: specifiers. You can use `import express from 'npm:express'` or configure imports in deno.json: `{ \"express\": \"npm:express@4\" }`. Not all npm packages work (those requiring Node.js built-ins may fail), but most pure JS packages and popular frameworks (Hono, Oak, Fresh) work perfectly." },
  { question: "How do I deploy to Deno Deploy from GitHub?", answer: "Connect your GitHub repo in the Deno Deploy dashboard, select the entry file (e.g. main.ts), and set the branch. Deno Deploy automatically deploys on every push. For CI/CD, use the deployctl GitHub Action: `uses: denoland/deployctl@v1` with your project name and entrypoint. Each deployment gets a unique preview URL for pull requests." },
];
---

<BaseLayout
  title="Deno Deploy Config Generator — Generate deno.json with Import Maps"
  description="Generate deno.json configuration for Deno Deploy projects. Configure import maps, tasks, TypeScript compiler options, and lint/format rules. Copy ready-to-use config. Free browser tool."
  tool="deno deploy config generator, deno.json generator, deno import map generator, deno configuration generator, deno.json import maps"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Deno Deploy Config Generator",
    "url": "https://devplaybook.cc/tools/deno-deploy-config-generator",
    "description": "Generate deno.json configuration with import maps for Deno Deploy projects.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Deno Deploy Config Generator</h1>
  <p class="text-text-muted mb-4">Generate <code class="bg-surface px-1 rounded text-xs">deno.json</code> configuration for Deno / Deno Deploy projects. Set import maps, tasks, TypeScript options, and linting rules.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Import maps</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Tasks / scripts</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript config</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Lint &amp; format rules</span>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
    <div class="space-y-4">
      <!-- Framework Preset -->
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <h2 class="text-sm font-semibold mb-3">Framework Preset</h2>
        <select id="framework" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="blank">Blank (no framework)</option>
          <option value="hono" selected>Hono (lightweight web framework)</option>
          <option value="oak">Oak (Koa-inspired)</option>
          <option value="fresh">Fresh (full-stack Deno)</option>
          <option value="ultra">Ultra (React SSR)</option>
        </select>
      </div>

      <!-- Import Maps -->
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <div class="flex justify-between items-center mb-2">
          <h2 class="text-sm font-semibold">Import Maps</h2>
          <button id="addImport" class="text-xs text-primary hover:text-primary/80">+ Add</button>
        </div>
        <div id="importList" class="space-y-2"></div>
        <div class="flex gap-2 mt-2">
          <input id="importAlias" type="text" placeholder="alias (e.g. hono)" class="flex-1 bg-surface border border-border rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-primary" />
          <input id="importUrl" type="text" placeholder="URL or npm:package" class="flex-1 bg-surface border border-border rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-primary" />
        </div>
      </div>

      <!-- Tasks -->
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <div class="flex justify-between items-center mb-2">
          <h2 class="text-sm font-semibold">Tasks</h2>
          <button id="addTask" class="text-xs text-primary hover:text-primary/80">+ Add</button>
        </div>
        <div id="taskList" class="space-y-2"></div>
        <div class="flex gap-2 mt-2">
          <input id="taskName" type="text" placeholder="task name (e.g. dev)" class="flex-1 bg-surface border border-border rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-primary" />
          <input id="taskCmd" type="text" placeholder="command" class="flex-1 bg-surface border border-border rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-primary" />
        </div>
      </div>

      <!-- Options -->
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <h2 class="text-sm font-semibold mb-3">Options</h2>
        <div class="space-y-2 text-sm">
          <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" id="optStrict" checked class="accent-primary" /> Strict TypeScript mode</label>
          <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" id="optLint" checked class="accent-primary" /> Enable lint rules</label>
          <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" id="optFmt" checked class="accent-primary" /> Enable formatter config</label>
          <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" id="optNodeCompat" class="accent-primary" /> Node.js compat mode</label>
        </div>
      </div>
    </div>

    <div class="bg-bg-card border border-border rounded-lg p-4">
      <div class="flex justify-between items-center mb-3">
        <h2 class="text-sm font-semibold">Generated deno.json</h2>
        <button id="copyBtn" class="text-xs px-3 py-1 bg-primary text-white rounded hover:bg-primary/90">Copy</button>
      </div>
      <pre id="output" class="text-xs font-mono bg-surface rounded p-3 overflow-x-auto whitespace-pre-wrap text-text min-h-48"></pre>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Deno Deploy Config Generator" relatedTags={['deno', 'typescript', 'serverless', 'edge', 'deploy']} />
</BaseLayout>

<script is:inline>
(function() {
  const PRESETS = {
    blank: { imports: {}, tasks: { dev: 'deno run --allow-net --watch main.ts', start: 'deno run --allow-net main.ts' } },
    hono: {
      imports: { 'hono': 'https://deno.land/x/hono@v4.3.11/mod.ts', 'hono/': 'https://deno.land/x/hono@v4.3.11/' },
      tasks: { dev: 'deno run --allow-net --watch main.ts', start: 'deno run --allow-net main.ts', deploy: 'deployctl deploy --project=my-project main.ts' },
    },
    oak: {
      imports: { 'oak': 'https://deno.land/x/oak@v12.6.1/mod.ts', 'oak/': 'https://deno.land/x/oak@v12.6.1/' },
      tasks: { dev: 'deno run --allow-net --allow-read --watch main.ts', start: 'deno run --allow-net --allow-read main.ts' },
    },
    fresh: {
      imports: { '$fresh/': 'https://deno.land/x/fresh@1.6.8/', 'preact': 'https://esm.sh/preact@10.19.6', 'preact/': 'https://esm.sh/preact@10.19.6/', '$std/': 'https://deno.land/std@0.216.0/' },
      tasks: { start: 'deno run -A --watch=static/,routes/ dev.ts', build: 'deno run -A dev.ts build', preview: 'deno run -A main.ts', update: 'deno run -A -r https://fresh.deno.dev/update .' },
    },
    ultra: {
      imports: { 'ultra/': 'https://deno.land/x/ultra@v2.5.2/', 'react': 'https://esm.sh/react@18.2.0', 'react-dom/client': 'https://esm.sh/react-dom@18.2.0/client', 'react-dom/server': 'https://esm.sh/react-dom@18.2.0/server' },
      tasks: { dev: 'deno run -A --watch server.ts', build: 'deno run -A build.ts', start: 'deno run -A server.ts' },
    },
  };

  let imports = {};
  let tasks = {};

  function loadPreset(fw) {
    const p = PRESETS[fw] || PRESETS.blank;
    imports = { ...p.imports };
    tasks = { ...p.tasks };
    renderImports();
    renderTasks();
    generate();
  }

  function renderImports() {
    const el = document.getElementById('importList');
    el.innerHTML = Object.entries(imports).map(([alias, url]) => `
      <div class="flex items-center gap-1 text-xs">
        <span class="font-mono bg-surface px-2 py-1 rounded text-primary flex-1 truncate">"${alias}"</span>
        <span class="text-text-muted">→</span>
        <span class="font-mono bg-surface px-2 py-1 rounded text-text-muted flex-1 truncate">"${url}"</span>
        <button onclick="removeImport('${alias.replace(/'/g,"\\'")}')\" class="text-red-400 hover:text-red-300 px-1">✕</button>
      </div>`).join('') || '<p class="text-xs text-text-muted italic">No imports configured.</p>';
  }

  function renderTasks() {
    const el = document.getElementById('taskList');
    el.innerHTML = Object.entries(tasks).map(([name, cmd]) => `
      <div class="flex items-center gap-1 text-xs">
        <span class="font-mono bg-surface px-2 py-1 rounded text-green-400 shrink-0">${name}</span>
        <span class="font-mono bg-surface px-2 py-1 rounded text-text-muted flex-1 truncate">${cmd}</span>
        <button onclick="removeTask('${name}')" class="text-red-400 hover:text-red-300 px-1">✕</button>
      </div>`).join('') || '<p class="text-xs text-text-muted italic">No tasks configured.</p>';
  }

  function generate() {
    const strict = document.getElementById('optStrict').checked;
    const lint = document.getElementById('optLint').checked;
    const fmt = document.getElementById('optFmt').checked;
    const nodeCompat = document.getElementById('optNodeCompat').checked;

    const config = {};
    if (Object.keys(imports).length > 0) config.imports = imports;
    if (Object.keys(tasks).length > 0) config.tasks = tasks;
    if (strict) config.compilerOptions = { strict: true, noImplicitAny: true, strictNullChecks: true };
    if (nodeCompat) { config.nodeModulesDir = true; }
    if (lint) config.lint = { rules: { tags: ['recommended'], include: ['ban-untagged-todo'] } };
    if (fmt) config.fmt = { useTabs: false, lineWidth: 80, indentWidth: 2, semiColons: true, singleQuote: false, proseWrap: 'preserve' };

    document.getElementById('output').textContent = JSON.stringify(config, null, 2);
  }

  window.removeImport = function(alias) { delete imports[alias]; renderImports(); generate(); };
  window.removeTask = function(name) { delete tasks[name]; renderTasks(); generate(); };

  document.getElementById('addImport').addEventListener('click', () => {
    const alias = document.getElementById('importAlias').value.trim();
    const url = document.getElementById('importUrl').value.trim();
    if (alias && url) { imports[alias] = url; document.getElementById('importAlias').value = ''; document.getElementById('importUrl').value = ''; renderImports(); generate(); }
  });

  document.getElementById('addTask').addEventListener('click', () => {
    const name = document.getElementById('taskName').value.trim();
    const cmd = document.getElementById('taskCmd').value.trim();
    if (name && cmd) { tasks[name] = cmd; document.getElementById('taskName').value = ''; document.getElementById('taskCmd').value = ''; renderTasks(); generate(); }
  });

  document.getElementById('framework').addEventListener('change', e => loadPreset(e.target.value));
  ['optStrict','optLint','optFmt','optNodeCompat'].forEach(id => document.getElementById(id).addEventListener('change', generate));

  document.getElementById('copyBtn').addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('output').textContent);
    const btn = document.getElementById('copyBtn');
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
  });

  loadPreset('hono');
})();
</script>
