---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DiffCheckerV2 from '../../components/DiffCheckerV2.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Diff Checker v2 — Side-by-Side Code Diff with Syntax Highlighting"
  description="Compare two code snippets with syntax highlighting, inline character-level diff, split and unified view. Supports JavaScript, TypeScript, Python, Rust, Go, SQL, and more. Runs entirely in your browser."
  tool="Diff Checker, Code Diff, Side-by-Side Diff, Syntax Highlighted Diff, Compare Code"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Diff Checker v2",
    "url": "https://devplaybook.cc/tools/diff-checker-v2",
    "description": "Advanced code diff tool with syntax highlighting, inline character diff, split and unified view. Supports JS, TS, Python, Rust, Go, SQL. Runs 100% in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Diff Checker v2</h1>
  <p class="text-text-muted mb-8">
    Paste two versions of any code snippet and see exactly what changed — with syntax highlighting and inline character-level diff.
    Choose between unified (GitHub-style) or split side-by-side view.
    Auto-detects JavaScript, TypeScript, Python, Rust, Go, SQL, CSS, JSON, and YAML.
    Runs 100% in your browser — nothing is sent to any server.
  </p>
  <DiffCheckerV2 client:only="preact" />
  <ToolPageCta currentTool="Diff Checker v2" relatedTags={['diff', 'code', 'comparison', 'git', 'productivity']} />
</BaseLayout>
