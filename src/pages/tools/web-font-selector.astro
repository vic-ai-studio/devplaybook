---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What makes a good font pairing?", answer: "A strong font pairing typically combines contrast with harmony. The most reliable approach is pairing a serif with a sans-serif — one for headings, one for body text. The fonts should share a similar x-height and mood (e.g. both geometric, or both humanist) while differing enough in style to create visual hierarchy. Avoid pairing two decorative display fonts together." },
  { question: "How do I load Google Fonts efficiently?", answer: "Use the <link rel='preconnect'> hint before your Google Fonts stylesheet tag to reduce latency. For body fonts, prefer display=swap to prevent invisible text during load. Only load the weights you actually use — loading 100,200,300,400,500,600,700,800,900 for every font significantly increases page load. Two weights per font (e.g. 400 and 700) is usually enough." },
  { question: "What is font-display: swap and should I use it?", answer: "font-display: swap tells the browser to show a fallback system font immediately while the custom font loads, then swap it in when ready. This prevents the Flash of Invisible Text (FOIT). Google Fonts adds &display=swap automatically when you use the standard embed URL. The trade-off is a brief layout shift (FOUT), but for most use cases this is preferable to invisible text." },
  { question: "How many fonts should I use on a website?", answer: "As a rule of thumb, limit your site to 2 font families — one for headings and one for body text. Three is acceptable if you have a distinct monospace font for code. More than three fonts creates visual noise, slows page load, and makes the design feel unpolished. You can create sufficient hierarchy with weight (bold vs regular) and size within a single family." },
  { question: "What is the difference between serif, sans-serif, monospace, and display fonts?", answer: "Serif fonts have small decorative strokes at the ends of letterforms (e.g. Georgia, Playfair Display) — traditionally used for print body text and convey authority. Sans-serif fonts lack those strokes (e.g. Inter, Roboto) and are dominant in digital UI for their clarity at small sizes. Monospace fonts have equal-width characters (e.g. JetBrains Mono) used for code. Display fonts are decorative, designed for large headlines only — not readable at small sizes." },
];
---

<BaseLayout
  title="Web Font Pairing Tool — Google Fonts Selector & Live Preview"
  description="Find perfect Google Fonts pairings for your project. Search by category, see live text previews, and get the CSS font-family declarations and embed code instantly."
  tool="Google Fonts Pairing, Web Font Selector, Typography Tool, Font Preview, CSS Font Stack, Font Combination Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Web Font Pairing Tool</h1>
  <p class="text-text-muted mb-4">Select Google Font categories, pick font pairings, and preview live text with the correct CSS font-family declarations and embed URLs ready to copy.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 40+ curated fonts</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CSS + embed code</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Pairing suggestions</span>
  </div>

  <!-- Font Selection -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Select Fonts</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <label class="block text-sm font-medium mb-1.5">Heading Font</label>
        <select id="heading-category" class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm mb-2 focus:outline-none focus:border-primary">
          <option value="serif">Serif</option>
          <option value="sans-serif" selected>Sans-serif</option>
          <option value="display">Display</option>
          <option value="monospace">Monospace</option>
        </select>
        <select id="heading-font" class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary"></select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Body Font</label>
        <select id="body-category" class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm mb-2 focus:outline-none focus:border-primary">
          <option value="serif">Serif</option>
          <option value="sans-serif" selected>Sans-serif</option>
          <option value="display">Display</option>
          <option value="monospace">Monospace</option>
        </select>
        <select id="body-font" class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary"></select>
      </div>
    </div>
    <div class="flex flex-wrap gap-2 mt-4">
      <span class="text-sm text-text-muted self-center">Quick pairings:</span>
      <button class="pairing-btn text-xs px-3 py-1.5 bg-bg-surface border border-border rounded-lg hover:border-primary hover:text-primary transition-colors" data-h="Playfair Display" data-hc="serif" data-b="Source Sans 3" data-bc="sans-serif">Playfair + Source Sans</button>
      <button class="pairing-btn text-xs px-3 py-1.5 bg-bg-surface border border-border rounded-lg hover:border-primary hover:text-primary transition-colors" data-h="Inter" data-hc="sans-serif" data-b="Lora" data-bc="serif">Inter + Lora</button>
      <button class="pairing-btn text-xs px-3 py-1.5 bg-bg-surface border border-border rounded-lg hover:border-primary hover:text-primary transition-colors" data-h="Montserrat" data-hc="sans-serif" data-b="Merriweather" data-bc="serif">Montserrat + Merriweather</button>
      <button class="pairing-btn text-xs px-3 py-1.5 bg-bg-surface border border-border rounded-lg hover:border-primary hover:text-primary transition-colors" data-h="Raleway" data-hc="sans-serif" data-b="Roboto" data-bc="sans-serif">Raleway + Roboto</button>
      <button class="pairing-btn text-xs px-3 py-1.5 bg-bg-surface border border-border rounded-lg hover:border-primary hover:text-primary transition-colors" data-h="Space Grotesk" data-hc="sans-serif" data-b="JetBrains Mono" data-bc="monospace">Space Grotesk + JetBrains Mono</button>
    </div>
  </div>

  <!-- Preview Controls -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
      <h2 class="text-base font-semibold">Live Preview</h2>
      <div class="flex items-center gap-3">
        <select id="preview-style" class="bg-bg-surface border border-border rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:border-primary">
          <option value="blog">Blog Article</option>
          <option value="landing">Landing Page</option>
          <option value="dashboard">Dashboard UI</option>
        </select>
      </div>
    </div>
    <div id="font-preview" class="bg-bg-surface border border-border rounded-lg p-6 min-h-48">
      <p class="text-text-muted text-sm">Loading preview…</p>
    </div>
  </div>

  <!-- Output Code -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-3">Generated Code</h2>
    <div class="space-y-4">
      <div>
        <div class="flex items-center justify-between mb-1.5">
          <label class="text-sm font-medium">Google Fonts Embed (HTML &lt;head&gt;)</label>
          <button id="copy-embed" class="text-xs px-3 py-1 bg-bg-surface border border-border rounded-lg hover:border-primary hover:text-primary transition-colors">Copy</button>
        </div>
        <pre id="embed-code" class="font-mono text-sm bg-bg-surface rounded-lg p-4 overflow-x-auto text-text-muted whitespace-pre-wrap break-all"></pre>
      </div>
      <div>
        <div class="flex items-center justify-between mb-1.5">
          <label class="text-sm font-medium">CSS Variables</label>
          <button id="copy-css" class="text-xs px-3 py-1 bg-bg-surface border border-border rounded-lg hover:border-primary hover:text-primary transition-colors">Copy</button>
        </div>
        <pre id="css-code" class="font-mono text-sm bg-bg-surface rounded-lg p-4 overflow-x-auto text-text-muted whitespace-pre-wrap"></pre>
      </div>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="web-font-selector" relatedTags={['fonts', 'typography', 'google-fonts', 'web-design', 'css']} />
</BaseLayout>

<script>
const FONTS = {
  serif: ['Playfair Display', 'Merriweather', 'Lora', 'Libre Baskerville', 'Crimson Text', 'EB Garamond', 'Cormorant Garamond', 'Bitter'],
  'sans-serif': ['Inter', 'Roboto', 'Open Sans', 'Lato', 'Montserrat', 'Raleway', 'Nunito', 'Poppins', 'Source Sans 3', 'Space Grotesk', 'DM Sans', 'Outfit'],
  display: ['Oswald', 'Bebas Neue', 'Righteous', 'Pacifico', 'Lobster', 'Abril Fatface', 'Fredoka One'],
  monospace: ['JetBrains Mono', 'Fira Code', 'Source Code Pro', 'Roboto Mono', 'Inconsolata', 'Space Mono'],
};

const PREVIEW_CONTENT = {
  blog: {
    heading: 'The Art of Good Typography',
    subheading: 'Why your font choices define how readers feel about your content',
    body: 'Typography is the visual voice of your writing. A well-chosen typeface communicates tone before a single word is read. The spacing between letters, the weight of strokes, and the flow of a paragraph all contribute to whether your reader feels comfortable or uneasy on the page.',
    meta: 'April 2, 2026 · 8 min read',
  },
  landing: {
    heading: 'Build Faster. Ship Better.',
    subheading: 'The developer toolkit trusted by 50,000+ engineers worldwide',
    body: 'Stop wasting time on boilerplate. Our platform gives you the building blocks to launch production-ready applications in hours, not weeks. Batteries included.',
    meta: '14-day free trial · No credit card required',
  },
  dashboard: {
    heading: 'System Overview',
    subheading: 'All services operational · Last updated 2 minutes ago',
    body: 'Monitor your infrastructure in real time. Track deployments, error rates, and response times across all your services from a single unified dashboard.',
    meta: '99.98% uptime this month',
  },
};

let loadedFonts = new Set();

function populateFontSelect(categoryId, selectId, defaultFont) {
  const category = document.getElementById(categoryId).value;
  const select = document.getElementById(selectId);
  const fonts = FONTS[category] || [];
  select.innerHTML = fonts.map(f => `<option value="${f}" ${f === defaultFont ? 'selected' : ''}>${f}</option>`).join('');
}

function encodeFontName(name) {
  return name.replace(/ /g, '+');
}

function loadFont(name) {
  if (loadedFonts.has(name)) return;
  loadedFonts.add(name);
  const link = document.createElement('link');
  link.rel = 'stylesheet';
  link.href = `https://fonts.googleapis.com/css2?family=${encodeFontName(name)}:wght@400;700&display=swap`;
  document.head.appendChild(link);
}

function updatePreview() {
  const headingFont = document.getElementById('heading-font').value;
  const bodyFont = document.getElementById('body-font').value;
  const style = document.getElementById('preview-style').value;
  const content = PREVIEW_CONTENT[style];

  if (!headingFont || !bodyFont) return;

  loadFont(headingFont);
  loadFont(bodyFont);

  const preview = document.getElementById('font-preview');
  preview.innerHTML = `
    <div>
      <p style="font-family:'${bodyFont}',sans-serif; font-size:0.75rem; color:var(--color-text-muted); margin-bottom:0.5rem;">${content.meta}</p>
      <h2 style="font-family:'${headingFont}',serif; font-size:1.75rem; font-weight:700; line-height:1.2; margin-bottom:0.5rem;">${content.heading}</h2>
      <h3 style="font-family:'${headingFont}',serif; font-size:1.1rem; font-weight:400; color:var(--color-text-muted); margin-bottom:1rem;">${content.subheading}</h3>
      <p style="font-family:'${bodyFont}',sans-serif; font-size:1rem; line-height:1.7;">${content.body}</p>
      <div style="margin-top:1rem; display:flex; gap:0.5rem; flex-wrap:wrap;">
        <span style="font-family:'${bodyFont}',sans-serif; font-size:0.75rem; padding:0.25rem 0.75rem; border:1px solid var(--color-border); border-radius:9999px;">Heading: ${headingFont}</span>
        <span style="font-family:'${bodyFont}',sans-serif; font-size:0.75rem; padding:0.25rem 0.75rem; border:1px solid var(--color-border); border-radius:9999px;">Body: ${bodyFont}</span>
      </div>
    </div>
  `;

  const hEncoded = encodeFontName(headingFont);
  const bEncoded = encodeFontName(bodyFont);
  const sameFont = headingFont === bodyFont;

  const embedUrl = sameFont
    ? `https://fonts.googleapis.com/css2?family=${hEncoded}:wght@400;700&display=swap`
    : `https://fonts.googleapis.com/css2?family=${hEncoded}:wght@700&family=${bEncoded}:wght@400;600&display=swap`;

  document.getElementById('embed-code').textContent =
    `<link rel="preconnect" href="https://fonts.googleapis.com">\n<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>\n<link href="${embedUrl}" rel="stylesheet">`;

  document.getElementById('css-code').textContent =
    `:root {\n  --font-heading: '${headingFont}', ${document.getElementById('heading-category').value};\n  --font-body: '${bodyFont}', ${document.getElementById('body-category').value};\n}\n\nh1, h2, h3, h4, h5, h6 {\n  font-family: var(--font-heading);\n}\n\nbody {\n  font-family: var(--font-body);\n}`;
}

function initSelects() {
  populateFontSelect('heading-category', 'heading-font', 'Inter');
  populateFontSelect('body-category', 'body-font', 'Lora');

  document.getElementById('heading-category').addEventListener('change', () => {
    populateFontSelect('heading-category', 'heading-font', '');
    updatePreview();
  });
  document.getElementById('body-category').addEventListener('change', () => {
    populateFontSelect('body-category', 'body-font', '');
    updatePreview();
  });
  document.getElementById('heading-font').addEventListener('change', updatePreview);
  document.getElementById('body-font').addEventListener('change', updatePreview);
  document.getElementById('preview-style').addEventListener('change', updatePreview);
}

document.querySelectorAll('.pairing-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const hCat = btn.dataset.hc;
    const bCat = btn.dataset.bc;
    const hFont = btn.dataset.h;
    const bFont = btn.dataset.b;

    document.getElementById('heading-category').value = hCat;
    populateFontSelect('heading-category', 'heading-font', hFont);

    document.getElementById('body-category').value = bCat;
    populateFontSelect('body-category', 'body-font', bFont);

    updatePreview();
  });
});

function copyText(id, btnId) {
  const text = document.getElementById(id).textContent;
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.getElementById(btnId);
    const orig = btn.textContent;
    btn.textContent = 'Copied!';
    btn.classList.add('text-green-500', 'border-green-500');
    setTimeout(() => { btn.textContent = orig; btn.classList.remove('text-green-500', 'border-green-500'); }, 1500);
  });
}

document.getElementById('copy-embed').addEventListener('click', () => copyText('embed-code', 'copy-embed'));
document.getElementById('copy-css').addEventListener('click', () => copyText('css-code', 'copy-css'));

initSelects();
updatePreview();
</script>
