---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What makes a good system prompt?", answer: "A high-quality system prompt defines the AI's role, clearly states the task, specifies output format, sets constraints and boundaries, and ideally includes few-shot examples. Studies show that role definition alone can improve output quality by 20–40%. The more specific your instructions, the more predictable and useful the responses." },
  { question: "What is few-shot prompting?", answer: "Few-shot prompting means including 1–3 examples of ideal input/output pairs directly in your prompt. This technique dramatically improves output quality for structured tasks (JSON generation, classification, formatting) because the model learns the pattern rather than inferring it from instructions alone." },
  { question: "Why should I specify output format?", answer: "Without format instructions, the model picks whatever structure feels natural — which changes between runs. Specifying 'respond as JSON', 'use a numbered list', or 'output only the code block' makes your outputs predictable, parseable, and easier to integrate into downstream systems." },
  { question: "What are prompt constraints?", answer: "Constraints are rules that limit what the AI should or shouldn't do — for example: 'Do not include code examples', 'Always respond in under 100 words', 'Never make up facts'. They prevent common failure modes and keep responses focused. Without constraints, models often over-explain or hallucinate." },
  { question: "Does the user message matter for scoring?", answer: "Yes. The combined analysis checks whether your user message is clear and specific enough to pair with your system prompt. A great system prompt with a vague user message still produces inconsistent results. This tool scores both and suggests improvements for each dimension." },
];
---

<BaseLayout
  title="OpenAI Prompt Quality Tester — Score & Improve Your System Prompts"
  description="Analyze and score your OpenAI system prompts and user messages. Get instant quality scores across 7 dimensions: role, clarity, format, constraints, examples, tone, and error handling. Includes improvement suggestions."
  tool="OpenAI Prompt Tester, Prompt Quality Scorer, System Prompt Analyzer, Prompt Engineering Tool, GPT Prompt Checker"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">OpenAI Prompt Quality Tester</h1>
  <p class="text-text-muted mb-4">Paste your system prompt and user message to get an instant quality score across 7 engineering dimensions. Find gaps and get actionable improvement suggestions.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 7 scoring dimensions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Improvement suggestions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No API key needed</span>
  </div>

  <!-- Input area -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <div>
      <div class="flex items-center justify-between mb-2">
        <label class="text-sm font-medium" for="system-prompt">System Prompt</label>
        <button id="load-example" class="text-xs text-primary hover:underline">Load example</button>
      </div>
      <textarea id="system-prompt" rows="10"
        placeholder="You are a helpful assistant that..."
        class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary resize-y font-mono"
      ></textarea>
      <p class="text-xs text-text-muted mt-1" id="system-char-count">0 characters</p>
    </div>

    <div>
      <label class="block text-sm font-medium mb-2" for="user-message">User Message</label>
      <textarea id="user-message" rows="10"
        placeholder="Summarize the following document..."
        class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary resize-y font-mono"
      ></textarea>
      <p class="text-xs text-text-muted mt-1" id="user-char-count">0 characters</p>
    </div>
  </div>

  <button id="analyze-btn"
    class="mb-8 px-6 py-2.5 bg-primary text-white rounded-lg font-medium hover:opacity-90 transition-opacity text-sm">
    Analyze Prompt
  </button>

  <!-- Score panel -->
  <div id="results" class="hidden">
    <!-- Overall score -->
    <div class="bg-bg-card border border-border rounded-xl p-6 mb-6 flex items-center gap-6 flex-wrap">
      <div class="text-center">
        <div id="score-circle" class="text-5xl font-black tabular-nums leading-none" style="color: #22c55e">0</div>
        <div class="text-xs text-text-muted mt-1 font-medium">/ 100</div>
      </div>
      <div class="flex-1 min-w-[200px]">
        <div id="score-label" class="text-xl font-bold mb-1">—</div>
        <div class="w-full bg-bg-surface border border-border rounded-full h-3">
          <div id="score-bar" class="h-full rounded-full transition-all duration-500" style="width: 0%; background: #22c55e"></div>
        </div>
        <p id="score-summary" class="text-xs text-text-muted mt-2"></p>
      </div>
    </div>

    <!-- Dimension breakdown -->
    <h2 class="text-base font-semibold mb-4">Dimension Breakdown</h2>
    <div id="dimensions" class="space-y-3 mb-8"></div>

    <!-- Suggestions -->
    <div id="suggestions-block" class="hidden mb-8">
      <h2 class="text-base font-semibold mb-4">Improvement Suggestions</h2>
      <div id="suggestions" class="space-y-2"></div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="OpenAI Prompt Quality Tester" relatedTags={['ai', 'openai', 'prompt', 'llm', 'gpt', 'prompt-engineering']} />
</BaseLayout>

<script>
  var EXAMPLE_SYSTEM = "You are a senior software engineer specialized in Python. When asked to review code, you:\n1. Check for bugs and logic errors\n2. Suggest performance improvements\n3. Point out security issues\n\nAlways respond in this format:\n**Bugs:** <list or 'None'>\n**Performance:** <list or 'None'>\n**Security:** <list or 'None'>\n**Summary:** <one sentence>\n\nKeep responses concise. Do not rewrite the full code unless asked.";

  var EXAMPLE_USER = "Review this Python function that parses user input from a web form and saves it to the database.";

  var DIMENSIONS = [
    {
      id: 'role',
      label: 'Role / Persona Definition',
      maxPts: 15,
      description: 'Does the prompt define who or what the AI is?',
      patterns: [/\byou are\b/i, /\bact as\b/i, /\byour role\b/i, /\byou('re| are) a\b/i, /\bpersona\b/i, /\bspeciali[sz]/i, /\bexpert in\b/i, /\byou work as\b/i],
      tip: 'Add a role definition: "You are a [role] specializing in [domain]."'
    },
    {
      id: 'task',
      label: 'Task Clarity',
      maxPts: 20,
      description: 'Is the task clearly stated with specific instructions?',
      patterns: [/\byour (job|task|goal|objective|purpose)\b/i, /when (asked|given|provided|you receive)\b/i, /\byou (should|must|will|need to)\b/i, /\balways\b/i, /\bnever\b/i, /\brespond (to|when|by)\b/i],
      tip: 'Clearly state what the AI should do: "When the user provides X, you should Y."'
    },
    {
      id: 'format',
      label: 'Output Format Instructions',
      maxPts: 15,
      description: 'Does it specify response format (JSON, markdown, list, etc.)?',
      patterns: [/\bjson\b/i, /\bmarkdown\b/i, /\bbullet\b/i, /\bformat\b/i, /\bstructure\b/i, /\blist\b/i, /\btable\b/i, /\bheading/i, /respond (in|as|with)\b/i, /\boutput (format|as|in)\b/i],
      tip: 'Specify format: "Respond as JSON", "Use markdown", "Structure your answer as a numbered list."'
    },
    {
      id: 'constraints',
      label: 'Constraints & Boundaries',
      maxPts: 15,
      description: 'Does it set rules about what to do or avoid?',
      patterns: [/\bdo not\b/i, /\bdon't\b/i, /\bavoid\b/i, /\bonly\b/i, /\blimit(ed)?\b/i, /\bno more than\b/i, /\bunder \d+ words?\b/i, /\bnever (include|use|say|mention|repeat)\b/i, /\bkeep (it |responses? )?(concise|brief|short)\b/i],
      tip: 'Add constraints: "Do not include X", "Limit responses to N words", "Never make up facts."'
    },
    {
      id: 'examples',
      label: 'Examples / Few-Shot',
      maxPts: 20,
      description: 'Does it include input/output examples?',
      patterns: [/\bexample\b/i, /\bfor instance\b/i, /\be\.g\.\b/i, /\binput:/i, /\boutput:/i, /\bsample\b/i, /```/, /\blike this\b/i, /\bsuch as\b/i],
      tip: 'Add 1–2 examples: "Example input: ... Example output: ..." or use code blocks to show expected format.'
    },
    {
      id: 'tone',
      label: 'Tone / Style',
      maxPts: 10,
      description: 'Does it specify communication tone or writing style?',
      patterns: [/\btone\b/i, /\bformal\b/i, /\bcasual\b/i, /\bfriendly\b/i, /\bprofessional\b/i, /\bconcise\b/i, /\bdetailed\b/i, /\bstyle\b/i, /\bvoice\b/i, /\btechnical\b/i],
      tip: 'Specify tone: "Be concise and professional", "Use a friendly tone", "Write in a technical style."'
    },
    {
      id: 'errors',
      label: 'Edge Case / Error Handling',
      maxPts: 5,
      description: 'Does it handle unclear input or edge cases?',
      patterns: [/\bif (you are|you're|the (user|input|question|request))\b/i, /\bunclear\b/i, /\bnot sure\b/i, /\bunable to\b/i, /\bclarify\b/i, /\bedge case\b/i, /\berror\b/i, /\bfallback\b/i, /\bask (for clarification|the user)\b/i],
      tip: 'Handle edge cases: "If the request is unclear, ask for clarification before proceeding."'
    }
  ];

  function matchesDimension(text, patterns) {
    return patterns.some(function(p) { return p.test(text); });
  }

  function getScoreColor(score) {
    if (score >= 80) return '#22c55e';
    if (score >= 60) return '#f59e0b';
    if (score >= 40) return '#f97316';
    return '#ef4444';
  }

  function getScoreLabel(score) {
    if (score >= 90) return 'Excellent';
    if (score >= 75) return 'Good';
    if (score >= 55) return 'Fair';
    if (score >= 35) return 'Weak';
    return 'Poor';
  }

  function analyze() {
    var systemText = document.getElementById('system-prompt').value;
    var userText = document.getElementById('user-message').value;
    var combined = systemText + ' ' + userText;

    if (!combined.trim()) return;

    var totalScore = 0;
    var suggestions = [];
    var dimResults = [];

    DIMENSIONS.forEach(function(dim) {
      var found = matchesDimension(combined, dim.patterns);
      var pts = found ? dim.maxPts : 0;
      totalScore += pts;
      dimResults.push({ dim: dim, found: found, pts: pts });
      if (!found) {
        suggestions.push({ label: dim.label, tip: dim.tip });
      }
    });

    // Render results
    document.getElementById('results').classList.remove('hidden');

    var color = getScoreColor(totalScore);
    var label = getScoreLabel(totalScore);

    var circle = document.getElementById('score-circle');
    circle.textContent = totalScore;
    circle.style.color = color;

    document.getElementById('score-label').textContent = label;

    var bar = document.getElementById('score-bar');
    bar.style.width = totalScore + '%';
    bar.style.background = color;

    var summary = 'Your prompt scored ' + totalScore + '/100. ';
    if (totalScore >= 90) {
      summary += 'This is a production-ready prompt with comprehensive coverage.';
    } else if (totalScore >= 75) {
      summary += 'A strong prompt. Address the missing dimensions for optimal reliability.';
    } else if (totalScore >= 55) {
      summary += 'Room for improvement. Add the missing dimensions to get consistent outputs.';
    } else {
      summary += 'This prompt is missing critical dimensions that cause unpredictable results.';
    }
    document.getElementById('score-summary').textContent = summary;

    // Render dimensions
    var dimsEl = document.getElementById('dimensions');
    dimsEl.innerHTML = '';
    dimResults.forEach(function(r) {
      var row = document.createElement('div');
      row.className = 'bg-bg-card border border-border rounded-lg p-4 flex items-center gap-4 flex-wrap';

      var badge = r.found
        ? '<span class="flex items-center gap-1 text-xs font-semibold text-green-500 bg-green-500/10 border border-green-500/20 rounded-full px-2.5 py-1 shrink-0">✓ Present</span>'
        : '<span class="flex items-center gap-1 text-xs font-semibold text-red-400 bg-red-400/10 border border-red-400/20 rounded-full px-2.5 py-1 shrink-0">✗ Missing</span>';

      var pts = r.found
        ? '<span class="text-xs font-bold text-green-500 shrink-0">+' + r.dim.maxPts + ' pts</span>'
        : '<span class="text-xs font-bold text-text-muted shrink-0">0 / ' + r.dim.maxPts + ' pts</span>';

      row.innerHTML = badge +
        '<div class="flex-1 min-w-0">' +
          '<div class="text-sm font-semibold">' + r.dim.label + '</div>' +
          '<div class="text-xs text-text-muted">' + r.dim.description + '</div>' +
        '</div>' +
        pts;

      dimsEl.appendChild(row);
    });

    // Render suggestions
    var sugBlock = document.getElementById('suggestions-block');
    var sugEl = document.getElementById('suggestions');
    if (suggestions.length > 0) {
      sugBlock.classList.remove('hidden');
      sugEl.innerHTML = '';
      suggestions.forEach(function(s) {
        var item = document.createElement('div');
        item.className = 'bg-bg-card border border-border rounded-lg p-4';
        item.innerHTML =
          '<div class="text-xs font-bold text-primary mb-1">' + s.label + '</div>' +
          '<p class="text-sm text-text-muted">' + s.tip + '</p>';
        sugEl.appendChild(item);
      });
    } else {
      sugBlock.classList.add('hidden');
    }
  }

  document.getElementById('analyze-btn').addEventListener('click', analyze);

  document.getElementById('system-prompt').addEventListener('input', function() {
    document.getElementById('system-char-count').textContent = this.value.length + ' characters';
  });

  document.getElementById('user-message').addEventListener('input', function() {
    document.getElementById('user-char-count').textContent = this.value.length + ' characters';
  });

  document.getElementById('load-example').addEventListener('click', function() {
    document.getElementById('system-prompt').value = EXAMPLE_SYSTEM;
    document.getElementById('user-message').value = EXAMPLE_USER;
    document.getElementById('system-char-count').textContent = EXAMPLE_SYSTEM.length + ' characters';
    document.getElementById('user-char-count').textContent = EXAMPLE_USER.length + ' characters';
    analyze();
  });
</script>
