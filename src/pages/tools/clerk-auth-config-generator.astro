---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ClerkAuthConfigGenerator from '../../components/ClerkAuthConfigGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Clerk and why use it?",
    answer: "Clerk is a drop-in authentication and user management service. It handles sign-up, sign-in, password resets, social OAuth, MFA, session management, and user profiles — so you don't have to build any of that from scratch. It integrates natively with Next.js App Router, Remix, and Astro via framework-specific SDKs."
  },
  {
    question: "What does the middleware.ts file do?",
    answer: "The middleware runs on every request before your route handler executes. It uses Clerk's clerkMiddleware() to check if a user is authenticated. For routes you mark as protected (using createRouteMatcher), it calls auth.protect() which redirects unauthenticated users to the sign-in page automatically. Public routes skip the auth check entirely."
  },
  {
    question: "How do I protect a specific page in Next.js App Router?",
    answer: "Add the route pattern to the protected routes list (e.g. /dashboard(.*) to protect /dashboard and all sub-paths). For page-level protection, you can also use auth().protect() inside a Server Component or getAuth() inside a Route Handler. The middleware approach is recommended for consistent protection across all routes without per-page code."
  },
  {
    question: "How do social providers work?",
    answer: "Social providers (Google, GitHub, etc.) are configured in the Clerk Dashboard under User & Authentication → Social Connections. You select which providers to enable, provide the OAuth app credentials (Client ID and Secret from the provider's developer console), and Clerk handles all the OAuth flow, token exchange, and user creation automatically."
  },
  {
    question: "Where do I get my Clerk API keys?",
    answer: "Go to dashboard.clerk.com, create a new application, and find your Publishable Key and Secret Key in the API Keys section. The Publishable Key is safe to expose in client-side code (it's prefixed pk_). The Secret Key must never be exposed — keep it only in server-side environment variables."
  },
  {
    question: "What is the difference between Remix and Next.js Clerk setups?",
    answer: "In Next.js App Router, Clerk uses a middleware.ts file to intercept requests and a ClerkProvider wrapper in your root layout. In Remix, the rootAuthLoader wraps your root loader and ClerkApp wraps your root component. Both approaches achieve the same result: server-side auth checks with client-side auth state propagation, but the integration points differ to match each framework's conventions."
  },
];
---

<BaseLayout
  title="Clerk Auth Config Generator — Next.js, Remix & Astro Setup"
  description="Generate Clerk authentication configuration code for Next.js, Remix, and Astro apps. Configure protected routes, social providers, middleware, and environment variables. Free, runs in your browser."
  tool="Clerk authentication setup, clerk nextjs config, clerk middleware generator, clerk auth configuration"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Clerk Auth Config Generator",
    "url": "https://devplaybook.cc/tools/clerk-auth-config-generator",
    "description": "Generate Clerk authentication configuration for Next.js, Remix, and Astro. Configure routes, social providers, middleware, and environment variables.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Clerk Auth Config Generator</h1>
  <p class="text-text-muted mb-4">
    Generate ready-to-use <strong>Clerk authentication</strong> configuration for Next.js, Remix, and Astro.
    Select your framework, configure protected routes, pick social providers, and get complete
    <code class="font-mono bg-surface px-1 rounded text-sm">middleware.ts</code>, layout wrappers, and <code class="font-mono bg-surface px-1 rounded text-sm">.env</code> templates instantly.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Next.js / Remix / Astro</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Social OAuth providers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Route protection config</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-ready code</span>
  </div>
  <ClerkAuthConfigGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Clerk Auth Config Generator" relatedTags={['authentication', 'security', 'nextjs', 'remix', 'astro', 'developer-tools']} />
</BaseLayout>
