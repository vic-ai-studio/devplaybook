---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ApiResponseFormatter from '../../components/ApiResponseFormatter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---
<BaseLayout
  title="API Response Formatter & Analyzer — Beautify JSON, Inspect Headers"
  description="Format any raw HTTP API response: beautify JSON, inspect headers, and analyze status codes, CORS, caching, and rate limits. Instant, client-side, no signup."
  tool="API Response Formatter, JSON Beautifier, HTTP Response Analyzer, API Debugger"
>
  <h1 class="text-3xl font-bold mb-2">API Response Formatter & Analyzer</h1>
  <p class="text-text-muted mb-8">Paste a raw HTTP response to instantly format the JSON body, inspect all headers, and analyze status codes, caching, CORS, and rate limit signals — all in your browser.</p>
  <ApiResponseFormatter client:only="preact" />
  <ToolPageCta currentTool="API Response Formatter" relatedTags={['api', 'json', 'http', 'debugging', 'network']} />
</BaseLayout>
