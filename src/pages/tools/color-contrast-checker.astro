---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ColorContrastChecker from "../../components/ColorContrastChecker.tsx";
import ToolPageCta from "../../components/ToolPageCta.astro";
import FaqSection from "../../components/FaqSection.astro";

const faq = [
  { question: "What is WCAG contrast ratio and why does it matter?", answer: "WCAG (Web Content Accessibility Guidelines) defines minimum contrast ratios between text and background colors to ensure legibility for people with low vision or color blindness. A ratio of 4.5:1 is required for normal text (AA), 3:1 for large text (AA), and 7:1 for the strictest AAA standard." },
  { question: "What is the difference between WCAG AA and AAA?", answer: "AA is the legal standard for most accessibility requirements (e.g., ADA, EN 301 549). It requires 4.5:1 contrast for normal text and 3:1 for large text (18pt+ or 14pt+ bold). AAA requires 7:1 for normal text and 4.5:1 for large text — used when maximum accessibility is the goal." },
  { question: "What counts as large text in WCAG?", answer: "Large text is defined as 18pt (24px) or larger for regular weight, or 14pt (approximately 18.67px) or larger for bold text. Large text has a lower contrast requirement (3:1 for AA) because it is inherently easier to read." },
  { question: "How do I fix a failing contrast ratio?", answer: "To increase contrast: darken your text color, lighten your background, or both. Even small adjustments (e.g., #777 to #595959) can move from failing to passing. This tool shows the ratio live as you adjust colors, so you can iterate until you pass." },
  { question: "Does contrast ratio apply to icons and UI components?", answer: "Yes. WCAG 1.4.11 (Non-text Contrast) requires a 3:1 ratio for UI components and informational graphics — such as icons, form inputs, focus indicators, and chart lines. Use this tool to check those as well, not just text." },
];
---

<BaseLayout
  title="Color Contrast Checker — WCAG AA/AAA Compliance Tool — Free"
  description="Check foreground/background color contrast ratios against WCAG 2.1 AA and AAA standards. Get instant pass/fail results, contrast ratio, and suggested fixes. Free, runs in your browser."
  tool="Color Contrast Checker, WCAG Contrast Ratio, Accessibility Color Checker, WCAG AA AAA, Color Accessibility, Contrast Ratio Calculator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Color Contrast Checker",
    "description": "Free WCAG 2.1 color contrast checker. Test foreground and background colors against AA and AAA accessibility standards.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Web",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "url": "https://devplaybook.cc/tools/color-contrast-checker"
  })} />
  <h1 class="text-3xl font-bold mb-2">Color Contrast Checker</h1>
  <p class="text-text-muted mb-4">Check if your text and background colors meet WCAG 2.1 accessibility standards. Get instant AA/AAA pass/fail and suggested fixes — all in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> WCAG 2.1 AA & AAA standards</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <ColorContrastChecker client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Color Contrast Checker" relatedTags={["accessibility", "wcag", "colors", "design", "css"]} />
</BaseLayout>
