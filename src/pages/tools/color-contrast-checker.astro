---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ColorContrastChecker from '../../components/ColorContrastChecker.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Color Contrast Checker — WCAG AA/AAA Compliance Tool"
  description="Check foreground/background color contrast ratios against WCAG 2.1 AA and AAA standards. Get instant pass/fail results and suggested fixes. Free, runs in your browser."
  tool="Color Contrast Checker, WCAG Contrast Ratio, Accessibility Color Checker"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Color Contrast Checker",
    "description": "Free WCAG 2.1 color contrast checker. Test foreground and background colors against AA and AAA accessibility standards.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Web",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "url": "https://devplaybook.cc/tools/color-contrast-checker"
  })} />
  <h1 class="text-3xl font-bold mb-2">Color Contrast Checker</h1>
  <p class="text-text-muted mb-8">Check if your text and background colors meet WCAG 2.1 accessibility standards. Get instant AA/AAA pass/fail and suggested fixes — all in your browser.</p>
  <ColorContrastChecker client:only="preact" />
  <ToolPageCta currentTool="Color Contrast Checker" relatedTags={['accessibility', 'wcag', 'colors', 'design', 'css']} />
</BaseLayout>
