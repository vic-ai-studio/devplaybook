---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ChromeExtensionManifestGenerator from '../../components/ChromeExtensionManifestGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Manifest V3 and why does it matter?",
    answer: "Manifest V3 (MV3) is the current Chrome extension platform. It replaced Manifest V2 with service workers instead of background pages, declarativeNetRequest instead of blocking webRequest, and stricter content security policies. Google began enforcing MV3 in 2024 — all new extensions must use MV3, and all existing MV2 extensions were sunset from the Chrome Web Store."
  },
  {
    question: "What is the difference between permissions and host_permissions?",
    answer: "permissions covers API access (storage, tabs, notifications, etc.) — Chrome features your extension can use. host_permissions covers which websites your extension can access (inject scripts, read cookies, make requests). In MV3 these are separate: APIs go in permissions[], website patterns go in host_permissions[]. Both require user consent during install."
  },
  {
    question: "When do I need a content script vs a background service worker?",
    answer: "Content scripts run in the context of web pages — they can read and modify page DOM, interact with the page's JavaScript environment, and listen to page events. Background service workers handle events not tied to a specific page: alarms, messages, network requests via fetch, or responding to browser events. They wake on demand and sleep when idle."
  },
  {
    question: "What permissions should I request for the minimal extension?",
    answer: "Follow least-privilege: only request what you actually use. For a simple popup that reads/writes settings: just storage. For reading the current tab URL: activeTab (granted on user click, no prompt). For scripting injection: scripting + host_permissions for the target sites. Chrome may warn users about 'sensitive permissions' — keep the list lean to improve install conversion."
  },
  {
    question: "How do I add icons to my extension?",
    answer: "Create icon PNG files at 16x16, 32x32, 48x48, and 128x128 pixels. Place them in an icons/ folder. Reference them in manifest.json under both the top-level icons (for the extensions page) and action.default_icon (for the toolbar button). For best results, use a transparent background and test on both light and dark Chrome themes."
  },
  {
    question: "How do I test my extension locally?",
    answer: "Open chrome://extensions in Chrome, enable 'Developer mode' (top right toggle), click 'Load unpacked', and select your extension folder containing manifest.json. Chrome loads the extension and shows any manifest errors. After code changes, click the refresh icon next to your extension to reload it without reinstalling."
  },
];
---

<BaseLayout
  title="Chrome Extension Manifest Generator — Generate manifest.json (MV3) Online"
  description="Free Chrome extension manifest.json generator for Manifest V3. Configure name, version, permissions, content scripts, background service worker, popup, and options page. Copy-ready JSON output."
  tool="Chrome extension manifest generator, manifest.json generator, Manifest V3 generator, Chrome extension maker, browser extension manifest"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Chrome Extension Manifest Generator",
    "url": "https://devplaybook.cc/tools/chrome-extension-manifest-generator",
    "description": "Generate manifest.json for Chrome extensions (Manifest V3). Configure permissions, host permissions, popup, background service worker, content scripts. Free, runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Chrome Extension Manifest Generator</h1>
  <p class="text-text-muted mb-4">
    Generate a valid <code class="font-mono bg-surface px-1 rounded text-sm">manifest.json</code> for Chrome extensions (Manifest V3). Configure permissions, host permissions, popup, background service worker, content scripts, and options page — then copy the ready-to-use JSON.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Manifest V3</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 25+ permission options</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Content scripts & service worker</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-ready JSON</span>
  </div>
  <ChromeExtensionManifestGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Chrome Extension Manifest Generator" relatedTags={['browser-extension', 'chrome', 'javascript', 'developer-tools', 'web-development']} />
</BaseLayout>
