---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What counts as a breaking change in an API?", answer: "A breaking change is anything that requires existing clients to update their code. Examples include: removing an endpoint, changing an HTTP method, removing a required request field, adding a new required field, changing a field's type, or changing a status code. Non-breaking changes include: adding optional fields, adding new endpoints, or loosening validation constraints." },
  { question: "What formats does this tool support?", answer: "This tool supports OpenAPI 3.x and Swagger 2.x specifications in JSON or YAML format. Paste the full spec text including the openapi/swagger version field. The parser handles both formats automatically." },
  { question: "Why check for breaking changes?", answer: "API consumers (mobile apps, third-party integrations, internal services) depend on your API contract. Breaking changes silently break their code. Detecting them before releasing a new version lets you communicate changes, version your API, or provide migration guides." },
  { question: "What does this tool not catch?", answer: "This tool performs structural diff analysis on paths, methods, parameters, and response codes. It does not execute the APIs, check authentication behavior, or detect semantic changes in business logic. Use contract testing frameworks like Pact for full consumer-driven contract testing." },
  { question: "How do I handle breaking changes?", answer: "Common strategies: bump the major version (v1 → v2) and run both versions in parallel, use deprecation headers to notify clients, provide a migration guide, or use API gateways to transform old requests to new formats." },
];
---

<BaseLayout
  title="OpenAPI Diff Checker — Detect Breaking API Changes — Free Tool"
  description="Paste two OpenAPI or Swagger specs and instantly see breaking vs non-breaking changes. Detect removed endpoints, changed methods, new required fields, and status code changes. Free, runs in browser."
  tool="OpenAPI diff, Swagger diff, API breaking changes, API version diff, OpenAPI comparison tool"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">OpenAPI Diff Checker</h1>
  <p class="text-text-muted mb-4">Paste two OpenAPI / Swagger specs and instantly see what changed — breaking changes highlighted in red, safe additions in green. Supports JSON and YAML.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> OpenAPI 3.x + Swagger 2.x</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <!-- Input panes -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
    <div class="bg-surface border border-border rounded-xl p-4">
      <label class="block text-sm font-semibold mb-2">Old Spec (v1 / before)</label>
      <textarea id="oa-spec-old" rows="14" placeholder='Paste OpenAPI/Swagger JSON or YAML here...'
        class="w-full bg-background border border-border rounded-lg px-3 py-2 text-xs font-mono focus:outline-none focus:border-accent resize-none"></textarea>
    </div>
    <div class="bg-surface border border-border rounded-xl p-4">
      <label class="block text-sm font-semibold mb-2">New Spec (v2 / after)</label>
      <textarea id="oa-spec-new" rows="14" placeholder='Paste OpenAPI/Swagger JSON or YAML here...'
        class="w-full bg-background border border-border rounded-lg px-3 py-2 text-xs font-mono focus:outline-none focus:border-accent resize-none"></textarea>
    </div>
  </div>

  <div class="flex gap-3 mb-6">
    <button id="oa-load-example" class="text-sm bg-background border border-border hover:bg-accent/10 px-4 py-2 rounded-lg transition-colors">Load Example</button>
    <button id="oa-compare" class="text-sm bg-accent hover:bg-accent/80 text-white px-6 py-2 rounded-lg font-medium transition-colors">Compare →</button>
    <button id="oa-clear" class="text-sm bg-background border border-border hover:bg-accent/10 px-4 py-2 rounded-lg transition-colors">Clear</button>
  </div>

  <!-- Results -->
  <div id="oa-results" class="hidden space-y-3">
    <div class="flex items-center gap-4 mb-2">
      <h2 class="text-base font-semibold">Diff Results</h2>
      <span id="oa-summary" class="text-sm text-text-muted"></span>
    </div>

    <div id="oa-breaking-section" class="hidden bg-surface border border-red-500/30 rounded-xl p-4">
      <h3 class="text-sm font-semibold text-red-400 mb-3 flex items-center gap-2">
        <span class="w-2 h-2 bg-red-400 rounded-full"></span> Breaking Changes
      </h3>
      <div id="oa-breaking-list" class="space-y-2 text-sm font-mono"></div>
    </div>

    <div id="oa-nonbreaking-section" class="hidden bg-surface border border-green-500/30 rounded-xl p-4">
      <h3 class="text-sm font-semibold text-green-400 mb-3 flex items-center gap-2">
        <span class="w-2 h-2 bg-green-400 rounded-full"></span> Non-Breaking Changes
      </h3>
      <div id="oa-nonbreaking-list" class="space-y-2 text-sm font-mono"></div>
    </div>

    <div id="oa-info-section" class="hidden bg-surface border border-border rounded-xl p-4">
      <h3 class="text-sm font-semibold text-text-muted mb-3">Info / Metadata Changes</h3>
      <div id="oa-info-list" class="space-y-2 text-sm font-mono text-text-muted"></div>
    </div>

    <div id="oa-nochange" class="hidden bg-surface border border-border rounded-xl p-4 text-sm text-text-muted text-center">
      No differences found between the two specs.
    </div>
  </div>

  <div id="oa-error" class="hidden bg-red-900/20 border border-red-500/40 rounded-xl p-4 text-sm text-red-300"></div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="OpenAPI Diff Checker" relatedTags={['api', 'openapi', 'swagger', 'rest-api', 'developer-tools']} />
</BaseLayout>

<script>
(function () {
  // Minimal YAML→JSON parser (handles simple flat + nested objects/arrays)
  function parseYamlSimple(text) {
    // If it looks like JSON, parse directly
    const trimmed = text.trim();
    if (trimmed.startsWith('{') || trimmed.startsWith('[')) {
      return JSON.parse(trimmed);
    }
    // Try a line-by-line YAML parser for OpenAPI structures
    const lines = text.split('\n');
    return parseYamlLines(lines, 0, 0).value;
  }

  function getIndent(line) {
    let i = 0;
    while (i < line.length && line[i] === ' ') i++;
    return i;
  }

  function parseYamlLines(lines, startIdx, baseIndent) {
    const obj = {};
    const arr = [];
    let isArray = false;
    let i = startIdx;

    while (i < lines.length) {
      const line = lines[i];
      const stripped = line.trim();
      if (!stripped || stripped.startsWith('#')) { i++; continue; }

      const indent = getIndent(line);
      if (indent < baseIndent) break;

      if (stripped.startsWith('- ')) {
        isArray = true;
        const val = stripped.slice(2).trim();
        if (val.includes(': ')) {
          // Object item
          const sub = parseYamlLines(lines, i, indent + 2);
          arr.push(sub.value);
          i = sub.nextIdx;
        } else {
          arr.push(parseScalar(val));
          i++;
        }
        continue;
      }

      const colonIdx = stripped.indexOf(': ');
      if (colonIdx !== -1) {
        const key = stripped.slice(0, colonIdx);
        const rest = stripped.slice(colonIdx + 2);
        if (!rest) {
          // Nested object/array
          const sub = parseYamlLines(lines, i + 1, indent + 2);
          obj[key] = sub.value;
          i = sub.nextIdx;
        } else {
          obj[key] = parseScalar(rest);
          i++;
        }
      } else if (stripped.endsWith(':')) {
        const key = stripped.slice(0, -1);
        const sub = parseYamlLines(lines, i + 1, indent + 2);
        obj[key] = sub.value;
        i = sub.nextIdx;
      } else {
        i++;
      }
    }

    return { value: isArray ? arr : obj, nextIdx: i };
  }

  function parseScalar(v) {
    if (v === 'true') return true;
    if (v === 'false') return false;
    if (v === 'null' || v === '~') return null;
    if (/^-?\d+$/.test(v)) return parseInt(v, 10);
    if (/^-?\d+\.\d+$/.test(v)) return parseFloat(v);
    return v.replace(/^['"]|['"]$/g, '');
  }

  function parseSpec(text) {
    try {
      return parseYamlSimple(text.trim());
    } catch (e) {
      throw new Error('Could not parse spec: ' + e.message);
    }
  }

  function getPaths(spec) {
    return spec.paths || {};
  }

  function getInfo(spec) {
    return spec.info || {};
  }

  function diffSpecs(oldSpec, newSpec) {
    const breaking = [];
    const nonBreaking = [];
    const info = [];

    const oldPaths = getPaths(oldSpec);
    const newPaths = getPaths(newSpec);

    // Check info changes
    const oldInfo = getInfo(oldSpec);
    const newInfo = getInfo(newSpec);
    if (oldInfo.version !== newInfo.version) {
      info.push(`version: ${oldInfo.version || '?'} → ${newInfo.version || '?'}`);
    }
    if (oldInfo.title !== newInfo.title) {
      info.push(`title: "${oldInfo.title}" → "${newInfo.title}"`);
    }

    // Removed paths (breaking)
    for (const path of Object.keys(oldPaths)) {
      if (!newPaths[path]) {
        breaking.push({ msg: `REMOVED endpoint: ${path}`, detail: 'All methods on this path no longer exist.' });
        continue;
      }
      const oldMethods = oldPaths[path];
      const newMethods = newPaths[path];

      for (const method of Object.keys(oldMethods)) {
        if (method === 'parameters' || method === 'summary') continue;
        if (!newMethods[method]) {
          breaking.push({ msg: `REMOVED ${method.toUpperCase()} ${path}`, detail: 'Method was removed.' });
          continue;
        }

        const oldOp = oldMethods[method];
        const newOp = newMethods[method];

        // Check parameters
        const oldParams = oldOp.parameters || [];
        const newParams = newOp.parameters || [];

        // Required params removed
        oldParams.forEach(p => {
          const found = newParams.find(np => np.name === p.name && np.in === p.in);
          if (!found) {
            if (p.required) {
              breaking.push({ msg: `REMOVED required param: ${p.in} '${p.name}' on ${method.toUpperCase()} ${path}`, detail: 'Removing a required parameter breaks existing clients that were sending it and may affect validation.' });
            } else {
              nonBreaking.push({ msg: `Removed optional param: ${p.in} '${p.name}' on ${method.toUpperCase()} ${path}`, detail: '' });
            }
          } else {
            // Type changed
            if (p.schema && found.schema && p.schema.type !== found.schema.type) {
              breaking.push({ msg: `CHANGED param type: ${p.in} '${p.name}' on ${method.toUpperCase()} ${path}: ${p.schema.type} → ${found.schema.type}`, detail: 'Type changes break clients expecting the old type.' });
            }
            // Became required
            if (!p.required && found.required) {
              breaking.push({ msg: `PARAM became required: ${p.in} '${p.name}' on ${method.toUpperCase()} ${path}`, detail: 'Existing clients not sending this param will now fail.' });
            }
          }
        });

        // New required params added (breaking)
        newParams.forEach(p => {
          const found = oldParams.find(op => op.name === p.name && op.in === p.in);
          if (!found) {
            if (p.required) {
              breaking.push({ msg: `ADDED required param: ${p.in} '${p.name}' on ${method.toUpperCase()} ${path}`, detail: 'Existing clients not sending this new required param will fail.' });
            } else {
              nonBreaking.push({ msg: `Added optional param: ${p.in} '${p.name}' on ${method.toUpperCase()} ${path}`, detail: '' });
            }
          }
        });

        // Response code changes
        const oldResponses = Object.keys(oldOp.responses || {});
        const newResponses = Object.keys(newOp.responses || {});
        oldResponses.forEach(code => {
          if (!newOp.responses[code]) {
            if (String(code).startsWith('2')) {
              breaking.push({ msg: `REMOVED success response ${code} from ${method.toUpperCase()} ${path}`, detail: 'Clients checking for this status code will fail.' });
            } else {
              nonBreaking.push({ msg: `Removed response ${code} from ${method.toUpperCase()} ${path}`, detail: '' });
            }
          }
        });
        newResponses.forEach(code => {
          if (!oldOp.responses[code]) {
            nonBreaking.push({ msg: `Added response ${code} to ${method.toUpperCase()} ${path}`, detail: '' });
          }
        });
      }

      // New methods added (non-breaking)
      for (const method of Object.keys(newMethods)) {
        if (method === 'parameters' || method === 'summary') continue;
        if (!oldMethods[method]) {
          nonBreaking.push({ msg: `Added ${method.toUpperCase()} ${path}`, detail: '' });
        }
      }
    }

    // Added paths (non-breaking)
    for (const path of Object.keys(newPaths)) {
      if (!oldPaths[path]) {
        const methods = Object.keys(newPaths[path]).filter(m => m !== 'parameters' && m !== 'summary');
        nonBreaking.push({ msg: `Added endpoint: ${path} [${methods.map(m => m.toUpperCase()).join(', ')}]`, detail: '' });
      }
    }

    return { breaking, nonBreaking, info };
  }

  function renderItems(containerId, items, colorClass) {
    const el = document.getElementById(containerId);
    el.innerHTML = items.map(item => `
      <div class="flex flex-col gap-0.5 py-1.5 border-b border-border/50 last:border-0">
        <span class="${colorClass}">${item.msg}</span>
        ${item.detail ? `<span class="text-xs text-text-muted pl-2">${item.detail}</span>` : ''}
      </div>
    `).join('');
  }

  document.getElementById('oa-compare').addEventListener('click', () => {
    const oldText = document.getElementById('oa-spec-old').value.trim();
    const newText = document.getElementById('oa-spec-new').value.trim();
    const errorEl = document.getElementById('oa-error');
    const resultsEl = document.getElementById('oa-results');

    errorEl.classList.add('hidden');
    resultsEl.classList.add('hidden');

    if (!oldText || !newText) {
      errorEl.textContent = 'Please paste both specs before comparing.';
      errorEl.classList.remove('hidden');
      return;
    }

    let oldSpec, newSpec;
    try {
      oldSpec = parseSpec(oldText);
    } catch (e) {
      errorEl.textContent = 'Error parsing Old Spec: ' + e.message;
      errorEl.classList.remove('hidden');
      return;
    }
    try {
      newSpec = parseSpec(newText);
    } catch (e) {
      errorEl.textContent = 'Error parsing New Spec: ' + e.message;
      errorEl.classList.remove('hidden');
      return;
    }

    const { breaking, nonBreaking, info } = diffSpecs(oldSpec, newSpec);

    resultsEl.classList.remove('hidden');

    const total = breaking.length + nonBreaking.length + info.length;
    const summaryEl = document.getElementById('oa-summary');
    if (total === 0) {
      summaryEl.textContent = 'No differences found.';
    } else {
      summaryEl.textContent = `${breaking.length} breaking · ${nonBreaking.length} non-breaking · ${info.length} info`;
    }

    const breakingSection = document.getElementById('oa-breaking-section');
    const nonBreakingSection = document.getElementById('oa-nonbreaking-section');
    const infoSection = document.getElementById('oa-info-section');
    const noChangeEl = document.getElementById('oa-nochange');

    if (breaking.length) {
      breakingSection.classList.remove('hidden');
      renderItems('oa-breaking-list', breaking, 'text-red-400');
    } else {
      breakingSection.classList.add('hidden');
    }

    if (nonBreaking.length) {
      nonBreakingSection.classList.remove('hidden');
      renderItems('oa-nonbreaking-list', nonBreaking, 'text-green-400');
    } else {
      nonBreakingSection.classList.add('hidden');
    }

    if (info.length) {
      infoSection.classList.remove('hidden');
      const infoListEl = document.getElementById('oa-info-list');
      infoListEl.innerHTML = info.map(i => `<div>${i}</div>`).join('');
    } else {
      infoSection.classList.add('hidden');
    }

    noChangeEl.classList.toggle('hidden', total > 0);
  });

  document.getElementById('oa-clear').addEventListener('click', () => {
    document.getElementById('oa-spec-old').value = '';
    document.getElementById('oa-spec-new').value = '';
    document.getElementById('oa-results').classList.add('hidden');
    document.getElementById('oa-error').classList.add('hidden');
  });

  document.getElementById('oa-load-example').addEventListener('click', () => {
    document.getElementById('oa-spec-old').value = `openapi: "3.0.0"
info:
  title: Pet Store API
  version: "1.0.0"
paths:
  /pets:
    get:
      summary: List pets
      parameters:
        - name: limit
          in: query
          required: false
          schema:
            type: integer
      responses:
        "200":
          description: Success
        "400":
          description: Bad request
  /pets/{id}:
    get:
      summary: Get pet
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: integer
      responses:
        "200":
          description: Success
        "404":
          description: Not found
    delete:
      summary: Delete pet
      responses:
        "204":
          description: Deleted`;

    document.getElementById('oa-spec-new').value = `openapi: "3.0.0"
info:
  title: Pet Store API
  version: "2.0.0"
paths:
  /pets:
    get:
      summary: List pets
      parameters:
        - name: limit
          in: query
          required: false
          schema:
            type: integer
        - name: filter
          in: query
          required: true
          schema:
            type: string
      responses:
        "200":
          description: Success
  /pets/{id}:
    get:
      summary: Get pet
      parameters:
        - name: id
          in: path
          required: true
          schema:
            type: string
      responses:
        "200":
          description: Success
        "404":
          description: Not found
  /pets/{id}/photos:
    get:
      summary: Get pet photos
      responses:
        "200":
          description: Success`;
  });
})();
</script>
