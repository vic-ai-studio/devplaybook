---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the difference between REST API and HTTP API in API Gateway?", answer: "REST API (v1) is the original API Gateway type offering full features: usage plans, API keys, request/response mapping templates, caching, WAF integration, and custom authorizers. HTTP API (v2) is a newer, cheaper, faster alternative with fewer features but 71% lower cost. HTTP APIs support JWT authorizers, Lambda integrations, and CORS natively. For most new Lambda-backed APIs, HTTP API is the better choice unless you need caching, usage plans, or complex mapping templates." },
  { question: "How much does API Gateway cost per million requests?", answer: "REST API costs $3.50 per million requests in us-east-1 (first 333M/month), then $2.80/million. HTTP API costs $1.00 per million for the first 300M/month, then $0.90/million. WebSocket API costs $1.00 per million connection-minutes plus $1.00/million messages. HTTP API is 71% cheaper than REST API for most workloads." },
  { question: "Does API Gateway charge for data transfer?", answer: "API Gateway charges for data transfer out to the internet at standard AWS rates ($0.09/GB for the first 10TB). Requests from within AWS (same region) to API Gateway are free. For high-bandwidth APIs returning large responses, this data transfer cost can exceed the per-request cost. Use compression (gzip/brotli), response pagination, and caching to minimize data transfer." },
  { question: "How does API Gateway caching work and what does it cost?", answer: "REST API (not HTTP API) supports response caching with a configurable TTL. Cache sizes range from 0.5GB ($0.020/hour) to 237GB ($3.800/hour). Caching can dramatically reduce Lambda invocations and latency. Cache hits return stored responses without invoking Lambda. Consider caching if you have repeated identical requests with stable responses — the cache cost often pays for itself by reducing Lambda invocations." },
  { question: "Is API Gateway cheaper than ALB for Lambda backends?", answer: "Application Load Balancer (ALB) costs $0.008/LCU-hour plus $0.0065/hour base (~$4.75/month minimum). For low-traffic APIs (under 1M requests/month), API Gateway HTTP API is often cheaper — no minimum hourly cost. For high-traffic APIs (10M+ requests/month), ALB becomes cost-competitive and offers features like sticky sessions and health checks. CloudFront + Lambda Function URL is another option for global APIs." },
  { question: "What are the API Gateway request and payload size limits?", answer: "API Gateway limits: Maximum integration timeout is 29 seconds (REST/HTTP API). Maximum request payload is 10MB (REST) or 10MB (HTTP). Maximum response payload is 10MB. For larger payloads or longer timeouts, use S3 pre-signed URLs for file uploads, and Step Functions or SQS for async long-running operations triggered via API Gateway." },
];
---

<BaseLayout
  title="AWS API Gateway Cost Calculator & Pricing Guide"
  description="Compare AWS API Gateway pricing: REST vs HTTP vs WebSocket API cost per million requests, caching pricing, data transfer costs, and optimization tips to reduce your bill."
  tool="AWS API Gateway, Pricing, Cost Calculator, HTTP API, REST API, Serverless Cost"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"AWS API Gateway Cost Calculator & Pricing Guide","url":"https://devplaybook.cc/tools/aws-api-gateway-cost-calculator","description":"Compare AWS API Gateway REST vs HTTP vs WebSocket API pricing with cost optimization strategies."})} />

  <h1 class="text-3xl font-bold mb-2">AWS API Gateway Cost Calculator & Pricing Guide</h1>
  <p class="text-text-muted mb-6">API Gateway is the front door for Lambda-backed APIs — but its pricing model has several components that can surprise teams at scale. This guide breaks down REST vs HTTP API costs, caching economics, data transfer charges, and when to switch to alternatives.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> REST vs HTTP vs WebSocket pricing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Caching cost-benefit analysis</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> API GW vs ALB vs CloudFront</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Cost optimization strategies</span>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-4">API Gateway Pricing Comparison</h2>
  <div class="overflow-x-auto mb-8">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4">API Type</th>
          <th class="text-left py-2 pr-4">First Tier (per M req)</th>
          <th class="text-left py-2 pr-4">Higher Volume</th>
          <th class="text-left py-2 pr-4">Caching Available</th>
          <th class="text-left py-2">Key Features</th>
        </tr>
      </thead>
      <tbody class="text-text-muted">
        <tr class="border-b border-border"><td class="py-2 pr-4">REST API (v1)</td><td class="py-2 pr-4">$3.50</td><td class="py-2 pr-4">$2.80 (333M+)</td><td class="py-2 pr-4">Yes ($0.02-$3.80/hr)</td><td class="py-2">Full features, WAF, usage plans</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">HTTP API (v2)</td><td class="py-2 pr-4">$1.00</td><td class="py-2 pr-4">$0.90 (300M+)</td><td class="py-2 pr-4">No</td><td class="py-2">JWT auth, CORS, 71% cheaper</td></tr>
        <tr><td class="py-2 pr-4">WebSocket API</td><td class="py-2 pr-4">$1.00/M msgs</td><td class="py-2 pr-4">$0.80/M msgs</td><td class="py-2 pr-4">No</td><td class="py-2">Real-time bidirectional</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-4">Monthly Cost Estimator</h2>
  <div class="overflow-x-auto mb-8">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4">Monthly Requests</th>
          <th class="text-left py-2 pr-4">REST API Cost</th>
          <th class="text-left py-2 pr-4">HTTP API Cost</th>
          <th class="text-left py-2">Savings with HTTP API</th>
        </tr>
      </thead>
      <tbody class="text-text-muted">
        <tr class="border-b border-border"><td class="py-2 pr-4">1 million</td><td class="py-2 pr-4">$3.50</td><td class="py-2 pr-4">$1.00</td><td class="py-2">$2.50 (71%)</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">10 million</td><td class="py-2 pr-4">$35.00</td><td class="py-2 pr-4">$10.00</td><td class="py-2">$25.00 (71%)</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">100 million</td><td class="py-2 pr-4">$350.00</td><td class="py-2 pr-4">$100.00</td><td class="py-2">$250.00 (71%)</td></tr>
        <tr><td class="py-2 pr-4">1 billion</td><td class="py-2 pr-4">$3,080.00</td><td class="py-2 pr-4">$910.00</td><td class="py-2">$2,170.00 (70%)</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-4">Creating an HTTP API (Cheapest Option)</h2>
  <pre class="bg-surface border border-border rounded-lg p-4 mb-6 overflow-x-auto text-sm"><code># AWS CLI — create HTTP API (v2, $1/M requests)
aws apigatewayv2 create-api \
  --name my-http-api \
  --protocol-type HTTP \
  --cors-configuration AllowOrigins=["*"],AllowMethods=["GET","POST"],AllowHeaders=["Content-Type","Authorization"]

# Create Lambda integration
aws apigatewayv2 create-integration \
  --api-id $API_ID \
  --integration-type AWS_PROXY \
  --integration-uri arn:aws:lambda:us-east-1:123456789:function:my-function \
  --payload-format-version 2.0

# Serverless Framework — HTTP API (default in v3)
functions:
  api:
    handler: src/handler.ts
    events:
      - httpApi:          # HTTP API (v2) — $1/M
          path: /users
          method: GET
      # Use 'http' for REST API (v1) — $3.50/M
      # - http:
      #     path: /users
      #     method: GET</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-4">API Gateway vs ALB vs CloudFront</h2>
  <div class="overflow-x-auto mb-8">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4">Option</th>
          <th class="text-left py-2 pr-4">Base Cost</th>
          <th class="text-left py-2 pr-4">Per Request</th>
          <th class="text-left py-2">Best For</th>
        </tr>
      </thead>
      <tbody class="text-text-muted">
        <tr class="border-b border-border"><td class="py-2 pr-4">API GW HTTP API</td><td class="py-2 pr-4">$0/mo min</td><td class="py-2 pr-4">$1.00/M</td><td class="py-2">Serverless APIs, low traffic</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">ALB + Lambda</td><td class="py-2 pr-4">~$16/mo min</td><td class="py-2 pr-4">~$0.008/LCU-hr</td><td class="py-2">High traffic, steady load</td></tr>
        <tr><td class="py-2 pr-4">Lambda Function URL</td><td class="py-2 pr-4">$0/mo min</td><td class="py-2 pr-4">Lambda cost only</td><td class="py-2">Direct Lambda, no routing needed</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-4">Cost Optimization: Enable Caching</h2>
  <pre class="bg-surface border border-border rounded-lg p-4 mb-6 overflow-x-auto text-sm"><code># REST API with caching (reduces Lambda invocations)
# serverless.yml
provider:
  apiGateway:
    restApiId: !Ref ApiGatewayRestApi
    shouldStartNameWithService: true

custom:
  apiGatewayThrottling:
    maxRequestsPerSecond: 1000
    maxConcurrentRequests: 500

functions:
  getUser:
    handler: src/getUser.handler
    events:
      - http:
          path: /users/&#123;id&#125;
          method: GET
          caching:
            enabled: true
            cacheKeyParameters:
              - name: request.path.id
            ttlInSeconds: 300  # 5 min cache

# Cache size 0.5GB = $0.020/hour = $14.40/month
# If cache reduces 80% of 10M requests: saves $2.80/month on Lambda
# ROI: needs ~500K requests/day to justify 0.5GB cache</code></pre>

  <ToolPageCta currentTool="AWS API Gateway Cost Calculator" relatedTags={['aws', 'api-gateway', 'serverless', 'cost', 'lambda']} />
  <FaqSection faq={faq} />
</BaseLayout>
