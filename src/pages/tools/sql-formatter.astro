---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SqlFormatter from '../../components/SqlFormatter.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How do I format a SQL query online?", answer: "Paste your SQL query into the editor and click Format. The tool automatically indents clauses, uppercases keywords (SELECT, FROM, WHERE, JOIN), and aligns subqueries — giving you clean, readable SQL instantly." },
  { question: "What SQL dialects does this formatter support?", answer: "This formatter handles standard SQL including SELECT, INSERT, UPDATE, DELETE, CREATE TABLE, ALTER TABLE, CTEs (WITH clauses), subqueries, and multi-table JOINs. It works well with MySQL, PostgreSQL, SQLite, and most standard SQL dialects." },
  { question: "Is my SQL data sent to any server?", answer: "No. This tool runs entirely in your browser using JavaScript. Your SQL queries never leave your machine, making it safe to use with production queries or sensitive database schemas." },
  { question: "Can I use this to minify SQL as well?", answer: "Yes. Use the Minify option to compress your SQL to a single line — useful for embedding queries in application code or reducing whitespace in config files." },
  { question: "Why should I format SQL queries?", answer: "Formatted SQL is much easier to read, debug, and review in pull requests. Consistent indentation and keyword casing make it faster to spot errors in complex queries with multiple JOINs, subqueries, or CTEs." },
];
---

<BaseLayout
  title="SQL Formatter & Beautifier — Format SQL Online Free"
  description="Format and beautify SQL online. Auto-indent SELECT, FROM, WHERE, JOIN, uppercase keywords, and minify to one line. Supports MySQL, PostgreSQL, SQLite. Free."
  tool="SQL Formatter, SQL Beautifier, SQL Minifier, SQL Pretty Print, Format SQL Online, SQL Indenter, SQL Query Formatter"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">SQL Formatter & Beautifier</h1>
  <p class="text-text-muted mb-4">Paste messy SQL to auto-indent and uppercase keywords. Supports SELECT, INSERT, UPDATE, DELETE, CREATE, ALTER, CTEs, subqueries, and JOIN clauses. Also minifies SQL to one line.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <SqlFormatter client:load />
  <FaqSection faq={faq} />
  <AffiliateSection category="database" />
  <ToolPageCta currentTool="SQL Formatter" relatedTags={['sql', 'database', 'formatting', 'development']} />
</BaseLayout>
