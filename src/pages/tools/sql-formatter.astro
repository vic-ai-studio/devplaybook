---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SqlFormatter from '../../components/SqlFormatter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="SQL Formatter & Beautifier"
  description="Format and beautify SQL queries online. Auto-indent SELECT, FROM, WHERE, JOIN clauses, uppercase keywords, and minify SQL to a single line. Free, runs in browser."
  tool="SQL Formatter, SQL Beautifier, SQL Minifier, SQL Pretty Print"
>
  <h1 class="text-3xl font-bold mb-2">SQL Formatter & Beautifier</h1>
  <p class="text-text-muted mb-8">Paste messy SQL to auto-indent and uppercase keywords. Supports SELECT, INSERT, UPDATE, DELETE, CREATE, ALTER, CTEs, subqueries, and JOIN clauses. Also minifies SQL to one line.</p>
  <SqlFormatter client:load />
  <ToolPageCta currentTool="SQL Formatter" relatedTags={['sql', 'database', 'formatting', 'development']} />
</BaseLayout>
