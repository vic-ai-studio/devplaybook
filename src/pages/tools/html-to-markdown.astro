---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HtmlToMarkdown from '../../components/HtmlToMarkdown.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What HTML elements does the converter support?", answer: "The converter handles headings (h1-h6), paragraphs, bold/strong, italic/em, strikethrough, links, images, code, pre/code blocks, blockquotes, ordered and unordered lists, tables, horizontal rules, and line breaks." },
  { question: "Why convert HTML to Markdown?", answer: "Markdown is much easier to read and write than HTML. Common use cases include converting blog post content for a static site generator, preparing content for GitHub READMEs, or migrating from a CMS to a Markdown-based system." },
  { question: "Will nested elements be converted correctly?", answer: "Yes. Nested structures like lists inside lists, bold inside links, or code inside paragraphs are handled correctly using recursive DOM traversal." },
  { question: "Is the output GitHub-Flavored Markdown (GFM)?", answer: "Mostly yes. The converter outputs GFM-compatible Markdown including strikethrough (~~text~~), tables with alignment separators, and fenced code blocks (``` syntax)." },
];
---

<BaseLayout
  title="HTML to Markdown Converter — Free Online Tool"
  description="Convert HTML to Markdown instantly. Supports headings, bold, italic, links, images, lists, tables, code blocks, and blockquotes. Free online tool, runs in your browser."
  tool="HTML to Markdown converter, HTML to MD, convert HTML markdown online, HTML markdown tool"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">HTML to Markdown Converter</h1>
  <p class="text-text-muted mb-4">Paste any HTML and get clean Markdown output instantly. Handles headings, formatting, links, lists, tables, code blocks, and more. Side-by-side view for easy comparison. Runs entirely in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No data leaves your machine</span>
  </div>
  <HtmlToMarkdown client:only="preact" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more free developer tools?</p>
    <a href="/tools" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Browse All Free Tools →</a>
  </div>
  <ToolPageCta currentTool="HTML to Markdown Converter" relatedTags={['html', 'markdown', 'converter', 'text']} />
</BaseLayout>
