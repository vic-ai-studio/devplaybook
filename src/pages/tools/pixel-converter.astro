---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PixelConverter from '../../components/PixelConverter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How do I convert px to rem?", answer: "Divide the pixel value by the root font size (usually 16px). So 24px ÷ 16 = 1.5rem. The rem unit is relative to the root element's font size, which defaults to 16px in most browsers unless overridden. This converter lets you set a custom root font size if your project uses a different base." },
  { question: "What is the difference between rem and em?", answer: "rem (root em) is relative to the root element's font size — it stays consistent across the entire document. em is relative to the current element's font size, which can cascade and compound: a child element inside a parent with font-size: 1.5em will have em calculated from that 1.5× value, causing unexpected sizes." },
  { question: "When should I use px vs rem for font sizes?", answer: "Use rem for font sizes and spacing to respect user browser settings — if a user increases their base font size for accessibility, rem-based layouts scale accordingly. Use px for things that should never scale with font size, like borders, specific icon sizes, or decorative element dimensions." },
  { question: "What are vh and vw units?", answer: "vh (viewport height) and vw (viewport width) are relative to the browser viewport size. 1vh = 1% of the viewport height; 100vh = the full height. They're useful for full-screen sections, hero images, and responsive layouts. Note: on mobile browsers, 100vh can be tricky because the browser chrome (address bar) affects the viewport height." },
  { question: "How does the % unit work in CSS?", answer: "Percentage (%) in CSS is relative to the parent element's size. For width/height, it's a percentage of the parent's width/height. For font-size, it's a percentage of the parent's font size. This converter lets you set the 'parent size' context to calculate percentage values accurately." },
];
---

<BaseLayout
  title="Pixel Converter — px to rem, em, vh, vw, % | Free Tool"
  description="Free pixel unit converter. Convert between px, rem, em, vh, vw, and % instantly. Set custom root font size, parent font size, and viewport dimensions for accurate conversions. Runs 100% in your browser."
  tool="Pixel Converter, px to rem converter, px to em, CSS unit converter, rem to px, em to px, vh vw converter, CSS responsive units"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Pixel Converter</h1>
  <p class="text-text-muted mb-4">Convert between px, rem, em, vh, vw, and % instantly. Set your root font size, viewport dimensions, and parent element size for accurate context-aware conversions. Click any result to copy it.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All 6 CSS units supported</span>
  </div>
  <PixelConverter client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Pixel Converter" relatedTags={['css', 'responsive', 'frontend', 'design', 'tailwind']} />
</BaseLayout>
