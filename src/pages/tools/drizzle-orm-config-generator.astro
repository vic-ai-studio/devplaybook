---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is Drizzle ORM?", answer: "Drizzle ORM is a lightweight, TypeScript-first ORM that generates type-safe SQL queries with zero runtime overhead. Unlike Prisma, it uses a code-first schema definition in TypeScript and supports PostgreSQL, MySQL, and SQLite. It's designed for serverless environments with minimal cold start impact." },
  { question: "What does drizzle.config.ts do?", answer: "drizzle.config.ts configures the Drizzle Kit CLI for migrations and schema introspection. It specifies the schema file path, migration output directory, and database connection details. Drizzle Kit reads this file when you run 'drizzle-kit generate', 'drizzle-kit push', or 'drizzle-kit studio'." },
  { question: "What is the difference between drizzle-kit push and generate?", answer: "'drizzle-kit push' directly applies schema changes to your database without creating migration files — ideal for development. 'drizzle-kit generate' creates SQL migration files that you review and apply with 'drizzle-kit migrate'. Use push for dev, generate+migrate for production workflows." },
  { question: "Which driver should I use with Drizzle for serverless?", answer: "For serverless: use @neondatabase/serverless for Neon PostgreSQL, @planetscale/database for PlanetScale MySQL, or @libsql/client for Turso SQLite. These drivers support HTTP-based connections without persistent TCP connections, which is critical for serverless environments like Vercel Edge or Cloudflare Workers." },
  { question: "How do I define a Drizzle schema?", answer: "Create a schema file (e.g., src/db/schema.ts) and use Drizzle's table builders: pgTable, mysqlTable, or sqliteTable. Each column is defined with type functions like varchar(), integer(), boolean(), timestamp(). Export your table definitions and import them in your application for type-safe queries." }
];
---

<BaseLayout
  title="Drizzle ORM Config Generator — Generate drizzle.config.ts"
  description="Generate Drizzle ORM configuration files instantly. Select your database, driver, and connection string to get drizzle.config.ts, schema imports, and db/index.ts. Free browser tool."
  tool="drizzle ORM config generator, drizzle.config.ts generator, drizzle ORM setup, drizzle kit config, drizzle database config"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Drizzle ORM Config Generator",
    "url": "https://devplaybook.cc/tools/drizzle-orm-config-generator",
    "description": "Generate Drizzle ORM drizzle.config.ts, schema setup, and db/index.ts files based on your database and driver selection.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Drizzle ORM Config Generator</h1>
  <p class="text-text-muted mb-4">
    Generate <code class="text-accent">drizzle.config.ts</code>, schema setup, and <code class="text-accent">db/index.ts</code>
    for your Drizzle ORM project. Select your database and driver, enter your connection string, and copy the output.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> PostgreSQL / MySQL / SQLite</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Serverless-ready drivers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> drizzle.config.ts + db/index.ts</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Copy each file separately</span>
  </div>

  <!-- Config inputs -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-semibold mb-3">Configuration</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">
      <div>
        <label class="block text-xs text-text-muted mb-1">Database</label>
        <select id="sel-db" class="w-full bg-surface border border-border rounded px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="pg">PostgreSQL</option>
          <option value="mysql">MySQL</option>
          <option value="sqlite">SQLite</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Driver</label>
        <select id="sel-driver" class="w-full bg-surface border border-border rounded px-3 py-2 text-sm focus:outline-none focus:border-primary">
        </select>
      </div>
    </div>
    <div class="mb-3">
      <label class="block text-xs text-text-muted mb-1">Connection String (or env var reference)</label>
      <input id="conn-str" type="text" value="process.env.DATABASE_URL" class="w-full bg-surface border border-border rounded px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <div>
        <label class="block text-xs text-text-muted mb-1">Schema file path</label>
        <input id="schema-path" type="text" value="./src/db/schema.ts" class="w-full bg-surface border border-border rounded px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Migrations output directory</label>
        <input id="migrations-dir" type="text" value="./drizzle" class="w-full bg-surface border border-border rounded px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
      </div>
    </div>
  </div>

  <!-- Output tabs -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <div class="flex gap-2 mb-3 flex-wrap">
      <button class="tab-btn px-3 py-1.5 text-xs rounded font-medium transition-colors" data-tab="config">drizzle.config.ts</button>
      <button class="tab-btn px-3 py-1.5 text-xs rounded font-medium transition-colors" data-tab="schema">schema.ts (starter)</button>
      <button class="tab-btn px-3 py-1.5 text-xs rounded font-medium transition-colors" data-tab="db">db/index.ts</button>
    </div>
    <div class="flex items-center justify-between mb-2">
      <span id="tab-label" class="text-sm font-semibold text-text-muted"></span>
      <button id="copy-out" class="px-4 py-1.5 bg-primary text-white rounded text-sm font-medium hover:bg-primary/90 transition-colors">Copy</button>
    </div>
    <pre id="code-output" class="bg-surface rounded p-3 text-xs font-mono text-foreground/90 overflow-x-auto whitespace-pre min-h-[160px]"></pre>
  </div>

  <!-- Install command -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <div class="flex items-center justify-between mb-2">
      <h2 class="text-sm font-semibold">Install Command</h2>
      <button id="copy-install" class="px-4 py-1.5 bg-surface border border-border rounded text-xs font-medium hover:border-primary transition-colors">Copy</button>
    </div>
    <pre id="install-output" class="bg-surface rounded p-3 text-xs font-mono text-foreground/90 overflow-x-auto whitespace-pre"></pre>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Drizzle ORM Config Generator" relatedTags={["drizzle", "orm", "database", "typescript", "postgresql", "sqlite"]} />
</BaseLayout>

<script is:inline>
(function () {
  var DRIVERS = {
    pg: [
      { val: "node-postgres", label: "node-postgres (pg)", pkg: "pg @types/pg" },
      { val: "neon", label: "Neon Serverless", pkg: "@neondatabase/serverless" },
      { val: "postgres-js", label: "postgres.js", pkg: "postgres" },
      { val: "vercel-pg", label: "Vercel Postgres", pkg: "@vercel/postgres" }
    ],
    mysql: [
      { val: "mysql2", label: "mysql2", pkg: "mysql2" },
      { val: "planetscale", label: "PlanetScale Serverless", pkg: "@planetscale/database" }
    ],
    sqlite: [
      { val: "better-sqlite3", label: "better-sqlite3 (local)", pkg: "better-sqlite3 @types/better-sqlite3" },
      { val: "turso", label: "Turso / libSQL", pkg: "@libsql/client" },
      { val: "bun-sqlite", label: "Bun SQLite (built-in)", pkg: "" }
    ]
  };

  var INSTALLS = {
    "node-postgres": "npm install drizzle-orm pg @types/pg\nnpm install -D drizzle-kit",
    "neon": "npm install drizzle-orm @neondatabase/serverless\nnpm install -D drizzle-kit",
    "postgres-js": "npm install drizzle-orm postgres\nnpm install -D drizzle-kit",
    "vercel-pg": "npm install drizzle-orm @vercel/postgres\nnpm install -D drizzle-kit",
    "mysql2": "npm install drizzle-orm mysql2\nnpm install -D drizzle-kit",
    "planetscale": "npm install drizzle-orm @planetscale/database\nnpm install -D drizzle-kit",
    "better-sqlite3": "npm install drizzle-orm better-sqlite3 @types/better-sqlite3\nnpm install -D drizzle-kit",
    "turso": "npm install drizzle-orm @libsql/client\nnpm install -D drizzle-kit",
    "bun-sqlite": "bun add drizzle-orm\nbun add -d drizzle-kit"
  };

  var activeTab = "config";

  function getDb(){ return document.getElementById("sel-db").value; }
  function getDriver(){ return document.getElementById("sel-driver").value; }
  function getConn(){ return document.getElementById("conn-str").value || "process.env.DATABASE_URL"; }
  function getSchema(){ return document.getElementById("schema-path").value || "./src/db/schema.ts"; }
  function getMig(){ return document.getElementById("migrations-dir").value || "./drizzle"; }

  function updateDrivers(){
    var db = getDb();
    var sel = document.getElementById("sel-driver");
    sel.innerHTML = (DRIVERS[db]||[]).map(function(d){
      return "<option value='"+d.val+"'>"+d.label+"</option>";
    }).join("");
    updateDefaultConn();
    generate();
  }

  function updateDefaultConn(){
    var db = getDb();
    var driver = getDriver();
    var conn = document.getElementById("conn-str");
    if(driver === "better-sqlite3") conn.value = "./local.db";
    else if(driver === "bun-sqlite") conn.value = "./local.db";
    else if(driver === "turso") conn.value = "process.env.TURSO_CONNECTION_URL";
    else conn.value = "process.env.DATABASE_URL";
  }

  function genConfig(){
    var db = getDb();
    var driver = getDriver();
    var conn = getConn();
    var schema = getSchema();
    var mig = getMig();

    var dialectMap = { pg: "postgresql", mysql: "mysql", sqlite: "sqlite" };
    var dialect = dialectMap[db] || "postgresql";

    var connLine;
    if(driver === "better-sqlite3" || driver === "bun-sqlite"){
      connLine = '  dbCredentials: {\n    url: "'+conn+'",\n  },';
    } else if(driver === "neon" || driver === "planetscale" || driver === "turso"){
      connLine = '  dbCredentials: {\n    url: '+conn+',\n  },';
    } else {
      connLine = '  dbCredentials: {\n    connectionString: '+conn+',\n  },';
    }

    return 'import type { Config } from "drizzle-kit";\n\nexport default {\n  schema: "'+schema+'",\n  out: "'+mig+'",\n  dialect: "'+dialect+'",\n'+connLine+'\n} satisfies Config;';
  }

  function genSchema(){
    var db = getDb();
    if(db === "pg"){
      return 'import { pgTable, serial, text, timestamp, boolean } from "drizzle-orm/pg-core";\n\nexport const users = pgTable("users", {\n  id:        serial("id").primaryKey(),\n  email:     text("email").notNull().unique(),\n  name:      text("name"),\n  active:    boolean("active").default(true),\n  createdAt: timestamp("created_at").defaultNow(),\n});\n\nexport type User = typeof users.$inferSelect;\nexport type NewUser = typeof users.$inferInsert;';
    } else if(db === "mysql"){
      return 'import { mysqlTable, serial, varchar, timestamp, boolean } from "drizzle-orm/mysql-core";\n\nexport const users = mysqlTable("users", {\n  id:        serial("id").primaryKey(),\n  email:     varchar("email", { length: 255 }).notNull().unique(),\n  name:      varchar("name", { length: 100 }),\n  active:    boolean("active").default(true),\n  createdAt: timestamp("created_at").defaultNow(),\n});\n\nexport type User = typeof users.$inferSelect;\nexport type NewUser = typeof users.$inferInsert;';
    } else {
      return 'import { sqliteTable, integer, text } from "drizzle-orm/sqlite-core";\n\nexport const users = sqliteTable("users", {\n  id:        integer("id").primaryKey({ autoIncrement: true }),\n  email:     text("email").notNull().unique(),\n  name:      text("name"),\n  createdAt: text("created_at").$defaultFn(() => new Date().toISOString()),\n});\n\nexport type User = typeof users.$inferSelect;\nexport type NewUser = typeof users.$inferInsert;';
    }
  }

  function genDbIndex(){
    var db = getDb();
    var driver = getDriver();
    var conn = getConn();
    var schema = getSchema().replace(/^\.\//, "../").replace(/\.ts$/, "");

    if(driver === "node-postgres"){
      return 'import { drizzle } from "drizzle-orm/node-postgres";\nimport { Pool } from "pg";\nimport * as schema from "'+schema+'";\n\nconst pool = new Pool({\n  connectionString: '+conn+',\n});\n\nexport const db = drizzle(pool, { schema });';
    } else if(driver === "neon"){
      return 'import { drizzle } from "drizzle-orm/neon-http";\nimport { neon } from "@neondatabase/serverless";\nimport * as schema from "'+schema+'";\n\nconst sql = neon('+conn+');\nexport const db = drizzle(sql, { schema });';
    } else if(driver === "postgres-js"){
      return 'import { drizzle } from "drizzle-orm/postgres-js";\nimport postgres from "postgres";\nimport * as schema from "'+schema+'";\n\nconst client = postgres('+conn+');\nexport const db = drizzle(client, { schema });';
    } else if(driver === "vercel-pg"){
      return 'import { drizzle } from "drizzle-orm/vercel-postgres";\nimport { sql } from "@vercel/postgres";\nimport * as schema from "'+schema+'";\n\nexport const db = drizzle(sql, { schema });';
    } else if(driver === "mysql2"){
      return 'import { drizzle } from "drizzle-orm/mysql2";\nimport mysql from "mysql2/promise";\nimport * as schema from "'+schema+'";\n\nconst connection = await mysql.createConnection('+conn+');\nexport const db = drizzle(connection, { schema, mode: "default" });';
    } else if(driver === "planetscale"){
      return 'import { drizzle } from "drizzle-orm/planetscale-serverless";\nimport { connect } from "@planetscale/database";\nimport * as schema from "'+schema+'";\n\nconst connection = connect({ url: '+conn+' });\nexport const db = drizzle(connection, { schema });';
    } else if(driver === "better-sqlite3"){
      return 'import { drizzle } from "drizzle-orm/better-sqlite3";\nimport Database from "better-sqlite3";\nimport * as schema from "'+schema+'";\n\nconst sqlite = new Database("'+conn+'");\nexport const db = drizzle(sqlite, { schema });';
    } else if(driver === "turso"){
      return 'import { drizzle } from "drizzle-orm/libsql";\nimport { createClient } from "@libsql/client";\nimport * as schema from "'+schema+'";\n\nconst client = createClient({\n  url: '+conn+',\n  authToken: process.env.TURSO_AUTH_TOKEN,\n});\nexport const db = drizzle(client, { schema });';
    } else if(driver === "bun-sqlite"){
      return 'import { drizzle } from "drizzle-orm/bun-sqlite";\nimport { Database } from "bun:sqlite";\nimport * as schema from "'+schema+'";\n\nconst sqlite = new Database("'+conn+'");\nexport const db = drizzle(sqlite, { schema });';
    }
    return "// Select a driver to generate db/index.ts";
  }

  function generate(){
    var out = activeTab === "config" ? genConfig() : activeTab === "schema" ? genSchema() : genDbIndex();
    document.getElementById("code-output").textContent = out;
    var labels = { config: "drizzle.config.ts", schema: "schema.ts (starter)", db: "db/index.ts" };
    document.getElementById("tab-label").textContent = labels[activeTab] || "";
    var driver = getDriver();
    var inst = INSTALLS[driver] || "npm install drizzle-orm\nnpm install -D drizzle-kit";
    document.getElementById("install-output").textContent = inst;
  }

  // Tabs
  document.querySelectorAll(".tab-btn").forEach(function(btn){
    btn.addEventListener("click", function(){
      activeTab = btn.dataset.tab;
      document.querySelectorAll(".tab-btn").forEach(function(b){
        b.className = b === btn
          ? "tab-btn px-3 py-1.5 text-xs rounded font-medium transition-colors bg-primary text-white"
          : "tab-btn px-3 py-1.5 text-xs rounded font-medium transition-colors bg-surface border border-border text-text-muted hover:border-primary";
      });
      generate();
    });
  });

  function activateTab(tab){
    document.querySelectorAll(".tab-btn").forEach(function(b){
      b.className = b.dataset.tab === tab
        ? "tab-btn px-3 py-1.5 text-xs rounded font-medium transition-colors bg-primary text-white"
        : "tab-btn px-3 py-1.5 text-xs rounded font-medium transition-colors bg-surface border border-border text-text-muted hover:border-primary";
    });
  }

  document.getElementById("copy-out").onclick = function(){
    navigator.clipboard.writeText(document.getElementById("code-output").textContent).then(function(){
      var b = document.getElementById("copy-out"); b.textContent="Copied!"; setTimeout(function(){b.textContent="Copy";},1500);
    });
  };
  document.getElementById("copy-install").onclick = function(){
    navigator.clipboard.writeText(document.getElementById("install-output").textContent).then(function(){
      var b = document.getElementById("copy-install"); b.textContent="Copied!"; setTimeout(function(){b.textContent="Copy";},1500);
    });
  };

  document.getElementById("sel-db").onchange = updateDrivers;
  document.getElementById("sel-driver").onchange = function(){ updateDefaultConn(); generate(); };
  document.getElementById("conn-str").oninput = generate;
  document.getElementById("schema-path").oninput = generate;
  document.getElementById("migrations-dir").oninput = generate;

  // Init
  updateDrivers();
  activateTab("config");
  generate();
})();
</script>
