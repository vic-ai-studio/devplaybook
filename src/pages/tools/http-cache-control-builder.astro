---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HttpCacheHeadersGenerator from '../../components/HttpCacheHeadersGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the Cache-Control header and what directives can it contain?",
    answer: "Cache-Control is an HTTP header that controls how browsers, CDNs, and proxies cache responses. Key directives: max-age=N (cache for N seconds), s-maxage=N (CDN-only override for max-age), no-cache (cache but revalidate every request), no-store (never cache), private (browser only, no CDN), public (shareable caches allowed), immutable (file won't change — skip revalidation), must-revalidate (don't use stale content), stale-while-revalidate=N (serve stale for N seconds while fetching fresh in background)."
  },
  {
    question: "What is the difference between no-cache and no-store?",
    answer: "no-cache means 'cache the response, but always revalidate before using it.' The browser stores the response and sends a conditional request (If-None-Match or If-Modified-Since). If the server returns 304 Not Modified, the cached version is used at zero data transfer cost. no-store means 'never save this response anywhere.' Every request fetches a completely fresh copy. Use no-store for sensitive data (bank statements, private health records). Use no-cache for HTML pages that need to stay fresh but can benefit from 304 conditional requests."
  },
  {
    question: "When should I use the immutable directive?",
    answer: "Use immutable for assets with content-hashed URLs like bundle.a3f9c1.js or styles.8e7d2b.css. These files never change at a given URL — the filename changes when content changes. immutable tells browsers to never revalidate even on reload (Ctrl+F5). Combined with max-age=31536000 (1 year), this eliminates all network requests for cached assets on repeat visits, dramatically improving performance."
  },
  {
    question: "What is stale-while-revalidate and how does it improve performance?",
    answer: "stale-while-revalidate=N allows serving a stale (expired) cached response for N seconds while fetching a fresh copy in the background. This eliminates the latency spike that occurs when a cache entry expires — users always get an instant response, and the cache is updated asynchronously. Pattern: Cache-Control: max-age=60, stale-while-revalidate=300 — serve fresh for 60 seconds, serve stale for 5 more minutes while refreshing. Widely supported in modern browsers and CDNs like Cloudflare."
  },
  {
    question: "What is the difference between private and public?",
    answer: "public means the response can be stored by any cache — browser, CDN, or intermediary proxy. Use this for static assets that are the same for all users. private means only the user's own browser can cache it — CDNs must not store it. Use private for authenticated responses that contain user-specific data. If you omit both, the cache behavior is heuristic-based and inconsistent across implementations — always set one explicitly."
  },
  {
    question: "How do ETags work with Cache-Control?",
    answer: "An ETag is a fingerprint of the response content (usually a hash or timestamp). When a cached response expires, the browser sends the ETag in an If-None-Match request header. If the content hasn't changed, the server responds with 304 Not Modified and no body — saving bandwidth. ETags work alongside Cache-Control: no-cache for HTML pages: the page is always revalidated, but if nothing changed, the revalidation costs only a round trip with no data transfer."
  },
];
---

<BaseLayout
  title="HTTP Cache-Control Builder — Generate Cache-Control Headers with Explanations"
  description="Visual builder for HTTP Cache-Control headers. Choose resource type, caching strategy, max-age, CDN directives, stale-while-revalidate, and more. Get the complete header string with plain-English explanation."
  tool="Cache-Control Builder, HTTP Cache Header Generator, Cache-Control Generator, HTTP Caching Tool"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "HTTP Cache-Control Builder",
    "url": "https://devplaybook.cc/tools/http-cache-control-builder",
    "description": "Visual builder for HTTP Cache-Control headers. Select resource type and caching strategy to generate the correct Cache-Control directive string with explanations.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">HTTP Cache-Control Builder</h1>
  <p class="text-text-muted mb-4">
    Build the right <code class="font-mono bg-surface px-1 rounded text-sm">Cache-Control</code> header for any resource type.
    Choose your caching strategy — HTML pages, hashed JS/CSS, API responses, images — and get the complete directive string
    with plain-English explanations for every directive included.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Resource-type presets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CDN + browser directives</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <HttpCacheHeadersGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="HTTP Cache-Control Builder" relatedTags={['http', 'performance', 'caching', 'cdn', 'developer-tools']} />
</BaseLayout>
