---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is app.json / app.config.js in Expo?", answer: "app.json is the static configuration file for Expo projects. It defines your app's name, version, icons, splash screen, permissions, and platform-specific settings. app.config.js is the dynamic version — it's a JavaScript file that exports a config object, allowing environment variables, conditional logic, and dynamic values at build time." },
  { question: "When should I use app.config.js instead of app.json?", answer: "Use app.config.js when you need: (1) environment-specific configs (dev/staging/prod), (2) secrets from environment variables rather than checked-in files, (3) dynamic version numbers from package.json, or (4) conditional feature flags. app.json is simpler and sufficient for static projects." },
  { question: "What are Expo plugins?", answer: "Expo plugins (config plugins) are functions that modify your native app configuration during the prebuild/EAS Build process. They let packages like expo-camera, expo-notifications, and expo-location add required native code, permissions, and entitlements automatically. You list them in the 'plugins' array. Most popular packages include their own config plugin." },
  { question: "What permissions do I need for common features?", answer: "Camera: NSCameraUsageDescription (iOS) + android.permission.CAMERA. Location: NSLocationWhenInUseUsageDescription + android.permission.ACCESS_FINE_LOCATION. Notifications: no extra permissions needed on iOS (requested at runtime). Microphone: NSMicrophoneUsageDescription + android.permission.RECORD_AUDIO. Contacts: NSContactsUsageDescription + android.permission.READ_CONTACTS." },
  { question: "What is EAS Build and how does it use app.config.js?", answer: "EAS Build is Expo's cloud build service. It reads your app.config.js at build time, applies config plugins to generate native code (android/, ios/ folders), then builds the APK/IPA. You can use process.env variables in app.config.js to inject different values per environment — set them in eas.json or as EAS secrets. This is the recommended way to manage build-time configuration." },
];
---

<BaseLayout
  title="Expo App Config Generator — Visual Builder for app.json / app.config.js"
  description="Generate Expo app.json and app.config.js configuration with a visual form. Set icons, permissions, plugins, and splash screens. Copy-ready for React Native Expo projects."
  tool="Expo app config generator, app.json builder, app.config.js generator, Expo permissions, React Native app config, EAS Build config"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Expo App Config Generator</h1>
  <p class="text-text-muted mb-4">Build your Expo <code class="bg-bg-card px-1.5 py-0.5 rounded text-sm">app.json</code> or <code class="bg-bg-card px-1.5 py-0.5 rounded text-sm">app.config.js</code> visually. Configure app metadata, permissions, plugins, and more.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> app.json + app.config.js</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> iOS + Android permissions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Config plugins</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> EAS Build ready</span>
  </div>

  <div class="space-y-5">
    <!-- Output format -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="font-semibold mb-3">Output Format</h2>
      <div class="flex gap-4">
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="output-format" value="json" id="fmt-json" checked class="accent-primary" />
          <span class="text-sm font-medium">app.json <span class="text-text-muted">(static)</span></span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="output-format" value="js" id="fmt-js" class="accent-primary" />
          <span class="text-sm font-medium">app.config.js <span class="text-text-muted">(dynamic, env vars)</span></span>
        </label>
      </div>
    </div>

    <!-- App basics -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="font-semibold mb-4">App Information</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm text-text-muted mb-1" for="app-name">App Name</label>
          <input id="app-name" type="text" value="My App" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
        </div>
        <div>
          <label class="block text-sm text-text-muted mb-1" for="app-slug">Slug</label>
          <input id="app-slug" type="text" value="my-app" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
        </div>
        <div>
          <label class="block text-sm text-text-muted mb-1" for="app-version">Version</label>
          <input id="app-version" type="text" value="1.0.0" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
        </div>
        <div>
          <label class="block text-sm text-text-muted mb-1" for="sdk-version">SDK Version</label>
          <select id="sdk-version" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40">
            <option value="52.0.0">SDK 52 (latest)</option>
            <option value="51.0.0">SDK 51</option>
            <option value="50.0.0">SDK 50</option>
          </select>
        </div>
        <div>
          <label class="block text-sm text-text-muted mb-1" for="bundle-id">iOS Bundle ID</label>
          <input id="bundle-id" type="text" value="com.yourcompany.myapp" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
        </div>
        <div>
          <label class="block text-sm text-text-muted mb-1" for="package-name">Android Package</label>
          <input id="package-name" type="text" value="com.yourcompany.myapp" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
        </div>
      </div>
    </div>

    <!-- Permissions -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="font-semibold mb-4">Permissions & Features</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3" id="permissions-grid"></div>
    </div>

    <!-- Plugins -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="font-semibold mb-4">Config Plugins</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3" id="plugins-grid"></div>
    </div>

    <!-- Generated output -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="font-semibold" id="output-title">app.json</h2>
        <button id="copy-btn" class="text-xs bg-bg border border-border px-3 py-1.5 rounded-lg hover:border-primary hover:text-primary transition-colors">Copy</button>
      </div>
      <pre id="output" class="bg-bg rounded-lg p-4 text-xs font-mono overflow-x-auto text-green-400 whitespace-pre max-h-96 overflow-y-auto"></pre>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Expo App Config Generator" relatedTags={['expo', 'react-native', 'mobile', 'javascript', 'ios', 'android']} />
</BaseLayout>

<script is:inline>
(function () {
  var PERMISSIONS = [
    { id: 'camera', label: 'Camera', ios: 'NSCameraUsageDescription', android: 'CAMERA', desc: 'Take photos and record video' },
    { id: 'location', label: 'Location', ios: 'NSLocationWhenInUseUsageDescription', android: 'ACCESS_FINE_LOCATION', desc: 'GPS location access' },
    { id: 'mic', label: 'Microphone', ios: 'NSMicrophoneUsageDescription', android: 'RECORD_AUDIO', desc: 'Voice recording' },
    { id: 'contacts', label: 'Contacts', ios: 'NSContactsUsageDescription', android: 'READ_CONTACTS', desc: 'Access device contacts' },
    { id: 'photos', label: 'Photo Library', ios: 'NSPhotoLibraryUsageDescription', android: 'READ_MEDIA_IMAGES', desc: 'Access saved photos' },
    { id: 'notifications', label: 'Notifications', ios: null, android: 'RECEIVE_BOOT_COMPLETED', desc: 'Push notifications' },
    { id: 'bluetooth', label: 'Bluetooth', ios: 'NSBluetoothAlwaysUsageDescription', android: 'BLUETOOTH', desc: 'BLE device connectivity' },
    { id: 'faceid', label: 'Face ID', ios: 'NSFaceIDUsageDescription', android: null, desc: 'Biometric authentication (iOS)' },
  ];

  var PLUGINS = [
    { id: 'expo-camera', label: 'expo-camera' },
    { id: 'expo-location', label: 'expo-location' },
    { id: 'expo-notifications', label: 'expo-notifications' },
    { id: 'expo-image-picker', label: 'expo-image-picker' },
    { id: 'expo-av', label: 'expo-av' },
    { id: 'expo-contacts', label: 'expo-contacts' },
    { id: 'expo-local-authentication', label: 'expo-local-auth' },
    { id: 'expo-maps', label: 'expo-maps' },
    { id: 'expo-in-app-purchases', label: 'expo-iap' },
  ];

  var selectedPerms = new Set();
  var selectedPlugins = new Set();

  var permGrid = document.getElementById('permissions-grid');
  var pluginGrid = document.getElementById('plugins-grid');
  var output = document.getElementById('output');
  var copyBtn = document.getElementById('copy-btn');
  var outputTitle = document.getElementById('output-title');

  function renderPermissions() {
    permGrid.innerHTML = PERMISSIONS.map(function (p) {
      var active = selectedPerms.has(p.id);
      return '<label class="flex items-start gap-3 p-3 border border-border rounded-lg cursor-pointer hover:border-primary/50 ' + (active ? 'border-primary/50 bg-primary/5' : 'bg-bg') + '">' +
        '<input type="checkbox" class="perm-check mt-0.5 accent-primary" data-id="' + p.id + '"' + (active ? ' checked' : '') + ' />' +
        '<div><div class="text-sm font-medium">' + p.label + '</div><div class="text-xs text-text-muted">' + p.desc + '</div></div>' +
        '</label>';
    }).join('');
    permGrid.querySelectorAll('.perm-check').forEach(function (cb) {
      cb.addEventListener('change', function () {
        if (cb.checked) selectedPerms.add(cb.dataset.id); else selectedPerms.delete(cb.dataset.id);
        renderPermissions(); updateOutput();
      });
    });
  }

  function renderPlugins() {
    pluginGrid.innerHTML = PLUGINS.map(function (p) {
      var active = selectedPlugins.has(p.id);
      return '<label class="flex items-center gap-2 p-2.5 border border-border rounded-lg cursor-pointer hover:border-primary/50 text-sm ' + (active ? 'border-primary/50 bg-primary/5 text-primary' : 'bg-bg') + '">' +
        '<input type="checkbox" class="plugin-check accent-primary" data-id="' + p.id + '"' + (active ? ' checked' : '') + ' />' +
        p.label +
        '</label>';
    }).join('');
    pluginGrid.querySelectorAll('.plugin-check').forEach(function (cb) {
      cb.addEventListener('change', function () {
        if (cb.checked) selectedPlugins.add(cb.dataset.id); else selectedPlugins.delete(cb.dataset.id);
        renderPlugins(); updateOutput();
      });
    });
  }

  function getIosPerms() {
    var perms = {};
    selectedPerms.forEach(function (id) {
      var p = PERMISSIONS.find(function (x) { return x.id === id; });
      if (p && p.ios) perms[p.ios] = 'This app requires ' + p.label.toLowerCase() + ' access.';
    });
    return perms;
  }

  function getAndroidPerms() {
    var perms = [];
    selectedPerms.forEach(function (id) {
      var p = PERMISSIONS.find(function (x) { return x.id === id; });
      if (p && p.android) perms.push('android.permission.' + p.android);
    });
    return perms;
  }

  function buildConfig() {
    var name = document.getElementById('app-name').value || 'My App';
    var slug = document.getElementById('app-slug').value || 'my-app';
    var version = document.getElementById('app-version').value || '1.0.0';
    var sdk = document.getElementById('sdk-version').value;
    var bundleId = document.getElementById('bundle-id').value || 'com.yourcompany.myapp';
    var packageName = document.getElementById('package-name').value || 'com.yourcompany.myapp';
    var iosPerms = getIosPerms();
    var androidPerms = getAndroidPerms();
    var plugins = Array.from(selectedPlugins);

    var config = {
      expo: {
        name: name,
        slug: slug,
        version: version,
        sdkVersion: sdk,
        orientation: 'portrait',
        icon: './assets/icon.png',
        userInterfaceStyle: 'automatic',
        splash: {
          image: './assets/splash-icon.png',
          resizeMode: 'contain',
          backgroundColor: '#ffffff'
        },
        ios: {
          supportsTablet: true,
          bundleIdentifier: bundleId,
        },
        android: {
          adaptiveIcon: {
            foregroundImage: './assets/adaptive-icon.png',
            backgroundColor: '#ffffff'
          },
          package: packageName,
        },
        web: {
          favicon: './assets/favicon.png'
        }
      }
    };

    if (Object.keys(iosPerms).length) config.expo.ios.infoPlist = iosPerms;
    if (androidPerms.length) config.expo.android.permissions = androidPerms;
    if (plugins.length) config.expo.plugins = plugins;

    return config;
  }

  function updateOutput() {
    var isJs = document.getElementById('fmt-js').checked;
    outputTitle.textContent = isJs ? 'app.config.js' : 'app.json';
    var cfg = buildConfig();
    var cfgStr = JSON.stringify(cfg, null, 2);

    if (isJs) {
      output.textContent =
        '// app.config.js\nexport default ({ config }) => ({\n' +
        '  ...config,\n' +
        '  name: process.env.APP_NAME ?? ' + JSON.stringify(cfg.expo.name) + ',\n' +
        '  version: process.env.APP_VERSION ?? ' + JSON.stringify(cfg.expo.version) + ',\n' +
        '  extra: {\n' +
        '    apiUrl: process.env.API_URL ?? "https://api.example.com",\n' +
        '    environment: process.env.APP_ENV ?? "development",\n' +
        '  },\n' +
        '  // Full config:\n' +
        '  ...(' + cfgStr.replace(/^/, '').split('\n').map(function (l, i) { return i === 0 ? l : '  ' + l; }).join('\n') + ').expo,\n' +
        '});';
    } else {
      output.textContent = cfgStr;
    }
  }

  document.querySelectorAll('input[name="output-format"]').forEach(function (r) { r.addEventListener('change', updateOutput); });
  ['app-name', 'app-slug', 'app-version', 'sdk-version', 'bundle-id', 'package-name'].forEach(function (id) {
    document.getElementById(id).addEventListener('input', updateOutput);
  });

  copyBtn.addEventListener('click', function () {
    navigator.clipboard.writeText(output.textContent).then(function () {
      copyBtn.textContent = 'Copied!'; setTimeout(function () { copyBtn.textContent = 'Copy'; }, 2000);
    });
  });

  // Init
  selectedPlugins.add('expo-notifications');
  selectedPerms.add('notifications');
  renderPermissions();
  renderPlugins();
  updateOutput();
})();
</script>
