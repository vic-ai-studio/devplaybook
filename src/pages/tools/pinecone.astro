---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Pinecone and why use it for AI?",
    answer: "Pinecone is a fully managed vector database designed for AI applications. Unlike general-purpose databases, it stores and retrieves high-dimensional embedding vectors efficiently using approximate nearest neighbor (ANN) algorithms. It handles infrastructure, scaling, and index management so you can focus on building RAG pipelines, semantic search, and recommendation systems without ops overhead."
  },
  {
    question: "What is the difference between Pinecone serverless and pod-based indexes?",
    answer: "Serverless indexes (introduced 2024) auto-scale with zero idle cost — you pay per read/write unit. They suit variable or unpredictable workloads. Pod-based indexes run on dedicated compute pods (s1, p1, p2 types) with predictable latency and throughput, suited for high-QPS production workloads. Serverless is the recommended default for new projects."
  },
  {
    question: "What are Pinecone namespaces?",
    answer: "Namespaces let you partition vectors within a single index into isolated segments. Each upsert and query can target a specific namespace, so different tenants or datasets share infrastructure without data leaking between them. This is the primary multi-tenancy mechanism in Pinecone — queries only search within the namespace you specify."
  },
  {
    question: "How does metadata filtering work in Pinecone?",
    answer: "When you upsert vectors, you attach a JSON metadata object to each vector (e.g., {source: 'blog', date: '2024-01-01', category: 'tech'}). At query time, you pass a filter dict alongside the embedding vector. Pinecone pre-filters by metadata before running ANN search, so only matching vectors are candidates. This enables hybrid search without sacrificing speed."
  },
  {
    question: "How does Pinecone compare to Weaviate, Qdrant, and pgvector?",
    answer: "Pinecone is fully managed with zero infrastructure work, best for teams wanting fast time-to-production. Weaviate and Qdrant are open-source and self-hostable — more control, lower long-term cost at scale, but require DevOps. pgvector sits inside PostgreSQL, ideal if you already use Postgres and want SQL joins with vector search. Pinecone wins on simplicity; Qdrant on performance-per-dollar self-hosted; pgvector on SQL integration."
  },
  {
    question: "What embedding dimension should I use with Pinecone?",
    answer: "Your Pinecone index dimension must exactly match your embedding model's output. OpenAI text-embedding-3-small outputs 1536 dims by default (or configurable down to 512). text-embedding-3-large outputs 3072. Cohere embed-v3 outputs 1024. Set the dimension once at index creation — you cannot change it later without recreating the index."
  },
];
---

<BaseLayout
  title="Pinecone: Managed Vector Database for AI Applications"
  description="Complete guide to Pinecone vector database — serverless vs pod indexes, upsert/query/fetch operations, metadata filtering, namespaces, Python SDK examples, and Pinecone vs Weaviate vs Qdrant vs pgvector comparison."
  tool="Pinecone, vector database, similarity search, AI embeddings, managed vector DB"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"Pinecone: Managed Vector Database for AI Applications","url":"https://devplaybook.cc/tools/pinecone","description":"Complete guide to Pinecone vector database — serverless vs pod indexes, upsert/query/fetch, metadata filtering, namespaces, and SDK examples."})} />

  <h1 class="text-3xl font-bold mb-2">Pinecone: Managed Vector Database for AI Applications</h1>
  <p class="text-text-muted mb-6">Pinecone is the leading managed vector database for AI applications. It stores high-dimensional embedding vectors and returns the most semantically similar results in milliseconds — powering RAG pipelines, semantic search, recommendation engines, and duplicate detection at any scale.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Serverless &amp; pod-based indexes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Metadata filtering</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Namespace multi-tenancy</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Python &amp; Node SDKs</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100M+ vectors at scale</span>
  </div>

  <ToolPageCta />

  <!-- Getting Started -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">Getting Started with Pinecone</h2>
    <p class="text-text-muted mb-4">Install the Python SDK and create your first serverless index in under five minutes.</p>
    <pre class="bg-bg-card border border-border rounded-xl p-4 text-sm font-mono overflow-x-auto mb-4"><code class="text-green-400"># Install the Pinecone Python SDK
pip install pinecone

# Initialize the client
from pinecone import Pinecone, ServerlessSpec

pc = Pinecone(api_key="YOUR_API_KEY")

# Create a serverless index (dimension must match your embedding model)
pc.create_index(
    name="my-rag-index",
    dimension=1536,           # OpenAI text-embedding-3-small default
    metric="cosine",          # cosine | dotproduct | euclidean
    spec=ServerlessSpec(
        cloud="aws",
        region="us-east-1"
    )
)

index = pc.Index("my-rag-index")
print(index.describe_index_stats())</code></pre>
  </section>

  <!-- Upsert, Query, Fetch -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">Upsert, Query, and Fetch Operations</h2>
    <p class="text-text-muted mb-4">The three core operations: upsert vectors with metadata, query by similarity, and fetch by ID.</p>
    <pre class="bg-bg-card border border-border rounded-xl p-4 text-sm font-mono overflow-x-auto mb-4"><code class="text-green-400">import openai

client = openai.OpenAI()

# Generate embeddings
def embed(texts):
    resp = client.embeddings.create(
        model="text-embedding-3-small",
        input=texts
    )
    return [r.embedding for r in resp.data]

# Upsert vectors with metadata
docs = [
    &#123;"id": "doc-1", "text": "RAG systems retrieve context before generation", "category": "ai"&#125;,
    &#123;"id": "doc-2", "text": "Pinecone supports real-time upserts", "category": "database"&#125;,
]
embeddings = embed([d["text"] for d in docs])

vectors = [
    &#123;"id": d["id"], "values": emb, "metadata": &#123;"text": d["text"], "category": d["category"]&#125;&#125;
    for d, emb in zip(docs, embeddings)
]
index.upsert(vectors=vectors, namespace="production")

# Query: find top-3 similar vectors with metadata filter
query_emb = embed(["how does retrieval augmented generation work?"])[0]
results = index.query(
    vector=query_emb,
    top_k=3,
    namespace="production",
    filter=&#123;"category": &#123;"$eq": "ai"&#125;&#125;,   # metadata filter
    include_metadata=True
)

for match in results.matches:
    print(f"&#123;match.score:.4f&#125; | &#123;match.metadata['text']&#125;")

# Fetch by ID
fetched = index.fetch(ids=["doc-1"], namespace="production")
print(fetched.vectors["doc-1"].metadata)</code></pre>
  </section>

  <!-- Namespaces -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">Namespace-Based Multi-Tenancy</h2>
    <p class="text-text-muted mb-4">Use namespaces to isolate data between tenants or environments within a single index.</p>
    <pre class="bg-bg-card border border-border rounded-xl p-4 text-sm font-mono overflow-x-auto mb-4"><code class="text-green-400"># Upsert into separate namespaces per tenant
index.upsert(vectors=tenant_a_vectors, namespace="tenant-a")
index.upsert(vectors=tenant_b_vectors, namespace="tenant-b")

# Query is scoped to a single namespace — no cross-tenant leakage
results_a = index.query(vector=query_vec, top_k=5, namespace="tenant-a")
results_b = index.query(vector=query_vec, top_k=5, namespace="tenant-b")

# Delete all vectors for a tenant (data isolation for GDPR etc.)
index.delete(delete_all=True, namespace="tenant-a")

# Stats per namespace
stats = index.describe_index_stats()
for ns, ns_stats in stats.namespaces.items():
    print(f"&#123;ns&#125;: &#123;ns_stats.vector_count&#125; vectors")</code></pre>
  </section>

  <!-- Comparison Table -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">Pinecone vs Weaviate vs Qdrant vs pgvector</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm min-w-[640px]">
        <thead>
          <tr class="text-text-muted text-xs uppercase border-b border-border">
            <th class="text-left pb-3 pr-4 font-medium">Feature</th>
            <th class="text-left pb-3 pr-4 font-medium">Pinecone</th>
            <th class="text-left pb-3 pr-4 font-medium">Weaviate</th>
            <th class="text-left pb-3 pr-4 font-medium">Qdrant</th>
            <th class="text-left pb-3 font-medium">pgvector</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border text-text-muted">
          <tr><td class="py-3 pr-4 font-medium text-text">Hosting</td><td class="py-3 pr-4">Managed only</td><td class="py-3 pr-4">Self-host / Cloud</td><td class="py-3 pr-4">Self-host / Cloud</td><td class="py-3">PostgreSQL extension</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Setup effort</td><td class="py-3 pr-4 text-green-500">Minimal</td><td class="py-3 pr-4">Medium</td><td class="py-3 pr-4">Low</td><td class="py-3">Low (if using PG)</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Scaling</td><td class="py-3 pr-4">Automatic</td><td class="py-3 pr-4">Manual sharding</td><td class="py-3 pr-4">Manual / Cloud</td><td class="py-3">Postgres scaling</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Metadata filter</td><td class="py-3 pr-4">Yes</td><td class="py-3 pr-4">Yes (GraphQL)</td><td class="py-3 pr-4">Yes (payload)</td><td class="py-3">Yes (SQL WHERE)</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Hybrid search</td><td class="py-3 pr-4">Limited</td><td class="py-3 pr-4 text-green-500">BM25 + vector</td><td class="py-3 pr-4 text-green-500">Sparse + dense</td><td class="py-3">Manual</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Open source</td><td class="py-3 pr-4">No</td><td class="py-3 pr-4 text-green-500">Yes</td><td class="py-3 pr-4 text-green-500">Yes (Rust)</td><td class="py-3 text-green-500">Yes</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">SQL joins</td><td class="py-3 pr-4">No</td><td class="py-3 pr-4">No</td><td class="py-3 pr-4">No</td><td class="py-3 text-green-500">Yes</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Free tier</td><td class="py-3 pr-4">1 index / 100K vecs</td><td class="py-3 pr-4">Self-host free</td><td class="py-3 pr-4">Self-host free</td><td class="py-3">Free (OSS)</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Pinecone Vector Database Guide" relatedTags={['ai', 'vector-database', 'embeddings', 'rag', 'semantic-search', 'llm']} />
</BaseLayout>
