---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Evidently AI and what problem does it solve?", answer: "Evidently AI is an open-source library for evaluating, testing, and monitoring ML models and data pipelines. It solves the production ML problem: models degrade silently after deployment. Data distributions shift, feature correlations change, and prediction quality drops — but without monitoring, you only discover this when business KPIs decline. Evidently provides ready-to-use statistical tests and reports to detect these issues automatically." },
  { question: "What is data drift and how does Evidently detect it?", answer: "Data drift (also called covariate shift) occurs when the statistical distribution of input features changes between training and production. For example, user age distribution shifts after a product pivot, or sensor readings change after hardware replacement. Evidently uses statistical tests to detect drift: Kolmogorov-Smirnov for continuous features, chi-squared for categorical features, Population Stability Index (PSI), and Jensen-Shannon divergence. Each test returns a drift score and a binary drift/no-drift verdict." },
  { question: "What is the difference between data drift and concept drift?", answer: "Data drift (covariate shift) is when P(X) changes — input feature distributions change but the true relationship between features and target remains the same. Concept drift is when P(Y|X) changes — the relationship between inputs and the target changes, meaning the model's learned function is now wrong. Data drift can be detected without labels (just compare feature distributions). Concept drift requires ground truth labels and comparison of prediction quality metrics over time." },
  { question: "How do Evidently Test Suites differ from Reports?", answer: "Reports are exploratory documents with rich visualizations — use them for EDA, debugging, and communicating model quality. Test Suites are assertion-based: you define pass/fail conditions (e.g., 'drift share < 0.2' or 'mean prediction error < 0.05') and the suite returns a binary pass/fail result. Use Test Suites in CI/CD pipelines to automatically block deployments if data quality degrades below thresholds." },
  { question: "How do I use Evidently in a batch monitoring pipeline?", answer: "In a batch pipeline (daily or hourly), load the reference dataset (training data) and the current production batch, create an Evidently Report with your desired presets, and save the HTML report or JSON metrics. For alerting, use Test Suites: if any test fails, trigger an alert to Slack/PagerDuty. Evidently integrates with Airflow, Prefect, and MLflow for automated monitoring workflows." },
  { question: "What is Evidently Cloud?", answer: "Evidently Cloud is the managed version of Evidently with a web dashboard for tracking metrics over time, configuring alerts, and comparing monitoring snapshots. Unlike the open-source library (which generates static HTML reports), Evidently Cloud stores monitoring history, shows metric trend charts, and sends automated alerts when drift thresholds are exceeded. It is useful for teams that need persistent monitoring history without managing their own infrastructure." },
];
---

<BaseLayout
  title="Evidently AI: ML Model Monitoring, Drift Detection & Reports"
  description="Complete Evidently AI guide: DataDriftPreset, DataQualityPreset, Test Suites, production batch pipeline integration, data drift vs concept drift, and Evidently vs WhyLogs vs NannyML comparison."
  tool="Evidently AI, ML monitoring, data drift, model monitoring, production ML, DataDriftPreset, Test Suites, covariate shift"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"Evidently AI: ML Model Monitoring, Drift Detection & Reports","url":"https://devplaybook.cc/tools/evidently-ai","description":"Complete guide to Evidently AI for ML model monitoring, data drift detection, Test Suites, and production pipeline integration."})} />

  <h1 class="text-3xl font-bold mb-2">Evidently AI: ML Model Monitoring, Drift Detection &amp; Reports</h1>
  <p class="text-text-muted mb-6">Evidently is the open-source ML monitoring library for detecting data drift, monitoring model quality, and generating rich HTML reports. Catch silent model degradation before it affects your business — in batch pipelines or real-time streams.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Data drift detection (KS/chi-sq/PSI)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Pass/fail Test Suites for CI/CD</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> HTML &amp; JSON report generation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No labels required for drift detection</span>
  </div>

  <ToolPageCta />

  <!-- Basic reports -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-xl font-semibold mb-3">Generating Data Drift Reports</h2>
    <p class="text-sm text-text-muted mb-3">Install with <code class="bg-bg border border-border rounded px-1 text-xs">pip install evidently</code>. Compare a reference dataset against current production data:</p>
    <pre class="bg-bg border border-border rounded-lg p-4 text-xs overflow-x-auto mb-3"><code>import pandas as pd
from evidently.report import Report
from evidently.metric_preset import DataDriftPreset, DataQualityPreset
from evidently.metric_preset import ClassificationPreset, RegressionPreset

# Load reference (training) and current (production) data
reference_data = pd.read_csv("train_data.csv")
current_data = pd.read_csv("prod_data_last_24h.csv")

# Data drift report — detects feature distribution changes
drift_report = Report(metrics=[
    DataDriftPreset(drift_share_threshold=0.2),  # fail if >20% features drift
    DataQualityPreset(),                           # missing values, outliers, etc.
])

drift_report.run(
    reference_data=reference_data,
    current_data=current_data,
    column_mapping=None   # or specify target/prediction/datetime columns
)

# Save interactive HTML report
drift_report.save_html("drift_report.html")

# Extract metrics programmatically
result = drift_report.as_dict()
drift_share = result["metrics"][0]["result"]["share_of_drifted_columns"]
print(f"Drifted features: &#123;drift_share * 100:.1f&#125;%")

# Model quality report (requires ground truth labels)
quality_report = Report(metrics=[ClassificationPreset()])
quality_report.run(
    reference_data=reference_data,
    current_data=current_data.assign(prediction=model.predict(current_data)),
)
quality_report.save_html("quality_report.html")</code></pre>
  </div>

  <!-- Test Suites -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-xl font-semibold mb-3">Test Suites for CI/CD Monitoring Gates</h2>
    <p class="text-sm text-text-muted mb-3">Use Test Suites instead of Reports when you need pass/fail decisions in pipelines:</p>
    <pre class="bg-bg border border-border rounded-lg p-4 text-xs overflow-x-auto mb-3"><code>from evidently.test_suite import TestSuite
from evidently.tests import (
    TestShareOfDriftedColumns,
    TestNumberOfMissingValues,
    TestColumnDrift,
    TestMeanInNSigmas,
    TestShareOfOutRangeValues,
)

suite = TestSuite(tests=[
    # Fail if more than 20% of features drift
    TestShareOfDriftedColumns(lt=0.2),

    # Fail if missing values exceed 5%
    TestNumberOfMissingValues(lt=0.05),

    # Monitor specific high-impact features individually
    TestColumnDrift(column_name="user_age"),
    TestColumnDrift(column_name="purchase_value"),

    # Fail if mean prediction outside 3 sigma of reference
    TestMeanInNSigmas(column_name="prediction", n=3),

    # Fail if out-of-range values exceed 1%
    TestShareOfOutRangeValues(column_name="feature_score", lt=0.01),
])

suite.run(reference_data=reference_data, current_data=current_data)
suite.save_html("test_results.html")

# CI/CD gate: exit non-zero if any test fails
result = suite.as_dict()
all_passed = all(t["status"] == "SUCCESS" for t in result["tests"])
if not all_passed:
    failed = [t["name"] for t in result["tests"] if t["status"] != "SUCCESS"]
    print(f"FAILED tests: &#123;failed&#125;")
    raise SystemExit(1)</code></pre>
  </div>

  <!-- Pipeline integration -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-xl font-semibold mb-3">Batch Pipeline Integration (Airflow / Prefect)</h2>
    <p class="text-sm text-text-muted mb-3">Schedule Evidently monitoring as a daily batch job:</p>
    <pre class="bg-bg border border-border rounded-lg p-4 text-xs overflow-x-auto mb-3"><code>from airflow import DAG
from airflow.operators.python import PythonOperator
from datetime import datetime, timedelta
import pandas as pd
from evidently.report import Report
from evidently.metric_preset import DataDriftPreset

def run_monitoring(**context):
    ds = context["ds"]  # execution date

    # Load reference data from feature store
    reference = pd.read_parquet("s3://ml-bucket/reference/train_features.parquet")

    # Load yesterday's production data
    current = pd.read_parquet(f"s3://ml-bucket/prod/&#123;ds&#125;/features.parquet")

    report = Report(metrics=[DataDriftPreset(drift_share_threshold=0.15)])
    report.run(reference_data=reference, current_data=current)

    # Save report and metrics to S3
    report.save_html(f"/tmp/drift_report_&#123;ds&#125;.html")
    metrics = report.as_dict()

    drift_share = metrics["metrics"][0]["result"]["share_of_drifted_columns"]
    if drift_share > 0.15:
        send_slack_alert(f"[ALERT] Data drift detected: &#123;drift_share:.0%&#125; features drifted on &#123;ds&#125;")

with DAG("ml_monitoring", schedule_interval="0 6 * * *", start_date=datetime(2024, 1, 1)) as dag:
    monitor = PythonOperator(task_id="run_drift_monitoring", python_callable=run_monitoring)</code></pre>
  </div>

