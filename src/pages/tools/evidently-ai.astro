        <tbody class="divide-y divide-border text-text-muted">
          <tr><td class="py-2 pr-4 font-medium text-text">Open-source</td><td class="py-2 pr-4 text-green-500">Yes (Apache 2.0)</td><td class="py-2 pr-4 text-green-500">Yes (Apache 2.0)</td><td class="py-2 pr-4 text-green-500">Yes (Apache 2.0)</td><td class="py-2">No (SaaS)</td></tr>
          <tr><td class="py-2 pr-4 font-medium text-text">HTML reports</td><td class="py-2 pr-4 text-green-500">Rich interactive HTML</td><td class="py-2 pr-4">JSON profiles</td><td class="py-2 pr-4">Plots (matplotlib)</td><td class="py-2">Cloud dashboard</td></tr>
          <tr><td class="py-2 pr-4 font-medium text-text">No-label drift detection</td><td class="py-2 pr-4 text-green-500">Yes</td><td class="py-2 pr-4 text-green-500">Yes</td><td class="py-2 pr-4 text-green-500">Yes (CBPE)</td><td class="py-2 text-green-500">Yes</td></tr>
          <tr><td class="py-2 pr-4 font-medium text-text">CI/CD test suites</td><td class="py-2 pr-4 text-green-500">Built-in TestSuite</td><td class="py-2 pr-4">whylabs integration</td><td class="py-2 pr-4">No</td><td class="py-2">No (SaaS alerts)</td></tr>
          <tr><td class="py-2 pr-4 font-medium text-text">Streaming support</td><td class="py-2 pr-4">Batch + window</td><td class="py-2 pr-4 text-green-500">Low-overhead logging</td><td class="py-2 pr-4">Batch only</td><td class="py-2 text-green-500">Real-time</td></tr>
          <tr><td class="py-2 pr-4 font-medium text-text">Best for</td><td class="py-2 pr-4">Batch monitoring, reports</td><td class="py-2 pr-4">Lightweight logging</td><td class="py-2 pr-4">Perf estimation</td><td class="py-2">Enterprise platform</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <FaqSection faq={faq} />
</BaseLayout>
