---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Uptime Monitor Config Generator — UptimeRobot, Better Uptime & Pingdom"
  description="Generate uptime monitoring configurations for UptimeRobot, Better Uptime, and Pingdom. Set check intervals, alert thresholds, notification channels, and HTTP options."
  tool="uptime monitor config, UptimeRobot config, Better Uptime, Pingdom config, website monitoring, uptime checker"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Uptime Monitor Config Generator",
    "url": "https://devplaybook.cc/tools/uptime-monitor-config",
    "description": "Generate uptime monitoring configurations for UptimeRobot, Better Uptime, and Pingdom. Set check intervals, alert thresholds, notification channels, and HTTP options.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Uptime Monitor Config Generator</h1>
  <p class="text-text-muted mb-4">
    Generate ready-to-use monitoring configurations for UptimeRobot, Better Uptime, and Pingdom.
    Configure check intervals, alert thresholds, notification channels, and HTTP options — export as JSON or YAML.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> UptimeRobot / Better Uptime / Pingdom</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> HTTP, TCP, Ping, Keyword</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Slack, PagerDuty, Discord, Webhook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <!-- Form -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
    <div>
      <label class="block text-sm font-medium mb-2" for="um-name">Monitor Name</label>
      <input id="um-name" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="e.g. My App Health Check" />
    </div>
    <div>
      <label class="block text-sm font-medium mb-2" for="um-url">URL to Monitor</label>
      <input id="um-url" type="url" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="https://example.com/health" />
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4">
    <div>
      <label class="block text-sm font-medium mb-2" for="um-type">Monitor Type</label>
      <select id="um-type" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
        <option value="http">HTTP/HTTPS</option>
        <option value="tcp">TCP Port</option>
        <option value="ping">Ping</option>
        <option value="keyword">Keyword Match</option>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium mb-2" for="um-interval">Check Interval</label>
      <select id="um-interval" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
        <option value="60">1 minute</option>
        <option value="120">2 minutes</option>
        <option value="300" selected>5 minutes</option>
        <option value="600">10 minutes</option>
        <option value="900">15 minutes</option>
        <option value="1800">30 minutes</option>
        <option value="3600">1 hour</option>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium mb-2" for="um-threshold">Alert After X Failures</label>
      <select id="um-threshold" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
        <option value="1">1 failure</option>
        <option value="2" selected>2 failures</option>
        <option value="3">3 failures</option>
      </select>
    </div>
  </div>

  <!-- Notification Channels -->
  <div class="mb-4">
    <label class="block text-sm font-medium mb-3">Notification Channels</label>
    <div class="flex flex-wrap gap-4">
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <input type="checkbox" id="ch-email" class="rounded" checked /> Email
      </label>
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <input type="checkbox" id="ch-slack" class="rounded" /> Slack
      </label>
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <input type="checkbox" id="ch-pagerduty" class="rounded" /> PagerDuty
      </label>
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <input type="checkbox" id="ch-sms" class="rounded" /> SMS
      </label>
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <input type="checkbox" id="ch-discord" class="rounded" /> Discord
      </label>
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <input type="checkbox" id="ch-webhook" class="rounded" /> Webhook
      </label>
    </div>
  </div>

  <!-- Webhook URL (conditional) -->
  <div id="webhook-url-row" class="mb-4 hidden">
    <label class="block text-sm font-medium mb-2" for="um-webhook-url">Webhook URL</label>
    <input id="um-webhook-url" type="url" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="https://hooks.example.com/alerts/uptime" />
  </div>

  <!-- HTTP Options (conditional) -->
  <div id="http-options" class="mb-4">
    <div class="border border-border rounded-lg p-4 bg-surface">
      <p class="text-sm font-medium mb-3 text-text-muted">HTTP Options</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-3">
        <div>
          <label class="block text-sm font-medium mb-2" for="um-status-code">Expected Status Code</label>
          <input id="um-status-code" type="number" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="200" value="200" />
        </div>
        <!-- Keyword field (shown for keyword type) -->
        <div id="keyword-field">
          <label class="block text-sm font-medium mb-2" for="um-keyword">Keyword to Match</label>
          <input id="um-keyword" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder='e.g. "status":"ok"' />
        </div>
      </div>
      <div class="flex flex-wrap gap-4">
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="um-follow-redirects" class="rounded" checked /> Follow Redirects
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="um-ssl-check" class="rounded" checked /> SSL Certificate Check
        </label>
      </div>
    </div>
  </div>

  <div class="flex gap-3 mb-6 flex-wrap">
    <button id="btn-generate" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Generate Config</button>
    <button id="btn-example-api" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">API Health Example</button>
    <button id="btn-example-tcp" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">TCP Port Example</button>
  </div>

  <!-- Output Tabs -->
  <div id="output-section" class="hidden">
    <div class="flex gap-1 mb-4 border-b border-border flex-wrap">
      <button data-tab="uptimerobot" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-primary text-primary transition-colors">UptimeRobot JSON</button>
      <button data-tab="betteruptime" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-foreground transition-colors">Better Uptime JSON</button>
      <button data-tab="pingdom" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-foreground transition-colors">Pingdom API JSON</button>
      <button data-tab="yaml" class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-foreground transition-colors">Generic YAML</button>
    </div>

    <!-- UptimeRobot panel -->
    <div id="tab-uptimerobot" class="tab-panel bg-bg-card border border-border rounded-lg p-4">
      <div class="flex justify-end mb-2">
        <button class="copy-btn px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-target="out-uptimerobot">Copy</button>
      </div>
      <pre id="out-uptimerobot" class="font-mono text-sm whitespace-pre-wrap break-words overflow-x-auto max-h-[500px] overflow-y-auto text-green-300"></pre>
    </div>

    <!-- Better Uptime panel -->
    <div id="tab-betteruptime" class="tab-panel hidden bg-bg-card border border-border rounded-lg p-4">
      <div class="flex justify-end mb-2">
        <button class="copy-btn px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-target="out-betteruptime">Copy</button>
      </div>
      <pre id="out-betteruptime" class="font-mono text-sm whitespace-pre-wrap break-words overflow-x-auto max-h-[500px] overflow-y-auto text-blue-300"></pre>
    </div>

    <!-- Pingdom panel -->
    <div id="tab-pingdom" class="tab-panel hidden bg-bg-card border border-border rounded-lg p-4">
      <div class="flex justify-end mb-2">
        <button class="copy-btn px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-target="out-pingdom">Copy</button>
      </div>
      <pre id="out-pingdom" class="font-mono text-sm whitespace-pre-wrap break-words overflow-x-auto max-h-[500px] overflow-y-auto text-yellow-300"></pre>
    </div>

    <!-- YAML panel -->
    <div id="tab-yaml" class="tab-panel hidden bg-bg-card border border-border rounded-lg p-4">
      <div class="flex justify-end mb-2">
        <button class="copy-btn px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-target="out-yaml">Copy</button>
      </div>
      <pre id="out-yaml" class="font-mono text-sm whitespace-pre-wrap break-words overflow-x-auto max-h-[500px] overflow-y-auto text-text-muted"></pre>
    </div>
  </div>

  <ToolPageCta />
</BaseLayout>

<script is:inline>
  // ---- UI wiring ----
  var activeTab = 'uptimerobot';

  document.getElementById('ch-webhook').addEventListener('change', function() {
    document.getElementById('webhook-url-row').classList.toggle('hidden', !this.checked);
  });

  document.getElementById('um-type').addEventListener('change', function() {
    var isHttp = this.value === 'http' || this.value === 'keyword';
    document.getElementById('http-options').classList.toggle('hidden', !isHttp && this.value !== 'keyword' && isHttp === false);
    document.getElementById('keyword-field').classList.toggle('hidden', this.value !== 'keyword');
    // show http-options for http and keyword, hide for tcp/ping
    var showHttp = (this.value === 'http' || this.value === 'keyword');
    document.getElementById('http-options').classList.toggle('hidden', !showHttp);
  });

  // Tab switching
  document.querySelectorAll('.tab-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tab = this.getAttribute('data-tab');
      activeTab = tab;
      document.querySelectorAll('.tab-btn').forEach(function(b) {
        b.classList.remove('border-primary', 'text-primary');
        b.classList.add('border-transparent', 'text-text-muted');
      });
      this.classList.add('border-primary', 'text-primary');
      this.classList.remove('border-transparent', 'text-text-muted');
      document.querySelectorAll('.tab-panel').forEach(function(p) {
        p.classList.add('hidden');
      });
      document.getElementById('tab-' + tab).classList.remove('hidden');
    });
  });

  // Copy buttons
  document.addEventListener('click', function(e) {
    if (e.target.classList.contains('copy-btn')) {
      var targetId = e.target.getAttribute('data-target');
      var text = document.getElementById(targetId).textContent;
      navigator.clipboard.writeText(text).then(function() {
        var orig = e.target.textContent;
        e.target.textContent = 'Copied!';
        setTimeout(function() { e.target.textContent = orig; }, 2000);
      });
    }
  });

  // ---- Config builders ----
  function getConfig() {
    return {
      name:            document.getElementById('um-name').value.trim() || 'My Monitor',
      url:             document.getElementById('um-url').value.trim() || 'https://example.com/health',
      type:            document.getElementById('um-type').value,
      interval:        parseInt(document.getElementById('um-interval').value, 10),
      threshold:       parseInt(document.getElementById('um-threshold').value, 10),
      email:           document.getElementById('ch-email').checked,
      slack:           document.getElementById('ch-slack').checked,
      pagerduty:       document.getElementById('ch-pagerduty').checked,
      sms:             document.getElementById('ch-sms').checked,
      discord:         document.getElementById('ch-discord').checked,
      webhook:         document.getElementById('ch-webhook').checked,
      webhookUrl:      document.getElementById('um-webhook-url').value.trim(),
      statusCode:      parseInt(document.getElementById('um-status-code').value, 10) || 200,
      keyword:         document.getElementById('um-keyword').value.trim(),
      followRedirects: document.getElementById('um-follow-redirects').checked,
      sslCheck:        document.getElementById('um-ssl-check').checked,
    };
  }

  function monitorTypeToUptimeRobot(type) {
    // 1=HTTP, 2=keyword, 3=ping, 4=port
    if (type === 'http')    return 1;
    if (type === 'keyword') return 2;
    if (type === 'ping')    return 3;
    if (type === 'tcp')     return 4;
    return 1;
  }

  function buildUptimeRobotConfig(c) {
    var obj = {
      api_key: 'YOUR_API_KEY',
      format: 'json',
      type: monitorTypeToUptimeRobot(c.type),
      url: c.url,
      friendly_name: c.name,
      interval: c.interval,
      alert_contacts: c.email ? '123_0_0' : '',
      http_username: '',
      http_password: '',
    };
    if (c.type === 'http' || c.type === 'keyword') {
      obj.http_auth_type = 0;
      if (c.sslCheck) {
        obj.ssl_check_disabled = 0;
      }
      if (c.type === 'keyword') {
        obj.keyword_type = 1;
        obj.keyword_value = c.keyword || 'ok';
      }
    }
    if (c.type === 'tcp') {
      var urlParts = c.url.replace(/https?:\/\//, '').split(':');
      obj.url = urlParts[0];
      obj.port = urlParts[1] ? parseInt(urlParts[1], 10) : 80;
    }
    var contacts = [];
    if (c.email)     contacts.push('# email contact ID (e.g. 123_0_0)');
    if (c.slack)     contacts.push('# Slack integration ID');
    if (c.pagerduty) contacts.push('# PagerDuty integration ID');
    if (c.sms)       contacts.push('# SMS contact ID');
    if (c.discord)   contacts.push('# Discord integration ID');
    if (contacts.length) {
      obj['_notification_contacts'] = contacts;
    }
    obj['_confirm_down_threshold'] = c.threshold;
    obj['_note'] = 'Generated by DevPlaybook Uptime Monitor Config Generator';
    return JSON.stringify(obj, null, 2);
  }

  function buildBetterUptimeConfig(c) {
    var monitorType = c.type === 'tcp' ? 'tcp' : c.type === 'ping' ? 'ping' : 'status';
    var obj = {
      data: {
        type: 'monitor',
        attributes: {
          url: c.url,
          pronounceable_name: c.name,
          monitor_type: monitorType,
          check_frequency: c.interval,
          confirmation_period: c.threshold * c.interval,
          email: c.email,
          sms: c.sms,
          call: false,
          push: false,
          team_wait: 0,
          paused: false,
          follow_redirects: c.followRedirects,
          verify_ssl: c.sslCheck,
          ssl_expiration: 30,
        }
      }
    };
    if (c.type === 'keyword') {
      obj.data.attributes.required_keyword = c.keyword || 'ok';
    }
    if (c.type === 'http' || c.type === 'keyword') {
      obj.data.attributes.expected_status_codes = [c.statusCode];
    }
    if (c.slack) {
      obj.data.attributes['_slack_webhook'] = 'YOUR_SLACK_WEBHOOK_URL';
    }
    if (c.pagerduty) {
      obj.data.attributes['_pagerduty_service_key'] = 'YOUR_PAGERDUTY_KEY';
    }
    if (c.webhook) {
      obj.data.attributes['_webhook_url'] = c.webhookUrl || 'YOUR_WEBHOOK_URL';
    }
    if (c.discord) {
      obj.data.attributes['_discord_webhook'] = 'YOUR_DISCORD_WEBHOOK_URL';
    }
    obj['_note'] = 'POST to https://betteruptime.com/api/v2/monitors — add header: Authorization: Bearer YOUR_TOKEN';
    return JSON.stringify(obj, null, 2);
  }

  function buildPingdomConfig(c) {
    var typeMap = { http: 'http', tcp: 'tcp', ping: 'ping', keyword: 'http' };
    var obj = {
      name: c.name,
      host: c.url.replace(/https?:\/\//, '').split('/')[0],
      type: typeMap[c.type] || 'http',
      resolution: Math.floor(c.interval / 60),
      sendnotificationwhendown: c.threshold,
      notifyagainevery: 0,
      notifywhenbackup: true,
      paused: false,
      encryption: c.url.startsWith('https'),
      url: c.url.includes('/') ? '/' + c.url.replace(/https?:\/\/[^/]+/, '').replace(/^\//, '') : '/',
      integrationids: [],
      userids: [],
      teamids: [],
      tags: [],
    };
    if (c.type === 'http' || c.type === 'keyword') {
      obj.shouldcontain = c.type === 'keyword' ? (c.keyword || 'ok') : undefined;
      obj.postdata = '';
      obj.requestheaders = {};
      obj.auth = '';
      obj.followredirects = c.followRedirects;
      obj.verifycertificate = c.sslCheck;
      obj.ssldowndaysbefore = 30;
    }
    if (c.type === 'tcp') {
      obj.port = 80;
    }
    if (c.slack)     obj['_slack_integration_id'] = 'YOUR_SLACK_INTEGRATION_ID';
    if (c.pagerduty) obj['_pagerduty_integration_id'] = 'YOUR_PAGERDUTY_INTEGRATION_ID';
    if (c.email)     obj['_email_integration_id'] = 'YOUR_EMAIL_INTEGRATION_ID';
    if (c.sms)       obj['_sms_integration_id'] = 'YOUR_SMS_INTEGRATION_ID';
    obj['_note'] = 'POST to https://api.pingdom.com/api/3.1/checks — add header: Authorization: Bearer YOUR_TOKEN';
    return JSON.stringify(obj, null, 2);
  }

  function buildYamlConfig(c) {
    var intervalLabel = c.interval < 60 ? c.interval + 's' : (c.interval / 60) + 'm';
    if (c.interval === 3600) intervalLabel = '1h';
    var channels = [];
    if (c.email)     channels.push('  - type: email');
    if (c.slack)     channels.push('  - type: slack\n    webhook: YOUR_SLACK_WEBHOOK_URL');
    if (c.pagerduty) channels.push('  - type: pagerduty\n    service_key: YOUR_PAGERDUTY_KEY');
    if (c.sms)       channels.push('  - type: sms');
    if (c.discord)   channels.push('  - type: discord\n    webhook: YOUR_DISCORD_WEBHOOK_URL');
    if (c.webhook)   channels.push('  - type: webhook\n    url: ' + (c.webhookUrl || 'YOUR_WEBHOOK_URL'));

    var lines = [
      '# Uptime Monitor Configuration',
      '# Generated by DevPlaybook Uptime Monitor Config Generator',
      '# https://devplaybook.cc/tools/uptime-monitor-config',
      '',
      'monitor:',
      '  name: "' + c.name + '"',
      '  url: "' + c.url + '"',
      '  type: ' + c.type,
      '  interval: ' + intervalLabel,
      '  confirm_down_after: ' + c.threshold + ' failures',
      '',
      'alerts:',
    ];
    if (channels.length) {
      channels.forEach(function(ch) { lines.push(ch); });
    } else {
      lines.push('  # No notification channels selected');
    }
    if (c.type === 'http' || c.type === 'keyword') {
      lines.push('');
      lines.push('http_options:');
      lines.push('  expected_status: ' + c.statusCode);
      lines.push('  follow_redirects: ' + c.followRedirects);
      lines.push('  verify_ssl: ' + c.sslCheck);
      if (c.type === 'keyword') {
        lines.push('  keyword_match: "' + (c.keyword || 'ok') + '"');
      }
    }
    return lines.join('\n');
  }

  // ---- Examples ----
  function loadExample(type) {
    if (type === 'api') {
      document.getElementById('um-name').value = 'payments-api health';
      document.getElementById('um-url').value = 'https://api.example.com/health';
      document.getElementById('um-type').value = 'http';
      document.getElementById('um-interval').value = '60';
      document.getElementById('um-threshold').value = '2';
      document.getElementById('ch-email').checked = true;
      document.getElementById('ch-slack').checked = true;
      document.getElementById('ch-pagerduty').checked = true;
      document.getElementById('ch-discord').checked = false;
      document.getElementById('ch-webhook').checked = false;
      document.getElementById('um-status-code').value = '200';
      document.getElementById('um-follow-redirects').checked = true;
      document.getElementById('um-ssl-check').checked = true;
      document.getElementById('um-keyword').value = '';
      document.getElementById('http-options').classList.remove('hidden');
      document.getElementById('keyword-field').classList.add('hidden');
    } else {
      document.getElementById('um-name').value = 'postgres-primary TCP';
      document.getElementById('um-url').value = 'postgres-primary.internal:5432';
      document.getElementById('um-type').value = 'tcp';
      document.getElementById('um-interval').value = '300';
      document.getElementById('um-threshold').value = '1';
      document.getElementById('ch-email').checked = true;
      document.getElementById('ch-slack').checked = false;
      document.getElementById('ch-pagerduty').checked = true;
      document.getElementById('ch-discord').checked = false;
      document.getElementById('ch-webhook').checked = true;
      document.getElementById('um-webhook-url').value = 'https://hooks.example.com/db-alerts';
      document.getElementById('webhook-url-row').classList.remove('hidden');
      document.getElementById('http-options').classList.add('hidden');
    }
  }

  // ---- Main generate ----
  document.getElementById('btn-generate').addEventListener('click', function() {
    var c = getConfig();
    document.getElementById('out-uptimerobot').textContent = buildUptimeRobotConfig(c);
    document.getElementById('out-betteruptime').textContent = buildBetterUptimeConfig(c);
    document.getElementById('out-pingdom').textContent = buildPingdomConfig(c);
    document.getElementById('out-yaml').textContent = buildYamlConfig(c);
    document.getElementById('output-section').classList.remove('hidden');
    document.getElementById('output-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  document.getElementById('btn-example-api').addEventListener('click', function() { loadExample('api'); });
  document.getElementById('btn-example-tcp').addEventListener('click', function() { loadExample('tcp'); });
</script>
