---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is values.yaml in Helm?", answer: "values.yaml is Helm's configuration file. It provides default values for your chart's templates. Users can override values with --set flags or by providing their own values.yaml. Templates reference values using {{ .Values.key }} syntax. The values.yaml you ship with a chart should represent safe, sensible defaults." },
  { question: "What is the difference between image.tag and image.digest?", answer: "Using image.tag (like 'v1.2.3') is convenient but mutable — the same tag can be updated to point to a different image layer. Using image.digest (like 'sha256:abc...') pins to a specific immutable image. For production, digest pinning prevents supply chain attacks where an image tag is silently replaced." },
  { question: "How do I manage secrets in Helm?", answer: "Never store secrets in values.yaml or commit them to source control. Options: (1) helm-secrets plugin with SOPS encryption, (2) External Secrets Operator (syncs from AWS Secrets Manager, Vault, etc.), (3) Kubernetes Secrets created separately and referenced by secretRef in your deployment, (4) Vault Agent injector." },
  { question: "What is a Helm chart test?", answer: "Helm chart tests are Kubernetes pods with annotation helm.sh/hook: test. They run after helm install/upgrade and exit 0 on success. Used to verify the deployment is healthy: check if the app responds to HTTP, database is reachable, etc. Run with: helm test <release-name>." },
];
---

<BaseLayout
  title="Helm Chart Values Generator — Generate values.yaml Templates for Kubernetes"
  description="Generate Helm chart values.yaml templates for common patterns: web apps, workers, cronjobs, databases. Configure replicas, resources, ingress, secrets, and HPA."
  tool="Helm Chart Values Generator, Helm values.yaml Generator, Kubernetes Helm Template, Helm Chart Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Helm Chart Values Generator</h1>
  <p class="text-text-muted mb-4">Generate <code class="font-mono text-sm">values.yaml</code> templates for common Helm chart patterns. Configure your workload type, resources, ingress, and autoscaling.</p>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
    <!-- Config -->
    <div class="space-y-4">
      <div class="bg-bg-card border border-border rounded-xl p-5 space-y-4">
        <h2 class="text-base font-semibold">Workload Type</h2>
        <div class="flex flex-wrap gap-2">
          {['web-app','worker','cronjob','statefulset'].map(t => (
            <button class="workload-btn text-xs px-3 py-1.5 border border-border rounded-lg hover:bg-bg" data-type={t}>{t}</button>
          ))}
        </div>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5 space-y-3">
        <h2 class="text-base font-semibold">Basic Config</h2>
        <div><label class="block text-xs font-medium mb-1">App Name</label>
          <input id="app-name" type="text" value="my-app" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" /></div>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium mb-1">Image Repository</label>
            <input id="img-repo" type="text" value="nginx" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" /></div>
          <div><label class="block text-xs font-medium mb-1">Image Tag</label>
            <input id="img-tag" type="text" value="latest" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" /></div>
        </div>
        <div><label class="block text-xs font-medium mb-1">Replicas</label>
          <input id="replicas" type="number" value="2" min="1" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" /></div>
        <div><label class="block text-xs font-medium mb-1">Service Port</label>
          <input id="service-port" type="number" value="80" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" /></div>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5 space-y-3">
        <h2 class="text-base font-semibold">Resources</h2>
        <div class="grid grid-cols-2 gap-3">
          <div><label class="block text-xs font-medium mb-1">CPU Request (m)</label>
            <input id="r-cpu-req" type="text" value="100m" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" /></div>
          <div><label class="block text-xs font-medium mb-1">CPU Limit (m)</label>
            <input id="r-cpu-lim" type="text" value="200m" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" /></div>
          <div><label class="block text-xs font-medium mb-1">Memory Request</label>
            <input id="r-mem-req" type="text" value="128Mi" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" /></div>
          <div><label class="block text-xs font-medium mb-1">Memory Limit</label>
            <input id="r-mem-lim" type="text" value="256Mi" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" /></div>
        </div>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5 space-y-3">
        <h2 class="text-base font-semibold">Options</h2>
        <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" id="opt-ingress" /> Enable Ingress</label>
        <div id="ingress-opts" class="hidden pl-4 space-y-2">
          <input id="ingress-host" type="text" placeholder="app.example.com" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
          <label class="flex items-center gap-2 text-xs cursor-pointer"><input type="checkbox" id="ingress-tls" /> TLS / HTTPS</label>
        </div>
        <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" id="opt-hpa" /> Enable HPA</label>
        <div id="hpa-opts" class="hidden pl-4 grid grid-cols-3 gap-2">
          <input id="hpa-min2" type="number" value="2" placeholder="Min" class="w-full bg-bg border border-border rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:border-primary" />
          <input id="hpa-max2" type="number" value="10" placeholder="Max" class="w-full bg-bg border border-border rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:border-primary" />
          <input id="hpa-cpu2" type="number" value="70" placeholder="CPU%" class="w-full bg-bg border border-border rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:border-primary" />
        </div>
        <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" id="opt-pdb" /> PodDisruptionBudget</label>
        <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" id="opt-sa" /> ServiceAccount</label>
      </div>
    </div>

    <!-- Output -->
    <div class="bg-bg-card border border-border rounded-xl p-5 sticky top-4">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-semibold">values.yaml</h2>
        <button id="copy-values" class="text-xs text-text-muted border border-border px-2 py-1 rounded hover:bg-bg">Copy</button>
      </div>
      <pre id="values-output" class="text-xs font-mono bg-bg rounded-lg p-3 overflow-auto text-text-muted whitespace-pre max-h-[60vh]"></pre>
    </div>
  </div>

  <AdUnit slot="in-content" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Helm Chart Values Generator" relatedTags={['devops', 'kubernetes', 'helm', 'k8s', 'infrastructure']} />
</BaseLayout>

<script>
let workloadType = 'web-app';

document.querySelectorAll('.workload-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    workloadType = (btn as HTMLElement).dataset.type || 'web-app';
    document.querySelectorAll('.workload-btn').forEach(b => {
      b.className = 'workload-btn text-xs px-3 py-1.5 border border-border rounded-lg hover:bg-bg';
    });
    btn.className = 'workload-btn text-xs px-3 py-1.5 border border-primary/50 rounded-lg bg-primary/10 text-primary';
    update();
  });
});

document.getElementById('opt-ingress')!.addEventListener('change', e => {
  document.getElementById('ingress-opts')!.classList.toggle('hidden', !(e.target as HTMLInputElement).checked);
  update();
});
document.getElementById('opt-hpa')!.addEventListener('change', e => {
  document.getElementById('hpa-opts')!.classList.toggle('hidden', !(e.target as HTMLInputElement).checked);
  update();
});

function sv(id: string) { return (document.getElementById(id) as HTMLInputElement)?.value || ''; }
function sb(id: string) { return (document.getElementById(id) as HTMLInputElement)?.checked || false; }

function update() {
  const name = sv('app-name') || 'my-app';
  const imgRepo = sv('img-repo') || 'nginx';
  const imgTag = sv('img-tag') || 'latest';
  const replicas = sv('replicas') || '2';
  const port = sv('service-port') || '80';
  const cpuReq = sv('r-cpu-req') || '100m';
  const cpuLim = sv('r-cpu-lim') || '200m';
  const memReq = sv('r-mem-req') || '128Mi';
  const memLim = sv('r-mem-lim') || '256Mi';
  const ingress = sb('opt-ingress');
  const ingressHost = sv('ingress-host') || 'app.example.com';
  const ingressTls = sb('ingress-tls');
  const hpa = sb('opt-hpa');
  const hpaMin = sv('hpa-min2') || '2';
  const hpaMax = sv('hpa-max2') || '10';
  const hpaCpu = sv('hpa-cpu2') || '70';
  const pdb = sb('opt-pdb');
  const sa = sb('opt-sa');

  let yaml = `# Helm values.yaml for ${name} (${workloadType})
# Override any value with: helm upgrade ${name} . -f custom-values.yaml

# -- Image configuration
image:
  repository: ${imgRepo}
  tag: "${imgTag}"
  pullPolicy: IfNotPresent

# -- Number of replicas
replicaCount: ${replicas}

# -- Service configuration
service:
  type: ClusterIP
  port: ${port}
`;

  if (workloadType === 'web-app') {
    yaml += `
# -- Container port
containerPort: ${port}
`;
  } else if (workloadType === 'worker') {
    yaml += `
# -- Worker concurrency
worker:
  concurrency: 4
  queues:
    - default
    - high-priority
`;
  } else if (workloadType === 'cronjob') {
    yaml += `
# -- CronJob schedule (cron format)
cronJob:
  schedule: "0 * * * *"
  successfulJobsHistoryLimit: 3
  failedJobsHistoryLimit: 1
  concurrencyPolicy: Forbid
`;
  } else if (workloadType === 'statefulset') {
    yaml += `
# -- StatefulSet persistence
persistence:
  enabled: true
  storageClass: ""
  accessMode: ReadWriteOnce
  size: 10Gi
`;
  }

  yaml += `
# -- Resource requests and limits
resources:
  requests:
    cpu: ${cpuReq}
    memory: ${memReq}
  limits:
    cpu: ${cpuLim}
    memory: ${memLim}
`;

  if (ingress) {
    yaml += `
# -- Ingress configuration
ingress:
  enabled: true
  className: "nginx"
  annotations:
    kubernetes.io/ingress.class: nginx
    cert-manager.io/cluster-issuer: "letsencrypt-prod"
  hosts:
    - host: ${ingressHost}
      paths:
        - path: /
          pathType: Prefix
`;
    if (ingressTls) {
      yaml += `  tls:
    - secretName: ${name}-tls
      hosts:
        - ${ingressHost}
`;
    }
  } else {
    yaml += `
# -- Ingress disabled
ingress:
  enabled: false
`;
  }

  if (hpa) {
    yaml += `
# -- Horizontal Pod Autoscaler
autoscaling:
  enabled: true
  minReplicas: ${hpaMin}
  maxReplicas: ${hpaMax}
  targetCPUUtilizationPercentage: ${hpaCpu}
`;
  }

  if (pdb) {
    yaml += `
# -- Pod Disruption Budget
podDisruptionBudget:
  enabled: true
  minAvailable: 1
`;
  }

  if (sa) {
    yaml += `
# -- Service Account
serviceAccount:
  create: true
  annotations: {}
  name: ""
`;
  }

  yaml += `
# -- Environment variables
env: []
  # - name: DATABASE_URL
  #   valueFrom:
  #     secretKeyRef:
  #       name: ${name}-secrets
  #       key: database-url

# -- Pod annotations
podAnnotations: {}

# -- Node selector
nodeSelector: {}

# -- Tolerations
tolerations: []

# -- Affinity rules
affinity: {}
`;

  document.getElementById('values-output')!.textContent = yaml;
}

document.querySelectorAll<HTMLElement>('#app-name, #img-repo, #img-tag, #replicas, #service-port, #r-cpu-req, #r-cpu-lim, #r-mem-req, #r-mem-lim, #ingress-host, #hpa-min2, #hpa-max2, #hpa-cpu2').forEach(el => el.addEventListener('input', update));

document.getElementById('copy-values')!.addEventListener('click', () => {
  navigator.clipboard.writeText(document.getElementById('values-output')!.textContent || '');
});

// Init
(document.querySelector('[data-type="web-app"]') as HTMLElement)?.click();
</script>
