---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Webhook Payload Builder & Formatter — JSON Webhook Tester"
  description="Build, format, and validate webhook JSON payloads. Add custom headers, select event types for GitHub/Stripe/Slack/custom webhooks, and generate curl commands. Runs in your browser."
  tool="webhook payload builder, webhook JSON formatter, GitHub webhook, Stripe webhook, webhook tester, JSON payload"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Webhook Payload Builder & Formatter",
    "url": "https://devplaybook.cc/tools/webhook-payload-tester",
    "description": "Build, format, and validate webhook JSON payloads. Add custom headers, select event types for GitHub/Stripe/Slack/custom webhooks, and generate curl commands.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Webhook Payload Builder & Formatter</h1>
  <p class="text-text-muted mb-4">Build, format, and validate webhook JSON payloads for any service. Select a provider to auto-fill a realistic example, add custom headers, and export as cURL, fetch, axios, or HTTPie. Runs entirely in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GitHub / Stripe / Slack / PagerDuty / SendGrid / Shopify</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> JSON format & validate</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> cURL / fetch / axios / HTTPie output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <!-- Config Row -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-4">
    <div>
      <label class="block text-sm font-medium mb-1.5" for="wh-type">Webhook Type</label>
      <select id="wh-type" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
        <option value="custom">Custom</option>
        <option value="github">GitHub</option>
        <option value="stripe">Stripe</option>
        <option value="slack">Slack</option>
        <option value="pagerduty">PagerDuty</option>
        <option value="sendgrid">SendGrid</option>
        <option value="shopify">Shopify</option>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium mb-1.5" for="wh-method">HTTP Method</label>
      <select id="wh-method" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
        <option value="POST">POST</option>
        <option value="PUT">PUT</option>
        <option value="PATCH">PATCH</option>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium mb-1.5" for="wh-url">Endpoint URL</label>
      <input id="wh-url" type="text" placeholder="https://your-server.com/webhook" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
    </div>
  </div>

  <!-- Headers -->
  <div class="mb-4">
    <div class="flex items-center justify-between mb-1.5">
      <label class="block text-sm font-medium">Headers</label>
      <button id="add-header-btn" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">+ Add Header</button>
    </div>
    <div id="headers-list" class="flex flex-col gap-2"></div>
  </div>

  <!-- Payload -->
  <div class="mb-4">
    <div class="flex items-center justify-between mb-1.5">
      <label class="block text-sm font-medium" for="wh-payload">Payload (JSON)</label>
      <div class="flex items-center gap-2">
        <button id="format-btn" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Format JSON</button>
        <button id="validate-btn" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Validate JSON</button>
      </div>
    </div>
    <textarea id="wh-payload" rows="12" placeholder='{"event": "my.event", "data": {}}' class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary font-mono resize-y"></textarea>
    <div id="validate-banner" class="hidden mt-2 px-3 py-2 rounded-lg text-sm font-medium"></div>
  </div>

  <!-- Generate -->
  <button id="generate-btn" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 mb-6">Generate Output</button>

  <!-- Output Tabs -->
  <div id="output-section" class="hidden">
    <div class="flex gap-1 mb-3 border-b border-border">
      <button class="output-tab px-4 py-2 text-sm font-medium border-b-2 border-primary text-primary" data-tab="curl">cURL</button>
      <button class="output-tab px-4 py-2 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-text" data-tab="fetch">fetch()</button>
      <button class="output-tab px-4 py-2 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-text" data-tab="axios">axios</button>
      <button class="output-tab px-4 py-2 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-text" data-tab="httpie">HTTPie</button>
    </div>
    <div class="relative">
      <pre id="output-pre" class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto whitespace-pre-wrap"></pre>
      <button id="copy-output-btn" class="absolute top-3 right-3 px-3 py-1.5 bg-bg-card border border-border rounded-md text-xs hover:border-primary transition-colors">Copy</button>
    </div>
  </div>

  <ToolPageCta currentTool="Webhook Payload Builder" relatedTags={['webhook', 'http', 'api', 'json', 'curl', 'testing']} />
</BaseLayout>

<script is:inline>
(function () {
  // ---- Example payloads ----
  var EXAMPLES = {
    custom: { event: 'my.event', data: { id: 1, message: 'Hello World' }, timestamp: new Date().toISOString() },
    github: {
      action: 'opened',
      number: 42,
      pull_request: {
        id: 123456,
        title: 'Add new feature',
        state: 'open',
        html_url: 'https://github.com/org/repo/pull/42',
        user: { login: 'developer', id: 789 },
        head: { ref: 'feature-branch', sha: 'abc123' },
        base: { ref: 'main', sha: 'def456' }
      },
      repository: { id: 1234, name: 'my-repo', full_name: 'org/my-repo' }
    },
    stripe: {
      id: 'evt_1OqXYZ2eZvKYlo2Cabcdefgh',
      object: 'event',
      api_version: '2023-10-16',
      type: 'payment_intent.succeeded',
      data: {
        object: {
          id: 'pi_3OqXYZ2eZvKYlo2C1234abcd',
          object: 'payment_intent',
          amount: 2000,
          currency: 'usd',
          status: 'succeeded',
          customer: 'cus_abc123',
          metadata: { order_id: '12345' }
        }
      },
      created: 1711234567,
      livemode: false
    },
    slack: {
      token: 'Jhj5dZrVaK7ZwHHjRyZWjbDl',
      challenge: 'abc123xyz',
      type: 'event_callback',
      team_id: 'T123ABC456',
      event: {
        type: 'message',
        channel: 'C123ABC456',
        user: 'U123ABC456',
        text: 'Hello, world!',
        ts: '1711234567.123456'
      },
      event_id: 'Ev123ABC456',
      event_time: 1711234567
    },
    pagerduty: {
      messages: [
        {
          id: 'abc123',
          event: 'incident.trigger',
          created_on: new Date().toISOString(),
          incident: {
            id: 'P123ABC',
            incident_number: 42,
            title: 'High CPU on production server',
            status: 'triggered',
            urgency: 'high',
            html_url: 'https://yourorg.pagerduty.com/incidents/P123ABC',
            service: { id: 'P456DEF', name: 'Production API', html_url: 'https://yourorg.pagerduty.com/services/P456DEF' },
            assignees: [{ id: 'P789GHI', name: 'On-Call Engineer' }]
          }
        }
      ]
    },
    sendgrid: [
      {
        email: 'user@example.com',
        timestamp: 1711234567,
        event: 'delivered',
        smtp_id: '<14c5d75ce93.dfd.64b469@ismtpd-555>',
        sg_event_id: 'VzcPxPv7SdWvUugt-xbVMA',
        sg_message_id: '14c5d75ce93.dfd.64b469.filter0001.16648.5515E0B88.0',
        response: '250 OK'
      }
    ],
    shopify: {
      id: 820982911946154508,
      admin_graphql_api_id: 'gid://shopify/Order/820982911946154508',
      buyer_accepts_marketing: false,
      cancel_reason: null,
      cancelled_at: null,
      cart_token: 'abc123',
      checkout_id: 901414060,
      confirmed: true,
      currency: 'USD',
      current_total_price: '598.94',
      financial_status: 'pending',
      fulfillment_status: null,
      order_number: 1001,
      email: 'jon@doe.ca',
      created_at: new Date().toISOString()
    }
  };

  // ---- Default headers per type ----
  var DEFAULT_HEADERS = {
    custom: [['Content-Type', 'application/json']],
    github: [['Content-Type', 'application/json'], ['X-GitHub-Event', 'pull_request'], ['X-Hub-Signature-256', 'sha256=abc123']],
    stripe: [['Content-Type', 'application/json'], ['Stripe-Signature', 't=1711234567,v1=abc123def456']],
    slack: [['Content-Type', 'application/json'], ['X-Slack-Signature', 'v0=abc123'], ['X-Slack-Request-Timestamp', '1711234567']],
    pagerduty: [['Content-Type', 'application/json'], ['X-PagerDuty-Signature', 'v1=abc123']],
    sendgrid: [['Content-Type', 'application/json']],
    shopify: [['Content-Type', 'application/json'], ['X-Shopify-Topic', 'orders/create'], ['X-Shopify-Hmac-Sha256', 'abc123=']]
  };

  var currentTab = 'curl';
  var lastOutputs = {};

  var typeEl = document.getElementById('wh-type');
  var methodEl = document.getElementById('wh-method');
  var urlEl = document.getElementById('wh-url');
  var payloadEl = document.getElementById('wh-payload');
  var headersList = document.getElementById('headers-list');
  var validateBanner = document.getElementById('validate-banner');
  var outputSection = document.getElementById('output-section');
  var outputPre = document.getElementById('output-pre');
  var copyBtn = document.getElementById('copy-output-btn');

  function makeHeaderRow(key, val) {
    var row = document.createElement('div');
    row.className = 'flex items-center gap-2 header-row';
    row.innerHTML =
      '<input type="text" placeholder="Header name" value="' + escAttr(key) + '" class="flex-1 bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary header-key" />' +
      '<input type="text" placeholder="Value" value="' + escAttr(val) + '" class="flex-[2] bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary header-val" />' +
      '<button class="remove-header px-3 py-2.5 bg-bg-card border border-border rounded-lg text-sm text-text-muted hover:border-red-400 hover:text-red-400 transition-colors">✕</button>';
    row.querySelector('.remove-header').addEventListener('click', function () { row.remove(); });
    return row;
  }

  function escAttr(s) {
    return String(s).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;');
  }

  function setHeaders(pairs) {
    headersList.innerHTML = '';
    pairs.forEach(function (p) { headersList.appendChild(makeHeaderRow(p[0], p[1])); });
  }

  function getHeaders() {
    var rows = headersList.querySelectorAll('.header-row');
    var out = [];
    rows.forEach(function (r) {
      var k = r.querySelector('.header-key').value.trim();
      var v = r.querySelector('.header-val').value.trim();
      if (k) out.push([k, v]);
    });
    return out;
  }

  // Init with custom defaults
  setHeaders(DEFAULT_HEADERS.custom);
  payloadEl.value = JSON.stringify(EXAMPLES.custom, null, 2);
  urlEl.value = 'https://your-server.com/webhook';

  typeEl.addEventListener('change', function () {
    var type = typeEl.value;
    setHeaders(DEFAULT_HEADERS[type] || DEFAULT_HEADERS.custom);
    payloadEl.value = JSON.stringify(EXAMPLES[type] || EXAMPLES.custom, null, 2);
    validateBanner.className = 'hidden mt-2 px-3 py-2 rounded-lg text-sm font-medium';
    outputSection.classList.add('hidden');
  });

  document.getElementById('add-header-btn').addEventListener('click', function () {
    headersList.appendChild(makeHeaderRow('', ''));
  });

  document.getElementById('format-btn').addEventListener('click', function () {
    try {
      payloadEl.value = JSON.stringify(JSON.parse(payloadEl.value), null, 2);
      showBanner('valid', 'JSON formatted successfully.');
    } catch (e) {
      showBanner('error', 'Invalid JSON: ' + e.message);
    }
  });

  document.getElementById('validate-btn').addEventListener('click', function () {
    try {
      JSON.parse(payloadEl.value);
      showBanner('valid', 'Valid JSON.');
    } catch (e) {
      showBanner('error', 'Invalid JSON: ' + e.message);
    }
  });

  function showBanner(type, msg) {
    validateBanner.textContent = msg;
    validateBanner.className = 'mt-2 px-3 py-2 rounded-lg text-sm font-medium ' +
      (type === 'valid' ? 'bg-green-500/10 border border-green-500/30 text-green-400' : 'bg-red-500/10 border border-red-500/30 text-red-400');
  }

  document.getElementById('generate-btn').addEventListener('click', function () {
    var method = methodEl.value;
    var url = urlEl.value.trim() || 'https://your-server.com/webhook';
    var headers = getHeaders();
    var payload = payloadEl.value.trim() || '{}';

    // Validate JSON before generating
    try { JSON.parse(payload); } catch (e) {
      showBanner('error', 'Invalid JSON — please fix before generating: ' + e.message);
      return;
    }

    lastOutputs = buildOutputs(method, url, headers, payload);
    renderTab(currentTab);
    outputSection.classList.remove('hidden');
  });

  function buildOutputs(method, url, headers, payload) {
    var curlLines = ['curl -X ' + method + ' \'' + url + '\''];
    headers.forEach(function (h) {
      curlLines.push('  -H \'' + h[0] + ': ' + h[1] + '\'');
    });
    curlLines.push('  -d \'' + payload.replace(/'/g, "'\\''") + '\'');
    var curl = curlLines.join(' \\\n');

    var headersObj = {};
    headers.forEach(function (h) { headersObj[h[0]] = h[1]; });
    var headersJson = JSON.stringify(headersObj, null, 2)
      .replace(/^{/, '').replace(/}$/, '').trim()
      .split('\n').map(function (l) { return '    ' + l; }).join('\n');

    var fetchCode = 'const response = await fetch(\'' + url + '\', {\n' +
      '  method: \'' + method + '\',\n' +
      '  headers: {\n' + headersJson + '\n  },\n' +
      '  body: JSON.stringify(' + payload + ')\n' +
      '});\nconst data = await response.json();\nconsole.log(data);';

    var axiosCode = 'const { data } = await axios({\n' +
      '  method: \'' + method.toLowerCase() + '\',\n' +
      '  url: \'' + url + '\',\n' +
      '  headers: {\n' + headersJson + '\n  },\n' +
      '  data: ' + payload + '\n' +
      '});\nconsole.log(data);';

    var httpieParts = ['http ' + method + ' "' + url + '"'];
    headers.forEach(function (h) { httpieParts.push('"' + h[0] + ': ' + h[1] + '"'); });
    httpieParts.push("<<<'" + payload + "'");
    var httpie = httpieParts.join(' \\\n  ');

    return { curl: curl, fetch: fetchCode, axios: axiosCode, httpie: httpie };
  }

  function renderTab(tab) {
    outputPre.textContent = lastOutputs[tab] || '';
    document.querySelectorAll('.output-tab').forEach(function (btn) {
      var active = btn.dataset.tab === tab;
      btn.className = 'output-tab px-4 py-2 text-sm font-medium border-b-2 ' +
        (active ? 'border-primary text-primary' : 'border-transparent text-text-muted hover:text-text');
    });
  }

  document.querySelectorAll('.output-tab').forEach(function (btn) {
    btn.addEventListener('click', function () {
      currentTab = btn.dataset.tab;
      renderTab(currentTab);
    });
  });

  copyBtn.addEventListener('click', function () {
    var text = outputPre.textContent;
    if (navigator.clipboard) {
      navigator.clipboard.writeText(text).then(function () {
        copyBtn.textContent = 'Copied!';
        setTimeout(function () { copyBtn.textContent = 'Copy'; }, 2000);
      });
    } else {
      var ta = document.createElement('textarea');
      ta.value = text;
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      copyBtn.textContent = 'Copied!';
      setTimeout(function () { copyBtn.textContent = 'Copy'; }, 2000);
    }
  });
})();
</script>
