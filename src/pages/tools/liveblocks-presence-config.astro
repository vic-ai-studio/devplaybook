---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LiveblocksPresenceConfig from '../../components/LiveblocksPresenceConfig.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is Liveblocks?", answer: "Liveblocks is a real-time collaboration infrastructure for building multiplayer features. It provides presence (who is online and what are they doing), storage (shared state via CRDT data structures), and broadcasting — all with React hooks and TypeScript support. Common use cases include collaborative document editors, live cursors, shared whiteboards, and multi-user dashboards." },
  { question: "What is Presence in Liveblocks?", answer: "Presence is ephemeral per-user state that is broadcast to all other users in the room in real-time. It's ideal for cursor positions, user focus states, active selections, or typing indicators. Presence data is not persisted — when a user leaves the room, their presence disappears. Access it with useMyPresence() to set your own and useOthers() to read other users' presence." },
  { question: "What is the difference between Presence and Storage in Liveblocks?", answer: "Presence is ephemeral and per-user — each user has their own presence object that others can read. Storage is shared persistent state using CRDT data structures (LiveObject, LiveList, LiveMap) that multiple users can edit simultaneously without conflicts. Use Presence for cursors and real-time feedback; use Storage for the actual document content that needs to persist between sessions." },
  { question: "What is throttle in Liveblocks Presence?", answer: "The throttle option (in milliseconds) limits how frequently presence updates are sent to other users. Lower values (16ms) mean near-real-time updates but more bandwidth usage. Higher values (100ms+) reduce bandwidth but make movements appear less smooth. For cursor tracking, 16-50ms is typical. For typing indicators, 100-200ms is sufficient. Default is 100ms." },
  { question: "How do LiveObject, LiveList, and LiveMap differ?", answer: "LiveObject is a CRDT map where each key can be independently edited — similar to a shared JavaScript object. Best for document-like data. LiveList is an ordered list of items that handles concurrent insertions gracefully — good for comment threads. LiveMap is a key-value store where keys can be added/removed independently — good for collections of named items. All three handle concurrent edits without conflicts using operational transforms." },
  { question: "How do I add Liveblocks authentication to my app?", answer: "Create an API endpoint (e.g. /api/liveblocks-auth) that uses @liveblocks/node to issue room access tokens. Use liveblocks.prepareSession(userId) then session.allow(roomId, session.FULL_ACCESS) to grant access, and return session.authorize(). Pass your endpoint URL as authEndpoint in createClient(). For public rooms (no auth), use publicApiKey in createClient() instead." },
];
---

<BaseLayout
  title="Liveblocks Config Builder — Presence & Room Setup Generator"
  description="Build Liveblocks room configurations visually. Define Presence types, Storage schema, throttle settings, and get TypeScript code for RoomProvider setup. Free tool."
  tool="Liveblocks, Liveblocks config, real-time collaboration, Presence API, LiveObject, LiveList, LiveMap, multiplayer React"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Liveblocks Presence Config Builder",
    "url": "https://devplaybook.cc/tools/liveblocks-presence-config",
    "description": "Generate Liveblocks room configuration TypeScript code. Define Presence fields, Storage schema (LiveObject/LiveList/LiveMap), throttle settings, and get a complete RoomProvider setup.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Liveblocks Presence Config Builder</h1>
  <p class="text-text-muted mb-4">Build <strong>Liveblocks</strong> room configurations with typed Presence and Storage. Define your real-time data model and get copy-ready TypeScript with <code class="text-accent font-mono">RoomProvider</code> setup.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Presence & Storage types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> LiveObject/LiveList/LiveMap</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> RoomProvider code</span>
  </div>
  <LiveblocksPresenceConfig client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Liveblocks Presence Config Builder" relatedTags={['react', 'realtime', 'collaboration', 'typescript', 'liveblocks', 'frontend']} />
</BaseLayout>
