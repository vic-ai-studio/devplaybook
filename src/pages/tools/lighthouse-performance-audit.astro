---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "How do I run a Lighthouse audit from the command line?", answer: "Install globally with `npm install -g lighthouse`, then run `lighthouse https://example.com --output html --output-path report.html`. This generates a full HTML report. For headless CI use, add `--chrome-flags='--headless'`. You can also output JSON with `--output json` for programmatic processing." },
  { question: "What is the difference between Lighthouse CLI and DevTools Lighthouse?", answer: "The CLI runs Lighthouse in a controlled Node.js environment with simulated throttling and is suitable for CI/CD pipelines. DevTools Lighthouse runs directly in your browser with your real network conditions and extensions. DevTools may show different scores because browser extensions, cached resources, and real network latency affect results. Use CLI scores for consistent benchmarks and DevTools for debugging real-user issues." },
  { question: "Why does my Lighthouse score differ between runs?", answer: "Performance scores vary ±2–5 points per run due to CPU/network simulation variance, garbage collection timing, and background system load. To get a stable score, run Lighthouse 3–5 times and use the median. In CI, configure `numberOfRuns: 3` in your lighthouserc.js. Do not alarm on a single-point score change — focus on consistent regressions of 5+ points." },
  { question: "What are the most impactful Lighthouse opportunities to fix?", answer: "The highest-impact fixes are: (1) Eliminate render-blocking resources — defer non-critical JS/CSS. (2) Reduce unused JavaScript — code-split large bundles. (3) Properly size images and use modern formats (WebP/AVIF). (4) Reduce server response times (TTFB) — enable compression, CDN caching. (5) Remove unused CSS with PurgeCSS. These five categories typically account for 80% of performance score improvements." },
  { question: "How do I audit pages that require authentication?", answer: "Use Lighthouse with a Puppeteer script to pre-authenticate. In your lighthouserc.js, set `puppeteerScript` to a script that logs in before the audit. Alternatively, use `--extra-headers` to inject auth cookies or tokens. For Lighthouse CLI, you can also pass `--cookies` with a JSON file containing session cookies exported from DevTools." },
];
---

<BaseLayout
  title="Lighthouse Performance Audit Guide — CLI, DevTools & CI Integration"
  description="Complete guide to Lighthouse performance audits: CLI usage, DevTools integration, CI/CD setup, score interpretation, and fixing the top performance opportunities."
  tool="Lighthouse, Lighthouse CLI, Lighthouse audit, web performance, Core Web Vitals, performance score"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Lighthouse Performance Audit Guide",
    "url": "https://devplaybook.cc/tools/lighthouse-performance-audit",
    "description": "Complete guide to Lighthouse performance audits: CLI, DevTools, CI/CD, and fixing top opportunities.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Lighthouse Performance Audit Guide</h1>
  <p class="text-text-muted mb-6">
    <strong>Lighthouse</strong> is Google's open-source tool for auditing web performance, accessibility, SEO, and best practices. Run it from Chrome DevTools, the CLI, or CI/CD pipelines to catch regressions before they ship.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CLI & DevTools usage</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CI/CD integration</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Score interpretation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Top opportunity fixes</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">CLI Installation & Basic Usage</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Install globally
npm install -g lighthouse

# Basic audit — opens HTML report in browser
lighthouse https://example.com

# Headless (no browser window) + HTML report
lighthouse https://example.com \
  --chrome-flags="--headless" \
  --output html \
  --output-path ./lighthouse-report.html

# JSON output for programmatic processing
lighthouse https://example.com \
  --output json \
  --output-path ./report.json \
  --quiet

# Audit with custom throttling (disable throttling for unthrottled score)
lighthouse https://example.com \
  --throttling-method=provided \
  --output html</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">DevTools Lighthouse Panel</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li>Open Chrome DevTools → <strong>Lighthouse</strong> tab</li>
    <li>Select categories: Performance, Accessibility, Best Practices, SEO</li>
    <li>Choose device: Mobile (default) or Desktop</li>
    <li>Click <strong>Analyze page load</strong> — DevTools reloads the page with throttling</li>
    <li>Expand each audit to see specifics and fix suggestions</li>
    <li>Use <strong>Throttling: Simulated Slow 4G</strong> to match Lighthouse CLI behavior</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Score Categories</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Category</th>
          <th class="border border-border px-3 py-2 text-left">What It Measures</th>
          <th class="border border-border px-3 py-2 text-left">Poor</th>
          <th class="border border-border px-3 py-2 text-left">Good</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2">Performance</td><td class="border border-border px-3 py-2">LCP, TBT, CLS, FCP, SI, TTI</td><td class="border border-border px-3 py-2 text-red-400">0–49</td><td class="border border-border px-3 py-2 text-green-400">90–100</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Accessibility</td><td class="border border-border px-3 py-2">ARIA, contrast, labels, keyboard</td><td class="border border-border px-3 py-2 text-red-400">0–49</td><td class="border border-border px-3 py-2 text-green-400">90–100</td></tr>
        <tr><td class="border border-border px-3 py-2">Best Practices</td><td class="border border-border px-3 py-2">HTTPS, console errors, deprecated APIs</td><td class="border border-border px-3 py-2 text-red-400">0–49</td><td class="border border-border px-3 py-2 text-green-400">90–100</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">SEO</td><td class="border border-border px-3 py-2">Meta, robots, crawlability</td><td class="border border-border px-3 py-2 text-red-400">0–49</td><td class="border border-border px-3 py-2 text-green-400">90–100</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Core Web Vitals in Lighthouse</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Metric</th>
          <th class="border border-border px-3 py-2 text-left">Good</th>
          <th class="border border-border px-3 py-2 text-left">Needs Improvement</th>
          <th class="border border-border px-3 py-2 text-left">Poor</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2">LCP (Largest Contentful Paint)</td><td class="border border-border px-3 py-2 text-green-400">≤ 2.5s</td><td class="border border-border px-3 py-2 text-yellow-400">2.5–4s</td><td class="border border-border px-3 py-2 text-red-400">&gt; 4s</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">INP (Interaction to Next Paint)</td><td class="border border-border px-3 py-2 text-green-400">≤ 200ms</td><td class="border border-border px-3 py-2 text-yellow-400">200–500ms</td><td class="border border-border px-3 py-2 text-red-400">&gt; 500ms</td></tr>
        <tr><td class="border border-border px-3 py-2">CLS (Cumulative Layout Shift)</td><td class="border border-border px-3 py-2 text-green-400">≤ 0.1</td><td class="border border-border px-3 py-2 text-yellow-400">0.1–0.25</td><td class="border border-border px-3 py-2 text-red-400">&gt; 0.25</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">TBT (Total Blocking Time)</td><td class="border border-border px-3 py-2 text-green-400">≤ 200ms</td><td class="border border-border px-3 py-2 text-yellow-400">200–600ms</td><td class="border border-border px-3 py-2 text-red-400">&gt; 600ms</td></tr>
        <tr><td class="border border-border px-3 py-2">FCP (First Contentful Paint)</td><td class="border border-border px-3 py-2 text-green-400">≤ 1.8s</td><td class="border border-border px-3 py-2 text-yellow-400">1.8–3s</td><td class="border border-border px-3 py-2 text-red-400">&gt; 3s</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Top Performance Opportunities</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Eliminate render-blocking resources</strong> — Add <code class="bg-bg-card px-1 rounded font-mono text-xs">defer</code>/<code class="bg-bg-card px-1 rounded font-mono text-xs">async</code> to scripts, inline critical CSS</li>
    <li><strong>Reduce unused JavaScript</strong> — Code-split with dynamic imports, tree-shake dependencies</li>
    <li><strong>Properly size images</strong> — Serve responsive images with <code class="bg-bg-card px-1 rounded font-mono text-xs">srcset</code>, use WebP/AVIF</li>
    <li><strong>Reduce server response time (TTFB)</strong> — Enable CDN, Brotli compression, HTTP/2</li>
    <li><strong>Remove unused CSS</strong> — PurgeCSS, CSS Modules, or Tailwind's JIT purge</li>
    <li><strong>Avoid enormous network payloads</strong> — Set JavaScript bundle size budget &lt; 200KB gzip</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Programmatic Usage (Node.js)</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">import lighthouse from 'lighthouse';
import * as chromeLauncher from 'chrome-launcher';

async function runAudit(url) &#123;
  const chrome = await chromeLauncher.launch(&#123; chromeFlags: ['--headless'] &#125;);
  const result = await lighthouse(url, &#123;
    logLevel: 'error',
    output: 'json',
    port: chrome.port,
    onlyCategories: ['performance'],
  &#125;);

  const &#123; lhr &#125; = result;
  console.log(`Performance: $&#123;lhr.categories.performance.score * 100&#125;`);
  console.log(`LCP: $&#123;lhr.audits['largest-contentful-paint'].displayValue&#125;`);
  console.log(`TBT: $&#123;lhr.audits['total-blocking-time'].displayValue&#125;`);
  console.log(`CLS: $&#123;lhr.audits['cumulative-layout-shift'].displayValue&#125;`);

  await chrome.kill();
  return lhr;
&#125;

runAudit('https://example.com');</pre>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Lighthouse Performance Audit Guide" relatedTags={['performance', 'lighthouse', 'core-web-vitals', 'seo', 'ci-cd']} />
</BaseLayout>
