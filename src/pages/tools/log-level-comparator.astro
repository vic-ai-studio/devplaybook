---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "Why do different logging frameworks use different level names?", answer: "Logging frameworks evolved independently across languages and ecosystems. Winston uses error/warn/info/http/verbose/debug/silly. Python uses CRITICAL/ERROR/WARNING/INFO/DEBUG. Log4j uses FATAL/ERROR/WARN/INFO/DEBUG/TRACE. They're conceptually similar but the names differ — this tool maps equivalents." },
  { question: "What is the lowest log level I should use in production?", answer: "Most production apps use INFO or WARN as the minimum level. DEBUG and TRACE/VERBOSE are too noisy for production and may expose sensitive data. Use environment variables to control the level: LOG_LEVEL=info. Enable DEBUG only during debugging sessions." },
  { question: "What is the syslog RFC 5424 severity scale?", answer: "Syslog defines 8 severities (0-7): EMERGENCY(0), ALERT(1), CRITICAL(2), ERROR(3), WARNING(4), NOTICE(5), INFORMATIONAL(6), DEBUG(7). Most application logging frameworks map to a subset of these. Syslog is used in Linux systems, network devices, and cloud logging services." },
  { question: "What does log level filtering mean?", answer: "Setting a minimum log level means only logs at that level or higher severity are emitted. If you set level=WARN, then DEBUG and INFO messages are suppressed. Lower numeric values mean higher severity (syslog convention), but most frameworks use higher numbers = more verbose." },
];

const FRAMEWORKS = [
  {
    name: 'Winston (Node.js)',
    levels: ['error', 'warn', 'info', 'http', 'verbose', 'debug', 'silly'],
    colors: ['red-400', 'orange-400', 'blue-400', 'indigo-400', 'purple-400', 'green-400', 'text-muted'],
    desc: 'Default Winston levels (npm log levels)',
  },
  {
    name: 'Pino (Node.js)',
    levels: ['fatal', 'error', 'warn', 'info', 'debug', 'trace'],
    colors: ['red-500', 'red-400', 'orange-400', 'blue-400', 'green-400', 'text-muted'],
    desc: 'Pino fast JSON logger',
  },
  {
    name: 'Python logging',
    levels: ['CRITICAL', 'ERROR', 'WARNING', 'INFO', 'DEBUG', 'NOTSET'],
    colors: ['red-500', 'red-400', 'orange-400', 'blue-400', 'green-400', 'text-muted'],
    desc: 'Python standard library logging module',
  },
  {
    name: 'Log4j / SLF4J (Java)',
    levels: ['FATAL', 'ERROR', 'WARN', 'INFO', 'DEBUG', 'TRACE'],
    colors: ['red-500', 'red-400', 'orange-400', 'blue-400', 'green-400', 'text-muted'],
    desc: 'Log4j, Log4j2, SLF4J, Logback',
  },
  {
    name: 'Syslog (RFC 5424)',
    levels: ['EMERG(0)', 'ALERT(1)', 'CRIT(2)', 'ERR(3)', 'WARNING(4)', 'NOTICE(5)', 'INFO(6)', 'DEBUG(7)'],
    colors: ['red-500', 'red-500', 'red-400', 'red-400', 'orange-400', 'yellow-400', 'blue-400', 'green-400'],
    desc: 'Linux syslog, RFC 5424 severity levels',
  },
  {
    name: 'Go (slog, zerolog)',
    levels: ['ERROR', 'WARN', 'INFO', 'DEBUG'],
    colors: ['red-400', 'orange-400', 'blue-400', 'green-400'],
    desc: 'Go standard slog, zerolog, zap',
  },
  {
    name: 'Ruby Logger',
    levels: ['FATAL', 'ERROR', 'WARN', 'INFO', 'DEBUG'],
    colors: ['red-500', 'red-400', 'orange-400', 'blue-400', 'green-400'],
    desc: 'Ruby stdlib Logger, Rails logger',
  },
];

const SEVERITY_MAP = [
  { label: 'Fatal / Emergency', desc: 'System unusable — process crashes', color: 'red-500', frameworks: ['error (highest)', 'fatal', 'CRITICAL', 'FATAL', 'EMERG/ALERT', 'ERROR', 'FATAL'] },
  { label: 'Error', desc: 'Operation failed, needs attention', color: 'red-400', frameworks: ['error', 'error', 'ERROR', 'ERROR', 'ERR', 'ERROR', 'ERROR'] },
  { label: 'Warning', desc: 'Unexpected behavior, still working', color: 'orange-400', frameworks: ['warn', 'warn', 'WARNING', 'WARN', 'WARNING', 'WARN', 'WARN'] },
  { label: 'Info', desc: 'Normal events, key milestones', color: 'blue-400', frameworks: ['info', 'info', 'INFO', 'INFO', 'NOTICE/INFO', 'INFO', 'INFO'] },
  { label: 'Debug', desc: 'Diagnostic details, dev use', color: 'green-400', frameworks: ['debug/verbose', 'debug', 'DEBUG', 'DEBUG', 'DEBUG', 'DEBUG', 'DEBUG'] },
  { label: 'Trace / Verbose', desc: 'Every detail, very noisy', color: 'text-muted', frameworks: ['silly', 'trace', '—', 'TRACE', '—', '—', '—'] },
];
---

<BaseLayout
  title="Log Level Comparator — Winston, Pino, Log4j, Python, Syslog"
  description="Compare log levels across logging frameworks. See Winston, Pino, Python logging, Log4j, syslog, Go slog, and Ruby Logger side by side with severity table and visual hierarchy."
  tool="Log level comparator, logging levels, Winston log levels, Python logging levels, Log4j levels, syslog severity"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Log Level Comparator</h1>
  <p class="text-text-muted mb-6">Compare log levels across 7 popular logging frameworks — Winston, Pino, Python, Log4j, syslog, Go slog, and Ruby Logger. Visual severity mapping table included.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 7 frameworks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Severity mapping</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Production guidance</span>
  </div>

  <div class="mb-8">
    <h2 class="text-lg font-semibold mb-4">Severity Mapping Table</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm min-w-[700px]">
        <thead>
          <tr class="text-text-muted text-xs uppercase border-b border-border">
            <th class="text-left pb-3 pr-4 font-medium">Severity</th>
            <th class="text-left pb-3 pr-4 font-medium">Description</th>
            {FRAMEWORKS.slice(0, 6).map(f => <th class="text-left pb-3 pr-2 font-medium">{f.name.split(' ')[0]}</th>)}
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          {SEVERITY_MAP.map(row => (
            <tr class="hover:bg-bg-card/50 transition-colors">
              <td class={`py-3 pr-4 font-semibold text-${row.color}`}>{row.label}</td>
              <td class="py-3 pr-4 text-text-muted text-xs">{row.desc}</td>
              {row.frameworks.slice(0, 6).map((fw, i) => (
                <td class={`py-3 pr-2 font-mono text-xs ${fw === '—' ? 'text-text-muted' : `text-${FRAMEWORKS[i].colors[0]}`}`}>{fw}</td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <div class="mb-8">
    <h2 class="text-lg font-semibold mb-4">Framework Level Hierarchies</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {FRAMEWORKS.map(fw => (
        <div class="bg-bg-card border border-border rounded-xl p-4">
          <p class="font-semibold text-sm mb-1">{fw.name}</p>
          <p class="text-xs text-text-muted mb-3">{fw.desc}</p>
          <div class="space-y-1">
            {fw.levels.map((lvl, i) => (
              <div class={`flex items-center gap-2 text-xs text-${fw.colors[i] || 'text-muted'}`}>
                <span class="font-mono font-medium">{lvl}</span>
                <span class="text-text-muted/50 text-xs">({i === 0 ? 'highest' : i === fw.levels.length - 1 ? 'lowest' : `level ${i + 1}`})</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="bg-bg-card border border-border rounded-xl p-4 mb-8">
    <p class="text-sm font-semibold mb-3">Quick Reference: Setting Log Levels</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-xs font-mono">
      <div>
        <p class="text-text-muted mb-1"># Winston (Node.js)</p>
        <p>const logger = winston.createLogger({'{'}</p>
        <p>  level: process.env.LOG_LEVEL || 'info',</p>
        <p>{'}'});</p>
      </div>
      <div>
        <p class="text-text-muted mb-1"># Python</p>
        <p>import logging</p>
        <p>logging.basicConfig(level=logging.INFO)</p>
        <p>logger = logging.getLogger(__name__)</p>
      </div>
      <div>
        <p class="text-text-muted mb-1"># Pino (Node.js)</p>
        <p>const log = pino({'{'} level: 'info' {'}'});</p>
        <p>log.info('message')</p>
      </div>
      <div>
        <p class="text-text-muted mb-1"># Go slog</p>
        <p>slog.SetLogLoggerLevel(slog.LevelInfo)</p>
        <p>slog.Info("message", "key", value)</p>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Log Level Comparator" relatedTags={['logging', 'nodejs', 'python', 'observability', 'developer-tools']} />
</BaseLayout>
