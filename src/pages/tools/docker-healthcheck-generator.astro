---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DockerHealthcheckGenerator from '../../components/DockerHealthcheckGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What does Docker HEALTHCHECK do?",
    answer: "The HEALTHCHECK instruction tells Docker how to test if a container is working. Docker runs the health check command at the specified interval. If the command exits with 0, the container is 'healthy'. If it exits with 1, it is 'unhealthy'. The health status is visible in docker inspect and docker ps, and used by orchestrators like Kubernetes and Docker Swarm for routing decisions."
  },
  {
    question: "What is start-period and why is it important?",
    answer: "start-period gives your container a grace period after it starts before health check failures count toward the retries threshold. During start-period, failures are recorded but don't contribute to the failure count. This prevents containers from being marked unhealthy during a slow initialization (e.g., database startup, JVM warm-up). Set it longer than your worst-case startup time."
  },
  {
    question: "What tools can I use for HTTP health checks?",
    answer: "curl is the most common: curl -f URL exits with non-zero on HTTP errors (4xx/5xx). wget -q --spider URL is a lighter alternative. If curl isn't in your image, install it, or use CMD-SHELL with a language-specific alternative. For minimal images, consider adding a tiny health check binary like healthcheck."
  },
  {
    question: "How do I check health for databases?",
    answer: "PostgreSQL: pg_isready -U postgres. MySQL/MariaDB: mysqladmin ping -h localhost. Redis: redis-cli ping. MongoDB: mongosh --eval 'db.runCommand({ping:1})'. These are purpose-built health check commands that don't require opening a full connection and are fast and low-overhead."
  },
  {
    question: "What is the difference between Dockerfile HEALTHCHECK and docker-compose healthcheck?",
    answer: "The Dockerfile HEALTHCHECK is baked into the image — it applies whenever the image is run. docker-compose healthcheck overrides or supplements the image's HEALTHCHECK for a specific service in a Compose setup. You can use depends_on with condition: service_healthy to wait for a service to be healthy before starting a dependent service."
  },
  {
    question: "What happens when a container becomes unhealthy?",
    answer: "Docker marks the container as 'unhealthy' in docker ps and docker inspect. The container keeps running — Docker does not automatically restart unhealthy containers. Orchestrators (Docker Swarm, Kubernetes) use health status to route traffic away from unhealthy containers and replace them. For Kubernetes, use readinessProbe and livenessProbe instead of Docker HEALTHCHECK."
  },
];
---

<BaseLayout
  title="Docker HEALTHCHECK Generator — Dockerfile & docker-compose Health Check Builder"
  description="Generate Docker HEALTHCHECK instructions for Dockerfiles and docker-compose.yml. Supports HTTP, TCP, command, and file-based health checks with configurable interval, timeout, and retries."
  tool="Docker Healthcheck Generator, Dockerfile HEALTHCHECK, docker-compose healthcheck, Docker Health Check Builder"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Docker HEALTHCHECK Generator",
    "url": "https://devplaybook.cc/tools/docker-healthcheck-generator",
    "description": "Generate Docker HEALTHCHECK instructions for Dockerfiles and docker-compose.yml with HTTP, TCP, command, and file-based checks.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Docker HEALTHCHECK Generator</h1>
  <p class="text-text-muted mb-4">
    Generate Docker <code class="font-mono bg-surface px-1 rounded text-sm">HEALTHCHECK</code> instructions for your
    Dockerfile and <code class="font-mono bg-surface px-1 rounded text-sm">docker-compose.yml</code>.
    Choose HTTP, TCP port, shell command, or file-based checks — with configurable timing options.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> HTTP / TCP / CMD / File checks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Dockerfile + docker-compose output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Timing validation warnings</span>
  </div>
  <DockerHealthcheckGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Docker HEALTHCHECK Generator" relatedTags={['docker', 'devops', 'containers', 'kubernetes', 'developer-tools']} />
</BaseLayout>
