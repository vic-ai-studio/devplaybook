---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NativewindStyleConverter from '../../components/NativewindStyleConverter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is NativeWind?", answer: "NativeWind brings Tailwind CSS utility classes to React Native. Instead of React Native's StyleSheet.create({}) objects, you write className='flex-1 bg-white p-4' on your components — just like in web development. NativeWind translates these classes to React Native StyleSheet objects at build time (or via CSS variables on the New Architecture). It works with Expo and bare React Native projects." },
  { question: "How is NativeWind different from using Tailwind in a web app?", answer: "NativeWind uses a subset of Tailwind classes that map to React Native style properties. Not all CSS properties are available — unsupported properties include box-shadow (use shadow-* classes instead), CSS grid (no equivalent), CSS animations (use Animated API), and some pseudo-classes. NativeWind also supports React Native-specific utilities like native: and ios:/android: platform variants." },
  { question: "Does every CSS property have a NativeWind equivalent?", answer: "No. NativeWind supports layout (flexbox), spacing, sizing, typography, colors, borders, opacity, and shadows. CSS properties without React Native equivalents — like background-image, CSS grid, clip-path, filter, or advanced pseudo-selectors — don't have NativeWind classes. For those, use inline styles with the style prop alongside className." },
  { question: "How do I install NativeWind v4?", answer: "Install: npm install nativewind tailwindcss. Initialize Tailwind: npx tailwindcss init. Add NativeWind preset to tailwind.config.js: presets: [require('nativewind/preset')]. Add the Babel plugin to babel.config.js: plugins: ['nativewind/babel']. For Expo: add NativeWind to metro.config.js and app-level global.css. Run expo start and add className to your components." },
  { question: "How do platform variants work in NativeWind?", answer: "NativeWind supports ios: and android: variants for platform-specific styles: className='p-4 ios:pt-safe-area-top android:bg-gray-900'. It also supports native: (applies only on native, not web) and web: (applies only when using React Native Web). The dark: variant works the same as in Tailwind but responds to React Native's useColorScheme() hook and Appearance API." },
  { question: "Can I use NativeWind with Expo Router?", answer: "Yes. NativeWind v4 is the recommended styling solution for Expo Router projects. After installing NativeWind, add a global CSS file (global.css with @tailwind base/components/utilities), import it in your root _layout.tsx, and configure metro to handle CSS files. Expo Router's file-based routing works with NativeWind out of the box — each screen component can use className props normally." },
];
---

<BaseLayout
  title="NativeWind Style Converter — CSS to React Native Tailwind Classes"
  description="Convert CSS styles to NativeWind className equivalents for React Native. Paste CSS rules and get Tailwind utility classes for your React Native components. Free tool."
  tool="NativeWind, CSS to React Native, Tailwind React Native, NativeWind converter, React Native styles, Expo styling"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "NativeWind Style Converter",
    "url": "https://devplaybook.cc/tools/nativewind-style-converter",
    "description": "Convert CSS rules to NativeWind/Tailwind className strings for React Native. Paste CSS, get the equivalent NativeWind classes with a React Native component example.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">NativeWind Style Converter</h1>
  <p class="text-text-muted mb-4">Convert <strong>CSS</strong> to <strong>NativeWind</strong> <code class="text-accent font-mono">className</code> equivalents for React Native. Paste CSS rules and get Tailwind utility classes with a component example — ideal for porting web styles to mobile.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 40+ CSS properties</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Component preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Unsupported property hints</span>
  </div>
  <NativewindStyleConverter client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="NativeWind Style Converter" relatedTags={['react-native', 'mobile', 'tailwind', 'css', 'expo', 'nativewind']} />
</BaseLayout>
