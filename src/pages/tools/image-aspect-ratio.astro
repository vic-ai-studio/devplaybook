---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ImageAspectRatio from '../../components/ImageAspectRatio.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "How do I calculate aspect ratio from pixel dimensions?",
    answer: "Divide both width and height by their Greatest Common Divisor (GCD). For 1920×1080: GCD(1920,1080) = 120, so 1920/120 = 16 and 1080/120 = 9, giving 16:9. For 1280×720: GCD = 80, so 1280/80 = 16 and 720/80 = 9 — also 16:9. The decimal ratio is simply width/height = 1.778 for 16:9."
  },
  {
    question: "What aspect ratio should I use for responsive web images?",
    answer: "For hero images: 16:9 (1920×1080) is the web standard. For thumbnails: 3:2 (600×400) or 4:3. For social cards (Open Graph): 1.91:1 (1200×628). For square thumbnails: 1:1. For portrait (mobile): 9:16 or 3:4. Use the srcset helper to generate all needed sizes for responsive images."
  },
  {
    question: "What is the padding-top trick for responsive aspect ratios in CSS?",
    answer: "Use percentage padding-top to maintain aspect ratio: for 16:9, set padding-top: 56.25% (9/16 × 100). For 4:3, use padding-top: 75%. In modern CSS, use the aspect-ratio property instead: aspect-ratio: 16/9. The padding-top trick is needed for older browser support only."
  },
  {
    question: "What srcset sizes should I generate for responsive images?",
    answer: "A good starting set covers the common viewport widths: 480w (mobile small), 640w (mobile standard), 768w (tablet portrait), 1024w (tablet landscape), 1280w (laptop), 1920w (desktop full HD). Add 2x versions (e.g. 960w for 480w containers) if supporting high-DPI displays. Use WebP or AVIF format for best compression at each size."
  },
  {
    question: "What aspect ratio is best for video thumbnails?",
    answer: "YouTube, Vimeo, and all major video platforms use 16:9 (1920x1080 or 1280x720) as the standard video thumbnail aspect ratio. Shorts/Reels use 9:16 (vertical). For custom video players on the web, 16:9 is the safe default. Never use 4:3 for new video content -- it will letterbox on widescreen displays."
  },
];
---

<BaseLayout
  title="Image Aspect Ratio Calculator — Calculate Ratios, Dimensions & srcset"
  description="Calculate image aspect ratios from pixel dimensions, derive missing dimensions from a ratio, and generate responsive srcset sizes. Free, runs 100% in your browser."
  tool="image aspect ratio calculator, aspect ratio from dimensions, responsive srcset generator, image dimensions calculator, 16:9 calculator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Image Aspect Ratio Calculator",
    "url": "https://devplaybook.cc/tools/image-aspect-ratio",
    "description": "Calculate image aspect ratios, derive dimensions, and generate responsive srcset sizes. Free, runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Image Aspect Ratio Calculator</h1>
  <p class="text-text-muted mb-4">
    Calculate the aspect ratio from pixel dimensions, derive missing dimensions from a known ratio, or generate a responsive <code class="font-mono bg-surface px-1 rounded text-sm">srcset</code> for any image size. All calculations run in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Dimensions to ratio simplification</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Ratio to missing dimension</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Responsive srcset generator</span>
  </div>
  <ImageAspectRatio client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Image Aspect Ratio Calculator" relatedTags={['images', 'css', 'responsive', 'design', 'html', 'media']} />
</BaseLayout>
