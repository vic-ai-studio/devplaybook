---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CssTransitionGenerator from '../../components/CssTransitionGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="CSS Transition Generator — Build & Preview CSS Transitions Instantly"
  description="Generate CSS transition declarations with live preview. Configure property, duration, delay, and timing function. Copy the ready-to-use CSS snippet — all in your browser, no sign-up needed."
  tool="CSS Transition Generator, CSS Transition Builder, CSS Animation Tool, Transition Preview"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "CSS Transition Generator",
    "description": "Free CSS transition generator with live preview. Configure property, duration, delay and timing function, then copy the CSS snippet instantly.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Web",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "url": "https://devplaybook.cc/tools/css-transition-generator"
  })} />
  <h1 class="text-3xl font-bold mb-2">CSS Transition Generator</h1>
  <p class="text-text-muted mb-8">Build CSS transitions visually. Choose the property, duration, delay, and timing function — hover the live preview to see the result, then copy the generated snippet.</p>
  <CssTransitionGenerator client:only="preact" />
  <ToolPageCta currentTool="CSS Transition Generator" relatedTags={['css', 'transitions', 'animation', 'design', 'frontend']} />
</BaseLayout>
