---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the difference between MIT and Apache 2.0?", answer: "Both are permissive licenses that let anyone use, modify, and redistribute your code. The key difference: Apache 2.0 explicitly grants patent rights and requires documenting changes to the code. MIT is simpler and shorter. For most projects, MIT is fine. If you want patent protection for users, use Apache 2.0." },
  { question: "When should I use GPL vs MIT?", answer: "GPL is 'copyleft' — any project that uses GPL code must also be GPL (this is called the 'viral' effect). Use GPL when you want to ensure derivatives remain open source. MIT is permissive — anyone can incorporate it into commercial or closed-source products. Most companies avoid GPL dependencies for this reason." },
  { question: "What is the difference between GPL v2 and GPL v3?", answer: "GPL v3 adds protections against 'tivoization' (using GPL software in locked hardware that can't run modified versions), patent retaliation clauses, and compatibility with more licenses. Linux kernel uses GPLv2. If you're unsure, GPLv3 is generally considered more protective of user freedoms." },
  { question: "Can I use MIT-licensed code in a commercial product?", answer: "Yes. MIT allows use in commercial products, closed-source software, SaaS, and any distribution — as long as you include the MIT license text and copyright notice. This is why MIT is the most popular license on GitHub; it maximizes adoption including by companies." },
  { question: "What is the Unlicense / CC0 and when should I use them?", answer: "Unlicense and CC0 effectively place work in the public domain — no attribution required, no restrictions. Use them for simple utilities, code snippets, or reference implementations where you want zero friction for users. Note: some jurisdictions don't fully recognize public domain dedication; Unlicense includes a fallback permissive license." },
  { question: "What does 'must disclose source' mean in copyleft licenses?", answer: "If your project uses a GPL or AGPL library and you distribute the software (or run it as a service for AGPL), you must make the complete corresponding source code available to users. This doesn't apply to private internal use. Purely permissive licenses (MIT, Apache, BSD) never require this." },
];
---

<BaseLayout
  title="Open Source License Picker — Compare MIT, Apache, GPL, and More"
  description="Compare open source licenses (MIT, Apache 2.0, GPL v2/v3, LGPL, AGPL, BSD, MPL, ISC, Unlicense) side by side. Filter by permission and choose the right license for your project. Free, runs in your browser."
  tool="open source license picker, license comparison, MIT vs Apache, GPL license chooser, software license guide, choose a license"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Open Source License Picker",
    "url": "https://devplaybook.cc/tools/license-picker",
    "description": "Compare open source licenses side by side and choose the right one for your project. Covers MIT, Apache 2.0, GPL, LGPL, AGPL, BSD, MPL, ISC, and Unlicense.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Open Source License Picker</h1>
  <p class="text-text-muted mb-6">
    Compare popular open source licenses and choose the right one for your project.
    Filter by what you allow — commercial use, modifications, distribution, and more.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 10 licenses compared</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Filter by permissions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy license text</span>
  </div>

  <div id="picker-app" class="space-y-6">
    <!-- Filters -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="text-sm font-semibold mb-3 text-text-muted uppercase tracking-wide">Filter by requirements</h2>
      <div class="flex flex-wrap gap-3">
        <label class="flex items-center gap-2 text-sm cursor-pointer bg-bg border border-border px-3 py-1.5 rounded-lg">
          <input type="checkbox" id="filter-commercial" class="rounded" /> Allow commercial use
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer bg-bg border border-border px-3 py-1.5 rounded-lg">
          <input type="checkbox" id="filter-closed" class="rounded" /> Allow closed-source derivatives
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer bg-bg border border-border px-3 py-1.5 rounded-lg">
          <input type="checkbox" id="filter-no-patent" class="rounded" /> Explicit patent grant
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer bg-bg border border-border px-3 py-1.5 rounded-lg">
          <input type="checkbox" id="filter-no-attribution" class="rounded" /> No attribution required
        </label>
      </div>
    </div>

    <!-- License cards -->
    <div id="license-grid" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>

    <!-- Full text modal -->
    <div id="license-modal" class="hidden fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4">
      <div class="bg-bg-card border border-border rounded-xl w-full max-w-2xl max-h-[80vh] flex flex-col">
        <div class="flex items-center justify-between p-4 border-b border-border">
          <h3 id="modal-title" class="font-semibold"></h3>
          <div class="flex gap-2">
            <button id="copy-license-btn" class="text-xs px-3 py-1.5 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors">Copy</button>
            <button id="close-modal-btn" class="text-xs px-3 py-1.5 bg-surface-2 border border-border rounded-lg hover:bg-surface-3 transition-colors">Close</button>
          </div>
        </div>
        <pre id="modal-text" class="p-4 text-xs font-mono overflow-y-auto whitespace-pre-wrap text-text-muted"></pre>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="License Picker" relatedTags={['open-source', 'licensing', 'git', 'github', 'legal']} />
</BaseLayout>

<script>
  type Permission = 'commercial' | 'modification' | 'distribution' | 'private' | 'patent' | 'sublicense';
  type Condition = 'disclose-source' | 'license-and-copyright' | 'same-license' | 'network-use-is-distribution' | 'document-changes';
  type Limitation = 'liability' | 'warranty' | 'trademark';

  interface License {
    id: string;
    name: string;
    spdx: string;
    type: 'permissive' | 'copyleft' | 'weak-copyleft' | 'public-domain';
    summary: string;
    permissions: Permission[];
    conditions: Condition[];
    limitations: Limitation[];
    commercial: boolean;
    closedSource: boolean;
    patentGrant: boolean;
    attributionRequired: boolean;
    template: string;
  }

  const LICENSES: License[] = [
    {
      id: 'mit',
      name: 'MIT License',
      spdx: 'MIT',
      type: 'permissive',
      summary: 'Simple and permissive. Use for maximum adoption. Attribution required.',
      permissions: ['commercial', 'modification', 'distribution', 'private', 'sublicense'],
      conditions: ['license-and-copyright'],
      limitations: ['liability', 'warranty'],
      commercial: true, closedSource: true, patentGrant: false, attributionRequired: true,
      template: `MIT License

Copyright (c) [year] [fullname]

Permission is hereby granted, free of charge, to any person obtaining a copy
of this software and associated documentation files (the "Software"), to deal
in the Software without restriction, including without limitation the rights
to use, copy, modify, merge, publish, distribute, sublicense, and/or sell
copies of the Software, and to permit persons to whom the Software is
furnished to do so, subject to the following conditions:

The above copyright notice and this permission notice shall be included in all
copies or substantial portions of the Software.

THE SOFTWARE IS PROVIDED "AS IS", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR
IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,
FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE
AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER
LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,
OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE
SOFTWARE.`,
    },
    {
      id: 'apache2',
      name: 'Apache License 2.0',
      spdx: 'Apache-2.0',
      type: 'permissive',
      summary: 'Permissive with explicit patent grant. Good for enterprise use.',
      permissions: ['commercial', 'modification', 'distribution', 'private', 'patent', 'sublicense'],
      conditions: ['license-and-copyright', 'document-changes'],
      limitations: ['liability', 'warranty', 'trademark'],
      commercial: true, closedSource: true, patentGrant: true, attributionRequired: true,
      template: `Apache License
Version 2.0, January 2004

Copyright [yyyy] [name of copyright owner]

Licensed under the Apache License, Version 2.0 (the "License");
you may not use this file except in compliance with the License.
You may obtain a copy of the License at

    https://www.apache.org/licenses/LICENSE-2.0

Unless required by applicable law or agreed to in writing, software
distributed under the License is distributed on an "AS IS" BASIS,
WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
See the License for the specific language governing permissions and
limitations under the License.`,
    },
    {
      id: 'gpl3',
      name: 'GNU GPL v3',
      spdx: 'GPL-3.0-only',
      type: 'copyleft',
      summary: 'Strong copyleft. Derivatives must also be GPL v3. Prevents proprietary forks.',
      permissions: ['commercial', 'modification', 'distribution', 'private', 'patent'],
      conditions: ['disclose-source', 'license-and-copyright', 'same-license', 'document-changes'],
      limitations: ['liability', 'warranty'],
      commercial: true, closedSource: false, patentGrant: true, attributionRequired: true,
      template: `GNU GENERAL PUBLIC LICENSE
Version 3, 29 June 2007

Copyright (C) [year] [name of author]

This program is free software: you can redistribute it and/or modify
it under the terms of the GNU General Public License as published by
the Free Software Foundation, either version 3 of the License, or
(at your option) any later version.

This program is distributed in the hope that it will be useful,
but WITHOUT ANY WARRANTY; without even the implied warranty of
MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE. See the
GNU General Public License for more details.`,
    },
    {
      id: 'gpl2',
      name: 'GNU GPL v2',
      spdx: 'GPL-2.0-only',
      type: 'copyleft',
      summary: 'Strong copyleft. Used by Linux kernel. Slightly less restrictive on patents.',
      permissions: ['commercial', 'modification', 'distribution', 'private'],
      conditions: ['disclose-source', 'license-and-copyright', 'same-license', 'document-changes'],
      limitations: ['liability', 'warranty'],
      commercial: true, closedSource: false, patentGrant: false, attributionRequired: true,
      template: `GNU GENERAL PUBLIC LICENSE
Version 2, June 1991

Copyright (C) [year] [name of author]

This program is free software; you can redistribute it and/or modify
it under the terms of the GNU General Public License as published by
the Free Software Foundation; either version 2 of the License, or
(at your option) any later version.`,
    },
    {
      id: 'lgpl3',
      name: 'GNU LGPL v3',
      spdx: 'LGPL-3.0-only',
      type: 'weak-copyleft',
      summary: 'Weak copyleft. Libraries can be used in proprietary software via dynamic linking.',
      permissions: ['commercial', 'modification', 'distribution', 'private', 'patent'],
      conditions: ['disclose-source', 'license-and-copyright', 'same-license', 'document-changes'],
      limitations: ['liability', 'warranty'],
      commercial: true, closedSource: true, patentGrant: true, attributionRequired: true,
      template: `GNU LESSER GENERAL PUBLIC LICENSE
Version 3, 29 June 2007

Copyright (C) [year] [name of author]

Everyone is permitted to copy and distribute verbatim copies of this license document,
but changing it is not allowed.

This version of the GNU Lesser General Public License incorporates the terms and
conditions of version 3 of the GNU General Public License, supplemented by the
additional permissions listed below.`,
    },
    {
      id: 'agpl3',
      name: 'GNU AGPL v3',
      spdx: 'AGPL-3.0-only',
      type: 'copyleft',
      summary: 'Strongest copyleft. Network use counts as distribution. Ideal for SaaS.',
      permissions: ['commercial', 'modification', 'distribution', 'private', 'patent'],
      conditions: ['disclose-source', 'license-and-copyright', 'same-license', 'document-changes', 'network-use-is-distribution'],
      limitations: ['liability', 'warranty'],
      commercial: true, closedSource: false, patentGrant: true, attributionRequired: true,
      template: `GNU AFFERO GENERAL PUBLIC LICENSE
Version 3, 19 November 2007

Copyright (C) [year] [name of author]

This program is free software: you can redistribute it and/or modify
it under the terms of the GNU Affero General Public License as published by
the Free Software Foundation, either version 3 of the License, or
(at your option) any later version.`,
    },
    {
      id: 'bsd2',
      name: 'BSD 2-Clause',
      spdx: 'BSD-2-Clause',
      type: 'permissive',
      summary: 'Similar to MIT. Two conditions: attribution and no endorsement.',
      permissions: ['commercial', 'modification', 'distribution', 'private'],
      conditions: ['license-and-copyright'],
      limitations: ['liability', 'warranty'],
      commercial: true, closedSource: true, patentGrant: false, attributionRequired: true,
      template: `BSD 2-Clause "Simplified" License

Copyright (c) [year], [fullname]
All rights reserved.

Redistribution and use in source and binary forms, with or without
modification, are permitted provided that the following conditions are met:

1. Redistributions of source code must retain the above copyright notice, this
   list of conditions and the following disclaimer.

2. Redistributions in binary form must reproduce the above copyright notice,
   this list of conditions and the following disclaimer in the documentation
   and/or other materials provided with the distribution.`,
    },
    {
      id: 'mpl2',
      name: 'Mozilla MPL 2.0',
      spdx: 'MPL-2.0',
      type: 'weak-copyleft',
      summary: 'File-level copyleft. Modified files must stay MPL; new files can be proprietary.',
      permissions: ['commercial', 'modification', 'distribution', 'private', 'patent'],
      conditions: ['disclose-source', 'license-and-copyright'],
      limitations: ['liability', 'warranty', 'trademark'],
      commercial: true, closedSource: true, patentGrant: true, attributionRequired: true,
      template: `Mozilla Public License 2.0

This Source Code Form is subject to the terms of the Mozilla Public
License, v. 2.0. If a copy of the MPL was not distributed with this
file, You can obtain one at https://mozilla.org/MPL/2.0/.`,
    },
    {
      id: 'isc',
      name: 'ISC License',
      spdx: 'ISC',
      type: 'permissive',
      summary: 'Functionally equivalent to MIT. Shorter text. Used by OpenBSD and npm.',
      permissions: ['commercial', 'modification', 'distribution', 'private'],
      conditions: ['license-and-copyright'],
      limitations: ['liability', 'warranty'],
      commercial: true, closedSource: true, patentGrant: false, attributionRequired: true,
      template: `ISC License

Copyright (c) [year], [fullname]

Permission to use, copy, modify, and/or distribute this software for any
purpose with or without fee is hereby granted, provided that the above
copyright notice and this permission notice appear in all copies.

THE SOFTWARE IS PROVIDED "AS IS" AND THE AUTHOR DISCLAIMS ALL WARRANTIES
WITH REGARD TO THIS SOFTWARE INCLUDING ALL IMPLIED WARRANTIES OF
MERCHANTABILITY AND FITNESS. IN NO EVENT SHALL THE AUTHOR BE LIABLE FOR
ANY SPECIAL, DIRECT, INDIRECT, OR CONSEQUENTIAL DAMAGES OR ANY DAMAGES
WHATSOEVER RESULTING FROM LOSS OF USE, DATA OR PROFITS, WHETHER IN AN
ACTION OF CONTRACT, NEGLIGENCE OR OTHER TORTIOUS ACTION, ARISING OUT OF
OR IN CONNECTION WITH THE USE OR PERFORMANCE OF THIS SOFTWARE.`,
    },
    {
      id: 'unlicense',
      name: 'The Unlicense',
      spdx: 'Unlicense',
      type: 'public-domain',
      summary: 'Effectively public domain. No conditions, no attribution needed.',
      permissions: ['commercial', 'modification', 'distribution', 'private'],
      conditions: [],
      limitations: ['liability', 'warranty'],
      commercial: true, closedSource: true, patentGrant: false, attributionRequired: false,
      template: `This is free and unencumbered software released into the public domain.

Anyone is free to copy, modify, publish, use, compile, sell, or
distribute this software, either in source code form or as a compiled
binary, for any purpose, commercial or non-commercial, and by any means.

In jurisdictions that recognize copyright laws, the author or authors
of this software dedicate any and all copyright interest in the
software to the public domain.

THE SOFTWARE IS PROVIDED "AS IS", WITHOUT WARRANTY OF ANY KIND,
EXPRESS OR IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF
MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT.
IN NO EVENT SHALL THE AUTHORS BE LIABLE FOR ANY CLAIM, DAMAGES OR
OTHER LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE,
ARISING FROM, OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR
OTHER DEALINGS IN THE SOFTWARE.`,
    },
  ];

  const TYPE_COLORS: Record<string, string> = {
    permissive: 'text-green-500 bg-green-500/10 border-green-500/30',
    'weak-copyleft': 'text-yellow-500 bg-yellow-500/10 border-yellow-500/30',
    copyleft: 'text-red-400 bg-red-500/10 border-red-500/30',
    'public-domain': 'text-blue-400 bg-blue-500/10 border-blue-500/30',
  };

  const TYPE_LABELS: Record<string, string> = {
    permissive: 'Permissive',
    'weak-copyleft': 'Weak Copyleft',
    copyleft: 'Copyleft',
    'public-domain': 'Public Domain',
  };

  function icon(ok: boolean) {
    return ok
      ? '<span class="text-green-500 font-bold">✓</span>'
      : '<span class="text-red-400">✕</span>';
  }

  function renderCards(filtered: License[]) {
    const grid = document.getElementById('license-grid') as HTMLElement;
    if (filtered.length === 0) {
      grid.innerHTML = '<p class="text-text-muted col-span-2 text-sm py-8 text-center">No licenses match the selected filters.</p>';
      return;
    }
    grid.innerHTML = filtered.map(l => `
      <div class="bg-bg-card border border-border rounded-xl p-5 flex flex-col gap-3">
        <div class="flex items-start justify-between gap-2">
          <div>
            <h3 class="font-semibold text-base">${l.name}</h3>
            <code class="text-xs text-text-muted">${l.spdx}</code>
          </div>
          <span class="text-xs px-2 py-0.5 rounded border font-medium ${TYPE_COLORS[l.type] || ''}">${TYPE_LABELS[l.type] || l.type}</span>
        </div>
        <p class="text-sm text-text-muted">${l.summary}</p>
        <div class="grid grid-cols-2 gap-1.5 text-xs">
          <span class="flex items-center gap-1.5">${icon(l.commercial)} Commercial use</span>
          <span class="flex items-center gap-1.5">${icon(l.closedSource)} Closed-source</span>
          <span class="flex items-center gap-1.5">${icon(l.patentGrant)} Patent grant</span>
          <span class="flex items-center gap-1.5">${icon(!l.attributionRequired)} No attribution</span>
        </div>
        ${l.conditions.length > 0 ? `<div class="text-xs text-text-muted">
          <span class="font-medium text-text">Conditions: </span>${l.conditions.map(c => c.replace(/-/g,' ')).join(', ')}
        </div>` : ''}
        <button data-id="${l.id}" class="view-btn mt-auto text-xs px-3 py-1.5 border border-border rounded-lg hover:border-primary hover:text-primary transition-colors text-left">
          View license text →
        </button>
      </div>
    `).join('');

    document.querySelectorAll('.view-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.id;
        const license = LICENSES.find(l => l.id === id);
        if (!license) return;
        (document.getElementById('modal-title') as HTMLElement).textContent = license.name;
        (document.getElementById('modal-text') as HTMLElement).textContent = license.template;
        document.getElementById('license-modal')?.classList.remove('hidden');
      });
    });
  }

  function applyFilters() {
    const filterCommercial = (document.getElementById('filter-commercial') as HTMLInputElement).checked;
    const filterClosed = (document.getElementById('filter-closed') as HTMLInputElement).checked;
    const filterPatent = (document.getElementById('filter-no-patent') as HTMLInputElement).checked;
    const filterNoAttrib = (document.getElementById('filter-no-attribution') as HTMLInputElement).checked;

    const filtered = LICENSES.filter(l => {
      if (filterCommercial && !l.commercial) return false;
      if (filterClosed && !l.closedSource) return false;
      if (filterPatent && !l.patentGrant) return false;
      if (filterNoAttrib && l.attributionRequired) return false;
      return true;
    });
    renderCards(filtered);
  }

  // Initial render
  renderCards(LICENSES);

  // Filter listeners
  ['filter-commercial', 'filter-closed', 'filter-no-patent', 'filter-no-attribution'].forEach(id => {
    document.getElementById(id)?.addEventListener('change', applyFilters);
  });

  // Modal
  document.getElementById('close-modal-btn')?.addEventListener('click', () => {
    document.getElementById('license-modal')?.classList.add('hidden');
  });
  document.getElementById('license-modal')?.addEventListener('click', (e) => {
    if (e.target === document.getElementById('license-modal')) {
      document.getElementById('license-modal')?.classList.add('hidden');
    }
  });
  document.getElementById('copy-license-btn')?.addEventListener('click', () => {
    const text = (document.getElementById('modal-text') as HTMLElement).textContent || '';
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById('copy-license-btn') as HTMLButtonElement;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
    });
  });
</script>
