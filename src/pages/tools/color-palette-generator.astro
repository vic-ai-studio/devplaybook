---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ColorPaletteGenerator from '../../components/ColorPaletteGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---
<BaseLayout
  title="Color Palette Generator — HEX to Tailwind Shades, Complementary & More"
  description="Generate color palettes from any HEX color. Create Tailwind-style shade scales, complementary, triadic, analogous, and tetradic palettes. Copy CSS custom properties instantly."
  tool="Color Palette Generator, Tailwind Color Shades, Complementary Colors, CSS Color Variables"
>
  <h1 class="text-3xl font-bold mb-2">Color Palette Generator</h1>
  <p class="text-text-muted mb-8">Enter any hex color to generate a complete palette — Tailwind-style shades, complementary, triadic, analogous, and more. Click any swatch to copy its hex. Export as CSS custom properties.</p>
  <ColorPaletteGenerator client:only="preact" />
  <ToolPageCta currentTool="Color Palette Generator" relatedTags={['color', 'css', 'design', 'palette', 'tailwind']} />
</BaseLayout>
