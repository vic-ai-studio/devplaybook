---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ColorPaletteGenerator from '../../components/ColorPaletteGenerator.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "How do I generate a color palette from a hex color?", answer: "Enter any hex color (e.g. #3b82f6) in the input field. The tool instantly generates Tailwind-style shades (50–900), complementary, triadic, analogous, and tetradic palettes. Click any swatch to copy its hex value." },
  { question: "What is the difference between complementary and triadic colors?", answer: "Complementary colors are directly opposite on the color wheel (180° apart) — high contrast, great for CTAs. Triadic colors are evenly spaced 120° apart — vibrant and balanced, good for playful designs. Analogous colors are adjacent (30° apart) — harmonious and calm." },
  { question: "How do I export colors as CSS custom properties?", answer: "After generating a palette, click the 'Export CSS' button. You'll get a :root block with CSS variables like --color-50, --color-100, ..., --color-900 ready to paste into your stylesheet." },
  { question: "What are Tailwind-style shades?", answer: "Tailwind CSS uses a numeric shade scale from 50 (lightest) to 900 (darkest) for each color. This generator creates the same 10-stop scale from your input hex, making it easy to extend an existing Tailwind config or build consistent UI components." },
  { question: "Is this tool free and does it send data anywhere?", answer: "Yes, it's completely free. All color calculations run in your browser using JavaScript — no data is sent to any server. You can use it offline once the page has loaded." },
];
---

<BaseLayout
  title="Color Palette Generator — HEX to Tailwind Shades, Complementary & More"
  description="Generate color palettes from any HEX color. Create Tailwind-style shade scales, complementary, triadic, analogous, and tetradic palettes. Copy CSS custom properties instantly. Free, runs in your browser."
  tool="Color Palette Generator, Tailwind Color Shades, Complementary Colors, CSS Color Variables"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Color Palette Generator</h1>
  <p class="text-text-muted mb-4">Enter any hex color to generate a complete palette — Tailwind-style shades, complementary, triadic, analogous, and more. Click any swatch to copy its hex. Export as CSS custom properties.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <ColorPaletteGenerator client:only="preact" />
  <!-- Ad slot below tool output — highest CTR position (user pauses after using the tool) -->
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <AffiliateSection category="deployment" />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more color tools?</p>
    <a href="/tools/color-converter" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Color Converter (HEX/RGB/HSL) →</a>
  </div>
  <ToolPageCta currentTool="Color Palette Generator" relatedTags={['color', 'css', 'design', 'palette', 'tailwind']} />
</BaseLayout>
