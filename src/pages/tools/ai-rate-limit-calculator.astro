---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How do OpenAI rate limits work?", answer: "OpenAI enforces two main limits per minute: RPM (requests per minute) and TPM (tokens per minute). Both limits reset every 60 seconds. If you hit either limit, subsequent requests receive a 429 error. Higher tiers offer dramatically higher limits — Tier 5 allows 10,000 RPM and 30M TPM vs Free tier's 3 RPM and 40K TPM." },
  { question: "What is burst capacity?", answer: "Burst capacity is how many requests or tokens you can fire instantly before hitting a rate limit. Since limits reset per minute, if you send 100 requests in the first 5 seconds on Tier 1 (500 RPM limit), you'll exhaust 20% of your minute budget immediately. Burst capacity = the total limit, since OpenAI doesn't enforce sub-minute buckets." },
  { question: "How many parallel workers should I run?", answer: "The recommended parallel worker count is based on distributing requests evenly over 60 seconds. For example, 500 RPM with 8 requests/second means you need roughly 8 workers, each firing 1 request/second. Running too many workers causes bursty traffic and 429s; too few leaves capacity unused." },
  { question: "What happens when I hit the TPM limit?", answer: "Token limits are often the binding constraint for long-context workloads. If your batch has 1,000 requests averaging 2,000 tokens each (2M tokens total) and your TPM is 200K, it'll take 10 minutes to process, not 2 minutes. This calculator shows which limit (RPM vs TPM) is the actual bottleneck." },
  { question: "Can I increase my OpenAI rate limits?", answer: "Yes. OpenAI automatically upgrades tiers based on pre-paid credits. Tier 1 requires $5 paid, Tier 2 requires $50 paid + 7-day account age, Tier 3 requires $100 paid + 7 days, Tier 4 requires $250 paid + 14 days, Tier 5 requires $1,000 paid + 30 days. Limits reset every minute regardless of tier." },
];

const tiers = [
  { name: 'Free', rpm: 3, tpm: 40000 },
  { name: 'Tier 1', rpm: 500, tpm: 200000 },
  { name: 'Tier 2', rpm: 5000, tpm: 2000000 },
  { name: 'Tier 3', rpm: 5000, tpm: 4000000 },
  { name: 'Tier 4', rpm: 10000, tpm: 10000000 },
  { name: 'Tier 5', rpm: 10000, tpm: 30000000 },
];
---

<BaseLayout
  title="AI Rate Limit Calculator — OpenAI RPM & TPM Tier Planner"
  description="Calculate OpenAI API rate limit scenarios for all tiers. Input your request volume and token size to see burst capacity, time to exhaust limits, parallel worker recommendations, and which limit is your bottleneck."
  tool="AI Rate Limit Calculator, OpenAI Rate Limits, RPM TPM Calculator, API Throttling Planner, OpenAI Tier Calculator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">AI Rate Limit Calculator</h1>
  <p class="text-text-muted mb-4">Plan your OpenAI API usage across all tiers. Calculate burst capacity, processing time, and parallel worker needs before hitting 429 errors in production.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All 6 OpenAI tiers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> RPM & TPM bottleneck detection</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Parallel worker recommendation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs in your browser</span>
  </div>

  <!-- Tier selector + custom inputs -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="text-sm font-semibold mb-3">OpenAI Tier Preset</h2>
      <div class="grid grid-cols-3 gap-2 mb-4" id="tier-buttons">
        {tiers.map((t, i) => (
          <button
            class={`tier-btn text-sm px-3 py-2 rounded-lg border transition-all ${i === 1 ? 'border-primary text-primary bg-primary/10 font-semibold' : 'border-border text-text-muted hover:border-primary hover:text-primary'}`}
            data-rpm={t.rpm}
            data-tpm={t.tpm}
            data-name={t.name}
          >
            {t.name}
          </button>
        ))}
      </div>

      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs text-text-muted mb-1">Requests / min (RPM)</label>
          <input id="rpm-input" type="number" min="1" value="500"
            class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">Tokens / min (TPM)</label>
          <input id="tpm-input" type="number" min="1" value="200000"
            class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
      </div>
    </div>

    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="text-sm font-semibold mb-3">Your Workload</h2>
      <div class="space-y-3">
        <div>
          <label class="block text-xs text-text-muted mb-1">Avg tokens per request</label>
          <div class="flex gap-2 flex-wrap mb-2">
            <button class="tok-preset text-xs px-2.5 py-1 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-val="500">500 (short)</button>
            <button class="tok-preset text-xs px-2.5 py-1 rounded-full border border-primary text-primary bg-primary/10 transition-all" data-val="2000">2K (medium)</button>
            <button class="tok-preset text-xs px-2.5 py-1 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-val="8000">8K (long)</button>
            <button class="tok-preset text-xs px-2.5 py-1 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-val="32000">32K (max)</button>
          </div>
          <input id="tokens-per-req" type="number" min="1" value="2000"
            class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">Total requests in batch</label>
          <input id="batch-size" type="number" min="1" value="1000"
            class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
      </div>
    </div>
  </div>

  <!-- Results -->
  <div id="results" class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
    <!-- Bottleneck card -->
    <div class="bg-bg-card border border-border rounded-xl p-5 md:col-span-2">
      <div class="flex items-center gap-3 mb-4">
        <div id="bottleneck-badge" class="text-xs font-bold px-3 py-1 rounded-full">—</div>
        <span class="text-sm text-text-muted" id="bottleneck-desc">—</span>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <div class="text-xs text-text-muted mb-1 font-medium">RPM Usage</div>
          <div class="flex items-center gap-3">
            <div class="flex-1 bg-bg-surface border border-border rounded-full h-3">
              <div id="rpm-bar" class="h-full rounded-full transition-all duration-500 bg-primary/60" style="width: 0%"></div>
            </div>
            <span id="rpm-pct" class="text-xs font-semibold tabular-nums w-10 text-right">0%</span>
          </div>
        </div>
        <div>
          <div class="text-xs text-text-muted mb-1 font-medium">TPM Usage</div>
          <div class="flex items-center gap-3">
            <div class="flex-1 bg-bg-surface border border-border rounded-full h-3">
              <div id="tpm-bar" class="h-full rounded-full transition-all duration-500 bg-primary/60" style="width: 0%"></div>
            </div>
            <span id="tpm-pct" class="text-xs font-semibold tabular-nums w-10 text-right">0%</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Metric cards -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="text-xs text-text-muted mb-1">Requests fit per minute</div>
      <div id="reqs-per-min" class="text-3xl font-black tabular-nums text-primary">—</div>
      <div class="text-xs text-text-muted mt-1">limited by the binding constraint</div>
    </div>

    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="text-xs text-text-muted mb-1">Burst capacity</div>
      <div id="burst-capacity" class="text-3xl font-black tabular-nums text-primary">—</div>
      <div class="text-xs text-text-muted mt-1">requests before hitting limit</div>
    </div>

    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="text-xs text-text-muted mb-1">Time to process batch</div>
      <div id="batch-time" class="text-3xl font-black tabular-nums" style="color: #f59e0b">—</div>
      <div class="text-xs text-text-muted mt-1">at sustained rate</div>
    </div>

    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="text-xs text-text-muted mb-1">Rate limit reset</div>
      <div class="text-3xl font-black tabular-nums text-green-500">60s</div>
      <div class="text-xs text-text-muted mt-1">OpenAI resets limits every minute</div>
    </div>

    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="text-xs text-text-muted mb-1">Recommended parallel workers</div>
      <div id="workers" class="text-3xl font-black tabular-nums text-primary">—</div>
      <div class="text-xs text-text-muted mt-1" id="workers-desc">—</div>
    </div>

    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="text-xs text-text-muted mb-1">Requests / second (sustained)</div>
      <div id="req-per-sec" class="text-3xl font-black tabular-nums text-primary">—</div>
      <div class="text-xs text-text-muted mt-1">safe sustained rate</div>
    </div>
  </div>

  <!-- Tier comparison table -->
  <h2 class="text-base font-semibold mb-4">Tier Comparison for Your Workload</h2>
  <div class="overflow-x-auto mb-8">
    <table class="w-full text-sm min-w-[560px]">
      <thead>
        <tr class="text-text-muted text-xs uppercase border-b border-border">
          <th class="text-left pb-3 pr-4 font-medium">Tier</th>
          <th class="text-right pb-3 pr-4 font-medium">RPM</th>
          <th class="text-right pb-3 pr-4 font-medium">TPM</th>
          <th class="text-right pb-3 pr-4 font-medium">Reqs/min</th>
          <th class="text-right pb-3 pr-4 font-medium">Batch time</th>
          <th class="text-right pb-3 font-medium">Workers</th>
        </tr>
      </thead>
      <tbody id="tier-table" class="divide-y divide-border">
        {tiers.map(t => (
          <tr class="tier-row hover:bg-bg-card/50 transition-colors" data-rpm={t.rpm} data-tpm={t.tpm} data-name={t.name}>
            <td class="py-3 pr-4 font-semibold">{t.name}</td>
            <td class="py-3 pr-4 text-right tabular-nums text-text-muted">{t.rpm.toLocaleString()}</td>
            <td class="py-3 pr-4 text-right tabular-nums text-text-muted">{(t.tpm / 1000).toFixed(0)}K</td>
            <td class="py-3 pr-4 text-right tabular-nums font-medium tier-rpm-eff">—</td>
            <td class="py-3 pr-4 text-right tabular-nums tier-batch-time">—</td>
            <td class="py-3 text-right tabular-nums tier-workers">—</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="AI Rate Limit Calculator" relatedTags={['ai', 'openai', 'api', 'rate-limit', 'llm', 'performance']} />
</BaseLayout>

<script>
  function formatDuration(seconds) {
    if (seconds < 60) return Math.ceil(seconds) + 's';
    if (seconds < 3600) {
      var m = Math.floor(seconds / 60);
      var s = Math.ceil(seconds % 60);
      return s > 0 ? m + 'm ' + s + 's' : m + 'm';
    }
    var h = Math.floor(seconds / 3600);
    var rem = Math.floor((seconds % 3600) / 60);
    return rem > 0 ? h + 'h ' + rem + 'm' : h + 'h';
  }

  function calcMetrics(rpm, tpm, tokensPerReq, batchSize) {
    var rpmEffective = Math.min(rpm, Math.floor(tpm / tokensPerReq));
    var bottleneck = rpm <= Math.floor(tpm / tokensPerReq) ? 'RPM' : 'TPM';
    var batchTimeSec = (batchSize / rpmEffective) * 60;
    var reqPerSec = rpmEffective / 60;
    var workers = Math.max(1, Math.ceil(reqPerSec));
    return {
      rpmEffective: rpmEffective,
      bottleneck: bottleneck,
      batchTimeSec: batchTimeSec,
      reqPerSec: reqPerSec,
      workers: workers,
      rpmPct: Math.min(100, (rpmEffective / rpm) * 100),
      tpmPct: Math.min(100, (rpmEffective * tokensPerReq / tpm) * 100)
    };
  }

  function calculate() {
    var rpm = parseInt(document.getElementById('rpm-input').value) || 500;
    var tpm = parseInt(document.getElementById('tpm-input').value) || 200000;
    var tokensPerReq = parseInt(document.getElementById('tokens-per-req').value) || 2000;
    var batchSize = parseInt(document.getElementById('batch-size').value) || 1000;

    var m = calcMetrics(rpm, tpm, tokensPerReq, batchSize);

    // Bottleneck badge
    var badge = document.getElementById('bottleneck-badge');
    var desc = document.getElementById('bottleneck-desc');
    if (m.bottleneck === 'RPM') {
      badge.textContent = 'Bottleneck: RPM';
      badge.className = 'text-xs font-bold px-3 py-1 rounded-full bg-orange-500/10 text-orange-400 border border-orange-500/20';
      desc.textContent = 'Request rate is the limiting factor. Increasing TPM alone won\'t help.';
    } else {
      badge.textContent = 'Bottleneck: TPM';
      badge.className = 'text-xs font-bold px-3 py-1 rounded-full bg-blue-500/10 text-blue-400 border border-blue-500/20';
      desc.textContent = 'Token volume is the limiting factor. Your requests consume tokens faster than RPM allows.';
    }

    // Bars
    var rpmBar = document.getElementById('rpm-bar');
    rpmBar.style.width = m.rpmPct + '%';
    rpmBar.style.background = m.rpmPct >= 90 ? '#ef4444' : m.rpmPct >= 70 ? '#f59e0b' : '';
    document.getElementById('rpm-pct').textContent = Math.round(m.rpmPct) + '%';

    var tpmBar = document.getElementById('tpm-bar');
    tpmBar.style.width = m.tpmPct + '%';
    tpmBar.style.background = m.tpmPct >= 90 ? '#ef4444' : m.tpmPct >= 70 ? '#f59e0b' : '';
    document.getElementById('tpm-pct').textContent = Math.round(m.tpmPct) + '%';

    // Metric cards
    document.getElementById('reqs-per-min').textContent = m.rpmEffective.toLocaleString();
    document.getElementById('burst-capacity').textContent = m.rpmEffective.toLocaleString();
    document.getElementById('batch-time').textContent = formatDuration(m.batchTimeSec);
    document.getElementById('req-per-sec').textContent = m.reqPerSec < 1
      ? '1/' + Math.ceil(1 / m.reqPerSec) + 's'
      : m.reqPerSec.toFixed(1);
    document.getElementById('workers').textContent = m.workers;
    document.getElementById('workers-desc').textContent =
      'Fire 1 request per worker, ' + (m.reqPerSec < 1 ? 'stagger by ' + Math.ceil(1 / m.reqPerSec) + 's' : 'at ' + m.reqPerSec.toFixed(1) + ' req/s');

    // Tier table
    document.querySelectorAll('.tier-row').forEach(function(row) {
      var tRpm = parseInt(row.getAttribute('data-rpm'));
      var tTpm = parseInt(row.getAttribute('data-tpm'));
      var tm = calcMetrics(tRpm, tTpm, tokensPerReq, batchSize);

      row.querySelector('.tier-rpm-eff').textContent = tm.rpmEffective.toLocaleString();
      row.querySelector('.tier-batch-time').textContent = formatDuration(tm.batchTimeSec);
      row.querySelector('.tier-workers').textContent = tm.workers;
    });
  }

  // Tier button clicks
  document.querySelectorAll('.tier-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.getElementById('rpm-input').value = this.getAttribute('data-rpm');
      document.getElementById('tpm-input').value = this.getAttribute('data-tpm');

      document.querySelectorAll('.tier-btn').forEach(function(b) {
        b.classList.remove('border-primary', 'text-primary', 'bg-primary/10', 'font-semibold');
        b.classList.add('border-border', 'text-text-muted');
      });
      this.classList.add('border-primary', 'text-primary', 'bg-primary/10', 'font-semibold');
      this.classList.remove('border-border', 'text-text-muted');

      calculate();
    });
  });

  // Token presets
  document.querySelectorAll('.tok-preset').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.getElementById('tokens-per-req').value = this.getAttribute('data-val');
      document.querySelectorAll('.tok-preset').forEach(function(b) {
        b.classList.remove('border-primary', 'text-primary', 'bg-primary/10');
        b.classList.add('border-border', 'text-text-muted');
      });
      this.classList.add('border-primary', 'text-primary', 'bg-primary/10');
      this.classList.remove('border-border', 'text-text-muted');
      calculate();
    });
  });

  ['rpm-input', 'tpm-input', 'tokens-per-req', 'batch-size'].forEach(function(id) {
    document.getElementById(id).addEventListener('input', calculate);
  });

  calculate();
</script>
