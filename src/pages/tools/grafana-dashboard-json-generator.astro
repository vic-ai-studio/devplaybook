---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Grafana Dashboard JSON Generator — Build & Export Grafana Dashboards"
  description="Generate Grafana dashboard JSON configurations. Add time series, stat, gauge, and table panels with PromQL or SQL queries. Export ready-to-import Grafana JSON compatible with versions 8+ and 10+. Runs in your browser."
  tool="Grafana dashboard JSON generator, Grafana JSON schema, Grafana panel builder, PromQL dashboard, Grafana export, Grafana 10 dashboard, timeseries panel, stat panel"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Grafana Dashboard JSON Generator",
    "url": "https://devplaybook.cc/tools/grafana-dashboard-json-generator",
    "description": "Generate Grafana dashboard JSON configurations. Add time series, stat, gauge, and table panels with PromQL or SQL queries. Export ready-to-import Grafana JSON for Grafana 8+ and 10+.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Grafana Dashboard JSON Generator</h1>
  <p class="text-text-muted mb-4">Build Grafana dashboards visually. Add time series, stat, gauge, and table panels with PromQL or SQL queries, then export ready-to-import JSON for Grafana 8+ and 10+.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> timeseries, stat, gauge, table panels</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Grafana 8+ / 10+ compatible</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Example CPU+memory dashboard</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs entirely in your browser</span>
  </div>

  <!-- Dashboard metadata -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-5">
    <h2 class="text-sm font-semibold mb-3 text-text-muted uppercase tracking-wide">Dashboard Settings</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium mb-2">Dashboard Title</label>
        <input id="dash-title" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="My Dashboard" value="My Dashboard" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">UID (unique identifier)</label>
        <input id="dash-uid" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="my-dashboard" value="my-dashboard" />
      </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium mb-2">Description</label>
        <input id="dash-description" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="Dashboard description" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Tags (comma-separated)</label>
        <input id="dash-tags" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="prometheus, infra, platform" value="prometheus" />
      </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium mb-2">Time Range</label>
        <select id="dash-timerange" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
          <option value="now-1h">Last 1 hour</option>
          <option value="now-3h">Last 3 hours</option>
          <option value="now-6h" selected>Last 6 hours</option>
          <option value="now-12h">Last 12 hours</option>
          <option value="now-24h">Last 24 hours</option>
          <option value="now-7d">Last 7 days</option>
          <option value="now-30d">Last 30 days</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Refresh Interval</label>
        <select id="dash-refresh" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
          <option value="">Off</option>
          <option value="5s">5s</option>
          <option value="10s">10s</option>
          <option value="30s" selected>30s</option>
          <option value="1m">1m</option>
          <option value="5m">5m</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Default Datasource</label>
        <input id="dash-datasource" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="Prometheus" value="Prometheus" />
      </div>
    </div>
  </div>

  <!-- Panels -->
  <div class="mb-4">
    <div class="flex items-center justify-between mb-3">
      <label class="text-sm font-medium">Panels</label>
      <button id="btn-add-panel" class="flex items-center gap-1.5 px-3 py-1.5 bg-primary text-white rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors">
        <span class="text-base leading-none">+</span> Add Panel
      </button>
    </div>
    <div id="panels-list" class="space-y-4"></div>
  </div>

  <div class="flex gap-3 mb-6 flex-wrap">
    <button id="btn-generate" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Generate Dashboard JSON</button>
    <button id="btn-example-infra" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Load CPU+Memory Example</button>
    <button id="btn-clear" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Clear All</button>
  </div>

  <!-- Output -->
  <div id="output-section" class="hidden">
    <h2 class="text-lg font-semibold mb-3">Dashboard JSON</h2>
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <div class="flex items-center justify-between mb-3">
        <span class="text-xs text-text-muted">Ready to import via Grafana → Dashboards → Import</span>
        <button id="btn-copy" class="px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">Copy JSON</button>
      </div>
      <pre id="json-output" class="font-mono text-sm whitespace-pre-wrap break-words text-yellow-300 overflow-x-auto max-h-[600px] overflow-y-auto"></pre>
    </div>
    <div class="mt-4 p-4 bg-bg-card border border-border rounded-lg">
      <h3 class="text-sm font-semibold mb-2">How to Import</h3>
      <ol class="text-sm text-text-muted space-y-1 list-decimal list-inside">
        <li>Copy the JSON above</li>
        <li>In Grafana, go to <strong>Dashboards → New → Import</strong></li>
        <li>Paste the JSON into the "Import via panel json" field</li>
        <li>Select your datasource and click <strong>Import</strong></li>
      </ol>
    </div>
  </div>

  <ToolPageCta />
</BaseLayout>

<script>
let panels = [];
let panelIdSeq = 0;

const PANEL_TYPE_CONFIG = {
  timeseries: { label: 'Time Series', color: 'text-blue-400', icon: '📈' },
  stat:       { label: 'Stat',        color: 'text-green-400', icon: '🔢' },
  gauge:      { label: 'Gauge',       color: 'text-yellow-400', icon: '⏱' },
  table:      { label: 'Table',       color: 'text-purple-400', icon: '📋' },
  bargauge:   { label: 'Bar Gauge',   color: 'text-orange-400', icon: '📊' },
  text:       { label: 'Text',        color: 'text-text-muted', icon: '📝' },
};

function esc(s) { return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function renderPanels() {
  const list = document.getElementById('panels-list');
  if (!list) return;
  list.innerHTML = '';
  if (panels.length === 0) {
    list.innerHTML = '<p class="text-sm text-text-muted text-center py-8 border border-dashed border-border rounded-lg">No panels yet. Click &quot;+ Add Panel&quot; or &quot;Load CPU+Memory Example&quot; to begin.</p>';
    return;
  }
  panels.forEach((p, idx) => {
    const cfg = PANEL_TYPE_CONFIG[p.type] || PANEL_TYPE_CONFIG.timeseries;
    const div = document.createElement('div');
    div.className = 'border border-border rounded-lg p-4 bg-bg-card';
    const isText = p.type === 'text';
    div.innerHTML = `
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-2">
          <span class="text-sm">${cfg.icon}</span>
          <span class="text-xs font-semibold ${cfg.color}">${cfg.label}</span>
          <span class="text-sm font-medium">${esc(p.title) || '<untitled panel>'}</span>
        </div>
        <button class="btn-rm-panel text-text-muted hover:text-red-400 transition-colors text-xl leading-none" data-idx="${idx}" aria-label="Remove">&#215;</button>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4">
        <div>
          <label class="block text-xs text-text-muted mb-1">Panel Type</label>
          <select class="p-type w-full bg-bg-card border border-border rounded p-2 text-sm focus:outline-none focus:border-primary" data-idx="${idx}">
            ${Object.entries(PANEL_TYPE_CONFIG).map(([k,v]) => `<option value="${k}"${p.type===k?' selected':''}>${v.icon} ${v.label}</option>`).join('')}
          </select>
        </div>
        <div class="sm:col-span-2">
          <label class="block text-xs text-text-muted mb-1">Panel Title</label>
          <input class="p-title w-full bg-bg-card border border-border rounded p-2 text-sm focus:outline-none focus:border-primary" value="${esc(p.title)}" data-idx="${idx}" placeholder="CPU Usage" />
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-xs text-text-muted mb-1">Datasource</label>
          <input class="p-datasource w-full bg-bg-card border border-border rounded p-2 text-sm font-mono focus:outline-none focus:border-primary" value="${esc(p.datasource)}" data-idx="${idx}" placeholder="Prometheus" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">Grid Width (1-24)</label>
          <input type="number" min="1" max="24" class="p-width w-full bg-bg-card border border-border rounded p-2 text-sm focus:outline-none focus:border-primary" value="${p.gridW || 12}" data-idx="${idx}" />
        </div>
      </div>
      ${isText ? `
      <div>
        <label class="block text-xs text-text-muted mb-1">Text Content (Markdown)</label>
        <textarea class="p-query w-full bg-bg-card border border-border rounded p-2 text-sm font-mono focus:outline-none focus:border-primary resize-none" rows="3" data-idx="${idx}" placeholder="# My Dashboard\nWelcome to the dashboard.">${esc(p.query)}</textarea>
      </div>` : `
      <div class="mb-3">
        <label class="block text-xs text-text-muted mb-1">Query (PromQL / SQL)</label>
        <input class="p-query w-full bg-bg-card border border-border rounded p-2 text-sm font-mono focus:outline-none focus:border-primary" value="${esc(p.query)}" data-idx="${idx}" placeholder='rate(node_cpu_seconds_total{mode="idle"}[5m])' />
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-text-muted mb-1">Legend Format</label>
          <input class="p-legend w-full bg-bg-card border border-border rounded p-2 text-sm font-mono focus:outline-none focus:border-primary" value="${esc(p.legend)}" data-idx="${idx}" placeholder="{{ instance }}" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">Unit</label>
          <select class="p-unit w-full bg-bg-card border border-border rounded p-2 text-sm focus:outline-none focus:border-primary" data-idx="${idx}">
            <option value="none"${p.unit==='none'?' selected':''}>None</option>
            <option value="percent"${p.unit==='percent'?' selected':''}>Percent (0-100)</option>
            <option value="percentunit"${p.unit==='percentunit'?' selected':''}>Percent (0.0-1.0)</option>
            <option value="bytes"${p.unit==='bytes'?' selected':''}>Bytes</option>
            <option value="decbytes"${p.unit==='decbytes'?' selected':''}>Bytes (SI)</option>
            <option value="short"${p.unit==='short'?' selected':''}>Short</option>
            <option value="reqps"${p.unit==='reqps'?' selected':''}>Requests/sec</option>
            <option value="ms"${p.unit==='ms'?' selected':''}>Milliseconds</option>
            <option value="s"${p.unit==='s'?' selected':''}>Seconds</option>
          </select>
        </div>
      </div>`}
    `;
    list.appendChild(div);
  });

  list.querySelectorAll('.btn-rm-panel').forEach(b => b.addEventListener('click', () => { panels.splice(+b.dataset.idx, 1); renderPanels(); }));
  list.querySelectorAll('.p-type').forEach(s => s.addEventListener('change', () => { panels[+s.dataset.idx].type = s.value; renderPanels(); }));
  list.querySelectorAll('.p-title').forEach(i => i.addEventListener('input', () => { panels[+i.dataset.idx].title = i.value; renderPanels(); }));
  list.querySelectorAll('.p-datasource').forEach(i => i.addEventListener('input', () => { panels[+i.dataset.idx].datasource = i.value; }));
  list.querySelectorAll('.p-width').forEach(i => i.addEventListener('input', () => { panels[+i.dataset.idx].gridW = +i.value || 12; }));
  list.querySelectorAll('.p-query').forEach(i => i.addEventListener('input', () => { panels[+i.dataset.idx].query = i.value; }));
  list.querySelectorAll('.p-legend').forEach(i => i.addEventListener('input', () => { panels[+i.dataset.idx].legend = i.value; }));
  list.querySelectorAll('.p-unit').forEach(s => s.addEventListener('change', () => { panels[+s.dataset.idx].unit = s.value; }));
}

function addPanel(overrides = {}) {
  const defaultDs = (document.getElementById('dash-datasource')?.value || 'Prometheus').trim();
  panels.push({
    _id: ++panelIdSeq,
    type: 'timeseries',
    title: '',
    datasource: defaultDs,
    query: '',
    legend: '{{ instance }}',
    unit: 'none',
    gridW: 12,
    ...overrides
  });
  renderPanels();
}

document.getElementById('btn-add-panel')?.addEventListener('click', () => addPanel());

document.getElementById('btn-clear')?.addEventListener('click', () => {
  if (panels.length > 0 && !confirm('Clear all panels?')) return;
  panels = [];
  renderPanels();
  document.getElementById('output-section').classList.add('hidden');
});

document.getElementById('btn-example-infra')?.addEventListener('click', () => {
  panels = [];
  document.getElementById('dash-title').value = 'Infrastructure Overview';
  document.getElementById('dash-uid').value = 'infra-overview';
  document.getElementById('dash-description').value = 'CPU, memory, disk, and network metrics from node_exporter';
  document.getElementById('dash-tags').value = 'prometheus, node-exporter, infrastructure';
  document.getElementById('dash-datasource').value = 'Prometheus';
  const ds = 'Prometheus';
  addPanel({ type: 'timeseries', title: 'CPU Usage %', datasource: ds, query: '100 - (avg by(instance)(rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100)', legend: '{{ instance }}', unit: 'percent', gridW: 12 });
  addPanel({ type: 'timeseries', title: 'Memory Usage %', datasource: ds, query: '100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))', legend: '{{ instance }}', unit: 'percent', gridW: 12 });
  addPanel({ type: 'stat', title: 'Avg CPU (now)', datasource: ds, query: 'avg(100 - (rate(node_cpu_seconds_total{mode="idle"}[5m]) * 100))', legend: '', unit: 'percent', gridW: 6 });
  addPanel({ type: 'stat', title: 'Total Memory', datasource: ds, query: 'sum(node_memory_MemTotal_bytes)', legend: '', unit: 'bytes', gridW: 6 });
  addPanel({ type: 'gauge', title: 'Disk Usage %', datasource: ds, query: '100 - ((node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"}) * 100)', legend: '{{ instance }}', unit: 'percent', gridW: 12 });
  addPanel({ type: 'table', title: 'Node Overview', datasource: ds, query: 'up{job="node"}', legend: 'Instance: {{ instance }}', unit: 'short', gridW: 24 });
  renderPanels();
});

function buildPanelJson(p, id, x, y) {
  const ds = { type: 'prometheus', uid: p.datasource || 'Prometheus' };
  const base = {
    id,
    title: p.title || 'Panel',
    type: p.type,
    datasource: ds,
    gridPos: { x, y, w: Math.min(24, Math.max(1, p.gridW || 12)), h: 8 },
    options: {},
    fieldConfig: {
      defaults: { unit: p.unit === 'none' ? 'short' : p.unit },
      overrides: []
    }
  };

  if (p.type === 'text') {
    base.options = { content: p.query || '', mode: 'markdown' };
    delete base.datasource;
    base.targets = [];
  } else {
    base.targets = [{
      datasource: ds,
      expr: p.query || '',
      legendFormat: p.legend || '{{ instance }}',
      refId: 'A',
      editorMode: 'code',
      range: true,
      instant: false
    }];
  }

  if (p.type === 'timeseries') {
    base.options = { tooltip: { mode: 'single' }, legend: { displayMode: 'list', placement: 'bottom' } };
  } else if (p.type === 'stat') {
    base.options = { reduceOptions: { values: false, calcs: ['lastNotNull'] }, orientation: 'auto', colorMode: 'value', graphMode: 'none', justifyMode: 'auto' };
    if (base.targets[0]) { base.targets[0].instant = true; base.targets[0].range = false; }
  } else if (p.type === 'gauge') {
    base.options = { reduceOptions: { values: false, calcs: ['lastNotNull'] }, orientation: 'auto', showThresholdLabels: false, showThresholdMarkers: true };
    base.fieldConfig.defaults.thresholds = { mode: 'absolute', steps: [{ color: 'green', value: null }, { color: 'yellow', value: 70 }, { color: 'red', value: 90 }] };
    base.fieldConfig.defaults.min = 0;
    base.fieldConfig.defaults.max = 100;
    if (base.targets[0]) { base.targets[0].instant = true; base.targets[0].range = false; }
  } else if (p.type === 'bargauge') {
    base.options = { reduceOptions: { values: false, calcs: ['lastNotNull'] }, orientation: 'horizontal', displayMode: 'gradient' };
    if (base.targets[0]) { base.targets[0].instant = true; base.targets[0].range = false; }
  } else if (p.type === 'table') {
    base.options = { showHeader: true };
    if (base.targets[0]) { base.targets[0].instant = true; base.targets[0].range = false; base.targets[0].format = 'table'; }
  }

  return base;
}

function generateJSON() {
  const title = (document.getElementById('dash-title')?.value || 'My Dashboard').trim();
  const uid = (document.getElementById('dash-uid')?.value || 'my-dashboard').trim().replace(/\s+/g, '-');
  const description = (document.getElementById('dash-description')?.value || '').trim();
  const tagsRaw = (document.getElementById('dash-tags')?.value || '').trim();
  const tags = tagsRaw.split(',').map(s => s.trim()).filter(Boolean);
  const timeFrom = document.getElementById('dash-timerange')?.value || 'now-6h';
  const refresh = document.getElementById('dash-refresh')?.value || '30s';

  if (panels.length === 0) { alert('Add at least one panel first.'); return; }

  // Read live panel values
  const livePanels = panels.map((p, idx) => {
    const g = (cls) => document.querySelector(`${cls}[data-idx="${idx}"]`);
    return {
      ...p,
      type: g('.p-type')?.value ?? p.type,
      title: g('.p-title')?.value ?? p.title,
      datasource: g('.p-datasource')?.value ?? p.datasource,
      query: g('.p-query')?.value ?? p.query,
      legend: g('.p-legend')?.value ?? p.legend,
      unit: g('.p-unit')?.value ?? p.unit,
      gridW: +(g('.p-width')?.value || p.gridW || 12),
    };
  });

  // Layout panels in rows
  const builtPanels = [];
  let x = 0, y = 0, rowId = 1;
  livePanels.forEach((p, i) => {
    const w = Math.min(24, Math.max(1, p.gridW || 12));
    if (x + w > 24) { x = 0; y += 8; }
    builtPanels.push(buildPanelJson(p, i + 1, x, y));
    x += w;
  });

  const dashboard = {
    __inputs: [],
    __requires: [
      { type: 'grafana', id: 'grafana', name: 'Grafana', version: '10.0.0' }
    ],
    annotations: { list: [] },
    description,
    editable: true,
    fiscalYearStartMonth: 0,
    graphTooltip: 0,
    id: null,
    links: [],
    panels: builtPanels,
    refresh,
    schemaVersion: 38,
    tags,
    templating: { list: [] },
    time: { from: timeFrom, to: 'now' },
    timepicker: {},
    timezone: 'browser',
    title,
    uid,
    version: 1,
    weekStart: ''
  };

  document.getElementById('json-output').textContent = JSON.stringify(dashboard, null, 2);
  document.getElementById('output-section').classList.remove('hidden');
  setTimeout(() => document.getElementById('output-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
}

document.getElementById('btn-generate')?.addEventListener('click', generateJSON);

document.getElementById('btn-copy')?.addEventListener('click', () => {
  const el = document.getElementById('json-output');
  if (!el) return;
  navigator.clipboard.writeText(el.textContent).then(() => {
    const b = document.getElementById('btn-copy');
    b.textContent = 'Copied!';
    setTimeout(() => b.textContent = 'Copy JSON', 2000);
  });
});

renderPanels();
</script>
