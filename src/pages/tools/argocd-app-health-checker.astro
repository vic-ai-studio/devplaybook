---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArgoCdAppHealthChecker from '../../components/ArgoCdAppHealthChecker.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is ArgoCD?",
    answer: "ArgoCD is a declarative, GitOps continuous delivery tool for Kubernetes. It monitors a Git repository (the source of truth) and automatically syncs the cluster state to match what's defined in Git. ArgoCD supports Helm charts, Kustomize, plain YAML, and other templating tools. It provides a web UI and CLI to visualize application health, sync status, and drift between Git and the live cluster."
  },
  {
    question: "What is GitOps and why does it matter?",
    answer: "GitOps is an operational model where Git is the single source of truth for infrastructure and application configuration. All changes go through Git (pull requests, reviews), and automation syncs the cluster to match. Benefits: full audit trail of every change, easy rollback (git revert), consistent environments, and reduced manual kubectl access. ArgoCD implements GitOps by continuously reconciling the cluster with the Git repository state."
  },
  {
    question: "What does syncPolicy.automated do in ArgoCD?",
    answer: "Without automated sync, ArgoCD detects drift between Git and the cluster but requires a manual sync (via UI or CLI). With 'automated: {}', ArgoCD automatically applies changes when it detects the Git state has changed. The 'prune: true' option tells ArgoCD to delete resources that have been removed from Git. The 'selfHeal: true' option tells ArgoCD to revert manual changes made directly to the cluster, ensuring Git remains the only source of truth."
  },
  {
    question: "What is the difference between Synced and Healthy in ArgoCD?",
    answer: "Synced means the live cluster state matches what's defined in Git. Healthy means the deployed resources are running correctly (Pods are running, Deployments have expected replicas, etc.). An application can be Synced but Unhealthy (e.g. all manifests applied but Pods are CrashLooping). It can also be OutOfSync but Healthy (manual changes made to a running app). Aim for both Synced and Healthy."
  },
  {
    question: "Should I target HEAD or a pinned revision?",
    answer: "targetRevision: HEAD tracks the tip of the default branch and auto-syncs with every commit. For production environments, pin to a specific tag or commit SHA for controlled, auditable deployments. For staging/dev environments, HEAD can be acceptable. Many teams use a promotion model: tag releases in Git and update the ArgoCD Application's targetRevision as part of the release process, maintaining a clear history of exactly what was deployed."
  },
  {
    question: "What is an ArgoCD AppProject?",
    answer: "An AppProject scopes what ArgoCD Applications are allowed to do: which source repositories they can use, which destination clusters and namespaces they can deploy to, and which resource types are allowed or denied. The 'default' project permits everything. For multi-team environments, create dedicated AppProjects with RBAC policies so team A cannot accidentally (or maliciously) deploy to team B's namespace. AppProjects are the primary access control mechanism in ArgoCD."
  },
];
---

<BaseLayout
  title="ArgoCD App Health Checker — Validate Application YAML Online"
  description="Free online ArgoCD Application YAML health checker. Validates apiVersion, source, destination, syncPolicy, prune, selfHeal, and GitOps best practices. No cluster required."
  tool="ArgoCD application validator, ArgoCD YAML checker, GitOps health check, ArgoCD Application health, ArgoCD sync policy validator, ArgoCD best practices"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">ArgoCD App Health Checker</h1>
  <p class="text-text-muted mb-4">Validate your ArgoCD Application YAML against best practices. Check required fields, sync policies, prune and selfHeal settings, destination configuration, and revision pinning — all without connecting to a cluster.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Health score with pass/fail breakdown</span>
  </div>
  <ArgoCdAppHealthChecker client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="ArgoCD App Health Checker" relatedTags={['devops', 'kubernetes', 'cloud', 'infrastructure', 'gitops']} />
</BaseLayout>
