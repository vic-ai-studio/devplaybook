---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Argon2HashGenerator from '../../components/Argon2HashGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Argon2 and how does it differ from bcrypt?", answer: "Argon2 is the winner of the 2015 Password Hashing Competition and is the current state-of-the-art for password hashing. Unlike bcrypt, Argon2 is memory-hard — it requires a configurable amount of RAM, making GPU and ASIC attacks far more expensive. Argon2 also supports parallelism and has three variants: Argon2d (faster, vulnerable to side-channels), Argon2i (side-channel resistant), and Argon2id (the recommended hybrid)." },
  { question: "What are the Argon2 parameters and how should I tune them?", answer: "Argon2 has three tunable parameters: memory cost (how much RAM to use, e.g., 64 MB), time cost (iterations), and parallelism (number of threads). OWASP recommends Argon2id with m=64MB, t=3, p=4 as a baseline. Increase memory first — it has the biggest impact on GPU resistance. Time cost trades CPU time for security. Match parallelism to your server's available threads." },
  { question: "What does the Argon2 encoded output look like?", answer: "The encoded format is: $argon2id$v=19$m=65536,t=3,p=1$<base64-salt>$<base64-hash>. This string contains all parameters needed to verify a password — you store only this string, not the salt separately. The version (v=19) is the Argon2 spec version. All parameters are embedded so verification always uses the correct settings." },
  { question: "Which Argon2 variant should I use?", answer: "Use Argon2id for most applications. It combines the data-dependent memory access of Argon2d with the data-independent first pass of Argon2i, providing resistance against both GPU attacks and side-channel attacks. Argon2i is for cryptographic applications like key derivation where side-channel resistance is critical. Argon2d is for cryptocurrency and proof-of-work where side channels are not a concern." },
  { question: "How does Argon2 compare to PBKDF2 and scrypt?", answer: "PBKDF2 is the weakest of the three — it's not memory-hard, so GPUs can attack it cheaply. scrypt is memory-hard but has a complex parameter space and doesn't support parallelism as cleanly as Argon2. Argon2id is the modern recommendation: it's simpler to configure, well-analyzed, and has first-class parallelism support. For new applications, prefer Argon2id over PBKDF2 and scrypt." },
];
---

<BaseLayout
  title="Argon2 Hash Generator — Argon2id, Argon2i, Argon2d Online Tool"
  description="Generate and verify Argon2id, Argon2i, and Argon2d password hashes in your browser. Configure memory cost, iterations, parallelism, and hash length. Uses argon2-browser WASM. Free, no signup."
  tool="Argon2 hash generator, Argon2id online, password hashing, Argon2 verify, key derivation"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Argon2 Hash Generator",
    "url": "https://devplaybook.cc/tools/argon2-hash-generator",
    "description": "Generate and verify Argon2id / Argon2i / Argon2d password hashes. Configure memory cost, iterations, parallelism. Runs in-browser via WASM.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Argon2 Hash Generator</h1>
  <p class="text-text-muted mb-4">Generate and verify Argon2 password hashes using the <a href="https://github.com/antelle/argon2-browser" target="_blank" rel="noopener" class="text-accent hover:underline">argon2-browser</a> WASM library. Supports all three variants: Argon2id (recommended), Argon2i, and Argon2d. Configure memory cost, iterations, and parallelism.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> WASM — runs in browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Argon2id / Argon2i / Argon2d</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Memory-hard, GPU-resistant</span>
  </div>
  <Argon2HashGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Argon2 Hash Generator" relatedTags={['security', 'hashing', 'password', 'encryption', 'authentication']} />
</BaseLayout>
