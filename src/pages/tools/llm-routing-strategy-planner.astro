---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LlmRoutingStrategyPlanner from '../../components/LlmRoutingStrategyPlanner.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "Why do I need different LLMs for different tasks?",
    answer: "Different LLMs have different cost/performance trade-offs. GPT-4o costs $2.50/1M input tokens while Llama 3.1 8B on Groq costs $0.05/1M. For simple classification (yes/no, category labeling), a cheap model is often as good as an expensive one. Saving expensive models for complex reasoning or code generation can reduce your LLM bill by 80-95% without sacrificing quality on the tasks that matter."
  },
  {
    question: "What is 'real-time' vs 'interactive' vs 'batch' latency?",
    answer: "Real-time means responses must appear within ~300ms (e.g. autocomplete, live filters). Interactive means users are waiting but can tolerate 1-3 seconds (e.g. chat messages, search results). Batch means results can arrive in seconds or minutes (e.g. nightly report generation, email drafting). Lower latency requirements allow more powerful, slower models and reduce infrastructure costs."
  },
  {
    question: "How accurate are the cost estimates?",
    answer: "Estimates use current provider pricing and typical token counts per task type. Actual costs vary based on your real prompt/response lengths. Classification tasks typically use 200-500 input tokens; code generation tasks can use 1000-3000 tokens. Monitor your actual token usage for the first 2 weeks with real traffic, then adjust routing based on observed averages."
  },
  {
    question: "How do I implement this routing in code?",
    answer: "The most common pattern is a task-type-based router function: `function getLLMClient(taskType: string)` that returns different configured SDK clients. Use LiteLLM, Portkey, or a simple if/switch statement to route. For production, store the model mapping in config/environment variables so you can update it without code deployments."
  },
  {
    question: "Should I always use the cheapest model for classification?",
    answer: "Not always. If classification errors have high business impact (e.g. content moderation, medical triage, financial risk flagging), use a stronger model even if it costs more. For low-stakes classification (e.g. tagging blog posts, sorting support tickets), cheap models work well. Always measure accuracy on your specific data before committing to a cheaper model."
  },
];
---

<BaseLayout
  title="LLM Routing Strategy Planner — Plan Cost-Optimized Model Routing"
  description="Plan cost-optimized LLM routing by task type. Compare models by cost, latency, and quality. Get a routing table showing the best model for chat, code, summarization, classification, and more — with monthly cost estimates."
  tool="LLM routing strategy, LLM cost optimizer, model routing planner, LLM task routing, AI cost calculator, which LLM to use"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "LLM Routing Strategy Planner",
    "url": "https://devplaybook.cc/tools/llm-routing-strategy-planner",
    "description": "Plan which LLM to use for each task type. Optimize for cost, latency, and quality. Includes monthly cost estimates across GPT-4o, Claude, Gemini, and Groq.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">LLM Routing Strategy Planner</h1>
  <p class="text-text-muted mb-4">
    Plan cost-optimized LLM routing for different task types. Select your tasks, latency requirements, and quality priorities — get a routing table showing the best model for each task with monthly cost estimates.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 8 task types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Real 2024 pricing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Monthly budget check</span>
  </div>
  <LlmRoutingStrategyPlanner client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="LLM Routing Strategy Planner" relatedTags={['ai', 'llm', 'developer-tools', 'cost-optimization', 'openai', 'anthropic', 'gemini']} />
</BaseLayout>
