---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is the difference between Ansible Tower, AWX, and Ansible CLI?", answer: "Ansible CLI is the open-source command-line tool you run from a terminal — great for individual use but lacks a web UI, role-based access, audit logging, or scheduling. AWX is the open-source upstream project that became Ansible Tower — it provides a web UI, REST API, job scheduling, credential vault, and RBAC, but receives less stable releases and is community-supported. Ansible Tower is the enterprise, supported product sold by Red Hat with a stable release cadence, commercial support, and certifications. For production team use, AWX (self-hosted, free) or Tower (paid, supported) are the right choices; CLI for local development and scripting." },
  { question: "How do I install AWX quickly for evaluation?", answer: "The fastest path is the AWX Operator on a local Kubernetes cluster (minikube or kind). Install the AWX Operator via kubectl, then create an AWX custom resource. Alternatively, the legacy Docker Compose method works for quick demos: clone the awx repo, run make docker-compose, wait ~5 minutes for containers to start, and access the UI at localhost:8013. For production, use the AWX Operator on a proper Kubernetes cluster with persistent storage and an external PostgreSQL database." },
  { question: "How does AWX/Tower handle secrets and credentials?", answer: "AWX has a built-in credential vault that encrypts secrets at rest using AES-256. You create Credential objects of various types (SSH key, sudo password, AWS access key, Vault password, etc.) and attach them to Job Templates. Operators never see the raw credential values after creation — they are injected into playbook runs as environment variables or files at execution time. For teams already using HashiCorp Vault, AWX supports Vault lookup plugins to dynamically fetch credentials at runtime, giving you a single source of truth for secrets." },
  { question: "What is the difference between a Job Template and a Workflow in AWX?", answer: "A Job Template is a single playbook run — it defines the playbook, inventory, credentials, and extra variables to use. A Workflow Job Template chains multiple Job Templates together into a directed acyclic graph (DAG). Workflow nodes can branch on success or failure — for example, run 'provision servers' → on success run 'deploy app', on failure run 'notify slack'. Workflows can also span multiple inventories and credentials, making them ideal for multi-stage deployment pipelines." },
  { question: "How do I trigger an AWX job from a CI/CD pipeline?", answer: "Use the AWX REST API. POST to /api/v2/job_templates/{id}/launch/ with basic auth or token auth and an optional JSON body for extra_vars. With curl: curl -X POST https://awx.example.com/api/v2/job_templates/42/launch/ -H 'Authorization: Bearer TOKEN' -H 'Content-Type: application/json' -d '{\"extra_vars\": {\"deploy_version\": \"1.2.3\"}}'. The response includes a job ID you can poll at /api/v2/jobs/{id}/ to wait for completion and check status. Many CI systems have AWX plugins (Jenkins AWX Plugin, GitLab CI templates) that wrap this pattern." },
  { question: "How does AWX compare to Semaphore for Ansible automation?", answer: "AWX is the full-featured upstream of Ansible Tower with a comprehensive web UI, workflow engine, RBAC, credential vault, REST API, and inventory management — but it is heavier (requires Kubernetes or Docker and a PostgreSQL database). Semaphore is a lightweight open-source Ansible web UI written in Go that is much simpler to install (single binary or Docker) with a smaller resource footprint. Semaphore is better for small teams or individuals who just want a web interface to run playbooks without the complexity of AWX. AWX is the right choice when you need workflows, audit trails, complex RBAC, or REST API integration." },
];
---

<BaseLayout
  title="Ansible Tower (AWX): Setup, Playbook Automation & API Guide"
  description="Complete guide to Ansible Tower and AWX: Docker quickstart, inventory management, job templates, workflow automation, REST API for CI/CD, RBAC, and comparison with Semaphore. Free DevOps reference."
  tool="Ansible Tower, AWX, playbook automation, inventory management, Red Hat Ansible, CI/CD automation"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Ansible Tower (AWX): Setup, Playbook Automation & API Guide",
    "url": "https://devplaybook.cc/tools/ansible-tower",
    "description": "Complete guide to Ansible Tower and AWX: setup, job templates, workflow automation, REST API integration, and RBAC for teams.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Ansible Tower (AWX)</h1>
  <p class="text-text-muted mb-6">
    The enterprise web UI and automation platform for Ansible. Schedule playbooks, manage inventories and credentials, control team access, and integrate with any CI/CD system via REST API.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Visual workflow builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Encrypted credential vault</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Full REST API</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> RBAC for team access</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Ansible Tower vs AWX vs Ansible CLI</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse mb-6">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">Ansible CLI</th>
          <th class="border border-border px-3 py-2 text-left">AWX</th>
          <th class="border border-border px-3 py-2 text-left">Ansible Tower</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-border px-3 py-2">Web UI</td>
          <td class="border border-border px-3 py-2">No</td>
          <td class="border border-border px-3 py-2">Yes</td>
          <td class="border border-border px-3 py-2">Yes</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">RBAC</td>
          <td class="border border-border px-3 py-2">No</td>
          <td class="border border-border px-3 py-2">Yes</td>
          <td class="border border-border px-3 py-2">Yes</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">REST API</td>
          <td class="border border-border px-3 py-2">No</td>
          <td class="border border-border px-3 py-2">Yes</td>
          <td class="border border-border px-3 py-2">Yes</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Credential vault</td>
          <td class="border border-border px-3 py-2">ansible-vault (file)</td>
          <td class="border border-border px-3 py-2">Built-in encrypted</td>
          <td class="border border-border px-3 py-2">Built-in encrypted</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">Audit logging</td>
          <td class="border border-border px-3 py-2">No</td>
          <td class="border border-border px-3 py-2">Yes</td>
          <td class="border border-border px-3 py-2">Yes</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Cost</td>
          <td class="border border-border px-3 py-2">Free</td>
          <td class="border border-border px-3 py-2">Free (self-hosted)</td>
          <td class="border border-border px-3 py-2">Red Hat subscription</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">Support</td>
          <td class="border border-border px-3 py-2">Community</td>
          <td class="border border-border px-3 py-2">Community</td>
          <td class="border border-border px-3 py-2">Red Hat SLA</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">AWX Quickstart with AWX Operator (Kubernetes)</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Prerequisites: kubectl configured, minikube or kind running
# Step 1: Install AWX Operator via kustomize
cat &lt;&lt;EOF &gt; kustomization.yaml
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization
resources:
  - github.com/ansible/awx-operator/config/default?ref=2.19.1
images:
  - name: quay.io/ansible/awx-operator
    newTag: 2.19.1
namespace: awx
EOF

kubectl apply -k .

# Step 2: Wait for operator pod
kubectl get pods -n awx -w

# Step 3: Create AWX instance
cat &lt;&lt;EOF | kubectl apply -f -
apiVersion: awx.ansible.com/v1beta1
kind: AWX
metadata:
  name: awx-demo
  namespace: awx
spec:
  service_type: nodeport
  nodeport_port: 30080
EOF

# Step 4: Wait for deployment (~5 minutes)
kubectl logs -f deployments/awx-operator-controller-manager -n awx

# Step 5: Get admin password
kubectl get secret awx-demo-admin-password -n awx \
  -o jsonpath='&#123;.data.password&#125;' | base64 -d</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Creating an Inventory and Running a Job Template</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Example inventory (static, in AWX UI or via API)
# Inventory → Source → Manual:
[webservers]
web1.example.com
web2.example.com

[dbservers]
db1.example.com

# Example playbook stored in GitHub (linked via Project)
# playbooks/deploy-app.yml
---
- name: Deploy application
  hosts: webservers
  become: yes
  vars:
    app_version: "&#123;&#123; deploy_version | default('latest') &#125;&#125;"
  tasks:
    - name: Pull latest Docker image
      docker_image:
        name: "myapp:&#123;&#123; app_version &#125;&#125;"
        source: pull

    - name: Restart app container
      docker_container:
        name: myapp
        image: "myapp:&#123;&#123; app_version &#125;&#125;"
        state: started
        restart: yes</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">REST API: Trigger a Job from CI/CD</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Get an API token (one-time)
curl -s -X POST https://awx.example.com/api/v2/tokens/ \
  -H 'Content-Type: application/json' \
  -u admin:your-password | jq '.token'

# Launch a Job Template (template ID 42)
curl -s -X POST https://awx.example.com/api/v2/job_templates/42/launch/ \
  -H 'Authorization: Bearer YOUR_TOKEN' \
  -H 'Content-Type: application/json' \
  -d '&#123;"extra_vars": &#123;"deploy_version": "1.2.3"&#125;&#125;' | jq '&#123;job_id: .id, status: .status&#125;'

# Poll until complete
JOB_ID=123
until [ "$(curl -s https://awx.example.com/api/v2/jobs/$JOB_ID/ \
  -H 'Authorization: Bearer YOUR_TOKEN' | jq -r '.status')" != "running" ]; do
  echo "Job still running..."; sleep 10
done
echo "Job finished"</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Building a Workflow Job Template</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Workflow Job Templates chain multiple Job Templates together with success/failure branches. A common deployment workflow:
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Workflow DAG (configured in AWX UI's visual editor):
#
#  [Run Tests] --SUCCESS--> [Deploy to Staging] --SUCCESS--> [Run Smoke Tests]
#                |                    |                              |
#                |               FAILURE                        FAILURE
#                |                    v                              v
#             FAILURE         [Rollback Staging]           [Notify Slack: Failed]
#                v
#       [Notify Slack: Test Fail]
#
# Each node in the workflow is a Job Template with its own:
# - Playbook
# - Inventory (can differ per node)
# - Credentials
# - Extra variables (can pass outputs between nodes via set_stats)</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">AWX vs Semaphore</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse mb-6">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">AWX</th>
          <th class="border border-border px-3 py-2 text-left">Semaphore</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-border px-3 py-2">Install complexity</td>
          <td class="border border-border px-3 py-2">High (Kubernetes + PostgreSQL)</td>
          <td class="border border-border px-3 py-2">Low (single binary or Docker)</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Workflow engine</td>
          <td class="border border-border px-3 py-2">Yes (DAG visual builder)</td>
          <td class="border border-border px-3 py-2">No</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">REST API</td>
          <td class="border border-border px-3 py-2">Full API</td>
          <td class="border border-border px-3 py-2">Limited API</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">RBAC granularity</td>
          <td class="border border-border px-3 py-2">Fine-grained (org/team/user)</td>
          <td class="border border-border px-3 py-2">Basic (project-level)</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">Resource usage</td>
          <td class="border border-border px-3 py-2">Heavy (4GB+ RAM)</td>
          <td class="border border-border px-3 py-2">Light (256MB RAM)</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Best for</td>
          <td class="border border-border px-3 py-2">Enterprise teams, complex workflows</td>
          <td class="border border-border px-3 py-2">Small teams, simple scheduling</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">RBAC Best Practices</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li>Create Organizations to isolate teams — each org has its own inventories, credentials, and projects</li>
    <li>Grant developers "Execute" permission on Job Templates but not "Admin" — they can run but not modify</li>
    <li>Use Teams to apply permissions in bulk rather than per-user grants</li>
    <li>Restrict who can edit credentials — most users should only see that a credential exists, not its value</li>
    <li>Use the "Ask at launch" option for extra_vars sparingly — prefer defined variables in Job Templates for auditability</li>
  </ul>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Ansible Tower (AWX)" relatedTags={['ansible', 'devops', 'automation', 'iac', 'configuration-management']} />
</BaseLayout>