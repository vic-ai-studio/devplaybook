---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UuidNamespaceGenerator from '../../components/UuidNamespaceGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a namespace UUID and why would I use one?",
    answer: "Namespace UUIDs (v3 and v5) are deterministic — the same namespace + name always produces the same UUID. This is useful when you want a stable identifier derived from a meaningful name, such as generating a UUID for a URL, a user email, or a domain name. Unlike random v4 UUIDs, namespace UUIDs can be reproduced without storing them in a database."
  },
  {
    question: "What is the difference between UUID v3 and v5?",
    answer: "Both v3 and v5 are name-based UUIDs. v3 uses MD5 hashing, while v5 uses SHA-1. For new projects, always prefer v5 (SHA-1) over v3 (MD5) because SHA-1 is more collision-resistant. v3 exists mainly for backward compatibility with older systems that were built before v5 was specified."
  },
  {
    question: "What are the standard RFC 4122 namespace UUIDs?",
    answer: "RFC 4122 defines four standard namespaces: DNS (6ba7b810-9dad-11d1-80b4-00c04fd430c8) for domain names, URL (6ba7b811-9dad-11d1-80b4-00c04fd430c8) for URLs, OID (6ba7b812-9dad-11d1-80b4-00c04fd430c8) for ISO Object Identifiers, and X500 (6ba7b814-9dad-11d1-80b4-00c04fd430c8) for X.500 distinguished names. You can also use any valid UUID as a custom namespace."
  },
  {
    question: "Can two different names in the same namespace produce the same UUID?",
    answer: "Theoretically yes (hash collision), but in practice it is astronomically unlikely. SHA-1 produces a 160-bit hash, of which 122 bits are used in v5. A collision would require a deliberate attack using known SHA-1 weaknesses, and even then producing a specific UUID from a name-based hash is not practically feasible."
  },
  {
    question: "When should I use a custom namespace vs. the DNS or URL presets?",
    answer: "Use the DNS namespace when your names are hostnames (e.g., api.example.com), and URL namespace when your names are full URLs. Use a custom namespace when you want UUIDs scoped specifically to your application — so there's no overlap with other applications that might generate namespace UUIDs from the same name strings. Generate your custom namespace once with UUID v4 and store it as a constant in your codebase."
  },
  {
    question: "Are namespace UUIDs safe to use as database primary keys?",
    answer: "Yes, but with caveats. Because v5 UUIDs are deterministic, a leaked namespace + algorithm allows anyone to reverse-engineer what identifier maps to what name. For sensitive data (e.g., deriving a UUID from a user's email), consider using a private custom namespace or adding a secret salt into the name before hashing. For non-sensitive content identifiers, namespace UUIDs are perfectly safe as primary keys."
  },
];
---

<BaseLayout
  title="UUID Namespace Generator — v3/v5 Name-Based UUIDs Online"
  description="Generate deterministic UUID v3 (MD5) and v5 (SHA-1) name-based UUIDs. Choose from DNS, URL, OID, X.500, or custom namespace presets. Batch generation up to 100 names. Runs entirely in your browser."
  tool="UUID v5 Generator, UUID v3 Generator, Namespace UUID, Name-based UUID, Deterministic UUID, UUID from URL, UUID from DNS"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "UUID Namespace Generator",
    "url": "https://devplaybook.cc/tools/uuid-namespace-generator",
    "description": "Generate deterministic UUID v3 and v5 from a namespace and name. Standard RFC 4122 namespace presets (DNS, URL, OID, X500), custom namespace support, and batch generation. Runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">UUID Namespace Generator</h1>
  <p class="text-text-muted mb-4">
    Generate deterministic UUID v3 (MD5) and v5 (SHA-1) from a namespace and name. Same inputs always produce the same UUID —
    great for stable identifiers derived from URLs, domain names, or any string. Also generates random v4. Batch mode for up to 100 names.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Deterministic v3 & v5</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> DNS / URL / OID / X500 presets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Batch up to 100 names</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100% browser — no server</span>
  </div>
  <UuidNamespaceGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="UUID Namespace Generator" relatedTags={['uuid', 'guid', 'id-generation', 'hashing', 'database']} />
</BaseLayout>
