---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SqlBeautifier from '../../components/SqlBeautifier.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is a SQL beautifier and why should I use one?",
    answer: "A SQL beautifier (also called a SQL formatter or SQL prettifier) reformats raw SQL queries into a clean, consistently indented structure with uppercase keywords and one clause per line. This makes queries dramatically easier to read, review, and debug — especially for long queries with multiple JOINs, WHERE conditions, and subqueries. Using a consistent format also helps teams collaborate on shared SQL without style debates."
  },
  {
    question: "Does this tool send my SQL to a server?",
    answer: "No. This SQL beautifier runs entirely in your browser using JavaScript. Your query never leaves your machine. That means it works offline, is instant regardless of your connection speed, and is safe to use with proprietary or sensitive SQL that you wouldn't want sent to a third-party API."
  },
  {
    question: "What SQL dialects are supported?",
    answer: "The formatter supports Standard SQL, MySQL, PostgreSQL, and SQLite. The dialect selector primarily affects how dialect-specific keywords and functions are recognized and uppercased — for example AUTO_INCREMENT (MySQL) versus SERIAL (PostgreSQL). Core formatting behavior (clause layout, indentation, operator spacing) is identical across all dialects."
  },
  {
    question: "How does the comma-first style work?",
    answer: "In comma-first formatting, the comma that separates column names or expressions is placed at the beginning of the new line rather than the end of the previous line. For example: '  col1 / , col2 / , col3' instead of 'col1, / col2, / col3'. This style makes it easier to spot missing or extra commas when reviewing a diff, since the comma is always in column 2 of each continuation line."
  },
  {
    question: "How are subqueries handled?",
    answer: "When the formatter detects a subquery — a SELECT statement inside parentheses — it formats the inner query with increased indentation relative to the outer query. The opening parenthesis appears on its own line, the inner clauses are indented one additional level, and the closing parenthesis returns to the outer indentation level. This makes it clear where subqueries begin and end, even when they are deeply nested."
  },
  {
    question: "Are SQL comments preserved during formatting?",
    answer: "Yes. Both single-line comments (-- comment) and multi-line block comments (/* comment */) are preserved exactly as written. The formatter identifies them during a tokenization pass before any keyword uppercasing or clause splitting occurs, so their content is never modified. This is important for queries that contain documentation, parameter hints, or query optimizer hints inside comments."
  },
];
---

<BaseLayout
  title="SQL Beautifier — Format & Prettify SQL Queries Online"
  description="Format and beautify SQL queries instantly in your browser. Capitalizes keywords, adds consistent indentation, one clause per line, handles JOINs and subqueries. Supports MySQL, PostgreSQL, SQLite."
  tool="SQL Beautifier, SQL Formatter, SQL Prettifier, SQL Indenter, SQL Syntax Highlighter"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">SQL Beautifier</h1>
  <p class="text-text-muted mb-4">Paste a raw SQL query to instantly format it with proper indentation, uppercase keywords, and one clause per line — entirely in your browser, no data sent to any server.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Keywords uppercased &amp; clauses on separate lines</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Subquery nesting &amp; comment preservation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> MySQL, PostgreSQL, SQLite &amp; Standard SQL</span>
  </div>

  <SqlBeautifier client:only="preact" />

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SQL Beautifier" relatedTags={['sql', 'formatting', 'database', 'code-quality']} />
</BaseLayout>
