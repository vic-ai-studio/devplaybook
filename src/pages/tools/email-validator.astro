---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmailValidator from '../../components/EmailValidator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What does email validation check?", answer: "This tool validates email format against RFC 5322 rules: presence of exactly one @ symbol, valid local part (before @), valid domain format with proper TLD, length constraints (local ≤ 64 chars, total ≤ 254 chars), no consecutive dots, and no leading/trailing dots. It also flags known disposable email providers." },
  { question: "Can this tool verify if an email actually exists?", answer: "No. Format validation only checks syntax rules. To verify if an email actually exists and can receive messages, you need to perform an MX record lookup and SMTP handshake — both require server-side processing. This tool runs entirely in your browser and cannot make DNS queries." },
  { question: "What is a disposable email?", answer: "Disposable email services (like Mailinator, Guerrilla Mail, or 10minutemail) provide temporary email addresses that expire quickly. They're often used to bypass sign-up requirements or avoid spam. This tool checks the domain against a list of known disposable providers to help you detect fake sign-ups." },
  { question: "What are the RFC 5321/5322 email length limits?", answer: "RFC 5321 defines: the local part (before @) must not exceed 64 characters, the domain must not exceed 255 characters, and the total email address must not exceed 254 characters. Exceeding these limits means some mail servers will reject the address even if it looks syntactically valid." },
  { question: "Why does my valid-looking email fail validation?", answer: "Common issues include: consecutive dots (john..doe@example.com), leading/trailing dots in the local part (.user@example.com), special characters not in the RFC 5322 allowed set, or an invalid TLD. Some technically valid RFC 5322 addresses (like quoted strings) are rejected by many mail servers in practice." },
];
---

<BaseLayout
  title="Email Validator — Free Email Format Checker"
  description="Free email address validator. Checks RFC 5322 format, validates domain structure, detects disposable email providers, and shows a breakdown of local part, domain, and TLD. Runs 100% in your browser — nothing sent to any server."
  tool="Email Validator, Email Format Checker, RFC 5322 Email Validation, Disposable Email Detector, Email Address Checker, Email Syntax Validator, MX Record Email Check"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Email Validator</h1>
  <p class="text-text-muted mb-4">Validate email address format against RFC 5322 rules. See a breakdown of local part, domain, and TLD. Detects disposable providers and common format errors. Runs entirely in your browser — no data sent anywhere.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No data leaves your machine</span>
  </div>
  <EmailValidator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Email Validator" relatedTags={['validation', 'email', 'security', 'api', 'forms']} />
</BaseLayout>
