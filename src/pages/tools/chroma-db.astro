---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Chroma and when should I use it?",
    answer: "Chroma (ChromaDB) is an open-source embedding database designed for developer simplicity. It runs entirely in-process in Python with no server required (ephemeral or persistent mode), making it the fastest way to prototype RAG pipelines. Use Chroma for local development, notebooks, and small-to-medium production apps. For billion-scale or managed cloud requirements, consider Pinecone or Qdrant."
  },
  {
    question: "What is the difference between ephemeral and persistent Chroma?",
    answer: "Ephemeral mode (chromadb.Client()) stores everything in memory — data is lost when the process exits. It is ideal for testing and CI. Persistent mode (chromadb.PersistentClient(path='./chroma_db')) saves data to disk as SQLite + parquet files. For production, you can also run Chroma as a standalone HTTP server and connect with chromadb.HttpClient()."
  },
  {
    question: "How do embedding functions work in Chroma?",
    answer: "Chroma's embedding functions wrap your chosen embedding model and are attached to a collection. When you add documents, Chroma automatically calls the embedding function on each document's text. Built-in functions include OpenAIEmbeddingFunction, CohereEmbeddingFunction, and SentenceTransformerEmbeddingFunction. You can also write a custom function by subclassing EmbeddingFunction."
  },
  {
    question: "Can Chroma filter by metadata?",
    answer: "Yes. Chroma supports metadata filtering via a 'where' dict at query time using operators like $eq, $ne, $gt, $lt, $in, $nin, $and, $or. You can combine filters: where={'$and': [{'source': {'$eq': 'blog'}}, {'year': {'$gte': 2024}}]}. Metadata filtering runs before the ANN search, so only matching documents are scored."
  },
  {
    question: "How does Chroma compare to Pinecone and Qdrant?",
    answer: "Chroma: easiest setup, Python-first, great for local dev and prototypes. No managed cloud. Pinecone: zero-infra managed cloud, best for production teams who don't want ops. Qdrant: highest performance self-hosted, Rust-based, supports sparse+dense hybrid search, also has a cloud offering. Choose Chroma to move fast locally; Pinecone for managed production; Qdrant for performance-critical self-hosted."
  },
  {
    question: "Does Chroma support multi-user or multi-tenant use cases?",
    answer: "Chroma uses collections as the primary isolation unit. You can create one collection per tenant and query them independently. For server mode, Chroma supports basic auth and SSL. However, Chroma does not have built-in row-level security or the shard-level tenant isolation that Weaviate offers. For strict multi-tenant SaaS, Weaviate or a namespace-based Pinecone setup is more robust."
  },
];
---

<BaseLayout
  title="Chroma: Embedding Database for AI & RAG Applications"
  description="Complete guide to ChromaDB — ephemeral vs persistent client, collections, embedding functions (OpenAI, sentence-transformers), add/query/update/delete operations, and Chroma vs Pinecone vs Qdrant comparison."
  tool="Chroma, ChromaDB, embedding database, RAG, Python vector database, open source"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"Chroma: Embedding Database for AI & RAG Applications","url":"https://devplaybook.cc/tools/chroma-db","description":"Complete ChromaDB guide — setup, collections, embedding functions, metadata filtering, and comparison with Pinecone and Qdrant."})} />

  <h1 class="text-3xl font-bold mb-2">Chroma: Embedding Database for AI &amp; RAG Applications</h1>
  <p class="text-text-muted mb-6">ChromaDB is the most developer-friendly embedding database for AI applications. It runs fully in-process with Python — no server, no Docker, no infrastructure. Add documents, query by similarity, filter by metadata, and integrate any embedding model in minutes. The go-to choice for RAG prototypes and local AI development.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Zero-config Python setup</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Ephemeral &amp; persistent modes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auto embedding functions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Metadata filtering</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Open source (Apache 2.0)</span>
  </div>

  <ToolPageCta />

  <!-- Setup and Client Modes -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">Setup: Ephemeral, Persistent &amp; HTTP Client</h2>
    <p class="text-text-muted mb-4">Three client modes for different use cases — from in-memory testing to full HTTP server deployment.</p>
    <pre class="bg-bg-card border border-border rounded-xl p-4 text-sm font-mono overflow-x-auto mb-4"><code class="text-green-400">pip install chromadb openai sentence-transformers

import chromadb
from chromadb.utils import embedding_functions

# 1. Ephemeral (in-memory, lost on exit) — great for tests
client = chromadb.Client()

# 2. Persistent (saves to disk as SQLite + parquet)
client = chromadb.PersistentClient(path="./chroma_db")

# 3. HTTP Server mode — run server first: chroma run --path ./chroma_db
client = chromadb.HttpClient(host="localhost", port=8000)

# Create a collection with OpenAI embedding function
openai_ef = embedding_functions.OpenAIEmbeddingFunction(
    api_key="YOUR_OPENAI_API_KEY",
    model_name="text-embedding-3-small"
)

collection = client.create_collection(
    name="my_rag_docs",
    embedding_function=openai_ef,
    metadata=&#123;"hnsw:space": "cosine"&#125;   # cosine | l2 | ip
)
print(f"Collection: &#123;collection.name&#125;, count: &#123;collection.count()&#125;")</code></pre>
  </section>

  <!-- CRUD Operations -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">Add, Query, Update &amp; Delete</h2>
    <p class="text-text-muted mb-4">The complete CRUD API for Chroma collections — Chroma auto-embeds text using the collection's embedding function.</p>
    <pre class="bg-bg-card border border-border rounded-xl p-4 text-sm font-mono overflow-x-auto mb-4"><code class="text-green-400"># ADD documents — embedding auto-generated by the embedding function
collection.add(
    documents=[
        "LangChain is a framework for building LLM applications",
        "Chroma stores embeddings for similarity search",
        "RAG combines retrieval with language model generation",
    ],
    metadatas=[
        &#123;"source": "blog", "year": 2024, "category": "llm"&#125;,
        &#123;"source": "docs", "year": 2024, "category": "database"&#125;,
        &#123;"source": "paper", "year": 2023, "category": "ai"&#125;,
    ],
    ids=["doc-1", "doc-2", "doc-3"]
)

# QUERY — similarity search with metadata filter
results = collection.query(
    query_texts=["how does retrieval augmented generation work?"],
    n_results=2,
    where=&#123;"category": &#123;"$in": ["ai", "llm"]&#125;&#125;,    # metadata filter
    include=["documents", "metadatas", "distances"]
)
for doc, meta, dist in zip(
    results["documents"][0],
    results["metadatas"][0],
    results["distances"][0]
):
    print(f"dist=&#123;dist:.4f&#125; | &#123;doc[:60]&#125; | &#123;meta&#125;")

# UPDATE metadata or documents
collection.update(
    ids=["doc-1"],
    metadatas=[&#123;"source": "blog", "year": 2025, "category": "llm"&#125;]
)

# UPSERT (insert or update)
collection.upsert(
    documents=["Updated content about LangChain LCEL"],
    ids=["doc-1"]
)

# DELETE by ID or filter
collection.delete(ids=["doc-3"])
collection.delete(where=&#123;"year": &#123;"$lt": 2024&#125;&#125;)</code></pre>
  </section>

  <!-- Sentence Transformers (local) -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">Local Embeddings with SentenceTransformers</h2>
    <p class="text-text-muted mb-4">Use a local embedding model for zero API cost and data privacy — no data leaves your machine.</p>
    <pre class="bg-bg-card border border-border rounded-xl p-4 text-sm font-mono overflow-x-auto mb-4"><code class="text-green-400">from chromadb.utils.embedding_functions import SentenceTransformerEmbeddingFunction

# all-MiniLM-L6-v2: 384 dims, very fast, great for local RAG
local_ef = SentenceTransformerEmbeddingFunction(
    model_name="all-MiniLM-L6-v2"
)

local_collection = client.create_collection(
    name="local_docs",
    embedding_function=local_ef
)

# Works identically — model runs locally, no API calls
local_collection.add(
    documents=["Local embedding with no API cost"],
    ids=["local-1"]
)

results = local_collection.query(
    query_texts=["free embeddings"],
    n_results=1
)
print(results["documents"])</code></pre>
  </section>

  <!-- Comparison Table -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">Chroma vs Pinecone vs Qdrant vs Weaviate</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm min-w-[640px]">
        <thead>
          <tr class="text-text-muted text-xs uppercase border-b border-border">
            <th class="text-left pb-3 pr-4 font-medium">Feature</th>
            <th class="text-left pb-3 pr-4 font-medium">Chroma</th>
            <th class="text-left pb-3 pr-4 font-medium">Pinecone</th>
            <th class="text-left pb-3 pr-4 font-medium">Qdrant</th>
            <th class="text-left pb-3 font-medium">Weaviate</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border text-text-muted">
          <tr><td class="py-3 pr-4 font-medium text-text">Setup time</td><td class="py-3 pr-4 text-green-500">~30 seconds</td><td class="py-3 pr-4">~5 minutes</td><td class="py-3 pr-4">~5 minutes</td><td class="py-3">~10 minutes</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Open source</td><td class="py-3 pr-4 text-green-500">Yes</td><td class="py-3 pr-4">No</td><td class="py-3 pr-4 text-green-500">Yes</td><td class="py-3 text-green-500">Yes</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">In-process mode</td><td class="py-3 pr-4 text-green-500">Yes</td><td class="py-3 pr-4">No</td><td class="py-3 pr-4">No</td><td class="py-3">No</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Managed cloud</td><td class="py-3 pr-4">No</td><td class="py-3 pr-4 text-green-500">Yes</td><td class="py-3 pr-4">Yes</td><td class="py-3">Yes</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Hybrid search</td><td class="py-3 pr-4">No</td><td class="py-3 pr-4">Limited</td><td class="py-3 pr-4 text-green-500">Yes</td><td class="py-3 text-green-500">Yes</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Scale</td><td class="py-3 pr-4">~10M vectors</td><td class="py-3 pr-4">100M+</td><td class="py-3 pr-4">Billion-scale</td><td class="py-3">100M+</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Best use case</td><td class="py-3 pr-4">Prototypes, local dev</td><td class="py-3 pr-4">Managed prod</td><td class="py-3 pr-4">Self-hosted prod</td><td class="py-3">Hybrid RAG, SaaS</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="ChromaDB Embedding Database Guide" relatedTags={['ai', 'vector-database', 'embeddings', 'rag', 'python', 'open-source']} />
</BaseLayout>
