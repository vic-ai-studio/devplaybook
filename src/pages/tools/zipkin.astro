---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const dockerExample = `# Zipkin all-in-one (in-memory storage — dev/testing)
docker run -d -p 9411:9411 openzipkin/zipkin

# With MySQL storage
docker run -d -p 9411:9411 \
  -e STORAGE_TYPE=mysql \
  -e MYSQL_HOST=mysql \
  -e MYSQL_USER=zipkin \
  -e MYSQL_PASS=zipkin \
  openzipkin/zipkin

# With Elasticsearch storage
docker run -d -p 9411:9411 \
  -e STORAGE_TYPE=elasticsearch \
  -e ES_HOSTS=http://elasticsearch:9200 \
  openzipkin/zipkin

# Open UI at http://localhost:9411`;

const otelCollectorExport = `# otel-collector-config.yaml — export to Zipkin
exporters:
  zipkin:
    endpoint: http://zipkin:9411/api/v2/spans
    format: proto   # or json

service:
  pipelines:
    traces:
      receivers: [otlp]
      processors: [batch]
      exporters: [zipkin]`;

const javaSpringExample = `# Spring Boot 3 — automatic Zipkin tracing via Micrometer
# pom.xml
<dependency>
  <groupId>io.micrometer</groupId>
  <artifactId>micrometer-tracing-bridge-brave</artifactId>
</dependency>
<dependency>
  <groupId>io.zipkin.reporter2</groupId>
  <artifactId>zipkin-reporter-brave</artifactId>
</dependency>

# application.properties
management.tracing.sampling.probability=1.0
management.zipkin.tracing.endpoint=http://zipkin:9411/api/v2/spans
spring.application.name=order-service

# That's it — all HTTP requests, DB calls, and messaging are auto-traced`;

const zipkinApiExample = `# Zipkin HTTP API v2
# POST spans (JSON)
curl -X POST http://zipkin:9411/api/v2/spans \
  -H "Content-Type: application/json" \
  -d '[{
    "traceId": "abc123def456",
    "id": "abc123def456",
    "name": "get-order",
    "timestamp": 1711584000000000,
    "duration": 45000,
    "localEndpoint": { "serviceName": "order-service" },
    "tags": { "http.status_code": "200", "order.id": "42" }
  }]'

# GET traces by service
GET /api/v2/traces?serviceName=order-service&limit=20

# GET trace by ID
GET /api/v2/trace/{traceId}

# GET services list
GET /api/v2/services`;

const faq = [
  { question: "What is Zipkin?", answer: "Zipkin is an open-source distributed tracing system originally developed by Twitter and inspired by Google's Dapper paper. It collects timing data from instrumented services and provides a UI to look up and visualize traces. Zipkin uses a push model — instrumented services report span data to the Zipkin collector over HTTP. It is one of the oldest distributed tracing tools and has wide framework support, especially in the Java ecosystem via Spring Cloud Sleuth and Micrometer Tracing." },
  { question: "What is the Zipkin B3 propagation format?", answer: "B3 is Zipkin's trace context propagation format, predating the W3C TraceContext standard. It uses HTTP headers: X-B3-TraceId (128-bit trace ID), X-B3-SpanId (64-bit span ID), X-B3-ParentSpanId (parent span), and X-B3-Sampled (0 or 1). A single-header variant encodes all of these as b3: {traceId}-{spanId}-{sampling}. OpenTelemetry supports B3 propagation natively, so Zipkin-instrumented and OTel-instrumented services can share trace context in the same trace." },
  { question: "What storage backends does Zipkin support?", answer: "Zipkin supports in-memory (development only), MySQL, Cassandra, and Elasticsearch/OpenSearch. Elasticsearch is the most common production choice due to its query flexibility and scale. The in-memory backend loses all data on restart but requires zero configuration, making it ideal for local testing. Cassandra was Zipkin's original production backend at Twitter and scales well for write-heavy workloads." },
  { question: "How does Zipkin compare to Jaeger?", answer: "Both are distributed tracing backends with similar feature sets. Key differences: Zipkin is older with broader legacy framework support (especially Java/Spring); Jaeger is CNCF-graduated and has a more active Kubernetes ecosystem with its Operator. Zipkin uses HTTP push; Jaeger supports OTLP (gRPC + HTTP), Zipkin, and Thrift. If you're starting fresh with OpenTelemetry, Jaeger or Grafana Tempo are often preferred; if you have a Spring Boot fleet already using Sleuth/Micrometer, Zipkin is a natural fit." },
  { question: "What is Zipkin Lens UI?", answer: "Zipkin Lens is the modern React-based UI included in Zipkin 2.x, replacing the older AngularJS UI. It provides service dependency graphs showing which services call which, trace search by service, operation name, tags, duration, and time range, waterfall timeline views of individual traces, and a summary panel showing the slowest spans. Access it at http://zipkin-host:9411." },
  { question: "How do I configure sampling in Zipkin?", answer: "Sampling is configured client-side in the instrumentation library — Zipkin itself stores whatever it receives. In Spring Boot / Micrometer: set management.tracing.sampling.probability=0.1 for 10% sampling. In Brave (the Java tracing library): Tracing.newBuilder().sampler(Sampler.create(0.1f)). For OpenTelemetry sending to Zipkin: configure the TraceIdRatioBased sampler in the OTel SDK. Head-based sampling is most common; tail-based sampling (deciding after seeing the full trace) requires an intermediate collector like the OTel Collector with tail-sampling processor." },
];
---

<BaseLayout
  title="Zipkin — Open-Source Distributed Tracing System"
  description="Zipkin is a distributed tracing system for collecting and visualizing timing data across microservices. Wide support in Java/Spring ecosystem via Micrometer Tracing and Brave."
  tool="Zipkin, distributed tracing, B3 propagation, Spring Boot Zipkin, Micrometer tracing, Brave, Zipkin Elasticsearch, Zipkin Lens, microservices tracing"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Zipkin — Open-Source Distributed Tracing System",
    "url": "https://devplaybook.cc/tools/zipkin",
    "description": "Zipkin is a distributed tracing system for collecting and visualizing timing data across microservices. Wide support in Java/Spring ecosystem via Micrometer Tracing.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Zipkin</h1>
  <p class="text-text-muted mb-6">
    An <strong>open-source distributed tracing system</strong> originally developed at Twitter, inspired
    by Google's Dapper research paper. Zipkin collects timing data from instrumented services and lets
    you search, visualize, and diagnose latency in distributed systems — particularly popular in the
    Java / Spring Boot ecosystem.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> B3 context propagation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Spring Boot auto-config</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Elasticsearch storage</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> OTel Collector compatible</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Zipkin?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Zipkin was open-sourced by Twitter in 2012, making it one of the oldest distributed tracing tools in the ecosystem. It implements the distributed tracing model from Google's Dapper paper: requests are tracked as a tree of <strong>spans</strong>, each representing a unit of work with a start time, duration, and metadata tags. The full tree of spans forms a <strong>trace</strong>.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    Zipkin uses a <strong>push model</strong>: instrumented services send completed spans to the Zipkin collector over HTTP. OpenTelemetry supports sending traces to Zipkin via the OTel Collector's Zipkin exporter, making it easy to migrate between backends. Spring Boot 3 includes first-class Zipkin support via Micrometer Tracing — adding two dependencies automatically instruments all HTTP requests, database calls, and messaging operations.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Storage Options</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 font-semibold">Backend</th>
          <th class="text-left py-2 pr-4 font-semibold">Use case</th>
          <th class="text-left py-2 font-semibold">Retention</th>
        </tr>
      </thead>
      <tbody class="text-text-muted">
        <tr class="border-b border-border/50"><td class="py-2 pr-4 font-mono text-xs">In-memory</td><td class="py-2 pr-4">Local dev, zero config</td><td class="py-2 font-mono text-xs">Lost on restart</td></tr>
        <tr class="border-b border-border/50"><td class="py-2 pr-4 font-mono text-xs">MySQL</td><td class="py-2 pr-4">Small-scale production</td><td class="py-2 font-mono text-xs">Persistent</td></tr>
        <tr class="border-b border-border/50"><td class="py-2 pr-4 font-mono text-xs">Cassandra</td><td class="py-2 pr-4">High write throughput</td><td class="py-2 font-mono text-xs">TTL configurable</td></tr>
        <tr><td class="py-2 pr-4 font-mono text-xs">Elasticsearch</td><td class="py-2 pr-4">Large-scale, full search</td><td class="py-2 font-mono text-xs">ILM policies</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Quick Start (Docker)</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={dockerExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Spring Boot 3 Auto-Configuration</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={javaSpringExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">OTel Collector → Zipkin</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={otelCollectorExport}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Zipkin HTTP API v2</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={zipkinApiExample}></pre>

  <ToolPageCta />
  <FaqSection faqs={faq} />
</BaseLayout>
