---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TwitterCardPreview from '../../components/TwitterCardPreview.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a Twitter/X Card and why does it matter?",
    answer: "A Twitter Card is rich media that appears when your URL is shared on X (formerly Twitter). Without cards, shared links show as plain text. With cards, you get a visual preview with your title, description, and image — dramatically improving click-through rates. Cards are controlled by meta tags in your HTML head."
  },
  {
    question: "What is the difference between summary and summary_large_image?",
    answer: "summary shows a small square thumbnail (144x144px minimum) beside the title and description — good for compact content sharing. summary_large_image shows a large prominent banner image (1200x630px recommended, 2:1 ratio) with the title and description below — better for blog posts, articles, and content where images drive clicks."
  },
  {
    question: "What image size should I use for Twitter Cards?",
    answer: "For summary_large_image: minimum 300x157px, recommended 1200x628px (or 1200x630px), maximum 5MB, ratio 1.91:1 (or 2:1). For summary: minimum 144x144px, recommended 400x400px. Use JPG or PNG. Images below 300x157px may not render on some clients. Always use absolute URLs for twitter:image — relative paths won't work."
  },
  {
    question: "Do Open Graph tags work for Twitter Cards?",
    answer: "Yes — Twitter falls back to og: meta tags if twitter: tags are missing. Twitter reads og:title, og:description, og:image, and og:url as fallbacks. This means if you already have Open Graph meta tags, Twitter Cards will work without adding twitter: tags. However, explicitly setting twitter: tags gives you more control over the Twitter appearance."
  },
  {
    question: "How do I test my Twitter Card before publishing?",
    answer: "Use Twitter's Card Validator at cards-dev.twitter.com/validator — paste your URL and it will show you the exact card Twitter will render, plus any warnings or errors. Note: the page must be publicly accessible for the validator to fetch it. After publishing, new URLs may take a few minutes to cache."
  },
  {
    question: "Why is my Twitter Card not showing an image?",
    answer: "Common reasons: (1) The image URL is not absolute or not publicly accessible. (2) The image is too small (minimum 300x157px for large card). (3) The image is over 5MB. (4) Twitter hasn't crawled the page yet — wait a few minutes and use the Card Validator to force a re-fetch. (5) The twitter:card meta tag is missing."
  },
];
---

<BaseLayout
  title="Twitter Card Preview — Test X Card Meta Tags Online"
  description="Preview your Twitter/X Card meta tags live before publishing. Configure card type (summary / summary_large_image), title, description, and image. Generates ready-to-copy meta tag HTML. No signup required."
  tool="Twitter Card Preview, X Card Generator, Twitter Meta Tags, Open Graph Twitter Preview, Social Media Preview Tool"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Twitter Card Preview",
    "url": "https://devplaybook.cc/tools/twitter-card-preview",
    "description": "Preview Twitter/X Card meta tags live. Configure card type, title, description, and image. Generates copy-ready meta tag HTML.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Twitter Card Preview</h1>
  <p class="text-text-muted mb-4">
    Preview your Twitter/X Card before publishing. Configure card type, title, description, and image URL
    to see a live visual preview — then copy the ready-to-use meta tags into your HTML.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> summary + summary_large_image</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live card preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-ready meta tags</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No signup required</span>
  </div>
  <TwitterCardPreview client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Twitter Card Preview" relatedTags={['seo', 'social-media', 'meta-tags', 'open-graph', 'marketing']} />
</BaseLayout>
