---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const agentConfigExample = `# /etc/datadog-agent/datadog.yaml (key settings)
api_key: <your-dd-api-key>
site: datadoghq.com    # or datadoghq.eu for EU region

# Enable APM tracing
apm_config:
  enabled: true
  receiver_port: 8126

# Enable log collection
logs_enabled: true

# Enable process monitoring
process_config:
  process_collection:
    enabled: true

# Enable network performance monitoring
network_config:
  enabled: true`;

const apmExample = `// APM auto-instrumentation (Node.js)
// MUST be first import — before any other requires
import tracer from 'dd-trace';

tracer.init({
  service: 'payments-api',
  env: process.env.NODE_ENV,
  version: process.env.APP_VERSION,
  logInjection: true,         // correlate logs with traces
  runtimeMetrics: true,       // Node.js heap, GC, event loop metrics
  profiling: true,            // CPU/heap profiling
});

// Custom span
const span = tracer.startSpan('process-order', {
  childOf: tracer.scope().active(),
});
span.setTag('order.id', orderId);
span.setTag('order.value', amount);
try {
  await processOrder(orderId);
} catch (err) {
  span.setTag('error', err);
  throw err;
} finally {
  span.finish();
}`;

const faq = [
  { question: "What is Datadog?", answer: "Datadog is a cloud monitoring and observability platform that unifies metrics, traces, logs, and security data into a single platform. The Datadog Agent runs on your hosts and collects system metrics, application traces (APM), container metrics, and logs, shipping them to Datadog's cloud for analysis, alerting, and visualization through dashboards." },
  { question: "What is the Datadog Agent?", answer: "The Datadog Agent is a lightweight daemon that runs on your hosts, VMs, or containers. It collects system metrics (CPU, memory, disk, network), integrates with 800+ technologies (databases, web servers, cloud services), forwards APM traces from instrumented applications, and ships logs. The Agent runs locally — your application sends traces to it on localhost:8126, and it batches and forwards them to Datadog's cloud." },
  { question: "What is Datadog APM?", answer: "Datadog APM (Application Performance Monitoring) provides distributed tracing for your services. Each request is represented as a trace — a tree of spans that shows every function call, database query, cache hit, and external HTTP call, with timing for each. APM automatically correlates traces with logs and infrastructure metrics, so when a trace is slow you can immediately see the host metrics (CPU spike, memory pressure) that caused it." },
  { question: "How does Datadog log management work?", answer: "Logs are collected by the Agent (tail log files) or shipped directly via HTTP. Datadog parses structured logs automatically and provides full-text search. Log pipelines let you parse, enrich, redact, and route logs. Logs are correlated with traces via trace_id and span_id injection, so from a slow APM trace you can jump directly to the logs from that exact request." },
  { question: "What are Datadog monitors and alerts?", answer: "Monitors are Datadog's alerting primitives. A monitor watches a metric query, log pattern, APM error rate, or composite condition and triggers alerts when thresholds are breached. Alerts route to Slack, PagerDuty, email, or webhook. Downtime schedules suppress alerts during planned maintenance. Anomaly Detection monitors use machine learning to detect unusual patterns without requiring static thresholds." },
  { question: "How is Datadog priced?", answer: "Datadog pricing is per-host per-month for infrastructure monitoring (includes the Agent and 15-month metric retention). APM is per-APM host. Logs are priced per GB ingested and per million log events analyzed/retained. Custom metrics are priced per metric. Costs can grow quickly at scale — use metric exclusion filters, log exclusion filters, and sampling to control spend." },
];
---

<BaseLayout
  title="Datadog — Cloud Infrastructure Monitoring and APM"
  description="Datadog unifies metrics, traces, logs, and security in one platform. Monitor cloud infrastructure, instrument services with APM distributed tracing, and set up alerts with 800+ integrations."
  tool="Datadog, Datadog APM, Datadog agent, distributed tracing, Datadog logs, Datadog monitors, cloud monitoring, dd-trace, Datadog dashboards"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Datadog — Cloud Infrastructure Monitoring and APM",
    "url": "https://devplaybook.cc/tools/datadog",
    "description": "Datadog unifies metrics, traces, logs, and security in one platform. Monitor cloud infrastructure, instrument services with APM distributed tracing, and set up alerts with 800+ integrations.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Datadog</h1>
  <p class="text-text-muted mb-6">
    The unified observability platform for <strong>metrics, traces, logs, and security</strong>. Datadog's Agent runs on your infrastructure, its APM auto-instruments your services, and its dashboards correlate everything into a single pane of glass — from host CPU to individual database queries.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Distributed APM tracing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 800+ integrations</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Unified metrics, logs, traces</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> ML-powered anomaly detection</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Datadog?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Datadog is a SaaS observability platform that collects telemetry data — metrics, distributed traces, logs, events, and security signals — from every layer of your stack and surfaces it through unified dashboards, intelligent alerts, and AI-powered analysis. The <strong>Datadog Agent</strong> is a lightweight daemon you deploy on each host; it handles collection, enrichment, and forwarding.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    Unlike open-source stacks where you compose Prometheus + Jaeger + ELK separately, Datadog provides a single agent, single backend, and single UI. The tradeoff is cost — Datadog is per-host SaaS, which becomes expensive at scale. The benefit is tight correlation: one click from a slow trace to the host metrics to the error logs from that exact request.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Capabilities</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Infrastructure Monitoring</strong> — CPU, memory, disk, network for hosts, containers, Kubernetes, cloud services</li>
    <li><strong>APM &amp; Distributed Tracing</strong> — end-to-end traces with automatic instrumentation for 20+ languages</li>
    <li><strong>Log Management</strong> — ingestion, parsing, full-text search, log-to-trace correlation</li>
    <li><strong>Synthetic Monitoring</strong> — browser tests and API checks that simulate user journeys</li>
    <li><strong>Real User Monitoring (RUM)</strong> — actual user session data: page load, JS errors, user actions</li>
    <li><strong>Database Monitoring</strong> — query-level performance for PostgreSQL, MySQL, MongoDB, Redis</li>
    <li><strong>Cloud Cost Management</strong> — break down and optimize AWS/Azure/GCP spend</li>
    <li><strong>Watchdog</strong> — ML anomaly detection that surfaces unusual patterns without threshold configuration</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Agent Configuration</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={agentConfigExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">APM Auto-Instrumentation (Node.js)</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={apmExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Agent Installation</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Ubuntu / Debian (one-liner)
DD_API_KEY=<your-api-key> DD_SITE="datadoghq.com" \
  bash -c "$(curl -L https://install.datadoghq.com/scripts/install_script_agent7.sh)"

# Kubernetes (Helm)
helm repo add datadog https://helm.datadoghq.com
helm install datadog datadog/datadog \
  --set datadog.apiKey=<your-api-key> \
  --set datadog.apm.portEnabled=true \
  --set datadog.logs.enabled=true

# Docker
docker run -d \
  -e DD_API_KEY=<your-api-key> \
  -e DD_SITE=datadoghq.com \
  -e DD_APM_ENABLED=true \
  -v /var/run/docker.sock:/var/run/docker.sock:ro \
  -v /proc/:/host/proc/:ro \
  gcr.io/datadoghq/agent:7</pre>

  <ToolPageCta />
  <FaqSection faqs={faq} />
</BaseLayout>
