---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UtmCampaignBuilder from '../../components/UtmCampaignBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What are UTM parameters and why do I need them?", answer: "UTM (Urchin Tracking Module) parameters are tags you append to URLs so analytics tools like Google Analytics 4 can identify exactly where a visitor came from. Without them, traffic from your email newsletter and your LinkedIn post both appear as 'direct' — you can't tell what's working. Use them on every external link you share." },
  { question: "What is the difference between utm_source, utm_medium, and utm_campaign?", answer: "utm_source is the referrer (google, newsletter, twitter), utm_medium is the marketing channel (cpc, email, social, affiliate), and utm_campaign is the specific campaign name (spring-sale, product-launch). Together they let you filter traffic by business objective in GA4 reports." },
  { question: "When should I use utm_term and utm_content?", answer: "utm_term is designed for paid keywords in search campaigns — use it to identify which keyword triggered the ad click. utm_content is for A/B testing and differentiating links in the same campaign (e.g. banner-a vs banner-b, or header-link vs footer-link)." },
  { question: "Does UTM tagging affect my website's SEO?", answer: "No. UTM parameters are stripped by Google before indexing and don't appear in canonical URLs. They are purely for analytics. However, you should not use UTM tags on internal links — that resets the session source and inflates your direct traffic numbers." },
  { question: "Are UTM parameters case-sensitive?", answer: "Yes — utm_source=Newsletter and utm_source=newsletter are counted as two different sources in GA4. Use lowercase consistently and replace spaces with hyphens or underscores. This tool uses your exact input, so maintain a consistent naming convention." },
];
---

<BaseLayout
  title="UTM Campaign URL Builder — Free UTM Parameter Generator"
  description="Build UTM-tagged URLs for Google Analytics 4 in seconds. Set utm_source, utm_medium, utm_campaign, utm_term, and utm_content with a live preview. Copy with one click. Free, runs in your browser."
  tool="UTM Builder, UTM Campaign URL, UTM Parameter Generator, GA4 UTM Tracking, utm_source utm_medium utm_campaign"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">UTM Campaign URL Builder</h1>
  <p class="text-text-muted mb-4">Generate UTM-tagged campaign URLs for Google Analytics 4. Fill in your campaign parameters, get a live URL preview, and copy it with one click. No sign-up needed — runs entirely in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Real-time URL preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GA4 & UA compatible</span>
  </div>
  <UtmCampaignBuilder client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="UTM Campaign URL Builder" relatedTags={['analytics', 'marketing', 'seo', 'url', 'tracking']} />
</BaseLayout>
