---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Prometheus Alertmanager Config Generator — Routing & Receiver Builder"
  description="Generate Prometheus Alertmanager configurations with routing rules, inhibition rules, and receivers (Slack, PagerDuty, Email, Webhook). Export as alertmanager.yml."
  tool="Alertmanager config, Prometheus alertmanager, alertmanager.yml generator, Slack receiver, PagerDuty receiver, alert routing"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Prometheus Alertmanager Config Generator",
    "url": "https://devplaybook.cc/tools/alertmanager-config-generator",
    "description": "Generate Prometheus Alertmanager configurations with routing rules, inhibition rules, and receivers for Slack, PagerDuty, Email, and Webhook.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Prometheus Alertmanager Config Generator</h1>
  <p class="text-text-muted mb-4">
    Build a production-ready <code class="bg-surface px-1 rounded text-sm">alertmanager.yml</code> with routing rules, multiple receivers, and inhibit rules.
    Configure Slack, PagerDuty, Email, and Webhook receivers — then export valid YAML.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Routing tree builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Slack / PagerDuty / Email / Webhook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Inhibit rules</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Valid YAML output</span>
  </div>

  <div class="space-y-5">

    <!-- Global Settings -->
    <div class="bg-surface border border-border rounded-xl p-5 space-y-4">
      <h2 class="text-sm font-semibold text-text-muted uppercase tracking-wide">Global Settings</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1">SMTP Smarthost</label>
          <input id="smtp-host" type="text" placeholder="smtp.gmail.com:587"
            class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1">SMTP From Address</label>
          <input id="smtp-from" type="text" placeholder="alerts@example.com"
            class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1">Slack API URL</label>
          <input id="slack-api-url" type="text" placeholder="https://hooks.slack.com/services/..."
            class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1">Resolve Timeout</label>
          <select id="resolve-timeout" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
            <option value="1m">1m</option>
            <option value="5m" selected>5m</option>
            <option value="10m">10m</option>
            <option value="30m">30m</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1">Default Receiver</label>
          <select id="default-receiver" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
            <option value="slack-notifications">slack-notifications</option>
            <option value="pagerduty-critical">pagerduty-critical</option>
            <option value="email-alerts">email-alerts</option>
            <option value="webhook-alerts">webhook-alerts</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1">Default Group Wait</label>
          <select id="default-group-wait" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
            <option value="10s">10s</option>
            <option value="30s" selected>30s</option>
            <option value="1m">1m</option>
            <option value="5m">5m</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1">Default Group Interval</label>
          <select id="default-group-interval" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
            <option value="1m">1m</option>
            <option value="5m" selected>5m</option>
            <option value="10m">10m</option>
            <option value="30m">30m</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1">Default Repeat Interval</label>
          <select id="default-repeat-interval" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
            <option value="15m">15m</option>
            <option value="30m">30m</option>
            <option value="1h" selected>1h</option>
            <option value="4h">4h</option>
            <option value="12h">12h</option>
            <option value="24h">24h</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Routes Builder -->
    <div class="bg-surface border border-border rounded-xl p-5 space-y-4">
      <div class="flex items-center justify-between">
        <h2 class="text-sm font-semibold text-text-muted uppercase tracking-wide">Routes</h2>
        <button id="add-route-btn"
          class="px-4 py-2 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">
          + Add Route
        </button>
      </div>
      <div id="routes-container" class="space-y-3">
        <!-- Routes injected by JS -->
      </div>
      <p class="text-xs text-text-muted">Routes are evaluated in order. The first matching route wins (unless <code class="bg-bg-card px-1 rounded">continue: true</code>).</p>
    </div>

    <!-- Receivers -->
    <div class="bg-surface border border-border rounded-xl p-5 space-y-5">
      <h2 class="text-sm font-semibold text-text-muted uppercase tracking-wide">Receivers</h2>

      <!-- Slack -->
      <div class="border border-border rounded-lg overflow-hidden">
        <label class="flex items-center gap-3 px-4 py-3 bg-bg-card cursor-pointer">
          <input id="enable-slack" type="checkbox" class="w-4 h-4 accent-primary" checked />
          <span class="text-sm font-semibold">Slack</span>
          <span class="text-xs text-text-muted ml-auto">slack-notifications</span>
        </label>
        <div id="slack-config" class="p-4 grid grid-cols-1 sm:grid-cols-3 gap-3">
          <div>
            <label class="block text-xs font-medium text-text-muted mb-1">Channel</label>
            <input id="slack-channel" type="text" value="#alerts"
              class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="block text-xs font-medium text-text-muted mb-1">Username</label>
            <input id="slack-username" type="text" value="AlertManager"
              class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="block text-xs font-medium text-text-muted mb-1">Title Template</label>
            <input id="slack-title" type="text" value="{{ "{{" }} .GroupLabels.alertname {{ "}}" }}"
              class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" />
          </div>
        </div>
      </div>

      <!-- PagerDuty -->
      <div class="border border-border rounded-lg overflow-hidden">
        <label class="flex items-center gap-3 px-4 py-3 bg-bg-card cursor-pointer">
          <input id="enable-pagerduty" type="checkbox" class="w-4 h-4 accent-primary" />
          <span class="text-sm font-semibold">PagerDuty</span>
          <span class="text-xs text-text-muted ml-auto">pagerduty-critical</span>
        </label>
        <div id="pagerduty-config" class="hidden p-4">
          <label class="block text-xs font-medium text-text-muted mb-1">Integration Key</label>
          <input id="pagerduty-key" type="text" placeholder="YOUR_PAGERDUTY_INTEGRATION_KEY"
            class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>
      </div>

      <!-- Email -->
      <div class="border border-border rounded-lg overflow-hidden">
        <label class="flex items-center gap-3 px-4 py-3 bg-bg-card cursor-pointer">
          <input id="enable-email" type="checkbox" class="w-4 h-4 accent-primary" />
          <span class="text-sm font-semibold">Email</span>
          <span class="text-xs text-text-muted ml-auto">email-alerts</span>
        </label>
        <div id="email-config" class="hidden p-4">
          <label class="block text-xs font-medium text-text-muted mb-1">To Address</label>
          <input id="email-to" type="text" placeholder="oncall@example.com"
            class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
        </div>
      </div>

      <!-- Webhook -->
      <div class="border border-border rounded-lg overflow-hidden">
        <label class="flex items-center gap-3 px-4 py-3 bg-bg-card cursor-pointer">
          <input id="enable-webhook" type="checkbox" class="w-4 h-4 accent-primary" />
          <span class="text-sm font-semibold">Webhook</span>
          <span class="text-xs text-text-muted ml-auto">webhook-alerts</span>
        </label>
        <div id="webhook-config" class="hidden p-4">
          <label class="block text-xs font-medium text-text-muted mb-1">Webhook URL</label>
          <input id="webhook-url" type="text" placeholder="https://example.com/webhook"
            class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
        </div>
      </div>
    </div>

    <!-- Inhibit Rules -->
    <div class="bg-surface border border-border rounded-xl p-5 space-y-3">
      <h2 class="text-sm font-semibold text-text-muted uppercase tracking-wide">Inhibit Rules</h2>
      <label class="flex items-center gap-3 cursor-pointer">
        <input id="inhibit-crit-warn" type="checkbox" class="w-4 h-4 accent-primary" checked />
        <div>
          <span class="text-sm font-medium">Suppress warnings when critical is firing</span>
          <p class="text-xs text-text-muted mt-0.5">
            source: <code class="bg-bg-card px-1 rounded">severity=critical</code> &rarr; silences target: <code class="bg-bg-card px-1 rounded">severity=warning</code> — matched on <code class="bg-bg-card px-1 rounded">alertname</code> + <code class="bg-bg-card px-1 rounded">instance</code>
          </p>
        </div>
      </label>
      <label class="flex items-center gap-3 cursor-pointer">
        <input id="inhibit-node-down" type="checkbox" class="w-4 h-4 accent-primary" />
        <div>
          <span class="text-sm font-medium">Suppress all alerts when node is down</span>
          <p class="text-xs text-text-muted mt-0.5">
            source: <code class="bg-bg-card px-1 rounded">alertname=NodeDown</code> &rarr; silences all targets — matched on <code class="bg-bg-card px-1 rounded">instance</code>
          </p>
        </div>
      </label>
    </div>

    <!-- Actions -->
    <div class="flex flex-wrap gap-3">
      <button id="generate-btn"
        class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90">
        Generate alertmanager.yml
      </button>
      <button id="load-example-btn"
        class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">
        Load Example
      </button>
      <button id="reset-btn"
        class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">
        Reset
      </button>
    </div>

    <!-- Output -->
    <div id="output-section" class="hidden bg-surface border border-border rounded-xl p-5 space-y-3">
      <div class="flex items-center justify-between">
        <h2 class="text-sm font-semibold text-text-muted uppercase tracking-wide">alertmanager.yml</h2>
        <div class="flex gap-2">
          <button id="copy-btn"
            class="px-4 py-2 bg-bg-card border border-border rounded-lg text-xs hover:border-primary transition-colors">
            Copy
          </button>
          <button id="download-btn"
            class="px-4 py-2 bg-bg-card border border-border rounded-lg text-xs hover:border-primary transition-colors">
            Download
          </button>
        </div>
      </div>
      <pre id="output" class="font-mono text-sm whitespace-pre-wrap break-words overflow-x-auto max-h-[500px] overflow-y-auto bg-bg-card border border-border rounded-lg p-4 text-foreground"></pre>
    </div>

  </div>

  <ToolPageCta currentTool="Prometheus Alertmanager Config Generator" relatedTags={['prometheus', 'alertmanager', 'devops', 'monitoring', 'yaml']} />
</BaseLayout>

<script is:inline>
(function () {
  // ── Route row state ──────────────────────────────────────────────────────────
  let routeCounter = 0;
  const routes = [];

  function createRouteRow() {
    routeCounter++;
    const id = routeCounter;
    const row = {
      id,
      matchLabel: 'severity',
      matchValue: 'critical',
      receiver: 'pagerduty-critical',
      groupWait: '10s',
      groupInterval: '5m',
      repeatInterval: '15m',
      continueRoute: false,
    };
    routes.push(row);
    renderRouteRow(row);
  }

  function renderRouteRow(row) {
    const container = document.getElementById('routes-container');
    const div = document.createElement('div');
    div.id = 'route-row-' + row.id;
    div.className = 'grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-2 items-end p-3 bg-bg-card border border-border rounded-lg';
    div.innerHTML = `
      <div>
        <label class="block text-xs text-text-muted mb-1">Match Label</label>
        <input data-field="matchLabel" type="text" value="${row.matchLabel}"
          class="w-full bg-surface border border-border rounded-lg p-2 text-xs focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Match Value</label>
        <input data-field="matchValue" type="text" value="${row.matchValue}"
          class="w-full bg-surface border border-border rounded-lg p-2 text-xs focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Receiver</label>
        <input data-field="receiver" type="text" value="${row.receiver}"
          class="w-full bg-surface border border-border rounded-lg p-2 text-xs focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Group Wait</label>
        <select data-field="groupWait"
          class="w-full bg-surface border border-border rounded-lg p-2 text-xs focus:outline-none focus:border-primary">
          ${['5s','10s','30s','1m','5m'].map(v => `<option ${v===row.groupWait?'selected':''}>${v}</option>`).join('')}
        </select>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Group Interval</label>
        <select data-field="groupInterval"
          class="w-full bg-surface border border-border rounded-lg p-2 text-xs focus:outline-none focus:border-primary">
          ${['1m','5m','10m','30m'].map(v => `<option ${v===row.groupInterval?'selected':''}>${v}</option>`).join('')}
        </select>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Repeat Interval</label>
        <select data-field="repeatInterval"
          class="w-full bg-surface border border-border rounded-lg p-2 text-xs focus:outline-none focus:border-primary">
          ${['5m','15m','30m','1h','4h','12h','24h'].map(v => `<option ${v===row.repeatInterval?'selected':''}>${v}</option>`).join('')}
        </select>
      </div>
      <div class="flex items-end gap-2">
        <label class="flex items-center gap-1 text-xs text-text-muted">
          <input data-field="continueRoute" type="checkbox" class="w-3 h-3 accent-primary" ${row.continueRoute?'checked':''} />
          continue
        </label>
        <button data-remove="${row.id}" class="ml-auto px-2 py-1.5 text-xs text-red-400 hover:text-red-300 border border-red-400/30 rounded-lg hover:border-red-400/60 transition-colors">✕</button>
      </div>
    `;

    // Bind changes back to state
    div.querySelectorAll('[data-field]').forEach(el => {
      el.addEventListener('change', () => {
        const field = el.dataset.field;
        row[field] = el.type === 'checkbox' ? el.checked : el.value;
      });
      el.addEventListener('input', () => {
        const field = el.dataset.field;
        if (el.type !== 'checkbox') row[field] = el.value;
      });
    });

    div.querySelector('[data-remove]').addEventListener('click', () => {
      const idx = routes.findIndex(r => r.id === row.id);
      if (idx !== -1) routes.splice(idx, 1);
      div.remove();
    });

    container.appendChild(div);
  }

  // ── Receiver toggle visibility ────────────────────────────────────────────────
  ['slack','pagerduty','email','webhook'].forEach(name => {
    const cb = document.getElementById('enable-' + name);
    const cfg = document.getElementById(name + '-config');
    if (!cb || !cfg) return;
    cb.addEventListener('change', () => {
      cfg.classList.toggle('hidden', !cb.checked);
    });
    // init
    if (!cb.checked) cfg.classList.add('hidden');
    else cfg.classList.remove('hidden');
  });

  // ── YAML helpers ─────────────────────────────────────────────────────────────
  function ind(n) { return '  '.repeat(n); }
  function q(v) {
    if (!v) return "''";
    if (/[:{}\[\],&*#?|<>=!%@`'"\n]/.test(v) || v.trim() !== v) return "'" + v.replace(/'/g, "''") + "'";
    return v;
  }

  // ── Generate YAML ─────────────────────────────────────────────────────────────
  function generate() {
    const smtpHost = document.getElementById('smtp-host').value.trim();
    const smtpFrom = document.getElementById('smtp-from').value.trim();
    const slackApiUrl = document.getElementById('slack-api-url').value.trim();
    const resolveTimeout = document.getElementById('resolve-timeout').value;
    const defaultReceiver = document.getElementById('default-receiver').value;
    const defaultGroupWait = document.getElementById('default-group-wait').value;
    const defaultGroupInterval = document.getElementById('default-group-interval').value;
    const defaultRepeatInterval = document.getElementById('default-repeat-interval').value;

    const enableSlack = document.getElementById('enable-slack').checked;
    const enablePagerduty = document.getElementById('enable-pagerduty').checked;
    const enableEmail = document.getElementById('enable-email').checked;
    const enableWebhook = document.getElementById('enable-webhook').checked;

    const slackChannel = document.getElementById('slack-channel').value.trim() || '#alerts';
    const slackUsername = document.getElementById('slack-username').value.trim() || 'AlertManager';
    const slackTitle = document.getElementById('slack-title').value.trim() || '{{ .GroupLabels.alertname }}';
    const pagerdutyKey = document.getElementById('pagerduty-key').value.trim() || 'YOUR_PAGERDUTY_KEY';
    const emailTo = document.getElementById('email-to').value.trim() || 'oncall@example.com';
    const webhookUrl = document.getElementById('webhook-url').value.trim() || 'https://example.com/webhook';

    const inhibitCritWarn = document.getElementById('inhibit-crit-warn').checked;
    const inhibitNodeDown = document.getElementById('inhibit-node-down').checked;

    let lines = [];

    // global
    lines.push('global:');
    lines.push(`  resolve_timeout: ${resolveTimeout}`);
    if (smtpHost) lines.push(`  smtp_smarthost: ${q(smtpHost)}`);
    if (smtpFrom) lines.push(`  smtp_from: ${q(smtpFrom)}`);
    if (slackApiUrl) lines.push(`  slack_api_url: ${q(slackApiUrl)}`);
    lines.push('');

    // route
    lines.push('route:');
    lines.push(`  receiver: ${q(defaultReceiver)}`);
    lines.push(`  group_wait: ${defaultGroupWait}`);
    lines.push(`  group_interval: ${defaultGroupInterval}`);
    lines.push(`  repeat_interval: ${defaultRepeatInterval}`);

    if (routes.length > 0) {
      lines.push('  routes:');
      routes.forEach(r => {
        lines.push(`    - match:`);
        lines.push(`        ${r.matchLabel}: ${q(r.matchValue)}`);
        lines.push(`      receiver: ${q(r.receiver)}`);
        lines.push(`      group_wait: ${r.groupWait}`);
        lines.push(`      group_interval: ${r.groupInterval}`);
        lines.push(`      repeat_interval: ${r.repeatInterval}`);
        if (r.continueRoute) lines.push(`      continue: true`);
      });
    }
    lines.push('');

    // receivers
    lines.push('receivers:');

    if (enableSlack) {
      lines.push(`  - name: 'slack-notifications'`);
      lines.push(`    slack_configs:`);
      lines.push(`      - channel: ${q(slackChannel)}`);
      lines.push(`        username: ${q(slackUsername)}`);
      lines.push(`        title: ${q(slackTitle)}`);
      lines.push(`        text: |-`);
      lines.push(`          {{ range .Alerts }}{{ .Annotations.description }}{{ "\\n" }}{{ end }}`);
      lines.push(`        send_resolved: true`);
      lines.push('');
    }

    if (enablePagerduty) {
      lines.push(`  - name: 'pagerduty-critical'`);
      lines.push(`    pagerduty_configs:`);
      lines.push(`      - integration_key: ${q(pagerdutyKey)}`);
      lines.push(`        send_resolved: true`);
      lines.push('');
    }

    if (enableEmail) {
      lines.push(`  - name: 'email-alerts'`);
      lines.push(`    email_configs:`);
      lines.push(`      - to: ${q(emailTo)}`);
      lines.push(`        send_resolved: true`);
      lines.push('');
    }

    if (enableWebhook) {
      lines.push(`  - name: 'webhook-alerts'`);
      lines.push(`    webhook_configs:`);
      lines.push(`      - url: ${q(webhookUrl)}`);
      lines.push(`        send_resolved: true`);
      lines.push('');
    }

    // inhibit rules
    if (inhibitCritWarn || inhibitNodeDown) {
      lines.push('inhibit_rules:');
      if (inhibitCritWarn) {
        lines.push(`  - source_match:`);
        lines.push(`      severity: 'critical'`);
        lines.push(`    target_match:`);
        lines.push(`      severity: 'warning'`);
        lines.push(`    equal: ['alertname', 'instance']`);
        lines.push('');
      }
      if (inhibitNodeDown) {
        lines.push(`  - source_match:`);
        lines.push(`      alertname: 'NodeDown'`);
        lines.push(`    target_match_re:`);
        lines.push(`      alertname: '.+'`);
        lines.push(`    equal: ['instance']`);
        lines.push('');
      }
    }

    return lines.join('\n').replace(/\n{3,}/g, '\n\n').trimEnd() + '\n';
  }

  // ── Load Example ─────────────────────────────────────────────────────────────
  function loadExample() {
    document.getElementById('smtp-host').value = 'smtp.gmail.com:587';
    document.getElementById('smtp-from').value = 'alerts@example.com';
    document.getElementById('slack-api-url').value = 'https://hooks.slack.com/services/YOUR_TEAM/YOUR_CHANNEL/your_webhook_token';
    document.getElementById('resolve-timeout').value = '5m';
    document.getElementById('default-receiver').value = 'slack-notifications';
    document.getElementById('default-group-wait').value = '30s';
    document.getElementById('default-group-interval').value = '5m';
    document.getElementById('default-repeat-interval').value = '1h';

    // enable all receivers
    ['slack','pagerduty','email','webhook'].forEach(name => {
      const cb = document.getElementById('enable-' + name);
      cb.checked = true;
      cb.dispatchEvent(new Event('change'));
    });

    document.getElementById('slack-channel').value = '#alerts';
    document.getElementById('slack-username').value = 'AlertManager';
    document.getElementById('pagerduty-key').value = 'abc123def456ghi789jkl012mno345p';
    document.getElementById('email-to').value = 'oncall@example.com';
    document.getElementById('webhook-url').value = 'https://example.com/alertmanager-webhook';

    document.getElementById('inhibit-crit-warn').checked = true;
    document.getElementById('inhibit-node-down').checked = false;

    // clear existing routes and add two example routes
    routes.length = 0;
    document.getElementById('routes-container').innerHTML = '';
    routeCounter = 0;

    const r1 = { id: ++routeCounter, matchLabel: 'severity', matchValue: 'critical', receiver: 'pagerduty-critical', groupWait: '10s', groupInterval: '5m', repeatInterval: '15m', continueRoute: false };
    routes.push(r1);
    renderRouteRow(r1);

    const r2 = { id: ++routeCounter, matchLabel: 'team', matchValue: 'frontend', receiver: 'slack-notifications', groupWait: '30s', groupInterval: '5m', repeatInterval: '1h', continueRoute: false };
    routes.push(r2);
    renderRouteRow(r2);

    generateAndShow();
  }

  function generateAndShow() {
    const yaml = generate();
    document.getElementById('output').textContent = yaml;
    document.getElementById('output-section').classList.remove('hidden');
    document.getElementById('output-section').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function resetAll() {
    ['smtp-host','smtp-from','slack-api-url'].forEach(id => document.getElementById(id).value = '');
    document.getElementById('resolve-timeout').value = '5m';
    document.getElementById('default-receiver').value = 'slack-notifications';
    document.getElementById('default-group-wait').value = '30s';
    document.getElementById('default-group-interval').value = '5m';
    document.getElementById('default-repeat-interval').value = '1h';

    document.getElementById('enable-slack').checked = true;
    ['pagerduty','email','webhook'].forEach(name => {
      document.getElementById('enable-' + name).checked = false;
    });
    ['slack','pagerduty','email','webhook'].forEach(name => {
      const cb = document.getElementById('enable-' + name);
      cb.dispatchEvent(new Event('change'));
    });

    document.getElementById('inhibit-crit-warn').checked = true;
    document.getElementById('inhibit-node-down').checked = false;
    routes.length = 0;
    document.getElementById('routes-container').innerHTML = '';
    routeCounter = 0;
    document.getElementById('output-section').classList.add('hidden');
  }

  // ── Event listeners ───────────────────────────────────────────────────────────
  document.getElementById('add-route-btn').addEventListener('click', createRouteRow);
  document.getElementById('generate-btn').addEventListener('click', generateAndShow);
  document.getElementById('load-example-btn').addEventListener('click', loadExample);
  document.getElementById('reset-btn').addEventListener('click', resetAll);

  document.getElementById('copy-btn').addEventListener('click', () => {
    const text = document.getElementById('output').textContent;
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById('copy-btn');
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
    });
  });

  document.getElementById('download-btn').addEventListener('click', () => {
    const text = document.getElementById('output').textContent;
    const blob = new Blob([text], { type: 'text/yaml' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'alertmanager.yml';
    a.click();
    URL.revokeObjectURL(url);
  });

  // ── Init: add one default route ───────────────────────────────────────────────
  createRouteRow();
})();
</script>
