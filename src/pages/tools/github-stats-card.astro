---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GitHubStatsCard from '../../components/GitHubStatsCard.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="GitHub Stats Card Generator — Embeddable SVG for Your README"
  description="Generate a beautiful, embeddable GitHub stats card. Input your username to get repos, stars, followers, and top languages as a shareable SVG card — paste it straight into your README."
  tool="GitHub Stats Card, GitHub Profile Card, GitHub README Card, GitHub Stats SVG"
>
  <h1 class="text-3xl font-bold mb-2">GitHub Stats Card Generator</h1>
  <p class="text-text-muted mb-8">Enter your GitHub username to generate an embeddable stats card — shows repos, total stars, followers, and top languages. Copy the Markdown or HTML and paste it into your README.</p>
  <GitHubStatsCard client:load />
  <ToolPageCta currentTool="GitHub Stats Card Generator" relatedTags={['github', 'readme', 'profile', 'developer-tools']} />
</BaseLayout>
