---
import BaseLayout from '../../layouts/BaseLayout.astro';
import KubernetesPdbGenerator from '../../components/KubernetesPdbGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a PodDisruptionBudget (PDB)?",
    answer: "A PodDisruptionBudget is a Kubernetes policy resource that limits the number of pods that can be voluntarily disrupted at one time. Voluntary disruptions include node drains (kubectl drain), cluster upgrades, and evictions by the Cluster Autoscaler. A PDB protects your service's availability during these maintenance operations by telling Kubernetes: 'don't evict pods if it would leave fewer than N available.' PDBs do NOT protect against involuntary disruptions like hardware failures or OOMKill."
  },
  {
    question: "What is the difference between minAvailable and maxUnavailable?",
    answer: "minAvailable sets the minimum number (or percentage) of pods that must be running and ready at all times. Kubernetes won't evict a pod if doing so would drop below this threshold. maxUnavailable sets the maximum number (or percentage) of pods that can be unavailable at the same time. Kubernetes won't evict a pod if already maxUnavailable pods are down. minAvailable is easier to reason about for stateful services; maxUnavailable maps naturally to rolling update semantics. Pick one — don't set both in the same PDB."
  },
  {
    question: "Should I use a number or percentage?",
    answer: "Use a percentage if your deployment scales up and down frequently (e.g., with HPA). Percentages scale with your replica count automatically — minAvailable: 50% on a 10-replica deployment allows 5 disruptions; on a 4-replica deployment it allows 2. Use a fixed number if you have a stable replica count or need precise guarantees (e.g., minAvailable: 2 on a 3-replica stateful cluster ensures at least 2 nodes stay up for quorum). Important: if minAvailable equals your total replica count, no voluntary evictions are ever permitted — kubectl drain will block forever."
  },
  {
    question: "What does unhealthyPodEvictionPolicy: AlwaysAllow do?",
    answer: "By default, Kubernetes won't evict unhealthy pods (not Running or not Ready) if they count against the PDB budget. This can cause kubectl drain to hang when you have crashed pods. Setting unhealthyPodEvictionPolicy: AlwaysAllow lets Kubernetes evict unhealthy pods regardless of the PDB budget. This was added in Kubernetes 1.26. Use it when you want drains to succeed even when pods are already failing — but be aware it may reduce your available pod count below minAvailable temporarily."
  },
  {
    question: "How does a PDB interact with Cluster Autoscaler or kubectl drain?",
    answer: "Both the Cluster Autoscaler and kubectl drain are PDB-aware — they check existing PDBs before evicting pods. If evicting a pod would violate a PDB, the operation blocks and retries until it's safe. kubectl drain will print a 'Cannot evict pod as it would violate the pod's disruption budget' message and wait. The Cluster Autoscaler will skip a node and retry on the next cycle. This is exactly the behavior you want — it prevents scale-down or drain from breaking your service's availability guarantees."
  },
  {
    question: "What is the matchLabels selector and how do I find the right labels?",
    answer: "matchLabels selects which pods this PDB applies to, using the same label selectors as Kubernetes Services and Deployments. Run kubectl get pods --show-labels to see pod labels, or kubectl get deployment my-app -o yaml to find the selector. Typically you'd match the same labels as your Deployment's selector (e.g., app: my-app, version: v2). The PDB only applies to pods it selects — if your selector doesn't match any pods, the PDB has no effect."
  },
];
---

<BaseLayout
  title="Kubernetes PodDisruptionBudget Generator — K8s PDB YAML"
  description="Generate Kubernetes PodDisruptionBudget (PDB) YAML interactively. Configure minAvailable or maxUnavailable, label selectors, namespace, and unhealthyPodEvictionPolicy. Copy or download ready-to-apply YAML with plain-English explanation."
  tool="Kubernetes PodDisruptionBudget, PDB generator, K8s PDB YAML, minAvailable maxUnavailable, kubectl PDB"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Kubernetes PodDisruptionBudget Generator",
    "url": "https://devplaybook.cc/tools/kubernetes-pod-disruption-budget",
    "description": "Generate Kubernetes PodDisruptionBudget YAML interactively. Configure minAvailable or maxUnavailable with fixed numbers or percentages, label selectors, and get a plain-English explanation of what the policy does.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Kubernetes PodDisruptionBudget Generator</h1>
  <p class="text-text-muted mb-4">
    Generate <strong>PodDisruptionBudget YAML</strong> for your Kubernetes workloads. Configure <code class="font-mono text-sm bg-surface px-1 rounded">minAvailable</code> or <code class="font-mono text-sm bg-surface px-1 rounded">maxUnavailable</code> with fixed counts or percentages, add label selectors, and get a plain-English explanation of what the policy does.
    Protects service availability during node drains and cluster upgrades.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> minAvailable + maxUnavailable</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Number or percentage values</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Label selector builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Plain-English explanation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy + Download YAML</span>
  </div>

  <KubernetesPdbGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Kubernetes PodDisruptionBudget Generator" relatedTags={['kubernetes', 'devops', 'cloud', 'infrastructure', 'k8s']} />
</BaseLayout>
