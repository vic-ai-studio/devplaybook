---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is the difference between INNER JOIN and LEFT JOIN?", answer: "INNER JOIN returns only rows where the join condition matches in BOTH tables. LEFT JOIN (LEFT OUTER JOIN) returns all rows from the left table plus matched rows from the right table — unmatched right-side columns are NULL. Use LEFT JOIN when you want to keep all left-table rows regardless of whether there's a match." },
  { question: "What is a CROSS JOIN?", answer: "CROSS JOIN produces the Cartesian product — every row from the left table paired with every row from the right table. A 5-row table CROSS JOINed with a 4-row table produces 20 rows. Usually accidental (missing ON clause); intentional uses include generating test data or combinations." },
  { question: "What is a SELF JOIN?", answer: "A SELF JOIN joins a table with itself, using table aliases. Common use cases: employee-manager hierarchies, finding duplicate rows, comparing rows within the same table. Example: SELECT e.name, m.name AS manager FROM employees e JOIN employees m ON e.manager_id = m.id." },
  { question: "When should I use FULL OUTER JOIN?", answer: "FULL OUTER JOIN returns all rows from both tables, with NULLs where there's no match. Use it when you want to see non-matching rows from both sides — for example, finding records in Table A that have no match in Table B AND records in Table B with no match in Table A simultaneously." },
];
---

<BaseLayout
  title="SQL JOIN Visualizer — Interactive INNER, LEFT, RIGHT, FULL OUTER JOIN"
  description="Visualize all SQL JOIN types with interactive Venn diagrams and live sample data. See INNER, LEFT, RIGHT, FULL OUTER, CROSS, and SELF JOIN results instantly."
  tool="SQL JOIN Visualizer, SQL Join Types, INNER JOIN vs LEFT JOIN, SQL Join Diagram"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">SQL JOIN Visualizer</h1>
  <p class="text-text-muted mb-4">Explore all SQL JOIN types with live Venn diagrams, SQL queries, and sample data results.</p>

  <!-- Join selector -->
  <div class="flex flex-wrap gap-2 mb-5">
    {['INNER JOIN', 'LEFT JOIN', 'RIGHT JOIN', 'FULL OUTER JOIN', 'LEFT EXCL', 'RIGHT EXCL', 'CROSS JOIN'].map(j => (
      <button class="join-btn text-sm border border-border px-3 py-1.5 rounded-lg hover:bg-primary/10 hover:border-primary/50" data-join={j}>{j}</button>
    ))}
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
    <!-- Venn diagram + description -->
    <div class="space-y-4">
      <div class="bg-bg-card border border-border rounded-xl p-5 flex flex-col items-center">
        <svg id="venn-svg" viewBox="0 0 200 120" class="w-full max-w-xs" xmlns="http://www.w3.org/2000/svg">
          <!-- Left circle -->
          <circle id="venn-left" cx="75" cy="60" r="45" fill="none" stroke="currentColor" class="text-border" stroke-width="1.5"/>
          <!-- Right circle -->
          <circle id="venn-right" cx="125" cy="60" r="45" fill="none" stroke="currentColor" class="text-border" stroke-width="1.5"/>
          <!-- Labels -->
          <text x="48" y="64" text-anchor="middle" class="fill-text-muted text-xs" style="font-size:8px">A</text>
          <text x="152" y="64" text-anchor="middle" class="fill-text-muted text-xs" style="font-size:8px">B</text>
          <!-- Highlight areas via clipPaths -->
          <defs>
            <clipPath id="clip-left"><circle cx="75" cy="60" r="44"/></clipPath>
            <clipPath id="clip-right"><circle cx="125" cy="60" r="44"/></clipPath>
          </defs>
          <!-- Filled regions -->
          <rect id="fill-left-only" x="20" y="14" width="56" height="92" clip-path="url(#clip-left)" fill="transparent"/>
          <rect id="fill-right-only" x="124" y="14" width="56" height="92" clip-path="url(#clip-right)" fill="transparent"/>
          <rect id="fill-center" x="100" y="14" width="0" height="92" clip-path="url(#clip-left)" fill="transparent"/>
        </svg>
        <p id="join-desc" class="text-xs text-text-muted text-center mt-2 leading-relaxed"></p>
      </div>

      <!-- SQL query -->
      <div class="bg-bg-card border border-border rounded-xl p-4">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-medium text-text-muted">SQL Query</span>
          <button id="copy-sql" class="text-xs text-text-muted border border-border px-2 py-0.5 rounded hover:bg-bg">Copy</button>
        </div>
        <pre id="sql-query" class="text-xs font-mono bg-bg rounded-lg px-3 py-2 text-text-muted whitespace-pre overflow-auto"></pre>
      </div>
    </div>

    <!-- Sample tables -->
    <div class="space-y-4">
      <div class="bg-bg-card border border-border rounded-xl p-4">
        <div class="text-xs font-semibold mb-2">Table A (employees)</div>
        <table class="w-full text-xs">
          <thead><tr class="text-left text-text-muted border-b border-border"><th class="pb-1">id</th><th class="pb-1">name</th><th class="pb-1">dept_id</th></tr></thead>
          <tbody class="font-mono">
            <tr><td>1</td><td>Alice</td><td>10</td></tr>
            <tr><td>2</td><td>Bob</td><td>20</td></tr>
            <tr><td>3</td><td>Carol</td><td>30</td></tr>
            <tr><td>4</td><td>Dave</td><td class="text-red-400/70">NULL</td></tr>
          </tbody>
        </table>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-4">
        <div class="text-xs font-semibold mb-2">Table B (departments)</div>
        <table class="w-full text-xs">
          <thead><tr class="text-left text-text-muted border-b border-border"><th class="pb-1">id</th><th class="pb-1">dept_name</th></tr></thead>
          <tbody class="font-mono">
            <tr><td>10</td><td>Engineering</td></tr>
            <tr><td>20</td><td>Marketing</td></tr>
            <tr><td>40</td><td>Finance</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Result -->
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <div class="text-xs font-semibold mb-2">Result</div>
      <div id="result-table" class="overflow-auto"></div>
      <p id="row-count" class="text-xs text-text-muted mt-2"></p>
    </div>
  </div>

  <AdUnit slot="in-content" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SQL JOIN Visualizer" relatedTags={['database', 'sql', 'postgresql', 'mysql', 'backend']} />
</BaseLayout>

<script>
interface Row { id: number; name?: string; dept_id?: number | null; dept_name?: string }

const tableA = [
  { id: 1, name: 'Alice', dept_id: 10 },
  { id: 2, name: 'Bob', dept_id: 20 },
  { id: 3, name: 'Carol', dept_id: 30 },
  { id: 4, name: 'Dave', dept_id: null },
];
const tableB = [
  { id: 10, dept_name: 'Engineering' },
  { id: 20, dept_name: 'Marketing' },
  { id: 40, dept_name: 'Finance' },
];

const joins: Record<string, {
  desc: string; sql: string;
  leftFill: string; rightFill: string; centerFill: string;
  compute: () => (Record<string, unknown>)[];
}> = {
  'INNER JOIN': {
    desc: 'Returns only rows where the join condition matches in BOTH tables.',
    sql: `SELECT a.id, a.name, b.dept_name\nFROM employees a\nINNER JOIN departments b\n  ON a.dept_id = b.id;`,
    leftFill: 'transparent', rightFill: 'transparent', centerFill: '#6366f180',
    compute: () => tableA.flatMap(a => tableB.filter(b => a.dept_id === b.id).map(b => ({ 'a.id': a.id, 'a.name': a.name, 'b.dept_name': b.dept_name }))),
  },
  'LEFT JOIN': {
    desc: 'Returns ALL rows from the left table, plus matched rows from right. Unmatched right columns are NULL.',
    sql: `SELECT a.id, a.name, b.dept_name\nFROM employees a\nLEFT JOIN departments b\n  ON a.dept_id = b.id;`,
    leftFill: '#6366f180', rightFill: 'transparent', centerFill: '#6366f180',
    compute: () => tableA.map(a => { const b = tableB.find(b => a.dept_id === b.id); return { 'a.id': a.id, 'a.name': a.name, 'b.dept_name': b?.dept_name ?? 'NULL' }; }),
  },
  'RIGHT JOIN': {
    desc: 'Returns ALL rows from the right table, plus matched rows from left. Unmatched left columns are NULL.',
    sql: `SELECT a.id, a.name, b.dept_name\nFROM employees a\nRIGHT JOIN departments b\n  ON a.dept_id = b.id;`,
    leftFill: 'transparent', rightFill: '#6366f180', centerFill: '#6366f180',
    compute: () => tableB.map(b => { const a = tableA.find(a => a.dept_id === b.id); return { 'a.id': a?.id ?? 'NULL', 'a.name': a?.name ?? 'NULL', 'b.dept_name': b.dept_name }; }),
  },
  'FULL OUTER JOIN': {
    desc: 'Returns ALL rows from both tables. NULLs where there is no match on either side.',
    sql: `SELECT a.id, a.name, b.dept_name\nFROM employees a\nFULL OUTER JOIN departments b\n  ON a.dept_id = b.id;`,
    leftFill: '#6366f180', rightFill: '#6366f180', centerFill: '#6366f180',
    compute: () => {
      const left = tableA.map(a => { const b = tableB.find(b => a.dept_id === b.id); return { 'a.id': a.id, 'a.name': a.name, 'b.dept_name': b?.dept_name ?? 'NULL' }; });
      const right = tableB.filter(b => !tableA.some(a => a.dept_id === b.id)).map(b => ({ 'a.id': 'NULL', 'a.name': 'NULL', 'b.dept_name': b.dept_name }));
      return [...left, ...right];
    },
  },
  'LEFT EXCL': {
    desc: 'Returns rows from the left table that have NO match in the right table (left-only rows).',
    sql: `SELECT a.id, a.name\nFROM employees a\nLEFT JOIN departments b\n  ON a.dept_id = b.id\nWHERE b.id IS NULL;`,
    leftFill: '#6366f180', rightFill: 'transparent', centerFill: 'transparent',
    compute: () => tableA.filter(a => !tableB.some(b => a.dept_id === b.id)).map(a => ({ 'a.id': a.id, 'a.name': a.name, 'b.dept_name': 'NULL' })),
  },
  'RIGHT EXCL': {
    desc: 'Returns rows from the right table that have NO match in the left table (right-only rows).',
    sql: `SELECT b.id, b.dept_name\nFROM employees a\nRIGHT JOIN departments b\n  ON a.dept_id = b.id\nWHERE a.id IS NULL;`,
    leftFill: 'transparent', rightFill: '#6366f180', centerFill: 'transparent',
    compute: () => tableB.filter(b => !tableA.some(a => a.dept_id === b.id)).map(b => ({ 'a.id': 'NULL', 'a.name': 'NULL', 'b.dept_name': b.dept_name })),
  },
  'CROSS JOIN': {
    desc: 'Produces every combination of rows from both tables (Cartesian product). No ON clause needed.',
    sql: `SELECT a.name, b.dept_name\nFROM employees a\nCROSS JOIN departments b;`,
    leftFill: '#6366f140', rightFill: '#6366f140', centerFill: '#6366f140',
    compute: () => tableA.flatMap(a => tableB.map(b => ({ 'a.name': a.name, 'b.dept_name': b.dept_name }))),
  },
};

let currentJoin = 'INNER JOIN';

function renderJoin(name: string) {
  currentJoin = name;
  const j = joins[name];
  if (!j) return;

  // Highlight buttons
  document.querySelectorAll('.join-btn').forEach(btn => {
    btn.classList.toggle('bg-primary/10', (btn as HTMLElement).dataset.join === name);
    btn.classList.toggle('border-primary/50', (btn as HTMLElement).dataset.join === name);
    btn.classList.toggle('text-primary', (btn as HTMLElement).dataset.join === name);
  });

  // Venn diagram
  document.getElementById('fill-left-only')!.setAttribute('fill', j.leftFill);
  document.getElementById('fill-right-only')!.setAttribute('fill', j.rightFill);
  // Center fill: use a wider rect clipped to left circle
  const center = document.getElementById('fill-center')!;
  center.setAttribute('x', '75');
  center.setAttribute('width', '56');
  center.setAttribute('fill', j.centerFill);

  document.getElementById('join-desc')!.textContent = j.desc;
  document.getElementById('sql-query')!.textContent = j.sql;

  // Result table
  const rows = j.compute();
  if (rows.length === 0) {
    document.getElementById('result-table')!.innerHTML = '<p class="text-xs text-text-muted">No rows returned.</p>';
  } else {
    const cols = Object.keys(rows[0]);
    const thead = `<thead><tr class="text-left text-xs text-text-muted border-b border-border">${cols.map(c => `<th class="pb-1 pr-3">${c}</th>`).join('')}</tr></thead>`;
    const tbody = `<tbody class="font-mono text-xs">${rows.map(r =>
      `<tr class="border-b border-border/30">${cols.map(c => {
        const v = r[c];
        const cls = v === 'NULL' ? 'text-red-400/70' : '';
        return `<td class="py-0.5 pr-3 ${cls}">${v}</td>`;
      }).join('')}</tr>`
    ).join('')}</tbody>`;
    document.getElementById('result-table')!.innerHTML = `<table class="w-full">${thead}${tbody}</table>`;
  }
  document.getElementById('row-count')!.textContent = `${rows.length} row${rows.length !== 1 ? 's' : ''} returned`;
}

document.querySelectorAll('.join-btn').forEach(btn => {
  btn.addEventListener('click', (e) => renderJoin((e.currentTarget as HTMLElement).dataset.join!));
});

document.getElementById('copy-sql')!.addEventListener('click', () => {
  navigator.clipboard.writeText(document.getElementById('sql-query')!.textContent || '');
});

renderJoin('INNER JOIN');
</script>
