  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"LangChain: LLM Application Framework Guide 2026","url":"https://devplaybook.cc/tools/langchain","description":"Complete LangChain guide — LCEL, RAG chains, agents, document loaders, LangSmith observability, and comparison with LlamaIndex."})} />

  <h1 class="text-3xl font-bold mb-2">LangChain: LLM Application Framework Guide 2026</h1>
  <p class="text-text-muted mb-6">LangChain is the most widely used framework for building LLM-powered applications. It provides composable building blocks for RAG pipelines, autonomous agents, document processing, conversation memory, and LLM chain orchestration — with integrations for 100+ LLM providers, vector databases, and external tools. Build production AI apps faster with LCEL's declarative chain syntax.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> LCEL composable chains</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100+ LLM integrations</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> RAG pipelines</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Agents &amp; tools</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> LangSmith observability</span>
  </div>

  <ToolPageCta />

  <!-- LCEL Basics -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">LCEL: LangChain Expression Language</h2>
    <p class="text-text-muted mb-4">Build composable chains with the pipe operator. Every component is a Runnable with invoke/stream/batch support.</p>
    <pre class="bg-bg-card border border-border rounded-xl p-4 text-sm font-mono overflow-x-auto mb-4"><code class="text-green-400">pip install langchain langchain-openai langchain-community

from langchain_openai import ChatOpenAI
from langchain_core.prompts import ChatPromptTemplate
from langchain_core.output_parsers import StrOutputParser

llm = ChatOpenAI(model="gpt-4o-mini", temperature=0)

# LCEL chain — pipe operator composes Runnables
prompt = ChatPromptTemplate.from_messages([
    ("system", "You are a helpful developer assistant. Be concise."),
    ("human", "&#123;question&#125;")
])

chain = prompt | llm | StrOutputParser()

# Invoke synchronously
result = chain.invoke(&#123;"question": "What is HNSW indexing?"&#125;)
print(result)

# Stream tokens in real-time
for chunk in chain.stream(&#123;"question": "Explain RAG in 3 steps"&#125;):
    print(chunk, end="", flush=True)

# Batch multiple inputs efficiently
results = chain.batch([
    &#123;"question": "What is pgvector?"&#125;,
    &#123;"question": "What is Qdrant?"&#125;,
    &#123;"question": "What is LangSmith?"&#125;,
])

# Async support (in async context)
# result = await chain.ainvoke(&#123;"question": "..."&#125;)</code></pre>
  </section>

  <!-- RAG Pipeline -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">Building a RAG Pipeline with LCEL</h2>
    <p class="text-text-muted mb-4">Load documents, split, embed, store in a vector DB, then wire up a retrieval-augmented generation chain.</p>
    <pre class="bg-bg-card border border-border rounded-xl p-4 text-sm font-mono overflow-x-auto mb-4"><code class="text-green-400">from langchain_community.document_loaders import WebBaseLoader, DirectoryLoader
from langchain.text_splitter import RecursiveCharacterTextSplitter
from langchain_openai import OpenAIEmbeddings
from langchain_community.vectorstores import Chroma
from langchain_core.runnables import RunnablePassthrough
from langchain_core.prompts import ChatPromptTemplate

# 1. Load documents
loader = DirectoryLoader("./docs", glob="**/*.md")
docs = loader.load()

# 2. Split into chunks
splitter = RecursiveCharacterTextSplitter(
    chunk_size=1000,
    chunk_overlap=200,
    separators=["\n\n", "\n", ".", " "]
)
chunks = splitter.split_documents(docs)

# 3. Embed and store in vector database
embeddings = OpenAIEmbeddings(model="text-embedding-3-small")
vectorstore = Chroma.from_documents(chunks, embeddings, persist_directory="./chroma")
retriever = vectorstore.as_retriever(search_kwargs=&#123;"k": 4&#125;)

# 4. RAG prompt template
rag_prompt = ChatPromptTemplate.from_messages([
    ("system", """Answer the question using only the following context.
If the answer is not in the context, say "I don't know."

Context:
&#123;context&#125;"""),
    ("human", "&#123;question&#125;")
])

def format_docs(docs):
    return "\n\n".join(doc.page_content for doc in docs)

# 5. LCEL RAG chain
rag_chain = (
    &#123;"context": retriever | format_docs, "question": RunnablePassthrough()&#125;
    | rag_prompt
    | llm
    | StrOutputParser()
)

answer = rag_chain.invoke("What is the main architecture of Milvus?")
print(answer)</code></pre>
  </section>

  <!-- Agents -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">LangChain Agents with Tool Use</h2>
    <p class="text-text-muted mb-4">Create an agent that dynamically decides which tools to call to answer a user's question.</p>
    <pre class="bg-bg-card border border-border rounded-xl p-4 text-sm font-mono overflow-x-auto mb-4"><code class="text-green-400">from langchain_core.tools import tool
from langchain.agents import create_tool_calling_agent, AgentExecutor
from langchain_core.prompts import ChatPromptTemplate, MessagesPlaceholder
import httpx

@tool
def web_search(query: str) -> str:
    """Search the web for current information about a topic."""
    # Placeholder — integrate Tavily or SerpAPI in production
    return f"Search results for: &#123;query&#125;"

@tool
def calculator(expression: str) -> str:
    """Evaluate a mathematical expression. Input: valid Python math expression."""
    try:
        return str(eval(expression, &#123;"__builtins__": &#123;&#125;&#125;))
    except Exception as e:
        return f"Error: &#123;e&#125;"

tools = [web_search, calculator]

agent_prompt = ChatPromptTemplate.from_messages([
    ("system", "You are a helpful assistant. Use tools when needed."),
    ("human", "&#123;input&#125;"),
    MessagesPlaceholder("agent_scratchpad")
])

agent = create_tool_calling_agent(llm, tools, agent_prompt)
executor = AgentExecutor(agent=agent, tools=tools, verbose=True)

result = executor.invoke(&#123;"input": "What is 256 * 1536 and why does that number matter for embeddings?"&#125;)
print(result["output"])

# Enable LangSmith tracing (set env vars)
import os
os.environ["LANGCHAIN_TRACING_V2"] = "true"
os.environ["LANGCHAIN_API_KEY"] = "YOUR_LANGSMITH_KEY"</code></pre>
  </section>

