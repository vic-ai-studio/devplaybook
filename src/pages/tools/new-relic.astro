---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const apmExample = `// New Relic APM — Node.js auto-instrumentation
// 1. Install the agent
// npm install newrelic

// 2. newrelic.js (project root — loaded before everything else)
'use strict';
exports.config = {
  app_name: ['My Application'],
  license_key: process.env.NEW_RELIC_LICENSE_KEY,
  logging: { level: 'info' },
  allow_all_headers: true,
  distributed_tracing: { enabled: true },
  application_logging: {
    forwarding: { enabled: true },
    local_decorating: { enabled: true },
  },
  transaction_tracer: {
    enabled: true,
    transaction_threshold: 'apdex_f', // trace transactions slower than Apdex threshold
    record_sql: 'obfuscated',
    explain_threshold: 500, // ms — log slow query explain plans
  },
};

// 3. Require newrelic as FIRST LINE of your entry point
require('newrelic');
const express = require('express');`;

const nrqlExample = `-- NRQL (New Relic Query Language) Examples

-- Error rate over the last hour
SELECT percentage(count(*), WHERE error IS TRUE)
FROM Transaction
WHERE appName = 'my-app'
SINCE 1 hour ago

-- P95 response time by endpoint
SELECT percentile(duration, 95)
FROM Transaction
WHERE appName = 'my-app'
FACET request.uri
SINCE 30 minutes ago

-- Throughput (requests per minute)
SELECT rate(count(*), 1 minute)
FROM Transaction
WHERE appName = 'my-app'
TIMESERIES 1 minute
SINCE 1 hour ago

-- Database slow queries
SELECT average(databaseDuration), count(*)
FROM Transaction
WHERE databaseDuration > 0.1
FACET databaseType
SINCE 1 day ago`;

const faq = [
  { question: "What is New Relic?", answer: "New Relic is a SaaS observability platform that provides full-stack telemetry: APM (application performance monitoring), infrastructure monitoring, distributed tracing, log management, browser monitoring (RUM), mobile monitoring, and synthetic testing. Its key differentiator is a unified data platform called the New Relic Database (NRDB) — all telemetry is stored together and queryable with NRQL, enabling deep correlation across signal types." },
  { question: "What is NRQL?", answer: "NRQL (New Relic Query Language) is New Relic's SQL-like query language for querying all telemetry data — events, metrics, logs, and traces — stored in NRDB. It supports SELECT, FROM, WHERE, FACET (group by), TIMESERIES (time bucketing), SINCE/UNTIL (time range), LIMIT, and aggregate functions like percentile(), rate(), filter(), funnel(), and uniqueCount(). NRQL powers all New Relic dashboards, alerts, and the Query Builder." },
  { question: "What is Apdex?", answer: "Apdex (Application Performance Index) is an industry standard score from 0 to 1 measuring user satisfaction with response time. You set a threshold T (e.g., 500ms). Requests under T are 'satisfied' (score 1), requests between T and 4T are 'tolerating' (score 0.5), and requests over 4T are 'frustrated' (score 0). The Apdex score is the weighted average: (Satisfied + Tolerating/2) / Total. New Relic displays Apdex prominently as a single health metric for each service." },
  { question: "How does New Relic distributed tracing work?", answer: "New Relic uses W3C Trace Context headers (traceparent, tracestate) or its own DT headers to propagate trace context across service boundaries. Each APM agent automatically injects headers on outbound HTTP calls and extracts them on inbound requests, creating parent-child span relationships. The resulting trace waterfall shows every service, database call, and external request in a single request's journey with timing and error information." },
  { question: "What is New Relic's pricing model?", answer: "New Relic uses a consumption-based model: you pay for data ingest (GB per month) and for Full Platform Users. The free tier includes 100GB/month data ingest and 1 full platform user. Core Users (limited capabilities) and Basic Users (read-only) are free. This model is transparent — your bill scales with data volume rather than host count, which benefits organizations with many small containers but penalizes those with high-cardinality or verbose logging." },
  { question: "How does New Relic compare to Datadog?", answer: "Both are full-stack SaaS observability platforms. Key differences: New Relic uses consumption-based pricing (per GB ingested + user seats) vs Datadog's per-host pricing. New Relic has a more generous free tier (100GB/month). Datadog has stronger infrastructure monitoring and more third-party integrations (800+). New Relic's NRDB unified data model makes cross-telemetry queries simpler. Datadog is generally stronger for infrastructure-heavy deployments; New Relic for application-centric teams." },
];
---

<BaseLayout
  title="New Relic — Full-Stack Observability and APM Platform"
  description="New Relic provides APM, distributed tracing, infrastructure monitoring, logs, and browser RUM in one platform. Query all telemetry with NRQL and correlate errors with traces, logs, and host metrics."
  tool="New Relic, New Relic APM, NRQL, New Relic distributed tracing, New Relic logs, New Relic browser, Apdex, New Relic alerting, full-stack observability"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "New Relic — Full-Stack Observability and APM Platform",
    "url": "https://devplaybook.cc/tools/new-relic",
    "description": "New Relic provides APM, distributed tracing, infrastructure monitoring, logs, and browser RUM in one platform. Query all telemetry with NRQL and correlate errors with traces, logs, and host metrics.",
  })} />

  <h1 class="text-3xl font-bold mb-2">New Relic</h1>
  <p class="text-text-muted mb-6">
    <strong>Full-stack observability</strong> from one platform. New Relic's unified NRDB stores all your telemetry —
    APM traces, infrastructure metrics, browser RUM, logs, and synthetic results — and lets you query and correlate
    everything with <code class="bg-bg-card px-1 rounded text-xs">NRQL</code>, a powerful SQL-like query language.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> APM + distributed tracing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> NRQL unified query language</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100GB/month free tier</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Browser RUM + synthetic</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is New Relic?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    New Relic is a cloud observability platform that ingests all telemetry types — metrics, events, logs, and traces (MELT) — into a single database called NRDB. Unlike traditional monitoring tools that store each signal type separately, NRDB enables cross-signal correlation: jump from an error event to the distributed trace to the infrastructure metrics to the log line, all within a single query or UI flow.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    New Relic's APM agents automatically instrument your application code with zero configuration changes. The agent patches your HTTP framework, database drivers, and cache clients at startup, injecting tracing headers and recording timing data without requiring manual span creation.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Platform Capabilities</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>APM</strong> — automatic instrumentation for transactions, database queries, external calls; Apdex scoring</li>
    <li><strong>Distributed Tracing</strong> — end-to-end traces across services with W3C Trace Context support</li>
    <li><strong>Infrastructure Monitoring</strong> — host metrics, container metrics, Kubernetes cluster monitoring</li>
    <li><strong>Log Management</strong> — ingest, search, and correlate logs with traces and errors</li>
    <li><strong>Browser Monitoring (RUM)</strong> — real user page load times, Core Web Vitals, JS error tracking</li>
    <li><strong>Synthetic Monitoring</strong> — scripted browser and API tests from global locations</li>
    <li><strong>Mobile Monitoring</strong> — crash reporting and performance for iOS and Android</li>
    <li><strong>Alerts</strong> — NRQL-based alert conditions, anomaly detection, notification routing</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">APM Agent Setup (Node.js)</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={apmExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">NRQL Query Examples</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={nrqlExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Agent Installation (Other Languages)</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Python
pip install newrelic
newrelic-admin generate-config $NEW_RELIC_LICENSE_KEY newrelic.ini
NEW_RELIC_CONFIG_FILE=newrelic.ini newrelic-admin run-program gunicorn app:application

# Java (via -javaagent JVM flag)
wget https://download.newrelic.com/newrelic/java-agent/newrelic-agent/current/newrelic.jar
java -javaagent:newrelic.jar -jar your-app.jar

# Go
go get github.com/newrelic/go-agent/v3/newrelic

# Infrastructure Agent (Linux)
curl -Ls https://download.newrelic.com/install/newrelic-cli/scripts/install.sh | bash
newrelic install</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">New Relic vs Datadog</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 font-semibold">Dimension</th>
          <th class="text-left py-2 pr-4 font-semibold">New Relic</th>
          <th class="text-left py-2 font-semibold">Datadog</th>
        </tr>
      </thead>
      <tbody class="text-text-muted">
        <tr class="border-b border-border/50"><td class="py-2 pr-4">Pricing model</td><td class="py-2 pr-4">Per GB ingested + user seats</td><td class="py-2">Per host per month</td></tr>
        <tr class="border-b border-border/50"><td class="py-2 pr-4">Free tier</td><td class="py-2 pr-4">100GB/month + 1 full user</td><td class="py-2">14-day trial only</td></tr>
        <tr class="border-b border-border/50"><td class="py-2 pr-4">Query language</td><td class="py-2 pr-4">NRQL (SQL-like, unified)</td><td class="py-2">Per-product query languages</td></tr>
        <tr class="border-b border-border/50"><td class="py-2 pr-4">Integrations</td><td class="py-2 pr-4">500+</td><td class="py-2">800+</td></tr>
        <tr><td class="py-2 pr-4">Best for</td><td class="py-2 pr-4">App-centric teams, startups</td><td class="py-2">Infra-heavy, large-scale</td></tr>
      </tbody>
    </table>
  </div>

  <ToolPageCta />
  <FaqSection faqs={faq} />
</BaseLayout>
