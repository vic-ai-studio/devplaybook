---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a percentage?", answer: "A percentage is a fraction expressed as parts per 100 (from Latin 'per centum'). 50% = 50/100 = 0.5. To convert a decimal to percentage: multiply by 100. To convert percentage to decimal: divide by 100. Percentages are used everywhere: discounts (20% off), tax rates (VAT 10%), interest rates (APR 6.5%), test scores (90/100 = 90%), growth rates (revenue grew 15%), and probability (30% chance of rain)." },
  { question: "How do I calculate percentage increase or decrease?", answer: "Percentage change = ((new - old) / |old|) × 100. If a stock goes from $50 to $65: ((65-50)/50) × 100 = 30% increase. If it drops from $65 to $50: ((50-65)/65) × 100 = -23.1% decrease. Note that a 30% increase followed by a 30% decrease does NOT return to the original value — $50 × 1.30 = $65, then $65 × 0.70 = $45.50. This asymmetry is important in finance and compound growth calculations." },
  { question: "What is the difference between percentage points and percentages?", answer: "Percentage points measure the arithmetic difference between two percentages; percentages measure relative change. If the interest rate rises from 2% to 3%, that is a 1 percentage point increase but a 50% relative increase ((3-2)/2 × 100 = 50%). This distinction matters in financial reporting: saying interest rates rose 50% sounds alarming; saying they rose 1 percentage point is accurate. Politicians and journalists often (accidentally or deliberately) confuse the two." },
  { question: "How do I calculate what percentage X is of Y?", answer: "Formula: (X / Y) × 100. Example: 45 is what percent of 180? (45/180) × 100 = 25%. Use case: you scored 45 out of 60 on a test — (45/60) × 100 = 75%. Your team completed 120 of 200 tasks — (120/200) × 100 = 60% completion." },
];
---

<BaseLayout
  title="Percentage Calculator — Find Percentages, Changes, and Values"
  description="Calculate percentages: X% of Y, what % is X of Y, percentage increase/decrease, original value from percentage. Multiple calculation modes."
  tool="percentage calculator, percent of number, percentage increase decrease, what percent is X of Y, find original value percentage"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Percentage Calculator",
    "url": "https://devplaybook.cc/tools/percentage-calculator",
    "description": "Calculate percentages in multiple modes: X% of Y, what % is X of Y, percentage increase/decrease, and original value recovery.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Percentage Calculator</h1>
  <p class="text-text-muted mb-6">
    Calculate <strong>percentages</strong> in four modes: find X% of a value, find what percentage X is of Y,
    calculate percentage change, or recover the original value from a percentage.
  </p>

  <div class="grid md:grid-cols-2 gap-4 mb-6">
    <!-- Mode 1: X% of Y -->
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-sm mb-3">What is X% of Y?</h3>
      <div class="flex items-center gap-2 mb-3 flex-wrap">
        <input type="number" id="m1pct" value="20" class="w-20 bg-bg-100 border border-border rounded px-2 py-1.5 text-sm" />
        <span class="text-text-muted text-sm">% of</span>
        <input type="number" id="m1val" value="500" class="w-24 bg-bg-100 border border-border rounded px-2 py-1.5 text-sm" />
        <span class="text-text-muted text-sm">=</span>
        <span id="m1result" class="text-xl font-bold text-primary">100</span>
      </div>
      <div id="m1formula" class="text-xs text-text-muted font-mono"></div>
    </div>

    <!-- Mode 2: X is what % of Y -->
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-sm mb-3">X is what % of Y?</h3>
      <div class="flex items-center gap-2 mb-3 flex-wrap">
        <input type="number" id="m2x" value="45" class="w-20 bg-bg-100 border border-border rounded px-2 py-1.5 text-sm" />
        <span class="text-text-muted text-sm">is</span>
        <span id="m2result" class="text-xl font-bold text-primary">25</span>
        <span class="text-text-muted text-sm">% of</span>
        <input type="number" id="m2y" value="180" class="w-24 bg-bg-100 border border-border rounded px-2 py-1.5 text-sm" />
      </div>
      <div id="m2formula" class="text-xs text-text-muted font-mono"></div>
    </div>

    <!-- Mode 3: % change -->
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-sm mb-3">Percentage change (old → new)</h3>
      <div class="flex items-center gap-2 mb-3 flex-wrap">
        <input type="number" id="m3old" value="80" class="w-24 bg-bg-100 border border-border rounded px-2 py-1.5 text-sm" />
        <span class="text-text-muted text-sm">→</span>
        <input type="number" id="m3new" value="100" class="w-24 bg-bg-100 border border-border rounded px-2 py-1.5 text-sm" />
        <span class="text-text-muted text-sm">=</span>
        <span id="m3result" class="text-xl font-bold text-primary">+25%</span>
      </div>
      <div id="m3formula" class="text-xs text-text-muted font-mono"></div>
    </div>

    <!-- Mode 4: recover original -->
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-sm mb-3">Original value (after % change)</h3>
      <div class="flex items-center gap-2 mb-3 flex-wrap">
        <span class="text-text-muted text-sm">Final</span>
        <input type="number" id="m4final" value="120" class="w-24 bg-bg-100 border border-border rounded px-2 py-1.5 text-sm" />
        <span class="text-text-muted text-sm">after</span>
        <input type="number" id="m4pct" value="20" class="w-20 bg-bg-100 border border-border rounded px-2 py-1.5 text-sm" />
        <span class="text-text-muted text-sm">% increase → original =</span>
        <span id="m4result" class="text-xl font-bold text-primary">100</span>
      </div>
      <div id="m4formula" class="text-xs text-text-muted font-mono"></div>
    </div>
  </div>

  <ToolPageCta />
  <FaqSection faqs={faq} />
</BaseLayout>

<script>
function fmt(n: number): string {
  return Number.isFinite(n) ? (Math.abs(n) < 0.001 && n !== 0 ? n.toExponential(3) : parseFloat(n.toPrecision(10)).toString()) : 'Error';
}

function update() {
  const m1pct = parseFloat((document.getElementById('m1pct') as HTMLInputElement).value);
  const m1val = parseFloat((document.getElementById('m1val') as HTMLInputElement).value);
  const r1 = (m1pct / 100) * m1val;
  (document.getElementById('m1result') as HTMLElement).textContent = fmt(r1);
  (document.getElementById('m1formula') as HTMLElement).textContent = `${m1pct}/100 × ${m1val} = ${fmt(r1)}`;

  const m2x = parseFloat((document.getElementById('m2x') as HTMLInputElement).value);
  const m2y = parseFloat((document.getElementById('m2y') as HTMLInputElement).value);
  const r2 = (m2x / m2y) * 100;
  (document.getElementById('m2result') as HTMLElement).textContent = fmt(r2);
  (document.getElementById('m2formula') as HTMLElement).textContent = `(${m2x} ÷ ${m2y}) × 100 = ${fmt(r2)}%`;

  const m3old = parseFloat((document.getElementById('m3old') as HTMLInputElement).value);
  const m3new = parseFloat((document.getElementById('m3new') as HTMLInputElement).value);
  const r3 = ((m3new - m3old) / Math.abs(m3old)) * 100;
  const r3str = (r3 >= 0 ? '+' : '') + fmt(r3) + '%';
  (document.getElementById('m3result') as HTMLElement).textContent = r3str;
  (document.getElementById('m3result') as HTMLElement).className = `text-xl font-bold ${r3 >= 0 ? 'text-green-500' : 'text-red-500'}`;
  (document.getElementById('m3formula') as HTMLElement).textContent = `((${m3new} - ${m3old}) ÷ |${m3old}|) × 100 = ${r3str}`;

  const m4final = parseFloat((document.getElementById('m4final') as HTMLInputElement).value);
  const m4pct = parseFloat((document.getElementById('m4pct') as HTMLInputElement).value);
  const r4 = m4final / (1 + m4pct / 100);
  (document.getElementById('m4result') as HTMLElement).textContent = fmt(r4);
  (document.getElementById('m4formula') as HTMLElement).textContent = `${m4final} ÷ (1 + ${m4pct}/100) = ${fmt(r4)}`;
}

['m1pct','m1val','m2x','m2y','m3old','m3new','m4final','m4pct'].forEach(id => {
  document.getElementById(id)?.addEventListener('input', update);
});
update();
</script>
