---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is grpcurl and how does it work?", answer: "grpcurl is a command-line tool for interacting with gRPC servers, similar to curl for HTTP. It uses protobuf reflection or a .proto file to discover service methods and can send requests in JSON format. It's the fastest way to test gRPC endpoints without writing code." },
  { question: "What is the difference between gRPC and gRPC-Web?", answer: "gRPC uses HTTP/2 framing directly and is suited for server-to-server or native client communication. gRPC-Web is a browser-compatible protocol that works over HTTP/1.1 or HTTP/2 via a proxy (like Envoy). Browsers cannot use raw gRPC because they lack low-level HTTP/2 stream control." },
  { question: "How do I include metadata (headers) in a gRPC request?", answer: "In grpcurl, use the -H flag: `-H 'authorization: Bearer TOKEN'`. In Node.js @grpc/grpc-js, pass metadata as the second argument: `const meta = new grpc.Metadata(); meta.add('authorization', 'Bearer TOKEN'); client.Method(request, meta, callback)`." },
  { question: "What does the package and service name look like in a proto definition?", answer: "A typical proto file starts with `package myapp.v1;` and then `service UserService { rpc GetUser (GetUserRequest) returns (GetUserResponse); }`. The fully-qualified method name used by grpcurl is `myapp.v1.UserService/GetUser`." },
  { question: "Can I use gRPC without a .proto file?", answer: "Yes — if the server has reflection enabled (most dev servers do), grpcurl can introspect services at runtime without any proto files using `-proto` flag or reflection. In production, reflection is often disabled for security, so you'd need the .proto file or a generated descriptor set." },
];
---

<BaseLayout
  title="gRPC Request Builder — Generate grpcurl, gRPC-Web & Node.js Code"
  description="Visually build gRPC requests from proto definitions. Generate grpcurl commands, gRPC-Web fetch code, and Node.js @grpc/grpc-js snippets instantly."
  tool="gRPC Request Builder, grpcurl Generator, gRPC-Web Code, Node.js gRPC Snippet, Proto Method Builder"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">gRPC Request Builder</h1>
  <p class="text-text-muted mb-4">Build gRPC requests visually from your proto definition. Get ready-to-run grpcurl commands, gRPC-Web fetch code, and Node.js snippets instantly.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> grpcurl command generator</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> gRPC-Web fetch code</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Node.js @grpc/grpc-js snippet</span>
  </div>

  <!-- Inputs -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Request Configuration</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Server Address</label>
        <input id="grpc-server" type="text" value="localhost:50051"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Method Name (e.g. GetUser)</label>
        <input id="grpc-method" type="text" value="GetUser"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Use TLS</label>
        <select id="grpc-tls" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="plaintext">Plaintext (-plaintext)</option>
          <option value="tls">TLS (default)</option>
          <option value="insecure">Insecure TLS (-insecure)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Metadata Header (optional)</label>
        <input id="grpc-meta" type="text" placeholder="authorization: Bearer TOKEN"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
      </div>
    </div>
    <div class="mb-4">
      <label class="block text-sm font-medium mb-1.5">Proto Service Definition</label>
      <textarea id="grpc-proto" rows="8"
        class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono resize-y"
></textarea>
    </div>
    <div class="mb-4">
      <label class="block text-sm font-medium mb-1.5">Request JSON</label>
      <textarea id="grpc-json" rows="4"
        class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono resize-y"
></textarea>
    </div>
    <button id="grpc-build" class="bg-primary text-white rounded-lg px-5 py-2 text-sm font-semibold hover:opacity-90 transition-opacity">
      Build Request Code
    </button>
  </div>

  <!-- Output Tabs -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <div class="flex gap-1 mb-4 border-b border-border">
      <button class="grpc-tab px-4 py-2 text-sm font-medium rounded-t-lg border-b-2 border-primary text-primary" data-tab="grpcurl">grpcurl</button>
      <button class="grpc-tab px-4 py-2 text-sm font-medium rounded-t-lg border-b-2 border-transparent text-text-muted hover:text-primary" data-tab="grpcweb">gRPC-Web</button>
      <button class="grpc-tab px-4 py-2 text-sm font-medium rounded-t-lg border-b-2 border-transparent text-text-muted hover:text-primary" data-tab="nodejs">Node.js</button>
    </div>
    <div id="grpc-tab-grpcurl" class="grpc-tab-panel">
      <div class="flex justify-between items-center mb-2">
        <span class="text-xs text-text-muted font-mono">bash</span>
        <button class="grpc-copy text-xs text-primary hover:underline" data-target="out-grpcurl">Copy</button>
      </div>
      <pre id="out-grpcurl" class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto whitespace-pre-wrap text-text-muted">Click "Build Request Code" to generate</pre>
    </div>
    <div id="grpc-tab-grpcweb" class="grpc-tab-panel hidden">
      <div class="flex justify-between items-center mb-2">
        <span class="text-xs text-text-muted font-mono">javascript</span>
        <button class="grpc-copy text-xs text-primary hover:underline" data-target="out-grpcweb">Copy</button>
      </div>
      <pre id="out-grpcweb" class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto whitespace-pre-wrap text-text-muted">Click "Build Request Code" to generate</pre>
    </div>
    <div id="grpc-tab-nodejs" class="grpc-tab-panel hidden">
      <div class="flex justify-between items-center mb-2">
        <span class="text-xs text-text-muted font-mono">javascript</span>
        <button class="grpc-copy text-xs text-primary hover:underline" data-target="out-nodejs">Copy</button>
      </div>
      <pre id="out-nodejs" class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto whitespace-pre-wrap text-text-muted">Click "Build Request Code" to generate</pre>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="gRPC Request Builder" relatedTags={['grpc', 'api', 'protobuf', 'nodejs', 'backend']} />
</BaseLayout>

<script>
  // Set default textarea values (avoids Astro parsing {} as expressions)
  (document.getElementById('grpc-proto') as HTMLTextAreaElement).value = `syntax = "proto3";\n\npackage myapp.v1;\n\nservice UserService {\n  rpc GetUser (GetUserRequest) returns (GetUserResponse);\n  rpc ListUsers (ListUsersRequest) returns (ListUsersResponse);\n}\n\nmessage GetUserRequest {\n  string user_id = 1;\n}\n\nmessage GetUserResponse {\n  string user_id = 1;\n  string name = 2;\n  string email = 3;\n}`;
  (document.getElementById('grpc-json') as HTMLTextAreaElement).value = '{ "user_id": "usr_123" }';

  function getV(id: string): string {
    return (document.getElementById(id) as HTMLInputElement).value.trim();
  }

  function extractPackageService(proto: string): { pkg: string; svc: string } {
    const pkgMatch = proto.match(/^\s*package\s+([\w.]+)\s*;/m);
    const svcMatch = proto.match(/^\s*service\s+(\w+)/m);
    return {
      pkg: pkgMatch ? pkgMatch[1] : '',
      svc: svcMatch ? svcMatch[1] : 'MyService',
    };
  }

  function build() {
    const server = getV('grpc-server') || 'localhost:50051';
    const method = getV('grpc-method') || 'MyMethod';
    const tls = getV('grpc-tls');
    const meta = getV('grpc-meta');
    const proto = getV('grpc-proto');
    const json = getV('grpc-json') || '{}';
    const { pkg, svc } = extractPackageService(proto);
    const fqMethod = pkg ? `${pkg}.${svc}/${method}` : `${svc}/${method}`;

    // Validate JSON
    let parsedJson: any = {};
    try { parsedJson = JSON.parse(json); } catch(e) { /* use empty */ }
    const prettyJson = JSON.stringify(parsedJson, null, 2);

    const tlsFlag = tls === 'plaintext' ? ' -plaintext' : tls === 'insecure' ? ' -insecure' : '';
    const metaFlag = meta ? ` \\\n  -H '${meta}'` : '';

    // grpcurl
    const grpcurlCmd = `grpcurl${tlsFlag} \\
  -proto service.proto${metaFlag} \\
  -d '${JSON.stringify(parsedJson)}' \\
  ${server} \\
  ${fqMethod}`;

    // gRPC-Web
    const grpcWebCode = `// npm install @connectrpc/connect @connectrpc/connect-web @bufbuild/protobuf
import { createClient } from "@connectrpc/connect";
import { createConnectTransport } from "@connectrpc/connect-web";
import { ${svc} } from "./gen/${svc.toLowerCase()}_connect";

const transport = createConnectTransport({
  baseUrl: "https://${server.replace('localhost', '127.0.0.1')}",
});

const client = createClient(${svc}, transport);

async function call${method}() {
  const response = await client.${method.charAt(0).toLowerCase() + method.slice(1)}(
    ${prettyJson.split('\n').map((l, i) => i === 0 ? l : '    ' + l).join('\n')}
  );
  console.log(response);
}

call${method}();`;

    // Node.js
    const creds = tls === 'plaintext'
      ? 'grpc.credentials.createInsecure()'
      : tls === 'insecure'
      ? 'grpc.credentials.createSsl(null, null, null, { checkServerIdentity: () => undefined })'
      : 'grpc.credentials.createSsl()';

    const metaSnippet = meta
      ? `\nconst metadata = new grpc.Metadata();\nmetadata.add('${meta.split(':')[0].trim()}', '${(meta.split(':')[1] || '').trim()}');\n`
      : '';
    const metaArg = meta ? ', metadata' : '';

    const nodeCode = `// npm install @grpc/grpc-js @grpc/proto-loader
const grpc = require('@grpc/grpc-js');
const protoLoader = require('@grpc/proto-loader');
const path = require('path');

const packageDef = protoLoader.loadSync(
  path.join(__dirname, 'service.proto'),
  { keepCase: true, longs: String, enums: String, defaults: true, oneofs: true }
);
const proto = grpc.loadPackageDefinition(packageDef)${pkg ? '.' + pkg.split('.').join('.') : ''};

const client = new proto.${svc}(
  '${server}',
  ${creds}
);
${metaSnippet}
const request = ${prettyJson};

client.${method.charAt(0).toLowerCase() + method.slice(1)}(request${metaArg}, (err, response) => {
  if (err) {
    console.error('gRPC Error:', err.message);
    return;
  }
  console.log('Response:', JSON.stringify(response, null, 2));
});`;

    (document.getElementById('out-grpcurl') as HTMLElement).textContent = grpcurlCmd;
    (document.getElementById('out-grpcweb') as HTMLElement).textContent = grpcWebCode;
    (document.getElementById('out-nodejs') as HTMLElement).textContent = nodeCode;
  }

  // Tab switching
  document.querySelectorAll('.grpc-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = (btn as HTMLElement).dataset.tab!;
      document.querySelectorAll('.grpc-tab').forEach(b => {
        b.classList.remove('border-primary', 'text-primary');
        b.classList.add('border-transparent', 'text-text-muted');
      });
      btn.classList.add('border-primary', 'text-primary');
      btn.classList.remove('border-transparent', 'text-text-muted');
      document.querySelectorAll('.grpc-tab-panel').forEach(p => p.classList.add('hidden'));
      document.getElementById('grpc-tab-' + tab)!.classList.remove('hidden');
    });
  });

  // Copy buttons
  document.querySelectorAll('.grpc-copy').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = (btn as HTMLElement).dataset.target!;
      const text = (document.getElementById(target) as HTMLElement).textContent || '';
      navigator.clipboard.writeText(text).then(() => {
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
      });
    });
  });

  document.getElementById('grpc-build')!.addEventListener('click', build);

  // Auto-build on load
  build();
</script>
