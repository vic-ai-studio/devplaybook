---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How are tokens counted?", answer: "This tool uses the standard approximation of 1 token ≈ 4 characters for English text. Code is denser — Python/JS typically runs 3–4 chars/token. For exact counts, use tiktoken (OpenAI) or the Anthropic tokenizer API. Tokenization varies slightly between providers, so use these as estimates." },
  { question: "Why do different models cost differently per token?", answer: "Pricing reflects model capability, size, and infrastructure cost. Flagship models like GPT-4o and Claude Opus are larger and more capable but cost 10–100× more than fast/mini tiers. Choose smaller models for simple tasks (extraction, classification) and flagship models for complex reasoning, code, or long-context work." },
  { question: "What is the difference between input and output cost?", answer: "Input tokens are the text you send (prompt, system message, conversation history). Output tokens are the response generated by the model. Output typically costs 3–5× more than input. For long streaming responses or documents, output cost dominates. Optimizing your prompts to reduce output length saves significant cost at scale." },
  { question: "How do I reduce token usage?", answer: "1) Trim system prompts to essentials. 2) Use shorter examples in few-shot prompts. 3) Don't include full conversation history — summarize old context. 4) Set max_tokens to cap output. 5) Use structured output (JSON) instead of verbose prose. 6) Use prompt caching (Anthropic/OpenAI) for repeated large prompts — saves up to 90% on cached tokens." },
  { question: "What is prompt caching and does it affect token count?", answer: "Prompt caching stores your large prompts server-side and reuses them at a discount (Anthropic: 90% off cached input, OpenAI: 50% off). The token count is the same — you're just billed less for re-used content. This is ideal for large system prompts, documents, or RAG contexts repeated across many calls." },
];
---

<BaseLayout
  title="AI Prompt Token Estimator — GPT-4, Claude, Gemini Token Counter & Cost"
  description="Estimate token count and API cost for your prompts across GPT-4o, Claude 3.5, and Gemini 1.5. Paste any text to see real-time token estimates and cost per model."
  tool="AI prompt token estimator, token counter, GPT-4 token cost, Claude token cost, Gemini token cost, prompt token calculator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">AI Prompt Token Estimator</h1>
  <p class="text-text-muted mb-4">Paste your prompt below to instantly estimate token count and API cost across major AI models.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GPT-4o, Claude, Gemini pricing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Real-time estimation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Input + output cost</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 1000-call projection</span>
  </div>

  <div class="space-y-5">
    <!-- Input -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="font-semibold mb-3">Your Prompt</h2>
      <textarea id="prompt-input" rows="8"
        placeholder="Paste your prompt, system message, or any text here..."
        class="w-full bg-bg border border-border rounded-lg px-3 py-2.5 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40 resize-y"></textarea>

      <div class="flex flex-col sm:flex-row gap-4 mt-4">
        <div class="flex-1">
          <label class="block text-sm font-medium text-text-muted mb-1" for="expected-output">Expected Output Tokens</label>
          <input id="expected-output" type="number" min="1" step="10" value="500"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          <div class="text-xs text-text-muted mt-1">Estimated response length</div>
        </div>
        <div class="flex-1">
          <label class="block text-sm font-medium text-text-muted mb-1" for="daily-calls">Daily API Calls</label>
          <input id="daily-calls" type="number" min="1" step="100" value="1000"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          <div class="text-xs text-text-muted mt-1">For monthly cost projection</div>
        </div>
      </div>

      <!-- Token stats -->
      <div class="mt-4 grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="bg-bg border border-border rounded-lg p-3 text-center">
          <div class="text-2xl font-bold text-primary" id="char-count">0</div>
          <div class="text-xs text-text-muted mt-1">Characters</div>
        </div>
        <div class="bg-bg border border-border rounded-lg p-3 text-center">
          <div class="text-2xl font-bold text-primary" id="token-count">0</div>
          <div class="text-xs text-text-muted mt-1">Input Tokens</div>
        </div>
        <div class="bg-bg border border-border rounded-lg p-3 text-center">
          <div class="text-2xl font-bold text-primary" id="word-count">0</div>
          <div class="text-xs text-text-muted mt-1">Words</div>
        </div>
        <div class="bg-bg border border-border rounded-lg p-3 text-center">
          <div class="text-2xl font-bold text-primary" id="line-count">0</div>
          <div class="text-xs text-text-muted mt-1">Lines</div>
        </div>
      </div>
    </div>

    <!-- Cost table -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-semibold">Cost by Model</h2>
        <div class="text-xs text-text-muted">Per call + monthly @ <span id="daily-label">1,000</span> calls/day</div>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-text-muted text-xs uppercase tracking-wide border-b border-border">
              <th class="text-left py-2 pr-4">Model</th>
              <th class="text-right py-2 pr-4">Input $/1M</th>
              <th class="text-right py-2 pr-4">Output $/1M</th>
              <th class="text-right py-2 pr-4">Per Call</th>
              <th class="text-right py-2">Monthly</th>
            </tr>
          </thead>
          <tbody id="model-table" class="divide-y divide-border"></tbody>
        </table>
      </div>
      <div class="mt-3 text-xs text-text-muted">Prices are approximate list prices as of 2025. Check provider pricing pages for current rates.</div>
    </div>

    <!-- Bar chart -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="font-semibold mb-4">Monthly Cost Comparison</h2>
      <div id="bar-chart" class="space-y-2"></div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="AI Prompt Token Estimator" relatedTags={['ai', 'llm', 'tokens', 'cost', 'openai', 'claude', 'gemini']} />
</BaseLayout>

<script is:inline>
(function () {
  var MODELS = [
    { name: 'GPT-4o',            provider: 'OpenAI',    input: 2.50,   output: 10.00,  color: '#34d399' },
    { name: 'GPT-4o Mini',       provider: 'OpenAI',    input: 0.15,   output: 0.60,   color: '#10b981' },
    { name: 'o1',                provider: 'OpenAI',    input: 15.00,  output: 60.00,  color: '#6ee7b7' },
    { name: 'Claude Opus 4',     provider: 'Anthropic', input: 15.00,  output: 75.00,  color: '#a78bfa' },
    { name: 'Claude Sonnet 4.6', provider: 'Anthropic', input: 3.00,   output: 15.00,  color: '#8b5cf6' },
    { name: 'Claude Haiku 4.5',  provider: 'Anthropic', input: 0.80,   output: 4.00,   color: '#7c3aed' },
    { name: 'Gemini 1.5 Pro',    provider: 'Google',    input: 1.25,   output: 5.00,   color: '#60a5fa' },
    { name: 'Gemini 1.5 Flash',  provider: 'Google',    input: 0.075,  output: 0.30,   color: '#3b82f6' },
    { name: 'Gemini 2.0 Flash',  provider: 'Google',    input: 0.10,   output: 0.40,   color: '#2563eb' },
    { name: 'Llama 3.3 70B',     provider: 'Groq',      input: 0.59,   output: 0.79,   color: '#fb923c' },
    { name: 'DeepSeek V3',       provider: 'DeepSeek',  input: 0.27,   output: 1.10,   color: '#f43f5e' },
    { name: 'Mistral Large',     provider: 'Mistral',   input: 2.00,   output: 6.00,   color: '#fbbf24' },
  ];

  var promptInput = document.getElementById('prompt-input');
  var outputInput = document.getElementById('expected-output');
  var callsInput = document.getElementById('daily-calls');
  var charCount = document.getElementById('char-count');
  var tokenCount = document.getElementById('token-count');
  var wordCount = document.getElementById('word-count');
  var lineCount = document.getElementById('line-count');
  var modelTable = document.getElementById('model-table');
  var barChart = document.getElementById('bar-chart');
  var dailyLabel = document.getElementById('daily-label');

  function estimateTokens(text) {
    if (!text) return 0;
    return Math.ceil(text.length / 4);
  }

  function fmt(n) {
    if (n < 0.001) return '$' + n.toFixed(6);
    if (n < 1) return '$' + n.toFixed(4);
    if (n < 100) return '$' + n.toFixed(2);
    return '$' + Math.round(n).toLocaleString();
  }

  function update() {
    var text = promptInput.value;
    var chars = text.length;
    var inputTok = estimateTokens(text);
    var outputTok = parseInt(outputInput.value) || 500;
    var dailyCalls = parseInt(callsInput.value) || 1000;

    charCount.textContent = chars.toLocaleString();
    tokenCount.textContent = inputTok.toLocaleString();
    wordCount.textContent = text.trim() ? text.trim().split(/\s+/).length.toLocaleString() : '0';
    lineCount.textContent = text ? text.split('\n').length.toLocaleString() : '0';
    dailyLabel.textContent = dailyCalls.toLocaleString();

    var rows = MODELS.map(function (m) {
      var perCallInput = (inputTok / 1e6) * m.input;
      var perCallOutput = (outputTok / 1e6) * m.output;
      var perCall = perCallInput + perCallOutput;
      var monthly = perCall * dailyCalls * 30;
      return { m: m, perCall: perCall, monthly: monthly };
    }).sort(function (a, b) { return a.monthly - b.monthly; });

    var maxMonthly = rows[rows.length - 1].monthly || 1;

    modelTable.innerHTML = rows.map(function (r) {
      return '<tr class="hover:bg-bg/50">' +
        '<td class="py-2 pr-4"><span class="font-medium">' + r.m.name + '</span><span class="ml-2 text-xs text-text-muted">' + r.m.provider + '</span></td>' +
        '<td class="text-right py-2 pr-4 font-mono text-xs">$' + r.m.input.toFixed(3) + '</td>' +
        '<td class="text-right py-2 pr-4 font-mono text-xs">$' + r.m.output.toFixed(3) + '</td>' +
        '<td class="text-right py-2 pr-4 font-mono text-xs">' + fmt(r.perCall) + '</td>' +
        '<td class="text-right py-2 font-mono text-sm font-semibold">' + fmt(r.monthly) + '</td>' +
        '</tr>';
    }).join('');

    barChart.innerHTML = rows.map(function (r) {
      var pct = maxMonthly > 0 ? Math.max(2, (r.monthly / maxMonthly) * 100) : 2;
      return '<div class="flex items-center gap-3">' +
        '<div class="w-40 text-xs text-right text-text-muted truncate">' + r.m.name + '</div>' +
        '<div class="flex-1 bg-bg rounded-full h-5 overflow-hidden">' +
        '<div class="h-5 rounded-full flex items-center justify-end pr-2 transition-all" style="width:' + pct + '%;background:' + r.m.color + '">' +
        '<span class="text-xs font-mono text-white/90 font-semibold" style="font-size:10px">' + fmt(r.monthly) + '</span>' +
        '</div></div></div>';
    }).join('');
  }

  promptInput.addEventListener('input', update);
  outputInput.addEventListener('input', update);
  callsInput.addEventListener('input', update);

  // Initial sample
  promptInput.value = 'You are a helpful assistant. Answer the following question concisely.\n\nUser: Explain the difference between REST and GraphQL APIs.';
  update();
})();
</script>
