---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WcagContrastChecker from '../../components/WcagContrastChecker.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is WCAG contrast ratio?", answer: "WCAG (Web Content Accessibility Guidelines) defines minimum contrast ratios to ensure text is readable for people with low vision or color blindness. The contrast ratio is calculated from the relative luminance of the foreground and background colors, ranging from 1:1 (identical) to 21:1 (black on white). The formula is (L1 + 0.05) / (L2 + 0.05) where L1 is the lighter luminance." },
  { question: "What is the difference between WCAG AA and AAA?", answer: "WCAG 2.1 defines two levels: AA is the legal standard required by most accessibility laws (ADA, EN 301 549, AODA). It requires 4.5:1 for normal text and 3:1 for large text. AAA is the enhanced level — 7:1 for normal text and 4.5:1 for large text. AAA is aspirational; most organizations target AA as the minimum baseline." },
  { question: "What counts as 'large text' for WCAG?", answer: "Large text is defined as 18pt (24px) or larger for regular weight, or 14pt (approximately 18.67px) or larger for bold text. Large text has a lower contrast requirement (3:1 for AA, 4.5:1 for AAA) because it's inherently easier to read at lower contrast than small text." },
  { question: "Do decorative images need to meet contrast requirements?", answer: "No. WCAG contrast requirements apply to text and images of text. Decorative elements, logos, and disabled UI components are exempt. However, UI components like buttons, inputs, and focus indicators do need to meet 3:1 contrast against adjacent colors under WCAG 2.1 Success Criterion 1.4.11 (Non-text Contrast)." },
  { question: "How do I fix a failing contrast ratio?", answer: "To increase contrast: darken the text color, lighten the background (or vice versa), or increase the font size to qualify as 'large text'. Tools like oklch color space allow you to adjust lightness while preserving hue. A good rule: if you're targeting AA compliance, aim for at least 5:1 to have a safety buffer when rendering varies." },
];
---

<BaseLayout
  title="WCAG Contrast Checker — AA/AAA Accessibility Compliance — Free Online Tool"
  description="Check foreground and background color contrast ratios against WCAG 2.1 AA and AAA standards. Input hex or RGB colors, see pass/fail for normal and large text, with live preview. Runs 100% in your browser."
  tool="WCAG contrast checker, color contrast ratio, accessibility contrast, AA AAA compliance, WCAG 2.1, color accessibility tool"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">WCAG Contrast Checker</h1>
  <p class="text-text-muted mb-4">
    Calculate the contrast ratio between any two colors and check WCAG 2.1 AA/AAA compliance.
    See instant pass/fail for normal text (4.5:1) and large text (3.0:1) with a live preview.
    Runs entirely in your browser — no data sent anywhere.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> WCAG 2.1 AA & AAA</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Hex color picker</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live text preview</span>
  </div>
  <WcagContrastChecker client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="WCAG Contrast Checker" relatedTags={['accessibility', 'wcag', 'colors', 'design', 'css']} />
</BaseLayout>
