---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CsvToJson from '../../components/CsvToJson.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What output format does the CSV to JSON converter produce?", answer: "When 'First row is header' is enabled, each CSV row becomes a JSON object with keys from the header row. When disabled, each row becomes a JSON array. The result is always a JSON array of records." },
  { question: "Does it handle quoted fields with commas inside?", answer: "Yes. Fields wrapped in double quotes are correctly parsed, including those containing the delimiter character or newlines. Escaped quotes (\"\") within quoted fields are also handled." },
  { question: "Can I download the JSON output?", answer: "Yes. Click the 'Download .json' button to download the converted data as a JSON file directly from your browser." },
  { question: "What delimiters are supported?", answer: "The converter supports comma (,), tab (TSV files from Excel/Google Sheets), semicolon (;), and pipe (|) as delimiters." },
];
---

<BaseLayout
  title="CSV to JSON Converter — Free Online Tool"
  description="Convert CSV data to JSON online. Supports comma, tab, semicolon, and pipe delimiters. Outputs array of objects (with headers) or array of arrays. Download as .json. Free, client-side."
  tool="CSV to JSON, CSV JSON converter, convert CSV to JSON online, TSV to JSON, CSV to JSON array"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">CSV to JSON Converter</h1>
  <p class="text-text-muted mb-4">Paste CSV data to convert it to JSON instantly. Supports multiple delimiters, optional header rows, and configurable indentation. Download the output as a .json file. All processing runs in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Download as .json</span>
  </div>
  <CsvToJson client:only="preact" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more free developer tools?</p>
    <a href="/tools" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Browse All Free Tools →</a>
  </div>
  <ToolPageCta currentTool="CSV to JSON Converter" relatedTags={['csv', 'json', 'converter', 'data']} />
</BaseLayout>
