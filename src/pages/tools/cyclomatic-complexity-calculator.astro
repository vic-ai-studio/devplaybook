---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is cyclomatic complexity?", answer: "Cyclomatic complexity (CC) measures the number of linearly independent paths through a function's source code. It equals 1 plus the number of decision points: each if, else if, for, while, do, case, catch, &&, ||, and ternary (?) adds 1. A CC of 1–5 is simple; 6–10 is moderate; 11–20 is high and should be refactored; 21+ is unmaintainable." },
  { question: "What risk level is acceptable?", answer: "McCabe's original guideline: CC ≤ 10 per function is the widely-accepted safe threshold. Many teams use 15 as a practical ceiling. Functions above 20 are considered too risky to modify safely without comprehensive test coverage. The key insight: CC also equals the minimum number of test cases needed to cover all branches." },
  { question: "What decision points does this tool count?", answer: "This tool counts: if / else if, for / for-of / for-in, while / do-while, switch case / default, catch blocks, logical && and ||, ternary ? operator, and optional chaining ?. (optional chaining). Each adds one independent path through the code." },
  { question: "How do I reduce cyclomatic complexity?", answer: "Extract complex conditions into named boolean variables. Use early returns (guard clauses) to flatten nested ifs. Split long functions into smaller single-responsibility helpers. Replace if/else chains with lookup tables or strategy patterns. Use Array methods (filter, map, reduce) instead of manual loops with conditions." },
  { question: "Is cyclomatic complexity the same as cognitive complexity?", answer: "No. Cyclomatic complexity counts structural paths (good for test coverage planning). Cognitive complexity (SonarSource) counts how hard code is to understand — it adds extra weight for nesting depth. A simple flat switch with 10 cases is CC=10 but low cognitive complexity. A deeply nested if-else tree may be CC=5 but high cognitive complexity. Both metrics are useful." },
];
---

<BaseLayout
  title="Cyclomatic Complexity Calculator — Per-Function Risk Scorer"
  description="Paste a function to calculate its cyclomatic complexity score. See decision points highlighted, risk level (Low/Medium/High/Critical), and the minimum test cases required. Runs in your browser."
  tool="Cyclomatic Complexity Calculator, McCabe complexity, code complexity score, decision point counter, branch coverage, risk level, code quality"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Cyclomatic Complexity Calculator",
    "url": "https://devplaybook.cc/tools/cyclomatic-complexity-calculator",
    "description": "Calculate cyclomatic complexity per function with decision point highlighting, risk levels, and minimum test case count. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Cyclomatic Complexity Calculator</h1>
  <p class="text-text-muted mb-4">Paste a function (JavaScript, TypeScript, Python, Java, or Go) to instantly calculate its <strong>cyclomatic complexity score</strong>, identify every decision point, and get the minimum number of test cases required for full branch coverage.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Per-function CC score + risk level</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Decision point list</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Min test cases required</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No code leaves your browser</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-6">
    <!-- Input -->
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <div class="flex items-center justify-between mb-3">
        <label class="text-sm font-semibold">Paste Function Code</label>
        <button id="btn-example" class="text-xs text-primary hover:underline">Load Example</button>
      </div>
      <textarea id="code-input" class="w-full bg-bg-page border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary resize-y" rows="18" placeholder="function processOrder(order) {&#10;  if (!order) return null;&#10;  // paste your function here...&#10;}"></textarea>
      <button id="btn-analyze" class="mt-3 w-full px-4 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Analyze Complexity</button>
    </div>

    <!-- Results -->
    <div id="results-panel" class="space-y-4">
      <!-- Score card -->
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <h2 class="text-sm font-semibold mb-3">Complexity Score</h2>
        <div class="flex items-end gap-4">
          <div id="score-display" class="text-6xl font-bold text-text-muted">—</div>
          <div class="pb-2">
            <div id="risk-badge" class="inline-flex px-3 py-1 rounded-full text-sm font-semibold bg-bg-page text-text-muted">No code yet</div>
            <div id="min-tests" class="text-xs text-text-muted mt-1"></div>
          </div>
        </div>
        <div class="mt-3 w-full bg-bg-page border border-border rounded-full h-2.5 overflow-hidden">
          <div id="score-bar" class="h-2.5 rounded-full transition-all duration-500 bg-text-muted" style="width:0%"></div>
        </div>
      </div>

      <!-- Decision points -->
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <h2 class="text-sm font-semibold mb-3">Decision Points Found</h2>
        <div id="decision-list" class="space-y-1 text-sm text-text-muted">
          <p class="text-xs italic">Run analysis to see decision points.</p>
        </div>
      </div>

      <!-- Refactoring tip -->
      <div id="refactor-tip" class="hidden bg-yellow-500/10 border border-yellow-500/30 rounded-lg p-4">
        <h3 class="text-sm font-semibold text-yellow-400 mb-1">Refactoring Suggestion</h3>
        <p id="refactor-msg" class="text-sm text-text-muted"></p>
      </div>

      <!-- Risk scale reference -->
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <h2 class="text-sm font-semibold mb-3">Risk Scale</h2>
        <div class="space-y-2">
          <div class="flex items-center gap-3">
            <span class="w-3 h-3 rounded-full bg-green-500 flex-shrink-0"></span>
            <span class="text-xs font-mono w-8">1–5</span>
            <span class="text-xs text-text-muted">Low — simple, easy to test</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="w-3 h-3 rounded-full bg-blue-400 flex-shrink-0"></span>
            <span class="text-xs font-mono w-8">6–10</span>
            <span class="text-xs text-text-muted">Moderate — acceptable, write tests</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="w-3 h-3 rounded-full bg-yellow-400 flex-shrink-0"></span>
            <span class="text-xs font-mono w-8">11–20</span>
            <span class="text-xs text-text-muted">High — refactor recommended</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="w-3 h-3 rounded-full bg-red-500 flex-shrink-0"></span>
            <span class="text-xs font-mono w-8">21+</span>
            <span class="text-xs text-text-muted">Critical — too risky, must refactor</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <ToolPageCta currentTool="Cyclomatic Complexity Calculator" relatedTags={['code-quality', 'testing', 'refactoring', 'javascript', 'typescript']} />
  <FaqSection faq={faq} />
</BaseLayout>

<script>
const EXAMPLE = `function processPayment(order, user, config) {
  if (!order || !user) {
    return { error: 'Missing required fields' };
  }

  if (order.total <= 0) {
    return { error: 'Invalid order total' };
  }

  let discount = 0;
  if (user.isPremium && order.total > 100) {
    discount = 0.15;
  } else if (user.hasCoupon && config.allowCoupons) {
    discount = 0.10;
  } else if (order.isFirstOrder) {
    discount = 0.05;
  }

  const finalTotal = order.total * (1 - discount);

  for (const item of order.items) {
    if (item.stock <= 0) {
      if (config.allowBackorder) {
        item.status = 'backordered';
      } else {
        return { error: \`Item \${item.id} out of stock\` };
      }
    }
  }

  const method = order.paymentMethod;
  if (method === 'card') {
    return processCard(finalTotal, user);
  } else if (method === 'paypal') {
    return processPaypal(finalTotal, user);
  } else if (method === 'crypto') {
    return processCrypto(finalTotal, user);
  } else {
    return { error: 'Unknown payment method' };
  }
}`;

// Decision point patterns with labels
const PATTERNS = [
  { regex: /\bif\s*\(/g, label: 'if' },
  { regex: /\belse\s+if\s*\(/g, label: 'else if' },
  { regex: /\bfor\s*\(/g, label: 'for' },
  { regex: /\bfor\s+\w+\s+(?:in|of)\b/g, label: 'for-in/of' },
  { regex: /\bwhile\s*\(/g, label: 'while' },
  { regex: /\bdo\s*\{/g, label: 'do-while' },
  { regex: /\bcase\s+[^:]+:/g, label: 'case' },
  { regex: /\bcatch\s*\(/g, label: 'catch' },
  { regex: /&&/g, label: '&&' },
  { regex: /\|\|/g, label: '||' },
  { regex: /\?\./g, label: '?.' },
  { regex: /(?<!\?)\?(?!\?|\.)/g, label: 'ternary ?' },
  // Python/Go patterns
  { regex: /\belif\b/g, label: 'elif' },
];

function getRisk(cc) {
  if (cc <= 5) return { label: 'Low', color: 'bg-green-500/20 text-green-400', bar: 'bg-green-500', barPct: Math.min(cc / 5 * 20, 20) };
  if (cc <= 10) return { label: 'Moderate', color: 'bg-blue-400/20 text-blue-400', bar: 'bg-blue-400', barPct: 20 + (cc - 5) / 5 * 30 };
  if (cc <= 20) return { label: 'High', color: 'bg-yellow-400/20 text-yellow-400', bar: 'bg-yellow-400', barPct: 50 + (cc - 10) / 10 * 30 };
  return { label: 'Critical', color: 'bg-red-500/20 text-red-400', bar: 'bg-red-500', barPct: Math.min(80 + (cc - 20) / 10 * 20, 100) };
}

const REFACTOR_TIPS = {
  Low: null,
  Moderate: 'Consider adding unit tests for each decision branch. CC equals the minimum number of test cases needed for branch coverage.',
  High: 'This function is complex. Extract helper functions, use early returns (guard clauses), and replace nested ifs with named boolean variables.',
  Critical: 'This function is too complex to safely maintain. Break it into 3–5 smaller functions, each with a single responsibility. Use a strategy pattern or lookup table to replace branching chains.',
};

function analyze() {
  const code = (document.getElementById('code-input') as HTMLTextAreaElement).value.trim();
  if (!code) return;

  const found: { label: string; count: number }[] = [];
  let total = 1; // base CC = 1

  for (const p of PATTERNS) {
    const matches = code.match(p.regex);
    if (matches && matches.length > 0) {
      found.push({ label: p.label, count: matches.length });
      total += matches.length;
    }
  }

  const risk = getRisk(total);

  // Update score
  const scoreEl = document.getElementById('score-display')!;
  scoreEl.textContent = String(total);
  scoreEl.className = `text-6xl font-bold transition-colors ${total <= 5 ? 'text-green-400' : total <= 10 ? 'text-blue-400' : total <= 20 ? 'text-yellow-400' : 'text-red-400'}`;

  const badge = document.getElementById('risk-badge')!;
  badge.textContent = risk.label;
  badge.className = `inline-flex px-3 py-1 rounded-full text-sm font-semibold ${risk.color}`;

  document.getElementById('min-tests')!.textContent = `Min ${total} test case${total !== 1 ? 's' : ''} for full branch coverage`;

  const bar = document.getElementById('score-bar')!;
  bar.className = `h-2.5 rounded-full transition-all duration-500 ${risk.bar}`;
  bar.style.width = `${risk.barPct}%`;

  // Decision list
  const list = document.getElementById('decision-list')!;
  if (found.length === 0) {
    list.innerHTML = '<p class="text-xs">No decision points found. CC = 1 (simple linear function).</p>';
  } else {
    list.innerHTML = found.map(f =>
      `<div class="flex items-center justify-between py-1 border-b border-border last:border-0">
        <code class="text-xs font-mono text-foreground">${f.label}</code>
        <span class="text-xs font-semibold">${f.count}×</span>
      </div>`
    ).join('');
  }

  // Refactor tip
  const tip = REFACTOR_TIPS[risk.label as keyof typeof REFACTOR_TIPS];
  const tipEl = document.getElementById('refactor-tip')!;
  if (tip) {
    document.getElementById('refactor-msg')!.textContent = tip;
    tipEl.classList.remove('hidden');
  } else {
    tipEl.classList.add('hidden');
  }
}

document.getElementById('btn-analyze')?.addEventListener('click', analyze);
document.getElementById('btn-example')?.addEventListener('click', () => {
  (document.getElementById('code-input') as HTMLTextAreaElement).value = EXAMPLE;
  analyze();
});

// Auto-analyze on Ctrl+Enter
document.getElementById('code-input')?.addEventListener('keydown', (e) => {
  if ((e as KeyboardEvent).ctrlKey && (e as KeyboardEvent).key === 'Enter') analyze();
});
</script>
