---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PrismaSchemaVisualizer from '../../components/PrismaSchemaVisualizer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is Prisma Schema?",
    answer: "Prisma Schema is a declarative data modeling language used by Prisma ORM. You define models (database tables), their fields (columns), relations (foreign keys), and constraints in a schema.prisma file. Prisma generates a type-safe database client from this schema, handles migrations, and provides an introspection tool to generate the schema from an existing database."
  },
  {
    question: "How do I define relations in Prisma?",
    answer: "One-to-many: add a list field (posts Post[]) on the parent model and a scalar foreign key plus @relation on the child. One-to-one: same but without [] and with @unique on the foreign key. Many-to-many: add list fields on both models — Prisma creates the junction table automatically. For explicit many-to-many with extra fields, create a join model manually."
  },
  {
    question: "What does @id @default(autoincrement()) mean?",
    answer: "@id marks the field as the primary key. @default(autoincrement()) makes the database auto-assign incrementing integers. Alternatives: @default(cuid()) for short unique strings, @default(uuid()) for standard UUIDs, @default(nanoid()) for URL-safe IDs, or @default(dbgenerated()) to use database-specific functions."
  },
  {
    question: "What is the difference between String and String?",
    answer: "In Prisma, String maps to VARCHAR/TEXT. String? (with ?) makes the field optional (nullable) — the column allows NULL. String (without ?) makes it required — NOT NULL. String[] is only available for databases that support arrays (PostgreSQL). Always use ? for fields you know can be empty, like optional bio, phone, or address fields."
  },
  {
    question: "How do I run migrations?",
    answer: "Run npx prisma migrate dev --name add_user_model during development — this creates a migration SQL file and applies it to your dev database. Run npx prisma migrate deploy in production/CI — this applies pending migrations without creating new ones. Run npx prisma db push for rapid prototyping without migration history (useful in early development)."
  },
  {
    question: "How do I generate the Prisma client?",
    answer: "Run npx prisma generate after any schema change. The Prisma client is auto-generated TypeScript code tailored to your schema — it provides prisma.user.findMany(), prisma.post.create(), etc. with full type safety. Add this to your postinstall script in package.json so the client is regenerated when teammates pull new changes."
  },
];
---

<BaseLayout
  title="Prisma Schema Visualizer — ER Diagram from Prisma Schema"
  description="Paste your Prisma schema to instantly visualize it as an ER diagram. See models, fields, types, and relations displayed as draggable cards. Color-coded field types. Free, runs in your browser."
  tool="Prisma Schema Visualizer, Prisma ER Diagram, Prisma schema viewer, database diagram, Prisma ORM visualization"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Prisma Schema Visualizer",
    "url": "https://devplaybook.cc/tools/prisma-schema-visualizer",
    "description": "Visualize your Prisma schema as an interactive ER diagram. Paste schema.prisma to see models, fields, types, and relations. Drag-and-drop cards, color-coded field types.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Prisma Schema Visualizer</h1>
  <p class="text-text-muted mb-4">
    Paste your <code class="text-accent font-mono">schema.prisma</code> to instantly visualize it as an
    interactive ER diagram. Models appear as draggable cards with color-coded field types and
    relation arrows. Great for reviewing schema design and sharing with your team.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Parses Prisma schema syntax</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Draggable model cards</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Color-coded field types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Relation arrows (1:N, 1:1)</span>
  </div>
  <PrismaSchemaVisualizer client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Prisma Schema Visualizer" relatedTags={['database', 'prisma', 'typescript', 'nodejs', 'sql', 'orm']} />
</BaseLayout>
