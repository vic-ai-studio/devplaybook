---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How much can WebP reduce image file size compared to JPEG?", answer: "WebP reduces file sizes by 25–35% compared to JPEG at equivalent visual quality, and 25–80% compared to PNG for photos. For lossless compression, WebP is about 26% smaller than PNG. These numbers vary by image content — photos with smooth gradients benefit most from lossy WebP, while images with sharp edges or text may see smaller gains." },
  { question: "What is AVIF and how does it compare to WebP?", answer: "AVIF (AV1 Image File Format) is the newest image format, offering 50% smaller file sizes than JPEG at equivalent quality, and 20% smaller than WebP for most images. AVIF is particularly excellent for high-quality photos. Browser support: Chrome 85+, Firefox 93+, Safari 16+. It's now safe to use with a WebP/JPEG fallback using the <picture> element." },
  { question: "How do I implement WebP and AVIF with fallbacks in HTML?", answer: "Use the <picture> element: <picture><source srcset='image.avif' type='image/avif'><source srcset='image.webp' type='image/webp'><img src='image.jpg' alt='...'></picture>. The browser uses the first format it supports. Next.js and Astro handle this automatically with their Image components. Cloudinary and Imgix can convert formats on-the-fly via URL parameters." },
  { question: "What compression ratios should I expect from each format?", answer: "Typical compression ratios vs JPEG (at equivalent quality): WebP lossy: 25–35% smaller. WebP lossless: 25% smaller vs PNG. AVIF lossy: 45–55% smaller. AVIF lossless: 30–45% smaller vs PNG. PNG vs JPEG: PNG is usually larger for photos (lossless), but smaller for graphics/screenshots with few colors. These estimates use quality settings of ~80 for JPEG, ~75 for WebP, ~60 for AVIF." },
  { question: "Should I convert all my JPEG images to WebP/AVIF?", answer: "Yes, for web delivery. Keep original JPEGs/PNGs as source files (editing AVIF is lossy on each save). Serve WebP with AVIF for browsers that support it. Use <picture> element or your CDN's automatic format conversion (Cloudflare Images, Cloudinary, Imgix all do this automatically). For a Next.js app, next/image handles format conversion automatically." },
  { question: "What are optimal dimensions for web images?", answer: "Don't serve larger images than needed. A 300px wide thumbnail should not be a 4000px source image. Use responsive images: srcset='img-400.webp 400w, img-800.webp 800w, img-1200.webp 1200w' sizes='(max-width: 600px) 400px, 800px'. Rule of thumb: serve images at 2× the CSS pixel size for retina displays (a 400px display slot needs an 800px image). Always specify intrinsic width/height to prevent CLS." },
];
---

<BaseLayout
  title="Image Compression Estimator — Calculate WebP & AVIF Savings"
  description="Estimate how much file size you can save by converting images to WebP or AVIF. Enter original file size and format, get projected savings with bandwidth and LCP improvement estimates."
  tool="image compression estimator, WebP savings calculator, AVIF file size calculator, image optimization tool, image format comparison"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Image Compression Estimator",
    "url": "https://devplaybook.cc/tools/image-compression-estimator",
    "description": "Estimate file size savings from converting images to WebP or AVIF. Get bandwidth savings and LCP improvement estimates based on industry-standard compression ratios.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Image Compression Estimator</h1>
  <p class="text-text-muted mb-4">
    Estimate how much file size you'll save by converting images to <strong>WebP</strong> or <strong>AVIF</strong>. Enter your current image details to get projected savings, bandwidth reduction, and LCP improvement estimates based on real-world compression ratios.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> JPEG → WebP / AVIF estimates</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> PNG → WebP / AVIF estimates</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Monthly bandwidth savings</span>
  </div>

  <!-- Input -->
  <div class="bg-bg-card border border-border rounded-xl p-6 mb-6">
    <h2 class="font-semibold text-base mb-4">Image Details</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">

      <div>
        <label class="block text-sm font-medium mb-1" for="file-size">Current File Size (KB)</label>
        <input id="file-size" type="number" min="1" step="1" placeholder="e.g. 450"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/50" />
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" for="source-format">Source Format</label>
        <select id="source-format"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/50">
          <option value="jpeg">JPEG / JPG</option>
          <option value="png">PNG</option>
          <option value="gif">GIF</option>
          <option value="bmp">BMP</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" for="img-width">Image Width (px, optional)</label>
        <input id="img-width" type="number" min="1" step="1" placeholder="e.g. 1200"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/50" />
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" for="monthly-views">Monthly Page Views (optional)</label>
        <input id="monthly-views" type="number" min="0" step="1000" placeholder="e.g. 50000"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/50" />
      </div>

    </div>

    <div class="flex gap-3">
      <button id="estimate-btn"
        class="bg-primary text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors">
        Estimate Savings
      </button>
      <button id="load-example-btn" class="text-sm text-primary hover:underline">Load example</button>
    </div>
  </div>

  <!-- Results -->
  <div id="results" class="hidden space-y-4 mb-6">

    <!-- Format comparison cards -->
    <h2 class="font-semibold text-base">Estimated Savings by Format</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

      <div class="bg-bg-card border border-green-500/30 rounded-xl p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-lg">🟢</span>
          <span class="font-semibold">WebP (lossy)</span>
          <span class="ml-auto text-xs bg-green-500/10 text-green-500 px-2 py-0.5 rounded-full">Recommended</span>
        </div>
        <div class="text-3xl font-bold text-green-500 mb-1" id="webp-saving">–</div>
        <div class="text-sm text-text-muted mb-2" id="webp-size">from — KB → — KB</div>
        <div class="text-xs text-text-muted">~30% smaller than JPEG on average. Supported by all modern browsers.</div>
      </div>

      <div class="bg-bg-card border border-blue-500/30 rounded-xl p-5">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-lg">🔵</span>
          <span class="font-semibold">AVIF (lossy)</span>
          <span class="ml-auto text-xs bg-blue-500/10 text-blue-400 px-2 py-0.5 rounded-full">Best compression</span>
        </div>
        <div class="text-3xl font-bold text-blue-400 mb-1" id="avif-saving">–</div>
        <div class="text-sm text-text-muted mb-2" id="avif-size">from — KB → — KB</div>
        <div class="text-xs text-text-muted">~50% smaller than JPEG. Chrome 85+, Firefox 93+, Safari 16+.</div>
      </div>

    </div>

    <!-- Bandwidth savings -->
    <div id="bandwidth-section" class="hidden bg-bg-card border border-border rounded-xl p-5">
      <h3 class="font-semibold text-sm mb-3">Monthly Bandwidth Savings</h3>
      <div class="grid grid-cols-2 gap-4 text-center">
        <div>
          <div class="text-2xl font-bold text-green-500" id="webp-bandwidth">–</div>
          <div class="text-xs text-text-muted mt-1">WebP saves / month</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-blue-400" id="avif-bandwidth">–</div>
          <div class="text-xs text-text-muted mt-1">AVIF saves / month</div>
        </div>
      </div>
    </div>

    <!-- Implementation snippet -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h3 class="font-semibold text-sm mb-3">HTML Implementation</h3>
      <pre class="bg-bg rounded-lg p-3 text-xs font-mono overflow-x-auto text-text-muted whitespace-pre-wrap"><code>&lt;picture&gt;
  &lt;source srcset="image.avif" type="image/avif"&gt;
  &lt;source srcset="image.webp" type="image/webp"&gt;
  &lt;img src="image.jpg" alt="..." width="..." height="..." loading="lazy"&gt;
&lt;/picture&gt;</code></pre>
      <p class="text-xs text-text-muted mt-2">The browser picks the first supported format. Always include the original as fallback.</p>
    </div>

    <!-- Tools recommendation -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h3 class="font-semibold text-sm mb-3">Conversion Tools</h3>
      <ul class="text-sm space-y-1.5 text-text-muted">
        <li><strong class="text-text">CLI:</strong> <code class="font-mono bg-bg px-1 rounded text-xs">cwebp -q 80 input.jpg -o output.webp</code> · <code class="font-mono bg-bg px-1 rounded text-xs">avifenc input.jpg output.avif</code></li>
        <li><strong class="text-text">Node.js:</strong> sharp (npm) — converts and resizes on-the-fly</li>
        <li><strong class="text-text">CDN:</strong> Cloudflare Images, Cloudinary, Imgix — auto-convert via URL</li>
        <li><strong class="text-text">Next.js:</strong> next/image — automatic WebP/AVIF with lazy loading</li>
        <li><strong class="text-text">Astro:</strong> astro:assets Image component — automatic format optimization</li>
      </ul>
    </div>

  </div>
</BaseLayout>

<script is:inline>
  // Compression ratios relative to source format (estimated savings %)
  const RATIOS = {
    jpeg: { webp: 0.30, avif: 0.50 },
    png:  { webp: 0.50, avif: 0.60 },
    gif:  { webp: 0.60, avif: 0.65 },
    bmp:  { webp: 0.70, avif: 0.75 },
  };

  function formatSize(kb) {
    if (kb >= 1024) return (kb / 1024).toFixed(2) + ' MB';
    return kb.toFixed(0) + ' KB';
  }

  function estimate() {
    const sizeKb = parseFloat(document.getElementById('file-size').value);
    const fmt = document.getElementById('source-format').value;
    const views = parseInt(document.getElementById('monthly-views').value) || 0;

    if (!sizeKb || sizeKb <= 0) {
      alert('Please enter a valid file size in KB.');
      return;
    }

    const ratios = RATIOS[fmt] || RATIOS.jpeg;

    const webpSaved = sizeKb * ratios.webp;
    const avifSaved = sizeKb * ratios.avif;
    const webpSize = sizeKb - webpSaved;
    const avifSize = sizeKb - avifSaved;

    document.getElementById('webp-saving').textContent = formatSize(webpSaved) + ' saved (' + Math.round(ratios.webp * 100) + '%)';
    document.getElementById('webp-size').textContent = formatSize(sizeKb) + ' → ' + formatSize(webpSize);

    document.getElementById('avif-saving').textContent = formatSize(avifSaved) + ' saved (' + Math.round(ratios.avif * 100) + '%)';
    document.getElementById('avif-size').textContent = formatSize(sizeKb) + ' → ' + formatSize(avifSize);

    if (views > 0) {
      const webpBw = (webpSaved * views) / 1024;
      const avifBw = (avifSaved * views) / 1024;
      document.getElementById('webp-bandwidth').textContent = formatSize(webpBw * 1024);
      document.getElementById('avif-bandwidth').textContent = formatSize(avifBw * 1024);
      document.getElementById('bandwidth-section').classList.remove('hidden');
    } else {
      document.getElementById('bandwidth-section').classList.add('hidden');
    }

    document.getElementById('results').classList.remove('hidden');
  }

  document.getElementById('estimate-btn').addEventListener('click', estimate);
  document.getElementById('load-example-btn').addEventListener('click', () => {
    document.getElementById('file-size').value = '450';
    document.getElementById('source-format').value = 'jpeg';
    document.getElementById('img-width').value = '1200';
    document.getElementById('monthly-views').value = '50000';
  });
  document.getElementById('file-size').addEventListener('keydown', e => {
    if (e.key === 'Enter') estimate();
  });
</script>

<FaqSection faq={faq} />
<ToolPageCta currentTool="Image Compression Estimator" relatedTags={['performance', 'images', 'webp', 'avif', 'optimization', 'developer-tools']} />
