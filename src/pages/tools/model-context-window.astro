---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a context window?", answer: "A context window is the maximum amount of text a language model can read and consider at once — including your system prompt, conversation history, and the model's own response. It's measured in tokens. 1 token ≈ 0.75 words in English. Running out of context causes the model to lose earlier parts of the conversation." },
  { question: "How many words fit in 128K tokens?", answer: "128K tokens ≈ 96,000 words ≈ a 350-page novel. At 200K tokens (Claude, o1), you can fit roughly 150,000 words. At 1M tokens (Gemini 1.5), you can process approximately 750,000 words — the equivalent of 5–6 full-length novels or an entire codebase." },
  { question: "Does a larger context window mean better understanding?", answer: "Not necessarily. Models with large context windows can technically process more text, but their ability to reason about information in the middle of very long contexts varies. This is known as the 'lost in the middle' problem. Gemini 1.5 and Claude 3.5 have shown strong performance across their full context windows in benchmarks." },
  { question: "What is the difference between context window and training data size?", answer: "Context window is how much the model can read at inference time. Training data size is how much text the model learned from during training. They are independent — a model can have a small context window but be trained on enormous datasets." },
  { question: "When would I need more than 128K tokens?", answer: "Common use cases for large context: processing entire codebases, book-length documents, long contract analysis, multi-hour transcripts, video frame analysis, or maintaining very long chat histories. 1M token context (Gemini 1.5) can ingest PDFs of hundreds of pages in a single call." },
];

const models = [
  { name: 'GPT-4o', provider: 'OpenAI', contextK: 128, released: '2024-05', notes: 'Flagship multimodal model' },
  { name: 'GPT-4o mini', provider: 'OpenAI', contextK: 128, released: '2024-07', notes: 'Budget-friendly, fast' },
  { name: 'o1', provider: 'OpenAI', contextK: 200, released: '2024-09', notes: 'Reasoning model, slow output' },
  { name: 'o1 mini', provider: 'OpenAI', contextK: 128, released: '2024-09', notes: 'Faster reasoning, lower cost' },
  { name: 'Claude 3.5 Sonnet', provider: 'Anthropic', contextK: 200, released: '2024-10', notes: 'Best coding + agents' },
  { name: 'Claude 3.5 Haiku', provider: 'Anthropic', contextK: 200, released: '2024-11', notes: 'Fastest Claude' },
  { name: 'Claude 3 Opus', provider: 'Anthropic', contextK: 200, released: '2024-03', notes: 'Complex reasoning' },
  { name: 'Gemini 1.5 Pro', provider: 'Google', contextK: 1000, released: '2024-02', notes: 'Largest context, 1M tokens' },
  { name: 'Gemini 1.5 Flash', provider: 'Google', contextK: 1000, released: '2024-05', notes: 'Fast + long context' },
  { name: 'Gemini 2.0 Flash', provider: 'Google', contextK: 1000, released: '2025-01', notes: 'Latest Gemini, fast' },
  { name: 'Llama 3.3 70B', provider: 'Meta', contextK: 128, released: '2024-12', notes: 'Best open-source large' },
  { name: 'Llama 3.1 8B', provider: 'Meta', contextK: 128, released: '2024-07', notes: 'Fast, self-hostable' },
  { name: 'Mixtral 8x7B', provider: 'Mistral', contextK: 32, released: '2023-12', notes: 'MoE architecture' },
  { name: 'DeepSeek-V2', provider: 'DeepSeek', contextK: 128, released: '2024-05', notes: 'Strong coding, cost-effective' },
];

const providers = [...new Set(models.map(m => m.provider))];
---

<BaseLayout
  title="LLM Context Window Comparison — GPT-4o vs Claude vs Gemini"
  description="Compare context window sizes across all major LLMs. GPT-4o (128K), Claude 3.5 Sonnet (200K), Gemini 1.5 Pro (1M), and more. See word equivalents and filter by provider."
  tool="LLM Context Window Comparison, GPT-4o Context Window, Claude Context Length, Gemini 1M Context, LLM Token Limit"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">LLM Context Window Comparison</h1>
  <p class="text-text-muted mb-4">Compare context window sizes across 14 major language models. Filter by provider and see word-equivalent estimates to understand what fits in context.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 14 LLMs compared</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Filter by provider</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Word equivalent shown</span>
  </div>

  <!-- Filter buttons -->
  <div class="flex flex-wrap gap-2 mb-6">
    <button class="ctx-filter active text-xs px-3 py-1.5 rounded-full border border-primary text-primary bg-primary/10 transition-all" data-provider="all">All Providers</button>
    {providers.map(p => (
      <button class="ctx-filter text-xs px-3 py-1.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-provider={p}>{p}</button>
    ))}
  </div>

  <!-- Search -->
  <div class="mb-4">
    <input id="model-search" type="text" placeholder="Search model name..."
      class="w-full sm:w-64 bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
  </div>

  <!-- Table -->
  <div class="overflow-x-auto mb-8">
    <table class="w-full text-sm min-w-[600px]">
      <thead>
        <tr class="text-text-muted text-xs uppercase border-b border-border">
          <th class="text-left pb-3 pr-4 font-medium cursor-pointer hover:text-primary" data-sort="name">Model ↕</th>
          <th class="text-left pb-3 pr-4 font-medium">Provider</th>
          <th class="text-right pb-3 pr-4 font-medium cursor-pointer hover:text-primary" data-sort="context">Context ↕</th>
          <th class="text-right pb-3 pr-4 font-medium">Words ~</th>
          <th class="text-left pb-3 pr-4 font-medium">Released</th>
          <th class="text-left pb-3 font-medium">Notes</th>
        </tr>
      </thead>
      <tbody id="ctx-table" class="divide-y divide-border">
        {models.map(m => (
          <tr class="ctx-row hover:bg-bg-card/50 transition-colors" data-provider={m.provider} data-name={m.name.toLowerCase()} data-context={m.contextK}>
            <td class="py-3 pr-4 font-semibold">{m.name}</td>
            <td class="py-3 pr-4 text-text-muted">{m.provider}</td>
            <td class="py-3 pr-4 text-right tabular-nums">
              <span class={`font-bold ${m.contextK >= 500 ? 'text-primary' : m.contextK >= 200 ? 'text-yellow-500' : ''}`}>
                {m.contextK >= 1000 ? '1M' : m.contextK + 'K'}
              </span>
            </td>
            <td class="py-3 pr-4 text-right tabular-nums text-text-muted">
              ~{(m.contextK * 750).toLocaleString()}
            </td>
            <td class="py-3 pr-4 text-text-muted">{m.released}</td>
            <td class="py-3 text-xs text-text-muted">{m.notes}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Visual bar chart -->
  <h2 class="text-lg font-bold mb-4">Context Size Visual Comparison</h2>
  <div id="bar-chart" class="space-y-2 mb-8">
    {models.sort((a, b) => b.contextK - a.contextK).map(m => {
      const pct = (m.contextK / 1000) * 100;
      return (
        <div class="flex items-center gap-3 text-sm">
          <div class="w-40 shrink-0 text-right text-xs text-text-muted truncate">{m.name}</div>
          <div class="flex-1 bg-bg-card border border-border rounded-full h-4 overflow-hidden">
            <div class="h-full bg-primary/60 rounded-full transition-all" style={`width: ${Math.max(pct, 1)}%`}></div>
          </div>
          <div class="w-16 shrink-0 text-xs tabular-nums text-right">{m.contextK >= 1000 ? '1M' : m.contextK + 'K'}</div>
        </div>
      );
    })}
  </div>

  <!-- Legend -->
  <div class="flex flex-wrap gap-4 mb-8 text-xs text-text-muted">
    <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-primary/60 inline-block"></span> Context size (relative to 1M = 100%)</span>
    <span>* "Words ~" = context tokens × 0.75 (approximate English word count)</span>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="LLM Context Window Comparison" relatedTags={['ai', 'llm', 'openai', 'claude', 'gemini', 'context-window', 'tokens']} />
</BaseLayout>

<script>
  type SortField = 'name' | 'context';
  let currentProvider = 'all';
  let currentSearch = '';
  let sortField: SortField = 'context';
  let sortDir = -1; // -1 = desc, 1 = asc

  const rows = Array.from(document.querySelectorAll('.ctx-row')) as HTMLTableRowElement[];
  const searchInput = document.getElementById('model-search') as HTMLInputElement;

  function applyFilters() {
    rows.forEach(row => {
      const provider = row.getAttribute('data-provider') || '';
      const name = row.getAttribute('data-name') || '';
      const matchProvider = currentProvider === 'all' || provider === currentProvider;
      const matchSearch = !currentSearch || name.includes(currentSearch.toLowerCase());
      row.style.display = (matchProvider && matchSearch) ? '' : 'none';
    });
    sortRows();
  }

  function sortRows() {
    const tbody = document.getElementById('ctx-table')!;
    const visibleRows = rows.filter(r => r.style.display !== 'none');
    visibleRows.sort((a, b) => {
      if (sortField === 'name') {
        return (a.getAttribute('data-name') || '').localeCompare(b.getAttribute('data-name') || '') * sortDir;
      } else {
        return (parseInt(a.getAttribute('data-context') || '0') - parseInt(b.getAttribute('data-context') || '0')) * sortDir;
      }
    });
    visibleRows.forEach(r => tbody.appendChild(r));
  }

  document.querySelectorAll('.ctx-filter').forEach(btn => {
    btn.addEventListener('click', () => {
      currentProvider = btn.getAttribute('data-provider') || 'all';
      document.querySelectorAll('.ctx-filter').forEach(b => {
        b.classList.remove('active', 'border-primary', 'text-primary', 'bg-primary/10');
        b.classList.add('border-border', 'text-text-muted');
      });
      btn.classList.add('active', 'border-primary', 'text-primary', 'bg-primary/10');
      btn.classList.remove('border-border', 'text-text-muted');
      applyFilters();
    });
  });

  document.querySelectorAll('[data-sort]').forEach(th => {
    th.addEventListener('click', () => {
      const field = th.getAttribute('data-sort') as SortField;
      if (sortField === field) {
        sortDir *= -1;
      } else {
        sortField = field;
        sortDir = field === 'context' ? -1 : 1;
      }
      sortRows();
    });
  });

  searchInput.addEventListener('input', () => {
    currentSearch = searchInput.value.trim();
    applyFilters();
  });
</script>
