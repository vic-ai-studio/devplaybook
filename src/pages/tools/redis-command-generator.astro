---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RedisCommandGenerator from '../../components/RedisCommandGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Redis and when should I use it?",
    answer: "Redis is an in-memory data structure store used as a database, cache, message broker, and queue. Use Redis for: caching database results (sub-millisecond reads), session storage (fast auth checks), real-time leaderboards (sorted sets), pub/sub messaging (fan-out notifications), rate limiting (atomic counters), and task queues (RPUSH/BLPOP pattern)."
  },
  {
    question: "What is the difference between SET with EX vs TTL/EXPIRE?",
    answer: "SET key value EX 3600 is atomic — sets the value and TTL in one operation. Calling SET followed by EXPIRE is two operations and not atomic; a crash between them leaves a key with no TTL (persists forever). Always use SET ... EX/PX when creating keys with TTL. Use EXPIRE/PEXPIRE only to extend or add TTL to existing keys."
  },
  {
    question: "How do I implement a distributed lock with Redis?",
    answer: "Use SET resource token NX PX ttl. NX=only set if not exists (atomic mutex). PX=TTL in milliseconds to auto-release if the holder crashes. Always store a unique token (UUID) and verify it before releasing — use a Lua script for atomic compare-and-delete. This is the core of the Redlock algorithm. Never use SETNX + EXPIRE (two separate commands) — it's not atomic."
  },
  {
    question: "What is the difference between LPOP/RPOP and BLPOP/BRPOP?",
    answer: "LPOP/RPOP immediately return null if the list is empty — your worker must loop and poll. BLPOP/BRPOP block the connection until an item is available or the timeout expires. Blocking pops are more efficient for task queues — no polling loop needed. Use BLPOP for worker processes. Note: a blocking connection cannot be used for other commands while waiting."
  },
  {
    question: "When should I use hashes (HSET) vs strings (SET) for sessions?",
    answer: "Use HSET for sessions with multiple fields — HGET retrieves a single field without deserializing the whole session. SET requires serializing/deserializing a full JSON blob on every access. HSET is also more memory-efficient for many small fields. Use SET when the session is always accessed as a whole and rarely updated partially."
  },
  {
    question: "What are the Redis data type use cases?",
    answer: "Strings: caching, counters, simple key-value. Lists: queues, stacks, activity feeds. Sets: unique members, tags, user followers (SADD, SMEMBERS, SINTER, SUNION). Sorted Sets: leaderboards, time-series, priority queues (ZADD, ZRANGE, ZREVRANK). Hashes: objects with fields, sessions, user profiles. Streams: event logs, message queues with consumer groups."
  },
];
---

<BaseLayout
  title="Redis Command Generator — Caching, Pub/Sub, Rate Limiting, Sessions, Leaderboard"
  description="Generate Redis commands for 8 common patterns: caching with TTL, pub/sub messaging, rate limiting, session storage, leaderboards, task queues, distributed locks, and geolocation. Copy-ready commands with explanations."
  tool="Redis command generator, Redis caching commands, Redis pub/sub, Redis rate limiting, Redis session storage, Redis leaderboard"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Redis Command Generator",
    "url": "https://devplaybook.cc/tools/redis-command-generator",
    "description": "Generate Redis commands for caching, pub/sub, rate limiting, sessions, leaderboards, queues, distributed locks, and geolocation. Copy-ready with explanations.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Redis Command Generator</h1>
  <p class="text-text-muted mb-4">
    Generate copy-ready Redis commands for 8 common patterns — caching with TTL, pub/sub messaging,
    rate limiting, session storage, leaderboards, task queues, distributed locks, and geolocation.
    Each command includes a plain-English explanation.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 8 patterns</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Configurable fields</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-ready commands</span>
  </div>
  <RedisCommandGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Redis Command Generator" relatedTags={['redis', 'database', 'caching', 'backend', 'devops', 'performance']} />
</BaseLayout>
