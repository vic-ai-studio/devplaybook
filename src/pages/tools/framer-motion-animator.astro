---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Framer Motion?", answer: "Framer Motion is a production-ready animation library for React. It provides a motion.div component (and other motion.* elements) that accept animation props like initial, animate, exit, whileHover, and whileTap. It handles complex animation sequencing, spring physics, and gesture detection with a declarative API." },
  { question: "What is the difference between animate and variants in Framer Motion?", answer: "animate accepts inline animation values directly on a component. variants allows you to define named animation states as an object and reference them by name — this enables parent-children orchestration via staggerChildren and delayChildren. Variants are preferred for complex animations with multiple elements." },
  { question: "How does AnimatePresence work?", answer: "AnimatePresence enables exit animations. Without it, React unmounts components immediately and the exit prop on motion.* elements is ignored. Wrap conditional renders or list items in AnimatePresence to allow components to animate out. The mode prop controls whether old/new components overlap ('sync'), old exits first ('wait'), or new enters first ('popLayout')." },
  { question: "What is useAnimation hook used for?", answer: "useAnimation returns an animation controls object that lets you manually trigger animations with controls.start() and controls.stop(). Useful for triggering animations based on external events like scroll position, intersection observer callbacks, or user interactions that aren't gesture-based." },
  { question: "What are spring animations in Framer Motion?", answer: "Spring animations simulate physics-based motion with bounce and natural deceleration. Key parameters: stiffness (how rigid the spring is — higher = snappier), damping (how quickly it stops oscillating — lower = more bounce), mass (virtual weight — higher = slower), and restDelta (threshold to stop animation). Spring feels more natural than duration-based easing for UI elements." },
];
---

<BaseLayout
  title="Framer Motion Animator — Generate motion.div, useAnimation, AnimatePresence Code"
  description="Build Framer Motion animation code visually. Configure fade, slide, scale, rotate, spring animations with trigger, duration, and easing controls. Copy-ready React code."
  tool="Framer Motion Generator, motion.div Code Builder, useAnimation Hook Generator, AnimatePresence React"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Framer Motion Animator</h1>
  <p class="text-text-muted mb-4">Generate Framer Motion code for React — <code class="text-primary bg-primary/10 px-1 rounded text-sm">motion.div</code> props, <code class="text-primary bg-primary/10 px-1 rounded text-sm">useAnimation</code> with variants, and <code class="text-primary bg-primary/10 px-1 rounded text-sm">AnimatePresence</code> wrappers — with a live preview.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Zero dependencies</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live CSS preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Spring + easing support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 3 output sections</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-5">
    <!-- Left: Controls -->
    <div class="space-y-5">

      <!-- Animation Type -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Animation Type</h2>
        <div class="grid grid-cols-2 gap-3 mb-4">
          <div>
            <label class="block text-sm font-medium mb-1.5">Type</label>
            <select id="anim-type" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="fade">Fade</option>
              <option value="slide">Slide</option>
              <option value="scale">Scale</option>
              <option value="rotate">Rotate</option>
              <option value="spring">Spring Bounce</option>
            </select>
          </div>
          <div id="direction-row">
            <label class="block text-sm font-medium mb-1.5">Direction</label>
            <select id="anim-direction" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="up">Up</option>
              <option value="down">Down</option>
              <option value="left">Left</option>
              <option value="right">Right</option>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium mb-1.5">Trigger</label>
            <select id="anim-trigger" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="mount">On Mount</option>
              <option value="hover">On Hover</option>
              <option value="tap">On Tap</option>
              <option value="scroll">On Scroll (useAnimation)</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5">Ease</label>
            <select id="anim-ease" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="easeOut">easeOut</option>
              <option value="easeIn">easeIn</option>
              <option value="easeInOut">easeInOut</option>
              <option value="linear">linear</option>
              <option value="circOut">circOut</option>
              <option value="backOut">backOut (overshoot)</option>
              <option value="anticipate">anticipate</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Timing -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Timing & Physics</h2>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium mb-1.5">Duration <span id="duration-label" class="text-primary font-mono">0.5s</span></label>
            <input type="range" id="duration" min="0.1" max="3" step="0.1" value="0.5" class="w-full accent-primary" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5">Delay <span id="delay-label" class="text-primary font-mono">0s</span></label>
            <input type="range" id="delay" min="0" max="2" step="0.1" value="0" class="w-full accent-primary" />
          </div>
          <div id="spring-controls" class="hidden space-y-3">
            <div>
              <label class="block text-sm font-medium mb-1.5">Stiffness <span id="stiffness-label" class="text-primary font-mono">100</span></label>
              <input type="range" id="stiffness" min="10" max="500" step="10" value="100" class="w-full accent-primary" />
            </div>
            <div>
              <label class="block text-sm font-medium mb-1.5">Damping <span id="damping-label" class="text-primary font-mono">10</span></label>
              <input type="range" id="damping" min="1" max="50" step="1" value="10" class="w-full accent-primary" />
            </div>
            <div>
              <label class="block text-sm font-medium mb-1.5">Mass <span id="mass-label" class="text-primary font-mono">1</span></label>
              <input type="range" id="mass" min="0.1" max="5" step="0.1" value="1" class="w-full accent-primary" />
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1.5">Repeat</label>
            <select id="repeat" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="0">None</option>
              <option value="1">Once</option>
              <option value="2">Twice</option>
              <option value="Infinity">Infinite</option>
            </select>
          </div>
          <div id="repeat-type-row" class="hidden">
            <label class="block text-sm font-medium mb-1.5">Repeat Type</label>
            <select id="repeat-type" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="loop">loop</option>
              <option value="reverse">reverse (ping-pong)</option>
              <option value="mirror">mirror</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Live Preview -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-base font-semibold">Live CSS Preview</h2>
          <button id="replay-btn" class="bg-primary text-white text-sm px-3 py-1.5 rounded-lg hover:opacity-90">Replay</button>
        </div>
        <div class="flex items-center justify-center h-32 bg-bg-card border border-border rounded-lg">
          <div id="preview-box" class="w-16 h-16 bg-primary rounded-lg flex items-center justify-center text-white text-2xl font-bold">
            M
          </div>
        </div>
        <p class="text-xs text-text-muted mt-2 text-center">CSS approximation — actual Framer Motion uses spring physics</p>
      </div>
    </div>

    <!-- Right: Output -->
    <div class="space-y-4">
      <!-- Tab bar -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex gap-1 mb-4 flex-wrap" id="fm-tab-bar">
          <button data-tab="props" class="fm-tab-btn px-3 py-1.5 text-sm rounded-lg border border-primary bg-primary text-white">motion.div Props</button>
          <button data-tab="variants" class="fm-tab-btn px-3 py-1.5 text-sm rounded-lg border border-border text-text-muted hover:border-primary hover:text-primary transition-colors">useAnimation Variants</button>
          <button data-tab="presence" class="fm-tab-btn px-3 py-1.5 text-sm rounded-lg border border-border text-text-muted hover:border-primary hover:text-primary transition-colors">AnimatePresence</button>
        </div>
        <div class="relative">
          <pre id="fm-code-output" class="text-green-400 text-xs font-mono overflow-x-auto whitespace-pre bg-bg-card border border-border rounded-lg p-3 min-h-[280px]"></pre>
          <button id="copy-fm-btn" class="absolute top-2 right-2 border border-border text-text-muted hover:text-primary hover:border-primary text-xs px-2.5 py-1 rounded-md transition-colors">Copy</button>
        </div>
      </div>

      <!-- Quick reference -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">Framer Motion Quick Reference</h2>
        <div class="space-y-2 text-xs text-text-muted font-mono">
          <div class="flex justify-between border-b border-border pb-1"><span class="text-blue-400">initial</span><span>State before animation</span></div>
          <div class="flex justify-between border-b border-border pb-1"><span class="text-blue-400">animate</span><span>Target state</span></div>
          <div class="flex justify-between border-b border-border pb-1"><span class="text-blue-400">exit</span><span>State on unmount (needs AnimatePresence)</span></div>
          <div class="flex justify-between border-b border-border pb-1"><span class="text-yellow-400">whileHover</span><span>State while hovered</span></div>
          <div class="flex justify-between border-b border-border pb-1"><span class="text-yellow-400">whileTap</span><span>State while pressed</span></div>
          <div class="flex justify-between border-b border-border pb-1"><span class="text-green-400">whileInView</span><span>State while in viewport</span></div>
          <div class="flex justify-between border-b border-border pb-1"><span class="text-purple-400">layout</span><span>Animate layout changes</span></div>
          <div class="flex justify-between"><span class="text-purple-400">layoutId</span><span>Shared element transition</span></div>
        </div>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Framer Motion Animator" relatedTags={['react', 'animation', 'framer-motion', 'css', 'ux', 'motion']} />
</BaseLayout>

<script>
  let activeTab = 'props';

  function getVal(id: string): string {
    const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement;
    return el?.value ?? '';
  }

  function getAnimValues(): { initial: Record<string, any>, animate: Record<string, any>, exit: Record<string, any> } {
    const type = getVal('anim-type');
    const dir = getVal('anim-direction');
    const DIST = 40;

    const dirMap: Record<string, [string, number]> = {
      up: ['y', DIST], down: ['y', -DIST], left: ['x', DIST], right: ['x', -DIST],
    };

    const initial: Record<string, any> = {};
    const animate: Record<string, any> = {};
    const exit: Record<string, any> = {};

    switch (type) {
      case 'fade':
        initial.opacity = 0;
        animate.opacity = 1;
        exit.opacity = 0;
        break;
      case 'slide': {
        const [axis, val] = dirMap[dir] ?? ['y', DIST];
        initial.opacity = 0;
        initial[axis] = val;
        animate.opacity = 1;
        animate[axis] = 0;
        exit.opacity = 0;
        exit[axis] = val;
        break;
      }
      case 'scale':
        initial.opacity = 0;
        initial.scale = 0.8;
        animate.opacity = 1;
        animate.scale = 1;
        exit.opacity = 0;
        exit.scale = 0.8;
        break;
      case 'rotate':
        initial.opacity = 0;
        initial.rotate = -15;
        initial.scale = 0.9;
        animate.opacity = 1;
        animate.rotate = 0;
        animate.scale = 1;
        exit.opacity = 0;
        exit.rotate = 15;
        break;
      case 'spring':
        initial.opacity = 0;
        initial.y = 30;
        initial.scale = 0.95;
        animate.opacity = 1;
        animate.y = 0;
        animate.scale = 1;
        exit.opacity = 0;
        exit.y = 30;
        break;
    }
    return { initial, animate, exit };
  }

  function getTransition(): Record<string, any> {
    const type = getVal('anim-type');
    const duration = parseFloat(getVal('duration'));
    const delay = parseFloat(getVal('delay'));
    const ease = getVal('anim-ease');
    const repeat = getVal('repeat');
    const repeatType = getVal('repeat-type');
    const stiffness = parseInt(getVal('stiffness')) || 100;
    const damping = parseInt(getVal('damping')) || 10;
    const mass = parseFloat(getVal('mass')) || 1;

    const t: Record<string, any> = {};

    if (type === 'spring') {
      t.type = 'spring';
      t.stiffness = stiffness;
      t.damping = damping;
      t.mass = mass;
    } else {
      t.duration = duration;
      t.ease = ease;
    }
    if (delay > 0) t.delay = delay;
    if (repeat !== '0') {
      t.repeat = repeat === 'Infinity' ? Infinity : parseInt(repeat);
      t.repeatType = repeatType;
    }
    return t;
  }

  function objToCode(obj: Record<string, any>, indent: string = '  '): string {
    return '{\n' + Object.entries(obj).map(([k, v]) => {
      const val = v === Infinity ? 'Infinity' : JSON.stringify(v);
      return `${indent}  ${k}: ${val},`;
    }).join('\n') + '\n' + indent + '}';
  }

  function generateProps(): string {
    const trigger = getVal('anim-trigger');
    const { initial, animate, exit } = getAnimValues();
    const transition = getTransition();

    const lines: string[] = [];
    lines.push(`import { motion } from 'framer-motion';`);
    lines.push('');
    lines.push('// Spread these props onto your motion component');

    if (trigger === 'mount') {
      lines.push(`<motion.div`);
      lines.push(`  initial={${JSON.stringify(initial)}}`);
      lines.push(`  animate={${JSON.stringify(animate)}}`);
      lines.push(`  exit={${JSON.stringify(exit)}}`);
      lines.push(`  transition={${JSON.stringify(transition)}}`);
      lines.push(`>`);
      lines.push(`  {/* your content */}`);
      lines.push(`</motion.div>`);
    } else if (trigger === 'hover') {
      lines.push(`<motion.div`);
      lines.push(`  whileHover={${JSON.stringify(animate)}}`);
      lines.push(`  transition={${JSON.stringify(transition)}}`);
      lines.push(`>`);
      lines.push(`  {/* your content */}`);
      lines.push(`</motion.div>`);
    } else if (trigger === 'tap') {
      lines.push(`<motion.div`);
      lines.push(`  whileTap={${JSON.stringify(animate)}}`);
      lines.push(`  transition={${JSON.stringify(transition)}}`);
      lines.push(`>`);
      lines.push(`  {/* your content */}`);
      lines.push(`</motion.div>`);
    } else if (trigger === 'scroll') {
      lines.push(`<motion.div`);
      lines.push(`  initial={${JSON.stringify(initial)}}`);
      lines.push(`  whileInView={${JSON.stringify(animate)}}`);
      lines.push(`  exit={${JSON.stringify(exit)}}`);
      lines.push(`  viewport={{ once: true, amount: 0.3 }}`);
      lines.push(`  transition={${JSON.stringify(transition)}}`);
      lines.push(`>`);
      lines.push(`  {/* your content */}`);
      lines.push(`</motion.div>`);
    }
    return lines.join('\n');
  }

  function generateVariants(): string {
    const { initial, animate, exit } = getAnimValues();
    const transition = getTransition();
    const trigger = getVal('anim-trigger');

    const lines: string[] = [];
    lines.push(`import { motion, useAnimation } from 'framer-motion';`);
    lines.push(`import { useEffect } from 'react';`);
    lines.push('');
    lines.push(`const variants = {`);
    lines.push(`  hidden: ${JSON.stringify(initial)},`);
    lines.push(`  visible: {`);
    lines.push(`    ...${JSON.stringify(animate)},`);
    lines.push(`    transition: ${JSON.stringify(transition)},`);
    lines.push(`  },`);
    lines.push(`  exit: ${JSON.stringify(exit)},`);
    lines.push(`};`);
    lines.push('');

    if (trigger === 'scroll') {
      lines.push(`export function AnimatedElement() {`);
      lines.push(`  const controls = useAnimation();`);
      lines.push('');
      lines.push(`  // Use with IntersectionObserver for scroll-based trigger`);
      lines.push(`  useEffect(() => {`);
      lines.push(`    const observer = new IntersectionObserver(`);
      lines.push(`      ([entry]) => {`);
      lines.push(`        if (entry.isIntersecting) controls.start('visible');`);
      lines.push(`        else controls.start('hidden');`);
      lines.push(`      },`);
      lines.push(`      { threshold: 0.3 }`);
      lines.push(`    );`);
      lines.push(`    const el = document.getElementById('animated-target');`);
      lines.push(`    if (el) observer.observe(el);`);
      lines.push(`    return () => observer.disconnect();`);
      lines.push(`  }, [controls]);`);
      lines.push('');
      lines.push(`  return (`);
      lines.push(`    <motion.div`);
      lines.push(`      id="animated-target"`);
      lines.push(`      variants={variants}`);
      lines.push(`      initial="hidden"`);
      lines.push(`      animate={controls}`);
      lines.push(`    >`);
      lines.push(`      {/* your content */}`);
      lines.push(`    </motion.div>`);
      lines.push(`  );`);
      lines.push(`}`);
    } else {
      lines.push(`// Stagger children example`);
      lines.push(`const containerVariants = {`);
      lines.push(`  hidden: { opacity: 0 },`);
      lines.push(`  visible: {`);
      lines.push(`    opacity: 1,`);
      lines.push(`    transition: {`);
      lines.push(`      staggerChildren: 0.1,`);
      lines.push(`      delayChildren: ${transition.delay ?? 0},`);
      lines.push(`    },`);
      lines.push(`  },`);
      lines.push(`};`);
      lines.push('');
      lines.push(`export function AnimatedList({ items }: { items: string[] }) {`);
      lines.push(`  return (`);
      lines.push(`    <motion.ul variants={containerVariants} initial="hidden" animate="visible">`);
      lines.push(`      {items.map((item, i) => (`);
      lines.push(`        <motion.li key={i} variants={variants}>{item}</motion.li>`);
      lines.push(`      ))}`);
      lines.push(`    </motion.ul>`);
      lines.push(`  );`);
      lines.push(`}`);
    }

    return lines.join('\n');
  }

  function generatePresence(): string {
    const { initial, animate, exit } = getAnimValues();
    const transition = getTransition();

    const lines: string[] = [];
    lines.push(`import { motion, AnimatePresence } from 'framer-motion';`);
    lines.push(`import { useState } from 'react';`);
    lines.push('');
    lines.push(`// AnimatePresence enables exit animations`);
    lines.push(`// Wrap conditionally-rendered elements`);
    lines.push('');
    lines.push(`export function ToggleComponent() {`);
    lines.push(`  const [isVisible, setIsVisible] = useState(true);`);
    lines.push('');
    lines.push(`  return (`);
    lines.push(`    <div>`);
    lines.push(`      <button onClick={() => setIsVisible(v => !v)}>Toggle</button>`);
    lines.push('');
    lines.push(`      <AnimatePresence mode="wait">`);
    lines.push(`        {isVisible && (`);
    lines.push(`          <motion.div`);
    lines.push(`            key="content"`);
    lines.push(`            initial={${JSON.stringify(initial)}}`);
    lines.push(`            animate={${JSON.stringify(animate)}}`);
    lines.push(`            exit={${JSON.stringify(exit)}}`);
    lines.push(`            transition={${JSON.stringify(transition)}}`);
    lines.push(`          >`);
    lines.push(`            {/* your content */}`);
    lines.push(`          </motion.div>`);
    lines.push(`        )}`);
    lines.push(`      </AnimatePresence>`);
    lines.push(`    </div>`);
    lines.push(`  );`);
    lines.push(`}`);
    lines.push('');
    lines.push(`// mode options:`);
    lines.push(`// "sync"       — old and new overlap`);
    lines.push(`// "wait"       — old exits before new enters`);
    lines.push(`// "popLayout"  — new enters using layout animations`);

    return lines.join('\n');
  }

  function updatePreview(): void {
    const box = document.getElementById('preview-box')!;
    const type = getVal('anim-type');
    const dir = getVal('anim-direction');
    const duration = getVal('duration');
    const delay = getVal('delay');
    const ease = getVal('anim-ease');
    const easeMap: Record<string, string> = {
      easeOut: 'ease-out', easeIn: 'ease-in', easeInOut: 'ease-in-out',
      linear: 'linear', circOut: 'ease-out', backOut: 'cubic-bezier(0.34,1.56,0.64,1)',
      anticipate: 'cubic-bezier(0.36,-0.4,0.12,1.4)',
    };
    const cssTiming = easeMap[ease] ?? 'ease-out';
    const dur = parseFloat(duration);
    const del = parseFloat(delay);

    const dirMap: Record<string, string> = {
      up: 'translateY(40px)', down: 'translateY(-40px)',
      left: 'translateX(40px)', right: 'translateX(-40px)',
    };

    let fromTransform = '';
    let fromOpacity = '0';
    let fromScale = '';
    let fromRotate = '';

    switch (type) {
      case 'fade': fromOpacity = '0'; break;
      case 'slide': fromTransform = dirMap[dir] ?? 'translateY(40px)'; fromOpacity = '0'; break;
      case 'scale': fromScale = 'scale(0.8)'; fromOpacity = '0'; break;
      case 'rotate': fromRotate = 'rotate(-15deg) scale(0.9)'; fromOpacity = '0'; break;
      case 'spring': fromTransform = 'translateY(30px) scale(0.95)'; fromOpacity = '0'; break;
    }

    box.style.transform = [fromTransform, fromScale, fromRotate].filter(Boolean).join(' ') || 'none';
    box.style.opacity = fromOpacity;
    box.style.transition = 'none';

    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        box.style.transition = `all ${dur}s ${cssTiming} ${del}s`;
        box.style.transform = 'none';
        box.style.opacity = '1';
      });
    });
  }

  function generate(): void {
    const outputs: Record<string, () => string> = {
      props: generateProps,
      variants: generateVariants,
      presence: generatePresence,
    };
    document.getElementById('fm-code-output')!.textContent = outputs[activeTab]?.() ?? '';
    updatePreview();
  }

  // Tab bar
  document.getElementById('fm-tab-bar')!.addEventListener('click', e => {
    const btn = (e.target as HTMLElement).closest('[data-tab]') as HTMLElement;
    if (!btn) return;
    activeTab = btn.dataset.tab!;
    document.querySelectorAll('.fm-tab-btn').forEach(b => {
      const isActive = (b as HTMLElement).dataset.tab === activeTab;
      b.className = isActive
        ? 'fm-tab-btn px-3 py-1.5 text-sm rounded-lg border border-primary bg-primary text-white'
        : 'fm-tab-btn px-3 py-1.5 text-sm rounded-lg border border-border text-text-muted hover:border-primary hover:text-primary transition-colors';
    });
    generate();
  });

  // Sliders
  ['duration','delay','stiffness','damping','mass'].forEach(id => {
    document.getElementById(id)!.addEventListener('input', () => {
      const el = document.getElementById(id) as HTMLInputElement;
      const label = document.getElementById(`${id}-label`)!;
      label.textContent = id === 'duration' || id === 'delay' || id === 'mass'
        ? `${el.value}s` : el.value;
      generate();
    });
  });

  // Selects
  ['anim-type','anim-direction','anim-trigger','anim-ease','repeat','repeat-type'].forEach(id => {
    document.getElementById(id)!.addEventListener('change', () => {
      const type = getVal('anim-type');
      const repeat = getVal('repeat');
      document.getElementById('spring-controls')!.classList.toggle('hidden', type !== 'spring');
      document.getElementById('direction-row')!.style.visibility = type === 'slide' ? 'visible' : 'hidden';
      document.getElementById('repeat-type-row')!.classList.toggle('hidden', repeat === '0');
      generate();
    });
  });

  // Copy
  document.getElementById('copy-fm-btn')!.addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('fm-code-output')!.textContent ?? '').then(() => {
      const btn = document.getElementById('copy-fm-btn')!;
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 1500);
    });
  });

  // Replay
  document.getElementById('replay-btn')!.addEventListener('click', updatePreview);

  generate();
</script>
