---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EnvParser from '../../components/EnvParser.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title=".env File Parser & Validator"
  description="Parse and validate .env files. Detect syntax errors, browse key-value pairs, generate a template with keys only, and export shell export commands. Runs entirely in your browser."
  tool=".env Parser, Environment Variable Validator, dotenv Parser, Env File Checker"
>
  <h1 class="text-3xl font-bold mb-2">.env File Parser & Validator</h1>
  <p class="text-text-muted mb-8">Paste your .env file to validate syntax, browse variables with optional value masking, generate a shareable template (keys only), or export as shell <code>export</code> commands. Nothing leaves your browser.</p>
  <EnvParser client:only="preact" />
  <ToolPageCta currentTool=".env File Parser" relatedTags={['env', 'dotenv', 'config', 'devops', 'security']} />
</BaseLayout>
