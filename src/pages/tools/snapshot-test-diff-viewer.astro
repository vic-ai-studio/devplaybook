---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is snapshot testing?", answer: "Snapshot testing captures the output of a component or function and saves it as a reference file. On subsequent test runs, the output is compared to the saved snapshot. If it differs, the test fails and you must either update the snapshot (if the change is intentional) or fix the bug causing the difference." },
  { question: "When should I use snapshot tests?", answer: "Snapshot tests are best for UI components (React, Vue, Svelte), serializable data structures, and generated output like HTML or JSON. They're poor for things that change often (timestamps, random IDs) or that need semantic assertions. Use them to catch unintended changes, not as a substitute for functional tests." },
  { question: "What does this diff viewer show?", answer: "This tool computes a line-by-line diff between two text inputs (old vs new snapshot). Lines only in the old snapshot are shown in red (removed). Lines only in the new snapshot are shown in green (added). Unchanged lines are shown in gray. This mirrors how Jest and Vitest display snapshot diff failures." },
  { question: "How do I update a Jest snapshot?", answer: "Run jest --updateSnapshot (or jest -u) to update all failing snapshots at once. To update a specific test's snapshot, run jest --testPathPattern=MyComponent -u. Always review the diff carefully before updating — an unexpected snapshot change may indicate a real bug." },
  { question: "Can I use this for non-JSON diffs?", answer: "Yes, this viewer works with any text: HTML strings, plain text, YAML, Markdown, or any serialized format. Just paste both versions and hit Compare." },
];
---

<BaseLayout
  title="Snapshot Test Diff Viewer — Compare JSON/Text Snapshots Online"
  description="Free online snapshot diff viewer. Paste two JSON or text snapshots and see a colored line-by-line diff. Mirrors Jest and Vitest snapshot failure output. No install needed."
  tool="snapshot diff viewer, jest snapshot diff, text diff tool, JSON diff, snapshot test comparison, vitest snapshot"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Snapshot Test Diff Viewer",
    "url": "https://devplaybook.cc/tools/snapshot-test-diff-viewer",
    "description": "Compare two snapshots with colored line-by-line diff output. Works with JSON, text, HTML, and any serialized format.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Snapshot Test Diff Viewer</h1>
  <p class="text-text-muted mb-4">Paste two JSON or text snapshots and instantly see a colored line-by-line diff — just like Jest and Vitest snapshot failure output. Useful for debugging failed snapshot tests or reviewing intentional changes.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Line-by-line diff</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Added / removed highlighting</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Works with JSON, HTML, text</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs entirely in browser</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
    <div>
      <div class="flex items-center justify-between mb-1">
        <label class="text-sm font-medium" for="snapshot-old">Old Snapshot (Before)</label>
        <span class="text-xs text-text-muted bg-red-500/10 text-red-400 border border-red-500/20 px-2 py-0.5 rounded">Removed</span>
      </div>
      <textarea id="snapshot-old" rows="14" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm font-mono focus:outline-none focus:border-red-400 transition-colors resize-y" placeholder="Paste old/expected snapshot here..."></textarea>
    </div>
    <div>
      <div class="flex items-center justify-between mb-1">
        <label class="text-sm font-medium" for="snapshot-new">New Snapshot (After)</label>
        <span class="text-xs text-text-muted bg-green-500/10 text-green-400 border border-green-500/20 px-2 py-0.5 rounded">Added</span>
      </div>
      <textarea id="snapshot-new" rows="14" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm font-mono focus:outline-none focus:border-green-400 transition-colors resize-y" placeholder="Paste new/received snapshot here..."></textarea>
    </div>
  </div>

  <div class="flex gap-3 mb-4">
    <button id="compare-btn" class="bg-accent hover:bg-accent/90 text-white font-semibold px-6 py-2.5 rounded-lg transition-colors text-sm">
      Compare Snapshots
    </button>
    <button id="format-btn" class="bg-bg-card hover:border-accent border border-border text-text font-semibold px-4 py-2.5 rounded-lg transition-colors text-sm">
      Format JSON
    </button>
    <button id="clear-btn" class="text-text-muted hover:text-text text-sm px-3 py-2.5">
      Clear
    </button>
  </div>

  <div id="diff-result" class="hidden">
    <div class="flex items-center justify-between mb-2">
      <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Diff Result</h2>
      <div id="diff-stats" class="flex gap-3 text-xs"></div>
    </div>
    <div id="diff-output" class="bg-bg border border-border rounded-xl overflow-x-auto font-mono text-sm leading-relaxed"></div>
  </div>

  <div id="no-diff" class="hidden bg-green-500/10 border border-green-500/20 rounded-xl p-6 text-center">
    <div class="text-3xl mb-2">✅</div>
    <p class="text-green-400 font-semibold">Snapshots are identical — no differences found.</p>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Snapshot Test Diff Viewer" relatedTags={['testing', 'developer-tools', 'json', 'debugging', 'jest', 'vitest']} />
</BaseLayout>

<script>
function lcs(a: string[], b: string[]): number[][] {
  const m = a.length, n = b.length;
  const dp: number[][] = Array.from({ length: m + 1 }, () => new Array(n + 1).fill(0));
  for (let i = 1; i <= m; i++)
    for (let j = 1; j <= n; j++)
      dp[i][j] = a[i-1] === b[j-1] ? dp[i-1][j-1] + 1 : Math.max(dp[i-1][j], dp[i][j-1]);
  return dp;
}

function diff(oldLines: string[], newLines: string[]): { type: 'same'|'add'|'remove', text: string }[] {
  const dp = lcs(oldLines, newLines);
  const result: { type: 'same'|'add'|'remove', text: string }[] = [];
  let i = oldLines.length, j = newLines.length;
  while (i > 0 || j > 0) {
    if (i > 0 && j > 0 && oldLines[i-1] === newLines[j-1]) {
      result.unshift({ type: 'same', text: oldLines[i-1] });
      i--; j--;
    } else if (j > 0 && (i === 0 || dp[i][j-1] >= dp[i-1][j])) {
      result.unshift({ type: 'add', text: newLines[j-1] });
      j--;
    } else {
      result.unshift({ type: 'remove', text: oldLines[i-1] });
      i--;
    }
  }
  return result;
}

function compare() {
  const oldText = (document.getElementById('snapshot-old') as HTMLTextAreaElement).value;
  const newText = (document.getElementById('snapshot-new') as HTMLTextAreaElement).value;

  const oldLines = oldText.split('\n');
  const newLines = newText.split('\n');

  if (oldText === newText) {
    document.getElementById('diff-result')!.classList.add('hidden');
    document.getElementById('no-diff')!.classList.remove('hidden');
    return;
  }

  document.getElementById('no-diff')!.classList.add('hidden');
  document.getElementById('diff-result')!.classList.remove('hidden');

  const changes = diff(oldLines, newLines);
  let added = 0, removed = 0;

  const html = changes.map(({ type, text }) => {
    const escaped = text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    if (type === 'add') { added++; return `<div class="flex px-4 py-0.5 bg-green-500/10 border-l-2 border-green-500"><span class="text-green-500 select-none mr-3 w-4 text-center">+</span><span class="text-green-300">${escaped}</span></div>`; }
    if (type === 'remove') { removed++; return `<div class="flex px-4 py-0.5 bg-red-500/10 border-l-2 border-red-500"><span class="text-red-500 select-none mr-3 w-4 text-center">-</span><span class="text-red-300">${escaped}</span></div>`; }
    return `<div class="flex px-4 py-0.5 text-text-muted"><span class="select-none mr-3 w-4 text-center opacity-30"> </span><span>${escaped}</span></div>`;
  }).join('');

  document.getElementById('diff-output')!.innerHTML = `<div class="py-2">${html}</div>`;
  document.getElementById('diff-stats')!.innerHTML = `
    <span class="bg-green-500/10 text-green-400 border border-green-500/20 px-2 py-0.5 rounded">+${added} added</span>
    <span class="bg-red-500/10 text-red-400 border border-red-500/20 px-2 py-0.5 rounded">-${removed} removed</span>
  `;
}

function formatJSON() {
  ['snapshot-old', 'snapshot-new'].forEach(id => {
    const el = document.getElementById(id) as HTMLTextAreaElement;
    try { el.value = JSON.stringify(JSON.parse(el.value), null, 2); } catch {}
  });
}

document.getElementById('compare-btn')!.addEventListener('click', compare);
document.getElementById('format-btn')!.addEventListener('click', () => { formatJSON(); compare(); });
document.getElementById('clear-btn')!.addEventListener('click', () => {
  (document.getElementById('snapshot-old') as HTMLTextAreaElement).value = '';
  (document.getElementById('snapshot-new') as HTMLTextAreaElement).value = '';
  document.getElementById('diff-result')!.classList.add('hidden');
  document.getElementById('no-diff')!.classList.add('hidden');
});

// Set default example values
(document.getElementById('snapshot-old') as HTMLTextAreaElement).value = JSON.stringify(JSON.parse('{"user":{"id":1,"name":"Alice","role":"admin","active":true}}'), null, 2);
(document.getElementById('snapshot-new') as HTMLTextAreaElement).value = JSON.stringify(JSON.parse('{"user":{"id":1,"name":"Alice Smith","role":"user","active":true,"createdAt":"2026-01-15"}}'), null, 2);
compare();
</script>
