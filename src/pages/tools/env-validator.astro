---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EnvValidator from '../../components/EnvValidator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What does this tool validate in a .env file?",
    answer: "The validator checks for: unquoted values containing spaces, duplicate key names, invalid characters in key names (keys must be A-Z, a-z, 0-9, underscore only), keys starting with a digit, lines missing the = sign, and the use of the export prefix (which is shell syntax, not standard .env format). Empty values are flagged as warnings."
  },
  {
    question: "Should I quote values in my .env file?",
    answer: "Quote values that contain spaces, special characters, or that could be misinterpreted by the parser. Single quotes preserve the literal value ('value with spaces'). Double quotes allow variable interpolation (\"$OTHER_VAR\"). For simple alphanumeric values and URLs, quotes are optional but recommended for clarity. Most .env parsers (dotenv, godotenv, python-dotenv) handle both quoted and unquoted values."
  },
  {
    question: "Is my .env data sent anywhere?",
    answer: "No. All parsing and validation happens entirely in your browser. Your environment variables — including any secrets, API keys, or passwords — never leave your machine and are never stored or logged anywhere."
  },
  {
    question: "Why are duplicate keys a problem?",
    answer: "Different .env parsers handle duplicates differently. Most will use the last value, but some use the first. This can cause hard-to-debug issues where the wrong value is applied depending on which library or deployment environment loads the file. Always use unique keys to avoid ambiguity."
  },
  {
    question: "What is the standard .env file format?",
    answer: "The standard .env format (popularized by dotenv) uses KEY=value pairs, one per line. Comments start with #. Values may optionally be wrapped in single or double quotes. Blank lines are ignored. Keys should be UPPER_CASE by convention (though case is technically allowed). The export prefix from shell scripts (export KEY=value) is NOT part of the standard format — remove it when using .env files with application libraries."
  },
];
---

<BaseLayout
  title="Environment Variable Validator — Check .env File for Errors & Issues"
  description="Paste your .env file and instantly check for common issues: unquoted values, duplicate keys, invalid key names, missing equals signs, and more. Free, runs 100% in your browser."
  tool=".env validator, environment variable checker, dotenv linter, .env file validator, env file checker"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Environment Variable Validator",
    "url": "https://devplaybook.cc/tools/env-validator",
    "description": "Validate .env files for common issues: duplicate keys, invalid key names, unquoted values, and more. Runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Environment Variable Validator</h1>
  <p class="text-text-muted mb-4">
    Paste your <code class="font-mono bg-surface px-1 rounded text-sm">.env</code> file content and instantly check for common issues: duplicate keys, invalid key names, unquoted values with spaces, and more. Your secrets never leave your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Duplicate key detection</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Invalid key name checks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <EnvValidator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Environment Variable Validator" relatedTags={['devops', 'environment', 'dotenv', 'configuration', 'developer-tools']} />
</BaseLayout>
