---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ColorBlindness from '../../components/ColorBlindness.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What types of color blindness are simulated?", answer: "The tool simulates: Protanopia (red-blind, ~1% of males), Deuteranopia (green-blind, ~1% of males), Tritanopia (blue-blind, rare), and Achromatopsia (total color blindness, very rare). These cover over 99% of color vision deficiency cases." },
  { question: "How does the simulation work?", answer: "The tool applies established color transformation matrices to the input color. These matrices approximate how the color would appear to someone with the corresponding color vision deficiency by shifting the RGB values." },
  { question: "Why does accessibility design need to consider color blindness?", answer: "About 8% of men and 0.5% of women have some form of color blindness. If your UI only uses color to convey information (like red=error, green=success), those users may not get the message. Always add shapes, patterns, or labels alongside color." },
  { question: "What is the most common type of color blindness?", answer: "Deuteranopia (green-blind) and protanopia (red-blind) are the most common, together affecting about 2% of males. Both cause difficulty distinguishing reds from greens." },
];
---

<BaseLayout
  title="Color Blindness Simulator — Preview Colors for Accessibility"
  description="Simulate how colors look with different types of color blindness: protanopia, deuteranopia, tritanopia, and achromatopsia. Free accessibility testing tool."
  tool="color blindness simulator, color accessibility, protanopia simulator, deuteranopia, color blind test, web accessibility colors"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Color Blindness Simulator</h1>
  <p class="text-text-muted mb-4">Preview how any color appears to people with different types of color vision deficiency. Simulates protanopia, deuteranopia, tritanopia, and achromatopsia using standard transformation matrices. Essential for accessible design.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 vision types simulated</span>
  </div>
  <ColorBlindness client:only="preact" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more free developer tools?</p>
    <a href="/tools" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Browse All Free Tools →</a>
  </div>
  <ToolPageCta currentTool="Color Blindness Simulator" relatedTags={['accessibility', 'color', 'design', 'css']} />
</BaseLayout>
