---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a shell alias?",
    answer: "A shell alias is a shortcut that maps a short name to a longer command. For example, alias k='kubectl' lets you type k instead of kubectl. Aliases are evaluated by the shell before command lookup, so they can override built-in commands and save significant typing in repetitive workflows."
  },
  {
    question: "What is the difference between bash and zsh alias syntax?",
    answer: "Bash and zsh use identical alias syntax: alias name='command'. The difference is where you put them — bash reads ~/.bashrc (interactive non-login) and ~/.bash_profile (login shells), while zsh reads ~/.zshrc. Both support the same quoting rules. zsh also supports global aliases (alias -g) that expand anywhere in a command line, not just at the start."
  },
  {
    question: "How do fish shell aliases differ from bash/zsh?",
    answer: "Fish uses a different syntax: alias name 'command' (no equals sign) or the more powerful abbr --add name command. Fish abbreviations (abbr) expand inline as you type — you see the full command before running it, which is more transparent. Fish aliases go in ~/.config/fish/config.fish or individual files in ~/.config/fish/functions/."
  },
  {
    question: "How do I make an alias permanent?",
    answer: "Add the alias definition to your shell's config file: ~/.bashrc for bash, ~/.zshrc for zsh, or ~/.config/fish/config.fish for fish. After editing, reload with source ~/.bashrc (or source ~/.zshrc). Aliases defined in the terminal without adding to the config file only last for the current session."
  },
  {
    question: "When should I use a function instead of an alias?",
    answer: "Use a function when you need to handle arguments in a complex way, use conditionals, or do more than one thing. Aliases pass all arguments verbatim to the end of the command — you cannot reference $1, $2, etc. Functions let you do: function deploy { git push && ssh server 'cd app && git pull'; }. For commands that need argument manipulation, a function is always more flexible."
  },
  {
    question: "Can I use an alias that accepts arguments?",
    answer: "Standard aliases cannot reference positional arguments. To pass arguments at a specific position you need a function. However, for simple appending use cases — like alias grep='grep --color=auto' — arguments added by the user are automatically appended after the alias expansion, so alias ls='ls -la' then typing ls /tmp works correctly."
  }
];
---

<BaseLayout
  title="Shell Alias Generator — bash, zsh, fish Alias Builder"
  description="Generate shell alias definitions for bash, zsh, and fish. Get simple aliases, function forms, and how-to-add-permanently instructions. Free browser tool."
  tool="shell alias generator, bash alias, zsh alias, fish alias, shell shortcut, terminal alias, bashrc alias"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Shell Alias Generator</h1>
  <p class="text-text-muted mb-4">Enter a long command and a short name — get ready-to-paste alias definitions for bash, zsh, and fish, plus instructions to make them permanent.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> bash / zsh / fish</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Function form with args</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Permanent install instructions</span>
  </div>

  <!-- Inputs -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Configure Alias</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium mb-1.5" for="alias-name">Alias name <span class="text-text-muted font-normal">(short)</span></label>
        <input id="alias-name" type="text" placeholder="e.g. kgp" maxlength="50"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5" for="shell-type">Shell</label>
        <select id="shell-type"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="bash">bash</option>
          <option value="zsh">zsh</option>
          <option value="fish">fish</option>
        </select>
      </div>
    </div>
    <div class="mb-4">
      <label class="block text-sm font-medium mb-1.5" for="alias-command">Command to alias <span class="text-text-muted font-normal">(full command)</span></label>
      <input id="alias-command" type="text" placeholder="e.g. kubectl get pods -n production"
        class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
    </div>
    <div class="flex flex-wrap gap-2">
      <span class="text-xs text-text-muted self-center">Examples:</span>
      <button class="example-btn px-2.5 py-1 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors text-text-muted"
        data-name="kgp" data-cmd="kubectl get pods -n production">kubectl get pods</button>
      <button class="example-btn px-2.5 py-1 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors text-text-muted"
        data-name="gs" data-cmd="git status">git status</button>
      <button class="example-btn px-2.5 py-1 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors text-text-muted"
        data-name="dps" data-cmd="docker ps --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}'">docker ps</button>
      <button class="example-btn px-2.5 py-1 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors text-text-muted"
        data-name="ll" data-cmd="ls -lahF --color=auto">ls -lahF</button>
      <button class="example-btn px-2.5 py-1 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors text-text-muted"
        data-name="py" data-cmd="python3">python3</button>
    </div>
  </div>

  <!-- Output -->
  <div id="output-section" class="hidden">

    <!-- Simple alias -->
    <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-base font-semibold">Simple Alias</h2>
        <button id="copy-simple" class="text-xs px-3 py-1.5 bg-bg-card border border-border rounded-lg hover:border-primary text-text-muted hover:text-primary transition-colors">Copy</button>
      </div>
      <pre id="out-simple" class="bg-bg-card border border-border rounded-lg p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text leading-relaxed"></pre>
    </div>

    <!-- Function form -->
    <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
      <div class="flex items-center justify-between mb-1">
        <h2 class="text-base font-semibold">Function Form <span class="text-text-muted text-sm font-normal">(with argument support)</span></h2>
        <button id="copy-fn" class="text-xs px-3 py-1.5 bg-bg-card border border-border rounded-lg hover:border-primary text-text-muted hover:text-primary transition-colors">Copy</button>
      </div>
      <p class="text-xs text-text-muted mb-3">Accepts extra arguments — type <code class="font-mono bg-bg-card px-1 rounded" id="fn-example-call"></code> to pass additional flags.</p>
      <pre id="out-fn" class="bg-bg-card border border-border rounded-lg p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text leading-relaxed"></pre>
    </div>

    <!-- Install instructions -->
    <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-base font-semibold">Make It Permanent</h2>
        <button id="copy-install" class="text-xs px-3 py-1.5 bg-bg-card border border-border rounded-lg hover:border-primary text-text-muted hover:text-primary transition-colors">Copy</button>
      </div>
      <pre id="out-install" class="bg-bg-card border border-border rounded-lg p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text leading-relaxed"></pre>
    </div>

    <!-- Fish abbr bonus -->
    <div id="fish-abbr-section" class="hidden bg-bg-card border border-border rounded-xl p-5 mb-5">
      <div class="flex items-center justify-between mb-1">
        <h2 class="text-base font-semibold">Fish Abbreviation <span class="text-xs text-primary font-normal ml-1">recommended</span></h2>
        <button id="copy-abbr" class="text-xs px-3 py-1.5 bg-bg-card border border-border rounded-lg hover:border-primary text-text-muted hover:text-primary transition-colors">Copy</button>
      </div>
      <p class="text-xs text-text-muted mb-3">Abbreviations expand inline as you type — you see the full command before pressing Enter.</p>
      <pre id="out-abbr" class="bg-bg-card border border-border rounded-lg p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text leading-relaxed"></pre>
    </div>

  </div>

  <!-- Validation message -->
  <div id="validation-msg" class="hidden bg-yellow-400/10 border border-yellow-400/30 rounded-xl p-4 mb-5 text-sm text-yellow-300"></div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Shell Alias Generator" relatedTags={['shell', 'bash', 'zsh', 'terminal', 'productivity', 'linux', 'devops']} />
</BaseLayout>

<script>
  function escapeForSingleQuote(cmd) {
    // In single-quoted strings, single quotes must be escaped as: '\''
    return cmd.replace(/'/g, "'\\''");
  }

  function isValidAliasName(name) {
    return /^[a-zA-Z_][a-zA-Z0-9_-]*$/.test(name);
  }

  function generate() {
    var name = (document.getElementById('alias-name') as HTMLInputElement).value.trim();
    var cmd = (document.getElementById('alias-command') as HTMLInputElement).value.trim();
    var shell = (document.getElementById('shell-type') as HTMLSelectElement).value;

    var validMsg = document.getElementById('validation-msg');
    var outSection = document.getElementById('output-section');

    if (!name || !cmd) {
      validMsg.classList.add('hidden');
      outSection.classList.add('hidden');
      return;
    }

    if (!isValidAliasName(name)) {
      validMsg.textContent = 'Alias name must start with a letter or underscore and contain only letters, numbers, underscores, and hyphens.';
      validMsg.classList.remove('hidden');
      outSection.classList.add('hidden');
      return;
    }

    validMsg.classList.add('hidden');
    outSection.classList.remove('hidden');

    var simpleEl = document.getElementById('out-simple');
    var fnEl = document.getElementById('out-fn');
    var installEl = document.getElementById('out-install');
    var abbrSection = document.getElementById('fish-abbr-section');
    var abbrEl = document.getElementById('out-abbr');
    var fnExampleCall = document.getElementById('fn-example-call');

    if (shell === 'fish') {
      // Fish alias
      simpleEl.textContent = 'alias ' + name + " '" + escapeForSingleQuote(cmd) + "'";

      // Fish function
      fnEl.textContent = 'function ' + name + "\n  " + cmd + " $argv\nend";

      // Fish install
      installEl.textContent = '# Add to ~/.config/fish/config.fish:\nalias ' + name + " '" + escapeForSingleQuote(cmd) + "'\n\n# Or save as a function file (auto-loaded):\nmkdir -p ~/.config/fish/functions\necho 'function " + name + "\n  " + cmd + ' $argv\nend\' > ~/.config/fish/functions/' + name + ".fish";

      // Fish abbr
      abbrSection.classList.remove('hidden');
      abbrEl.textContent = '# Add abbreviation (expands inline as you type):\nabbr --add ' + name + " '" + escapeForSingleQuote(cmd) + "'\n\n# To make it permanent, add to ~/.config/fish/config.fish:\nabbr --add " + name + " '" + escapeForSingleQuote(cmd) + "'";

      fnExampleCall.textContent = name + ' --extra-flag';

    } else {
      // bash / zsh — same syntax
      var escapedCmd = escapeForSingleQuote(cmd);
      simpleEl.textContent = "alias " + name + "='" + escapedCmd + "'";

      // Function form
      fnEl.textContent = name + "() {\n  " + cmd + ' "$@"\n}';

      // Config file path
      var rcFile = shell === 'zsh' ? '~/.zshrc' : '~/.bashrc';
      var reloadCmd = shell === 'zsh' ? 'source ~/.zshrc' : 'source ~/.bashrc';

      installEl.textContent = '# 1. Open your shell config:\nnano ' + rcFile + '\n\n# 2. Add this line at the end:\nalias ' + name + "='" + escapedCmd + "'\n\n# 3. Reload config in current session:\n" + reloadCmd + '\n\n# 4. Verify:\ntype ' + name;

      abbrSection.classList.add('hidden');
      fnExampleCall.textContent = name + ' --extra-flag';
    }
  }

  function copyText(elementId, buttonId) {
    var el = document.getElementById(elementId);
    var btn = document.getElementById(buttonId);
    if (!el || !btn) return;
    navigator.clipboard.writeText(el.textContent || '').then(function() {
      var orig = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(function() { btn.textContent = orig; }, 1500);
    });
  }

  document.getElementById('alias-name').addEventListener('input', generate);
  document.getElementById('alias-command').addEventListener('input', generate);
  document.getElementById('shell-type').addEventListener('change', generate);

  document.getElementById('copy-simple').addEventListener('click', function() { copyText('out-simple', 'copy-simple'); });
  document.getElementById('copy-fn').addEventListener('click', function() { copyText('out-fn', 'copy-fn'); });
  document.getElementById('copy-install').addEventListener('click', function() { copyText('out-install', 'copy-install'); });
  document.getElementById('copy-abbr').addEventListener('click', function() { copyText('out-abbr', 'copy-abbr'); });

  document.querySelectorAll('.example-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var name = btn.getAttribute('data-name');
      var cmd = btn.getAttribute('data-cmd');
      (document.getElementById('alias-name') as HTMLInputElement).value = name;
      (document.getElementById('alias-command') as HTMLInputElement).value = cmd;
      generate();
    });
  });
</script>
