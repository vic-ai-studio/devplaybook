---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the difference between preload and prefetch?", answer: "preload fetches a resource needed for the current page with high priority — use it for fonts, hero images, and critical scripts that are discovered late. prefetch fetches a resource likely needed for the next navigation with low priority — use it for assets of the next page in a user journey. preload improves current page performance; prefetch improves future page performance. Preloaded resources that aren't used within a few seconds trigger a browser warning." },
  { question: "What does preconnect do and when should I use it?", answer: "preconnect establishes a TCP connection, TLS handshake, and DNS lookup to an origin in advance, saving 100–500ms of latency when that origin is first requested. Use it for critical third-party origins you know will be needed soon (CDN, Google Fonts, analytics). Limit to 2–3 preconnects — each one reserves a socket and consumes resources. For origins you're less certain about, use dns-prefetch instead (DNS only, cheaper)." },
  { question: "What is modulepreload and how is it different from preload?", answer: "modulepreload is purpose-built for ES modules. Unlike preload (which fetches and stores), modulepreload also parses the module, compiles the JavaScript, and registers it in the module map — so when the module is imported, it's instantly available with zero parsing overhead. Use modulepreload for your main JS entry points (app.js, chunks). It's supported in all modern browsers. Regular preload with as=script doesn't give the same compile-time benefit for modules." },
  { question: "What is the 'as' attribute and why does it matter for preload?", answer: "The as attribute tells the browser what type of resource is being preloaded, which affects request priority, cache matching, and Content Security Policy enforcement. Without it, the browser fetches with lowest priority. Values: script, style, font, image, fetch, document, track, worker. For fonts, always include crossorigin='anonymous' — even same-origin fonts need it because fonts use CORS. Missing crossorigin causes a double download." },
  { question: "How do I use resource hints in HTTP headers vs HTML?", answer: "Resource hints work in both HTML link tags and HTTP Link response headers. HTTP Link headers have a slight advantage: they're processed before HTML parsing begins, giving a tiny head start. Use HTTP headers for preconnect and preload on the initial HTML document. Example: Link: </fonts/myfont.woff2>; rel=preload; as=font; crossorigin. Most CDNs and servers (Nginx, Cloudflare, Vercel) support Link headers via config or response headers." },
];
---

<BaseLayout
  title="Resource Hints Generator — preload, prefetch, preconnect HTML & HTTP Headers"
  description="Generate HTML link tags and HTTP Link headers for preload, prefetch, preconnect, dns-prefetch, and modulepreload. Add resources, set types, and copy the output instantly."
  tool="resource hints generator, preload prefetch preconnect generator, HTML link tag generator, HTTP Link header builder, modulepreload dns-prefetch tool"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Resource Hints Generator",
    "url": "https://devplaybook.cc/tools/resource-hints-generator",
    "description": "Build HTML link tags and HTTP Link headers for preload, prefetch, preconnect, dns-prefetch, and modulepreload hints.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Resource Hints Generator</h1>
  <p class="text-text-muted mb-4">Add URLs, choose hint types and resource types, then copy the generated HTML link tags or HTTP Link response headers. Supports preload, prefetch, preconnect, dns-prefetch, and modulepreload.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> HTML link tags</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> HTTP Link headers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CORS / as attribute</span>
  </div>

  <div class="space-y-5">
    <!-- Add resource form -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="font-semibold mb-4">Add Resource</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-sm font-medium text-text-muted mb-1" for="rh-url">Resource URL</label>
          <input id="rh-url" type="text"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40"
            placeholder="/fonts/inter.woff2" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-1" for="rh-hint">Hint Type</label>
          <select id="rh-hint" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40">
            <option value="preload">preload</option>
            <option value="prefetch">prefetch</option>
            <option value="preconnect">preconnect</option>
            <option value="dns-prefetch">dns-prefetch</option>
            <option value="modulepreload">modulepreload</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-1" for="rh-as">As Type (for preload/modulepreload)</label>
          <select id="rh-as" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40">
            <option value="">— none —</option>
            <option value="script">script</option>
            <option value="style">style</option>
            <option value="font">font</option>
            <option value="image">image</option>
            <option value="fetch">fetch</option>
            <option value="document">document</option>
            <option value="track">track</option>
            <option value="worker">worker</option>
          </select>
        </div>
        <div class="flex items-end">
          <label class="flex items-center gap-2 cursor-pointer">
            <input id="rh-cors" type="checkbox" class="rounded" />
            <span class="text-sm text-text-muted">Add <code class="text-primary">crossorigin</code> (required for fonts)</span>
          </label>
        </div>
      </div>

      <div class="flex gap-2 flex-wrap">
        <button id="rh-add-btn" class="bg-primary text-white px-5 py-2 rounded-lg font-semibold hover:bg-primary/80 transition-colors text-sm">
          Add Resource
        </button>
        <button id="rh-clear-btn" class="bg-bg border border-border text-text-muted px-4 py-2 rounded-lg text-sm hover:border-primary/40 transition-colors">
          Clear All
        </button>
      </div>

      <!-- Quick presets -->
      <div class="mt-4">
        <div class="text-xs text-text-muted mb-2 font-medium uppercase tracking-wide">Quick Add Presets</div>
        <div class="flex flex-wrap gap-2" id="rh-presets"></div>
      </div>
    </div>

    <!-- Resource list -->
    <div id="rh-list-section" class="hidden bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="font-semibold">Resources (<span id="rh-count">0</span>)</h2>
      </div>
      <div id="rh-list" class="space-y-2"></div>
    </div>

    <!-- Output -->
    <div id="rh-output-section" class="hidden space-y-4">
      <!-- HTML output -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-semibold">HTML Link Tags</h2>
          <button id="copy-html-btn" class="text-xs text-primary hover:text-primary/80 border border-primary/30 px-3 py-1 rounded-lg transition-colors">Copy</button>
        </div>
        <pre id="rh-html-output" class="bg-bg rounded-lg p-4 text-sm font-mono text-text-muted overflow-x-auto whitespace-pre-wrap break-all"></pre>
      </div>

      <!-- HTTP header output -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-semibold">HTTP Link Headers</h2>
          <button id="copy-http-btn" class="text-xs text-primary hover:text-primary/80 border border-primary/30 px-3 py-1 rounded-lg transition-colors">Copy</button>
        </div>
        <pre id="rh-http-output" class="bg-bg rounded-lg p-4 text-sm font-mono text-text-muted overflow-x-auto whitespace-pre-wrap break-all"></pre>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Resource Hints Generator" relatedTags={['performance', 'preload', 'prefetch', 'preconnect', 'web-vitals', 'html']} />
</BaseLayout>

<script is:inline>
(function () {
  var resources = [];

  var PRESETS = [
    { label: 'Google Fonts origin', url: 'https://fonts.googleapis.com', hint: 'preconnect', as: '', cors: false },
    { label: 'Google Fonts static', url: 'https://fonts.gstatic.com', hint: 'preconnect', as: '', cors: true },
    { label: 'Hero image', url: '/images/hero.webp', hint: 'preload', as: 'image', cors: false },
    { label: 'Main font', url: '/fonts/inter.woff2', hint: 'preload', as: 'font', cors: true },
    { label: 'App JS module', url: '/js/app.js', hint: 'modulepreload', as: '', cors: false },
    { label: 'Critical CSS', url: '/css/critical.css', hint: 'preload', as: 'style', cors: false },
    { label: 'Analytics', url: 'https://www.googletagmanager.com', hint: 'dns-prefetch', as: '', cors: false },
  ];

  var presetsEl = document.getElementById('rh-presets');
  PRESETS.forEach(function (p) {
    var btn = document.createElement('button');
    btn.className = 'px-3 py-1 text-xs rounded-lg border border-border bg-bg hover:bg-primary/10 hover:border-primary/40 transition-colors';
    btn.textContent = p.label;
    btn.addEventListener('click', function () {
      document.getElementById('rh-url').value = p.url;
      document.getElementById('rh-hint').value = p.hint;
      document.getElementById('rh-as').value = p.as;
      document.getElementById('rh-cors').checked = p.cors;
    });
    presetsEl.appendChild(btn);
  });

  function buildHtmlTag(r) {
    var attrs = 'rel="' + r.hint + '" href="' + r.url + '"';
    if (r.as) attrs += ' as="' + r.as + '"';
    if (r.cors) attrs += ' crossorigin';
    return '<link ' + attrs + '>';
  }

  function buildHttpHeader(r) {
    var val = '<' + r.url + '>; rel=' + r.hint;
    if (r.as) val += '; as=' + r.as;
    if (r.cors) val += '; crossorigin';
    return 'Link: ' + val;
  }

  function render() {
    var listSection = document.getElementById('rh-list-section');
    var outputSection = document.getElementById('rh-output-section');

    if (resources.length === 0) {
      listSection.classList.add('hidden');
      outputSection.classList.add('hidden');
      return;
    }

    listSection.classList.remove('hidden');
    outputSection.classList.remove('hidden');

    document.getElementById('rh-count').textContent = resources.length;

    var list = document.getElementById('rh-list');
    list.innerHTML = '';
    resources.forEach(function (r, i) {
      var row = document.createElement('div');
      row.className = 'flex items-center justify-between gap-3 p-3 bg-bg rounded-lg border border-border';
      row.innerHTML = '<div class="flex-1 min-w-0">'
        + '<div class="text-sm font-mono text-text-muted truncate">' + r.url + '</div>'
        + '<div class="text-xs mt-0.5 flex gap-2">'
        + '<span class="text-primary">' + r.hint + '</span>'
        + (r.as ? '<span class="text-text-muted">as=' + r.as + '</span>' : '')
        + (r.cors ? '<span class="text-yellow-400">crossorigin</span>' : '')
        + '</div>'
        + '</div>'
        + '<button data-idx="' + i + '" class="rh-remove text-red-400 hover:text-red-300 text-xs px-2 py-1 rounded transition-colors shrink-0">Remove</button>';
      list.appendChild(row);
    });

    list.querySelectorAll('.rh-remove').forEach(function (btn) {
      btn.addEventListener('click', function () {
        resources.splice(parseInt(btn.dataset.idx), 1);
        render();
      });
    });

    var htmlLines = resources.map(buildHtmlTag).join('\n');
    var httpLines = resources.map(buildHttpHeader).join('\n');

    document.getElementById('rh-html-output').textContent = htmlLines;
    document.getElementById('rh-http-output').textContent = httpLines;
  }

  document.getElementById('rh-add-btn').addEventListener('click', function () {
    var url = document.getElementById('rh-url').value.trim();
    if (!url) { alert('Please enter a resource URL.'); return; }
    resources.push({
      url: url,
      hint: document.getElementById('rh-hint').value,
      as: document.getElementById('rh-as').value,
      cors: document.getElementById('rh-cors').checked,
    });
    document.getElementById('rh-url').value = '';
    document.getElementById('rh-cors').checked = false;
    render();
  });

  document.getElementById('rh-clear-btn').addEventListener('click', function () {
    resources = [];
    render();
  });

  function makeCopyBtn(btnId, outputId) {
    document.getElementById(btnId).addEventListener('click', function () {
      var text = document.getElementById(outputId).textContent;
      navigator.clipboard.writeText(text).then(function () {
        var btn = document.getElementById(btnId);
        btn.textContent = 'Copied!';
        setTimeout(function () { btn.textContent = 'Copy'; }, 2000);
      });
    });
  }

  makeCopyBtn('copy-html-btn', 'rh-html-output');
  makeCopyBtn('copy-http-btn', 'rh-http-output');

  // Load example
  [
    { url: '/fonts/inter.woff2', hint: 'preload', as: 'font', cors: true },
    { url: 'https://fonts.gstatic.com', hint: 'preconnect', as: '', cors: true },
    { url: '/js/app.js', hint: 'modulepreload', as: '', cors: false },
  ].forEach(function (r) { resources.push(r); });
  render();
})();
</script>
