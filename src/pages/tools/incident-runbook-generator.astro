---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Incident Runbook Generator — On-Call Runbook Template Builder"
  description="Generate structured incident runbooks for on-call engineers. Define service name, severity, symptoms, triage steps, escalation path, and rollback procedures. Export as Markdown."
  tool="incident runbook generator, on-call runbook, incident response template, SRE runbook, postmortem template"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Incident Runbook Generator",
    "url": "https://devplaybook.cc/tools/incident-runbook-generator",
    "description": "Generate structured incident runbooks for on-call engineers. Define service name, severity, symptoms, triage steps, escalation path, and rollback procedures. Export as Markdown.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Incident Runbook Generator</h1>
  <p class="text-text-muted mb-4">
    Build structured on-call runbooks in seconds. Fill in service details, symptoms, triage steps, and escalation paths — get a professional Markdown runbook ready to commit to your repo or wiki.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> SEV1–SEV4 severity levels</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Markdown output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Rollback command + postmortem checklist</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <!-- Form -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
    <div>
      <label class="block text-sm font-medium mb-2" for="rb-service">Service Name</label>
      <input id="rb-service" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="e.g. payments-api" />
    </div>
    <div>
      <label class="block text-sm font-medium mb-2" for="rb-author">Runbook Author</label>
      <input id="rb-author" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="e.g. Platform Team" />
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4">
    <div>
      <label class="block text-sm font-medium mb-2" for="rb-severity">Severity Level</label>
      <select id="rb-severity" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
        <option value="SEV1 — Critical">SEV1 — Critical</option>
        <option value="SEV2 — High" selected>SEV2 — High</option>
        <option value="SEV3 — Medium">SEV3 — Medium</option>
        <option value="SEV4 — Low">SEV4 — Low</option>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium mb-2" for="rb-service-type">Service Type</label>
      <select id="rb-service-type" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
        <option value="Web API">Web API</option>
        <option value="Database">Database</option>
        <option value="Message Queue">Message Queue</option>
        <option value="Cache">Cache</option>
        <option value="CDN">CDN</option>
        <option value="Microservice">Microservice</option>
        <option value="Batch Job">Batch Job</option>
        <option value="Other">Other</option>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium mb-2" for="rb-updated">Last Updated</label>
      <input id="rb-updated" type="date" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
    </div>
  </div>

  <div class="mb-4">
    <label class="block text-sm font-medium mb-2" for="rb-symptoms">Typical Symptoms <span class="text-text-muted font-normal">(one per line)</span></label>
    <textarea id="rb-symptoms" rows="4" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary resize-none" placeholder="e.g. Error rate above 5%&#10;P95 latency above 2s&#10;Health check endpoint returning 503&#10;PagerDuty alert fired"></textarea>
  </div>

  <div class="mb-4">
    <label class="block text-sm font-medium mb-2" for="rb-triage">Initial Triage Steps <span class="text-text-muted font-normal">(one per line)</span></label>
    <textarea id="rb-triage" rows="5" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary resize-none" placeholder="e.g. Check service health dashboard&#10;Review error logs in Datadog&#10;Check recent deployments&#10;Verify upstream dependencies&#10;Check database connection pool"></textarea>
  </div>

  <div class="mb-4">
    <label class="block text-sm font-medium mb-2" for="rb-metrics">Key Metrics &amp; Dashboards to Check</label>
    <textarea id="rb-metrics" rows="3" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary resize-none" placeholder="e.g. Error rate (Datadog: payments-api.error_rate)&#10;Latency P95 (Grafana: payments-latency dashboard)&#10;DB connection count (CloudWatch: RDS/DatabaseConnections)"></textarea>
  </div>

  <div class="mb-4">
    <label class="block text-sm font-medium mb-2" for="rb-escalation">Escalation Path</label>
    <input id="rb-escalation" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="e.g. L1 Oncall → L2 Platform Team → VP Engineering" />
  </div>

  <div class="mb-6">
    <label class="block text-sm font-medium mb-2" for="rb-rollback">Rollback Command <span class="text-text-muted font-normal">(optional)</span></label>
    <input id="rb-rollback" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="e.g. kubectl rollout undo deployment/payments-api -n production" />
  </div>

  <div class="flex gap-3 mb-6 flex-wrap">
    <button id="btn-generate" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Generate Runbook</button>
    <button id="btn-web-api" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Web API Example</button>
    <button id="btn-database" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Database Example</button>
  </div>

  <!-- Output -->
  <div id="output-section" class="hidden">
    <div class="flex items-center justify-between mb-3">
      <span class="text-sm font-medium">Markdown Runbook</span>
      <div class="flex gap-2">
        <button id="btn-copy" class="px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">Copy Markdown</button>
        <button id="btn-download" class="px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">Download .md</button>
      </div>
    </div>
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <pre id="output-md" class="font-mono text-sm whitespace-pre-wrap break-words overflow-x-auto max-h-[600px] overflow-y-auto text-green-300"></pre>
    </div>
  </div>

  <ToolPageCta />
</BaseLayout>

<script is:inline>
  // Set today's date as default
  (function() {
    const d = new Date();
    const iso = d.toISOString().split('T')[0];
    document.getElementById('rb-updated').value = iso;
  })();

  function lines(text) {
    return text.split('\n').map(l => l.trim()).filter(Boolean);
  }

  function buildRunbook() {
    const service   = document.getElementById('rb-service').value.trim() || 'my-service';
    const author    = document.getElementById('rb-author').value.trim() || 'On-Call Team';
    const severity  = document.getElementById('rb-severity').value;
    const svcType   = document.getElementById('rb-service-type').value;
    const updated   = document.getElementById('rb-updated').value || new Date().toISOString().split('T')[0];
    const symptoms  = lines(document.getElementById('rb-symptoms').value);
    const triage    = lines(document.getElementById('rb-triage').value);
    const metrics   = document.getElementById('rb-metrics').value.trim();
    const escalation = document.getElementById('rb-escalation').value.trim() || 'L1 Oncall → L2 Platform Team → VP Engineering';
    const rollback  = document.getElementById('rb-rollback').value.trim();

    const sevCode = severity.split(' ')[0]; // e.g. "SEV2"
    const sevLabel = severity;

    const symptomsBlock = symptoms.length
      ? symptoms.map(s => `- ${s}`).join('\n')
      : '- (No symptoms defined)';

    const triageBlock = triage.length
      ? triage.map((s, i) => `${i + 1}. ${s}`).join('\n')
      : '1. (No triage steps defined)';

    const metricsBlock = metrics
      ? metrics.split('\n').map(l => l.trim()).filter(Boolean).map(l => `- ${l}`).join('\n')
      : '- (No metrics defined)';

    const rollbackBlock = rollback
      ? `## Rollback Procedure\n\n\`\`\`bash\n${rollback}\n\`\`\``
      : `## Rollback Procedure\n\n> No rollback command defined. Coordinate with engineering lead for manual rollback steps.`;

    const sevEmoji = sevCode === 'SEV1' ? '🔴' : sevCode === 'SEV2' ? '🟠' : sevCode === 'SEV3' ? '🟡' : '🟢';

    const md = `# Runbook: ${service} — ${sevLabel} Incident

**Service:** ${service}
**Service Type:** ${svcType}
**Severity:** ${sevEmoji} ${sevLabel}
**Author:** ${author}
**Last Updated:** ${updated}

---

## Overview

This runbook covers on-call response for **${service}** incidents classified as **${sevLabel}**.
Follow the triage steps in order. Escalate if not resolved within the time window for this severity.

| Severity | Response SLA | Escalate After |
|----------|-------------|----------------|
| SEV1 — Critical | Acknowledge in 5 min | 15 min |
| SEV2 — High | Acknowledge in 15 min | 30 min |
| SEV3 — Medium | Acknowledge in 30 min | 2 hours |
| SEV4 — Low | Acknowledge in 2 hours | Next business day |

---

## Symptoms

${symptomsBlock}

---

## Initial Triage (First 5 Minutes)

${triageBlock}

---

## Key Metrics & Dashboards

${metricsBlock}

---

## Escalation Path

\`\`\`
${escalation}
\`\`\`

**When to escalate:** If the incident is not mitigated within the SLA window above, or if the blast radius is expanding.

---

${rollbackBlock}

---

## Communication Template

\`\`\`
[INCIDENT] ${service} — ${sevLabel}
Status: INVESTIGATING
Impact: <describe user impact>
Started: <timestamp>
On-call: <your name>
Updates: every 15 min
\`\`\`

---

## Post-Incident Actions

- [ ] Write postmortem within 48 hours
- [ ] Update this runbook with new findings
- [ ] Review and tune monitoring thresholds
- [ ] File follow-up tickets for root cause fixes
- [ ] Share learnings with the team
- [ ] Update incident timeline in incident tracker

---

*Runbook generated by [DevPlaybook Incident Runbook Generator](https://devplaybook.cc/tools/incident-runbook-generator)*
`;
    return md;
  }

  function loadExample(type) {
    if (type === 'web-api') {
      document.getElementById('rb-service').value = 'payments-api';
      document.getElementById('rb-author').value = 'Platform SRE Team';
      document.getElementById('rb-severity').value = 'SEV2 — High';
      document.getElementById('rb-service-type').value = 'Web API';
      document.getElementById('rb-symptoms').value = 'Error rate above 5% (baseline: <0.1%)\nP95 latency above 2000ms (baseline: 200ms)\nHealth check endpoint /health returning 503\nPagerDuty alert: payments-api-high-error-rate fired\nCustomer reports of checkout failures';
      document.getElementById('rb-triage').value = 'Check service health at https://dashboard.internal/payments-api\nReview error logs: kubectl logs -n production deploy/payments-api --since=15m\nCheck recent deployments: kubectl rollout history deploy/payments-api -n production\nVerify upstream dependency: curl https://stripe.com/healthcheck\nCheck DB connection pool: SELECT count(*) FROM pg_stat_activity WHERE datname=\'payments\'\nReview CPU and memory metrics in Datadog';
      document.getElementById('rb-metrics').value = 'Error rate — Datadog: payments-api.request.error_rate (threshold: >2%)\nP95 Latency — Grafana: payments-latency dashboard > API Response Times\nDB Connections — CloudWatch: RDS/payments-db/DatabaseConnections\nQueue depth — SQS: payment-events-queue / ApproximateNumberOfMessagesVisible\nPod restarts — kubectl get pods -n production | grep payments';
      document.getElementById('rb-escalation').value = 'L1 Oncall → L2 Platform Team (#platform-oncall) → VP Engineering';
      document.getElementById('rb-rollback').value = 'kubectl rollout undo deployment/payments-api -n production && kubectl rollout status deployment/payments-api -n production';
    } else {
      document.getElementById('rb-service').value = 'postgres-primary';
      document.getElementById('rb-author').value = 'Database SRE Team';
      document.getElementById('rb-severity').value = 'SEV1 — Critical';
      document.getElementById('rb-service-type').value = 'Database';
      document.getElementById('rb-symptoms').value = 'PostgreSQL primary is unreachable\nConnection timeout errors from all application services\nReplication lag above 60 seconds on replica\nDisk usage above 95% on data volume\nDeadlock rate spike in pg_stat_activity';
      document.getElementById('rb-triage').value = 'Check DB status: pg_isready -h postgres-primary.internal -U app\nReview PostgreSQL logs: tail -n 200 /var/log/postgresql/postgresql-main.log\nCheck active connections: SELECT count(*), state FROM pg_stat_activity GROUP BY state\nCheck disk usage: df -h /var/lib/postgresql\nCheck replication: SELECT * FROM pg_stat_replication\nCheck for long-running queries: SELECT pid, now()-query_start, query FROM pg_stat_activity WHERE state=\'active\' ORDER BY 2 DESC LIMIT 10\nAttempt failover to replica if primary unrecoverable';
      document.getElementById('rb-metrics').value = 'Active connections — Datadog: postgresql.connections (alert: >400)\nReplication lag — Datadog: postgresql.replication.delay (alert: >30s)\nDisk usage — CloudWatch: RDS/FreeStorageSpace (alert: <10%)\nTransaction rate — Grafana: postgres-performance > TPS panel\nCache hit ratio — Datadog: postgresql.cache.hit_ratio (warn: <0.95)';
      document.getElementById('rb-escalation').value = 'L1 Oncall → L2 Database SRE (#db-oncall) → Database Lead → CTO';
      document.getElementById('rb-rollback').value = 'pg_ctl promote -D /var/lib/postgresql/data  # promote replica to primary';
    }
  }

  document.getElementById('btn-generate').addEventListener('click', function() {
    const md = buildRunbook();
    document.getElementById('output-md').textContent = md;
    document.getElementById('output-section').classList.remove('hidden');
    document.getElementById('output-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  document.getElementById('btn-web-api').addEventListener('click', function() {
    loadExample('web-api');
  });

  document.getElementById('btn-database').addEventListener('click', function() {
    loadExample('database');
  });

  document.getElementById('btn-copy').addEventListener('click', function() {
    const text = document.getElementById('output-md').textContent;
    navigator.clipboard.writeText(text).then(function() {
      const btn = document.getElementById('btn-copy');
      btn.textContent = 'Copied!';
      setTimeout(function() { btn.textContent = 'Copy Markdown'; }, 2000);
    });
  });

  document.getElementById('btn-download').addEventListener('click', function() {
    const text = document.getElementById('output-md').textContent;
    const service = (document.getElementById('rb-service').value.trim() || 'runbook').replace(/\s+/g, '-').toLowerCase();
    const blob = new Blob([text], { type: 'text/markdown' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'runbook-' + service + '.md';
    a.click();
    URL.revokeObjectURL(url);
  });
</script>
