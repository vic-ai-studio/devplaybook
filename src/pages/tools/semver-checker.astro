---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SemverChecker from '../../components/SemverChecker.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Semver Checker — Semantic Version Range Validator"
  description="Parse, compare, and check semantic version ranges. Verify ^, ~, >=, <=, > and < constraints. Bump major, minor, or patch versions. All client-side, no signup."
  tool="Semver Checker, Semantic Version, Version Range, NPM Version Checker"
>
  <h1 class="text-3xl font-bold mb-2">Semver Checker</h1>
  <p class="text-text-muted mb-8">Compare two semantic versions, check if a version satisfies a range constraint (^, ~, >=, &lt;), or calculate the next major/minor/patch bump. Follows the semver 2.0.0 spec.</p>
  <SemverChecker client:only="preact" />
  <ToolPageCta currentTool="Semver Checker" relatedTags={['semver', 'npm', 'versioning', 'devops', 'package']} />
</BaseLayout>
