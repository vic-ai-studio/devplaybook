---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BcryptHashGenerator from '../../components/BcryptHashGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is bcrypt and why is it used for passwords?", answer: "bcrypt is a password-hashing function designed in 1999 by Niels Provos and David Mazières. Unlike SHA-256 or MD5, bcrypt is intentionally slow and includes a cost factor that controls how many iterations to run. This makes brute-force attacks computationally expensive. bcrypt also automatically salts every hash, preventing rainbow table attacks." },
  { question: "What is the cost factor in bcrypt?", answer: "The cost factor (also called work factor) is a power of 2 that controls how many iterations bcrypt runs. Cost 12 means 2^12 = 4,096 iterations. Cost 13 means 8,192 iterations. Higher cost = slower hash = harder to crack. The default of 12 is currently recommended for most applications. As hardware gets faster, you should increase the cost factor over time." },
  { question: "What does the bcrypt hash format look like?", answer: "A bcrypt hash looks like: $2b$12$<salt><hash>. The $2b$ is the algorithm version (2b is standard), 12 is the cost factor, the next 22 characters are a base64-encoded random salt, and the final 31 characters are the hashed output. The full hash is always 60 characters." },
  { question: "Can I verify a password against a bcrypt hash without knowing the salt?", answer: "Yes — that's the beauty of bcrypt. The salt is embedded directly in the hash string. When verifying, bcrypt extracts the salt from the stored hash and re-hashes the candidate password with the same salt and cost factor. If the results match, the password is correct. You never need to store the salt separately." },
  { question: "Is bcrypt still safe in 2024?", answer: "bcrypt is still widely considered safe for password hashing. However, security researchers now recommend Argon2id (the 2015 Password Hashing Competition winner) for new applications, because Argon2 is more resistant to GPU-based attacks (due to memory-hardness). If you're starting a new project, prefer Argon2id. For existing bcrypt systems, continue using it — bcrypt is not broken." },
];
---

<BaseLayout
  title="Bcrypt Hash Generator — Generate & Verify bcrypt Passwords Online"
  description="Generate bcrypt password hashes with a custom cost factor and verify passwords against existing bcrypt hashes. Shows hash breakdown (version, cost, salt, hash). Runs entirely in your browser using bcryptjs."
  tool="Bcrypt Hash Generator, bcrypt password hash, bcrypt verify, password hashing online"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Bcrypt Hash Generator",
    "url": "https://devplaybook.cc/tools/bcrypt-hash-generator",
    "description": "Generate and verify bcrypt password hashes in your browser. Supports custom cost factors from 4 to 31, verify mode, and hash breakdown.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Bcrypt Hash Generator</h1>
  <p class="text-text-muted mb-4">Generate bcrypt password hashes with a configurable cost factor, or verify a password against an existing hash. Shows the full hash breakdown. Runs entirely in your browser using <a href="https://github.com/dcodeIO/bcrypt.js" target="_blank" rel="noopener" class="text-accent hover:underline">bcryptjs</a>.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100% browser — no server calls</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Adjustable cost factor (4–31)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Generate & verify mode</span>
  </div>
  <BcryptHashGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Bcrypt Hash Generator" relatedTags={['security', 'hashing', 'password', 'encryption', 'authentication']} />
</BaseLayout>
