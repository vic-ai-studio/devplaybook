---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GrpcProtoLinter from '../../components/GrpcProtoLinter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the difference between a proto linter and a proto validator?",
    answer: "A validator checks that your .proto file is structurally correct — required fields, valid syntax, no duplicate field numbers. A linter checks code style, naming conventions, and best practices — things that compile fine but may cause issues with SDK generation, readability, or cross-team consistency. This linter focuses on style and conventions."
  },
  {
    question: "What naming conventions does this linter enforce?",
    answer: "Following Google's Protocol Buffer Style Guide: service and message names must be PascalCase (e.g. UserService, GetUserRequest), RPC method names must be PascalCase (e.g. GetUser, ListUsers), field names must be snake_case (e.g. user_id, created_at), and enum values must be SCREAMING_SNAKE_CASE prefixed with the enum type name (e.g. STATUS_ACTIVE for enum Status)."
  },
  {
    question: "Why should RPC request types end with 'Request' and responses with 'Response'?",
    answer: "The Request/Response naming convention is a widely adopted best practice (used by Google's own APIs and buf.build's style guide). It makes it immediately clear which messages are input vs output, allows tools to auto-detect request/response pairs, and improves readability when many message types are defined in one file."
  },
  {
    question: "Why should repeated fields be plural?",
    answer: "A field like 'repeated string role' is ambiguous — is it one role or many? Using 'repeated string roles' makes the intent clear. This is a recommendation from Google's API design guide and adopted by most protobuf linting tools."
  },
  {
    question: "Why use google.protobuf.Timestamp instead of int64 for timestamps?",
    answer: "google.protobuf.Timestamp is a well-known type that maps to RFC 3339 timestamps in JSON, is timezone-aware, and works consistently across all language bindings. Using int64 forces consumers to decide whether it's milliseconds, seconds, or microseconds — a common source of bugs. Timestamp also provides clear semantics for tooling."
  },
  {
    question: "Why should enum values be prefixed with the enum type name?",
    answer: "In proto3, enum values share the namespace of the enclosing .proto file. If you have two enums that both define ACTIVE = 1, the compiler will complain. Prefixing (STATUS_ACTIVE, ROLE_ACTIVE) avoids these collisions. It also makes the value self-documenting when used outside the enum context."
  },
];
---

<BaseLayout
  title="gRPC Proto Linter — Lint Protocol Buffer Files for Naming & Best Practices"
  description="Lint your .proto files online. Checks naming conventions (PascalCase services, snake_case fields, SCREAMING_SNAKE_CASE enums), Request/Response suffixes, repeated field naming, timestamp types, and proto3 best practices. Runs 100% in your browser."
  tool="gRPC proto linter, protobuf linter, proto naming conventions, proto3 best practices, Protocol Buffer style guide checker"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "gRPC Proto Linter",
    "url": "https://devplaybook.cc/tools/grpc-proto-linter",
    "description": "Lint Protocol Buffer .proto files for naming conventions and best practices. Checks PascalCase services/messages, snake_case fields, SCREAMING_SNAKE_CASE enums, Request/Response suffixes, and proto3 rules. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">gRPC Proto Linter</h1>
  <p class="text-text-muted mb-4">
    Lint your <code class="font-mono bg-surface px-1 rounded text-sm">.proto</code> files for naming conventions and best practices.
    Catches style violations that pass the compiler but break SDK generators, API design guides, and cross-team consistency.
    Runs entirely in your browser — nothing is sent to any server.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Naming conventions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Request/Response suffixes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Field type suggestions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Proto3 best practices</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <GrpcProtoLinter client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="gRPC Proto Linter" relatedTags={['grpc', 'protobuf', 'api', 'validation', 'microservices', 'backend', 'linting']} />
</BaseLayout>
