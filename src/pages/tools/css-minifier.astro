---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CssMinifier from '../../components/CssMinifier.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What does a CSS minifier do?", answer: "A CSS minifier removes all characters that are unnecessary for browsers to interpret the stylesheet — whitespace, newlines, comments, and redundant semicolons — without changing how the CSS behaves. The result is a smaller file that loads faster." },
  { question: "How much file size can CSS minification save?", answer: "Typical savings range from 20% to 50% depending on how much whitespace and comments are in the original file. Heavily commented CSS with generous indentation can see 40–60% reductions. Combined with gzip compression on your server, total transfer savings can exceed 80%." },
  { question: "Does minification change how my CSS works?", answer: "No. Minification only removes formatting characters that browsers ignore. Selectors, property names, values, and the cascade order are all preserved exactly. The visual output in a browser is identical." },
  { question: "When should I minify CSS?", answer: "Always minify CSS for production builds. Use a build tool (Vite, webpack, PostCSS) to automate this in your CI pipeline. Never manually edit minified CSS — keep the original source and minify as a build step." },
  { question: "What is the difference between minification and compression?", answer: "Minification removes unnecessary characters from the source code itself. Compression (gzip or Brotli) is applied by the web server when transmitting files over HTTP. They are complementary — use both. Minify first, then let your server compress the minified output." },
];
---

<BaseLayout
  title="CSS Minifier — Compress CSS & Reduce File Size Online"
  description="Free online CSS minifier. Paste your CSS to strip comments, whitespace, and redundant characters. Instantly shows original size, minified size, and % saved. Runs entirely in your browser."
  tool="CSS Minifier, CSS Compressor, Minify CSS Online, CSS Size Reducer"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">CSS Minifier</h1>
  <p class="text-text-muted mb-4">Paste your CSS to remove comments, whitespace, and redundant characters. See exactly how many bytes you save. All processing runs in your browser — nothing is sent to any server.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <CssMinifier client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CSS Minifier" relatedTags={['css', 'minifier', 'performance', 'web', 'styling', 'development']} />
</BaseLayout>
