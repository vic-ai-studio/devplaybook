---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="OAuth 2.0 Flow Debugger — Decode Tokens, Build Auth URLs, Debug PKCE"
  description="Debug OAuth 2.0 authorization flows. Decode access tokens (JWT), inspect scopes, validate token expiry, check PKCE parameters, and trace authorization code flow. Runs in your browser."
  tool="OAuth 2.0 debugger, JWT decoder, OAuth token inspector, PKCE debugger, authorization code flow, access token expiry, scope inspector, OAuth URL builder"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "OAuth 2.0 Flow Debugger",
    "url": "https://devplaybook.cc/tools/oauth2-flow-debugger",
    "description": "Debug OAuth 2.0 authorization flows. Decode access tokens (JWT), inspect scopes, validate token expiry, check PKCE parameters, and trace authorization code flow. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">OAuth 2.0 Flow Debugger</h1>
  <p class="text-text-muted mb-4">Decode JWT access tokens, inspect scopes and expiry, build OAuth 2.0 authorization URLs with PKCE, and trace the full authorization code flow — all in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> JWT decoder — header, payload, expiry</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> OAuth2 URL builder with PKCE</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Token expiry checker</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs entirely in your browser</span>
  </div>

  <!-- Tab navigation -->
  <div class="flex gap-1 mb-6 border-b border-border">
    <button data-tab="jwt" class="oauth-tab px-4 py-2.5 text-sm font-medium border-b-2 border-primary text-primary transition-colors">JWT Decoder</button>
    <button data-tab="url" class="oauth-tab px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-foreground transition-colors">URL Builder</button>
    <button data-tab="pkce" class="oauth-tab px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-foreground transition-colors">PKCE Helper</button>
  </div>

  <!-- JWT Decoder Panel -->
  <div id="panel-jwt" class="oauth-panel">
    <div class="mb-4">
      <label class="block text-sm font-medium mb-2">Paste JWT Access Token</label>
      <textarea id="jwt-input" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary resize-none" rows="4" placeholder="eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9..."></textarea>
    </div>
    <div class="flex gap-3 mb-6 flex-wrap">
      <button id="btn-decode-jwt" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Decode Token</button>
      <button id="btn-jwt-example" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Load Example</button>
      <button id="btn-jwt-clear" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Clear</button>
    </div>
    <div id="jwt-result" class="hidden space-y-4">
      <!-- Expiry banner -->
      <div id="jwt-expiry-banner" class="p-3 rounded-lg text-sm font-medium"></div>
      <!-- Header -->
      <div class="bg-bg-card border border-border rounded-lg overflow-hidden">
        <div class="flex items-center justify-between px-4 py-2.5 border-b border-border bg-blue-500/5">
          <span class="text-sm font-semibold text-blue-400">Header</span>
          <button class="jwt-copy-btn px-3 py-1 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-target="jwt-header-out">Copy</button>
        </div>
        <pre id="jwt-header-out" class="p-4 font-mono text-sm text-blue-300 whitespace-pre-wrap break-all overflow-x-auto"></pre>
      </div>
      <!-- Payload -->
      <div class="bg-bg-card border border-border rounded-lg overflow-hidden">
        <div class="flex items-center justify-between px-4 py-2.5 border-b border-border bg-green-500/5">
          <span class="text-sm font-semibold text-green-400">Payload</span>
          <button class="jwt-copy-btn px-3 py-1 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors" data-target="jwt-payload-out">Copy</button>
        </div>
        <pre id="jwt-payload-out" class="p-4 font-mono text-sm text-green-300 whitespace-pre-wrap break-all overflow-x-auto"></pre>
      </div>
      <!-- Claims summary -->
      <div id="jwt-claims" class="bg-bg-card border border-border rounded-lg p-4">
        <h3 class="text-sm font-semibold mb-3">Claims Summary</h3>
        <div id="jwt-claims-list" class="space-y-2 text-sm"></div>
      </div>
    </div>
    <div id="jwt-error" class="hidden p-4 bg-red-500/10 border border-red-500/30 rounded-lg text-sm text-red-400"></div>
  </div>

  <!-- URL Builder Panel -->
  <div id="panel-url" class="oauth-panel hidden">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium mb-2">Authorization Endpoint</label>
        <input id="url-endpoint" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="https://auth.example.com/oauth/authorize" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Client ID</label>
        <input id="url-client-id" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="your-client-id" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Redirect URI</label>
        <input id="url-redirect" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="https://yourapp.com/callback" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Scope (space-separated)</label>
        <input id="url-scope" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="openid profile email" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">State (optional)</label>
        <div class="flex gap-2">
          <input id="url-state" type="text" class="flex-1 bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="random-state-value" />
          <button id="btn-gen-state" class="px-3 py-2 bg-bg-card border border-border rounded-lg text-xs hover:border-primary transition-colors whitespace-nowrap">Generate</button>
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Response Type</label>
        <select id="url-response-type" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
          <option value="code">code (Authorization Code)</option>
          <option value="token">token (Implicit — legacy)</option>
          <option value="code id_token">code id_token (Hybrid)</option>
        </select>
      </div>
    </div>
    <div class="flex items-center gap-3 mb-4">
      <label class="flex items-center gap-2 cursor-pointer">
        <input id="url-pkce-toggle" type="checkbox" class="w-4 h-4 accent-primary" checked />
        <span class="text-sm font-medium">Include PKCE (recommended)</span>
      </label>
    </div>
    <div id="url-pkce-fields" class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4 p-4 bg-bg-card border border-border rounded-lg">
      <div>
        <label class="block text-xs text-text-muted mb-1">Code Challenge Method</label>
        <select id="url-cc-method" class="w-full bg-bg-card border border-border rounded p-2 text-sm focus:outline-none focus:border-primary">
          <option value="S256">S256 (recommended)</option>
          <option value="plain">plain (not recommended)</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Code Verifier (auto-generated)</label>
        <div class="flex gap-2">
          <input id="url-code-verifier" type="text" class="flex-1 bg-bg-card border border-border rounded p-2 text-xs font-mono focus:outline-none focus:border-primary" readonly />
          <button id="btn-regen-verifier" class="px-2 py-1 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">↺</button>
        </div>
      </div>
      <div class="sm:col-span-2">
        <label class="block text-xs text-text-muted mb-1">Code Challenge (derived from verifier)</label>
        <input id="url-code-challenge" type="text" class="w-full bg-bg-card border border-border rounded p-2 text-xs font-mono focus:outline-none focus:border-primary" readonly />
      </div>
    </div>
    <div class="flex gap-3 mb-6 flex-wrap">
      <button id="btn-build-url" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Build Authorization URL</button>
      <button id="btn-url-example" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Load Example</button>
    </div>
    <div id="url-result" class="hidden">
      <div class="bg-bg-card border border-border rounded-lg overflow-hidden">
        <div class="flex items-center justify-between px-4 py-2.5 border-b border-border">
          <span class="text-sm font-semibold">Authorization URL</span>
          <button id="btn-copy-url" class="px-3 py-1 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">Copy</button>
        </div>
        <div class="p-4">
          <div id="url-output" class="font-mono text-sm text-primary break-all whitespace-pre-wrap mb-3"></div>
          <div id="url-params-breakdown" class="space-y-1.5 text-xs"></div>
        </div>
      </div>
      <div id="url-verifier-reminder" class="hidden mt-3 p-3 bg-yellow-500/10 border border-yellow-500/30 rounded-lg text-sm text-yellow-300">
        <strong>Store the Code Verifier!</strong> You must send it in the token exchange request as <code class="font-mono bg-bg-card px-1 rounded">code_verifier</code>.
      </div>
    </div>
  </div>

  <!-- PKCE Helper Panel -->
  <div id="panel-pkce" class="oauth-panel hidden">
    <p class="text-sm text-text-muted mb-6">PKCE (Proof Key for Code Exchange) prevents authorization code interception attacks. Generate a verifier/challenge pair and validate existing ones.</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-6">
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <h3 class="text-sm font-semibold mb-3">Generate PKCE Pair</h3>
        <div class="space-y-3">
          <div>
            <label class="block text-xs text-text-muted mb-1">Code Verifier (128 chars, URL-safe base64)</label>
            <div class="flex gap-2">
              <input id="pkce-verifier-out" type="text" class="flex-1 bg-bg-card border border-border rounded p-2 text-xs font-mono focus:outline-none" readonly />
              <button class="pkce-copy" data-target="pkce-verifier-out" class="px-2 py-1 bg-bg-card border border-border rounded text-xs hover:border-primary">Copy</button>
            </div>
          </div>
          <div>
            <label class="block text-xs text-text-muted mb-1">Code Challenge (SHA-256, base64url)</label>
            <div class="flex gap-2">
              <input id="pkce-challenge-out" type="text" class="flex-1 bg-bg-card border border-border rounded p-2 text-xs font-mono focus:outline-none" readonly />
              <button class="pkce-copy" data-target="pkce-challenge-out" class="px-2 py-1 bg-bg-card border border-border rounded text-xs hover:border-primary">Copy</button>
            </div>
          </div>
          <button id="btn-gen-pkce" class="w-full px-4 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Generate New Pair</button>
        </div>
      </div>
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <h3 class="text-sm font-semibold mb-3">Validate PKCE</h3>
        <div class="space-y-3">
          <div>
            <label class="block text-xs text-text-muted mb-1">Code Verifier</label>
            <input id="pkce-val-verifier" type="text" class="w-full bg-bg-card border border-border rounded p-2 text-xs font-mono focus:outline-none focus:border-primary" placeholder="Paste code_verifier..." />
          </div>
          <div>
            <label class="block text-xs text-text-muted mb-1">Code Challenge</label>
            <input id="pkce-val-challenge" type="text" class="w-full bg-bg-card border border-border rounded p-2 text-xs font-mono focus:outline-none focus:border-primary" placeholder="Paste code_challenge..." />
          </div>
          <button id="btn-validate-pkce" class="w-full px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Validate</button>
          <div id="pkce-validate-result" class="hidden p-3 rounded-lg text-sm font-medium"></div>
        </div>
      </div>
    </div>
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <h3 class="text-sm font-semibold mb-3">PKCE Flow Reference</h3>
      <ol class="space-y-2 text-sm text-text-muted list-decimal list-inside">
        <li>Generate a cryptographically random <code class="font-mono text-foreground bg-bg-card border border-border px-1.5 rounded text-xs">code_verifier</code> (43–128 chars, URL-safe)</li>
        <li>Compute <code class="font-mono text-foreground bg-bg-card border border-border px-1.5 rounded text-xs">code_challenge = BASE64URL(SHA256(code_verifier))</code></li>
        <li>Include <code class="font-mono text-foreground bg-bg-card border border-border px-1.5 rounded text-xs">code_challenge</code> and <code class="font-mono text-foreground bg-bg-card border border-border px-1.5 rounded text-xs">code_challenge_method=S256</code> in the authorization request</li>
        <li>Store <code class="font-mono text-foreground bg-bg-card border border-border px-1.5 rounded text-xs">code_verifier</code> securely client-side</li>
        <li>Send <code class="font-mono text-foreground bg-bg-card border border-border px-1.5 rounded text-xs">code_verifier</code> in the token exchange request — the server validates it</li>
      </ol>
    </div>
  </div>

  <ToolPageCta />
</BaseLayout>

<script>
// ── Utilities ──────────────────────────────────────────────────────────────
function b64urlDecode(str) {
  str = str.replace(/-/g, '+').replace(/_/g, '/');
  while (str.length % 4) str += '=';
  try { return atob(str); } catch { return null; }
}

function b64urlEncode(buf) {
  const bytes = new Uint8Array(buf);
  let str = '';
  bytes.forEach(b => str += String.fromCharCode(b));
  return btoa(str).replace(/\+/g, '-').replace(/\//g, '_').replace(/=/g, '');
}

function randomB64url(len = 32) {
  const buf = new Uint8Array(len);
  crypto.getRandomValues(buf);
  return b64urlEncode(buf);
}

async function sha256B64url(str) {
  const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str));
  return b64urlEncode(buf);
}

function fmtTime(secs) {
  if (secs < 0) return `${Math.abs(secs)} seconds ago`;
  const m = Math.floor(secs / 60), h = Math.floor(m / 60), d = Math.floor(h / 24);
  if (d > 0) return `in ${d}d ${h % 24}h`;
  if (h > 0) return `in ${h}h ${m % 60}m`;
  if (m > 0) return `in ${m}m ${secs % 60}s`;
  return `in ${secs}s`;
}

// ── Tab Switching ──────────────────────────────────────────────────────────
function switchTab(tab) {
  document.querySelectorAll('.oauth-tab').forEach(t => {
    const active = t.dataset.tab === tab;
    t.classList.toggle('border-primary', active);
    t.classList.toggle('text-primary', active);
    t.classList.toggle('border-transparent', !active);
    t.classList.toggle('text-text-muted', !active);
  });
  document.querySelectorAll('.oauth-panel').forEach(p => p.classList.add('hidden'));
  document.getElementById(`panel-${tab}`)?.classList.remove('hidden');
}
document.querySelectorAll('.oauth-tab').forEach(t => t.addEventListener('click', () => switchTab(t.dataset.tab)));

// ── JWT Decoder ────────────────────────────────────────────────────────────
const SAMPLE_JWT = 'eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCIsImtpZCI6ImV4YW1wbGUta2V5LTEifQ..signature';

document.getElementById('btn-jwt-example')?.addEventListener('click', () => {
  document.getElementById('jwt-input').value = SAMPLE_JWT;
});
document.getElementById('btn-jwt-clear')?.addEventListener('click', () => {
  document.getElementById('jwt-input').value = '';
  document.getElementById('jwt-result').classList.add('hidden');
  document.getElementById('jwt-error').classList.add('hidden');
});

document.getElementById('btn-decode-jwt')?.addEventListener('click', () => {
  const raw = document.getElementById('jwt-input').value.trim();
  const errEl = document.getElementById('jwt-error');
  const resultEl = document.getElementById('jwt-result');
  errEl.classList.add('hidden');
  resultEl.classList.add('hidden');

  if (!raw) { errEl.textContent = 'Please paste a JWT token.'; errEl.classList.remove('hidden'); return; }

  const parts = raw.split('.');
  if (parts.length < 2) { errEl.textContent = 'Invalid JWT: must have at least 2 parts (header.payload).'; errEl.classList.remove('hidden'); return; }

  const headerRaw = b64urlDecode(parts[0]);
  const payloadRaw = b64urlDecode(parts[1]);
  if (!headerRaw || !payloadRaw) { errEl.textContent = 'Failed to decode JWT: invalid base64url encoding.'; errEl.classList.remove('hidden'); return; }

  let header, payload;
  try { header = JSON.parse(headerRaw); } catch { errEl.textContent = 'Failed to parse JWT header as JSON.'; errEl.classList.remove('hidden'); return; }
  try { payload = JSON.parse(payloadRaw); } catch { errEl.textContent = 'Failed to parse JWT payload as JSON.'; errEl.classList.remove('hidden'); return; }

  document.getElementById('jwt-header-out').textContent = JSON.stringify(header, null, 2);
  document.getElementById('jwt-payload-out').textContent = JSON.stringify(payload, null, 2);

  // Expiry banner
  const bannerEl = document.getElementById('jwt-expiry-banner');
  const now = Math.floor(Date.now() / 1000);
  if (payload.exp) {
    const diff = payload.exp - now;
    if (diff < 0) {
      bannerEl.className = 'p-3 rounded-lg text-sm font-medium bg-red-500/10 border border-red-500/30 text-red-400';
      bannerEl.textContent = `⚠ Token EXPIRED ${fmtTime(diff)} (exp: ${new Date(payload.exp * 1000).toUTCString()})`;
    } else if (diff < 300) {
      bannerEl.className = 'p-3 rounded-lg text-sm font-medium bg-yellow-500/10 border border-yellow-500/30 text-yellow-400';
      bannerEl.textContent = `⚠ Token expires very soon — ${fmtTime(diff)} (exp: ${new Date(payload.exp * 1000).toUTCString()})`;
    } else {
      bannerEl.className = 'p-3 rounded-lg text-sm font-medium bg-green-500/10 border border-green-500/30 text-green-400';
      bannerEl.textContent = `✓ Token valid — expires ${fmtTime(diff)} (exp: ${new Date(payload.exp * 1000).toUTCString()})`;
    }
  } else {
    bannerEl.className = 'p-3 rounded-lg text-sm font-medium bg-yellow-500/10 border border-yellow-500/30 text-yellow-400';
    bannerEl.textContent = '⚠ No expiry (exp) claim found — token has no expiration.';
  }

  // Claims summary
  const claimInfo = {
    sub: 'Subject — unique user identifier',
    iss: 'Issuer — who issued the token',
    aud: 'Audience — intended recipient',
    exp: 'Expiry time (Unix timestamp)',
    iat: 'Issued at (Unix timestamp)',
    nbf: 'Not valid before (Unix timestamp)',
    jti: 'JWT ID — unique token identifier',
    scope: 'OAuth 2.0 scopes granted',
    email: 'User email address',
    name: 'User display name',
    azp: 'Authorized party (client_id)',
  };
  const claimsList = document.getElementById('jwt-claims-list');
  claimsList.innerHTML = '';
  Object.entries(payload).forEach(([k, v]) => {
    const desc = claimInfo[k] || '';
    let displayVal = typeof v === 'object' ? JSON.stringify(v) : String(v);
    if ((k === 'exp' || k === 'iat' || k === 'nbf') && typeof v === 'number') {
      displayVal = `${v} (${new Date(v * 1000).toUTCString()})`;
    }
    const row = document.createElement('div');
    row.className = 'flex items-start gap-2 text-xs';
    row.innerHTML = `<span class="font-mono text-primary flex-shrink-0 w-14">${k}</span><span class="font-mono text-foreground flex-1 break-all">${displayVal}</span>${desc ? `<span class="text-text-muted flex-shrink-0 hidden sm:block max-w-xs">${desc}</span>` : ''}`;
    claimsList.appendChild(row);
  });

  // Scopes
  if (payload.scope) {
    const scopes = String(payload.scope).split(/\s+/);
    const scopeDiv = document.createElement('div');
    scopeDiv.className = 'mt-3 pt-3 border-t border-border';
    scopeDiv.innerHTML = `<div class="text-xs text-text-muted mb-2">Scopes (${scopes.length})</div><div class="flex flex-wrap gap-1.5">${scopes.map(s => `<span class="text-xs px-2 py-0.5 bg-primary/10 border border-primary/20 text-primary rounded-full font-mono">${s}</span>`).join('')}</div>`;
    claimsList.appendChild(scopeDiv);
  }

  resultEl.classList.remove('hidden');
});

document.querySelectorAll('.jwt-copy-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const el = document.getElementById(btn.dataset.target);
    if (!el) return;
    navigator.clipboard.writeText(el.textContent).then(() => { btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = 'Copy', 2000); });
  });
});

// ── URL Builder ────────────────────────────────────────────────────────────
let codeVerifier = '';
let codeChallenge = '';

async function regenVerifier() {
  codeVerifier = randomB64url(96); // 128 chars base64url
  document.getElementById('url-code-verifier').value = codeVerifier;
  await recomputeChallenge();
}

async function recomputeChallenge() {
  const method = document.getElementById('url-cc-method')?.value;
  if (method === 'S256') {
    codeChallenge = await sha256B64url(codeVerifier);
  } else {
    codeChallenge = codeVerifier;
  }
  document.getElementById('url-code-challenge').value = codeChallenge;
}

document.getElementById('btn-regen-verifier')?.addEventListener('click', regenVerifier);
document.getElementById('url-cc-method')?.addEventListener('change', recomputeChallenge);
document.getElementById('btn-gen-state')?.addEventListener('click', () => {
  document.getElementById('url-state').value = randomB64url(16);
});
document.getElementById('url-pkce-toggle')?.addEventListener('change', (e) => {
  document.getElementById('url-pkce-fields').classList.toggle('hidden', !e.target.checked);
});

document.getElementById('btn-url-example')?.addEventListener('click', () => {
  document.getElementById('url-endpoint').value = 'https://accounts.google.com/o/oauth2/v2/auth';
  document.getElementById('url-client-id').value = 'your-google-client-id.apps.googleusercontent.com';
  document.getElementById('url-redirect').value = 'https://yourapp.com/auth/callback';
  document.getElementById('url-scope').value = 'openid profile email';
  document.getElementById('url-state').value = randomB64url(16);
  document.getElementById('url-pkce-toggle').checked = true;
  document.getElementById('url-pkce-fields').classList.remove('hidden');
});

document.getElementById('btn-build-url')?.addEventListener('click', async () => {
  const endpoint = document.getElementById('url-endpoint').value.trim();
  const clientId = document.getElementById('url-client-id').value.trim();
  const redirect = document.getElementById('url-redirect').value.trim();
  const scope = document.getElementById('url-scope').value.trim();
  const state = document.getElementById('url-state').value.trim();
  const responseType = document.getElementById('url-response-type').value;
  const usePkce = document.getElementById('url-pkce-toggle').checked;

  if (!endpoint || !clientId || !redirect) {
    alert('Authorization endpoint, client_id, and redirect_uri are required.');
    return;
  }

  const params = new URLSearchParams({
    response_type: responseType,
    client_id: clientId,
    redirect_uri: redirect,
  });
  if (scope) params.set('scope', scope);
  if (state) params.set('state', state);
  if (usePkce) {
    const method = document.getElementById('url-cc-method').value;
    params.set('code_challenge', codeChallenge);
    params.set('code_challenge_method', method);
  }

  const url = `${endpoint}?${params.toString()}`;
  document.getElementById('url-output').textContent = url;

  // Params breakdown
  const breakdown = document.getElementById('url-params-breakdown');
  breakdown.innerHTML = Array.from(params.entries()).map(([k, v]) => `
    <div class="flex gap-2 text-xs">
      <span class="font-mono text-primary flex-shrink-0 min-w-[160px]">${k}</span>
      <span class="font-mono text-text-muted break-all">${v}</span>
    </div>`).join('');

  document.getElementById('url-verifier-reminder').classList.toggle('hidden', !usePkce);
  document.getElementById('url-result').classList.remove('hidden');
});

document.getElementById('btn-copy-url')?.addEventListener('click', () => {
  const el = document.getElementById('url-output');
  navigator.clipboard.writeText(el.textContent).then(() => {
    const btn = document.getElementById('btn-copy-url');
    btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = 'Copy', 2000);
  });
});

// ── PKCE Helper ────────────────────────────────────────────────────────────
async function genPkce() {
  const verifier = randomB64url(96);
  const challenge = await sha256B64url(verifier);
  document.getElementById('pkce-verifier-out').value = verifier;
  document.getElementById('pkce-challenge-out').value = challenge;
}

document.getElementById('btn-gen-pkce')?.addEventListener('click', genPkce);

document.getElementById('btn-validate-pkce')?.addEventListener('click', async () => {
  const v = document.getElementById('pkce-val-verifier').value.trim();
  const c = document.getElementById('pkce-val-challenge').value.trim();
  const resultEl = document.getElementById('pkce-validate-result');
  if (!v || !c) { resultEl.className = 'p-3 rounded-lg text-sm font-medium bg-yellow-500/10 border border-yellow-500/30 text-yellow-400'; resultEl.textContent = 'Enter both verifier and challenge.'; resultEl.classList.remove('hidden'); return; }
  const computed = await sha256B64url(v);
  if (computed === c) {
    resultEl.className = 'p-3 rounded-lg text-sm font-medium bg-green-500/10 border border-green-500/30 text-green-400';
    resultEl.textContent = '✓ Valid — code_challenge matches SHA-256(code_verifier)';
  } else {
    resultEl.className = 'p-3 rounded-lg text-sm font-medium bg-red-500/10 border border-red-500/30 text-red-400';
    resultEl.textContent = `✗ Invalid — expected: ${computed}`;
  }
  resultEl.classList.remove('hidden');
});

document.querySelectorAll('.pkce-copy').forEach(btn => {
  btn.addEventListener('click', () => {
    const el = document.getElementById(btn.dataset.target);
    if (!el) return;
    navigator.clipboard.writeText(el.value).then(() => { btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = 'Copy', 2000); });
  });
});

// Init
regenVerifier();
genPkce();
</script>
