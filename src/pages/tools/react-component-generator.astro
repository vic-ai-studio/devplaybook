---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReactComponentGenerator from '../../components/ReactComponentGenerator.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What types of React components can I generate?", answer: "The generator supports three component types: standard functional components, React.memo-wrapped components (for performance optimization by skipping re-renders when props haven't changed), and forwardRef components (for exposing a DOM ref to parent components, needed for input focus management and animation libraries)." },
  { question: "Should I use TypeScript for React components?", answer: "Yes, for most production projects. TypeScript catches prop-type mismatches at compile time, makes refactoring safer, and gives you autocomplete in editors. The generator creates a typed Props interface automatically from your prop definitions." },
  { question: "When should I use React.memo?", answer: "Use React.memo for components that render frequently with the same props — lists, table rows, sidebar items, dashboard widgets. It does a shallow comparison of props and skips re-render if nothing changed. Don't use it everywhere — the comparison itself has a cost, and premature optimization can make bugs harder to track." },
  { question: "What is forwardRef used for?", answer: "forwardRef lets parent components pass a ref down to a DOM element inside your component. It's needed when you want to focus an input impernatically, measure element dimensions, use animation libraries like Framer Motion, or integrate with third-party DOM libraries." },
  { question: "How do I add the generated component to my project?", answer: "Click 'Copy' to copy the generated code, create a new file in your components folder (e.g. src/components/MyComponent.tsx), and paste. If you enabled the test file, repeat for the .test.tsx file. The imports are standard — ensure you have React and any styling libraries installed." },
];
---

<BaseLayout
  title="React Component Generator — TypeScript Boilerplate with Hooks"
  description="Generate React component boilerplate with TypeScript, hooks, and styled output. Choose functional, memo, or forwardRef. Add props and useState hooks. Get production-ready code instantly."
  tool="React Component Generator, React Boilerplate, TypeScript React Component, React Hooks Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">React Component Generator</h1>
  <p class="text-text-muted mb-4">Generate production-ready React component boilerplate. Configure props, hooks, TypeScript types, and styling approach — then copy the code in one click.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <ReactComponentGenerator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <AffiliateSection category="frontend" />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Want to write TypeScript?</p>
    <a href="/tools/typescript-playground" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">TypeScript Playground →</a>
  </div>
  <ToolPageCta currentTool="React Component Generator" relatedTags={['react', 'typescript', 'javascript', 'frontend', 'code']} />
</BaseLayout>
