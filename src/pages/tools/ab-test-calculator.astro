---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AbTestCalculator from '../../components/AbTestCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What statistical test does this calculator use?", answer: "This calculator uses a two-proportion z-test, which is the standard for comparing conversion rates in A/B tests. It computes a z-score from the pooled proportion standard error, then derives a two-tailed p-value using the normal distribution. This is equivalent to Pearson's chi-square test for 2×2 contingency tables." },
  { question: "What does the p-value mean in A/B testing?", answer: "The p-value is the probability of observing a difference this large (or larger) purely by chance, assuming the null hypothesis is true (i.e., both variants have the same conversion rate). A p-value below 0.05 at 95% confidence means there is less than a 5% probability this result is random." },
  { question: "What is statistical significance and why does it matter?", answer: "A result is statistically significant when the p-value is below your chosen alpha threshold (0.05 for 95% confidence). It means the observed difference is unlikely to be due to random sampling variation. Without statistical significance, you cannot reliably conclude that one variant is actually better." },
  { question: "Why should I not stop the test early?", answer: "Stopping a test as soon as significance is reached inflates your false-positive rate dramatically — a phenomenon called 'peeking'. Even if your results look significant after 20% of the planned sample, the actual false-positive rate can be 20-30% instead of 5%. Always predetermine your sample size and run to completion." },
  { question: "What is the Minimum Detectable Effect (MDE)?", answer: "MDE is the smallest relative improvement you care about detecting. A 20% MDE on a 5% baseline means you want to reliably detect a lift from 5% to 6%. Smaller MDEs require larger sample sizes. Setting too ambitious an MDE (e.g. 5%) requires enormous traffic and long test durations." },
  { question: "What does the confidence interval represent?", answer: "The confidence interval shows the range of plausible values for the true difference (B minus A) in conversion rates. A 95% CI of [+0.5%, +2.1%] means you are 95% confident the true improvement is between 0.5% and 2.1% percentage points. If the interval contains 0, the test is inconclusive." },
];
---

<BaseLayout
  title="A/B Test Calculator — Statistical Significance, p-value & Confidence Interval"
  description="Free A/B test significance calculator. Enter visitors and conversions for variants A and B. Get p-value, z-score, confidence interval, and lift. Includes sample size planner. Runs in your browser."
  tool="A/B Test Calculator, Statistical Significance Calculator, p-value Calculator, Conversion Rate Test, Split Test Calculator, Chi-square Test"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">A/B Test Statistical Significance Calculator</h1>
  <p class="text-text-muted mb-4">Enter your experiment results to instantly calculate statistical significance, p-value, z-score, lift, and confidence intervals. Use the sample size planner to know how many visitors you need before starting a test.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Two-proportion z-test (chi-square equivalent)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 90%, 95%, 99% confidence levels</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Sample size planner included</span>
  </div>
  <AbTestCalculator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="A/B Test Statistical Significance Calculator" relatedTags={['analytics', 'testing', 'statistics', 'calculator', 'marketing']} />
</BaseLayout>
