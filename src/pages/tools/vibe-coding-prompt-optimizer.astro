---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is vibe coding?",
    answer: "Vibe coding (coined by Andrej Karpathy in 2025) is a programming approach where you describe what you want in natural language and let AI tools (Claude Code, Cursor, GitHub Copilot) generate the implementation. You 'vibe' with the AI — guiding it with high-level intent, reviewing outputs, and iterating. It's not about writing less code; it's about communicating intent more effectively."
  },
  {
    question: "What makes a good vibe coding prompt?",
    answer: "Great vibe coding prompts: (1) Specify the tech stack and constraints upfront. (2) Describe the desired behavior, not implementation details. (3) Include examples of inputs/outputs when helpful. (4) Mention what to avoid or what already exists. (5) Break large features into focused sub-tasks. (6) Add context about the codebase state. Vague prompts lead to hallucinated architectures; specific prompts get production-ready code."
  },
  {
    question: "How is Claude Code different from Cursor for vibe coding?",
    answer: "Claude Code is a CLI-based agent that runs in your terminal, has full access to your filesystem, and can make multi-file changes autonomously. It's ideal for complex, multi-step tasks. Cursor is an IDE with inline AI assistance — better for small edits, code completion, and contextual chat. Use Claude Code for 'build this feature' tasks; use Cursor for 'fix this function' tasks."
  },
  {
    question: "What are common vibe coding mistakes?",
    answer: "Common mistakes: (1) Too vague — 'build a web app' gives you a generic scaffold. (2) No constraints — AI picks random tech stacks. (3) Too large — one prompt for an entire feature leads to inconsistent code. (4) No context — AI doesn't know about your existing architecture. (5) Not iterating — accepting first output without review. (6) Over-trusting — using AI-generated security or auth code without manual review."
  },
  {
    question: "Should I review AI-generated code before committing?",
    answer: "Yes, always. Even excellent AI coding tools produce: security vulnerabilities (SQLi, XSS, unvalidated inputs), race conditions in async code, incorrect error handling, non-idiomatic patterns for your language, and outdated API usage. For security-critical code (auth, payments, cryptography), always have a human expert review. Use AI for velocity, human review for correctness."
  }
];
---

<BaseLayout
  title="Vibe Coding Prompt Optimizer — Improve AI Coding Prompts for Claude Code & Cursor"
  description="Optimize your vibe coding prompts for Claude Code, Cursor, GitHub Copilot, and Windsurf. Get structured, effective prompts that generate better AI code. Includes templates and analysis."
  tool="vibe coding prompt optimizer, claude code prompt, cursor ai prompt, ai coding prompt generator, vibe coding tips"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Vibe Coding Prompt Optimizer",
    "url": "https://devplaybook.cc/tools/vibe-coding-prompt-optimizer",
    "description": "Optimize vibe coding prompts for Claude Code, Cursor, and GitHub Copilot. Analyze prompts for clarity, specificity, and context, then generate improved versions.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Vibe Coding Prompt Optimizer</h1>
  <p class="text-text-muted mb-4">
    Paste your AI coding prompt and get an optimized version with better context, constraints, and structure for Claude Code, Cursor, or GitHub Copilot.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Prompt quality analysis</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Optimized output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 8 prompt templates</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <!-- Input -->
    <div class="space-y-3">
      <div class="flex items-center justify-between">
        <label class="text-sm font-medium">Your Prompt</label>
        <select id="target-tool" class="text-xs px-2 py-1 bg-surface border border-border rounded focus:outline-none">
          <option value="claude-code">Claude Code</option>
          <option value="cursor">Cursor</option>
          <option value="copilot">GitHub Copilot</option>
          <option value="windsurf">Windsurf</option>
        </select>
      </div>
      <textarea
        id="prompt-input"
        class="w-full h-40 px-3 py-2 bg-surface border border-border rounded-lg text-sm font-mono resize-y focus:outline-none focus:ring-2 focus:ring-primary/50 placeholder:text-text-muted"
        placeholder="e.g. build me a login page"
      ></textarea>
      <div class="space-y-2">
        <label class="text-xs text-text-muted">Tech Stack Context</label>
        <input id="tech-stack" type="text" class="w-full px-3 py-1.5 bg-surface border border-border rounded text-sm focus:outline-none focus:ring-1 focus:ring-primary/50" placeholder="e.g. Next.js 14, TypeScript, Prisma, PostgreSQL, Tailwind">
      </div>
      <button id="btn-optimize" class="w-full px-4 py-2 bg-primary text-white text-sm font-medium rounded-lg hover:bg-primary/90 transition-colors">
        Optimize Prompt
      </button>
    </div>

    <!-- Analysis -->
    <div class="space-y-3">
      <label class="text-sm font-medium">Prompt Quality Analysis</label>
      <div id="analysis-panel" class="border border-border rounded-xl p-4 space-y-3 min-h-40">
        <div class="text-sm text-text-muted">← Enter a prompt and click Optimize</div>
      </div>
    </div>
  </div>

  <!-- Optimized output -->
  <div id="output-section" class="hidden border border-border rounded-xl p-5 mb-6">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-base font-semibold">Optimized Prompt</h2>
      <button id="btn-copy" class="text-xs px-3 py-1 bg-surface border border-border rounded hover:border-primary hover:text-primary transition-colors">Copy</button>
    </div>
    <pre id="optimized-output" class="text-sm font-mono text-accent bg-surface rounded-lg p-4 overflow-x-auto whitespace-pre-wrap"></pre>
  </div>

  <!-- Templates -->
  <div class="border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-3">Prompt Templates</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3" id="templates-grid"></div>
  </div>

  <AdUnit />
  <ToolPageCta />

<script>
(() => {
  const ANALYSIS_CHECKS = [
    { id: 'has_stack', label: 'Tech stack specified', check: (p, s) => s.length > 5 || /\b(react|next|vue|python|typescript|node|rails|django|fastapi)\b/i.test(p), tip: 'Add your tech stack: "Using Next.js 14, TypeScript, and Tailwind..."' },
    { id: 'has_behavior', label: 'Describes behavior/UX', check: (p) => p.length > 50 && /\b(should|must|when|after|display|show|allow|prevent|validate|return)\b/i.test(p), tip: 'Describe what the code should do: "When clicked, it should..."' },
    { id: 'has_constraints', label: 'Mentions constraints', check: (p) => /\b(don.t|avoid|no|without|only|must not|existing|already)\b/i.test(p), tip: 'Add constraints: "Don\'t add new dependencies" or "Must work with existing auth"' },
    { id: 'not_too_vague', label: 'Not too vague', check: (p) => p.length > 30, tip: 'Add more detail — what specifically should be built?' },
    { id: 'not_too_large', label: 'Appropriately scoped', check: (p) => p.length < 500, tip: 'Consider breaking into smaller sub-tasks for better AI output' },
    { id: 'has_output_hint', label: 'Output format hinted', check: (p) => /\b(file|function|component|class|api|endpoint|returns|outputs|generates)\b/i.test(p), tip: 'Specify what to produce: "a React component", "a FastAPI endpoint", "a utility function"' },
    { id: 'has_example', label: 'Example given (optional+)', check: (p) => /\b(example|e\.g\.|like|for instance|input|output)\b/i.test(p), tip: 'Adding input/output examples helps AI generate more accurate code' },
    { id: 'imperative', label: 'Uses imperative voice', check: (p) => /^(add|build|create|implement|write|generate|refactor|fix|update|modify)/i.test(p.trim()), tip: 'Start with a verb: "Create a...", "Build a...", "Implement..."' },
  ];

  const TEMPLATES = [
    {
      label: '🆕 New Feature',
      template: `Add a {feature_name} feature to the {component_name} component.

Tech stack: {stack}
Location: {file_path}

Requirements:
- {requirement_1}
- {requirement_2}
- {requirement_3}

Constraints:
- Do not modify {existing_file}
- Must work with existing {auth/state/data layer}
- Follow the existing code patterns in {reference_file}

Expected output: A working {component/function/endpoint} that {behavior}`
    },
    {
      label: '🐛 Bug Fix',
      template: `Fix the bug where {describe_bug}.

Affected file: {file_path}
Repro steps: {steps}
Expected behavior: {expected}
Actual behavior: {actual}

Do not change the function signature or public API.
Add a comment explaining the root cause.`
    },
    {
      label: '🔌 API Endpoint',
      template: `Create a {METHOD} /api/{endpoint} endpoint.

Tech: {framework} + {orm/db}
Auth: {auth_method}

Request body:
{
  "field1": string,
  "field2": number
}

Response:
{
  "data": {...},
  "error": null | string
}

Validation: {validation_rules}
Error cases: {error_cases}`
    },
    {
      label: '⚛️ React Component',
      template: `Build a {ComponentName} React component.

Tech: React, TypeScript, Tailwind CSS
File: src/components/{ComponentName}.tsx

Props interface:
- prop1: string — {description}
- prop2: boolean — {description}
- onAction: () => void

Behavior:
- {behavior_1}
- {behavior_2}

Style: Match the existing {reference_component} pattern. Dark mode compatible.`
    },
    {
      label: '🗄️ Database Schema',
      template: `Create a {table_name} database schema and migration.

ORM: {prisma/drizzle/sqlalchemy}
DB: {postgresql/mysql/sqlite}

Fields needed:
- id (primary key, auto-increment)
- {field_1}: {type} — {description}
- {field_2}: {type} — {description}
- createdAt, updatedAt timestamps

Relations: {belongs_to/has_many}
Indexes: {indexed_fields}
Constraints: {unique/not_null}`
    },
    {
      label: '🔄 Refactor',
      template: `Refactor {function/component/module} to improve {readability/performance/maintainability}.

File: {file_path}
Current issue: {describe_problem}
Goal: {desired_outcome}

Requirements:
- Keep the same public interface (no breaking changes)
- Add types where missing
- Keep existing tests passing
- Add JSDoc for complex logic`
    },
    {
      label: '🧪 Write Tests',
      template: `Write {unit/integration/e2e} tests for {function/component/endpoint}.

Test framework: {jest/vitest/pytest/playwright}
File to test: {file_path}

Test cases to cover:
1. {happy_path}
2. {edge_case_1}
3. {edge_case_2}
4. {error_case}

Mocks needed: {list_dependencies_to_mock}
Coverage target: 80%+`
    },
    {
      label: '📝 Documentation',
      template: `Add documentation to {module/component/function}.

What to document:
- {item_1}: {what_it_does}
- {item_2}: {params_and_returns}

Format: {JSDoc/docstring/MDX}
Include: usage examples, parameter types, return values, edge cases.
Do not change any implementation code — documentation only.`
    },
  ];

  function analyzePrompt(prompt, stack) {
    return ANALYSIS_CHECKS.map(c => ({
      ...c,
      passed: c.check(prompt, stack)
    }));
  }

  function renderAnalysis(checks) {
    const passed = checks.filter(c => c.passed).length;
    const score = Math.round((passed / checks.length) * 100);
    const color = score >= 75 ? 'text-green-400' : score >= 50 ? 'text-yellow-400' : 'text-red-400';

    document.getElementById('analysis-panel').innerHTML = `
      <div class="flex items-center justify-between mb-3">
        <span class="text-sm font-medium">Prompt Quality</span>
        <span class="text-lg font-bold font-mono ${color}">${score}%</span>
      </div>
      <div class="space-y-1.5">
        ${checks.map(c => `
          <div class="flex items-start gap-2 text-xs">
            <span class="${c.passed ? 'text-green-400' : 'text-red-400'} shrink-0 mt-0.5">${c.passed ? '✓' : '✗'}</span>
            <div>
              <span class="${c.passed ? '' : 'text-text-muted'}">${c.label}</span>
              ${!c.passed ? `<div class="text-text-muted mt-0.5">${c.tip}</div>` : ''}
            </div>
          </div>
        `).join('')}
      </div>
    `;
  }

  function optimizePrompt(prompt, stack, tool) {
    const toolContexts = {
      'claude-code': 'You are using Claude Code CLI. Prefix with relevant context about the codebase.',
      'cursor': 'You are using Cursor IDE. Keep prompts focused and reference specific files.',
      'copilot': 'You are using GitHub Copilot. Inline comments and function-level prompts work best.',
      'windsurf': 'You are using Windsurf AI. Use the Cascade feature for multi-file operations.'
    };

    const checks = analyzePrompt(prompt, stack);
    const missing = checks.filter(c => !c.passed);

    let optimized = '';

    // Add stack context if missing
    if (stack && !checks.find(c => c.id === 'has_stack')?.passed) {
      optimized += `Tech stack: ${stack}\n\n`;
    } else if (stack) {
      optimized += `Tech stack: ${stack}\n\n`;
    }

    // Clean up the original prompt
    let cleanPrompt = prompt.trim();
    if (!/^[A-Z]/.test(cleanPrompt)) {
      cleanPrompt = cleanPrompt.charAt(0).toUpperCase() + cleanPrompt.slice(1);
    }
    if (!/^(add|build|create|implement|write|generate|refactor|fix|update|modify)/i.test(cleanPrompt)) {
      cleanPrompt = 'Implement ' + cleanPrompt.toLowerCase();
    }

    optimized += cleanPrompt;

    // Add structure if very short
    if (prompt.length < 100) {
      optimized += `\n\nRequirements:\n- Follow existing code patterns and conventions\n- Add appropriate error handling\n- Use TypeScript types/interfaces where applicable\n- Keep changes minimal and focused`;

      if (missing.find(c => c.id === 'has_constraints')) {
        optimized += `\n\nConstraints:\n- Do not break existing functionality\n- Do not add unnecessary dependencies`;
      }
    }

    // Add tool-specific tip
    if (toolContexts[tool]) {
      optimized += `\n\n// Tool tip: ${toolContexts[tool]}`;
    }

    return optimized;
  }

  document.getElementById('btn-optimize').addEventListener('click', () => {
    const prompt = document.getElementById('prompt-input').value.trim();
    const stack = document.getElementById('tech-stack').value.trim();
    const tool = document.getElementById('target-tool').value;
    if (!prompt) return;

    const checks = analyzePrompt(prompt, stack);
    renderAnalysis(checks);

    const optimized = optimizePrompt(prompt, stack, tool);
    document.getElementById('optimized-output').textContent = optimized;
    document.getElementById('output-section').classList.remove('hidden');
  });

  document.getElementById('btn-copy').addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('optimized-output').textContent).then(() => {
      const btn = document.getElementById('btn-copy');
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 1500);
    });
  });

  // Render templates
  document.getElementById('templates-grid').innerHTML = TEMPLATES.map((t, i) =>
    `<button class="tpl-btn text-left px-3 py-2 border border-border rounded-lg hover:border-primary hover:text-primary transition-all text-sm" data-idx="${i}">${t.label}</button>`
  ).join('');

  document.querySelectorAll('.tpl-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.getElementById('prompt-input').value = TEMPLATES[btn.dataset.idx].template;
    });
  });
})();
</script>

  <FaqSection faq={faq} />
</BaseLayout>
