---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonDiffViewer from '../../components/JsonDiffViewer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="JSON Diff Viewer"
  description="Compare two JSON objects side-by-side. Instantly highlight added, removed, and unchanged lines. Free, no signup, runs in your browser."
  tool="JSON Diff, JSON Compare, JSON Difference Checker"
>
  <h1 class="text-3xl font-bold mb-2">JSON Diff Viewer</h1>
  <p class="text-text-muted mb-8">Paste two JSON objects to instantly see what changed — added lines in green, removed in red. Auto-formats JSON for clean comparison.</p>
  <JsonDiffViewer client:load />
  <ToolPageCta currentTool="JSON Diff Viewer" relatedTags={['json', 'api', 'debugging', 'development']} />
</BaseLayout>
