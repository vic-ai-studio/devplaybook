---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonDiffViewer from '../../components/JsonDiffViewer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How do I compare two JSON objects?", answer: "Paste the first JSON into the left panel and the second into the right panel. The tool instantly highlights added lines in green, removed lines in red, and unchanged lines in gray — giving you a clear visual diff." },
  { question: "Does JSON Diff Viewer auto-format messy JSON?", answer: "Yes. Both panels automatically pretty-print your JSON before comparing, so even minified or inconsistently indented JSON is reformatted for a clean, readable diff. You don't need to format it yourself." },
  { question: "Is my JSON data sent to any server?", answer: "No. This tool runs entirely in your browser using JavaScript. Your JSON never leaves your machine, making it safe to use with API responses, configuration files, or any sensitive data." },
  { question: "Can I use this to compare API responses?", answer: "Absolutely. Paste two API responses side-by-side to see exactly what fields changed between requests or deployments. It's especially useful for debugging REST API contracts during development or testing." },
  { question: "What is the difference between JSON diff and JSON merge?", answer: "JSON diff shows the differences between two JSON documents — what was added, removed, or changed. JSON merge combines two objects, with one overwriting the other's conflicting keys. This tool focuses on diffing, not merging." },
];
---

<BaseLayout
  title="JSON Diff Viewer — Compare Two JSON Objects Online"
  description="Compare two JSON objects side-by-side. Color-coded highlights: added in green, removed in red. Auto-formats before comparing. Free, runs in your browser."
  tool="JSON Diff, JSON Compare, JSON Difference Checker, Compare JSON Objects, JSON Diff Viewer Online, API Response Diff, JSON Side by Side"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">JSON Diff Viewer</h1>
  <p class="text-text-muted mb-4">Paste two JSON objects to instantly see what changed — added lines in green, removed in red. Auto-formats JSON for clean comparison. Perfect for debugging API responses and config changes. Runs entirely in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <JsonDiffViewer client:load />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="JSON Diff Viewer" relatedTags={['json', 'api', 'debugging', 'development']} />
</BaseLayout>
