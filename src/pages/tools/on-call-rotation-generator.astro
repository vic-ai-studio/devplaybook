---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What rotation length is best for on-call schedules?", answer: "Weekly rotations are the most common and generally recommended for teams of 4+ engineers. They provide enough time for the on-call engineer to build context while limiting burnout. Biweekly rotations work for smaller teams (2-3 people) where weekly would mean too frequent rotation. Avoid rotations shorter than 5 days — context switching overhead outweighs any benefit." },
  { question: "How many engineers should be in an on-call rotation?", answer: "A healthy on-call rotation needs at least 4-6 engineers to avoid burnout. With 4 people on weekly rotations, each person is on-call roughly once a month. Fewer than 4 means too-frequent duty; more than 8 means engineers lose familiarity with the rotation cadence. For critical services, consider a primary + secondary (shadow) rotation." },
  { question: "Should on-call rotations be evenly distributed?", answer: "Yes, fairness is critical to preventing burnout and resentment. Ensure rotations cycle through team members evenly, including weekends. If some periods are inherently more stressful (e.g., after major releases), consider compensation or lighter duty periods. Track on-call hours and incidents per person over time to identify imbalances." },
  { question: "What is a shadow on-call rotation?", answer: "A shadow (secondary) rotation pairs a less experienced engineer with the primary on-call to provide learning opportunities without full responsibility. The shadow observes pages, joins incident calls, and can help with resolution. After 2-3 shadow rotations, engineers graduate to primary. This is excellent for onboarding new team members into SRE responsibilities." },
  { question: "How do you handle holidays and time-off in on-call rotations?", answer: "Build a swap process into your on-call policy: any engineer can swap their on-call week with another willing team member, with manager approval. Maintain a shared calendar for blackout dates. For holidays, consider offering compensatory time off equal to the holiday hours. Some teams create an explicit holiday rotation separate from the regular one." },
];
---

<BaseLayout
  title="On-Call Rotation Generator — Schedule Builder for Engineering Teams"
  description="Generate fair on-call rotation schedules for your engineering team. Supports weekly and biweekly rotations with customizable start dates, team size, and schedule length."
  tool="On-Call Rotation Generator, On-Call Schedule Builder, Engineering On-Call Planner, SRE Rotation Schedule, PagerDuty Schedule Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">On-Call Rotation Generator</h1>
  <p class="text-text-muted mb-4">Generate fair on-call rotation schedules for your team. Enter your engineers, pick a rotation cadence, and get a formatted schedule ready to share or import.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Weekly & biweekly rotations</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Fair team distribution</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-ready schedule table</span>
  </div>

  <!-- Configuration -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Rotation Configuration</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <label class="block text-sm font-medium mb-1.5">Team Members (one per line)</label>
        <textarea id="team-members" rows="8" placeholder="Alice Chen&#10;Bob Smith&#10;Carol Davis&#10;David Lee&#10;Eve Martinez&#10;Frank Wilson"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary">Alice Chen
Bob Smith
Carol Davis
David Lee
Eve Martinez
Frank Wilson</textarea>
      </div>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium mb-1.5">Rotation Type</label>
          <select id="rotation-type" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
            <option value="7">Weekly (7 days)</option>
            <option value="14">Biweekly (14 days)</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5">Start Date</label>
          <input id="start-date" type="date"
            class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5">Number of Periods to Generate</label>
          <input id="num-periods" type="number" value="12" min="1" max="52"
            class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5">Include Secondary (Shadow) On-Call?</label>
          <select id="include-secondary" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
            <option value="no">No</option>
            <option value="yes">Yes</option>
          </select>
        </div>
      </div>
    </div>
    <div class="mt-4">
      <button id="generate-btn" onclick="generate()"
        class="px-6 py-2 rounded-lg text-sm font-medium bg-primary text-white hover:opacity-90 transition-opacity">
        Generate Schedule
      </button>
    </div>
  </div>

  <!-- Stats -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-3">Distribution Stats</h2>
    <div id="stats-grid" class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
      <div class="bg-bg-card border border-border rounded-lg p-3 text-center">
        <div id="stat-engineers" class="text-2xl font-bold text-primary mb-1">6</div>
        <div class="text-xs text-text-muted">Engineers</div>
      </div>
      <div class="bg-bg-card border border-border rounded-lg p-3 text-center">
        <div id="stat-periods" class="text-2xl font-bold text-primary mb-1">12</div>
        <div class="text-xs text-text-muted">Total Periods</div>
      </div>
      <div class="bg-bg-card border border-border rounded-lg p-3 text-center">
        <div id="stat-per-person" class="text-2xl font-bold text-primary mb-1">2</div>
        <div class="text-xs text-text-muted">Periods/Person</div>
      </div>
      <div class="bg-bg-card border border-border rounded-lg p-3 text-center">
        <div id="stat-coverage" class="text-2xl font-bold text-primary mb-1">84d</div>
        <div class="text-xs text-text-muted">Coverage Days</div>
      </div>
    </div>
    <div id="distribution-bars" class="space-y-2"></div>
  </div>

  <!-- Schedule Table -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-base font-semibold">Schedule</h2>
      <button onclick="copySchedule()" class="text-xs px-3 py-1.5 rounded-lg border border-border hover:border-primary text-text-muted hover:text-primary transition-colors">Copy as Text</button>
    </div>
    <div id="schedule-table" class="overflow-x-auto"></div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="On-Call Rotation Generator" relatedTags={['devops', 'sre', 'oncall', 'team', 'scheduling']} />
</BaseLayout>

<script>
  let scheduleData: Array<{ period: number; start: string; end: string; primary: string; secondary: string }> = [];

  // Set default start date to next Monday
  const today = new Date();
  const day = today.getDay();
  const daysUntilMonday = day === 0 ? 1 : (8 - day) % 7 || 7;
  const nextMonday = new Date(today);
  nextMonday.setDate(today.getDate() + daysUntilMonday);
  (document.getElementById('start-date') as HTMLInputElement).value = nextMonday.toISOString().split('T')[0];

  function formatDate(d: Date): string {
    return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  }

  function addDays(d: Date, n: number): Date {
    const result = new Date(d);
    result.setDate(result.getDate() + n);
    return result;
  }

  (window as any).generate = function() {
    const membersRaw = (document.getElementById('team-members') as HTMLTextAreaElement).value;
    const members = membersRaw.split('\n').map(m => m.trim()).filter(Boolean);
    if (members.length < 2) {
      alert('Please enter at least 2 team members.');
      return;
    }

    const periodDays = parseInt((document.getElementById('rotation-type') as HTMLSelectElement).value);
    const startDateVal = (document.getElementById('start-date') as HTMLInputElement).value;
    const numPeriods = parseInt((document.getElementById('num-periods') as HTMLInputElement).value) || 12;
    const includeSecondary = (document.getElementById('include-secondary') as HTMLSelectElement).value === 'yes';

    const startDate = new Date(startDateVal + 'T00:00:00');
    scheduleData = [];

    for (let i = 0; i < numPeriods; i++) {
      const primaryIdx = i % members.length;
      const secondaryIdx = (i + 1) % members.length;
      const start = addDays(startDate, i * periodDays);
      const end = addDays(start, periodDays - 1);
      scheduleData.push({
        period: i + 1,
        start: formatDate(start),
        end: formatDate(end),
        primary: members[primaryIdx],
        secondary: includeSecondary ? members[secondaryIdx] : '',
      });
    }

    // Stats
    document.getElementById('stat-engineers')!.textContent = String(members.length);
    document.getElementById('stat-periods')!.textContent = String(numPeriods);
    document.getElementById('stat-per-person')!.textContent = (numPeriods / members.length).toFixed(1);
    document.getElementById('stat-coverage')!.textContent = `${numPeriods * periodDays}d`;

    // Distribution
    const counts: Record<string, number> = {};
    members.forEach(m => counts[m] = 0);
    scheduleData.forEach(s => counts[s.primary]++);
    const maxCount = Math.max(...Object.values(counts));
    document.getElementById('distribution-bars')!.innerHTML = members.map(m => {
      const pct = maxCount > 0 ? (counts[m] / maxCount) * 100 : 0;
      return `<div class="flex items-center gap-3 text-sm">
        <span class="w-32 text-text-muted truncate text-right text-xs">${m}</span>
        <div class="flex-1 bg-bg-card border border-border rounded-full h-2.5">
          <div class="bg-primary h-full rounded-full" style="width:${pct}%"></div>
        </div>
        <span class="w-8 font-mono text-xs">${counts[m]}x</span>
      </div>`;
    }).join('');

    // Table
    const headers = includeSecondary
      ? ['#', 'Start', 'End', 'Primary On-Call', 'Secondary (Shadow)']
      : ['#', 'Start', 'End', 'Primary On-Call'];
    document.getElementById('schedule-table')!.innerHTML = `
      <table class="w-full text-sm min-w-[400px]">
        <thead><tr class="text-text-muted text-xs uppercase border-b border-border">
          ${headers.map(h => `<th class="text-left pb-2 pr-4">${h}</th>`).join('')}
        </tr></thead>
        <tbody class="divide-y divide-border">
          ${scheduleData.map((row, i) => `<tr class="${i % 2 === 0 ? '' : 'bg-bg-card/50'}">
            <td class="py-2.5 pr-4 text-text-muted font-mono text-xs">${row.period}</td>
            <td class="py-2.5 pr-4 font-mono text-xs">${row.start}</td>
            <td class="py-2.5 pr-4 font-mono text-xs">${row.end}</td>
            <td class="py-2.5 pr-4 font-semibold">${row.primary}</td>
            ${includeSecondary ? `<td class="py-2.5 text-text-muted">${row.secondary}</td>` : ''}
          </tr>`).join('')}
        </tbody>
      </table>
    `;
  };

  (window as any).copySchedule = function() {
    if (scheduleData.length === 0) return;
    const lines = ['Period\tStart\tEnd\tPrimary On-Call\tSecondary'];
    scheduleData.forEach(r => lines.push(`${r.period}\t${r.start}\t${r.end}\t${r.primary}\t${r.secondary}`));
    navigator.clipboard.writeText(lines.join('\n')).then(() => {
      const btn = document.querySelector('[onclick="copySchedule()"]') as HTMLButtonElement;
      const orig = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = orig; }, 1500);
    });
  };

  // Auto-generate on input change
  document.getElementById('rotation-type')!.addEventListener('change', (window as any).generate);
  document.getElementById('start-date')!.addEventListener('change', (window as any).generate);
  document.getElementById('num-periods')!.addEventListener('input', (window as any).generate);
  document.getElementById('include-secondary')!.addEventListener('change', (window as any).generate);
  document.getElementById('team-members')!.addEventListener('input', (window as any).generate);

  (window as any).generate();
</script>
