---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Falco Rule Builder — Build Falco Security Rules for Runtime Threat Detection"
  description="Build Falco rules for Kubernetes and container runtime security. Create custom rules for detecting suspicious system calls, file access, network connections, and privilege escalation. Free, runs in browser."
  tool="Falco rule builder, Falco security rules, container runtime security, Kubernetes threat detection, syscall monitoring, CNCF Falco"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Falco Rule Builder",
    "url": "https://devplaybook.cc/tools/falco-rule-builder",
    "description": "Build Falco YAML rules for container runtime security. Detect suspicious syscalls, file access, network connections, and privilege escalation in Kubernetes.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Falco Rule Builder</h1>
  <p class="text-text-muted mb-4">
    Build <a href="https://falco.org" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">Falco</a> runtime security rules for detecting threats in containers and Kubernetes.
    Use presets for common attack patterns or build custom rules with macro and list support. Runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 8 threat detection presets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Custom rule builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Macros + lists + rules</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Priority + output format guide</span>
  </div>

  <!-- Tabs -->
  <div class="flex gap-2 mb-6 flex-wrap">
    <button id="tab-presets" class="tab-btn px-4 py-2 rounded-lg text-sm font-semibold bg-primary text-white transition-colors">Presets</button>
    <button id="tab-builder" class="tab-btn px-4 py-2 rounded-lg text-sm font-semibold bg-bg-card border border-border hover:border-primary transition-colors">Rule Builder</button>
    <button id="tab-editor" class="tab-btn px-4 py-2 rounded-lg text-sm font-semibold bg-bg-card border border-border hover:border-primary transition-colors">YAML Editor</button>
  </div>

  <!-- Presets Section -->
  <div id="section-presets">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
      <button data-preset="shell_spawn" class="preset-card p-4 bg-bg-card border border-border rounded-lg text-left hover:border-primary transition-colors group">
        <div class="text-lg mb-1">🐚</div>
        <div class="text-sm font-semibold mb-1 group-hover:text-primary">Shell Spawned in Container</div>
        <div class="text-xs text-text-muted">Detect interactive shell execution inside containers</div>
      </button>
      <button data-preset="write_binary" class="preset-card p-4 bg-bg-card border border-border rounded-lg text-left hover:border-primary transition-colors group">
        <div class="text-lg mb-1">📝</div>
        <div class="text-sm font-semibold mb-1 group-hover:text-primary">Write to Binary Directory</div>
        <div class="text-xs text-text-muted">Detect writes to /bin, /sbin, /usr/bin, etc.</div>
      </button>
      <button data-preset="outbound" class="preset-card p-4 bg-bg-card border border-border rounded-lg text-left hover:border-primary transition-colors group">
        <div class="text-lg mb-1">🌐</div>
        <div class="text-sm font-semibold mb-1 group-hover:text-primary">Unexpected Outbound Network</div>
        <div class="text-xs text-text-muted">Detect unexpected outbound connections from containers</div>
      </button>
      <button data-preset="privilege" class="preset-card p-4 bg-bg-card border border-border rounded-lg text-left hover:border-primary transition-colors group">
        <div class="text-lg mb-1">⚠️</div>
        <div class="text-sm font-semibold mb-1 group-hover:text-primary">Privilege Escalation</div>
        <div class="text-xs text-text-muted">Detect privilege escalation via sudo, su, SUID binaries</div>
      </button>
      <button data-preset="sensitive_file" class="preset-card p-4 bg-bg-card border border-border rounded-lg text-left hover:border-primary transition-colors group">
        <div class="text-lg mb-1">🔒</div>
        <div class="text-sm font-semibold mb-1 group-hover:text-primary">Sensitive File Access</div>
        <div class="text-xs text-text-muted">Detect reads to /etc/passwd, /etc/shadow, service tokens</div>
      </button>
      <button data-preset="crypto_miner" class="preset-card p-4 bg-bg-card border border-border rounded-lg text-left hover:border-primary transition-colors group">
        <div class="text-lg mb-1">⛏️</div>
        <div class="text-sm font-semibold mb-1 group-hover:text-primary">Crypto Miner Detection</div>
        <div class="text-xs text-text-muted">Detect common crypto mining processes and network patterns</div>
      </button>
      <button data-preset="k8s_audit" class="preset-card p-4 bg-bg-card border border-border rounded-lg text-left hover:border-primary transition-colors group">
        <div class="text-lg mb-1">☸️</div>
        <div class="text-sm font-semibold mb-1 group-hover:text-primary">K8s Audit Log Rules</div>
        <div class="text-xs text-text-muted">Detect K8s API anomalies: secret access, RBAC changes</div>
      </button>
      <button data-preset="file_integrity" class="preset-card p-4 bg-bg-card border border-border rounded-lg text-left hover:border-primary transition-colors group">
        <div class="text-lg mb-1">🛡️</div>
        <div class="text-sm font-semibold mb-1 group-hover:text-primary">File Integrity Monitor</div>
        <div class="text-xs text-text-muted">Monitor critical system file modifications</div>
      </button>
    </div>

    <div id="preset-output-section" class="hidden">
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <div class="flex justify-between items-center mb-3">
          <span id="preset-output-title" class="text-sm font-medium text-text-muted">Rule</span>
          <div class="flex gap-2">
            <button id="send-to-editor-btn" class="px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">Edit in YAML Editor</button>
            <button id="copy-preset-btn" class="px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">Copy</button>
          </div>
        </div>
        <pre id="preset-output" class="font-mono text-sm whitespace-pre-wrap break-words overflow-x-auto max-h-[500px] overflow-y-auto text-foreground"></pre>
      </div>
    </div>
  </div>

  <!-- Rule Builder Section -->
  <div id="section-builder" class="hidden">
    <div class="space-y-4 mb-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium mb-2">Rule Name</label>
          <input id="builder-name" type="text" value="Detect Suspicious Activity" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">Priority</label>
          <select id="builder-priority" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
            <option value="EMERGENCY">EMERGENCY</option>
            <option value="ALERT">ALERT</option>
            <option value="CRITICAL">CRITICAL</option>
            <option value="ERROR">ERROR</option>
            <option value="WARNING" selected>WARNING</option>
            <option value="NOTICE">NOTICE</option>
            <option value="INFORMATIONAL">INFORMATIONAL</option>
            <option value="DEBUG">DEBUG</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">Event Type</label>
          <select id="builder-event" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
            <option value="execve">execve (process execution)</option>
            <option value="open">open (file open)</option>
            <option value="openat">openat (file open relative)</option>
            <option value="write">write (file write)</option>
            <option value="connect">connect (network connect)</option>
            <option value="accept">accept (network accept)</option>
            <option value="clone">clone (process fork)</option>
            <option value="setuid">setuid (privilege change)</option>
            <option value="socket">socket (socket creation)</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">Output Format</label>
          <input id="builder-output" type="text" value="Suspicious activity detected (user=%user.name cmd=%proc.cmdline container=%container.id)" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary font-mono text-xs" />
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium mb-2">Description</label>
        <input id="builder-desc" type="text" value="Detect suspicious activity in containers" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
      </div>

      <div>
        <label class="block text-sm font-medium mb-2">Condition</label>
        <textarea id="builder-condition" rows="4" spellcheck="false" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary resize-y" placeholder="spawned_process and container and proc.name in (bash, sh, zsh)"></textarea>
        <p class="text-xs text-text-muted mt-1">Use Falco fields: proc.name, fd.filename, user.name, container.id, k8s.pod.name, etc.</p>
      </div>

      <div>
        <label class="block text-sm font-medium mb-2">Tags (comma-separated)</label>
        <input id="builder-tags" type="text" value="process,container,security" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
      </div>

      <div class="flex items-center gap-3">
        <input type="checkbox" id="builder-enabled" checked class="rounded" />
        <label for="builder-enabled" class="text-sm">Rule enabled</label>
        <input type="checkbox" id="builder-warn-evttypes" class="rounded ml-4" />
        <label for="builder-warn-evttypes" class="text-sm">warn_evttypes: false</label>
      </div>
    </div>

    <button id="btn-build" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors mb-4">Build Rule</button>

    <div id="builder-output-section" class="hidden">
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <div class="flex justify-between items-center mb-3">
          <span class="text-sm font-medium text-text-muted">Custom Rule</span>
          <button id="copy-builder-btn" class="px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">Copy</button>
        </div>
        <pre id="builder-output" class="font-mono text-sm whitespace-pre-wrap break-words overflow-x-auto max-h-[400px] overflow-y-auto text-foreground"></pre>
      </div>
    </div>
  </div>

  <!-- YAML Editor Section -->
  <div id="section-editor" class="hidden">
    <p class="text-sm text-text-muted mb-3">Edit Falco rules YAML directly. Validate syntax and get feedback.</p>
    <textarea id="yaml-editor" rows="25" spellcheck="false" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary resize-y mb-4" placeholder="# Paste or type your Falco rules YAML here"></textarea>
    <div class="flex gap-3 mb-4">
      <button id="btn-validate-yaml" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Validate</button>
      <button id="btn-copy-yaml" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Copy</button>
      <button id="btn-clear-yaml" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Clear</button>
    </div>
    <div id="yaml-validation-result" class="hidden mb-4 p-3 rounded-lg text-sm"></div>
  </div>

  <ToolPageCta currentTool="Falco Rule Builder" relatedTags={['security', 'kubernetes', 'container', 'runtime-security', 'devops', 'monitoring']} />
</BaseLayout>

<script is:inline>
  // Tab switching
  function switchTab(active) {
    ['presets', 'builder', 'editor'].forEach(t => {
      document.getElementById('tab-' + t).className = t === active
        ? 'tab-btn px-4 py-2 rounded-lg text-sm font-semibold bg-primary text-white transition-colors'
        : 'tab-btn px-4 py-2 rounded-lg text-sm font-semibold bg-bg-card border border-border hover:border-primary transition-colors';
      document.getElementById('section-' + t).classList.toggle('hidden', t !== active);
    });
  }
  ['presets','builder','editor'].forEach(t => {
    document.getElementById('tab-' + t).addEventListener('click', () => switchTab(t));
  });

  const PRESET_RULES = {
    shell_spawn: {
      title: 'Shell Spawned in Container',
      yaml: `# Detect a shell spawned inside a container
- list: shell_binaries
  items: [ash, bash, csh, ksh, sh, tcsh, zsh, dash]

- macro: shell_procs
  condition: proc.name in (shell_binaries)

- rule: Terminal Shell in Container
  desc: A shell was spawned by a non-shell program in a container.
      Container environments frequently forbid user terminals.
  condition: >
    spawned_process
    and container
    and shell_procs
    and proc.tty != 0
    and not proc.pname in (shell_binaries)
  output: >
    A shell was spawned in a container with an attached terminal
    (user=%user.name user_loginuid=%user.loginuid
    k8s.pod=%k8s.pod.name container=%container.id
    shell=%proc.name parent=%proc.pname
    cmdline=%proc.cmdline terminal=%proc.tty
    container_id=%container.id image=%container.image.repository)
  priority: WARNING
  tags: [container, shell, mitre_execution]
`
    },
    write_binary: {
      title: 'Write to Binary Directory',
      yaml: `# Detect file writes to system binary directories
- list: binary_dirs
  items: [/bin, /sbin, /usr/bin, /usr/sbin, /usr/local/bin, /usr/local/sbin]

- macro: bin_dir
  condition: fd.directory in (binary_dirs)

- rule: Write Binary Dir
  desc: An attempt to write to any file below a set of binary directories.
  condition: >
    bin_dir
    and evt.dir = <
    and open_write
    and not proc.name in (package_mgmt_binaries)
    and not container.image.repository in (known_setuid_binaries)
  output: >
    File below a known binary directory opened for writing
    (user=%user.name user_loginuid=%user.loginuid
    command=%proc.cmdline
    file=%fd.name
    container_id=%container.id
    image=%container.image.repository)
  priority: ERROR
  tags: [filesystem, mitre_persistence]

- macro: open_write
  condition: (evt.type=open or evt.type=openat or evt.type=openat2) and evt.is_open_write=true and fd.typechar='f' and fd.num>=0

- list: package_mgmt_binaries
  items: [dpkg, apt, apt-get, yum, rpm, pip, pip3, npm, yarn]
`
    },
    outbound: {
      title: 'Unexpected Outbound Network',
      yaml: `# Detect unexpected outbound network connections
- list: allowed_outbound_ports
  items: [80, 443, 53, 8080, 8443]

- macro: outbound
  condition: >
    (((evt.type = connect and evt.dir=<) or
     (evt.type = sendto and evt.dir=<)) and
    (fd.typechar = 4 or fd.typechar = 6) and
    (fd.ip != "0.0.0.0" and fd.net != "127.0.0.0/8") and
    (evt.rawres >= 0 or evt.res = EINPROGRESS))

- rule: Unexpected Outbound Connection Destination
  desc: Detect outbound connections to unexpected destinations.
  condition: >
    outbound
    and container
    and not fd.sport in (allowed_outbound_ports)
    and not fd.rip.name in (trusted_dns_servers)
  output: >
    Unexpected outbound connection destination
    (user=%user.name
    command=%proc.cmdline
    connection=%fd.name
    container_id=%container.id
    image=%container.image.repository
    k8s.pod=%k8s.pod.name)
  priority: NOTICE
  tags: [network, container, mitre_command_and_control]

- list: trusted_dns_servers
  items: ["8.8.8.8", "8.8.4.4", "1.1.1.1"]
`
    },
    privilege: {
      title: 'Privilege Escalation',
      yaml: `# Detect privilege escalation attempts
- list: priv_esc_binaries
  items: [sudo, su, newgrp, newuidmap, newgidmap]

- macro: setuid_process
  condition: proc.name in (priv_esc_binaries)

- rule: SUID/SGID Execution in Container
  desc: Detect execution of setuid/setgid binaries that could escalate privileges.
  condition: >
    spawned_process
    and container
    and (proc.is_suid=true or proc.is_sgid=true)
    and not proc.name in (known_suid_binaries)
  output: >
    SUID/SGID binary executed in container
    (user=%user.name user_loginuid=%user.loginuid
    parent=%proc.pname
    cmdline=%proc.cmdline
    uid=%user.uid euid=%user.euid
    container_id=%container.id
    image=%container.image.repository)
  priority: WARNING
  tags: [users, mitre_privilege_escalation]

- rule: Sudo Execution in Container
  desc: Detect sudo or su usage in containers (often indicates misconfiguration).
  condition: >
    spawned_process
    and container
    and setuid_process
  output: >
    Privilege escalation binary run in container
    (user=%user.name
    cmd=%proc.cmdline
    container=%container.id
    image=%container.image.repository)
  priority: WARNING
  tags: [container, users, mitre_privilege_escalation]

- list: known_suid_binaries
  items: [fusermount, mount, ping, su, sudo, unix_chkpwd]
`
    },
    sensitive_file: {
      title: 'Sensitive File Access',
      yaml: `# Detect access to sensitive system files
- list: sensitive_files
  items:
    - /etc/shadow
    - /etc/sudoers
    - /etc/sudoers.d
    - /proc/*/mem
    - /etc/pam.conf
    - /etc/pam.d

- list: sensitive_file_names
  items: [.bash_history, .ssh/config, .ssh/id_rsa, .ssh/id_ecdsa, .aws/credentials]

- macro: sensitive_file_opened
  condition: >
    fd.name in (sensitive_files) or
    fd.filename in (sensitive_file_names)

- rule: Read Sensitive File Untrusted
  desc: An attempt to read any sensitive file (e.g. files containing user/password/authentication information).
  condition: >
    open_read
    and sensitive_file_opened
    and not proc.name in (userspace_tools)
    and not container.image.repository in (trusted_images)
  output: >
    Sensitive file opened for reading by non-trusted program
    (user=%user.name user_loginuid=%user.loginuid
    program=%proc.name
    command=%proc.cmdline
    file=%fd.name
    container_id=%container.id
    image=%container.image.repository)
  priority: WARNING
  tags: [filesystem, mitre_credential_access]

- macro: open_read
  condition: (evt.type=open or evt.type=openat or evt.type=openat2) and evt.is_open_read=true and fd.typechar='f' and fd.num>=0

- list: userspace_tools
  items: [passwd, login, sudo, sshd, pam_unix.so]

- list: trusted_images
  items: [docker.io/library/ubuntu, docker.io/library/debian]

- rule: Service Account Token Read
  desc: Detect reading of Kubernetes service account token.
  condition: >
    open_read
    and fd.name startswith /var/run/secrets/kubernetes.io/serviceaccount/token
    and not proc.name in (known_k8s_clients)
  output: >
    K8s service account token read
    (user=%user.name
    cmd=%proc.cmdline
    container=%container.id
    image=%container.image.repository)
  priority: WARNING
  tags: [k8s, mitre_credential_access]

- list: known_k8s_clients
  items: [kubectl, kubelet, kube-proxy, fluentd, prometheus]
`
    },
    crypto_miner: {
      title: 'Crypto Miner Detection',
      yaml: `# Detect cryptocurrency mining activity
- list: miner_binaries
  items: [xmrig, xmr-stak, cpuminer, ccminer, cgminer, bfgminer,
          minerd, ethminer, t-rex, phoenixminer, nbminer]

- list: miner_domains
  items: [pool.minexmr.com, moneroocean.stream, c3pool.com,
          xmrpool.eu, supportxmr.com, nanopool.org, f2pool.com]

- list: miner_ports
  items: [3333, 4444, 5555, 7777, 8888, 9999, 14444, 45560]

- rule: Crypto Miner Process Detected
  desc: Detect execution of known cryptocurrency mining binaries.
  condition: >
    spawned_process
    and proc.name in (miner_binaries)
  output: >
    Crypto miner process detected
    (user=%user.name
    cmdline=%proc.cmdline
    container=%container.id
    image=%container.image.repository
    k8s.pod=%k8s.pod.name)
  priority: CRITICAL
  tags: [process, container, mitre_impact]

- rule: Outbound Connection to Mining Pool
  desc: Detect outbound connections to known cryptocurrency mining pools.
  condition: >
    outbound
    and (fd.sport in (miner_ports) or
         fd.rip.name in (miner_domains))
  output: >
    Outbound connection to possible crypto mining pool
    (user=%user.name
    connection=%fd.name
    cmdline=%proc.cmdline
    container=%container.id
    image=%container.image.repository)
  priority: CRITICAL
  tags: [network, mitre_impact]

- macro: outbound
  condition: >
    (evt.type = connect and evt.dir=<) and
    (fd.typechar = 4 or fd.typechar = 6) and
    (fd.ip != "0.0.0.0" and fd.net != "127.0.0.0/8")
`
    },
    k8s_audit: {
      title: 'K8s Audit Log Rules',
      yaml: `# Falco K8s Audit Log rules
# Requires k8s_audit plugin or audit log webhook
- rule: K8s Secret Get/List
  desc: Detect attempts to read or list K8s Secrets.
  condition: >
    ka.verb in (get, list, watch)
    and ka.target.resource = secrets
    and not ka.user.name in (system:kube-controller-manager, system:node)
    and not ka.user.groups intersects (system:nodes)
  output: >
    K8s Secrets accessed (user=%ka.user.name
    verb=%ka.verb
    resource=%ka.target.resource
    ns=%ka.target.namespace
    name=%ka.target.name)
  priority: WARNING
  tags: [k8s, mitre_credential_access]

- rule: K8s ClusterRole Binding Created
  desc: Detect creation of ClusterRoleBindings (could indicate privilege escalation).
  condition: >
    ka.verb = create
    and ka.target.resource = clusterrolebindings
    and not ka.user.name in (system:kube-controller-manager)
  output: >
    ClusterRoleBinding created
    (user=%ka.user.name
    binding=%ka.target.name
    role=%jevt.value[/requestObject/roleRef/name])
  priority: WARNING
  tags: [k8s, mitre_privilege_escalation]

- rule: Exec Into Container
  desc: Detect exec or attach into a running container (kubectl exec/attach).
  condition: >
    ka.verb in (create)
    and ka.uri.param[subresource] in (exec, attach)
    and ka.target.resource = pods
    and not ka.user.name in (system:serviceaccount:kube-system:)
  output: >
    Exec/Attach into pod
    (user=%ka.user.name
    pod=%ka.target.name
    ns=%ka.target.namespace
    command=%ka.uri.param[command])
  priority: NOTICE
  tags: [k8s, mitre_execution]

- rule: K8s Anonymous Request
  desc: Detect anonymous requests to the API server.
  condition: >
    ka.user.name = system:anonymous
    and not ka.uri startswith /healthz
    and not ka.uri startswith /livez
    and not ka.uri startswith /readyz
  output: >
    Anonymous request to K8s API
    (uri=%ka.uri verb=%ka.verb)
  priority: ERROR
  tags: [k8s, mitre_initial_access]
`
    },
    file_integrity: {
      title: 'File Integrity Monitor',
      yaml: `# File Integrity Monitoring rules
- list: fim_monitored_files
  items:
    - /etc/passwd
    - /etc/group
    - /etc/hosts
    - /etc/hostname
    - /etc/resolv.conf
    - /etc/ssh/sshd_config
    - /etc/crontab
    - /etc/cron.d
    - /etc/sudoers

- macro: open_write
  condition: >
    (evt.type=open or evt.type=openat or evt.type=openat2)
    and evt.is_open_write=true
    and fd.typechar='f'
    and fd.num>=0

- rule: System File Modified
  desc: Critical system file was modified.
  condition: >
    open_write
    and fd.name in (fim_monitored_files)
    and not proc.name in (trusted_file_editors)
  output: >
    System file modified
    (user=%user.name user_loginuid=%user.loginuid
    command=%proc.cmdline
    file=%fd.name
    container_id=%container.id
    image=%container.image.repository)
  priority: ERROR
  tags: [filesystem, mitre_persistence, FIM]

- rule: Cron File Modified
  desc: Cron configuration file modified.
  condition: >
    open_write
    and (fd.name startswith /etc/cron or
         fd.name startswith /var/spool/cron)
    and not proc.name in (trusted_file_editors)
  output: >
    Cron file modified
    (user=%user.name
    cmd=%proc.cmdline
    file=%fd.name
    container_id=%container.id)
  priority: WARNING
  tags: [filesystem, mitre_persistence, FIM]

- rule: SSH Config Modified
  desc: SSH server configuration was modified.
  condition: >
    open_write
    and fd.name startswith /etc/ssh/
  output: >
    SSH configuration modified
    (user=%user.name
    cmd=%proc.cmdline
    file=%fd.name)
  priority: WARNING
  tags: [filesystem, network, mitre_lateral_movement, FIM]

- list: trusted_file_editors
  items: [chef-client, puppet, ansible, salt-minion, cfengine]
`
    }
  };

  document.querySelectorAll('.preset-card').forEach(card => {
    card.addEventListener('click', function () {
      const key = this.dataset.preset;
      const preset = PRESET_RULES[key];
      if (!preset) return;
      document.getElementById('preset-output-title').textContent = preset.title;
      document.getElementById('preset-output').textContent = preset.yaml.trim();
      document.getElementById('preset-output-section').classList.remove('hidden');
      document.getElementById('preset-output-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  document.getElementById('copy-preset-btn').addEventListener('click', function () {
    navigator.clipboard.writeText(document.getElementById('preset-output').textContent).then(() => {
      this.textContent = 'Copied!'; setTimeout(() => { this.textContent = 'Copy'; }, 2000);
    });
  });

  document.getElementById('send-to-editor-btn').addEventListener('click', function () {
    const yaml = document.getElementById('preset-output').textContent;
    document.getElementById('yaml-editor').value = yaml;
    switchTab('editor');
  });

  // Rule Builder
  document.getElementById('btn-build').addEventListener('click', () => {
    const name = document.getElementById('builder-name').value.trim() || 'My Custom Rule';
    const priority = document.getElementById('builder-priority').value;
    const desc = document.getElementById('builder-desc').value.trim() || 'Custom Falco rule';
    const condition = document.getElementById('builder-condition').value.trim() || 'spawned_process and container';
    const output = document.getElementById('builder-output').value.trim() || 'Event detected (user=%user.name cmdline=%proc.cmdline container=%container.id)';
    const tags = document.getElementById('builder-tags').value.split(',').map(t => t.trim()).filter(Boolean);
    const enabled = document.getElementById('builder-enabled').checked;
    const warnEvt = document.getElementById('builder-warn-evttypes').checked;

    let yaml = `- rule: ${name}\n`;
    yaml += `  desc: ${desc}\n`;
    yaml += `  condition: >\n    ${condition}\n`;
    yaml += `  output: >\n    ${output}\n`;
    yaml += `  priority: ${priority}\n`;
    if (!enabled) yaml += `  enabled: false\n`;
    if (warnEvt) yaml += `  warn_evttypes: false\n`;
    if (tags.length > 0) yaml += `  tags: [${tags.join(', ')}]\n`;

    document.getElementById('builder-output').textContent = yaml.trim();
    document.getElementById('builder-output-section').classList.remove('hidden');
  });

  document.getElementById('copy-builder-btn').addEventListener('click', function () {
    navigator.clipboard.writeText(document.getElementById('builder-output').textContent).then(() => {
      this.textContent = 'Copied!'; setTimeout(() => { this.textContent = 'Copy'; }, 2000);
    });
  });

  // YAML Editor
  document.getElementById('btn-validate-yaml').addEventListener('click', () => {
    const yaml = document.getElementById('yaml-editor').value.trim();
    const result = document.getElementById('yaml-validation-result');

    if (!yaml) {
      result.className = 'mb-4 p-3 rounded-lg text-sm bg-orange-900/20 border border-orange-800 text-orange-300';
      result.textContent = 'Editor is empty.';
      result.classList.remove('hidden');
      return;
    }

    const issues = [];

    // Check for required rule fields
    const ruleBlocks = [...yaml.matchAll(/^- rule:/gm)];
    for (const _match of ruleBlocks) {
      if (!yaml.includes('  condition:')) issues.push('Rule missing required "condition" field');
      if (!yaml.includes('  output:')) issues.push('Rule missing required "output" field');
      if (!yaml.includes('  priority:')) issues.push('Rule missing required "priority" field');
    }

    // Check for valid priority values
    const priorityMatch = yaml.match(/priority:\s*(\w+)/g);
    const validPriorities = ['EMERGENCY','ALERT','CRITICAL','ERROR','WARNING','NOTICE','INFORMATIONAL','DEBUG'];
    if (priorityMatch) {
      for (const p of priorityMatch) {
        const val = p.split(':')[1].trim();
        if (!validPriorities.includes(val)) {
          issues.push(`Invalid priority value: "${val}". Must be one of: ${validPriorities.join(', ')}`);
        }
      }
    }

    // Check for unmatched quotes
    const singleQuotes = (yaml.match(/'/g) || []).length;
    if (singleQuotes % 2 !== 0) issues.push('Possible unmatched single quotes');

    if (issues.length === 0) {
      result.className = 'mb-4 p-3 rounded-lg text-sm bg-green-900/20 border border-green-800 text-green-300';
      result.textContent = `✓ YAML looks valid. Found ${ruleBlocks.length} rule(s).`;
    } else {
      result.className = 'mb-4 p-3 rounded-lg text-sm bg-red-900/20 border border-red-800 text-red-300';
      result.innerHTML = '✗ Issues found:\n• ' + issues.join('\n• ');
    }
    result.classList.remove('hidden');
  });

  document.getElementById('btn-copy-yaml').addEventListener('click', function () {
    navigator.clipboard.writeText(document.getElementById('yaml-editor').value).then(() => {
      this.textContent = 'Copied!'; setTimeout(() => { this.textContent = 'Copy'; }, 2000);
    });
  });

  document.getElementById('btn-clear-yaml').addEventListener('click', () => {
    document.getElementById('yaml-editor').value = '';
    document.getElementById('yaml-validation-result').classList.add('hidden');
  });
</script>
