---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AiPrDescriptionGenerator from '../../components/AiPrDescriptionGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="AI PR Description Generator — Generate Pull Request Descriptions Instantly"
  description="Enter your branch name and commit messages to generate a complete pull request description with summary, change list, type label, and testing checklist. Works with GitHub, GitLab, and Bitbucket."
  tool="AI PR Description Generator, Pull Request Description Generator, PR Template Generator, GitHub PR Generator"
>
  <h1 class="text-3xl font-bold mb-2">AI PR Description Generator</h1>
  <p class="text-text-muted mb-8">
    Paste your branch name and commit messages to instantly generate a complete pull request description —
    including summary, change type, change list, testing steps, and a reviewer checklist.
    Works with GitHub, GitLab, and Bitbucket. Runs entirely in your browser.
  </p>
  <AiPrDescriptionGenerator client:load />
  <ToolPageCta currentTool="AI PR Description Generator" relatedTags={['ai', 'git', 'developer-tools', 'productivity']} />
</BaseLayout>
