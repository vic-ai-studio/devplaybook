---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is NativeWind and how does it relate to Tailwind CSS?",
    answer: "NativeWind is a library that brings Tailwind CSS utility classes to React Native. It uses the Tailwind CSS compiler to generate styles at build time, then applies them via React Native's StyleSheet API. This means you can write className='text-lg font-bold text-blue-500' in your RN components just like in web development, rather than using StyleSheet.create() objects."
  },
  {
    question: "Do all Tailwind classes work in React Native with NativeWind?",
    answer: "Not all Tailwind classes have RN equivalents. Supported: text size/color/weight, background color, margin, padding, flex, border radius, width, height, opacity. Unsupported: box shadows (limited), some pseudo-classes (:hover works on some platforms), CSS grid (use flex instead), transition animations (use Animated API or Reanimated). NativeWind v4 improved coverage significantly."
  },
  {
    question: "What is the difference between margin and padding in React Native vs CSS?",
    answer: "In React Native, margin and padding work the same as CSS but with shorthand differences. RN accepts individual sides (marginTop, paddingLeft) and uses camelCase. There's no shorthand like margin: '8px 16px' — you must set each side separately or use marginVertical/marginHorizontal. Tailwind shorthand like m-2 (margin on all sides) translates to margin: 8 in RN."
  },
  {
    question: "How do colors work differently in React Native vs web Tailwind?",
    answer: "React Native accepts hex (#333333), rgb(), rgba(), and named colors. Tailwind color classes like text-blue-500 map to specific hex values (e.g., #3b82f6). When converting, the tool maps Tailwind color names to their hex values. In NativeWind, you can use Tailwind color utilities directly. Custom colors defined in tailwind.config.js work the same in both environments."
  },
  {
    question: "What is the best approach for responsive styles in React Native?",
    answer: "React Native doesn't have CSS media queries. Common approaches: 1) Dimensions API — get screen width/height and compute styles. 2) useWindowDimensions hook for reactive updates. 3) Platform.select() for iOS vs Android differences. 4) NativeWind's breakpoint system (sm:, md:, lg:) maps to device width breakpoints. For most cases, flexbox with flex-wrap handles responsive layouts without explicit breakpoints."
  }
];
---

<BaseLayout
  title="React Native StyleSheet to Tailwind Converter — NativeWind Class Generator"
  description="Convert React Native StyleSheet objects to Tailwind CSS / NativeWind classes and vice versa. Supports fontSize, color, margin, padding, flex, borderRadius, and more. Free browser tool."
  tool="react native to tailwind, nativewind converter, stylesheet to tailwind, react native style converter, rn styles to css"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "React Native StyleSheet to Tailwind Converter",
    "url": "https://devplaybook.cc/tools/react-native-style-converter",
    "description": "Convert React Native StyleSheet objects to Tailwind CSS / NativeWind classes and vice versa. Supports all major style properties.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">React Native ↔ Tailwind Converter</h1>
  <p class="text-text-muted mb-4">
    Convert React Native StyleSheet objects to Tailwind / NativeWind classes and back.
    Paste a style object JSON to get equivalent utility classes, or enter class names to get RN styles.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> RN → Tailwind conversion</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Tailwind → RN conversion</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> NativeWind className output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 30+ supported properties</span>
  </div>

  <!-- Mode toggle -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <div class="flex gap-2 mb-4">
      <button id="btn-rn-to-tw" class="mode-btn px-4 py-2 rounded-lg text-sm font-medium bg-primary text-white transition-colors">RN → Tailwind</button>
      <button id="btn-tw-to-rn" class="mode-btn px-4 py-2 rounded-lg text-sm font-medium bg-surface border border-border text-text-muted hover:border-primary transition-colors">Tailwind → RN</button>
    </div>

    <div id="panel-rn-to-tw">
      <label class="block text-sm font-medium mb-2">React Native Style Object (JSON)</label>
      <textarea id="rn-input" rows="8" placeholder='{
  "fontSize": 16,
  "color": "#333333",
  "backgroundColor": "#f0f4ff",
  "marginTop": 8,
  "paddingHorizontal": 16,
  "borderRadius": 8,
  "fontWeight": "bold",
  "flex": 1
}' class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary resize-none"></textarea>
    </div>

    <div id="panel-tw-to-rn" class="hidden">
      <label class="block text-sm font-medium mb-2">Tailwind / NativeWind Classes</label>
      <input id="tw-input" type="text" placeholder="text-base text-gray-800 bg-blue-50 mt-2 px-4 rounded-lg font-bold flex-1" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
    </div>

    <button id="convert-btn" class="mt-3 px-5 py-2 bg-primary text-white rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors">Convert</button>
  </div>

  <!-- Output -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-sm font-medium" id="out-label-1">Tailwind Classes</h2>
        <button id="copy-tw" class="text-xs text-text-muted hover:text-foreground transition-colors">Copy</button>
      </div>
      <div id="output-tw" class="font-mono text-sm text-accent bg-surface rounded p-3 min-h-[80px] break-all"></div>
    </div>
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-sm font-medium" id="out-label-2">NativeWind className</h2>
        <button id="copy-nw" class="text-xs text-text-muted hover:text-foreground transition-colors">Copy</button>
      </div>
      <div id="output-nw" class="font-mono text-sm text-accent bg-surface rounded p-3 min-h-[80px] break-all"></div>
    </div>
  </div>

  <!-- Unmapped properties -->
  <div id="unmapped-container" class="hidden bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-medium mb-2 text-yellow-400">Properties Without Direct Tailwind Equivalent</h2>
    <div id="unmapped-list" class="text-sm font-mono text-text-muted space-y-1"></div>
  </div>

  <!-- Quick reference -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-medium mb-3">Common Mappings Reference</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2" id="ref-grid"></div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="React Native Style Converter" relatedTags={['react-native', 'tailwind', 'nativewind', 'mobile', 'css']} />
</BaseLayout>

<script is:inline>
(function() {
  // RN prop -> Tailwind class mapping functions
  const TAILWIND_COLORS = {
    '#000000': 'black', '#ffffff': 'white', '#f9fafb': 'gray-50',
    '#f3f4f6': 'gray-100', '#e5e7eb': 'gray-200', '#d1d5db': 'gray-300',
    '#9ca3af': 'gray-400', '#6b7280': 'gray-500', '#4b5563': 'gray-600',
    '#374151': 'gray-700', '#1f2937': 'gray-800', '#111827': 'gray-900',
    '#333333': 'gray-800', '#666666': 'gray-500', '#999999': 'gray-400',
    '#eff6ff': 'blue-50', '#dbeafe': 'blue-100', '#bfdbfe': 'blue-200',
    '#93c5fd': 'blue-300', '#60a5fa': 'blue-400', '#3b82f6': 'blue-500',
    '#2563eb': 'blue-600', '#1d4ed8': 'blue-700', '#1e40af': 'blue-800',
    '#f0f9ff': 'sky-50', '#e0f2fe': 'sky-100', '#0ea5e9': 'sky-500',
    '#f0fdf4': 'green-50', '#dcfce7': 'green-100', '#22c55e': 'green-500',
    '#16a34a': 'green-600', '#15803d': 'green-700',
    '#fef2f2': 'red-50', '#fee2e2': 'red-100', '#ef4444': 'red-500',
    '#dc2626': 'red-600', '#b91c1c': 'red-700',
    '#fffbeb': 'yellow-50', '#fef3c7': 'yellow-100', '#f59e0b': 'yellow-500',
    '#d97706': 'yellow-600', '#ffa500': 'orange-400',
    '#f0f4ff': 'blue-50', '#e8f5e9': 'green-50',
  };

  const TW_COLOR_TO_HEX = Object.fromEntries(Object.entries(TAILWIND_COLORS).map(([k,v]) => [v, k]));

  function nearestTailwindColor(hex) {
    if (!hex || hex === 'transparent') return null;
    const h = hex.toLowerCase();
    if (TAILWIND_COLORS[h]) return TAILWIND_COLORS[h];
    // Try to parse and find nearest
    const r = parseInt(h.slice(1,3),16), g = parseInt(h.slice(3,5),16), b = parseInt(h.slice(5,7),16);
    if (isNaN(r)) return null;
    let best = null, bestDist = Infinity;
    for (const [k, v] of Object.entries(TAILWIND_COLORS)) {
      const kr = parseInt(k.slice(1,3),16), kg = parseInt(k.slice(3,5),16), kb = parseInt(k.slice(5,7),16);
      const d = Math.sqrt((r-kr)**2+(g-kg)**2+(b-kb)**2);
      if (d < bestDist) { bestDist = d; best = v; }
    }
    return best;
  }

  const SPACING_MAP = {
    0: '0', 1: 'px', 2: '0.5', 4: '1', 6: '1.5', 8: '2', 10: '2.5',
    12: '3', 14: '3.5', 16: '4', 20: '5', 24: '6', 28: '7', 32: '8',
    36: '9', 40: '10', 44: '11', 48: '12', 56: '14', 64: '16',
    80: '20', 96: '24', 112: '28', 128: '32', 160: '40', 192: '48',
    224: '56', 256: '64', 288: '72', 320: '80', 384: '96'
  };

  function nearestSpacing(val) {
    if (val === 0) return '0';
    let best = null, bestDiff = Infinity;
    for (const [px, cls] of Object.entries(SPACING_MAP)) {
      const diff = Math.abs(val - parseInt(px));
      if (diff < bestDiff) { bestDiff = diff; best = cls; }
    }
    return best;
  }

  const FONT_SIZE_MAP = {
    10: 'xs', 12: 'xs', 14: 'sm', 16: 'base', 18: 'lg', 20: 'xl',
    24: '2xl', 28: '3xl', 30: '3xl', 32: '3xl', 36: '4xl', 40: '4xl', 48: '5xl', 60: '6xl', 72: '7xl'
  };
  const FONT_WEIGHT_MAP = {
    '100': 'thin', '200': 'extralight', '300': 'light', '400': 'normal',
    '500': 'medium', '600': 'semibold', '700': 'bold', '800': 'extrabold',
    '900': 'black', 'thin': 'thin', 'light': 'light', 'normal': 'normal',
    'medium': 'medium', 'semibold': 'semibold', 'bold': 'bold', 'heavy': 'extrabold'
  };
  const BORDER_RADIUS_MAP = {
    0: 'none', 2: 'sm', 4: '', 6: 'md', 8: 'lg', 12: 'xl', 16: '2xl', 24: '3xl', 9999: 'full'
  };

  function rnToTailwind(styleObj) {
    const classes = [];
    const unmapped = {};

    for (const [prop, val] of Object.entries(styleObj)) {
      switch(prop) {
        case 'fontSize': {
          const sizes = Object.keys(FONT_SIZE_MAP).map(Number).sort((a,b)=>a-b);
          const nearest = sizes.reduce((prev, cur) => Math.abs(cur - val) < Math.abs(prev - val) ? cur : prev);
          const tw = FONT_SIZE_MAP[nearest];
          classes.push(tw === 'base' ? 'text-base' : `text-${tw}`);
          break;
        }
        case 'fontWeight': {
          const tw = FONT_WEIGHT_MAP[String(val)];
          if (tw) classes.push(`font-${tw}`);
          else unmapped[prop] = val;
          break;
        }
        case 'color': {
          const c = nearestTailwindColor(val);
          if (c) classes.push(`text-${c}`);
          else { classes.push('text-[' + val + ']'); }
          break;
        }
        case 'backgroundColor': {
          const c = nearestTailwindColor(val);
          if (c) classes.push(`bg-${c}`);
          else classes.push('bg-[' + val + ']');
          break;
        }
        case 'margin': { classes.push(`m-${nearestSpacing(val)}`); break; }
        case 'marginTop': { classes.push(`mt-${nearestSpacing(val)}`); break; }
        case 'marginBottom': { classes.push(`mb-${nearestSpacing(val)}`); break; }
        case 'marginLeft': { classes.push(`ml-${nearestSpacing(val)}`); break; }
        case 'marginRight': { classes.push(`mr-${nearestSpacing(val)}`); break; }
        case 'marginHorizontal': { classes.push(`mx-${nearestSpacing(val)}`); break; }
        case 'marginVertical': { classes.push(`my-${nearestSpacing(val)}`); break; }
        case 'padding': { classes.push(`p-${nearestSpacing(val)}`); break; }
        case 'paddingTop': { classes.push(`pt-${nearestSpacing(val)}`); break; }
        case 'paddingBottom': { classes.push(`pb-${nearestSpacing(val)}`); break; }
        case 'paddingLeft': { classes.push(`pl-${nearestSpacing(val)}`); break; }
        case 'paddingRight': { classes.push(`pr-${nearestSpacing(val)}`); break; }
        case 'paddingHorizontal': { classes.push(`px-${nearestSpacing(val)}`); break; }
        case 'paddingVertical': { classes.push(`py-${nearestSpacing(val)}`); break; }
        case 'flex': {
          if (val === 1) classes.push('flex-1');
          else if (val === 0) classes.push('flex-none');
          else classes.push(`flex-[${val}]`);
          break;
        }
        case 'flexDirection': {
          const map = { 'row': 'flex-row', 'column': 'flex-col', 'row-reverse': 'flex-row-reverse', 'column-reverse': 'flex-col-reverse' };
          if (map[val]) classes.push(map[val]); else unmapped[prop] = val;
          break;
        }
        case 'flexWrap': {
          if (val === 'wrap') classes.push('flex-wrap');
          else if (val === 'nowrap') classes.push('flex-nowrap');
          else unmapped[prop] = val;
          break;
        }
        case 'alignItems': {
          const map = { 'flex-start': 'items-start', 'flex-end': 'items-end', 'center': 'items-center', 'stretch': 'items-stretch', 'baseline': 'items-baseline' };
          if (map[val]) classes.push(map[val]); else unmapped[prop] = val;
          break;
        }
        case 'justifyContent': {
          const map = { 'flex-start': 'justify-start', 'flex-end': 'justify-end', 'center': 'justify-center', 'space-between': 'justify-between', 'space-around': 'justify-around', 'space-evenly': 'justify-evenly' };
          if (map[val]) classes.push(map[val]); else unmapped[prop] = val;
          break;
        }
        case 'borderRadius': {
          const radii = Object.keys(BORDER_RADIUS_MAP).map(Number).sort((a,b)=>a-b);
          const nearest = radii.reduce((prev, cur) => Math.abs(cur - val) < Math.abs(prev - val) ? cur : prev);
          const tw = BORDER_RADIUS_MAP[nearest];
          classes.push(tw === '' ? 'rounded' : tw === 'none' ? 'rounded-none' : `rounded-${tw}`);
          break;
        }
        case 'borderWidth': {
          if (val === 0) classes.push('border-0');
          else if (val === 1) classes.push('border');
          else if (val === 2) classes.push('border-2');
          else if (val === 4) classes.push('border-4');
          else unmapped[prop] = val;
          break;
        }
        case 'borderColor': {
          const c = nearestTailwindColor(val);
          if (c) classes.push(`border-${c}`); else classes.push(`border-[${val}]`);
          break;
        }
        case 'opacity': {
          const pct = Math.round(val * 100);
          const opts = [0,5,10,20,25,30,40,50,60,70,75,80,90,95,100];
          const nearest = opts.reduce((prev, cur) => Math.abs(cur - pct) < Math.abs(prev - pct) ? cur : prev);
          classes.push(`opacity-${nearest}`);
          break;
        }
        case 'width': {
          if (val === '100%') classes.push('w-full');
          else if (typeof val === 'number') classes.push(`w-${nearestSpacing(val)}`);
          else unmapped[prop] = val;
          break;
        }
        case 'height': {
          if (val === '100%') classes.push('h-full');
          else if (typeof val === 'number') classes.push(`h-${nearestSpacing(val)}`);
          else unmapped[prop] = val;
          break;
        }
        case 'textAlign': {
          classes.push(`text-${val}`);
          break;
        }
        case 'overflow': {
          if (val === 'hidden') classes.push('overflow-hidden');
          else if (val === 'visible') classes.push('overflow-visible');
          else if (val === 'scroll') classes.push('overflow-scroll');
          else unmapped[prop] = val;
          break;
        }
        case 'position': {
          classes.push(val); // absolute, relative
          break;
        }
        case 'top': { classes.push(`top-${nearestSpacing(val)}`); break; }
        case 'bottom': { classes.push(`bottom-${nearestSpacing(val)}`); break; }
        case 'left': { classes.push(`left-${nearestSpacing(val)}`); break; }
        case 'right': { classes.push(`right-${nearestSpacing(val)}`); break; }
        case 'gap': { classes.push(`gap-${nearestSpacing(val)}`); break; }
        case 'rowGap': { classes.push(`gap-y-${nearestSpacing(val)}`); break; }
        case 'columnGap': { classes.push(`gap-x-${nearestSpacing(val)}`); break; }
        case 'minWidth': {
          if (val === '100%') classes.push('min-w-full');
          else unmapped[prop] = val;
          break;
        }
        case 'maxWidth': {
          if (val === '100%') classes.push('max-w-full');
          else unmapped[prop] = val;
          break;
        }
        case 'letterSpacing': {
          if (val <= -0.5) classes.push('tracking-tighter');
          else if (val < 0) classes.push('tracking-tight');
          else if (val === 0) classes.push('tracking-normal');
          else if (val <= 0.5) classes.push('tracking-wide');
          else if (val <= 1) classes.push('tracking-wider');
          else classes.push('tracking-widest');
          break;
        }
        case 'lineHeight': {
          if (val <= 16) classes.push('leading-none');
          else if (val <= 20) classes.push('leading-tight');
          else if (val <= 24) classes.push('leading-snug');
          else if (val <= 28) classes.push('leading-normal');
          else if (val <= 32) classes.push('leading-relaxed');
          else classes.push('leading-loose');
          break;
        }
        default:
          unmapped[prop] = val;
      }
    }

    return { classes, unmapped };
  }

  // Tailwind → RN (reverse mapping)
  function tailwindToRN(classStr) {
    const classes = classStr.trim().split(/\s+/).filter(Boolean);
    const styles = {};
    const unmapped = [];

    for (const cls of classes) {
      // Text color
      if (cls.startsWith('text-') && !['text-left','text-center','text-right','text-justify','text-xs','text-sm','text-base','text-lg','text-xl','text-2xl','text-3xl','text-4xl','text-5xl','text-6xl','text-7xl','text-8xl','text-9xl'].includes(cls)) {
        const color = cls.slice(5);
        if (TW_COLOR_TO_HEX[color]) styles.color = TW_COLOR_TO_HEX[color];
        else unmapped.push(cls);
        continue;
      }
      // Font size
      const fsMap = {'text-xs': 12,'text-sm': 14,'text-base': 16,'text-lg': 18,'text-xl': 20,'text-2xl': 24,'text-3xl': 30,'text-4xl': 36,'text-5xl': 48,'text-6xl': 60,'text-7xl': 72};
      if (fsMap[cls]) { styles.fontSize = fsMap[cls]; continue; }
      // Text align
      const taMap = {'text-left':'left','text-center':'center','text-right':'right','text-justify':'justify'};
      if (taMap[cls]) { styles.textAlign = taMap[cls]; continue; }
      // Font weight
      const fwMap = {'font-thin':100,'font-extralight':200,'font-light':300,'font-normal':400,'font-medium':500,'font-semibold':600,'font-bold':700,'font-extrabold':800,'font-black':900};
      if (fwMap[cls] !== undefined) { styles.fontWeight = String(fwMap[cls]); continue; }
      // Background
      if (cls.startsWith('bg-')) {
        const color = cls.slice(3);
        if (TW_COLOR_TO_HEX[color]) styles.backgroundColor = TW_COLOR_TO_HEX[color];
        else unmapped.push(cls);
        continue;
      }
      // Spacing map (px values)
      const spMap = {'0':0,'px':1,'0.5':2,'1':4,'1.5':6,'2':8,'2.5':10,'3':12,'3.5':14,'4':16,'5':20,'6':24,'7':28,'8':32,'9':36,'10':40,'11':44,'12':48,'14':56,'16':64,'20':80,'24':96,'28':112,'32':128,'40':160,'48':192,'56':224,'64':256,'72':288,'80':320,'96':384};
      const spMatch = cls.match(/^(m|mt|mb|ml|mr|mx|my|p|pt|pb|pl|pr|px|py|gap|gap-x|gap-y|top|bottom|left|right|w|h)-(.+)$/);
      if (spMatch) {
        const [, prefix, val] = spMatch;
        const px = val === 'full' ? '100%' : (spMap[val] !== undefined ? spMap[val] : null);
        if (px !== null) {
          const propMap = {
            'm':'margin','mt':'marginTop','mb':'marginBottom','ml':'marginLeft','mr':'marginRight',
            'mx':'marginHorizontal','my':'marginVertical','p':'padding','pt':'paddingTop',
            'pb':'paddingBottom','pl':'paddingLeft','pr':'paddingRight','px':'paddingHorizontal',
            'py':'paddingVertical','gap':'gap','gap-x':'columnGap','gap-y':'rowGap',
            'top':'top','bottom':'bottom','left':'left','right':'right','w':'width','h':'height'
          };
          if (propMap[prefix]) styles[propMap[prefix]] = px;
          else unmapped.push(cls);
        } else unmapped.push(cls);
        continue;
      }
      // Flex
      if (cls === 'flex-1') { styles.flex = 1; continue; }
      if (cls === 'flex-none') { styles.flex = 0; continue; }
      if (cls === 'flex-auto') { styles.flex = 1; continue; }
      if (cls === 'flex-row') { styles.flexDirection = 'row'; continue; }
      if (cls === 'flex-col') { styles.flexDirection = 'column'; continue; }
      if (cls === 'flex-row-reverse') { styles.flexDirection = 'row-reverse'; continue; }
      if (cls === 'flex-col-reverse') { styles.flexDirection = 'column-reverse'; continue; }
      if (cls === 'flex-wrap') { styles.flexWrap = 'wrap'; continue; }
      if (cls === 'flex-nowrap') { styles.flexWrap = 'nowrap'; continue; }
      // Align/Justify
      const aiMap = {'items-start':'flex-start','items-end':'flex-end','items-center':'center','items-stretch':'stretch','items-baseline':'baseline'};
      if (aiMap[cls]) { styles.alignItems = aiMap[cls]; continue; }
      const jcMap = {'justify-start':'flex-start','justify-end':'flex-end','justify-center':'center','justify-between':'space-between','justify-around':'space-around','justify-evenly':'space-evenly'};
      if (jcMap[cls]) { styles.justifyContent = jcMap[cls]; continue; }
      // Border radius
      const rrMap = {'rounded-none':0,'rounded-sm':2,'rounded':4,'rounded-md':6,'rounded-lg':8,'rounded-xl':12,'rounded-2xl':16,'rounded-3xl':24,'rounded-full':9999};
      if (rrMap[cls] !== undefined) { styles.borderRadius = rrMap[cls]; continue; }
      // Opacity
      const opMatch = cls.match(/^opacity-(\d+)$/);
      if (opMatch) { styles.opacity = parseInt(opMatch[1]) / 100; continue; }
      // Position
      if (cls === 'absolute') { styles.position = 'absolute'; continue; }
      if (cls === 'relative') { styles.position = 'relative'; continue; }
      // Overflow
      if (cls === 'overflow-hidden') { styles.overflow = 'hidden'; continue; }
      if (cls === 'overflow-visible') { styles.overflow = 'visible'; continue; }
      if (cls === 'overflow-scroll') { styles.overflow = 'scroll'; continue; }

      unmapped.push(cls);
    }

    return { styles, unmapped };
  }

  const REFERENCE = [
    { rn: 'fontSize: 14', tw: 'text-sm' },
    { rn: 'fontSize: 16', tw: 'text-base' },
    { rn: 'fontSize: 18', tw: 'text-lg' },
    { rn: 'fontSize: 24', tw: 'text-2xl' },
    { rn: 'fontWeight: "bold"', tw: 'font-bold' },
    { rn: 'fontWeight: "600"', tw: 'font-semibold' },
    { rn: 'color: "#3b82f6"', tw: 'text-blue-500' },
    { rn: 'backgroundColor: "#f3f4f6"', tw: 'bg-gray-100' },
    { rn: 'marginTop: 16', tw: 'mt-4' },
    { rn: 'paddingHorizontal: 16', tw: 'px-4' },
    { rn: 'borderRadius: 8', tw: 'rounded-lg' },
    { rn: 'flex: 1', tw: 'flex-1' },
    { rn: 'flexDirection: "row"', tw: 'flex-row' },
    { rn: 'alignItems: "center"', tw: 'items-center' },
    { rn: 'justifyContent: "space-between"', tw: 'justify-between' },
    { rn: 'opacity: 0.5', tw: 'opacity-50' },
  ];

  let mode = 'rn-to-tw';

  function setMode(m) {
    mode = m;
    document.getElementById('btn-rn-to-tw').className = m === 'rn-to-tw'
      ? 'mode-btn px-4 py-2 rounded-lg text-sm font-medium bg-primary text-white transition-colors'
      : 'mode-btn px-4 py-2 rounded-lg text-sm font-medium bg-surface border border-border text-text-muted hover:border-primary transition-colors';
    document.getElementById('btn-tw-to-rn').className = m === 'tw-to-rn'
      ? 'mode-btn px-4 py-2 rounded-lg text-sm font-medium bg-primary text-white transition-colors'
      : 'mode-btn px-4 py-2 rounded-lg text-sm font-medium bg-surface border border-border text-text-muted hover:border-primary transition-colors';
    document.getElementById('panel-rn-to-tw').classList.toggle('hidden', m !== 'rn-to-tw');
    document.getElementById('panel-tw-to-rn').classList.toggle('hidden', m !== 'tw-to-rn');
    const l1 = document.getElementById('out-label-1');
    const l2 = document.getElementById('out-label-2');
    if (m === 'rn-to-tw') {
      l1.textContent = 'Tailwind Classes'; l2.textContent = 'NativeWind className';
    } else {
      l1.textContent = 'React Native StyleSheet'; l2.textContent = 'StyleSheet.create()';
    }
  }

  function doConvert() {
    const twEl = document.getElementById('output-tw');
    const nwEl = document.getElementById('output-nw');
    const unmappedContainer = document.getElementById('unmapped-container');
    const unmappedList = document.getElementById('unmapped-list');

    if (mode === 'rn-to-tw') {
      const raw = document.getElementById('rn-input').value.trim();
      let obj;
      try { obj = JSON.parse(raw); } catch(e) {
        twEl.textContent = 'Error: Invalid JSON — ' + e.message;
        nwEl.textContent = '';
        return;
      }
      const { classes, unmapped } = rnToTailwind(obj);
      const joined = classes.join(' ');
      twEl.textContent = joined || '(no mappings found)';
      nwEl.textContent = joined ? `className="${joined}"` : '';

      const unmappedEntries = Object.entries(unmapped);
      unmappedContainer.classList.toggle('hidden', unmappedEntries.length === 0);
      unmappedList.innerHTML = unmappedEntries.map(([k, v]) =>
        `<div><span class="text-yellow-300">${k}</span>: <span class="text-text-muted">${JSON.stringify(v)}</span> — no direct Tailwind equivalent</div>`
      ).join('');
    } else {
      const raw = document.getElementById('tw-input').value.trim();
      const { styles, unmapped } = tailwindToRN(raw);
      const json = JSON.stringify(styles, null, 2);
      twEl.textContent = json;
      nwEl.textContent = `const styles = StyleSheet.create({\n  container: ${json}\n});`;

      unmappedContainer.classList.toggle('hidden', unmapped.length === 0);
      unmappedList.innerHTML = unmapped.map(c =>
        `<div><span class="text-yellow-300">${c}</span> — no RN equivalent</div>`
      ).join('');
    }
  }

  function buildRef() {
    const grid = document.getElementById('ref-grid');
    grid.innerHTML = REFERENCE.map(r => `
      <div class="bg-surface border border-border rounded px-3 py-2 flex gap-3 text-xs font-mono">
        <span class="text-text-muted shrink-0">${r.rn}</span>
        <span class="text-accent shrink-0">→ ${r.tw}</span>
      </div>
    `).join('');
  }

  function copyText(id, text) {
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById(id);
      const orig = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = orig, 1500);
    });
  }

  document.getElementById('btn-rn-to-tw').addEventListener('click', () => setMode('rn-to-tw'));
  document.getElementById('btn-tw-to-rn').addEventListener('click', () => setMode('tw-to-rn'));
  document.getElementById('convert-btn').addEventListener('click', doConvert);
  document.getElementById('copy-tw').addEventListener('click', () => copyText('copy-tw', document.getElementById('output-tw').textContent));
  document.getElementById('copy-nw').addEventListener('click', () => copyText('copy-nw', document.getElementById('output-nw').textContent));

  buildRef();

  // Auto-convert sample
  document.getElementById('rn-input').value = `{
  "fontSize": 16,
  "color": "#333333",
  "backgroundColor": "#f0f4ff",
  "marginTop": 8,
  "paddingHorizontal": 16,
  "borderRadius": 8,
  "fontWeight": "bold",
  "flex": 1,
  "alignItems": "center"
}`;
  doConvert();
})();
</script>
