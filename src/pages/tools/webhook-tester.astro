---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WebhookTester from '../../components/WebhookTester.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is a webhook and how do I test one?",
    answer: "A webhook is an HTTP POST request that one service sends to another when an event occurs (e.g., GitHub sends a push event, Stripe sends a payment event). To test a webhook handler, you need to send a realistic payload to your endpoint with the right headers. This tool generates accurate sample payloads for popular services and gives you a curl command to send them from your terminal.",
  },
  {
    question: "Why do I need to use curl instead of sending directly from the browser?",
    answer: "Browsers enforce CORS (Cross-Origin Resource Sharing) policies, so a browser-based tool can't send POST requests to arbitrary endpoints on localhost or other domains. curl runs outside the browser and can send requests anywhere — making it the standard way to test webhook endpoints during local development.",
  },
  {
    question: "How do I verify webhook signatures?",
    answer: "Most services sign webhook payloads using HMAC-SHA256 with a secret key. GitHub uses X-Hub-Signature-256, Stripe uses Stripe-Signature (with timestamp + signature), and Slack uses X-Slack-Signature. Your handler should validate this signature against the raw request body before processing. The sample headers in this tool show placeholder signatures — replace them with real ones from your service dashboard.",
  },
  {
    question: "How do I test webhooks with a local dev server?",
    answer: "Use a tunneling tool like ngrok (ngrok http 3000) or Cloudflare Tunnel to expose your local port to the internet. Copy the public URL, register it in your service's webhook settings, and trigger real events. For faster iteration without real events, use this tool to generate curl commands that replicate the exact payload format — no internet required.",
  },
  {
    question: "What headers does a GitHub webhook include?",
    answer: "GitHub webhooks include: Content-Type (application/json or application/x-www-form-urlencoded), X-GitHub-Event (the event name, e.g. push, pull_request), X-GitHub-Delivery (a UUID for the delivery), X-Hub-Signature (HMAC-SHA1 of the body, deprecated), and X-Hub-Signature-256 (HMAC-SHA256, preferred). Always validate X-Hub-Signature-256 against your webhook secret.",
  },
  {
    question: "How do I handle Stripe webhook signatures correctly?",
    answer: "Stripe's Stripe-Signature header contains a timestamp (t=) and one or more signatures (v1=). To verify: 1) extract the timestamp, 2) construct the signed payload string as timestamp + '.' + raw body, 3) compute HMAC-SHA256 of that string using your endpoint's signing secret, 4) compare against the v1 signature. Never parse JSON before signature verification — you need the raw body bytes. Use Stripe's official SDK webhooks.constructEvent() method.",
  },
];
---

<BaseLayout
  title="Webhook Tester — Generate & Send Test Webhook Payloads (GitHub, Stripe, Slack)"
  description="Generate realistic webhook test payloads for GitHub, Stripe, Slack, and custom services. Get a curl command to send the payload to your local endpoint. Inspect headers, payload size, and content-type. Free, runs in your browser."
  tool="Webhook Tester, Test Webhook Payload, GitHub Webhook Test, Stripe Webhook Test, Webhook Curl Generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Webhook Tester",
    "url": "https://devplaybook.cc/tools/webhook-tester",
    "description": "Generate realistic webhook test payloads for GitHub, Stripe, Slack, and custom services. Get a curl command to send them to your local endpoint.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Webhook Tester</h1>
  <p class="text-text-muted mb-4">
    Generate realistic <strong>webhook test payloads</strong> for GitHub, Stripe, Slack, and custom services.
    Pick a service, customize the payload, enter your endpoint URL, and get a ready-to-run <strong>curl command</strong> to send the test request to your local handler.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GitHub, Stripe, Slack presets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Editable payload & headers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> curl command generator</span>
  </div>
  <WebhookTester client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Webhook Tester" relatedTags={['api', 'webhooks', 'testing', 'http', 'developer-tools']} />
</BaseLayout>
