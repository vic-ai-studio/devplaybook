---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CronExpressionVisualizer from '../../components/CronExpressionVisualizer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is a cron expression?", answer: "A cron expression is a 5-field string that defines a recurring schedule: minute (0–59), hour (0–23), day-of-month (1–31), month (1–12), day-of-week (0–6, Sunday=0). For example, '0 9 * * 1-5' runs every weekday at 9:00 AM." },
  { question: "How do I read the 5 fields in a cron expression?", answer: "Read left to right: minute, hour, day-of-month, month, day-of-week. An asterisk (*) means 'every value'. Use */5 for 'every 5th', 1-5 for a range, and 1,3,5 for specific values." },
  { question: "What does */15 mean in the minute field?", answer: "'*/15' means every 15 minutes — at 0, 15, 30, and 45 past each hour. The step syntax (*/n) works in any field: */2 in the hour field means every 2 hours." },
  { question: "How do I schedule a job on weekdays only?", answer: "Set the day-of-week field to 1-5. For example, '0 9 * * 1-5' runs at 9 AM Monday through Friday (1=Mon, 5=Fri). '0,6' in the day-of-week field targets weekends only." },
  { question: "Can I use cron expressions in GitHub Actions?", answer: "Yes. GitHub Actions supports cron syntax in the 'schedule' trigger: `on: schedule: - cron: '0 9 * * 1-5'`. Note that GitHub Actions runs are in UTC, so adjust the hour field for your local timezone." },
];
---

<BaseLayout
  title="Cron Expression Visualizer — Parse & Preview Next Run Times"
  description="Visualize cron expressions instantly. See a plain-English description, field-by-field breakdown, and the next 5 scheduled run times. Common presets included. Free, runs in your browser."
  tool="Cron Expression Visualizer, Cron Parser, Cron Expression Explainer, Cron Schedule Preview"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Cron Expression Visualizer</h1>
  <p class="text-text-muted mb-4">Enter a cron expression to see it explained in plain English, broken down field-by-field, and previewed with the next 5 upcoming run times. Use presets for common schedules or type your own.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <CronExpressionVisualizer client:load />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Need to build a cron expression from scratch?</p>
    <a href="/tools/cron-builder" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Cron Expression Builder →</a>
  </div>
  <ToolPageCta currentTool="Cron Expression Visualizer" relatedTags={['automation', 'devops', 'ci-cd', 'bash', 'linux']} />
</BaseLayout>
