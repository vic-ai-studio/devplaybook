---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MermaidDiagramGenerator from '../../components/MermaidDiagramGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Mermaid and where can I use it?",
    answer: "Mermaid is a JavaScript-based diagramming language that turns text into diagrams. It's supported natively in GitHub Markdown, GitLab, Notion, Obsidian, and VS Code (with extensions). You can also embed it in any webpage using the mermaid.js library. Great for documentation-as-code."
  },
  {
    question: "What diagram types does this tool support?",
    answer: "Flowchart (processes, decisions, branching), Sequence diagram (actor/system interactions over time), Class diagram (OOP relationships and methods), ER diagram (database entity-relationship), and Gantt chart (project timelines with task dependencies). The editor includes a working example for each type."
  },
  {
    question: "How do I add a Mermaid diagram to GitHub?",
    answer: "In any GitHub Markdown file (.md), wrap the Mermaid code in triple backtick blocks with 'mermaid' as the language: ```mermaid (newline) your diagram code (newline) ```. GitHub renders these automatically in .md files, issues, and pull request descriptions."
  },
  {
    question: "What's the syntax for flowchart arrows?",
    answer: "In Mermaid flowcharts: --> is a normal arrow, ---  is a line without arrow, -- text --> adds a label, ==> is a thick arrow, and -.-> is a dotted arrow. Node shapes: [Rectangle], (Rounded), {Diamond for decisions}, ((Circle)), >Asymmetric]. Flowchart direction: TD (top-down), LR (left-right), RL (right-left), BT (bottom-top)."
  },
  {
    question: "How do I export the diagram as an image?",
    answer: "Right-click the rendered SVG and choose 'Save image as' to download as SVG. For PNG export, you can use the mermaid CLI (npm install -g @mermaid-js/mermaid-cli then mmdc -i diagram.md -o diagram.png) or paste your code into Mermaid Live Editor at mermaid.live for more export options."
  },
  {
    question: "Why isn't my diagram rendering?",
    answer: "Common errors: incorrect indentation (use spaces, not tabs), missing diagram type keyword on the first line (e.g. flowchart TD), unmatched brackets or quotes, or invalid keywords. Check the error message in the preview panel — it usually points to the problematic line."
  },
];
---

<BaseLayout
  title="Mermaid Diagram Generator — Flowchart, Sequence, ER & Gantt Online"
  description="Free online Mermaid diagram generator with live preview. Create flowcharts, sequence diagrams, class diagrams, ER diagrams, and Gantt charts. Works with GitHub, Notion, and any Mermaid-compatible tool."
  tool="Mermaid diagram generator, Mermaid live editor, flowchart generator, sequence diagram tool, ER diagram generator, Gantt chart maker"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Mermaid Diagram Generator",
    "url": "https://devplaybook.cc/tools/mermaid-diagram-generator",
    "description": "Create Mermaid diagrams with live preview. Supports flowchart, sequence, class, ER, and Gantt chart types. Compatible with GitHub, Notion, Obsidian.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Mermaid Diagram Generator</h1>
  <p class="text-text-muted mb-4">
    Write <a href="https://mermaid.js.org" class="text-accent hover:underline" target="_blank" rel="noopener">Mermaid</a> syntax and see your diagram live. Supports flowcharts, sequence diagrams, class diagrams, ER diagrams, and Gantt charts — compatible with GitHub, Notion, Obsidian, and more.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 diagram types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GitHub compatible</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy code instantly</span>
  </div>
  <MermaidDiagramGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Mermaid Diagram Generator" relatedTags={['documentation', 'diagrams', 'architecture', 'developer-tools', 'visualization', 'markdown']} />
</BaseLayout>
