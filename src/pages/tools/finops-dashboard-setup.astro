---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is FinOps and why does it need dedicated tooling?", answer: "FinOps (Financial Operations) is the practice of bringing financial accountability to cloud spending through cross-functional collaboration between engineering, finance, and business teams. Cloud billing is fundamentally different from traditional IT costs — it's variable, granular, and accrues in real time. Without dedicated tooling, engineers can't see cost impact of their infrastructure decisions, and finance can't attribute spend to business outcomes. FinOps tools provide chargeback/showback reporting, anomaly detection, optimization recommendations, and the shared language between technical and financial teams." },
  { question: "What KPIs should a FinOps dashboard track?", answer: "The most important FinOps KPIs: (1) Cost per unit of business value — cost per API call, cost per user, cost per transaction. This ties cloud spend to revenue. (2) Savings Plan / Reserved Instance utilization — should be above 80%. (3) Waste percentage — idle resources as % of total spend, target below 5%. (4) Coverage rate — what % of eligible spend is covered by commitments. (5) Variance to budget — actual vs planned, with trend. (6) Environment cost breakdown — what % is production vs staging vs dev. (7) Tag coverage rate — what % of resources are properly tagged. These seven KPIs tell you if your FinOps program is working." },
  { question: "How does CAST AI differ from Kubecost and CloudHealth?", answer: "CAST AI is an autonomous Kubernetes optimization platform — it not only shows costs but automatically rightsizes nodes, switches workloads to Spot instances, and scales node groups for you. It's an active optimizer, not just a reporting tool. Kubecost is primarily a cost visibility and allocation tool for Kubernetes that shows recommendations but requires manual action. CloudHealth (VMware Aria) is a broad multi-cloud FinOps platform covering governance, tagging enforcement, reserved instance management, and reporting across AWS/GCP/Azure — it's enterprise-grade with a corresponding price tag. Choose CAST AI if you want automated K8s savings, Kubecost for K8s visibility, CloudHealth for enterprise multi-cloud governance." },
  { question: "Can I build a FinOps dashboard with open-source tools only?", answer: "Yes — a solid open-source FinOps stack uses: OpenCost for Kubernetes cost allocation, AWS Cost Explorer API or GCP Billing Export to BigQuery for cloud costs, Prometheus + node-exporter for resource utilization metrics, and Grafana for dashboards. Export cloud costs to an S3 bucket or BigQuery table, use Grafana's AWS CloudWatch or BigQuery datasource to query them, and combine with OpenCost's Prometheus metrics. This gives you cost by namespace, service, team, and environment in Grafana without any SaaS cost. The effort is in the setup and ongoing maintenance — roughly 1-2 days initially and a few hours per month." },
];
---

<BaseLayout
  title="FinOps Dashboard Setup — Kubecost vs CloudHealth vs CAST AI + Grafana"
  description="Set up a FinOps tooling stack: compare Kubecost vs CloudHealth vs CAST AI, build Grafana cost dashboards, and track the KPIs that matter for cloud financial management."
  tool="FinOps, Kubecost, CloudHealth, CAST AI, Grafana cost dashboard, cloud financial management, FinOps KPIs"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "FinOps Dashboard Setup Guide",
    "url": "https://devplaybook.cc/tools/finops-dashboard-setup",
    "description": "Compare FinOps tools and build Grafana cost dashboards to track cloud spend KPIs across teams and services.",
  })} />

  <h1 class="text-3xl font-bold mb-2">FinOps Dashboard Setup</h1>
  <p class="text-text-muted mb-6">
    Build a <strong>cloud cost visibility dashboard</strong> with the right FinOps tooling. Compare Kubecost, CloudHealth, and CAST AI — then set up Grafana dashboards to track the KPIs that connect cloud spend to business value.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Tool comparison table</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Grafana dashboard JSON</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> FinOps KPIs</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Open-source stack</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">FinOps Tool Comparison</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 font-semibold">Feature</th>
          <th class="text-left py-2 pr-4 font-semibold">Kubecost</th>
          <th class="text-left py-2 pr-4 font-semibold">CloudHealth</th>
          <th class="text-left py-2 font-semibold">CAST AI</th>
        </tr>
      </thead>
      <tbody class="text-text-muted">
        <tr class="border-b border-border"><td class="py-2 pr-4">Primary focus</td><td class="py-2 pr-4">K8s cost visibility</td><td class="py-2 pr-4">Multi-cloud governance</td><td class="py-2">K8s autonomous optimization</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Auto-optimization</td><td class="py-2 pr-4">Recommendations only</td><td class="py-2 pr-4">RI purchase automation</td><td class="py-2">✓ Fully autonomous</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Multi-cloud</td><td class="py-2 pr-4">K8s on any cloud</td><td class="py-2 pr-4">✓ AWS + GCP + Azure</td><td class="py-2">AWS + GCP + Azure K8s</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Free tier</td><td class="py-2 pr-4">Free (15-day retention)</td><td class="py-2 pr-4">No free tier</td><td class="py-2">Free up to $10K/month</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Typical savings</td><td class="py-2 pr-4">Visibility-driven</td><td class="py-2 pr-4">15–30%</td><td class="py-2">40–60% K8s costs</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Target org size</td><td class="py-2 pr-4">Any</td><td class="py-2 pr-4">Enterprise</td><td class="py-2">K8s-heavy teams</td></tr>
        <tr><td class="py-2 pr-4">Pricing model</td><td class="py-2 pr-4">Free / per cluster</td><td class="py-2 pr-4">% of cloud spend</td><td class="py-2">% of savings</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Grafana Dashboard — AWS Cost via CloudWatch</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// Grafana panel JSON snippet — monthly cost by service
// Add as a new panel in your Grafana dashboard JSON
&#123;
  "title": "AWS Monthly Cost by Service",
  "type": "barchart",
  "datasource": "CloudWatch",
  "targets": [
    &#123;
      "queryType": "timeSeriesQuery",
      "namespace": "AWS/Billing",
      "metricName": "EstimatedCharges",
      "dimensions": &#123;
        "ServiceName": ["Amazon EC2", "Amazon RDS", "AWS Lambda",
                        "Amazon S3", "Amazon EKS"]
      &#125;,
      "statistics": ["Maximum"],
      "period": "2592000"
    &#125;
  ],
  "fieldConfig": &#123;
    "defaults": &#123;
      "unit": "currencyUSD",
      "thresholds": &#123;
        "steps": [
          &#123;"color": "green", "value": null&#125;,
          &#123;"color": "yellow", "value": 1000&#125;,
          &#123;"color": "red", "value": 5000&#125;
        ]
      &#125;
    &#125;
  &#125;
&#125;</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">GCP Billing Export to BigQuery + Grafana</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">-- Enable billing export: GCP Console → Billing → Budget &amp; alerts → Billing export
-- Then query in Grafana using BigQuery datasource

-- Cost by service this month
SELECT
  service.description AS service,
  ROUND(SUM(cost), 2) AS total_cost,
  currency
FROM `project.dataset.gcp_billing_export_v1_XXXXXX`
WHERE DATE(_PARTITIONTIME) &gt;= DATE_TRUNC(CURRENT_DATE(), MONTH)
GROUP BY service.description, currency
ORDER BY total_cost DESC
LIMIT 20;

-- Daily cost trend by team label
SELECT
  DATE(usage_start_time) AS date,
  labels.value AS team,
  ROUND(SUM(cost), 2) AS daily_cost
FROM `project.dataset.gcp_billing_export_v1_XXXXXX`,
  UNNEST(labels) AS labels
WHERE labels.key = 'team'
  AND DATE(usage_start_time) &gt;= DATE_SUB(CURRENT_DATE(), INTERVAL 30 DAY)
GROUP BY date, team
ORDER BY date, daily_cost DESC;</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key FinOps KPIs to Track</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 font-semibold">KPI</th>
          <th class="text-left py-2 pr-4 font-semibold">Target</th>
          <th class="text-left py-2 font-semibold">How to Calculate</th>
        </tr>
      </thead>
      <tbody class="text-text-muted">
        <tr class="border-b border-border"><td class="py-2 pr-4">Savings Plan utilization</td><td class="py-2 pr-4">&gt; 80%</td><td class="py-2">Used commitment / purchased commitment</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Waste percentage</td><td class="py-2 pr-4">&lt; 5%</td><td class="py-2">Idle resource cost / total cloud spend</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Tag coverage</td><td class="py-2 pr-4">&gt; 95%</td><td class="py-2">Tagged resources / total resources</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Cost per unit</td><td class="py-2 pr-4">Trend ↓</td><td class="py-2">Total cloud cost / active users or requests</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Budget variance</td><td class="py-2 pr-4">&lt; ±10%</td><td class="py-2">(Actual - Budget) / Budget × 100</td></tr>
        <tr><td class="py-2 pr-4">Env cost ratio</td><td class="py-2 pr-4">Prod &gt; 70%</td><td class="py-2">Production cost / total cluster cost</td></tr>
      </tbody>
    </table>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="finops-dashboard-setup" relatedTags={["finops", "cloud", "cost-optimization", "grafana", "devops", "kubernetes"]} />
</BaseLayout>
