---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonToTypeScript from '../../components/JsonToTypeScript.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How do I convert JSON to TypeScript interfaces?", answer: "Paste your JSON into the input field and the tool instantly generates TypeScript interface definitions. Nested objects become separate interfaces, arrays are typed by their element type, and you can customize the root interface name." },
  { question: "Does it handle nested JSON objects?", answer: "Yes. Each nested object becomes its own named interface. For example, a user object with an address sub-object generates both a User interface and an Address interface, properly referenced." },
  { question: "What about arrays with mixed types?", answer: "Arrays with elements of the same type get typed as that type (e.g. string[]). Arrays with mixed types are typed as a union (e.g. (string | number)[]). Empty arrays default to any[]." },
  { question: "Can I add the export keyword to generated interfaces?", answer: "Yes. Toggle the export option and every generated interface will be prefixed with 'export'. This is useful when the interfaces will be imported across multiple files in your project." },
  { question: "Is my JSON data sent to any server?", answer: "No. All conversion runs entirely in your browser using JavaScript. Your JSON data never leaves your machine — safe for API responses containing sensitive information." },
];
---

<BaseLayout
  title="JSON to TypeScript Interface Converter — Free Online Tool"
  description="Paste JSON and get TypeScript interfaces instantly. Supports nested objects, arrays, optional fields, union types, and the export keyword. Used by 60K+ developers for API response typing, mock data generation, and codebase migration. Free, runs 100% in your browser — no data sent to servers."
  tool="JSON to TypeScript, JSON to TS Interface, JSON Type Generator, TypeScript Interface Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">JSON to TypeScript Interface</h1>
  <p class="text-text-muted mb-4">Paste any JSON and get TypeScript interface definitions instantly. Handles nested objects, arrays, optional fields, and custom root names. 100% client-side.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <JsonToTypeScript client:load />
  <!-- Real-World Use Cases -->
  <section class="mt-12 mb-8">
    <h2 class="text-2xl font-bold mb-6">Real-World Use Cases</h2>

    <div class="space-y-6">
      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">1. Typing a REST API Response</h3>
        <p class="text-text-muted mb-3">You call <code class="font-mono text-sm bg-bg-card px-1 rounded">GET /api/users/42</code> and receive this JSON. Paste it here to get a TypeScript interface you can use with <code class="font-mono text-sm bg-bg-card px-1 rounded">fetch</code> or Axios.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Input JSON</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{"{"}"id": 42, "name": "Alice", "email": "alice@example.com", "roles": ["admin", "editor"], "address": {"{"}"city": "Taipei", "zip": "100"{"}"}{"}"}
</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Output TypeScript</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">export interface Root {"{"}{"\n"}  id: number;{"\n"}  name: string;{"\n"}  email: string;{"\n"}  roles: string[];{"\n"}  address: Address;{"\n"}{"}"}{"\n"}{"\n"}export interface Address {"{"}{"\n"}  city: string;{"\n"}  zip: string;{"\n"}{"}"}</pre>
          </div>
        </div>
      </div>

      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">2. Converting Stripe Webhook Payloads</h3>
        <p class="text-text-muted mb-3">Stripe webhooks send deeply nested JSON. Paste a sample <code class="font-mono text-sm bg-bg-card px-1 rounded">checkout.session.completed</code> event and generate type-safe interfaces for your webhook handler — no more <code class="font-mono text-sm bg-bg-card px-1 rounded">any</code> types.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Input (Stripe event excerpt)</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{"{"}"type": "checkout.session.completed", "data": {"{"}"object": {"{"}"id": "cs_live_abc", "amount_total": 2999, "currency": "usd", "customer": "cus_xyz"{"}"}{"}"}{"}"}
</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Output TypeScript</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">export interface Root {"{"}{"\n"}  type: string;{"\n"}  data: Data;{"\n"}{"}"}{"\n"}{"\n"}export interface Data {"{"}{"\n"}  object: SessionObject;{"\n"}{"}"}{"\n"}{"\n"}export interface SessionObject {"{"}{"\n"}  id: string;{"\n"}  amount_total: number;{"\n"}  currency: string;{"\n"}  customer: string;{"\n"}{"}"}</pre>
          </div>
        </div>
      </div>

      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">3. Migrating a JavaScript Config to TypeScript</h3>
        <p class="text-text-muted mb-3">When moving a <code class="font-mono text-sm bg-bg-card px-1 rounded">config.json</code> to a typed system, paste the config JSON to generate an interface. Then use that interface to validate your config at compile time instead of runtime.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Input (config.json)</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{"{"}"port": 3000, "debug": false, "db": {"{"}"host": "localhost", "port": 5432, "name": "myapp"{"}"}{"}"}
</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Output TypeScript</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">export interface Config {"{"}{"\n"}  port: number;{"\n"}  debug: boolean;{"\n"}  db: Db;{"\n"}{"}"}{"\n"}{"\n"}export interface Db {"{"}{"\n"}  host: string;{"\n"}  port: number;{"\n"}  name: string;{"\n"}{"}"}</pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Step-by-Step Guide -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">How to Use — Step by Step</h2>
    <ol class="list-decimal list-inside space-y-3 text-text-muted">
      <li><strong>Paste your JSON</strong> — Copy a JSON response from your browser DevTools, Postman, or API docs and paste it into the input field on the left.</li>
      <li><strong>Preview the output</strong> — TypeScript interfaces appear instantly on the right. Nested objects are split into separate named interfaces.</li>
      <li><strong>Set the root name</strong> — Change the root interface name from <code class="font-mono text-sm bg-bg-card px-1 rounded">Root</code> to something meaningful like <code class="font-mono text-sm bg-bg-card px-1 rounded">UserResponse</code>.</li>
      <li><strong>Toggle export</strong> — Enable the export option if you need <code class="font-mono text-sm bg-bg-card px-1 rounded">export interface</code> for multi-file projects.</li>
      <li><strong>Copy &amp; use</strong> — Click the copy button and paste the interfaces into your <code class="font-mono text-sm bg-bg-card px-1 rounded">.ts</code> or <code class="font-mono text-sm bg-bg-card px-1 rounded">.d.ts</code> file. Pair them with your API client for full type safety.</li>
    </ol>
  </section>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="JSON to TypeScript Interface" relatedTags={['typescript', 'json', 'types', 'interfaces', 'developer-tools']} />
</BaseLayout>
