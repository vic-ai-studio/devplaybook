---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonToTypeScript from '../../components/JsonToTypeScript.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="JSON to TypeScript Interface Converter"
  description="Paste JSON and get TypeScript interfaces instantly. Supports nested objects, arrays, optional fields, and export keyword. Free, runs in your browser."
  tool="JSON to TypeScript, JSON to TS Interface, JSON Type Generator, TypeScript Interface Generator"
>
  <h1 class="text-3xl font-bold mb-2">JSON to TypeScript Interface</h1>
  <p class="text-text-muted mb-8">Paste any JSON and get TypeScript interface definitions instantly. Handles nested objects, arrays, optional fields, and custom root names. 100% client-side.</p>
  <JsonToTypeScript client:load />
  <ToolPageCta currentTool="JSON to TypeScript Interface" relatedTags={['typescript', 'json', 'types', 'interfaces', 'developer-tools']} />
</BaseLayout>
