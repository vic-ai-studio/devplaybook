---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CurlBuilder from '../../components/CurlBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="curl Command Builder — GUI for curl"
  description="Build curl commands visually. Set method, URL, headers, auth (Bearer, Basic, API key), and body — copy the ready-to-run command instantly. Free."
  tool="curl Builder, curl Command Generator, HTTP Request Builder, curl GUI"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "curl Command Builder",
    "url": "https://devplaybook.cc/tools/curl-builder",
    "description": "GUI tool to build curl commands with method, URL, headers, auth, and body. Copy the ready-to-run command instantly.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">curl Command Builder</h1>
  <p class="text-text-muted mb-8">
    Build <code class="font-mono bg-surface px-1 rounded">curl</code> commands visually — no memorizing flags.
    Set your method, URL, query params, headers, authentication, and body, then copy the ready-to-run command.
    Supports Bearer tokens, Basic Auth, API key headers, JSON/form/XML bodies, and advanced options like <code class="font-mono bg-surface px-1 rounded">-v</code>, <code class="font-mono bg-surface px-1 rounded">-k</code>, and <code class="font-mono bg-surface px-1 rounded">--max-time</code>.
  </p>
  <CurlBuilder client:load />
  <ToolPageCta currentTool="curl Command Builder" relatedTags={['http', 'api', 'curl', 'devops', 'cli']} />
</BaseLayout>
