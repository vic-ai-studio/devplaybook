---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the NATO phonetic alphabet?", answer: "The NATO phonetic alphabet (officially the International Radiotelephony Spelling Alphabet) assigns a distinct word to each letter of the Latin alphabet to avoid miscommunication when spelling words over radio, phone, or noisy channels. Letters that sound similar (B/D/P, M/N, F/S) are replaced with unambiguous words: Bravo, Delta, Papa, Mike, November, Foxtrot, Sierra. It is used globally by aviation, military, emergency services, and customer support." },
  { question: "When was the NATO phonetic alphabet standardized?", answer: "The current version was adopted by NATO in 1956 and by the International Civil Aviation Organization (ICAO) and International Telecommunication Union (ITU). Earlier versions existed during World War II: the US military used Able/Baker/Charlie, while Britain used Apple/Beer/Cat. The 1956 standardization unified all NATO forces and civil aviation onto a single alphabet. The words were chosen based on intelligibility testing across many languages and accents." },
  { question: "How do I use the phonetic alphabet?", answer: "Spell out each letter of a word using its code word, preceded by 'I spell.' For example, to spell 'DEVOPS': 'Delta, Echo, Victor, Oscar, Papa, Sierra.' When reading a call sign or account number character by character, each character is spoken as its phonetic code word plus the character itself: 'D as in Delta, E as in Echo.' Numbers are spoken as: 'Zero, One, Two, Three, Four, Five, Six, Seven, Eight, Niner' — 'niner' is used instead of 'nine' to avoid confusion with the German word 'nein' (no)." },
  { question: "Why is it 'Niner' instead of 'Nine'?", answer: "The digit 9 is pronounced 'niner' in aviation and military communication to distinguish it from the German word 'nein' (meaning 'no'), which could cause confusion on international frequencies. This is especially important in international aviation where controllers and pilots may not share a native language. Similarly, 'fife' is sometimes used for 5 to distinguish it from 'fire' or 'nine' at high speed, and 'tree' for 3 to distinguish from 'free'." },
];
---

<BaseLayout
  title="NATO Phonetic Alphabet Converter — Spell Any Text"
  description="Convert any text to the NATO/ICAO phonetic alphabet. Spell words as Alpha, Bravo, Charlie... for clear radio and phone communication. Instant conversion."
  tool="NATO phonetic alphabet, ICAO phonetic alphabet, spell phonetically, Alpha Bravo Charlie, radio communication spelling, phonetic converter"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "NATO Phonetic Alphabet Converter",
    "url": "https://devplaybook.cc/tools/nato-phonetic-alphabet",
    "description": "Convert any text to NATO/ICAO phonetic alphabet. Spell words as Alpha, Bravo, Charlie for unambiguous radio and phone communication.",
  })} />

  <h1 class="text-3xl font-bold mb-2">NATO Phonetic Alphabet</h1>
  <p class="text-text-muted mb-6">
    Convert any text to the <strong>NATO / ICAO phonetic alphabet</strong> — the international standard
    for unambiguous spelling over radio, phone, and noisy channels.
    Used by aviation, military, and emergency services worldwide.
  </p>

  <div class="mb-6">
    <label class="block text-sm font-medium mb-2">Enter text to convert</label>
    <input
      type="text"
      id="inputText"
      class="w-full bg-bg-card border border-border rounded-xl p-3 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary"
      placeholder="e.g. DEVOPS or N7845B or A1B2C3..."
      value="DEVOPS"
    />
  </div>

  <div id="output" class="bg-bg-card border border-border rounded-xl p-4 mb-6">
    <div class="flex items-center justify-between mb-3">
      <span class="text-sm font-medium">Phonetic Spelling</span>
      <button id="copyBtn" class="text-xs text-primary hover:underline">Copy</button>
    </div>
    <div id="phonetic" class="text-sm leading-relaxed font-mono text-text"></div>
    <div id="spoken" class="text-xs text-text-muted mt-3 leading-relaxed"></div>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Full NATO Phonetic Alphabet</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 font-semibold">Letter</th>
          <th class="text-left py-2 pr-4 font-semibold">Word</th>
          <th class="text-left py-2 pr-4 font-semibold">Letter</th>
          <th class="text-left py-2 pr-4 font-semibold">Word</th>
          <th class="text-left py-2 pr-4 font-semibold">Letter</th>
          <th class="text-left py-2 font-semibold">Word</th>
        </tr>
      </thead>
      <tbody class="text-text-muted">
        <tr class="border-b border-border/50"><td class="py-1.5 pr-4 font-mono font-bold">A</td><td class="py-1.5 pr-4">Alpha</td><td class="py-1.5 pr-4 font-mono font-bold">J</td><td class="py-1.5 pr-4">Juliett</td><td class="py-1.5 pr-4 font-mono font-bold">S</td><td class="py-1.5">Sierra</td></tr>
        <tr class="border-b border-border/50"><td class="py-1.5 pr-4 font-mono font-bold">B</td><td class="py-1.5 pr-4">Bravo</td><td class="py-1.5 pr-4 font-mono font-bold">K</td><td class="py-1.5 pr-4">Kilo</td><td class="py-1.5 pr-4 font-mono font-bold">T</td><td class="py-1.5">Tango</td></tr>
        <tr class="border-b border-border/50"><td class="py-1.5 pr-4 font-mono font-bold">C</td><td class="py-1.5 pr-4">Charlie</td><td class="py-1.5 pr-4 font-mono font-bold">L</td><td class="py-1.5 pr-4">Lima</td><td class="py-1.5 pr-4 font-mono font-bold">U</td><td class="py-1.5">Uniform</td></tr>
        <tr class="border-b border-border/50"><td class="py-1.5 pr-4 font-mono font-bold">D</td><td class="py-1.5 pr-4">Delta</td><td class="py-1.5 pr-4 font-mono font-bold">M</td><td class="py-1.5 pr-4">Mike</td><td class="py-1.5 pr-4 font-mono font-bold">V</td><td class="py-1.5">Victor</td></tr>
        <tr class="border-b border-border/50"><td class="py-1.5 pr-4 font-mono font-bold">E</td><td class="py-1.5 pr-4">Echo</td><td class="py-1.5 pr-4 font-mono font-bold">N</td><td class="py-1.5 pr-4">November</td><td class="py-1.5 pr-4 font-mono font-bold">W</td><td class="py-1.5">Whiskey</td></tr>
        <tr class="border-b border-border/50"><td class="py-1.5 pr-4 font-mono font-bold">F</td><td class="py-1.5 pr-4">Foxtrot</td><td class="py-1.5 pr-4 font-mono font-bold">O</td><td class="py-1.5 pr-4">Oscar</td><td class="py-1.5 pr-4 font-mono font-bold">X</td><td class="py-1.5">X-ray</td></tr>
        <tr class="border-b border-border/50"><td class="py-1.5 pr-4 font-mono font-bold">G</td><td class="py-1.5 pr-4">Golf</td><td class="py-1.5 pr-4 font-mono font-bold">P</td><td class="py-1.5 pr-4">Papa</td><td class="py-1.5 pr-4 font-mono font-bold">Y</td><td class="py-1.5">Yankee</td></tr>
        <tr class="border-b border-border/50"><td class="py-1.5 pr-4 font-mono font-bold">H</td><td class="py-1.5 pr-4">Hotel</td><td class="py-1.5 pr-4 font-mono font-bold">Q</td><td class="py-1.5 pr-4">Quebec</td><td class="py-1.5 pr-4 font-mono font-bold">Z</td><td class="py-1.5">Zulu</td></tr>
        <tr><td class="py-1.5 pr-4 font-mono font-bold">I</td><td class="py-1.5 pr-4">India</td><td class="py-1.5 pr-4 font-mono font-bold">R</td><td class="py-1.5 pr-4">Romeo</td><td class="py-1.5 pr-4 font-mono font-bold">0-9</td><td class="py-1.5">Zero–Niner</td></tr>
      </tbody>
    </table>
  </div>

  <ToolPageCta />
  <FaqSection faqs={faq} />
</BaseLayout>

<script>
const NATO: Record<string, string> = {
  'A':'Alpha','B':'Bravo','C':'Charlie','D':'Delta','E':'Echo','F':'Foxtrot','G':'Golf','H':'Hotel',
  'I':'India','J':'Juliett','K':'Kilo','L':'Lima','M':'Mike','N':'November','O':'Oscar','P':'Papa',
  'Q':'Quebec','R':'Romeo','S':'Sierra','T':'Tango','U':'Uniform','V':'Victor','W':'Whiskey',
  'X':'X-ray','Y':'Yankee','Z':'Zulu',
  '0':'Zero','1':'One','2':'Two','3':'Three','4':'Four','5':'Five','6':'Six','7':'Seven','8':'Eight','9':'Niner',
  '.':'Decimal',',':'Comma','-':'Dash','_':'Underscore',' ':'[space]'
};

function convert(text: string) {
  const upper = text.toUpperCase();
  const parts: string[] = [];
  const spoken: string[] = [];
  for (const ch of upper) {
    const word = NATO[ch];
    if (word) {
      parts.push(`<span class="inline-block bg-primary/10 text-primary rounded px-1.5 py-0.5 mr-1 mb-1 text-xs font-mono">${word}</span>`);
      spoken.push(word);
    } else {
      parts.push(`<span class="inline-block bg-bg-card border border-border/50 rounded px-1.5 py-0.5 mr-1 mb-1 text-xs font-mono">${ch}</span>`);
      spoken.push(ch);
    }
  }
  return { html: parts.join(''), spoken: spoken.join(', ') };
}

function update() {
  const input = (document.getElementById('inputText') as HTMLInputElement).value;
  const { html, spoken } = convert(input);
  (document.getElementById('phonetic') as HTMLElement).innerHTML = html || '<span class="text-text-muted">Type text above...</span>';
  (document.getElementById('spoken') as HTMLElement).textContent = spoken ? `Spoken: "${spoken}"` : '';
}

document.getElementById('inputText')?.addEventListener('input', update);
document.getElementById('copyBtn')?.addEventListener('click', () => {
  const input = (document.getElementById('inputText') as HTMLInputElement).value;
  const { spoken } = convert(input);
  navigator.clipboard.writeText(spoken);
  const btn = document.getElementById('copyBtn');
  if (btn) { btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = 'Copy', 2000); }
});
update();
</script>
