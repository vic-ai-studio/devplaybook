---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is load testing and when should I do it?", answer: "Load testing simulates multiple concurrent users hitting your application to measure performance under expected (and peak) load. Run load tests before major releases, after infrastructure changes, before anticipated traffic spikes (product launches, marketing campaigns), and regularly in CI to catch performance regressions." },
  { question: "What is the difference between k6 and Locust?", answer: "k6 uses JavaScript for test scripts and is optimized for high concurrency from a single machine with minimal CPU overhead. Locust uses Python and has a web UI for real-time monitoring. k6 is better for CI/CD integration and DevOps workflows; Locust is better for teams that prefer Python and want a visual dashboard." },
  { question: "What load test scenarios should I run?", answer: "Key scenarios: (1) Ramp-up test — gradually increase load to find the breaking point. (2) Spike test — sudden traffic surge then return to normal. (3) Soak test — sustained moderate load for hours to find memory leaks. (4) Stress test — load above expected peak to find failure modes. Start with ramp-up, then soak." },
  { question: "What thresholds should I set?", answer: "Common thresholds: http_req_duration p(95) < 500ms (95th percentile response under 500ms), http_req_failed rate < 0.01 (under 1% error rate). For strict SLAs, use p(99) < 1000ms. Set thresholds that match your user experience SLA, not arbitrary numbers." },
  { question: "How many virtual users (VUs) should I simulate?", answer: "Base your VU count on real traffic data. If your peak concurrent users is 500, test with 500 VUs (steady state) and spike to 1,500 VUs (3x peak). If you don't have data, start with 50 VUs, observe server metrics, then scale up. 1 VU ≈ 1 concurrent active user." },
];
---

<BaseLayout
  title="Load Test Scenario Builder — Generate k6 and Locust Load Test Configs"
  description="Free online load test scenario builder. Configure test type (ramp-up, spike, soak), virtual users, stages, and thresholds. Generates ready-to-run k6 JavaScript and Locust Python scripts."
  tool="load test scenario builder, k6 config generator, locust load test, performance test generator, load test script, stress test config"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Load Test Scenario Builder",
    "url": "https://devplaybook.cc/tools/load-test-scenario-builder",
    "description": "Generate k6 and Locust load test scenario configurations. Choose scenario type, configure VUs and stages, set thresholds, and copy ready-to-run scripts.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Load Test Scenario Builder</h1>
  <p class="text-text-muted mb-4">Build load test scenario configurations for <strong>k6</strong> or <strong>Locust</strong>. Choose a scenario template, configure your endpoint and VU count, then copy the generated script.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> k6 JS & Locust Python output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Ramp-up, spike, soak, stress</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auto-calculated stages</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Threshold configuration</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Config -->
    <div class="bg-bg-card border border-border rounded-xl p-5 flex flex-col gap-4">
      <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Scenario Configuration</h2>

      <div>
        <label class="block text-sm font-medium mb-1" for="tool-target">Output Format</label>
        <div class="grid grid-cols-2 gap-2">
          <button id="btn-k6" class="tool-btn py-2 px-4 rounded-lg border text-sm font-medium transition-colors bg-accent text-white border-accent">k6 (JavaScript)</button>
          <button id="btn-locust" class="tool-btn py-2 px-4 rounded-lg border text-sm font-medium transition-colors bg-bg border-border text-text hover:border-accent">Locust (Python)</button>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" for="scenario-type">Scenario Type</label>
        <select id="scenario-type" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors">
          <option value="rampup">Ramp-Up — gradually increase to peak load</option>
          <option value="spike">Spike — sudden burst then cool down</option>
          <option value="soak">Soak — sustained load over long period</option>
          <option value="stress">Stress — push beyond expected peak</option>
          <option value="smoke">Smoke — minimal load sanity check</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" for="target-url">Target URL</label>
        <input id="target-url" type="text" value="https://api.example.com/health" placeholder="https://api.example.com/endpoint" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm font-mono focus:outline-none focus:border-accent transition-colors" />
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" for="http-method-lt">HTTP Method</label>
        <select id="http-method-lt" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors">
          <option value="GET">GET</option>
          <option value="POST">POST</option>
          <option value="PUT">PUT</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" for="peak-vus">Peak Virtual Users (VUs)</label>
        <input id="peak-vus" type="number" value="100" min="1" max="10000" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" for="p95-threshold">p(95) Response Time Threshold (ms)</label>
        <input id="p95-threshold" type="number" value="500" min="50" step="50" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" for="error-rate">Max Error Rate (%)</label>
        <input id="error-rate" type="number" value="1" min="0.1" max="50" step="0.1" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
      </div>

      <div>
        <label class="block text-sm font-medium mb-1" for="auth-header">Auth Header (optional)</label>
        <input id="auth-header" type="text" placeholder="Bearer your-token-here" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm font-mono focus:outline-none focus:border-accent transition-colors" />
      </div>
    </div>

    <!-- Output -->
    <div class="bg-bg-card border border-border rounded-xl p-5 flex flex-col gap-3">
      <div class="flex items-center justify-between">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Generated Script</h2>
        <button id="copy-script" class="flex items-center gap-1.5 text-xs bg-bg border border-border hover:border-accent text-text-muted hover:text-accent px-3 py-1.5 rounded-lg transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          Copy
        </button>
      </div>
      <pre id="script-output" class="flex-1 bg-bg rounded-lg p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text border border-border min-h-96"></pre>
      <div id="run-cmd" class="text-xs text-text-muted bg-bg border border-border rounded-lg p-3"></div>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Load Test Scenario Builder" relatedTags={['performance', 'testing', 'devops', 'k6', 'api', 'infrastructure']} />
</BaseLayout>

<script>
let activeToolFormat = 'k6';

const scenarios: Record<string, { stages: (vus: number) => string; locustWaitMin: number; locustWaitMax: number; description: string }> = {
  rampup: {
    stages: (vus) => `    { duration: '30s', target: ${Math.round(vus * 0.1)} },\n    { duration: '1m', target: ${vus} },\n    { duration: '3m', target: ${vus} },\n    { duration: '30s', target: 0 },`,
    locustWaitMin: 1, locustWaitMax: 3,
    description: 'Ramp from 0 to peak VUs, hold, then ramp down.',
  },
  spike: {
    stages: (vus) => `    { duration: '10s', target: ${Math.round(vus * 0.1)} },\n    { duration: '30s', target: ${vus * 3} },\n    { duration: '1m', target: ${vus} },\n    { duration: '30s', target: 0 },`,
    locustWaitMin: 0.1, locustWaitMax: 0.5,
    description: 'Sudden 3x spike then return to steady state.',
  },
  soak: {
    stages: (vus) => `    { duration: '2m', target: ${Math.round(vus * 0.5)} },\n    { duration: '1h', target: ${Math.round(vus * 0.5)} },\n    { duration: '2m', target: 0 },`,
    locustWaitMin: 2, locustWaitMax: 5,
    description: 'Sustained moderate load for 1 hour (memory leak detection).',
  },
  stress: {
    stages: (vus) => `    { duration: '1m', target: ${vus} },\n    { duration: '2m', target: ${vus * 2} },\n    { duration: '2m', target: ${vus * 3} },\n    { duration: '1m', target: 0 },`,
    locustWaitMin: 0.5, locustWaitMax: 1,
    description: 'Escalating stress test beyond expected peak load.',
  },
  smoke: {
    stages: (_) => `    { duration: '30s', target: 1 },\n    { duration: '1m', target: 1 },\n    { duration: '10s', target: 0 },`,
    locustWaitMin: 1, locustWaitMax: 2,
    description: 'Minimal load smoke test to verify basic functionality.',
  },
};

function generate() {
  const url = (document.getElementById('target-url') as HTMLInputElement).value.trim() || 'https://example.com';
  const method = (document.getElementById('http-method-lt') as HTMLSelectElement).value;
  const vus = parseInt((document.getElementById('peak-vus') as HTMLInputElement).value) || 100;
  const p95 = parseInt((document.getElementById('p95-threshold') as HTMLInputElement).value) || 500;
  const errRate = parseFloat((document.getElementById('error-rate') as HTMLInputElement).value) / 100;
  const authHeader = (document.getElementById('auth-header') as HTMLInputElement).value.trim();
  const scenarioType = (document.getElementById('scenario-type') as HTMLSelectElement).value;
  const scenario = scenarios[scenarioType];

  const headerStr = authHeader ? `\n    'Authorization': '${authHeader}',` : '';

  let script = '';
  let runCmd = '';

  if (activeToolFormat === 'k6') {
    const stagesStr = scenario.stages(vus);
    script = `import http from 'k6/http';
import { check, sleep } from 'k6';

// ${scenario.description}
export const options = {
  stages: [
${stagesStr}
  ],
  thresholds: {
    http_req_duration: ['p(95)<${p95}'],
    http_req_failed: ['rate<${errRate}'],
  },
};

export default function () {
  const headers = {
    'Content-Type': 'application/json',${headerStr}
  };

  const res = http.${method.toLowerCase()}('${url}', null, { headers });

  check(res, {
    'status is 2xx': (r) => r.status >= 200 && r.status < 300,
    'response time < ${p95}ms': (r) => r.timings.duration < ${p95},
  });

  sleep(1);
}`;
    runCmd = `# Install: npm install -g k6\n# Run:     k6 run load-test.js\n# Cloud:   k6 cloud load-test.js`;
  } else {
    // Locust Python
    script = `from locust import HttpUser, task, between

# ${scenario.description}
# Peak VUs: ${vus} | p(95) target: <${p95}ms | Max error: ${(errRate*100).toFixed(1)}%

class LoadTestUser(HttpUser):
    wait_time = between(${scenario.locustWaitMin}, ${scenario.locustWaitMax})
    host = "${url.replace(/\/[^\/]*$/, '')}"
${authHeader ? `\n    def on_start(self):\n        self.client.headers.update({\n            "Authorization": "${authHeader}"\n        })\n` : ''}
    @task
    def load_endpoint(self):
        with self.client.${method.toLowerCase()}(
            "${url.replace(/^https?:\/\/[^\/]+/, '')}",
            catch_response=True,
        ) as response:
            if response.status_code >= 400:
                response.failure(f"Got status {response.status_code}")
            elif response.elapsed.total_seconds() * 1000 > ${p95}:
                response.failure(f"Slow: {response.elapsed.total_seconds()*1000:.0f}ms")
            else:
                response.success()`;
    runCmd = `# Install: pip install locust\n# Run:     locust -f locustfile.py --headless -u ${vus} -r ${Math.round(vus/10)} --run-time 5m\n# UI:      locust -f locustfile.py  (open http://localhost:8089)`;
  }

  (document.getElementById('script-output') as HTMLElement).textContent = script;
  (document.getElementById('run-cmd') as HTMLElement).textContent = runCmd;
}

document.getElementById('btn-k6')!.addEventListener('click', function() {
  activeToolFormat = 'k6';
  (this as HTMLElement).className = 'tool-btn py-2 px-4 rounded-lg border text-sm font-medium transition-colors bg-accent text-white border-accent';
  (document.getElementById('btn-locust') as HTMLElement).className = 'tool-btn py-2 px-4 rounded-lg border text-sm font-medium transition-colors bg-bg border-border text-text hover:border-accent';
  generate();
});

document.getElementById('btn-locust')!.addEventListener('click', function() {
  activeToolFormat = 'locust';
  (this as HTMLElement).className = 'tool-btn py-2 px-4 rounded-lg border text-sm font-medium transition-colors bg-accent text-white border-accent';
  (document.getElementById('btn-k6') as HTMLElement).className = 'tool-btn py-2 px-4 rounded-lg border text-sm font-medium transition-colors bg-bg border-border text-text hover:border-accent';
  generate();
});

['scenario-type','target-url','http-method-lt','peak-vus','p95-threshold','error-rate','auth-header'].forEach(id => {
  document.getElementById(id)!.addEventListener('input', generate);
  document.getElementById(id)!.addEventListener('change', generate);
});

document.getElementById('copy-script')!.addEventListener('click', function() {
  const code = (document.getElementById('script-output') as HTMLElement).textContent || '';
  navigator.clipboard.writeText(code).then(() => {
    const btn = this as HTMLElement;
    const orig = btn.innerHTML;
    btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Copied!';
    setTimeout(() => { btn.innerHTML = orig; }, 2000);
  });
});

generate();
</script>
