---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HttpMockServerConfig from '../../components/HttpMockServerConfig.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is MSW (Mock Service Worker)?", answer: "MSW intercepts network requests at the service worker level in browsers, or using a custom Node server in tests. It lets you mock REST and GraphQL APIs without changing application code. It's the most popular choice for frontend integration tests with React Testing Library or Vitest." },
  { question: "What is json-server?", answer: "json-server creates a full fake REST API from a JSON file in about 30 seconds. It auto-generates CRUD endpoints for each resource in your db.json. Ideal for rapid prototyping and frontend development when the real backend isn't ready yet." },
  { question: "What is WireMock?", answer: "WireMock is a flexible API mocking tool available as a standalone server or Java library. It's popular in Java/Spring ecosystems and enterprise environments. It supports request matching by URL, method, headers, and body, as well as response templating and stateful behavior." },
  { question: "When should I use MSW vs json-server?", answer: "Use MSW for frontend testing (Jest/Vitest + Testing Library) — it intercepts fetch/XHR at the browser level with zero configuration changes. Use json-server for development mocking when you need a quick REST API with CRUD operations accessible from any tool (browser, curl, Postman). Use WireMock for Java/enterprise environments or when you need complex request matching and stateful scenarios." },
  { question: "How do I add a delay to simulate slow APIs?", answer: "Set the delay field (in milliseconds) on each route. This is useful for testing loading states, skeleton screens, and timeouts in your application. MSW uses the delay() helper from the msw package. json-server supports a global --delay flag. WireMock uses fixedDelayMilliseconds per mapping." },
];
---

<BaseLayout
  title="HTTP Mock Server Config Generator — MSW, json-server, WireMock"
  description="Generate HTTP mock server configuration for MSW, json-server, or WireMock. Define routes, methods, status codes, response bodies, and delays — export ready-to-use config."
  tool="HTTP mock server generator, MSW config generator, json-server config, WireMock config, API mock tool, REST mock generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">HTTP Mock Server Config Generator</h1>
  <p class="text-text-muted mb-4">Define your API routes visually and generate ready-to-use mock server configuration for <strong>MSW</strong>, <strong>json-server</strong>, or <strong>WireMock</strong>. Set methods, paths, status codes, response bodies, and optional delays to simulate slow endpoints.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> MSW, json-server, WireMock</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Simulate delays & error codes</span>
  </div>
  <HttpMockServerConfig client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="HTTP Mock Server Config Generator" relatedTags={['testing', 'api', 'mock', 'frontend', 'msw', 'devtools']} />
</BaseLayout>
