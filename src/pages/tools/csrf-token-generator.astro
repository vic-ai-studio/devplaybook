---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CsrfTokenGenerator from '../../components/CsrfTokenGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is a CSRF token and why do I need one?",
    answer: "CSRF (Cross-Site Request Forgery) is an attack where a malicious website tricks a logged-in user's browser into making an unintended request to another site — for example, submitting a form or transferring funds. A CSRF token is a secret, random value tied to the user's session. Your server generates it, embeds it in forms, and validates it on every state-changing request (POST, PUT, DELETE). Because attackers on other origins can't read your page's content, they can't obtain the token and the forged request is rejected."
  },
  {
    question: "How many bytes should a CSRF token be?",
    answer: "32 bytes (256-bit) is the standard recommendation and provides ample security for virtually all applications. 16 bytes (128-bit) is still considered secure and matches what many frameworks use internally. 64 bytes offers extra margin but yields unnecessarily long token strings without a practical security benefit. The key requirement is that tokens are generated with a cryptographically secure random number generator — the length matters less than the source of randomness."
  },
  {
    question: "What's the difference between hex, base64, and base64url formats?",
    answer: "All three formats encode the same random bytes — only the representation differs. Hex uses characters 0-9 and a-f, producing a string twice as long as the byte count (32 bytes → 64 chars). It's easy to read and safe in all contexts. Base64 uses A-Z, a-z, 0-9, +, / and = padding (32 bytes → ~44 chars). Base64url replaces + with - and / with _, and omits padding, making it safe for URLs, HTTP headers, and cookies without additional encoding. For CSRF tokens embedded in HTML forms or HTTP headers, base64url is the most convenient choice."
  },
  {
    question: "Do I need CSRF protection for REST APIs that use JWT Bearer tokens?",
    answer: "No — if your API exclusively uses Authorization: Bearer <token> headers (not cookies) for authentication, CSRF is not a concern. Browsers enforce the Same-Origin Policy on custom headers: a cross-origin page cannot set an Authorization header on a fetch/XHR request without first passing a CORS preflight, which your server controls. CSRF exploits cookie-based authentication because browsers automatically attach cookies to cross-origin requests. If you use cookies for auth, even for an API, you need CSRF protection."
  },
  {
    question: "Does SameSite=Strict on my session cookie replace CSRF tokens?",
    answer: "SameSite=Strict prevents browsers from sending the cookie on any cross-site request, which effectively blocks most CSRF attacks in modern browsers. However, OWASP still recommends keeping CSRF tokens as a defense-in-depth layer because: (1) SameSite support varies across older browsers and certain mobile WebViews, (2) same-site subdomain vulnerabilities can bypass SameSite in some configurations, and (3) some browsers have known SameSite bugs. Using both SameSite and CSRF tokens gives you two independent protection layers."
  },
];
---

<BaseLayout
  title="CSRF Token Generator — Generate Secure CSRF Tokens & Implementation Examples"
  description="Generate cryptographically secure CSRF tokens in your browser. Choose token length (16/32/64 bytes), format (hex/base64/base64url), and batch-generate 5 tokens at once. Includes implementation examples for Express.js, Django, Rails, and FastAPI."
  tool="CSRF Token Generator, CSRF Protection, Cross-Site Request Forgery, Security Tokens, Express CSRF, Django CSRF, Rails CSRF"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "CSRF Token Generator",
    "url": "https://devplaybook.cc/tools/csrf-token-generator",
    "description": "Generate cryptographically secure CSRF tokens in your browser. Choose token length and format, batch-generate tokens, and see implementation examples for Express.js, Django, Rails, and FastAPI.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">CSRF Token Generator</h1>
  <p class="text-text-muted mb-4">
    Generate cryptographically secure CSRF tokens using the browser's
    <code class="text-accent font-mono">crypto.getRandomValues()</code> API.
    Choose token length and encoding format, batch-generate 5 tokens at once,
    and see ready-to-use implementation code for Express.js, Django, Rails, and FastAPI.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 16 / 32 / 64-byte tokens</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> hex / base64 / base64url</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Batch generate 5 tokens</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Express / Django / Rails / FastAPI examples</span>
  </div>
  <CsrfTokenGenerator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CSRF Token Generator" relatedTags={['security', 'csrf', 'authentication', 'express', 'developer-tools']} />
</BaseLayout>
