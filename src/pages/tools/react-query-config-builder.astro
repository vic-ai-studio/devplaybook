---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is TanStack Query (React Query)?", answer: "TanStack Query is an async state management library for React (and other frameworks). It handles fetching, caching, background updates, and synchronization of server state. Instead of manually managing loading/error/data state with useState and useEffect, you call useQuery and let the library handle everything." },
  { question: "What is staleTime?", answer: "staleTime is how long (in ms) fetched data is considered fresh. During this window, React Query won't refetch the data — it serves the cached version. After staleTime expires, data is considered stale, and React Query will refetch when the query is re-used (e.g., on window focus or component mount)." },
  { question: "What is gcTime (formerly cacheTime)?", answer: "gcTime (garbage collection time) is how long inactive query data stays in memory after all components using it unmount. Once gcTime expires, the cache entry is removed. gcTime should always be ≥ staleTime. Default is 5 minutes. Setting it to Infinity keeps data in memory until page reload." },
  { question: "When should I use initialData vs placeholderData?", answer: "initialData is treated as real data — it counts as a successful cache entry, respects staleTime, and won't trigger a background fetch if still fresh. placeholderData is UI-only — it's shown while the query loads but never persisted to the cache. Use initialData for SSR-hydrated data, placeholderData for skeleton/preview content." },
  { question: "What does retry do?", answer: "retry controls how many times React Query retries a failed request before marking the query as error state. Default is 3. Each retry uses exponential backoff (retryDelay). Set to false to disable retries (useful for user-input queries where immediate feedback is needed)." },
  { question: "How do I use QueryClient globally?", answer: "Create a QueryClient instance outside your component tree and pass it to QueryClientProvider at your app root. You can access it with useQueryClient() hook inside components for manual invalidation, prefetching, or setting cached data. For SSR/Next.js, create a new QueryClient per request to avoid shared state between users." },
];
---

<BaseLayout
  title="TanStack Query Config Builder — React Query staleTime & gcTime Calculator"
  description="Configure TanStack Query (React Query) settings visually. Calculate staleTime and gcTime, set retry logic, generate QueryClient config and useQuery/useMutation TypeScript code."
  tool="TanStack Query Config Builder, React Query staleTime Calculator, gcTime Calculator, React Query Configuration Generator, useQuery TypeScript Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">TanStack Query Config Builder</h1>
  <p class="text-text-muted mb-4">Configure your TanStack Query (React Query v5) setup visually. Set staleTime, gcTime, retry logic, and generate production-ready TypeScript code for your QueryClient and hooks.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> staleTime / gcTime calculator</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> QueryClient config generator</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> useQuery + useMutation code</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-5">
    <!-- Config Panel -->
    <div class="space-y-4">
      <!-- Presets -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">Presets</h2>
        <div class="grid grid-cols-2 gap-2">
          <button data-preset="realtime" class="preset-btn text-xs border border-border rounded-lg px-3 py-2 hover:border-primary hover:text-primary transition-colors text-left">
            <div class="font-medium">Real-time data</div>
            <div class="text-text-muted">stale: 0, gc: 30s</div>
          </button>
          <button data-preset="live" class="preset-btn text-xs border border-border rounded-lg px-3 py-2 hover:border-primary hover:text-primary transition-colors text-left">
            <div class="font-medium">Live feed</div>
            <div class="text-text-muted">stale: 10s, gc: 60s</div>
          </button>
          <button data-preset="normal" class="preset-btn text-xs border border-border rounded-lg px-3 py-2 hover:border-primary hover:text-primary transition-colors text-left">
            <div class="font-medium">Normal (default)</div>
            <div class="text-text-muted">stale: 0, gc: 5min</div>
          </button>
          <button data-preset="slow" class="preset-btn text-xs border border-border rounded-lg px-3 py-2 hover:border-primary hover:text-primary transition-colors text-left">
            <div class="font-medium">Slow-changing</div>
            <div class="text-text-muted">stale: 5min, gc: 10min</div>
          </button>
          <button data-preset="static" class="preset-btn text-xs border border-border rounded-lg px-3 py-2 hover:border-primary hover:text-primary transition-colors text-left">
            <div class="font-medium">Static data</div>
            <div class="text-text-muted">stale: 1h, gc: 24h</div>
          </button>
          <button data-preset="immutable" class="preset-btn text-xs border border-border rounded-lg px-3 py-2 hover:border-primary hover:text-primary transition-colors text-left">
            <div class="font-medium">Immutable</div>
            <div class="text-text-muted">stale: ∞, gc: ∞</div>
          </button>
        </div>
      </div>

      <!-- Timing Config -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Cache Timing</h2>
        <div class="space-y-4">
          <div>
            <div class="flex justify-between items-center mb-1">
              <label class="text-sm font-medium">staleTime</label>
              <span id="stale-display" class="text-sm font-mono text-primary">0 ms (immediate)</span>
            </div>
            <input id="stale-time" type="range" min="0" max="9" value="0" class="w-full accent-primary" />
            <div class="flex justify-between text-xs text-text-muted mt-1">
              <span>0 (always stale)</span><span>1h</span><span>∞</span>
            </div>
          </div>
          <div>
            <div class="flex justify-between items-center mb-1">
              <label class="text-sm font-medium">gcTime</label>
              <span id="gc-display" class="text-sm font-mono text-primary">5 min</span>
            </div>
            <input id="gc-time" type="range" min="0" max="9" value="4" class="w-full accent-primary" />
            <div class="flex justify-between text-xs text-text-muted mt-1">
              <span>30s</span><span>5min</span><span>∞</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Query Settings -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Query Settings</h2>
        <div class="space-y-3">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium mb-1">retry</label>
              <select id="retry" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
                <option value="false">false (disabled)</option>
                <option value="1">1</option>
                <option value="2">2</option>
                <option value="3" selected>3 (default)</option>
                <option value="5">5</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">retryDelay</label>
              <select id="retry-delay" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
                <option value="exponential" selected>Exponential (default)</option>
                <option value="1000">Fixed 1s</option>
                <option value="2000">Fixed 2s</option>
              </select>
            </div>
          </div>
          <div class="space-y-2">
            <label class="flex items-center gap-2 text-sm cursor-pointer">
              <input type="checkbox" id="refetch-focus" checked class="rounded" />
              <span>refetchOnWindowFocus</span>
            </label>
            <label class="flex items-center gap-2 text-sm cursor-pointer">
              <input type="checkbox" id="refetch-mount" checked class="rounded" />
              <span>refetchOnMount</span>
            </label>
            <label class="flex items-center gap-2 text-sm cursor-pointer">
              <input type="checkbox" id="refetch-reconnect" checked class="rounded" />
              <span>refetchOnReconnect</span>
            </label>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Query Key Example</label>
            <input id="query-key" type="text" value="['todos', userId]" placeholder="['todos', userId]"
              class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
          </div>
        </div>
      </div>
    </div>

    <!-- Code Output -->
    <div class="space-y-4">
      <!-- Timeline Visualization -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">Cache Lifecycle</h2>
        <div id="timeline" class="space-y-2 text-sm"></div>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-base font-semibold">Generated Code</h2>
          <button id="copy-btn" class="text-xs bg-primary/10 text-primary border border-primary/30 rounded-lg px-3 py-1.5 hover:bg-primary/20 transition-colors">Copy</button>
        </div>
        <pre id="code-output" class="text-xs font-mono bg-bg-card border border-border rounded-lg p-4 overflow-auto max-h-[450px] whitespace-pre-wrap text-text-muted"></pre>
      </div>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="TanStack Query Config Builder" relatedTags={['react', 'data-fetching', 'typescript', 'tanstack', 'frontend']} />
</BaseLayout>

<script>
  const STALE_VALUES = [0, 5000, 10000, 30000, 60000, 300000, 600000, 1800000, 3600000, Infinity];
  const GC_VALUES = [30000, 60000, 120000, 300000, 600000, 1800000, 3600000, 14400000, 86400000, Infinity];

  const PRESETS: Record<string, { stale: number; gc: number; focus: boolean; mount: boolean; reconnect: boolean; retry: string }> = {
    realtime: { stale: 0, gc: 1, focus: true, mount: true, reconnect: true, retry: 'false' },
    live: { stale: 1, gc: 2, focus: true, mount: true, reconnect: true, retry: '1' },
    normal: { stale: 0, gc: 4, focus: true, mount: true, reconnect: true, retry: '3' },
    slow: { stale: 5, gc: 5, focus: false, mount: true, reconnect: true, retry: '3' },
    static: { stale: 7, gc: 8, focus: false, mount: false, reconnect: false, retry: '2' },
    immutable: { stale: 9, gc: 9, focus: false, mount: false, reconnect: false, retry: '1' },
  };

  function msToLabel(ms: number): string {
    if (ms === Infinity) return 'Infinity';
    if (ms === 0) return '0';
    if (ms < 1000) return `${ms}ms`;
    if (ms < 60000) return `${ms / 1000}s`;
    if (ms < 3600000) return `${ms / 60000} min`;
    return `${ms / 3600000}h`;
  }

  function msToCode(ms: number): string {
    if (ms === Infinity) return 'Infinity';
    return String(ms);
  }

  function getStale(): number { return STALE_VALUES[parseInt((document.getElementById('stale-time') as HTMLInputElement).value)]; }
  function getGc(): number { return GC_VALUES[parseInt((document.getElementById('gc-time') as HTMLInputElement).value)]; }

  function updateDisplays() {
    const stale = getStale();
    const gc = getGc();
    document.getElementById('stale-display')!.textContent = stale === 0 ? '0 ms (immediate)' : msToLabel(stale);
    document.getElementById('gc-display')!.textContent = msToLabel(gc);
  }

  function updateTimeline() {
    const stale = getStale();
    const gc = getGc();
    const tl = document.getElementById('timeline')!;
    const rows = [
      { label: 'Fetch starts', time: 0, color: 'text-blue-500', desc: 'query executes' },
      { label: 'Data fresh', time: 0, color: 'text-green-500', desc: `for ${msToLabel(stale)}` },
      { label: 'Data goes stale', time: stale, color: 'text-yellow-500', desc: 'background refetch on next use' },
      { label: 'GC clears cache', time: gc === Infinity ? null : stale + gc, color: 'text-red-500', desc: stale + gc > 0 ? `at ${msToLabel(stale + gc)} total` : 'never' },
    ];
    tl.innerHTML = rows.map(r => `
      <div class="flex items-start gap-3">
        <div class="w-2 h-2 rounded-full mt-1 flex-shrink-0 ${r.color.replace('text-', 'bg-')}"></div>
        <div>
          <span class="font-medium ${r.color}">${r.label}</span>
          <span class="text-text-muted ml-2">${r.desc}</span>
        </div>
      </div>
    `).join('');
  }

  function generateCode(): string {
    const stale = getStale();
    const gc = getGc();
    const retry = (document.getElementById('retry') as HTMLSelectElement).value;
    const retryDelay = (document.getElementById('retry-delay') as HTMLSelectElement).value;
    const focus = (document.getElementById('refetch-focus') as HTMLInputElement).checked;
    const mount = (document.getElementById('refetch-mount') as HTMLInputElement).checked;
    const reconnect = (document.getElementById('refetch-reconnect') as HTMLInputElement).checked;
    const queryKey = (document.getElementById('query-key') as HTMLInputElement).value.trim() || "['todos']";

    const retryDelayCode = retryDelay === 'exponential'
      ? 'attemptIndex => Math.min(1000 * 2 ** attemptIndex, 30000)'
      : retryDelay;

    return `import { QueryClient, QueryClientProvider, useQuery, useMutation } from '@tanstack/react-query';

// QueryClient configuration
const queryClient = new QueryClient({
  defaultOptions: {
    queries: {
      staleTime: ${msToCode(stale)},
      gcTime: ${msToCode(gc)},
      retry: ${retry},
      retryDelay: ${retryDelayCode},
      refetchOnWindowFocus: ${focus},
      refetchOnMount: ${mount},
      refetchOnReconnect: ${reconnect},
    },
    mutations: {
      retry: ${retry === 'false' ? 'false' : '0'},
    },
  },
});

// Wrap your app
function App() {
  return (
    <QueryClientProvider client={queryClient}>
      <YourApp />
    </QueryClientProvider>
  );
}

// Query hook usage
function useTodos(userId: string) {
  return useQuery({
    queryKey: ${queryKey},
    queryFn: () => fetch(\`/api/todos?user=\${userId}\`).then(r => r.json()),
    staleTime: ${msToCode(stale)},   // override per-query
    gcTime: ${msToCode(gc)},
    select: (data) => data.filter((t: any) => !t.completed),
  });
}

// Mutation hook usage
function useCreateTodo() {
  return useMutation({
    mutationFn: (newTodo: { title: string }) =>
      fetch('/api/todos', {
        method: 'POST',
        body: JSON.stringify(newTodo),
      }).then(r => r.json()),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['todos'] });
    },
  });
}`;
  }

  function update() {
    updateDisplays();
    updateTimeline();
    document.getElementById('code-output')!.textContent = generateCode();
  }

  document.querySelectorAll('.preset-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const key = btn.getAttribute('data-preset')!;
      const p = PRESETS[key];
      (document.getElementById('stale-time') as HTMLInputElement).value = String(p.stale);
      (document.getElementById('gc-time') as HTMLInputElement).value = String(p.gc);
      (document.getElementById('refetch-focus') as HTMLInputElement).checked = p.focus;
      (document.getElementById('refetch-mount') as HTMLInputElement).checked = p.mount;
      (document.getElementById('refetch-reconnect') as HTMLInputElement).checked = p.reconnect;
      (document.getElementById('retry') as HTMLSelectElement).value = p.retry;
      update();
    });
  });

  document.querySelectorAll('input, select').forEach(el => {
    el.addEventListener('input', update);
    el.addEventListener('change', update);
  });

  document.getElementById('copy-btn')!.addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('code-output')!.textContent || '');
    const btn = document.getElementById('copy-btn')!;
    btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = 'Copy', 1500);
  });

  update();
</script>
