---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HAProxyConfigValidator from '../../components/HAProxyConfigValidator.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is HAProxy?", answer: "HAProxy (High Availability Proxy) is a free, open-source TCP/HTTP load balancer and proxy server. It's widely used in high-traffic websites including GitHub, Stack Overflow, and Twitter. It provides layer 4 (TCP) and layer 7 (HTTP) load balancing, SSL termination, health checks, and detailed stats." },
  { question: "What is the difference between HAProxy frontend and backend?", answer: "A frontend defines how HAProxy accepts connections — the bind address/port, ACL rules, and which backend to use. A backend defines the pool of servers to send traffic to, including the load balancing algorithm (roundrobin, leastconn) and health check configuration. A 'listen' block combines both into one section." },
  { question: "What load balancing algorithms does HAProxy support?", answer: "roundrobin (default, equal distribution), leastconn (send to least-loaded server), source (IP hash, sticky sessions by client IP), static-rr (like roundrobin but static weights), first (fill servers sequentially), uri (hash on URI path, useful for caching), url_param (hash on URL parameter), hdr (hash on HTTP header), and random." },
  { question: "How do HAProxy health checks work?", answer: "Add 'check' to a server line: 'server web1 127.0.0.1:8080 check'. By default, HAProxy makes a TCP connection. For HTTP health checks, add 'option httpchk GET /health HTTP/1.1' to the backend. Configure check interval with 'inter 2s', failure threshold with 'fall 3', and recovery with 'rise 2'. Failed servers are removed from rotation automatically." },
  { question: "How do I configure SSL termination in HAProxy?", answer: "In the frontend bind line: 'bind *:443 ssl crt /etc/ssl/certs/example.pem'. HAProxy expects the certificate and private key concatenated into one .pem file: cat fullchain.pem privkey.pem > example.pem. Add 'ssl-min-ver TLSv1.2' and 'ciphers ECDHE-ECDSA-AES256-GCM-SHA384:...'. For HTTP/2 support, add 'alpn h2,http/1.1'." },
  { question: "How do I test my HAProxy config?", answer: "Run: haproxy -c -f /etc/haproxy/haproxy.cfg. The -c flag checks configuration without starting the service. To reload without dropping connections: haproxy -sf $(cat /var/run/haproxy.pid) -f /etc/haproxy/haproxy.cfg. Or with systemd: systemctl reload haproxy." },
];
---

<BaseLayout
  title="HAProxy Config Validator — Validate HAProxy Configuration Online"
  description="Paste your haproxy.cfg and validate it instantly. Checks frontend/backend definitions, server directives, health checks, SSL config, balance algorithms, and timeout syntax. Runs 100% in your browser."
  tool="haproxy config validator, haproxy configuration checker, haproxy syntax check, haproxy online validator, load balancer config"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">HAProxy Config Validator</h1>
  <p class="text-text-muted mb-4">
    Paste your <code class="bg-surface px-1 rounded text-sm">haproxy.cfg</code> and catch configuration errors before deploying.
    Validates frontend/backend structure, server directives, health checks, SSL settings, and balance algorithms.
    Runs entirely in your browser — your config never leaves your machine.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Structure validation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Backend cross-reference</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> SSL & health check hints</span>
  </div>
  <HAProxyConfigValidator client:only="preact" />
  <FaqSection faq={faq} />
  <AffiliateSection category={['devops', 'hosting']} />
  <ToolPageCta currentTool="HAProxy Config Validator" relatedTags={['haproxy', 'load-balancer', 'devops', 'server', 'infrastructure']} />
</BaseLayout>
