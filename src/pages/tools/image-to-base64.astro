---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ImageToBase64 from '../../components/ImageToBase64.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Image to Base64 Converter"
  description="Convert any image (PNG, JPG, GIF, SVG, WebP) to Base64 encoding. Get the Base64 string, data URL, or CSS background-image value. Runs in your browser."
  tool="Image to Base64, Base64 Image Encoder, Data URL Generator, Inline Image Converter"
>
  <h1 class="text-3xl font-bold mb-2">Image to Base64 Converter</h1>
  <p class="text-text-muted mb-8">Drop or select any image (PNG, JPG, SVG, WebP, GIF) to convert it to Base64. Get the raw Base64 string, a data URL for use in HTML/CSS, or a ready-to-paste CSS background-image value. All processing is local — no upload.</p>
  <ImageToBase64 client:only="preact" />
  <ToolPageCta currentTool="Image to Base64 Converter" relatedTags={['base64', 'image', 'encoding', 'css', 'frontend']} />
</BaseLayout>
