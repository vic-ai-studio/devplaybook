---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ChangesetConfigBuilder from '../../components/ChangesetConfigBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Changesets and how does it work?",
    answer: "Changesets is a tool for managing versioning and changelogs in JavaScript monorepos (and single packages). The workflow: 1) Developers run `pnpm changeset` to add a changeset file (markdown) describing what changed and the semver bump type (patch/minor/major). 2) On merge to main, the Changesets GitHub Action creates a 'Version Packages' PR that bumps versions and updates CHANGELOGs. 3) When that PR merges, packages are automatically published to npm. This separates the 'what changed' decision (made by developers) from the 'when to release' decision (made by merging the Version PR)."
  },
  {
    question: "What is the difference between linked and fixed package groups?",
    answer: "Fixed packages always have the same version number — releasing one bumps all of them to the same version, even if the others have no changes. Use this for packages that are always released together and consumers use as a unit (like @babel/core and @babel/cli). Linked packages can have different version numbers but their changesets are considered together — if any linked package has a minor bump, all linked packages get at least a minor bump. Use linked for packages where the relative version matters but they don't need to be identical."
  },
  {
    question: "When should I use @changesets/changelog-github?",
    answer: "Use @changesets/changelog-github when your project is on GitHub and you want changelogs to include links to PRs and contributor GitHub handles. It makes changelogs like '- Fixed critical bug (#123) by @contributor'. Requires the `GITHUB_TOKEN` secret in GitHub Actions. For private repos or non-GitHub hosting, use the default changelog (`@changesets/cli/changelog`) which just uses commit messages. You can also write a custom changelog generator if you need a specific format."
  },
  {
    question: "What is updateInternalDependencies?",
    answer: "updateInternalDependencies controls how workspace package dependencies are updated when a package they depend on has a new release. 'patch' means that if @myorg/utils releases a patch, all packages depending on it get a patch bump to update their dependency. 'minor' bumps dependent packages more aggressively. For libraries where consumers need predictable updates, use 'patch'. For internal tools where you want to force consumers to acknowledge the update, use 'minor'."
  },
  {
    question: "How does the Changesets GitHub Action workflow work?",
    answer: "The changesets/action GitHub Action runs on every push to main. If there are pending changesets, it creates or updates a 'Version Packages' PR that shows the diff of version bumps and changelog updates. When you merge that PR, the action runs your `publish` script (e.g., `pnpm changeset publish`) which publishes changed packages to npm. The action uses the NPM_TOKEN secret for publishing. This flow gives you a clear 'pending release' PR to review before any packages go live."
  },
  {
    question: "What packages should I add to the ignore list?",
    answer: "Add packages to ignore that should never be published to npm but still live in your monorepo. Common examples: private apps (`apps/web`, `apps/docs`), internal tooling (`tools/scripts`), Storybook apps, and e2e test packages. Also ignore packages that have their own release process outside of Changesets. Make sure to also set `\"private\": true` in those packages' package.json so Changesets and npm both skip them during publish."
  },
];
---

<BaseLayout
  title="Changeset Config Builder — .changeset/config.json Generator"
  description="Build Changesets configuration for your monorepo or single package. Configure changelog format, linked/fixed package groups, ignore lists, and base branch. Generates .changeset/config.json and GitHub Actions workflow."
  tool="changeset config builder, changesets monorepo, changeset json generator, changeset github action, npm publish automation"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Changeset Config Builder",
    "url": "https://devplaybook.cc/tools/changeset-config-builder",
    "description": "Generate .changeset/config.json for Changesets. Configure changelog type, linked packages, fixed groups, ignored packages, and base branch. Includes GitHub Actions release workflow.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Changeset Config Builder</h1>
  <p class="text-text-muted mb-4">
    Generate <strong>.changeset/config.json</strong> for your Changesets setup. Configure changelog format (GitHub-linked or basic), linked and fixed package groups for monorepos, ignored packages, and base branch. Also generates a ready-to-use <strong>GitHub Actions release workflow</strong>.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Monorepo & single package</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Linked & fixed groups</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GitHub changelog format</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GitHub Actions workflow</span>
  </div>
  <ChangesetConfigBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Changeset Config Builder" relatedTags={['monorepo', 'npm', 'publish', 'versioning', 'github', 'javascript']} />
</BaseLayout>
