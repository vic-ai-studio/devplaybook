---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AwsCostEstimator from '../../components/AwsCostEstimator.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "How accurate is this AWS cost estimator?",
    answer: "This tool uses simplified on-demand pricing for US East (N. Virginia) region as of 2024. Actual costs depend on your specific region, reserved instance discounts, Savings Plans, data transfer between AZs, and usage patterns. Use this for ballpark estimates — always verify with the official AWS Pricing Calculator for production budgets."
  },
  {
    question: "What is the difference between on-demand and reserved instances?",
    answer: "On-demand instances are billed by the hour with no commitment — flexible but most expensive. Reserved Instances (1 or 3-year commitment) offer 30-60% savings. Savings Plans offer similar discounts with more flexibility. For stable workloads running 24/7, reserved instances pay for themselves quickly."
  },
  {
    question: "When should I use t3 vs m5 vs c5 instances?",
    answer: "t3 instances are burstable — great for dev environments and variable-load apps with occasional CPU spikes. m5 instances are general-purpose with balanced CPU/memory — best for most production workloads. c5 instances are compute-optimized — ideal for CPU-intensive tasks like encoding, ML inference, or batch processing."
  },
  {
    question: "Why does Multi-AZ double my RDS cost?",
    answer: "Multi-AZ RDS maintains a synchronous standby replica in a different availability zone. AWS charges for both the primary and standby instances. This provides automatic failover in under 60 seconds if the primary fails, which is worth the cost for production databases."
  },
  {
    question: "How does CloudFront reduce costs compared to direct EC2 bandwidth?",
    answer: "EC2 egress bandwidth costs $0.09/GB vs CloudFront at $0.0085/GB for the first 10TB. For high-traffic sites, CloudFront can reduce bandwidth costs by 90%+ while also improving latency by caching content at edge locations worldwide."
  },
  {
    question: "What are LCUs for Application Load Balancer?",
    answer: "LCU (Load Balancer Capacity Units) measure ALB resource consumption across 4 dimensions: new connections/sec, active connections, processed bytes, and rule evaluations. AWS charges for the highest-consumed dimension. For most web apps, 5-10 LCUs is typical at moderate traffic."
  },
];
---

<BaseLayout
  title="AWS Cost Estimator — EC2, RDS, S3, CloudFront Monthly Calculator"
  description="Estimate your monthly AWS costs for EC2 instances, RDS databases, S3 storage, CloudFront CDN, and Load Balancers. Interactive calculator with itemized breakdown."
  tool="AWS cost estimator, EC2 pricing calculator, RDS cost, S3 pricing, CloudFront cost, AWS monthly cost"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">AWS Cost Estimator</h1>
  <p class="text-text-muted mb-8">Estimate your monthly AWS infrastructure costs. Configure EC2 instances, RDS databases, S3 storage, CloudFront CDN, and Load Balancers to get an itemized cost breakdown.</p>
  <AwsCostEstimator client:only="preact" />
  <FaqSection faq={faq} />
  <AffiliateSection category={['cloud', 'devops']} />
  <ToolPageCta currentTool="AWS Cost Estimator" relatedTags={['aws', 'cloud', 'devops', 'infrastructure', 'cost-optimization']} />
</BaseLayout>
