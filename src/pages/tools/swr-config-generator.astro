---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is SWR?", answer: "SWR (stale-while-revalidate) is a React data-fetching library by Vercel. The name comes from the HTTP cache control strategy: serve stale data immediately while revalidating in the background. This gives users instant UI updates while keeping data fresh. SWR is lightweight, framework-agnostic (works with REST, GraphQL, any async source), and built for React." },
  { question: "What is dedupingInterval?", answer: "dedupingInterval prevents duplicate requests to the same key within the specified time window (default: 2 seconds). If multiple components call useSWR with the same key, only one network request fires. Subsequent calls use the in-flight request's result. Increase this for expensive endpoints, decrease for data that must always be fresh." },
  { question: "How does SWR handle focus revalidation?", answer: "When revalidateOnFocus is true (default), SWR re-fetches data whenever the browser tab regains focus. This is great for dashboards or collaborative apps where data may have changed while the user was away. Set it to false for data that's expensive to fetch or doesn't change often (e.g., user profile, static config)." },
  { question: "What is the difference between SWR and React Query?", answer: "Both are data-fetching libraries with similar features. SWR is lighter (~4KB) and simpler — great for straightforward data fetching in Next.js apps. React Query (TanStack Query) is more feature-rich: better mutation handling, query invalidation patterns, pagination utilities, and offline support. For most Next.js apps, SWR is sufficient; for complex server state management, React Query wins." },
  { question: "How do I share data between components in SWR?", answer: "Any two components using useSWR with the same key string automatically share the cache. No context provider is needed — SWR handles this globally. You can configure global defaults with SWRConfig at your app root. Use the useSWRConfig hook inside components to access the mutate function for manual cache updates." },
  { question: "What is optimistic UI with SWR?", answer: "Optimistic UI updates the local cache immediately before the server confirms the change. With SWR's mutate, you can update the cache optimistically and then revert on error: await mutate(key, optimisticData, { optimisticData, rollbackOnError: true, populateCache: true, revalidate: false }). This makes mutations feel instant to users." },
];
---

<BaseLayout
  title="SWR Config Generator — SWR Configuration with Revalidation Options"
  description="Generate SWR (stale-while-revalidate) configuration code for React. Set revalidation intervals, focus/reconnect behavior, deduping, error retries, and generate TypeScript SWRConfig and useSWR hooks."
  tool="SWR Config Generator, SWR Configuration Builder, SWR revalidation options, useSWR TypeScript generator, Next.js SWR setup"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">SWR Config Generator</h1>
  <p class="text-text-muted mb-4">Configure SWR (stale-while-revalidate) for your React or Next.js app. Set revalidation strategy, deduping intervals, error handling, and generate production-ready TypeScript code.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> SWRConfig global setup</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Revalidation strategy builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> useSWR + mutate examples</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-5">
    <!-- Config Panel -->
    <div class="space-y-4">
      <!-- Strategy Presets -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">Strategy Presets</h2>
        <div class="grid grid-cols-2 gap-2">
          <button data-preset="default" class="swr-preset text-xs border border-border rounded-lg px-3 py-2 hover:border-primary hover:text-primary transition-colors text-left">
            <div class="font-medium">Default</div><div class="text-text-muted">Focus + reconnect</div>
          </button>
          <button data-preset="aggressive" class="swr-preset text-xs border border-border rounded-lg px-3 py-2 hover:border-primary hover:text-primary transition-colors text-left">
            <div class="font-medium">Aggressive</div><div class="text-text-muted">Polling every 5s</div>
          </button>
          <button data-preset="conservative" class="swr-preset text-xs border border-border rounded-lg px-3 py-2 hover:border-primary hover:text-primary transition-colors text-left">
            <div class="font-medium">Conservative</div><div class="text-text-muted">Manual only</div>
          </button>
          <button data-preset="static" class="swr-preset text-xs border border-border rounded-lg px-3 py-2 hover:border-primary hover:text-primary transition-colors text-left">
            <div class="font-medium">Static data</div><div class="text-text-muted">No auto-revalidate</div>
          </button>
        </div>
      </div>

      <!-- Revalidation -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Revalidation Options</h2>
        <div class="space-y-3">
          <label class="flex items-center justify-between gap-2 text-sm cursor-pointer">
            <div>
              <span class="font-medium">revalidateOnFocus</span>
              <div class="text-xs text-text-muted">Refetch when tab regains focus</div>
            </div>
            <input type="checkbox" id="revalidate-focus" checked class="rounded" />
          </label>
          <label class="flex items-center justify-between gap-2 text-sm cursor-pointer">
            <div>
              <span class="font-medium">revalidateOnMount</span>
              <div class="text-xs text-text-muted">Refetch when component mounts</div>
            </div>
            <input type="checkbox" id="revalidate-mount" checked class="rounded" />
          </label>
          <label class="flex items-center justify-between gap-2 text-sm cursor-pointer">
            <div>
              <span class="font-medium">revalidateOnReconnect</span>
              <div class="text-xs text-text-muted">Refetch when network reconnects</div>
            </div>
            <input type="checkbox" id="revalidate-reconnect" checked class="rounded" />
          </label>
          <label class="flex items-center justify-between gap-2 text-sm cursor-pointer">
            <div>
              <span class="font-medium">revalidateIfStale</span>
              <div class="text-xs text-text-muted">Refetch if cache is stale on mount</div>
            </div>
            <input type="checkbox" id="revalidate-stale" checked class="rounded" />
          </label>
        </div>
      </div>

      <!-- Intervals & Retries -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-4">Timing & Retries</h2>
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium mb-1">refreshInterval (polling)</label>
            <select id="refresh-interval" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="0" selected>0 (disabled)</option>
              <option value="1000">1s</option>
              <option value="5000">5s</option>
              <option value="10000">10s</option>
              <option value="30000">30s</option>
              <option value="60000">1 min</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">dedupingInterval</label>
            <select id="dedup-interval" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="1000">1s</option>
              <option value="2000" selected>2s (default)</option>
              <option value="5000">5s</option>
              <option value="10000">10s</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">errorRetryCount</label>
            <select id="error-retry" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="0">0 (disabled)</option>
              <option value="3" selected>3 (default)</option>
              <option value="5">5</option>
              <option value="10">10</option>
            </select>
          </div>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="keep-prev" class="rounded" />
            <div>
              <span class="font-medium">keepPreviousData</span>
              <div class="text-xs text-text-muted">Show previous data during refetch</div>
            </div>
          </label>
        </div>
      </div>
    </div>

    <!-- Output -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-base font-semibold">Generated Code</h2>
        <button id="copy-btn" class="text-xs bg-primary/10 text-primary border border-primary/30 rounded-lg px-3 py-1.5 hover:bg-primary/20 transition-colors">Copy</button>
      </div>
      <pre id="code-output" class="text-xs font-mono bg-bg-card border border-border rounded-lg p-4 overflow-auto max-h-[600px] whitespace-pre-wrap text-text-muted"></pre>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SWR Config Generator" relatedTags={['react', 'nextjs', 'data-fetching', 'swr', 'frontend']} />
</BaseLayout>

<script>
  interface Preset {
    focus: boolean; mount: boolean; reconnect: boolean; stale: boolean;
    refresh: string; dedup: string; retry: string; keepPrev: boolean;
  }
  const PRESETS: Record<string, Preset> = {
    default: { focus: true, mount: true, reconnect: true, stale: true, refresh: '0', dedup: '2000', retry: '3', keepPrev: false },
    aggressive: { focus: true, mount: true, reconnect: true, stale: true, refresh: '5000', dedup: '1000', retry: '5', keepPrev: true },
    conservative: { focus: false, mount: true, reconnect: false, stale: false, refresh: '0', dedup: '5000', retry: '3', keepPrev: false },
    static: { focus: false, mount: false, reconnect: false, stale: false, refresh: '0', dedup: '10000', retry: '0', keepPrev: false },
  };

  function getBool(id: string): boolean { return (document.getElementById(id) as HTMLInputElement).checked; }
  function getVal(id: string): string { return (document.getElementById(id) as HTMLSelectElement).value; }

  function generateCode(): string {
    const focus = getBool('revalidate-focus');
    const mount = getBool('revalidate-mount');
    const reconnect = getBool('revalidate-reconnect');
    const stale = getBool('revalidate-stale');
    const refresh = getVal('refresh-interval');
    const dedup = getVal('dedup-interval');
    const retry = getVal('error-retry');
    const keepPrev = getBool('keep-prev');

    const lines: string[] = [];
    if (!focus) lines.push(`      revalidateOnFocus: false,`);
    if (!mount) lines.push(`      revalidateOnMount: false,`);
    if (!reconnect) lines.push(`      revalidateOnReconnect: false,`);
    if (!stale) lines.push(`      revalidateIfStale: false,`);
    if (refresh !== '0') lines.push(`      refreshInterval: ${refresh},`);
    if (dedup !== '2000') lines.push(`      dedupingInterval: ${dedup},`);
    if (retry !== '3') lines.push(`      errorRetryCount: ${retry},`);
    if (keepPrev) lines.push(`      keepPreviousData: true,`);

    const configBody = lines.length
      ? `{\n${lines.join('\n')}\n    }`
      : `{ /* using SWR defaults */ }`;

    return `import useSWR, { SWRConfig, useSWRConfig } from 'swr';

// Global fetcher (define once, use everywhere)
const fetcher = (url: string) => fetch(url).then(r => {
  if (!r.ok) throw new Error('Request failed: ' + r.status);
  return r.json();
});

// Global SWR configuration — wrap your app
function App() {
  return (
    <SWRConfig
      value=${configBody}
    >
      <YourApp />
    </SWRConfig>
  );
}

// Basic useSWR hook
interface Todo {
  id: number;
  title: string;
  completed: boolean;
}

function useTodos() {
  const { data, error, isLoading, isValidating, mutate } = useSWR<Todo[]>(
    '/api/todos',
    fetcher${refresh !== '0' ? `,\n    { refreshInterval: ${refresh} }` : ''}
  );

  return {
    todos: data,
    isLoading,
    isRefreshing: isValidating && !isLoading,
    error,
    refresh: () => mutate(),
  };
}

// Optimistic mutation example
function useUpdateTodo() {
  const { mutate } = useSWRConfig();

  return async (id: number, updates: Partial<Todo>) => {
    await mutate(
      '/api/todos',
      async (current: Todo[] = []) => {
        const res = await fetch(\`/api/todos/\${id}\`, {
          method: 'PATCH',
          body: JSON.stringify(updates),
        }).then(r => r.json());
        return current.map(t => t.id === id ? res : t);
      },
      {
        optimisticData: (current: Todo[] = []) =>
          current.map(t => t.id === id ? { ...t, ...updates } : t),
        rollbackOnError: true,
        revalidate: false,
      }
    );
  };
}`;
  }

  function update() {
    document.getElementById('code-output')!.textContent = generateCode();
  }

  document.querySelectorAll('.swr-preset').forEach(btn => {
    btn.addEventListener('click', () => {
      const key = btn.getAttribute('data-preset')!;
      const p = PRESETS[key];
      (document.getElementById('revalidate-focus') as HTMLInputElement).checked = p.focus;
      (document.getElementById('revalidate-mount') as HTMLInputElement).checked = p.mount;
      (document.getElementById('revalidate-reconnect') as HTMLInputElement).checked = p.reconnect;
      (document.getElementById('revalidate-stale') as HTMLInputElement).checked = p.stale;
      (document.getElementById('refresh-interval') as HTMLSelectElement).value = p.refresh;
      (document.getElementById('dedup-interval') as HTMLSelectElement).value = p.dedup;
      (document.getElementById('error-retry') as HTMLSelectElement).value = p.retry;
      (document.getElementById('keep-prev') as HTMLInputElement).checked = p.keepPrev;
      update();
    });
  });

  document.querySelectorAll('input, select').forEach(el => {
    el.addEventListener('input', update);
    el.addEventListener('change', update);
  });

  document.getElementById('copy-btn')!.addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('code-output')!.textContent || '');
    const btn = document.getElementById('copy-btn')!;
    btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = 'Copy', 1500);
  });

  update();
</script>
