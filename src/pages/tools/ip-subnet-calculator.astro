---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SubnetCalculator from '../../components/SubnetCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is CIDR notation?",
    answer: "CIDR (Classless Inter-Domain Routing) notation combines an IP address with a prefix length to define a network range. For example, 192.168.1.0/24 means a network with a 24-bit subnet mask (255.255.255.0), giving 254 usable host addresses."
  },
  {
    question: "How do I calculate the number of usable hosts?",
    answer: "Usable hosts = 2^(32 - prefix) - 2. The -2 subtracts the network address (all host bits 0) and broadcast address (all host bits 1). For /24: 2^8 - 2 = 254. For /16: 2^16 - 2 = 65,534. For /30: 2^2 - 2 = 2 (common for point-to-point links)."
  },
  {
    question: "What is a subnet mask?",
    answer: "A subnet mask is a 32-bit number that divides an IP address into network and host portions. /24 → 255.255.255.0, /16 → 255.255.0.0, /8 → 255.0.0.0. In binary, it's a contiguous block of 1s followed by 0s."
  },
  {
    question: "What is the difference between network address and broadcast address?",
    answer: "The network address (first address, all host bits = 0) identifies the subnet and cannot be assigned to a host. The broadcast address (last address, all host bits = 1) sends packets to all hosts on the subnet and also cannot be assigned."
  },
  {
    question: "What subnet should I use for a home/office network?",
    answer: "For small home networks, 192.168.1.0/24 (254 hosts) is standard. For medium offices, 10.0.0.0/22 (1022 hosts) or /23 (510 hosts) works well. For cloud VPCs, /16 gives room for multiple subnets. Reserve /28 or /30 for infrastructure point-to-point links."
  },
  {
    question: "How are private IP address ranges defined?",
    answer: "RFC 1918 defines three private ranges: 10.0.0.0/8 (Class A, ~16M addresses), 172.16.0.0/12 (Class B, ~1M addresses), and 192.168.0.0/16 (Class C, ~65K addresses). These are not routed on the public internet and require NAT to access external services."
  },
];
---

<BaseLayout
  title="IP Subnet Calculator — IPv4 CIDR Subnet Mask & Host Calculator"
  description="Calculate IPv4 subnet details from CIDR notation. Get network address, subnet mask, broadcast address, first/last usable host, and total hosts. Binary breakdown included. Free browser tool."
  tool="IP Subnet Calculator, CIDR Calculator, IPv4 Subnet, Network Address Calculator, Subnet Mask Calculator, IP Range Calculator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "IP Subnet Calculator",
    "url": "https://devplaybook.cc/tools/ip-subnet-calculator",
    "description": "Calculate IPv4 subnet details from CIDR notation. Get network address, subnet mask, broadcast address, host range, and total usable hosts instantly.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">IP Subnet Calculator</h1>
  <p class="text-text-muted mb-4">
    Enter an IPv4 address with CIDR prefix (e.g., <code class="font-mono bg-surface px-1 rounded text-sm">192.168.1.0/24</code>) to calculate
    the network address, subnet mask, broadcast address, usable host range, and total hosts. Binary breakdown included.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Network & broadcast address</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Host range & total hosts</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <SubnetCalculator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="IP Subnet Calculator" relatedTags={['network', 'devops', 'linux', 'infrastructure', 'security']} />
</BaseLayout>
