---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DockerfileGenerator from '../../components/DockerfileGenerator.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What languages does this Dockerfile generator support?", answer: "It supports Node.js, Python, Go, Java, and Rust. Each language template uses the official base image and follows Docker best practices for that ecosystem — package manager caching, proper ENTRYPOINT/CMD, and non-root user setup." },
  { question: "What is a multi-stage Docker build and why should I use it?", answer: "Multi-stage builds use multiple FROM statements. The build stage installs dependencies and compiles code, then a smaller runtime stage copies only the final artifacts. This dramatically reduces image size — often 50–90% smaller — and removes build tools from production." },
  { question: "How do I choose the right base image version?", answer: "Use specific version tags (e.g. node:20-alpine) instead of 'latest' for reproducible builds. Alpine variants are smaller but may lack some system libraries. Use slim variants as a middle ground between size and compatibility." },
  { question: "Can I add custom layers to the generated Dockerfile?", answer: "Yes. The generator lets you add custom RUN, COPY, and ENV instructions. You can install system packages, set environment variables, and add configuration files to customize the build for your project." },
  { question: "Is the generated Dockerfile production-ready?", answer: "The generated Dockerfile follows Docker best practices: layer ordering for optimal caching, .dockerignore awareness, non-root user setup, and proper signal handling. Review the output and adjust for your specific deployment requirements." },
];
---

<BaseLayout
  title="Dockerfile Generator — Node.js, Python, Go, Java, Rust"
  description="Generate production-ready Dockerfiles for Node.js, Python, Go, Java, and Rust with an interactive wizard. Supports multi-stage builds for 50–90% smaller images, custom RUN/COPY/ENV layers, version selection, port configuration, and non-root user setup. Follow Docker best practices instantly — perfect for containerizing APIs, microservices, and CI/CD pipelines. Free DevOps tool, runs in your browser."
  tool="Dockerfile Generator, Docker Builder, Node Dockerfile, Python Dockerfile, Multi-stage Docker Build"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Dockerfile Generator</h1>
  <p class="text-text-muted mb-4">Generate production-ready Dockerfiles for common stacks. Select your language, customize layers, and enable multi-stage builds.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <DockerfileGenerator client:load />
  <!-- Real-World Use Cases -->
  <section class="mt-12 mb-8">
    <h2 class="text-2xl font-bold mb-6">Real-World Use Cases</h2>

    <div class="space-y-6">
      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">1. Containerizing a Next.js App for Vercel/Fly.io</h3>
        <p class="text-text-muted mb-3">You have a Next.js 14 app and need a Docker image for deployment to Fly.io. Select Node.js, enable multi-stage builds, and get a Dockerfile that separates <code class="font-mono text-sm bg-bg-card px-1 rounded">npm ci</code> from the production runtime — resulting in a ~150MB image instead of 1GB+.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Settings</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`Language: Node.js\nVersion: 20-alpine\nMulti-stage: Yes\nPort: 3000\nCMD: npm start`}</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Generated Dockerfile (excerpt)</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`FROM node:20-alpine AS builder\nWORKDIR /app\nCOPY package*.json ./\nRUN npm ci\nCOPY . .\nRUN npm run build\n\nFROM node:20-alpine\nCOPY --from=builder /app .\nEXPOSE 3000\nCMD ["npm", "start"]`}</pre>
          </div>
        </div>
      </div>

      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">2. Building a Python FastAPI Microservice</h3>
        <p class="text-text-muted mb-3">Your FastAPI service needs a production Dockerfile with pip caching and a non-root user. Select Python, add a custom <code class="font-mono text-sm bg-bg-card px-1 rounded">RUN</code> for system dependencies, and the generator creates a secure, cacheable image.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Settings</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`Language: Python\nVersion: 3.12-slim\nPort: 8000\nCustom RUN: apt-get install -y\n  libpq-dev\nCMD: uvicorn main:app`}</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Generated Dockerfile (excerpt)</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`FROM python:3.12-slim\nRUN apt-get install -y libpq-dev\nWORKDIR /app\nCOPY requirements.txt .\nRUN pip install --no-cache-dir\n  -r requirements.txt\nCOPY . .\nEXPOSE 8000\nUSER appuser\nCMD ["uvicorn", "main:app"]`}</pre>
          </div>
        </div>
      </div>

      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">3. Compiling a Go Binary for Minimal Alpine Image</h3>
        <p class="text-text-muted mb-3">Go compiles to a static binary — perfect for tiny Docker images. Enable multi-stage to build in a full Go image and copy only the binary to a ~5MB Alpine or scratch image.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Settings</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`Language: Go\nVersion: 1.22-alpine\nMulti-stage: Yes\nPort: 8080`}</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Generated Dockerfile (excerpt)</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`FROM golang:1.22-alpine AS build\nWORKDIR /src\nCOPY go.* ./\nRUN go mod download\nCOPY . .\nRUN CGO_ENABLED=0 go build\n  -o /app ./...\n\nFROM alpine:3.19\nCOPY --from=build /app /app\nEXPOSE 8080\nENTRYPOINT ["/app"]`}</pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Step-by-Step Guide -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">How to Use — Step by Step</h2>
    <ol class="list-decimal list-inside space-y-3 text-text-muted">
      <li><strong>Select your language</strong> — Choose Node.js, Python, Go, Java, or Rust. The template adjusts base image, package manager, and build commands automatically.</li>
      <li><strong>Pick a version</strong> — Select the runtime version (e.g. <code class="font-mono text-sm bg-bg-card px-1 rounded">node:20-alpine</code>, <code class="font-mono text-sm bg-bg-card px-1 rounded">python:3.12-slim</code>). Alpine variants produce smaller images; slim variants offer broader compatibility.</li>
      <li><strong>Enable multi-stage</strong> — Toggle multi-stage builds to separate the build environment from the production runtime. This reduces image size by 50–90%.</li>
      <li><strong>Add custom layers</strong> — Add <code class="font-mono text-sm bg-bg-card px-1 rounded">RUN</code>, <code class="font-mono text-sm bg-bg-card px-1 rounded">COPY</code>, or <code class="font-mono text-sm bg-bg-card px-1 rounded">ENV</code> instructions for system packages, config files, or environment variables specific to your project.</li>
      <li><strong>Copy the Dockerfile</strong> — Click copy, paste into your project root as <code class="font-mono text-sm bg-bg-card px-1 rounded">Dockerfile</code>, and run <code class="font-mono text-sm bg-bg-card px-1 rounded">docker build -t myapp .</code> to build your image.</li>
    </ol>
  </section>

  <FaqSection faq={faq} />
  <AffiliateSection category={['deployment', 'devops']} />
  <ToolPageCta currentTool="Dockerfile Generator" relatedTags={['devops', 'docker', 'ci-cd', 'boilerplate']} />
</BaseLayout>
