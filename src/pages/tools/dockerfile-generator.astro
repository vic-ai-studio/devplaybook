---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DockerfileGenerator from '../../components/DockerfileGenerator.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout title="Dockerfile Generator" description="Generate Dockerfiles for Node.js, Python, Go, Java, and Rust. Interactive wizard with multi-stage builds, custom layers, version selection, and port configuration. Free DevOps tool." tool="Dockerfile Generator, Docker Builder, Node Dockerfile, Python Dockerfile, Multi-stage Docker Build">
  <h1 class="text-3xl font-bold mb-2">Dockerfile Generator</h1>
  <p class="text-text-muted mb-8">Generate production-ready Dockerfiles for common stacks. Select your language, customize layers, and enable multi-stage builds.</p>
  <DockerfileGenerator client:load />
  <AffiliateSection category={['deployment', 'devops']} />
  <ToolPageCta currentTool="Dockerfile Generator" relatedTags={['devops', 'docker', 'ci-cd', 'boilerplate']} />
</BaseLayout>
