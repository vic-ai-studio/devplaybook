---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Base64EncoderPro from '../../components/Base64EncoderPro.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is Base64 encoding?", answer: "Base64 is a binary-to-text encoding scheme that represents binary data using 64 printable ASCII characters (A-Z, a-z, 0-9, +, /). It's commonly used to encode binary data (images, files) for transmission over text-based protocols like HTTP, JSON, and email." },
  { question: "What is URL-safe Base64?", answer: "URL-safe Base64 replaces + with - and / with _ to produce output that can be included in URLs and filenames without percent-encoding. Required for JWT tokens and many web APIs." },
  { question: "How do I encode an image to Base64?", answer: "Switch to the 'Image' or 'File' tab. Select your image file — the tool outputs a data URI (data:image/png;base64,...) ready to embed in HTML <img src> or CSS background-image." },
  { question: "What's the size overhead of Base64?", answer: "Base64 encoding increases data size by approximately 33% (every 3 bytes becomes 4 characters). So a 100KB image becomes approximately 133KB when Base64-encoded." },
  { question: "Is my data sent to any server?", answer: "No. All encoding and decoding runs entirely in your browser using JavaScript. Your data never leaves your device." },
];
---

<BaseLayout
  title="Base64 Encoder & Decoder Pro — Text, Image & File Encoding"
  description="Advanced Base64 encoder and decoder. Support for text, images, and files. URL-safe mode, data URI generation, and instant preview. No file size limits. Runs in your browser."
  tool="Base64 Encoder, Base64 Decoder, Base64 Encode Online, Base64 to Text, Image to Base64, Data URI Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Base64 Encoder & Decoder Pro</h1>
  <p class="text-text-muted mb-4">Advanced Base64 tool supporting text, image, and file encoding. URL-safe mode, data URI generation, and instant preview. All processing runs client-side — your data never leaves your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Text, image & file support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> URL-safe Base64 (JWT compatible)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Data URI generation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Client-side only</span>
  </div>
  <Base64EncoderPro client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Base64 Encoder & Decoder Pro" relatedTags={['encoding', 'security', 'converter', 'base64', 'utilities']} />
</BaseLayout>
