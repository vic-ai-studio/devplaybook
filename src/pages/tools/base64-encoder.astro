---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Base64EncoderPro from '../../components/Base64EncoderPro.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is Base64 encoding?", answer: "Base64 is a binary-to-text encoding scheme that converts binary data into a string of 64 printable ASCII characters (A-Z, a-z, 0-9, +, /). It's widely used to embed images in HTML/CSS, transmit files over JSON APIs, and encode credentials in HTTP headers." },
  { question: "How do I convert an image to Base64?", answer: "Switch to the Image tab, click to upload your image (or drag it in), and the tool instantly generates both the raw Base64 string and the full data URI (data:image/png;base64,…). Copy the data URI and use it directly in an img src or CSS background-image." },
  { question: "How do I encode any file to Base64?", answer: "Switch to the File tab, select 'File → Base64', and upload any file — PDF, ZIP, JSON, binary, etc. The tool reads it in your browser and produces a raw Base64 string. To decode Base64 back to a file, select 'Base64 → File', paste your string, and click Download." },
  { question: "What is URL-safe Base64?", answer: "Standard Base64 uses + and / which have special meaning in URLs. URL-safe Base64 (RFC 4648) replaces + with - and / with _, and removes padding =. This makes the output safe for use in query parameters, filenames, and JWT tokens without percent-encoding." },
  { question: "Does Base64 encryption protect my data?", answer: "No. Base64 is encoding, not encryption — anyone can decode it instantly. It's designed for safe binary transport through text-only channels, not for data security. Never use Base64 as a substitute for encryption or hashing." },
  { question: "Is this tool safe for sensitive data?", answer: "Yes. All encoding and decoding runs 100% in your browser using JavaScript. No data is sent to any server — not for text, images, or files. Everything stays on your machine." },
  { question: "Why is Base64 output larger than the input?", answer: "Base64 encodes every 3 bytes of input into 4 ASCII characters, creating approximately 33% size overhead. This is the trade-off for encoding binary data into a text-safe format." },
];
---

<BaseLayout
  title="Base64 Encoder & Decoder — Text, Image & File Converter Online"
  description="Free Base64 Encoder & Decoder. Convert text, images, and any file to Base64 and back. Supports URL-safe Base64, image data URIs, and file download from Base64. Runs 100% in your browser — no data sent to any server."
  tool="Base64 Encoder, Base64 Decoder, Image to Base64, File to Base64, Data URI Generator, URL-safe Base64, Base64 Converter Online, Base64 File Download"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Base64 Encoder & Decoder</h1>
  <p class="text-text-muted mb-4">Convert text, images, and any file to Base64 — and back. Three modes: <strong>Text</strong> (encode/decode strings), <strong>Image</strong> (generate data URIs for HTML/CSS), <strong>File</strong> (encode any binary file or download decoded Base64 as a file). URL-safe mode available. Everything runs in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Text · Image · File support</span>
  </div>
  <Base64EncoderPro client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Need simple text-only Base64?</p>
    <a href="/tools/base64" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Base64 (Text + URL-safe) →</a>
  </div>
  <ToolPageCta currentTool="Base64 Encoder & Decoder" relatedTags={['encoding', 'base64', 'data-uri', 'api', 'files']} />
</BaseLayout>
