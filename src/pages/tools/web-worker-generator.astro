        js: {
          worker: `// worker.js — Shared Memory Worker
self.addEventListener('message', function(e) {
  var sharedBuffer = e.data.buffer;
  var sharedArray = new Int32Array(sharedBuffer);

  // Signal ready (index 0 = status)
  Atomics.store(sharedArray, 0, 1);

  // Do heavy computation, write results to shared buffer
  for (var i = 1; i < sharedArray.length; i++) {
    sharedArray[i] = computeValue(i);
  }

  // Signal done
  Atomics.store(sharedArray, 0, 2);
  Atomics.notify(sharedArray, 0, 1);
});

function computeValue(i) {
  return i * i; // Example: squares
}`,
          main: `// main.js — Main Thread (requires COOP/COEP headers)
// Server must set:
// Cross-Origin-Opener-Policy: same-origin
// Cross-Origin-Embedder-Policy: require-corp

var SIZE = 1024;
var buffer = new SharedArrayBuffer(SIZE * Int32Array.BYTES_PER_ELEMENT);
var sharedArray = new Int32Array(buffer);

var worker = new Worker('./worker.js');

worker.postMessage({ buffer: buffer });

// Poll for completion (or use Atomics.waitAsync)
Atomics.waitAsync(sharedArray, 0, 0).value.then(function() {
  if (Atomics.load(sharedArray, 0) === 2) {
    console.log('Worker done. Results:', Array.from(sharedArray.slice(1, 11)));
  }
});`
