self.addEventListener('message', (e: MessageEvent<{ buffer: SharedArrayBuffer }>) => {
  const sharedArray = new Int32Array(e.data.buffer);

  Atomics.store(sharedArray, 0, 1); // mark running

  for (let i = 1; i < sharedArray.length; i++) {
    sharedArray[i] = i * i;
  }

  Atomics.store(sharedArray, 0, 2); // mark done
  Atomics.notify(sharedArray, 0, 1);
});`,
