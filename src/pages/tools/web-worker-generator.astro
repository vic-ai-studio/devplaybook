    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 4 task types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 3 communication patterns</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript toggle</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Worker + main thread side by side</span>
  </div>

  <!-- Config -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <label class="block text-xs text-text-muted mb-1">Task Type</label>
        <select id="task-type" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="computation">Heavy Computation</option>
          <option value="image">Image Processing</option>
          <option value="parsing">Data Parsing (JSON/CSV)</option>
          <option value="custom">Custom Task</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Communication Pattern</label>
        <select id="comm-pattern" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="postmessage">postMessage (copy)</option>
          <option value="sharedbuffer">SharedArrayBuffer</option>
          <option value="broadcast">BroadcastChannel</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Language</label>
