    image: {
      postmessage: {
        js: {
          worker: `// worker.js — Image Processing Worker
self.addEventListener('message', function(e) {
  var imageData = e.data.imageData;
  var operation = e.data.operation;
  var processed;

  if (operation === 'grayscale') {
    processed = applyGrayscale(imageData);
  } else if (operation === 'invert') {
    processed = applyInvert(imageData);
  } else if (operation === 'blur') {
    processed = applyBoxBlur(imageData, e.data.radius || 1);
  } else {
    processed = imageData;
  }

  // Transfer back with ownership transfer (no copy!)
  self.postMessage({ imageData: processed }, [processed.data.buffer]);
});

function applyGrayscale(imgData) {
  var data = new Uint8ClampedArray(imgData.data);
  for (var i = 0; i < data.length; i += 4) {
    var avg = (data[i] + data[i+1] + data[i+2]) / 3;
    data[i] = data[i+1] = data[i+2] = avg;
  }
  return new ImageData(data, imgData.width, imgData.height);
}

function applyInvert(imgData) {
  var data = new Uint8ClampedArray(imgData.data);
  for (var i = 0; i < data.length; i += 4) {
    data[i] = 255 - data[i];
    data[i+1] = 255 - data[i+1];
    data[i+2] = 255 - data[i+2];
  }
  return new ImageData(data, imgData.width, imgData.height);
}

function applyBoxBlur(imgData, radius) {
  // Simple box blur implementation
  var data = new Uint8ClampedArray(imgData.data);
  var w = imgData.width, h = imgData.height;
  var output = new Uint8ClampedArray(data.length);
  for (var y = 0; y < h; y++) {
    for (var x = 0; x < w; x++) {
      var r=0,g=0,b=0,count=0;
      for (var dy=-radius; dy<=radius; dy++) {
        for (var dx=-radius; dx<=radius; dx++) {
          var nx=x+dx, ny=y+dy;
          if (nx>=0 && nx<w && ny>=0 && ny<h) {
            var idx=(ny*w+nx)*4;
            r+=data[idx]; g+=data[idx+1]; b+=data[idx+2]; count++;
          }
        }
      }
      var oi=(y*w+x)*4;
      output[oi]=r/count; output[oi+1]=g/count; output[oi+2]=b/count; output[oi+3]=data[oi+3];
    }
  }
  return new ImageData(output, w, h);
}`,
          main: `// main.js — Main Thread
