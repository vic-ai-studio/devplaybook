          worker: `// worker.js — Heavy Computation Worker
self.addEventListener('message', function(e) {
  var data = e.data;

  // Signal start
  self.postMessage({ type: 'progress', value: 0 });

  // Example: compute prime numbers up to N
  var result = computePrimes(data.limit);

  self.postMessage({ type: 'result', result: result });
});

function computePrimes(limit) {
  var sieve = new Uint8Array(limit + 1);
  var primes = [];

  for (var i = 2; i <= limit; i++) {
    if (!sieve[i]) {
      primes.push(i);
      for (var j = i * 2; j <= limit; j += i) {
        sieve[j] = 1;
      }
    }
  }
  return primes;
}`,
          main: `// main.js — Main Thread
var worker = new Worker('./worker.js');

worker.addEventListener('message', function(e) {
  if (e.data.type === 'progress') {
    console.log('Worker started...');
  } else if (e.data.type === 'result') {
    console.log('Primes found:', e.data.result.length);
    worker.terminate();
  }
});

worker.addEventListener('error', function(err) {
  console.error('Worker error:', err.message);
});

// Start computation
worker.postMessage({ limit: 100000 });`
        },
        ts: {
          worker: `// worker.ts — Heavy Computation Worker
interface WorkerMessage {
  limit: number;
}

interface WorkerResult {
  type: 'progress' | 'result';
  value?: number;
  result?: number[];
}

self.addEventListener('message', (e: MessageEvent<WorkerMessage>) => {
  const { limit } = e.data;

  self.postMessage({ type: 'progress', value: 0 } satisfies WorkerResult);

  const result = computePrimes(limit);

  self.postMessage({ type: 'result', result } satisfies WorkerResult);
});

function computePrimes(limit: number): number[] {
  const sieve = new Uint8Array(limit + 1);
  const primes: number[] = [];

  for (let i = 2; i <= limit; i++) {
    if (!sieve[i]) {
      primes.push(i);
      for (let j = i * 2; j <= limit; j += i) {
        sieve[j] = 1;
      }
    }
  }
  return primes;
}`,
          main: `// main.ts — Main Thread
import type { WorkerResult } from './worker';

const worker = new Worker(new URL('./worker.ts', import.meta.url), {
  type: 'module'
});

worker.addEventListener('message', (e: MessageEvent<WorkerResult>) => {
  if (e.data.type === 'progress') {
    console.log('Worker started...');
  } else if (e.data.type === 'result') {
    console.log('Primes found:', e.data.result?.length);
    worker.terminate();
  }
});

worker.addEventListener('error', (err: ErrorEvent) => {
  console.error('Worker error:', err.message);
});

worker.postMessage({ limit: 100000 });`
        }
