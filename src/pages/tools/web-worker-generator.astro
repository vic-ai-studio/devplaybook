          <option value="js">JavaScript</option>
          <option value="ts">TypeScript</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Code output side by side -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <div class="flex items-center justify-between mb-3">
        <div>
          <h2 class="text-sm font-medium" id="worker-file-label">worker.js</h2>
          <p class="text-xs text-text-muted">Background thread code</p>
        </div>
        <button id="copy-worker" class="px-3 py-1.5 bg-primary text-white rounded text-xs font-medium hover:bg-primary/90 transition-colors">Copy</button>
      </div>
      <pre id="worker-code" class="bg-surface rounded p-3 text-xs font-mono text-foreground/90 overflow-x-auto whitespace-pre max-h-96 overflow-y-auto"></pre>
    </div>
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <div class="flex items-center justify-between mb-3">
        <div>
          <h2 class="text-sm font-medium" id="main-file-label">main.js</h2>
