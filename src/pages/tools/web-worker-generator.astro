function processImage(operation: 'grayscale' | 'invert' | 'blur') {
  const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
  worker.postMessage({ imageData, operation }, [imageData.data.buffer]);
}

processImage('grayscale');`
