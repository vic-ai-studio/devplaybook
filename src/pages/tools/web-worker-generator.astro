      result = rows.map(row => {
        const vals = row.split(',');
        return Object.fromEntries(keys.map((k, i) => [k, vals[i]?.trim() ?? '']));
      });
    }
    self.postMessage({ success: true, result, count: result.length } satisfies ParseResult);
  } catch (err) {
    self.postMessage({ success: false, error: (err as Error).message } satisfies ParseResult);
  }
});`,
