type ImageOp = 'grayscale' | 'invert' | 'blur';

interface ImageTask {
  imageData: ImageData;
  operation: ImageOp;
  radius?: number;
}

self.addEventListener('message', (e: MessageEvent<ImageTask>) => {
  const { imageData, operation, radius = 1 } = e.data;
  let processed: ImageData;

  if (operation === 'grayscale') processed = applyGrayscale(imageData);
  else if (operation === 'invert') processed = applyInvert(imageData);
