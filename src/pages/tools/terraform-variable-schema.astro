---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TerraformVariableSchema from '../../components/TerraformVariableSchema.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the difference between variables.tf and terraform.tfvars?",
    answer: "variables.tf declares the variable schema — names, types, descriptions, and optional defaults. It tells Terraform what variables exist and what shape they must have. terraform.tfvars provides the actual values for those variables. Separating them is best practice: commit variables.tf to version control (it contains no secrets), and keep terraform.tfvars out of git (it may contain sensitive values). You can also use .tfvars.json for JSON-format variable values, or pass values via TF_VAR_name environment variables."
  },
  {
    question: "How does this tool differ from a form-based Terraform variable generator?",
    answer: "This tool takes a JSON object as input and automatically infers the correct Terraform types — string, number, bool, list, or map — from the JSON structure. You paste your existing configuration JSON (from an API response, environment config, or JSON Schema example) and immediately get a complete variables.tf with proper HCL type constraints, plus a matching terraform.tfvars with the actual values. This is faster than filling in a form field-by-field when you already have data in JSON format."
  },
  {
    question: "What Terraform types are supported and how are they inferred?",
    answer: "The tool infers: string (JSON strings), number (JSON numbers), bool (JSON booleans), list(string) (JSON arrays of strings), list(number) (JSON arrays of numbers), and map(string) (JSON objects with key-value pairs). For complex nested objects, it defaults to map(string) — you can override the type in the UI before copying. Terraform also supports object(&#123; attr = type &#125;) and tuple types for strict structural typing, which you'd add manually for complex nested schemas."
  },
  {
    question: "Should I commit terraform.tfvars to version control?",
    answer: "Generally no — terraform.tfvars often contains sensitive values like database passwords, API keys, and access tokens. Add *.tfvars to .gitignore. Use terraform.tfvars.example (committed) to document what values are needed, and the actual terraform.tfvars (gitignored) for real values. For CI/CD, inject variable values via TF_VAR_name environment variables or use a secrets manager like HashiCorp Vault, AWS Secrets Manager, or GitHub Actions secrets."
  },
];
---

<BaseLayout
  title="Terraform Variable Schema Generator — JSON to variables.tf Converter"
  description="Convert JSON objects or JSON Schema to Terraform variables.tf declarations. Automatically infer types and generate matching terraform.tfvars. Paste JSON and get HCL variables instantly."
  tool="terraform variable schema generator, json to variables.tf, terraform variable generator, hcl variable converter, terraform tfvars"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Terraform Variable Schema Generator",
    "url": "https://devplaybook.cc/tools/terraform-variable-schema",
    "description": "Convert JSON objects to Terraform variables.tf declarations. Automatically infer types (string, number, bool, list, map) and generate matching terraform.tfvars.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Terraform Variable Schema Generator</h1>
  <p class="text-text-muted mb-4">
    Paste a <strong>JSON object</strong> and instantly generate a complete <strong>variables.tf</strong> with inferred Terraform types (string, number, bool, list, map) plus a matching <strong>terraform.tfvars</strong>. Override types and descriptions before copying.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auto-infers HCL types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> variables.tf + terraform.tfvars</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Override types per variable</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No upload, runs in browser</span>
  </div>
  <TerraformVariableSchema client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Terraform Variable Schema Generator" relatedTags={['terraform', 'iac', 'devops', 'infrastructure', 'developer-tools']} />
</BaseLayout>
