---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CssUnitConverter from '../../components/CssUnitConverter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="CSS Unit Converter — px, rem, em, vw, vh, pt, %"
  description="Convert between CSS units: px, rem, em, vw, vh, pt, and %. Configure base font size, viewport dimensions, and parent element size. Instant conversion."
  tool="CSS Unit Converter, px to rem, rem to px, em to px, CSS Units Calculator"
>
  <h1 class="text-3xl font-bold mb-2">CSS Unit Converter</h1>
  <p class="text-text-muted mb-8">Convert CSS values between px, rem, em, vw, vh, pt, and % instantly. Set your base font size, parent size, and viewport dimensions for accurate relative unit calculations.</p>
  <CssUnitConverter client:only="preact" />
  <ToolPageCta currentTool="CSS Unit Converter" relatedTags={['css', 'frontend', 'responsive', 'typography']} />
</BaseLayout>
