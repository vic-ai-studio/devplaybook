---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is a service worker and how does it enable caching?", answer: "A service worker is a JavaScript file that runs in a background thread, separate from the web page. It can intercept network requests and serve responses from a cache. Unlike HTTP caching (controlled by response headers), service worker caching is programmatic — you decide exactly what to cache, when to cache it, and what strategy to use. Service workers require HTTPS (or localhost) and are registered via `navigator.serviceWorker.register('/sw.js')`." },
  { question: "What are the main service worker caching strategies?", answer: "The five main strategies are: (1) Cache First — serve from cache, fall back to network (best for static assets). (2) Network First — try network, fall back to cache on failure (best for dynamic API data). (3) Stale-While-Revalidate — serve from cache immediately, update cache in background (best for user-facing content). (4) Cache Only — only serve from cache, never hit network (rare, for fully offline apps). (5) Network Only — bypass cache always (for analytics, billing, real-time data)." },
  { question: "Should I write service workers manually or use Workbox?", answer: "Use Workbox (Google's service worker library) unless you have specific requirements. Manual service workers are error-prone — common mistakes include not versioning caches, not handling failed cache opens, and not properly managing scope. Workbox provides battle-tested strategies, automatic precaching of build assets (via workbox-webpack-plugin or vite-plugin-pwa), background sync, and TypeScript types. Manual is appropriate for learning or very simple, static offline pages." },
  { question: "How do I update a service worker when I deploy new assets?", answer: "Service workers update automatically when the sw.js file changes (even by one byte). For precaching with Workbox, change the cache version or update the precache manifest (auto-generated by build plugins). When a new SW installs, it doesn't activate until all pages using the old SW are closed. Use `skipWaiting()` in the new SW and `clients.claim()` in the activate event to take over immediately. Notify users with a 'New version available, reload?' prompt for major updates." },
];
---

<BaseLayout
  title="Service Worker Caching Guide — Strategies, Workbox & Offline Support"
  description="Implement service worker caching: Cache First, Network First, Stale-While-Revalidate strategies using Workbox. Build offline-capable PWAs with reliable asset caching."
  tool="service worker, caching strategy, Workbox, PWA, offline, Cache API, Cache First, Network First"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Service Worker Caching Guide",
    "url": "https://devplaybook.cc/tools/service-worker-caching",
    "description": "Implement service worker caching strategies with Workbox to build fast, offline-capable web apps.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Service Worker Caching Guide</h1>
  <p class="text-text-muted mb-6">
    <strong>Service workers</strong> intercept network requests and serve assets from cache, enabling offline support and near-instant repeat visits. Choose the right caching strategy for each resource type.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 caching strategies</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Workbox setup</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Vite / Next.js integration</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Cache versioning</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Caching Strategy Decision Matrix</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Strategy</th>
          <th class="border border-border px-3 py-2 text-left">Best For</th>
          <th class="border border-border px-3 py-2 text-left">Freshness</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2">Cache First</td><td class="border border-border px-3 py-2">Static assets (JS, CSS, fonts, images)</td><td class="border border-border px-3 py-2 text-yellow-400">Stale until new SW</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Network First</td><td class="border border-border px-3 py-2">API responses, user-specific data</td><td class="border border-border px-3 py-2 text-green-400">Always fresh (online)</td></tr>
        <tr><td class="border border-border px-3 py-2">Stale-While-Revalidate</td><td class="border border-border px-3 py-2">Blog posts, product pages, public API</td><td class="border border-border px-3 py-2 text-yellow-400">Fresh on next visit</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Cache Only</td><td class="border border-border px-3 py-2">Offline app shell</td><td class="border border-border px-3 py-2 text-red-400">Never updates</td></tr>
        <tr><td class="border border-border px-3 py-2">Network Only</td><td class="border border-border px-3 py-2">Analytics, payments, real-time data</td><td class="border border-border px-3 py-2 text-green-400">Always fresh</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Workbox Setup with Vite (vite-plugin-pwa)</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">npm install --save-dev vite-plugin-pwa workbox-window</pre>

  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// vite.config.ts
import &#123; VitePWA &#125; from 'vite-plugin-pwa';

export default defineConfig(&#123;
  plugins: [
    VitePWA(&#123;
      registerType: 'autoUpdate',
      workbox: &#123;
        // Precache all build assets (auto-generated manifest)
        globPatterns: ['**/*.&#123;js,css,html,ico,png,svg,woff2&#125;'],

        // Runtime caching rules
        runtimeCaching: [
          &#123;
            // API data: Network First with 7-day fallback
            urlPattern: /^https:\/\/api\.example\.com\//,
            handler: 'NetworkFirst',
            options: &#123;
              cacheName: 'api-cache',
              expiration: &#123; maxAgeSeconds: 60 * 60 * 24 * 7 &#125;,
            &#125;,
          &#125;,
          &#123;
            // Google Fonts: Stale-While-Revalidate
            urlPattern: /^https:\/\/fonts\.(googleapis|gstatic)\.com\//,
            handler: 'StaleWhileRevalidate',
            options: &#123;
              cacheName: 'google-fonts',
              expiration: &#123; maxAgeSeconds: 60 * 60 * 24 * 365 &#125;,
            &#125;,
          &#125;,
          &#123;
            // Images: Cache First, max 100 images
            urlPattern: /\.(?:png|jpg|jpeg|svg|gif|webp|avif)$/,
            handler: 'CacheFirst',
            options: &#123;
              cacheName: 'images',
              expiration: &#123;
                maxEntries: 100,
                maxAgeSeconds: 60 * 60 * 24 * 30,
              &#125;,
            &#125;,
          &#125;,
        ],
      &#125;,
    &#125;),
  ],
&#125;);</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Manual Service Worker (Simple Example)</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// public/sw.js
const CACHE_VERSION = 'v2';
const STATIC_CACHE = `static-$&#123;CACHE_VERSION&#125;`;
const PRECACHE_ASSETS = ['/', '/offline.html', '/styles.css', '/app.js'];

self.addEventListener('install', event => &#123;
  event.waitUntil(
    caches.open(STATIC_CACHE)
      .then(cache => cache.addAll(PRECACHE_ASSETS))
      .then(() => self.skipWaiting())  // Activate immediately
  );
&#125;);

self.addEventListener('activate', event => &#123;
  event.waitUntil(
    caches.keys()
      .then(keys => Promise.all(
        // Delete old cache versions
        keys.filter(k => k !== STATIC_CACHE).map(k => caches.delete(k))
      ))
      .then(() => self.clients.claim())  // Take over all open tabs
  );
&#125;);

self.addEventListener('fetch', event => &#123;
  // Cache First for static assets
  if (PRECACHE_ASSETS.includes(new URL(event.request.url).pathname)) &#123;
    event.respondWith(
      caches.match(event.request).then(r => r || fetch(event.request))
    );
  &#125;
&#125;);</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Update Notification Pattern</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// main.ts — notify users of new version
import &#123; registerSW &#125; from 'virtual:pwa-register';

const updateSW = registerSW(&#123;
  onNeedRefresh() &#123;
    if (confirm('New version available! Reload to update?')) &#123;
      updateSW(true);
    &#125;
  &#125;,
  onOfflineReady() &#123;
    console.log('App ready for offline use');
  &#125;,
&#125;);</pre>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Service Worker Caching" relatedTags={['service-worker', 'pwa', 'caching', 'offline', 'performance', 'workbox']} />
</BaseLayout>
