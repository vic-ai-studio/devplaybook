---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FeatureFlagGenerator from '../../components/FeatureFlagGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is a feature flag?", answer: "A feature flag (also called a feature toggle or feature switch) is a configuration value that lets you enable or disable functionality in your application without deploying new code. Teams use flags to do gradual rollouts, A/B tests, kill switches, and trunk-based development where incomplete features are merged but hidden." },
  { question: "What is the difference between LaunchDarkly, Unleash, and OpenFeature?", answer: "LaunchDarkly is a commercial SaaS platform with a rich targeting UI and analytics. Unleash is an open-source feature flag server you self-host. OpenFeature is a vendor-neutral CNCF standard that defines a common SDK interface — you can swap providers without changing application code. For small projects, a simple JSON file or environment variables may be all you need." },
  { question: "When should I use percentage rollout vs user segments?", answer: "Use percentage rollout for gradual production launches — start at 5%, monitor error rates, then ramp to 100%. Use user segments when you want to target specific groups: beta testers, internal employees, paid users, or users in a specific region. Segments require user context in your evaluation call (user ID, group, attributes)." },
  { question: "Should I use boolean flags or multivariate flags?", answer: "Boolean flags (on/off) are simplest and cover 80% of cases: enable a feature, run an experiment, kill-switch a service. Multivariate flags (string, number, JSON) are for A/B/n testing with more than two variants, configuration-as-flags (returning a JSON config object), or dynamically controlling rate limits and thresholds without a deploy." },
  { question: "What does 'flag is disabled' vs 'default value is false' mean?", answer: "These are distinct concepts. A disabled flag means the flag system returns the off/default variant regardless of targeting rules — it's an emergency stop. The default value is what gets served when no targeting rule matches. A flag can be enabled (targeting rules active) but still return false for most users if they don't match any rule." },
  { question: "How should I name feature flags?", answer: "Use kebab-case or snake_case, be descriptive, and include the domain: new-checkout-flow, enable-dark-mode, ai-summary-panel-v2. Avoid vague names like 'test' or 'experiment1'. Include the expected lifetime in the description — flags should be cleaned up once the rollout is complete." },
];
---

<BaseLayout
  title="Feature Flag Config Generator — LaunchDarkly, Unleash, OpenFeature"
  description="Generate feature flag configurations for LaunchDarkly, Unleash, OpenFeature, and simple JSON/env setups. Configure flag type, default value, rollout strategy, and targeting rules. Free, runs in your browser."
  tool="Feature Flag Generator, LaunchDarkly Config, Unleash Feature Flag, OpenFeature JSON, Feature Toggle, Feature Switch"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Feature Flag Config Generator</h1>
  <p class="text-text-muted mb-4">Generate feature flag configurations for popular systems: LaunchDarkly, Unleash, OpenFeature, or simple JSON/env. Configure flag type, default value, and rollout strategy — get a copy-ready config.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 target systems</span>
  </div>
  <FeatureFlagGenerator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Feature Flag Config Generator" relatedTags={['javascript', 'typescript', 'devops', 'deployment', 'testing', 'development']} />
</BaseLayout>
