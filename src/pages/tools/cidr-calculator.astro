---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CidrCalculator from '../../components/CidrCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is CIDR notation?", answer: "CIDR (Classless Inter-Domain Routing) notation represents an IP address and its associated network prefix length. For example, 192.168.1.0/24 means the first 24 bits are the network portion, giving 256 total addresses with 254 usable hosts." },
  { question: "How do I calculate the number of hosts in a subnet?", answer: "The number of total addresses is 2^(32-prefix). For a /24, that's 2^8 = 256 addresses. Subtract 2 for the network address and broadcast address to get 254 usable hosts. A /30 gives 4 total, 2 usable — ideal for point-to-point links." },
  { question: "What is a wildcard mask?", answer: "A wildcard mask is the inverse of the subnet mask. It's used in access control lists (ACLs) on Cisco routers. For a /24 subnet (mask 255.255.255.0), the wildcard is 0.0.0.255. A 1 bit means 'don't care', a 0 bit means 'must match'." },
  { question: "What is the difference between /30 and /31?", answer: "A /30 has 4 addresses (2 usable hosts + network + broadcast) and is the classic choice for point-to-point links. A /31 has 2 addresses — no broadcast — and is specified in RFC 3021 for point-to-point links to save address space. A /32 is a host route (single address)." },
  { question: "What are private IP address ranges?", answer: "RFC 1918 defines three private ranges: 10.0.0.0/8 (16.7M addresses), 172.16.0.0/12 (1M addresses), and 192.168.0.0/16 (65K addresses). These are not routed on the internet and are used for internal networks." },
];
---

<BaseLayout
  title="CIDR Calculator — Subnet Calculator for IPv4"
  description="Free CIDR subnet calculator. Enter any IPv4 CIDR notation to instantly see network address, broadcast, host range, subnet mask, wildcard mask, and usable host count."
  tool="CIDR calculator, subnet calculator, IPv4 subnetting, network address calculator, wildcard mask, CIDR notation tool"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">CIDR Calculator</h1>
  <p class="text-text-muted mb-4">Enter any IPv4 CIDR notation (e.g. <code class="font-mono text-sm">192.168.1.0/24</code>) to instantly calculate network address, broadcast address, host range, subnet mask, wildcard mask, and usable host count. All computation runs in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Supports /0 to /32</span>
  </div>
  <CidrCalculator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CIDR Calculator" relatedTags={['networking', 'devops', 'infrastructure', 'linux', 'cloud']} />
</BaseLayout>
