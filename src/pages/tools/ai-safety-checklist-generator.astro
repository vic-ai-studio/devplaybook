---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is an AI safety evaluation checklist?",
    answer: "An AI safety evaluation checklist is a structured set of criteria to assess whether an AI system meets safety, reliability, and ethical standards before deployment. It covers technical safety (error handling, fallbacks), content safety (harmful output prevention), security (prompt injection, data leakage), fairness (bias, discrimination), privacy (PII handling), and operational reliability (monitoring, incident response)."
  },
  {
    question: "What is responsible AI deployment?",
    answer: "Responsible AI deployment means shipping AI systems that are safe, fair, transparent, and accountable. Key principles: (1) Human oversight — humans can review and override AI decisions. (2) Transparency — users know when they're interacting with AI. (3) Fairness — the system doesn't discriminate based on protected characteristics. (4) Privacy — user data is handled according to regulations. (5) Robustness — the system fails safely and handles edge cases gracefully."
  },
  {
    question: "What regulations apply to AI deployments?",
    answer: "Key regulations: EU AI Act (risk-based framework, enforcement 2025-2026), GDPR (data privacy for EU users), CCPA (California users), HIPAA (US healthcare AI), FTC guidelines (US consumer AI), and sector-specific rules (finance, healthcare, education). High-risk AI systems (hiring, credit, medical, law enforcement) face the strictest requirements including mandatory human oversight, transparency reports, and bias audits."
  },
  {
    question: "How do I test for AI bias?",
    answer: "Bias testing approaches: (1) Demographic parity — compare outputs across demographic groups. (2) Counterfactual testing — change only demographic attributes and check for output changes. (3) Red-teaming — dedicated team tries to elicit biased or harmful outputs. (4) Benchmark evaluation — use datasets like WinoBias, BBQ, ToxiGen. (5) User feedback analysis — monitor real-world outputs for disparate impact. Tools: Fairlearn, AI Fairness 360, Holistic AI."
  },
  {
    question: "What should be in an AI incident response plan?",
    answer: "AI incident response plan should include: (1) Detection — automated monitoring for harmful outputs, performance degradation, or unexpected behavior. (2) Triage — severity classification (critical = immediate shutdown, high = urgent patch, medium = scheduled fix). (3) Containment — ability to disable AI features or revert to safe fallback. (4) Communication — user notification procedures, regulatory reporting requirements. (5) Post-mortem — root cause analysis and prevention measures."
  }
];
---

<BaseLayout
  title="AI Safety Checklist Generator — Evaluate AI Deployments for Safety & Compliance"
  description="Generate a customized AI safety evaluation checklist for your deployment. Covers technical safety, content moderation, security, bias, privacy, and regulatory compliance."
  tool="ai safety checklist, ai deployment checklist, responsible ai evaluation, llm safety assessment, ai compliance checklist"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "AI Safety Checklist Generator",
    "url": "https://devplaybook.cc/tools/ai-safety-checklist-generator",
    "description": "Generate a customized AI safety evaluation checklist covering technical safety, content moderation, security, bias, privacy, and regulatory compliance.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">AI Safety Checklist Generator</h1>
  <p class="text-text-muted mb-4">
    Configure your AI deployment context and generate a tailored safety evaluation checklist. Track your progress and export to Markdown.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 6 safety domains</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60+ checklist items</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Export to Markdown</span>
  </div>

  <!-- Config panel -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
    <div>
      <label class="block text-sm font-medium mb-2">Deployment Context</label>
      <select id="sel-context" class="w-full px-3 py-2 bg-surface border border-border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/50">
        <option value="general">General Purpose / Chatbot</option>
        <option value="healthcare">Healthcare / Medical</option>
        <option value="finance">Finance / Banking</option>
        <option value="education">Education / EdTech</option>
        <option value="hr">HR / Hiring / HR Tech</option>
        <option value="legal">Legal / Compliance</option>
        <option value="customer">Customer Service / Support</option>
        <option value="developer">Developer Tool / API</option>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium mb-2">User Audience</label>
      <select id="sel-audience" class="w-full px-3 py-2 bg-surface border border-border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/50">
        <option value="general">General Public</option>
        <option value="enterprise">Enterprise / B2B</option>
        <option value="minors">Children / Minors</option>
        <option value="developer">Developers / Technical</option>
        <option value="medical">Medical Professionals</option>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium mb-2">Risk Level</label>
      <select id="sel-risk" class="w-full px-3 py-2 bg-surface border border-border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/50">
        <option value="low">Low Risk (informational only)</option>
        <option value="medium" selected>Medium Risk (decisions supported by AI)</option>
        <option value="high">High Risk (AI drives decisions)</option>
        <option value="critical">Critical Risk (safety-critical systems)</option>
      </select>
    </div>
  </div>

  <button id="btn-generate" class="px-4 py-2 bg-primary text-white text-sm font-medium rounded-lg hover:bg-primary/90 transition-colors mb-6">
    Generate Safety Checklist
  </button>

  <!-- Checklist output -->
  <div id="checklist-output" class="hidden space-y-6">
    <!-- Progress bar -->
    <div class="border border-border rounded-xl p-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-medium">Safety Readiness Score</span>
        <span id="score-label" class="text-sm font-medium"></span>
      </div>
      <div class="h-2 bg-surface rounded-full overflow-hidden border border-border mb-1">
        <div id="score-bar" class="h-full rounded-full transition-all duration-500 bg-red-500" style="width:0%"></div>
      </div>
      <div class="text-xs text-text-muted"><span id="checked-count">0</span> of <span id="total-count">0</span> items checked</div>
    </div>

    <div id="checklist-sections" class="space-y-6"></div>

    <div class="flex gap-3">
      <button id="btn-export" class="px-4 py-2 bg-surface border border-border text-sm rounded-lg hover:border-primary hover:text-primary transition-colors">
        Export as Markdown
      </button>
      <button id="btn-reset" class="px-4 py-2 bg-surface border border-border text-sm rounded-lg hover:border-red-500/50 hover:text-red-400 transition-colors">
        Reset All
      </button>
    </div>
  </div>

  <AdUnit />
  <ToolPageCta />

<script>
(() => {
  const CHECKLIST_ITEMS = {
    technical: {
      title: '🔧 Technical Safety',
      description: 'System reliability, error handling, and fallback mechanisms',
      items: [
        { id: 'tc1', text: 'Error handling: graceful degradation when LLM fails or times out', risk: ['low','medium','high','critical'] },
        { id: 'tc2', text: 'Rate limiting: protect against abuse and unexpected cost spikes', risk: ['low','medium','high','critical'] },
        { id: 'tc3', text: 'Output validation: structured outputs verified before display or action', risk: ['medium','high','critical'] },
        { id: 'tc4', text: 'Fallback mode: system functions without AI when unavailable', risk: ['medium','high','critical'] },
        { id: 'tc5', text: 'Human override: humans can review and override AI decisions', risk: ['high','critical'] },
        { id: 'tc6', text: 'Latency SLOs: defined and monitored response time thresholds', risk: ['medium','high','critical'] },
        { id: 'tc7', text: 'Version control: AI model versions tracked and rollback possible', risk: ['medium','high','critical'] },
        { id: 'tc8', text: 'Load testing: system tested under peak expected load', risk: ['medium','high','critical'] },
      ]
    },
    content: {
      title: '📋 Content Safety',
      description: 'Prevention of harmful, illegal, or inappropriate outputs',
      items: [
        { id: 'cs1', text: 'Content filters: output screened for harmful, violent, or illegal content', risk: ['low','medium','high','critical'] },
        { id: 'cs2', text: 'System prompt hardening: explicit instructions to refuse harmful requests', risk: ['low','medium','high','critical'] },
        { id: 'cs3', text: 'Hallucination mitigation: RAG or source grounding for factual claims', risk: ['medium','high','critical'] },
        { id: 'cs4', text: 'Disclaimer: users informed AI can make mistakes for high-stakes outputs', risk: ['medium','high','critical'] },
        { id: 'cs5', text: 'Content categories defined: clear list of topics AI should refuse', risk: ['medium','high','critical'] },
        { id: 'cs6', text: 'Red team testing: adversarial prompts tested before launch', risk: ['high','critical'] },
        { id: 'cs7', text: 'User reporting: mechanism for users to flag inappropriate outputs', risk: ['medium','high','critical'] },
        { id: 'cs8', text: 'Child safety: CSAM prevention if minors in audience', risk: ['minors'] },
      ]
    },
    security: {
      title: '🔐 Security',
      description: 'Protection against attacks and data leakage',
      items: [
        { id: 'sec1', text: 'Prompt injection defense: system prompt instructs model to ignore user overrides', risk: ['low','medium','high','critical'] },
        { id: 'sec2', text: 'System prompt confidentiality: model instructed not to reveal system prompt', risk: ['medium','high','critical'] },
        { id: 'sec3', text: 'Input sanitization: user input filtered for injection patterns', risk: ['medium','high','critical'] },
        { id: 'sec4', text: 'API key security: keys not exposed in client-side code or logs', risk: ['low','medium','high','critical'] },
        { id: 'sec5', text: 'Output sanitization: rendered outputs don\'t execute scripts (XSS prevention)', risk: ['low','medium','high','critical'] },
        { id: 'sec6', text: 'Authentication: AI features behind proper auth where required', risk: ['medium','high','critical'] },
        { id: 'sec7', text: 'Data minimization: only necessary data sent to LLM provider', risk: ['medium','high','critical'] },
        { id: 'sec8', text: 'Penetration testing: AI-specific security test conducted before launch', risk: ['high','critical'] },
      ]
    },
    bias: {
      title: '⚖️ Fairness & Bias',
      description: 'Prevention of discriminatory or unfair outcomes',
      items: [
        { id: 'bi1', text: 'Bias audit: system tested for differential performance across demographic groups', risk: ['medium','high','critical'] },
        { id: 'bi2', text: 'Protected attributes: AI does not make decisions based on race, gender, age, etc.', risk: ['medium','high','critical'] },
        { id: 'bi3', text: 'Counterfactual testing: outputs tested with demographic attribute variations', risk: ['high','critical'] },
        { id: 'bi4', text: 'Training data audit: known biases in training data documented', risk: ['high','critical'] },
        { id: 'bi5', text: 'Fairness metrics: defined and monitored (demographic parity, equal opportunity)', risk: ['high','critical'] },
        { id: 'bi6', text: 'Diverse testing: evaluation dataset includes diverse demographic representations', risk: ['medium','high','critical'] },
        { id: 'bi7', text: 'Appeals process: affected users can contest AI-based decisions', risk: ['high','critical'] },
      ]
    },
    privacy: {
      title: '🔒 Privacy & Data',
      description: 'Compliance with privacy regulations and data handling',
      items: [
        { id: 'pv1', text: 'PII handling: personally identifiable information not unnecessarily sent to LLM', risk: ['low','medium','high','critical'] },
        { id: 'pv2', text: 'Data retention: LLM provider data retention policy reviewed and acceptable', risk: ['medium','high','critical'] },
        { id: 'pv3', text: 'User consent: users informed that data may be processed by AI', risk: ['medium','high','critical'] },
        { id: 'pv4', text: 'GDPR/CCPA: applicable privacy regulations assessed and addressed', risk: ['medium','high','critical'] },
        { id: 'pv5', text: 'Data processing agreement: DPA signed with LLM provider', risk: ['high','critical'] },
        { id: 'pv6', text: 'Right to deletion: user data deletion handled for AI training opt-outs', risk: ['medium','high','critical'] },
        { id: 'pv7', text: 'Cross-border transfers: data residency requirements met', risk: ['high','critical'] },
        { id: 'pv8', text: 'HIPAA: healthcare data compliance assessed if medical context', risk: ['healthcare'] },
      ]
    },
    operational: {
      title: '📊 Operations & Monitoring',
      description: 'Ongoing monitoring, incident response, and accountability',
      items: [
        { id: 'op1', text: 'Logging: AI inputs/outputs logged for audit purposes (with retention policy)', risk: ['medium','high','critical'] },
        { id: 'op2', text: 'Monitoring: real-time alerts for harmful outputs or anomalies', risk: ['medium','high','critical'] },
        { id: 'op3', text: 'Incident response: documented plan for AI failures or harmful output incidents', risk: ['medium','high','critical'] },
        { id: 'op4', text: 'Kill switch: ability to disable AI features in under 1 hour', risk: ['high','critical'] },
        { id: 'op5', text: 'Transparency: users know they are interacting with AI (not a human)', risk: ['low','medium','high','critical'] },
        { id: 'op6', text: 'Model card: AI system capabilities and limitations documented', risk: ['medium','high','critical'] },
        { id: 'op7', text: 'Stakeholder review: legal, ethics, and compliance teams signed off', risk: ['high','critical'] },
        { id: 'op8', text: 'Regular audits: safety review scheduled on recurring basis (quarterly+)', risk: ['high','critical'] },
      ]
    }
  };

  let checkedItems = new Set();
  let currentItems = [];

  function getRelevantItems(context, audience, risk) {
    const specialContexts = { healthcare: ['pv8','tc5','tc7','tc8'], finance: ['bi7','op7','pv5'], hr: ['bi1','bi2','bi3','bi4','bi5','bi6','bi7'], legal: ['op6','op7','pv5'], minors: ['cs8'] };
    const audienceMap = { minors: ['cs8'] };

    return Object.entries(CHECKLIST_ITEMS).map(([key, section]) => {
      const filtered = section.items.filter(item => {
        if (item.risk.includes(risk)) return true;
        if (specialContexts[context]?.includes(item.id)) return true;
        if (audienceMap[audience]?.includes(item.id)) return true;
        if (item.risk.includes('low')) return true; // always include low-risk items
        return false;
      });
      return { ...section, key, items: filtered };
    }).filter(s => s.items.length > 0);
  }

  function renderChecklist(sections) {
    currentItems = sections.flatMap(s => s.items);
    document.getElementById('total-count').textContent = currentItems.length;

    document.getElementById('checklist-sections').innerHTML = sections.map(section => `
      <div class="border border-border rounded-xl p-5">
        <h3 class="text-base font-semibold mb-1">${section.title}</h3>
        <p class="text-xs text-text-muted mb-4">${section.description}</p>
        <div class="space-y-3">
          ${section.items.map(item => `
            <label class="flex items-start gap-3 cursor-pointer group">
              <input type="checkbox" class="checklist-item mt-0.5 w-4 h-4 rounded border-border text-primary focus:ring-primary/50 shrink-0" data-id="${item.id}" ${checkedItems.has(item.id) ? 'checked' : ''}>
              <span class="text-sm ${checkedItems.has(item.id) ? 'line-through text-text-muted' : ''} group-hover:text-primary transition-colors">${item.text}</span>
            </label>
          `).join('')}
        </div>
      </div>
    `).join('');

    document.querySelectorAll('.checklist-item').forEach(cb => {
      cb.addEventListener('change', () => {
        if (cb.checked) checkedItems.add(cb.dataset.id);
        else checkedItems.delete(cb.dataset.id);
        updateScore();
        // Update label style
        const label = cb.nextElementSibling;
        label.classList.toggle('line-through', cb.checked);
        label.classList.toggle('text-text-muted', cb.checked);
      });
    });

    updateScore();
  }

  function updateScore() {
    const total = currentItems.length;
    const checked = currentItems.filter(i => checkedItems.has(i.id)).length;
    const pct = total > 0 ? Math.round((checked / total) * 100) : 0;

    document.getElementById('checked-count').textContent = checked;
    document.getElementById('score-bar').style.width = pct + '%';

    const bar = document.getElementById('score-bar');
    const label = document.getElementById('score-label');
    if (pct >= 80) {
      bar.className = 'h-full rounded-full transition-all duration-500 bg-green-500';
      label.className = 'text-sm font-medium text-green-400';
      label.textContent = `Ready (${pct}%)`;
    } else if (pct >= 50) {
      bar.className = 'h-full rounded-full transition-all duration-500 bg-yellow-500';
      label.className = 'text-sm font-medium text-yellow-400';
      label.textContent = `In Progress (${pct}%)`;
    } else {
      bar.className = 'h-full rounded-full transition-all duration-500 bg-red-500';
      label.className = 'text-sm font-medium text-red-400';
      label.textContent = `Not Ready (${pct}%)`;
    }
  }

  document.getElementById('btn-generate').addEventListener('click', () => {
    const context = document.getElementById('sel-context').value;
    const audience = document.getElementById('sel-audience').value;
    const risk = document.getElementById('sel-risk').value;
    checkedItems.clear();

    const sections = getRelevantItems(context, audience, risk);
    renderChecklist(sections);
    document.getElementById('checklist-output').classList.remove('hidden');
    document.getElementById('checklist-output').scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  document.getElementById('btn-reset').addEventListener('click', () => {
    checkedItems.clear();
    document.querySelectorAll('.checklist-item').forEach(cb => {
      cb.checked = false;
      cb.nextElementSibling.classList.remove('line-through', 'text-text-muted');
    });
    updateScore();
  });

  document.getElementById('btn-export').addEventListener('click', () => {
    const context = document.getElementById('sel-context').value;
    const risk = document.getElementById('sel-risk').value;
    const total = currentItems.length;
    const checked = currentItems.filter(i => checkedItems.has(i.id)).length;

    let md = `# AI Safety Checklist\n\n`;
    md += `**Context:** ${context} | **Risk Level:** ${risk} | **Score:** ${checked}/${total}\n\n`;

    document.querySelectorAll('.border.border-border.rounded-xl').forEach(section => {
      const title = section.querySelector('h3');
      const items = section.querySelectorAll('.checklist-item');
      if (!title || items.length === 0) return;
      md += `## ${title.textContent}\n\n`;
      items.forEach(cb => {
        const text = cb.nextElementSibling.textContent;
        md += `- [${cb.checked ? 'x' : ' '}] ${text}\n`;
      });
      md += '\n';
    });

    const blob = new Blob([md], { type: 'text/markdown' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'ai-safety-checklist.md';
    a.click();
    URL.revokeObjectURL(url);
  });
})();
</script>

  <FaqSection faq={faq} />
</BaseLayout>
