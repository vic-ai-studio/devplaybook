---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "When should I use 200 vs 201 vs 204?", answer: "Use 200 OK for general success with a response body. Use 201 Created when a POST creates a new resource — include a Location header pointing to the new resource. Use 204 No Content for successful operations that return nothing (e.g. DELETE, or PATCH when you don't need to return the updated state)." },
  { question: "What is the difference between 401 and 403?", answer: "401 Unauthorized means the request lacks valid authentication credentials — the client should authenticate and retry. 403 Forbidden means the server understood the request and the client IS authenticated, but lacks permission to access the resource. In short: 401 = not logged in, 403 = logged in but not allowed." },
  { question: "When should I use 422 instead of 400?", answer: "400 Bad Request covers malformed syntax (invalid JSON, wrong content-type). 422 Unprocessable Entity is for requests that are syntactically correct but semantically invalid — e.g. a valid JSON body where a required field fails business validation. REST APIs often use 400 for both, but GraphQL and some frameworks prefer 422 for validation errors." },
  { question: "What does 429 Too Many Requests mean and how should I handle it?", answer: "429 indicates the client has sent too many requests in a given time window (rate limiting). The response should include a Retry-After header indicating when the client can retry. Clients should implement exponential backoff and respect this header to avoid being permanently blocked." },
  { question: "Should I use 503 or 502 for downstream service errors?", answer: "Use 502 Bad Gateway when your server received an invalid response from an upstream service it's proxying to. Use 503 Service Unavailable when your server itself is overloaded or temporarily down for maintenance — include a Retry-After header. Use 504 Gateway Timeout when the upstream service didn't respond in time." },
];
---

<BaseLayout
  title="HTTP Status Code Explorer — Complete Reference with Code Examples"
  description="Interactive HTTP status code reference. Search any code, browse by category, and see Express, FastAPI, and Hono implementation examples for every status."
  tool="HTTP Status Codes, REST API Status Codes, Express Status Code, FastAPI Status, HTTP Reference"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">HTTP Status Code Explorer</h1>
  <p class="text-text-muted mb-4">Complete HTTP status code reference with descriptions, use cases, and code examples for Express, FastAPI, and Hono. Click any code or search by number or keyword.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All 1xx–5xx codes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Express / FastAPI / Hono examples</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Search by code or keyword</span>
  </div>

  <!-- Search -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <div class="flex gap-3">
      <input id="http-search" type="text" placeholder="Search by code (e.g. 404) or keyword (e.g. not found)…"
        class="flex-1 bg-bg-card border border-border rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-primary" />
      <button id="http-clear" class="text-sm text-text-muted hover:text-primary px-3">Clear</button>
    </div>
  </div>

  <!-- Detail Panel -->
  <div id="http-detail" class="bg-bg-card border border-border rounded-xl p-5 mb-5 hidden">
    <div class="flex items-center gap-4 mb-4">
      <span id="detail-code" class="text-4xl font-bold text-primary"></span>
      <div>
        <div id="detail-title" class="text-lg font-semibold"></div>
        <div id="detail-category" class="text-xs text-text-muted"></div>
      </div>
    </div>
    <p id="detail-desc" class="text-sm text-text-muted mb-3"></p>
    <p id="detail-when" class="text-sm mb-4 border-l-2 border-primary pl-3"></p>
    <h3 class="text-sm font-semibold mb-2">Body / Header conventions</h3>
    <p id="detail-body" class="text-sm text-text-muted mb-4"></p>
    <h3 class="text-sm font-semibold mb-3">Code Examples</h3>
    <div class="flex gap-1 mb-3 border-b border-border">
      <button class="http-code-tab px-3 py-1.5 text-xs font-medium rounded-t border-b-2 border-primary text-primary" data-tab="express">Express</button>
      <button class="http-code-tab px-3 py-1.5 text-xs font-medium rounded-t border-b-2 border-transparent text-text-muted" data-tab="fastapi">FastAPI</button>
      <button class="http-code-tab px-3 py-1.5 text-xs font-medium rounded-t border-b-2 border-transparent text-text-muted" data-tab="hono">Hono</button>
    </div>
    <div id="http-code-express" class="http-code-panel">
      <div class="flex justify-between items-center mb-1.5">
        <span class="text-xs text-text-muted">javascript</span>
        <button class="http-copy text-xs text-primary hover:underline" data-target="detail-express-code">Copy</button>
      </div>
      <pre id="detail-express-code" class="bg-bg-card border border-border rounded-lg p-3 text-sm font-mono overflow-x-auto whitespace-pre-wrap text-text-muted"></pre>
    </div>
    <div id="http-code-fastapi" class="http-code-panel hidden">
      <div class="flex justify-between items-center mb-1.5">
        <span class="text-xs text-text-muted">python</span>
        <button class="http-copy text-xs text-primary hover:underline" data-target="detail-fastapi-code">Copy</button>
      </div>
      <pre id="detail-fastapi-code" class="bg-bg-card border border-border rounded-lg p-3 text-sm font-mono overflow-x-auto whitespace-pre-wrap text-text-muted"></pre>
    </div>
    <div id="http-code-hono" class="http-code-panel hidden">
      <div class="flex justify-between items-center mb-1.5">
        <span class="text-xs text-text-muted">typescript</span>
        <button class="http-copy text-xs text-primary hover:underline" data-target="detail-hono-code">Copy</button>
      </div>
      <pre id="detail-hono-code" class="bg-bg-card border border-border rounded-lg p-3 text-sm font-mono overflow-x-auto whitespace-pre-wrap text-text-muted"></pre>
    </div>
  </div>

  <!-- Grid -->
  <div id="http-grid-wrap">
    <div id="http-grid" class="space-y-6"></div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="HTTP Status Code Explorer" relatedTags={['http', 'api', 'rest', 'express', 'fastapi', 'hono']} />
</BaseLayout>

<script>
  interface StatusCode {
    code: number;
    title: string;
    desc: string;
    when: string;
    body: string;
    express: string;
    fastapi: string;
    hono: string;
  }

  const CODES: StatusCode[] = [
    { code: 100, title: 'Continue', desc: 'The server has received the request headers and the client should proceed to send the request body.', when: 'Use when the client sends an Expect: 100-continue header before sending a large request body.', body: 'No body. Used with Expect header in chunked upload workflows.', express: `app.post('/upload', (req, res) => {\n  // Express handles 100-continue automatically\n  // Client sends: Expect: 100-continue\n  res.status(200).json({ uploaded: true });\n});`, fastapi: `# FastAPI handles 100-continue automatically at the ASGI level\n# No manual action needed for standard request body handling`, hono: `// Hono handles 100-continue automatically\n// No manual action needed` },
    { code: 101, title: 'Switching Protocols', desc: 'The server agrees to switch protocols as requested by the client.', when: 'Returned when upgrading from HTTP/1.1 to WebSocket after the client sends an Upgrade: websocket header.', body: 'No body. Includes Upgrade and Connection headers.', express: `const { WebSocketServer } = require('ws');\nconst wss = new WebSocketServer({ server });\n// HTTP 101 is sent automatically by ws during handshake`, fastapi: `from fastapi import WebSocket\n\n@app.websocket("/ws")\nasync def websocket_endpoint(websocket: WebSocket):\n    await websocket.accept()  # sends 101 automatically\n    data = await websocket.receive_text()\n    await websocket.send_text(f"Echo: {data}")`, hono: `import { upgradeWebSocket } from 'hono/cloudflare-workers'\n\napp.get('/ws', upgradeWebSocket((c) => ({\n  onMessage(event, ws) { ws.send('Echo: ' + event.data); }\n})))` },
    { code: 200, title: 'OK', desc: 'The request succeeded. The meaning of success depends on the HTTP method used.', when: 'Standard success response for GET, POST (when not creating), PUT, PATCH when returning the updated resource.', body: 'Include a response body with the requested resource or operation result.', express: `app.get('/users/:id', async (req, res) => {\n  const user = await db.users.findById(req.params.id);\n  if (!user) return res.status(404).json({ error: 'Not found' });\n  res.status(200).json({ data: user });\n});`, fastapi: `from fastapi import FastAPI\n\n@app.get("/users/{user_id}", status_code=200)\nasync def get_user(user_id: str):\n    user = await db.get_user(user_id)\n    return {"data": user}`, hono: `app.get('/users/:id', async (c) => {\n  const user = await db.users.findById(c.req.param('id'));\n  return c.json({ data: user }, 200);\n});` },
    { code: 201, title: 'Created', desc: 'The request succeeded and a new resource was created as a result.', when: 'Use after a successful POST that creates a new resource. Include a Location header pointing to the new resource.', body: 'Return the newly created resource in the body. Set Location header to the new resource URL.', express: `app.post('/users', async (req, res) => {\n  const user = await db.users.create(req.body);\n  res\n    .status(201)\n    .location(\`/users/\${user.id}\`)\n    .json({ data: user });\n});`, fastapi: `from fastapi import FastAPI, Response\n\n@app.post("/users", status_code=201)\nasync def create_user(user: UserCreate, response: Response):\n    created = await db.create_user(user)\n    response.headers["Location"] = f"/users/{created.id}"\n    return {"data": created}`, hono: `app.post('/users', async (c) => {\n  const body = await c.req.json();\n  const user = await db.users.create(body);\n  return c.json({ data: user }, 201, {\n    Location: \`/users/\${user.id}\`\n  });\n});` },
    { code: 204, title: 'No Content', desc: 'The server successfully processed the request but is not returning any content.', when: 'Use for DELETE operations, or PATCH/PUT when no response body is needed.', body: 'No response body — do not include Content-Type or body. A body would be ignored anyway.', express: `app.delete('/users/:id', async (req, res) => {\n  await db.users.delete(req.params.id);\n  res.status(204).send();\n});`, fastapi: `from fastapi import status\n\n@app.delete("/users/{user_id}", status_code=status.HTTP_204_NO_CONTENT)\nasync def delete_user(user_id: str):\n    await db.delete_user(user_id)\n    # return nothing — FastAPI handles 204 correctly`, hono: `app.delete('/users/:id', async (c) => {\n  await db.users.delete(c.req.param('id'));\n  return new Response(null, { status: 204 });\n});` },
    { code: 301, title: 'Moved Permanently', desc: 'The URL of the requested resource has been changed permanently.', when: 'Use for permanent URL changes (site migrations, slug changes). Browsers and bots will update cached URLs.', body: 'Include Location header with the new URL. Body is optional — most clients follow the redirect automatically.', express: `app.get('/old-path', (req, res) => {\n  res.redirect(301, '/new-path');\n});`, fastapi: `from fastapi.responses import RedirectResponse\n\n@app.get("/old-path")\nasync def old_path():\n    return RedirectResponse(url="/new-path", status_code=301)`, hono: `app.get('/old-path', (c) => {\n  return c.redirect('/new-path', 301);\n});` },
    { code: 302, title: 'Found', desc: 'The URL of the requested resource has been changed temporarily.', when: 'Use for temporary redirects (maintenance pages, temporary URL changes). Clients should continue using the original URL.', body: 'Include Location header. The method and body may change to GET on redirect (use 307 to preserve method).', express: `app.get('/maintenance', (req, res) => {\n  res.redirect(302, '/maintenance-page');\n});`, fastapi: `from fastapi.responses import RedirectResponse\n\n@app.get("/maintenance")\nasync def maintenance():\n    return RedirectResponse(url="/maintenance-page", status_code=302)`, hono: `app.get('/maintenance', (c) => c.redirect('/maintenance-page', 302));` },
    { code: 304, title: 'Not Modified', desc: 'Indicates the resource has not been modified since the version specified by request headers.', when: 'Use with ETag or Last-Modified / If-None-Match / If-Modified-Since conditional requests for caching.', body: 'No body. Include ETag and Cache-Control headers.', express: `app.get('/data', (req, res) => {\n  const etag = computeEtag(data);\n  res.setHeader('ETag', etag);\n  if (req.headers['if-none-match'] === etag) {\n    return res.status(304).send();\n  }\n  res.json(data);\n});`, fastapi: `from fastapi import Request, Response\n\n@app.get("/data")\nasync def get_data(request: Request, response: Response):\n    etag = compute_etag(data)\n    if request.headers.get("if-none-match") == etag:\n        return Response(status_code=304)\n    response.headers["ETag"] = etag\n    return data`, hono: `app.get('/data', (c) => {\n  const etag = computeEtag(data);\n  if (c.req.header('if-none-match') === etag) {\n    return new Response(null, { status: 304 });\n  }\n  return c.json(data, 200, { ETag: etag });\n});` },
    { code: 400, title: 'Bad Request', desc: 'The server cannot process the request due to a client error (malformed syntax, invalid parameters).', when: 'Use when the request is malformed: invalid JSON, missing required fields, wrong data types, invalid query params.', body: 'Return an error object with details: { error: "message", details: [...] }', express: `app.post('/users', (req, res) => {\n  const { name, email } = req.body;\n  if (!name || !email) {\n    return res.status(400).json({\n      error: 'Validation failed',\n      details: ['name is required', 'email is required']\n    });\n  }\n  // proceed...\n});`, fastapi: `from fastapi import HTTPException\nfrom pydantic import BaseModel, validator\n\nclass UserCreate(BaseModel):\n    name: str\n    email: str\n\n# Pydantic validation errors automatically return 422\n# For manual 400:\n@app.post("/users")\nasync def create_user(user: UserCreate):\n    if not is_valid_domain(user.email):\n        raise HTTPException(status_code=400, detail="Invalid email domain")`, hono: `app.post('/users', async (c) => {\n  const body = await c.req.json().catch(() => null);\n  if (!body?.name || !body?.email) {\n    return c.json({ error: 'name and email required' }, 400);\n  }\n  // proceed...\n});` },
    { code: 401, title: 'Unauthorized', desc: 'The request lacks valid authentication credentials.', when: 'Use when the request requires authentication but none was provided, or the provided credentials are invalid/expired.', body: 'Return { error: "Unauthorized" }. Include WWW-Authenticate header specifying the auth scheme.', express: `app.get('/profile', (req, res) => {\n  const token = req.headers.authorization?.split(' ')[1];\n  if (!token) {\n    return res\n      .status(401)\n      .setHeader('WWW-Authenticate', 'Bearer realm="api"')\n      .json({ error: 'Authentication required' });\n  }\n  // verify token...\n});`, fastapi: `from fastapi import Depends, HTTPException\nfrom fastapi.security import HTTPBearer\n\nsecurity = HTTPBearer()\n\n@app.get("/profile")\nasync def profile(token = Depends(security)):\n    if not verify_token(token.credentials):\n        raise HTTPException(\n            status_code=401,\n            detail="Invalid credentials",\n            headers={"WWW-Authenticate": "Bearer"}\n        )`, hono: `import { bearerAuth } from 'hono/bearer-auth'\n\napp.use('/profile/*', bearerAuth({ token: process.env.API_TOKEN }))\n// Automatically returns 401 for invalid/missing tokens` },
    { code: 403, title: 'Forbidden', desc: 'The server understood the request but refuses to authorize it.', when: 'Use when the user IS authenticated but lacks permission for the requested resource. Do not return 404 to hide existence of resources.', body: 'Return { error: "Forbidden", message: "Insufficient permissions" }', express: `app.delete('/users/:id', requireAuth, (req, res) => {\n  if (req.user.role !== 'admin') {\n    return res.status(403).json({\n      error: 'Forbidden',\n      message: 'Admin role required'\n    });\n  }\n  // delete user...\n});`, fastapi: `from fastapi import HTTPException\n\n@app.delete("/users/{user_id}")\nasync def delete_user(user_id: str, current_user = Depends(get_current_user)):\n    if current_user.role != "admin":\n        raise HTTPException(\n            status_code=403,\n            detail="Admin role required"\n        )`, hono: `app.delete('/users/:id', async (c) => {\n  const user = c.get('user');\n  if (user.role !== 'admin') {\n    return c.json({ error: 'Forbidden' }, 403);\n  }\n  // delete...\n});` },
    { code: 404, title: 'Not Found', desc: 'The server cannot find the requested resource. The URL is not recognized or the resource does not exist.', when: 'Use when a specific resource (by ID or slug) does not exist. Also used to deliberately hide the existence of resources from unauthorized users.', body: 'Return { error: "Not found", resource: "User" } or just { error: "Not found" }', express: `app.get('/users/:id', async (req, res) => {\n  const user = await db.users.findById(req.params.id);\n  if (!user) {\n    return res.status(404).json({\n      error: 'Not found',\n      message: \`User \${req.params.id} does not exist\`\n    });\n  }\n  res.json({ data: user });\n});`, fastapi: `from fastapi import HTTPException\n\n@app.get("/users/{user_id}")\nasync def get_user(user_id: str):\n    user = await db.get_user(user_id)\n    if not user:\n        raise HTTPException(\n            status_code=404,\n            detail=f"User {user_id} not found"\n        )\n    return {"data": user}`, hono: `app.get('/users/:id', async (c) => {\n  const user = await db.users.findById(c.req.param('id'));\n  if (!user) return c.json({ error: 'Not found' }, 404);\n  return c.json({ data: user });\n});` },
    { code: 405, title: 'Method Not Allowed', desc: 'The HTTP method used is not supported for this endpoint.', when: 'Use when a client calls GET on a POST-only endpoint, or DELETE on a read-only resource.', body: 'Include Allow header listing supported methods: Allow: GET, POST', express: `// Express auto-handles with 404, but you can be explicit:\napp.all('/users', (req, res, next) => {\n  if (!['GET', 'POST'].includes(req.method)) {\n    return res\n      .status(405)\n      .set('Allow', 'GET, POST')\n      .json({ error: 'Method not allowed' });\n  }\n  next();\n});`, fastapi: `# FastAPI automatically returns 405 with Allow header\n# when a route exists but the HTTP method doesn't match\n@app.get("/read-only")\nasync def read_only():\n    return {"data": "read only"}`, hono: `// Hono returns 405 automatically for wrong methods\napp.get('/read-only', (c) => c.json({ data: 'read only' }));\n// POST /read-only → 405 Method Not Allowed` },
    { code: 409, title: 'Conflict', desc: 'The request conflicts with the current state of the resource.', when: 'Use when a POST tries to create a duplicate resource, or when a PUT/PATCH causes a version conflict (optimistic locking).', body: 'Return details about the conflict: { error: "Conflict", field: "email", message: "Already registered" }', express: `app.post('/users', async (req, res) => {\n  const existing = await db.users.findByEmail(req.body.email);\n  if (existing) {\n    return res.status(409).json({\n      error: 'Conflict',\n      field: 'email',\n      message: 'Email already registered'\n    });\n  }\n  // create...\n});`, fastapi: `from fastapi import HTTPException\n\n@app.post("/users")\nasync def create_user(user: UserCreate):\n    existing = await db.find_by_email(user.email)\n    if existing:\n        raise HTTPException(\n            status_code=409,\n            detail={"field": "email", "message": "Already registered"}\n        )`, hono: `app.post('/users', async (c) => {\n  const body = await c.req.json();\n  const existing = await db.users.findByEmail(body.email);\n  if (existing) return c.json({ error: 'Email taken' }, 409);\n  // create...\n});` },
    { code: 422, title: 'Unprocessable Entity', desc: 'The request was well-formed but could not be processed due to semantic errors.', when: 'Use for business logic validation failures where the JSON is syntactically valid but the values are semantically invalid.', body: 'Return structured validation errors: { errors: [{ field: "age", message: "Must be 18+" }] }', express: `app.post('/register', async (req, res) => {\n  const errors = [];\n  if (req.body.age < 18) errors.push({ field: 'age', message: 'Must be 18+' });\n  if (req.body.password.length < 8) errors.push({ field: 'password', message: 'Min 8 chars' });\n  if (errors.length) return res.status(422).json({ errors });\n  // proceed...\n});`, fastapi: `from fastapi import HTTPException\nfrom pydantic import BaseModel, field_validator\n\nclass RegisterSchema(BaseModel):\n    age: int\n    password: str\n\n    @field_validator('age')\n    def age_min(cls, v):\n        if v < 18:\n            raise ValueError('Must be 18+')\n        return v\n# Pydantic automatically returns 422 with error details`, hono: `app.post('/register', async (c) => {\n  const body = await c.req.json();\n  const errors = [];\n  if (body.age < 18) errors.push({ field: 'age', msg: 'Min 18' });\n  if (errors.length) return c.json({ errors }, 422);\n});` },
    { code: 429, title: 'Too Many Requests', desc: 'The user has sent too many requests in a given time window (rate limiting).', when: 'Use when implementing rate limiting. Always include Retry-After and optionally X-RateLimit-* headers.', body: 'Return { error: "Too Many Requests", retryAfter: 60 }. Include Retry-After header.', express: `const rateLimit = require('express-rate-limit');\n\nconst limiter = rateLimit({\n  windowMs: 15 * 60 * 1000, // 15 min\n  max: 100,\n  standardHeaders: true,\n  legacyHeaders: false,\n  message: { error: 'Too many requests', retryAfter: 900 }\n});\n\napp.use('/api/', limiter);`, fastapi: `from slowapi import Limiter\nfrom slowapi.util import get_remote_address\n\nlimiter = Limiter(key_func=get_remote_address)\n\n@app.get("/api/data")\n@limiter.limit("100/15minutes")\nasync def get_data(request: Request):\n    return {"data": "result"}`, hono: `import { rateLimiter } from 'hono-rate-limiter'\n\napp.use(\n  '/api/*',\n  rateLimiter({ windowMs: 15 * 60 * 1000, limit: 100 })\n);` },
    { code: 500, title: 'Internal Server Error', desc: 'The server encountered an unexpected condition that prevented it from fulfilling the request.', when: 'Use as the generic catch-all for unexpected server errors. Never return stack traces or internal details in production.', body: 'Return { error: "Internal server error" }. Log full details server-side. Include a request ID for tracing.', express: `// Global error handler\napp.use((err, req, res, next) => {\n  const requestId = req.headers['x-request-id'] || crypto.randomUUID();\n  console.error({ requestId, error: err.message, stack: err.stack });\n  res.status(500).json({\n    error: 'Internal server error',\n    requestId\n  });\n});`, fastapi: `from fastapi import Request\nfrom fastapi.responses import JSONResponse\nimport traceback, uuid\n\n@app.exception_handler(Exception)\nasync def global_exception_handler(request: Request, exc: Exception):\n    request_id = str(uuid.uuid4())\n    print(f"[{request_id}] {traceback.format_exc()}")\n    return JSONResponse(\n        status_code=500,\n        content={"error": "Internal server error", "requestId": request_id}\n    )`, hono: `app.onError((err, c) => {\n  const requestId = crypto.randomUUID();\n  console.error({ requestId, error: err.message });\n  return c.json({ error: 'Internal server error', requestId }, 500);\n});` },
    { code: 502, title: 'Bad Gateway', desc: 'The server, acting as a gateway or proxy, received an invalid response from an upstream server.', when: 'Use when your server proxies to another service and that service returned an invalid or unexpected response.', body: 'Return { error: "Bad gateway", upstream: "payment-service" }', express: `app.post('/charge', async (req, res) => {\n  try {\n    const result = await paymentService.charge(req.body);\n    res.json({ data: result });\n  } catch (err) {\n    if (err.code === 'UPSTREAM_INVALID_RESPONSE') {\n      return res.status(502).json({ error: 'Bad gateway', upstream: 'payment-service' });\n    }\n    throw err;\n  }\n});`, fastapi: `import httpx\nfrom fastapi import HTTPException\n\n@app.post("/charge")\nasync def charge(body: ChargeRequest):\n    async with httpx.AsyncClient() as client:\n        try:\n            r = await client.post("http://payment-svc/charge", json=body.dict())\n            r.raise_for_status()\n            return r.json()\n        except httpx.HTTPStatusError:\n            raise HTTPException(status_code=502, detail="Payment service error")`, hono: `app.post('/charge', async (c) => {\n  const r = await fetch('http://payment-svc/charge', { ... });\n  if (!r.ok && r.status >= 500) {\n    return c.json({ error: 'Bad gateway' }, 502);\n  }\n  return c.json(await r.json());\n});` },
    { code: 503, title: 'Service Unavailable', desc: 'The server is temporarily unable to handle requests (overloaded or down for maintenance).', when: 'Use during maintenance windows, when the service is overloaded, or when a critical dependency is unavailable.', body: 'Include Retry-After header. Return { error: "Service unavailable", retryAfter: 300 }', express: `let isMaintenanceMode = process.env.MAINTENANCE === 'true';\n\napp.use((req, res, next) => {\n  if (isMaintenanceMode) {\n    return res\n      .status(503)\n      .set('Retry-After', '3600')\n      .json({ error: 'Maintenance in progress', retryAfter: 3600 });\n  }\n  next();\n});`, fastapi: `from fastapi import Response\n\n@app.middleware("http")\nasync def maintenance_check(request: Request, call_next):\n    if os.getenv("MAINTENANCE") == "true":\n        return Response(\n            content='{"error":"Maintenance in progress"}',\n            status_code=503,\n            headers={"Retry-After": "3600", "Content-Type": "application/json"}\n        )\n    return await call_next(request)`, hono: `app.use('*', async (c, next) => {\n  if (process.env.MAINTENANCE === 'true') {\n    return c.json({ error: 'Maintenance' }, 503, { 'Retry-After': '3600' });\n  }\n  await next();\n});` },
    { code: 504, title: 'Gateway Timeout', desc: 'The server, acting as a gateway, did not receive a timely response from the upstream server.', when: 'Use when proxying to an upstream service that times out. Different from 503 (your server is down) — here the upstream is slow.', body: 'Return { error: "Gateway timeout", upstream: "service-name" }', express: `app.get('/data', async (req, res) => {\n  const controller = new AbortController();\n  const timeout = setTimeout(() => controller.abort(), 5000);\n  try {\n    const result = await fetch('http://slow-service/data', { signal: controller.signal });\n    clearTimeout(timeout);\n    res.json(await result.json());\n  } catch (err) {\n    if (err.name === 'AbortError') {\n      return res.status(504).json({ error: 'Gateway timeout' });\n    }\n    throw err;\n  }\n});`, fastapi: `import asyncio, httpx\nfrom fastapi import HTTPException\n\n@app.get("/data")\nasync def get_data():\n    try:\n        async with httpx.AsyncClient(timeout=5.0) as client:\n            r = await client.get("http://slow-service/data")\n            return r.json()\n    except httpx.TimeoutException:\n        raise HTTPException(status_code=504, detail="Gateway timeout")`, hono: `app.get('/data', async (c) => {\n  try {\n    const r = await fetch('http://slow-svc/data', {\n      signal: AbortSignal.timeout(5000)\n    });\n    return c.json(await r.json());\n  } catch (e) {\n    return c.json({ error: 'Gateway timeout' }, 504);\n  }\n});` },
  ];

  const CATEGORIES: Record<string, { label: string; color: string; textColor: string }> = {
    '1': { label: '1xx Informational', color: 'border-blue-500/30 bg-blue-500/5', textColor: 'text-blue-400' },
    '2': { label: '2xx Success', color: 'border-green-500/30 bg-green-500/5', textColor: 'text-green-400' },
    '3': { label: '3xx Redirection', color: 'border-yellow-500/30 bg-yellow-500/5', textColor: 'text-yellow-400' },
    '4': { label: '4xx Client Errors', color: 'border-orange-500/30 bg-orange-500/5', textColor: 'text-orange-400' },
    '5': { label: '5xx Server Errors', color: 'border-red-500/30 bg-red-500/5', textColor: 'text-red-400' },
  };

  let activeTab = 'express';

  function getCat(code: number): string {
    return String(Math.floor(code / 100));
  }

  function showDetail(item: StatusCode) {
    const detailEl = document.getElementById('http-detail')!;
    detailEl.classList.remove('hidden');
    detailEl.scrollIntoView({ behavior: 'smooth', block: 'start' });

    const cat = getCat(item.code);
    const catInfo = CATEGORIES[cat];
    (document.getElementById('detail-code') as HTMLElement).textContent = String(item.code);
    (document.getElementById('detail-code') as HTMLElement).className = `text-4xl font-bold ${catInfo?.textColor || 'text-primary'}`;
    (document.getElementById('detail-title') as HTMLElement).textContent = item.title;
    (document.getElementById('detail-category') as HTMLElement).textContent = catInfo?.label || '';
    (document.getElementById('detail-desc') as HTMLElement).textContent = item.desc;
    (document.getElementById('detail-when') as HTMLElement).textContent = item.when;
    (document.getElementById('detail-body') as HTMLElement).textContent = item.body;
    (document.getElementById('detail-express-code') as HTMLElement).textContent = item.express;
    (document.getElementById('detail-fastapi-code') as HTMLElement).textContent = item.fastapi;
    (document.getElementById('detail-hono-code') as HTMLElement).textContent = item.hono;
  }

  function renderGrid(items: StatusCode[]) {
    const grid = document.getElementById('http-grid')!;
    if (items.length === 0) {
      grid.innerHTML = '<p class="text-text-muted text-sm">No matching status codes.</p>';
      return;
    }

    const groups: Record<string, StatusCode[]> = {};
    items.forEach(item => {
      const cat = getCat(item.code);
      if (!groups[cat]) groups[cat] = [];
      groups[cat].push(item);
    });

    grid.innerHTML = Object.entries(groups).map(([cat, codes]) => {
      const catInfo = CATEGORIES[cat];
      return `
        <div>
          <h2 class="text-base font-semibold mb-3 ${catInfo?.textColor || ''}">${catInfo?.label || cat + 'xx'}</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2">
            ${codes.map(c => `
              <button class="http-code-btn border rounded-lg p-3 text-left hover:border-primary transition-colors ${catInfo?.color || ''}" data-code="${c.code}">
                <div class="text-lg font-bold font-mono ${catInfo?.textColor || ''}">${c.code}</div>
                <div class="text-xs text-text-muted leading-tight mt-0.5">${c.title}</div>
              </button>
            `).join('')}
          </div>
        </div>
      `;
    }).join('');

    grid.querySelectorAll('.http-code-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const code = parseInt((btn as HTMLElement).dataset.code || '0');
        const item = CODES.find(c => c.code === code);
        if (item) showDetail(item);
      });
    });
  }

  function filterCodes(query: string): StatusCode[] {
    if (!query) return CODES;
    const q = query.toLowerCase();
    return CODES.filter(c =>
      String(c.code).includes(q) ||
      c.title.toLowerCase().includes(q) ||
      c.desc.toLowerCase().includes(q) ||
      c.when.toLowerCase().includes(q)
    );
  }

  // Code tab switching
  document.querySelectorAll('.http-code-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      activeTab = (btn as HTMLElement).dataset.tab!;
      document.querySelectorAll('.http-code-tab').forEach(b => {
        b.classList.remove('border-primary', 'text-primary');
        b.classList.add('border-transparent', 'text-text-muted');
      });
      btn.classList.add('border-primary', 'text-primary');
      btn.classList.remove('border-transparent', 'text-text-muted');
      document.querySelectorAll('.http-code-panel').forEach(p => p.classList.add('hidden'));
      document.getElementById('http-code-' + activeTab)!.classList.remove('hidden');
    });
  });

  // Copy buttons
  document.querySelectorAll('.http-copy').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = (btn as HTMLElement).dataset.target!;
      const text = (document.getElementById(target) as HTMLElement).textContent || '';
      navigator.clipboard.writeText(text).then(() => {
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
      });
    });
  });

  // Search
  const searchEl = document.getElementById('http-search') as HTMLInputElement;
  searchEl.addEventListener('input', () => {
    renderGrid(filterCodes(searchEl.value));
  });
  document.getElementById('http-clear')!.addEventListener('click', () => {
    searchEl.value = '';
    renderGrid(CODES);
  });

  // Initial render
  renderGrid(CODES);
</script>
