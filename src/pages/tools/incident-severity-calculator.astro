---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What are DORA metrics?", answer: "DORA (DevOps Research and Assessment) metrics are four key measures of software delivery performance: Deployment Frequency, Lead Time for Changes, Time to Restore Service (MTTR), and Change Failure Rate. They were identified through years of research by the DORA team at Google and are now industry-standard benchmarks." },
  { question: "What do the DORA performance tiers mean?", answer: "Elite: top 25% of performers. High: above median. Medium: below median. Low: bottom 25%. Elite performers deploy multiple times per day with lead times under 1 hour, MTTR under 1 hour, and change failure rates under 5%. Moving up one tier typically correlates with significant business outcome improvements." },
  { question: "What is MTTR and how is it calculated?", answer: "MTTR (Mean Time to Restore/Recover) measures the average time to restore service after an incident. Calculate it as: total downtime during incidents / number of incidents. The DORA Elite benchmark is under 1 hour; Low performers take over 6 months to recover from failures." },
  { question: "What is change failure rate?", answer: "Change failure rate (CFR) is the percentage of deployments that cause degraded service and require remediation (rollback, hotfix, or patch). DORA Elite benchmark is 0-5%. CFR = incidents caused by deployments / total deployments × 100. High CFR indicates insufficient testing or review processes." },
  { question: "How do I improve DORA metrics?", answer: "Deployment Frequency: invest in CI/CD automation and trunk-based development. Lead Time: shorten code review cycles and test execution times. MTTR: improve alerting, runbooks, and on-call processes. Change Failure Rate: add integration tests, feature flags, and progressive delivery (canary/blue-green deployments)." },
];
---

<BaseLayout
  title="DORA Metrics & Incident Severity Calculator — Elite/High/Medium/Low Tier"
  description="Calculate your DORA performance tier (Elite/High/Medium/Low) from deployment frequency, lead time, MTTR, and change failure rate. Get improvement recommendations per metric."
  tool="DORA Metrics Calculator, Incident Severity Calculator, MTTR Calculator, Change Failure Rate, DevOps Performance"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">DORA Metrics & Incident Severity Calculator</h1>
  <p class="text-text-muted mb-4">Enter your DevOps metrics to calculate your DORA performance tier, reliability score, and get actionable improvement recommendations for each metric.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> DORA Elite / High / Medium / Low tiers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Per-metric recommendations</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Overall DORA score</span>
  </div>

  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Deployment Metrics</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Deployment Frequency (per day)</label>
        <input id="deploy-freq" type="number" value="2" min="0" step="0.01"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        <p class="text-xs text-text-muted mt-1">e.g. 0.1 = once per 10 days, 2 = twice per day</p>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Lead Time for Changes (hours)</label>
        <input id="lead-time" type="number" value="4" min="0" step="0.5"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        <p class="text-xs text-text-muted mt-1">From commit to production deployment</p>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Time to Restore Service / MTTR (hours)</label>
        <input id="mttr" type="number" value="0.75" min="0" step="0.25"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        <p class="text-xs text-text-muted mt-1">Average hours to restore after an incident</p>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Change Failure Rate (%)</label>
        <input id="cfr" type="number" value="3" min="0" max="100" step="0.5"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        <p class="text-xs text-text-muted mt-1">% of deployments causing incidents</p>
      </div>
    </div>
  </div>

  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Incident Stats (last 30 days)</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Number of Incidents</label>
        <input id="incident-count" type="number" value="3" min="0"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Avg Incident Duration (hours)</label>
        <input id="incident-duration" type="number" value="0.5" min="0" step="0.25"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
    </div>
  </div>

  <!-- Overall Score -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-5">
    <div class="bg-bg-card border border-border rounded-lg p-3 text-center md:col-span-2">
      <div id="overall-tier" class="text-3xl font-bold text-green-400 mb-1">—</div>
      <div class="text-xs text-text-muted">Overall DORA Tier</div>
    </div>
    <div class="bg-bg-card border border-border rounded-lg p-3 text-center">
      <div id="overall-score" class="text-2xl font-bold text-primary mb-1">—</div>
      <div class="text-xs text-text-muted">DORA Score (0-100)</div>
    </div>
    <div class="bg-bg-card border border-border rounded-lg p-3 text-center">
      <div id="reliability-score" class="text-2xl font-bold text-primary mb-1">—</div>
      <div class="text-xs text-text-muted">Reliability Score</div>
    </div>
  </div>

  <!-- Per-Metric Results -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Per-Metric Breakdown</h2>
    <div id="metric-breakdown" class="space-y-4"></div>
  </div>

  <!-- DORA Benchmark Table -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-3">DORA Benchmark Reference</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm min-w-[540px]">
        <thead>
          <tr class="text-text-muted text-xs uppercase border-b border-border">
            <th class="text-left pb-2 pr-4">Metric</th>
            <th class="text-center pb-2 pr-4 text-green-400">Elite</th>
            <th class="text-center pb-2 pr-4 text-blue-400">High</th>
            <th class="text-center pb-2 pr-4 text-yellow-400">Medium</th>
            <th class="text-center pb-2 text-red-400">Low</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          <tr>
            <td class="py-2.5 pr-4 text-sm font-medium">Deployment Frequency</td>
            <td class="py-2.5 pr-4 text-center text-xs">Multiple/day</td>
            <td class="py-2.5 pr-4 text-center text-xs">1/day – 1/week</td>
            <td class="py-2.5 pr-4 text-center text-xs">1/week – 1/month</td>
            <td class="py-2.5 text-center text-xs">Less than 1/month</td>
          </tr>
          <tr>
            <td class="py-2.5 pr-4 text-sm font-medium">Lead Time for Changes</td>
            <td class="py-2.5 pr-4 text-center text-xs">&lt; 1 hour</td>
            <td class="py-2.5 pr-4 text-center text-xs">1h – 1 day</td>
            <td class="py-2.5 pr-4 text-center text-xs">1 day – 1 week</td>
            <td class="py-2.5 text-center text-xs">&gt; 1 month</td>
          </tr>
          <tr>
            <td class="py-2.5 pr-4 text-sm font-medium">Time to Restore (MTTR)</td>
            <td class="py-2.5 pr-4 text-center text-xs">&lt; 1 hour</td>
            <td class="py-2.5 pr-4 text-center text-xs">&lt; 1 day</td>
            <td class="py-2.5 pr-4 text-center text-xs">1 day – 1 week</td>
            <td class="py-2.5 text-center text-xs">&gt; 6 months</td>
          </tr>
          <tr>
            <td class="py-2.5 pr-4 text-sm font-medium">Change Failure Rate</td>
            <td class="py-2.5 pr-4 text-center text-xs">0 – 5%</td>
            <td class="py-2.5 pr-4 text-center text-xs">5 – 10%</td>
            <td class="py-2.5 pr-4 text-center text-xs">10 – 15%</td>
            <td class="py-2.5 text-center text-xs">16 – 30%</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="DORA Metrics & Incident Severity Calculator" relatedTags={['devops', 'dora', 'sre', 'incident', 'reliability', 'mttr', 'monitoring']} />
</BaseLayout>

<script is:inline>
  // Returns { tier, score, color, rec }
  function rateDeployFreq(v) {
    if (v >= 1)     return { tier: "Elite",  score: 4, color: "text-green-400",  rec: "You are at Elite tier. Maintain CI/CD pipelines and trunk-based development." };
    if (v >= 0.143) return { tier: "High",   score: 3, color: "text-blue-400",   rec: "Good frequency. Aim for daily deployments by reducing batch size and improving test coverage." };
    if (v >= 0.033) return { tier: "Medium", score: 2, color: "text-yellow-400", rec: "Weekly/monthly cadence. Invest in automated testing and pipeline reliability to deploy more often." };
    return             { tier: "Low",    score: 1, color: "text-red-400",    rec: "Less than monthly deployments. Focus on CI/CD foundation: automated tests, staging environments, deploy automation." };
  }

  function rateLeadTime(hours) {
    if (hours < 1)   return { tier: "Elite",  score: 4, color: "text-green-400",  rec: "Sub-hour lead time is Elite. Keep PR review SLAs tight and tests fast (<5 min)." };
    if (hours < 24)  return { tier: "High",   score: 3, color: "text-blue-400",   rec: "Good lead time. Target sub-hour by parallelizing test stages and automating approvals for low-risk changes." };
    if (hours < 168) return { tier: "Medium", score: 2, color: "text-yellow-400", rec: "Days-long lead time. Identify longest pipeline stages, reduce manual gates, and improve test speed." };
    return             { tier: "Low",    score: 1, color: "text-red-400",    rec: "Weeks+ lead time. Major investment needed: automate reviews, reduce batch size, eliminate manual sign-offs." };
  }

  function rateMttr(hours) {
    if (hours < 1)    return { tier: "Elite",  score: 4, color: "text-green-400",  rec: "Sub-hour MTTR is Elite. Maintain runbooks and automated alerting. Run chaos engineering to stay sharp." };
    if (hours < 24)   return { tier: "High",   score: 3, color: "text-blue-400",   rec: "Good MTTR. Improve by pre-building runbooks, improving alert signal-to-noise, and on-call training." };
    if (hours < 168)  return { tier: "Medium", score: 2, color: "text-yellow-400", rec: "Days to restore is concerning. Invest in better dashboards, on-call runbooks, and escalation policies." };
    return              { tier: "Low",    score: 1, color: "text-red-400",    rec: "Very slow recovery. Critical gaps in observability, on-call process, or rollback capabilities. Address immediately." };
  }

  function rateCFR(pct) {
    if (pct <= 5)  return { tier: "Elite",  score: 4, color: "text-green-400",  rec: "Excellent CFR. Maintain with integration tests, code review standards, and feature flags." };
    if (pct <= 10) return { tier: "High",   score: 3, color: "text-blue-400",   rec: "Good CFR. Reduce further with canary deployments and more comprehensive integration tests." };
    if (pct <= 15) return { tier: "Medium", score: 2, color: "text-yellow-400", rec: "Above-average CFR. Add contract tests, improve staging environment parity, use feature flags." };
    return           { tier: "Low",    score: 1, color: "text-red-400",    rec: "High failure rate. Fundamental testing gaps. Add integration tests, require code review, use staging environments." };
  }

  function calculate() {
    var df  = parseFloat(document.getElementById("deploy-freq").value)     || 0;
    var lt  = parseFloat(document.getElementById("lead-time").value)        || 0;
    var mt  = parseFloat(document.getElementById("mttr").value)             || 0;
    var cfr = parseFloat(document.getElementById("cfr").value)              || 0;
    var inc = parseInt(document.getElementById("incident-count").value)     || 0;
    var dur = parseFloat(document.getElementById("incident-duration").value) || 0;

    var rDF  = rateDeployFreq(df);
    var rLT  = rateLeadTime(lt);
    var rMT  = rateMttr(mt);
    var rCFR = rateCFR(cfr);

    var totalScore = rDF.score + rLT.score + rMT.score + rCFR.score;  // 4-16
    var scoreNorm  = Math.round(((totalScore - 4) / 12) * 100);       // 0-100

    var tiers = [rDF.tier, rLT.tier, rMT.tier, rCFR.tier];
    var tierScores = { Elite: 4, High: 3, Medium: 2, Low: 1 };
    var avgTierScore = tiers.reduce(function(a,t){ return a + tierScores[t]; }, 0) / 4;
    var overallTier = avgTierScore >= 3.5 ? "Elite" : avgTierScore >= 2.5 ? "High" : avgTierScore >= 1.5 ? "Medium" : "Low";
    var tierColors  = { Elite: "text-green-400", High: "text-blue-400", Medium: "text-yellow-400", Low: "text-red-400" };

    var totalDowntime = inc * dur;
    var reliabilityPct = totalDowntime > 0 ? Math.max(0, 100 - (totalDowntime / (30 * 24)) * 100).toFixed(2) : "99.99";

    document.getElementById("overall-tier").textContent   = overallTier;
    document.getElementById("overall-tier").className     = "text-3xl font-bold mb-1 " + tierColors[overallTier];
    document.getElementById("overall-score").textContent  = scoreNorm + "/100";
    document.getElementById("reliability-score").textContent = reliabilityPct + "%";

    var metrics = [
      { label: "Deployment Frequency", value: df + "/day", result: rDF },
      { label: "Lead Time for Changes", value: lt + "h",  result: rLT },
      { label: "Time to Restore (MTTR)", value: mt + "h", result: rMT },
      { label: "Change Failure Rate",   value: cfr + "%", result: rCFR },
    ];

    document.getElementById("metric-breakdown").innerHTML = metrics.map(function(m) {
      return "<div class=\"border border-border rounded-lg p-4\">" +
        "<div class=\"flex items-center justify-between mb-2\">" +
        "<span class=\"text-sm font-medium\">" + m.label + "</span>" +
        "<div class=\"flex items-center gap-3\">" +
        "<span class=\"font-mono text-sm\">" + m.value + "</span>" +
        "<span class=\"text-xs font-bold px-2 py-0.5 rounded " + m.result.color + " bg-black/20\">" + m.result.tier + "</span>" +
        "</div></div>" +
        "<p class=\"text-xs text-text-muted\">" + m.result.rec + "</p>" +
        "</div>";
    }).join("");
  }

  document.querySelectorAll("input").forEach(function(el) { el.addEventListener("input", calculate); });
  calculate();
</script>
