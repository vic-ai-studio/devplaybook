---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DockerMultistageBuildGenerator from '../../components/DockerMultistageBuildGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a multi-stage Docker build and why should I use it?",
    answer: "A multi-stage Docker build uses multiple FROM instructions in one Dockerfile. Each stage can use a different base image and selectively copy artifacts to the next stage. The key benefit: your final production image only contains the compiled output — not build tools, source code, or dev dependencies. A typical Node.js app can shrink from 1+ GB (with node_modules and build tools) to under 100 MB. Go apps can use the scratch base image, producing images under 10 MB."
  },
  {
    question: "How much smaller will my Docker image be with multi-stage builds?",
    answer: "Results vary by language and app, but typical gains are significant: Node.js apps go from ~1 GB (full node:22) to ~150-300 MB with node:22-alpine + multi-stage. Go apps using scratch can be under 20 MB since the binary is statically linked. Python apps reduce by 40-60% by excluding pip cache and build tools. Rust apps with debian:bookworm-slim production stage typically yield 50-100 MB final images compared to 2+ GB build images."
  },
  {
    question: "What is the difference between node:22-alpine and node:22-slim?",
    answer: "node:22-alpine uses Alpine Linux (~5 MB base) with musl libc — extremely small but may have compatibility issues with native npm modules that expect glibc. node:22-slim uses Debian Bookworm Slim with glibc — larger (~200 MB) but compatible with all npm packages including native addons (bcrypt, sharp, canvas). Use alpine when you have no native modules; use slim when you need glibc compatibility."
  },
  {
    question: "Why does the Go Dockerfile use FROM scratch as the production stage?",
    answer: "Go compiles to a statically-linked binary with CGO_ENABLED=0, meaning it has zero runtime dependencies — no OS libraries needed. FROM scratch is a completely empty Docker layer. The only files needed are the binary and SSL certificates (for HTTPS requests). This produces the smallest possible image and the smallest attack surface. If your Go binary uses CGO or dynamic linking, switch the production stage to FROM debian:bookworm-slim or FROM alpine instead."
  },
];
---

<BaseLayout
  title="Docker Multi-Stage Build Generator — Optimized Dockerfile for Node.js, Python, Go"
  description="Generate optimized multi-stage Dockerfiles for Node.js, Python, Go, Rust, and Java. Minimize image size with build/production stage separation. Get Dockerfile + .dockerignore instantly."
  tool="docker multistage build generator, dockerfile generator, docker build optimization, multi-stage dockerfile, docker image size reduction"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Docker Multi-Stage Build Generator",
    "url": "https://devplaybook.cc/tools/docker-multistage-build-generator",
    "description": "Generate optimized multi-stage Dockerfiles for Node.js, Python, Go, Rust, and Java. Minimize image size with build/production stage separation.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Docker Multi-Stage Build Generator</h1>
  <p class="text-text-muted mb-4">
    Generate optimized <strong>multi-stage Dockerfiles</strong> for Node.js, Python, Go, Rust, and Java. Separate build and production stages to minimize your final image size. Get a ready-to-use <strong>Dockerfile</strong> and matching <strong>.dockerignore</strong> instantly.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 languages supported</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Build + production stages</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> .dockerignore included</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs in browser</span>
  </div>
  <DockerMultistageBuildGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Docker Multi-Stage Build Generator" relatedTags={['docker', 'devops', 'containers', 'dockerfile', 'developer-tools']} />
</BaseLayout>
