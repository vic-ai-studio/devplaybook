---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is a confusion matrix?", answer: "A confusion matrix is a table that summarizes the performance of a classification model by showing True Positives (TP), True Negatives (TN), False Positives (FP), and False Negatives (FN). It provides a complete picture of model performance beyond simple accuracy." },
  { question: "What is the difference between Precision and Recall?", answer: "Precision = TP/(TP+FP) — of all positive predictions, how many were actually positive. Recall = TP/(TP+FN) — of all actual positives, how many did the model find. High precision means fewer false alarms; high recall means fewer missed positives. The right balance depends on your use case." },
  { question: "When should I use F1 score instead of accuracy?", answer: "Use F1 when your dataset is imbalanced (e.g., 95% negative class). Accuracy on an imbalanced dataset can be misleading — a model predicting all negatives gets 95% accuracy but 0% recall. F1 balances precision and recall and is more meaningful for imbalanced classification problems." },
  { question: "What is Matthews Correlation Coefficient (MCC)?", answer: "MCC is a balanced metric that considers all four confusion matrix values. It ranges from -1 (perfect inverse prediction) to +1 (perfect prediction), with 0 being random. MCC is considered one of the best single-value metrics for binary classification, especially for imbalanced datasets." },
  { question: "What is Cohen's Kappa?", answer: "Cohen's Kappa measures agreement between predicted and actual labels while accounting for chance agreement. Values: <0 (worse than chance), 0-0.20 (slight), 0.21-0.40 (fair), 0.41-0.60 (moderate), 0.61-0.80 (substantial), 0.81-1.0 (near perfect). It's useful when comparing models on imbalanced datasets." },
];
---

<BaseLayout
  title="Confusion Matrix Calculator — Precision, Recall, F1, MCC, Accuracy Metrics"
  description="Calculate all ML classification metrics from a confusion matrix. Enter TP, TN, FP, FN to get Accuracy, Precision, Recall, F1 Score, Specificity, MCC, Cohen's Kappa instantly."
  tool="confusion matrix calculator, precision recall calculator, F1 score calculator, classification metrics, MCC calculator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Confusion Matrix Calculator</h1>
  <p class="text-text-muted mb-4">Enter your binary classification results to instantly compute all key metrics: Accuracy, Precision, Recall, F1, Specificity, MCC, and Cohen's Kappa. Visual confusion matrix included.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 8 classification metrics</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Visual confusion matrix</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Imbalance detection</span>
  </div>

  <!-- Input -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Confusion Matrix Values</h2>
    <div class="grid grid-cols-2 gap-4 max-w-sm mb-4">
      <div>
        <label class="block text-xs font-medium mb-1 text-green-400">True Positive (TP)</label>
        <input id="tp" type="number" value="85" min="0" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-xs font-medium mb-1 text-red-400">False Positive (FP)</label>
        <input id="fp" type="number" value="10" min="0" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-xs font-medium mb-1 text-orange-400">False Negative (FN)</label>
        <input id="fn" type="number" value="15" min="0" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-xs font-medium mb-1 text-green-400">True Negative (TN)</label>
        <input id="tn" type="number" value="90" min="0" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
    </div>
    <button id="calc-btn" class="px-4 py-2 bg-primary text-white rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors">Calculate Metrics</button>
  </div>

  <!-- Visual Matrix -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5" id="matrix-section" style="display:none">
    <h2 class="text-base font-semibold mb-4">Visual Confusion Matrix</h2>
    <div class="overflow-x-auto">
      <table class="text-sm">
        <thead>
          <tr>
            <th class="p-2"></th>
            <th class="p-3 text-center text-xs font-semibold text-text-muted" colspan="2">Predicted</th>
          </tr>
          <tr>
            <th class="p-2"></th>
            <th class="p-3 text-center text-xs font-semibold">Positive</th>
            <th class="p-3 text-center text-xs font-semibold">Negative</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="p-3 text-xs font-semibold text-text-muted writing-vertical">Actual Positive</td>
            <td id="cell-tp" class="p-4 text-center rounded-lg font-bold text-lg bg-green-500/20 border border-green-500/40"></td>
            <td id="cell-fn" class="p-4 text-center rounded-lg font-bold text-lg bg-orange-500/20 border border-orange-500/40"></td>
          </tr>
          <tr>
            <td class="p-3 text-xs font-semibold text-text-muted">Actual Negative</td>
            <td id="cell-fp" class="p-4 text-center rounded-lg font-bold text-lg bg-red-500/20 border border-red-500/40"></td>
            <td id="cell-tn" class="p-4 text-center rounded-lg font-bold text-lg bg-green-500/20 border border-green-500/40"></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Metrics Results -->
  <div id="results-section" style="display:none">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-5">
      <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
        <div class="text-xs text-text-muted mb-1">Accuracy</div>
        <div id="r-accuracy" class="text-2xl font-bold text-primary"></div>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
        <div class="text-xs text-text-muted mb-1">Precision</div>
        <div id="r-precision" class="text-2xl font-bold text-blue-400"></div>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
        <div class="text-xs text-text-muted mb-1">Recall</div>
        <div id="r-recall" class="text-2xl font-bold text-green-400"></div>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
        <div class="text-xs text-text-muted mb-1">F1 Score</div>
        <div id="r-f1" class="text-2xl font-bold text-yellow-400"></div>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
        <div class="text-xs text-text-muted mb-1">Specificity</div>
        <div id="r-specificity" class="text-2xl font-bold text-purple-400"></div>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
        <div class="text-xs text-text-muted mb-1">MCC</div>
        <div id="r-mcc" class="text-2xl font-bold text-pink-400"></div>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
        <div class="text-xs text-text-muted mb-1">Cohen's Kappa</div>
        <div id="r-kappa" class="text-2xl font-bold text-orange-400"></div>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
        <div class="text-xs text-text-muted mb-1">Balanced Acc.</div>
        <div id="r-balanced" class="text-2xl font-bold text-cyan-400"></div>
      </div>
    </div>
    <div id="imbalance-warning" class="hidden bg-yellow-500/10 border border-yellow-500/30 rounded-xl p-4 mb-5 text-sm text-yellow-300">
      ⚠️ <strong>Imbalanced dataset detected.</strong> Consider using F1, MCC, or Balanced Accuracy as primary metrics instead of plain Accuracy.
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Confusion Matrix Calculator" relatedTags={['machine-learning', 'data-science', 'calculator', 'metrics', 'classification']} />
</BaseLayout>

<script>
function fmt(v: number) { return (v * 100).toFixed(2) + '%'; }

function calculate() {
  const tp = parseFloat((document.getElementById('tp') as HTMLInputElement).value) || 0;
  const fp = parseFloat((document.getElementById('fp') as HTMLInputElement).value) || 0;
  const fn = parseFloat((document.getElementById('fn') as HTMLInputElement).value) || 0;
  const tn = parseFloat((document.getElementById('tn') as HTMLInputElement).value) || 0;
  const total = tp + fp + fn + tn;
  if (total === 0) return;

  const accuracy = (tp + tn) / total;
  const precision = (tp + fp) > 0 ? tp / (tp + fp) : 0;
  const recall = (tp + fn) > 0 ? tp / (tp + fn) : 0;
  const f1 = (precision + recall) > 0 ? 2 * precision * recall / (precision + recall) : 0;
  const specificity = (tn + fp) > 0 ? tn / (tn + fp) : 0;
  const mccDen = Math.sqrt((tp+fp)*(tp+fn)*(tn+fp)*(tn+fn));
  const mcc = mccDen > 0 ? (tp*tn - fp*fn) / mccDen : 0;
  const balanced = (recall + specificity) / 2;

  // Cohen's Kappa
  const po = accuracy;
  const pe = ((tp+fp)*(tp+fn) + (tn+fn)*(tn+fp)) / (total * total);
  const kappa = (1 - pe) > 0 ? (po - pe) / (1 - pe) : 0;

  (document.getElementById('r-accuracy') as HTMLElement).textContent = fmt(accuracy);
  (document.getElementById('r-precision') as HTMLElement).textContent = fmt(precision);
  (document.getElementById('r-recall') as HTMLElement).textContent = fmt(recall);
  (document.getElementById('r-f1') as HTMLElement).textContent = fmt(f1);
  (document.getElementById('r-specificity') as HTMLElement).textContent = fmt(specificity);
  (document.getElementById('r-mcc') as HTMLElement).textContent = mcc.toFixed(4);
  (document.getElementById('r-kappa') as HTMLElement).textContent = kappa.toFixed(4);
  (document.getElementById('r-balanced') as HTMLElement).textContent = fmt(balanced);

  // Visual matrix
  (document.getElementById('cell-tp') as HTMLElement).textContent = `TP: ${tp}`;
  (document.getElementById('cell-fp') as HTMLElement).textContent = `FP: ${fp}`;
  (document.getElementById('cell-fn') as HTMLElement).textContent = `FN: ${fn}`;
  (document.getElementById('cell-tn') as HTMLElement).textContent = `TN: ${tn}`;

  const pos = tp + fn;
  const neg = fp + tn;
  const ratio = pos > neg ? pos/neg : neg/pos;
  const warning = document.getElementById('imbalance-warning') as HTMLElement;
  if (ratio > 3) { warning.classList.remove('hidden'); } else { warning.classList.add('hidden'); }

  (document.getElementById('matrix-section') as HTMLElement).style.display = '';
  (document.getElementById('results-section') as HTMLElement).style.display = '';
}

document.getElementById('calc-btn')?.addEventListener('click', calculate);
document.addEventListener('DOMContentLoaded', calculate);
</script>
