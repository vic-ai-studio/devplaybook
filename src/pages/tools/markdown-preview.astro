---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MarkdownPreview from '../../components/MarkdownPreview.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Markdown Preview & Editor"
  description="Live Markdown preview editor with split view. Supports GFM tables, task lists, code blocks, and bold/italic. Copy output as HTML. Free, runs in your browser."
  tool="Markdown Previewer, Markdown Editor Online, Markdown to HTML"
>
  <h1 class="text-3xl font-bold mb-2">Markdown Preview & Editor</h1>
  <p class="text-text-muted mb-8">Write Markdown and see a live rendered preview side-by-side. Supports GitHub Flavored Markdown (GFM): tables, task lists, code blocks, and more. Copy the output as HTML with one click.</p>
  <MarkdownPreview client:only="preact" />
  <ToolPageCta currentTool="Markdown Preview & Editor" relatedTags={['markdown', 'content', 'html', 'documentation', 'readme']} />
</BaseLayout>
