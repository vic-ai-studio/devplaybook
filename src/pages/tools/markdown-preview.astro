---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MarkdownPreview from '../../components/MarkdownPreview.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How do I preview Markdown online?", answer: "Type or paste your Markdown into the left panel and see the rendered HTML preview live in the right panel. The preview updates in real time as you type, with full support for GitHub Flavored Markdown (GFM)." },
  { question: "What Markdown features does this preview support?", answer: "This tool supports the full GitHub Flavored Markdown spec: headings, bold, italic, strikethrough, inline code and code blocks with syntax hints, blockquotes, ordered and unordered lists, task lists (checkboxes), tables, and horizontal rules." },
  { question: "Can I convert Markdown to HTML and copy it?", answer: "Yes. Click the 'Copy HTML' button to copy the rendered HTML output to your clipboard. This is useful for pasting Markdown-generated content into email editors, CMS platforms, or any tool that accepts HTML." },
  { question: "Is Markdown the same as GitHub README format?", answer: "GitHub READMEs use GitHub Flavored Markdown (GFM), which is an extension of standard Markdown. GFM adds features like task lists, tables, fenced code blocks with language hints, and @mentions. This tool renders GFM, so your GitHub README previews accurately here." },
  { question: "What is the difference between Markdown and HTML?", answer: "Markdown is a lightweight markup language designed for humans to write easily. HTML is the output format that browsers render. Markdown is converted to HTML before display — so `**bold**` in Markdown becomes `<strong>bold</strong>` in HTML. This tool shows both sides of that conversion." },
];
---

<BaseLayout
  title="Markdown Preview & Editor — Live Markdown to HTML Converter"
  description="Free live Markdown preview editor. Write Markdown and see rendered HTML side-by-side in real time. Supports GitHub Flavored Markdown: tables, task lists, code blocks, and more. Copy output as HTML. Runs in your browser."
  tool="Markdown Previewer, Markdown Editor Online, Markdown to HTML, Live Markdown Preview, GitHub Flavored Markdown, GFM Preview, Markdown Renderer"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Markdown Preview & Editor</h1>
  <p class="text-text-muted mb-8">Write Markdown and see a live rendered preview side-by-side. Supports GitHub Flavored Markdown (GFM): tables, task lists, code blocks, and more. Copy the output as HTML with one click. Runs entirely in your browser.</p>
  <MarkdownPreview client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Markdown Preview & Editor" relatedTags={['markdown', 'content', 'html', 'documentation', 'readme']} />
</BaseLayout>
