---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DataPipelineDiagramGenerator from '../../components/DataPipelineDiagramGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the difference between ETL and ELT?",
    answer: "ETL (Extract, Transform, Load) transforms data before loading it into the destination — the transform step runs in a dedicated processing layer (Apache Spark, dbt on a staging DB, custom Python). This is common for legacy data warehouses with limited compute. ELT (Extract, Load, Transform) loads raw data first into the destination (Snowflake, BigQuery, Redshift), then transforms it using the warehouse's compute power. ELT is now dominant in modern cloud data stacks because cloud warehouses are cheap and powerful. dbt (data build tool) is the de facto ELT transform layer."
  },
  {
    question: "What should I include in each pipeline stage?",
    answer: "Source stages: database (Postgres, MySQL), file (S3, GCS, SFTP), API (REST, GraphQL), or stream (Kafka, Kinesis). Transform stages: filter (remove rows), join (combine datasets), aggregate (GROUP BY operations), normalize (standardize formats/types), enrich (add data from external sources), validate (data quality checks), deduplicate (remove exact/fuzzy duplicates). Sink stages: operational database, analytical data warehouse (Snowflake, BigQuery), file output (Parquet on S3), downstream API, or event stream."
  },
  {
    question: "How do I use Mermaid diagrams in documentation?",
    answer: "Mermaid is natively supported in GitHub Markdown (use ```mermaid code blocks), GitLab, Notion, Confluence (with plugin), Obsidian, and many wikis. For standalone rendering, use mermaid.live (online editor with live preview), or install the Mermaid CLI: npm install -g @mermaid-js/mermaid-cli, then mmdc -i diagram.mmd -o diagram.png. For React/Vue apps, use the mermaid npm package to render diagrams dynamically."
  },
  {
    question: "What are common data pipeline architecture patterns?",
    answer: "Lambda Architecture: dual batch + streaming paths that merge into a serving layer — complex but handles both historical and real-time data. Kappa Architecture: streaming-only, simpler but requires replayable streams (Kafka). Modern Data Stack: dbt + Fivetran/Airbyte + Snowflake/BigQuery — ELT with managed connectors. Medallion Architecture (used in Databricks): Bronze (raw) → Silver (cleaned) → Gold (aggregated) layers in a data lakehouse. For most teams starting in 2026, a simple ELT pipeline with Fivetran/Airbyte + dbt + BigQuery is the fastest path to production."
  },
];
---

<BaseLayout
  title="Data Pipeline Diagram Generator — Build ETL/ELT Flow Diagrams as Mermaid"
  description="Build ETL and ELT data pipeline diagrams visually. Add sources, transforms, and sinks, then export as Mermaid flowchart code. Design data flows for any pipeline architecture."
  tool="data pipeline diagram generator, etl diagram, elt diagram, mermaid data pipeline, data flow diagram, pipeline architecture"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Data Pipeline Diagram Generator",
    "url": "https://devplaybook.cc/tools/data-pipeline-diagram-generator",
    "description": "Build ETL and ELT data pipeline diagrams visually. Add sources, transforms, and sinks, then export as Mermaid flowchart code.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Data Pipeline Diagram Generator</h1>
  <p class="text-text-muted mb-4">
    Design <strong>ETL and ELT data pipeline flows</strong> visually. Add source, transform, and sink stages, reorder them, then export as <strong>Mermaid flowchart code</strong> for GitHub, Notion, or any Mermaid-compatible tool.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Source / Transform / Sink</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Mermaid flowchart output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Drag to reorder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Pre-loaded example</span>
  </div>
  <DataPipelineDiagramGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Data Pipeline Diagram Generator" relatedTags={['data-engineering', 'etl', 'mermaid', 'data-pipeline', 'developer-tools']} />
</BaseLayout>
