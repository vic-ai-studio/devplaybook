---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the content array in tailwind.config.js?", answer: "The content array tells Tailwind CSS which files to scan for class names. Tailwind uses this to purge unused styles in production builds, resulting in tiny CSS bundles. Common patterns include './src/**/*.{js,ts,jsx,tsx}' for source files and './public/index.html' for HTML files. Missing paths are the #1 cause of styles not appearing in production." },
  { question: "How do I add custom colors to Tailwind?", answer: "Custom colors go in theme.extend.colors to add alongside defaults, or theme.colors to replace all defaults. Each color can be a hex string, an object with shades (50-950), or a CSS variable reference like 'var(--color-brand)'. Using theme.extend is recommended to keep Tailwind's built-in palette available." },
  { question: "What are Tailwind plugins?", answer: "Official Tailwind plugins add pre-built component and utility classes. @tailwindcss/forms resets default browser styles on form elements. @tailwindcss/typography adds the 'prose' class for rich text. DaisyUI adds 50+ component classes. tailwindcss-animate adds animation utilities compatible with Radix UI and shadcn/ui." },
  { question: "How do custom breakpoints work in Tailwind?", answer: "Tailwind's default breakpoints are sm (640px), md (768px), lg (1024px), xl (1280px), 2xl (1536px). You can add custom breakpoints in theme.extend.screens. Tailwind uses min-width by default (mobile-first). Use 'max-sm' prefix for max-width queries. Custom screen names become responsive prefixes: '3xl:text-xl'." },
  { question: "What is the difference between theme and theme.extend?", answer: "theme replaces Tailwind's default theme entirely for that key. theme.extend merges your additions with Tailwind's defaults. Almost always use theme.extend — otherwise you lose all built-in colors, spacing, fonts etc. Only use theme (without extend) when you want a completely custom design system with no Tailwind defaults." },
];
---

<BaseLayout
  title="Tailwind Config Generator — tailwind.config.js Builder with Custom Colors, Fonts & Plugins"
  description="Generate a complete tailwind.config.js file with custom colors, fonts, breakpoints, and plugins. Includes global CSS imports. Copy-ready output."
  tool="Tailwind Config Generator, tailwind.config.js Builder, Tailwind CSS Configuration, Custom Colors Tailwind"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Tailwind Config Generator</h1>
  <p class="text-text-muted mb-4">Build a production-ready <code class="text-primary bg-primary/10 px-1 rounded text-sm">tailwind.config.js</code> with custom colors, fonts, breakpoints, and plugins — plus the global CSS imports you need.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Zero dependencies</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Custom colors + fonts</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Plugin checkboxes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Global CSS output</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-5">
    <!-- Left: Inputs -->
    <div class="space-y-5">

      <!-- Content Paths -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">Content Paths</h2>
        <textarea id="content-paths" rows="5"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary resize-y"
          placeholder="One path per line">./src/**/*.{js,ts,jsx,tsx}
./app/**/*.{js,ts,jsx,tsx}
./pages/**/*.{js,ts,jsx,tsx}
./components/**/*.{js,ts,jsx,tsx}
./public/index.html</textarea>
      </div>

      <!-- Custom Colors -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-base font-semibold">Custom Colors</h2>
          <button id="add-color-btn" class="bg-primary text-white text-sm px-3 py-1 rounded-lg hover:opacity-90">+ Add</button>
        </div>
        <div id="colors-container" class="space-y-2"></div>
      </div>

      <!-- Custom Fonts -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-base font-semibold">Custom Font Families</h2>
          <button id="add-font-btn" class="bg-primary text-white text-sm px-3 py-1 rounded-lg hover:opacity-90">+ Add</button>
        </div>
        <div id="fonts-container" class="space-y-2"></div>
      </div>

      <!-- Screens -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-base font-semibold">Custom Breakpoints</h2>
          <button id="add-screen-btn" class="bg-primary text-white text-sm px-3 py-1 rounded-lg hover:opacity-90">+ Add</button>
        </div>
        <div id="screens-container" class="space-y-2"></div>
      </div>

      <!-- Plugins -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">Plugins</h2>
        <div class="space-y-2">
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="plugin-forms" class="rounded" />
            <span class="font-medium">@tailwindcss/forms</span>
            <span class="text-text-muted text-xs">— Resets form element styles</span>
          </label>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="plugin-typography" class="rounded" />
            <span class="font-medium">@tailwindcss/typography</span>
            <span class="text-text-muted text-xs">— Adds 'prose' class for rich text</span>
          </label>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="plugin-daisyui" class="rounded" />
            <span class="font-medium">daisyui</span>
            <span class="text-text-muted text-xs">— 50+ component classes</span>
          </label>
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input type="checkbox" id="plugin-animate" class="rounded" />
            <span class="font-medium">tailwindcss-animate</span>
            <span class="text-text-muted text-xs">— Animation utilities (shadcn/ui compatible)</span>
          </label>
        </div>
      </div>
    </div>

    <!-- Right: Output -->
    <div class="space-y-5">
      <!-- tailwind.config.js -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-base font-semibold">tailwind.config.js</h2>
          <button id="copy-config-btn" class="border border-border text-text-muted hover:text-primary hover:border-primary text-xs px-2.5 py-1 rounded-md transition-colors">Copy</button>
        </div>
        <pre id="config-output" class="text-green-400 text-xs font-mono overflow-x-auto whitespace-pre bg-bg-card border border-border rounded-lg p-3 min-h-[200px]"></pre>
      </div>

      <!-- globals.css -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-base font-semibold">globals.css / CSS Imports</h2>
          <button id="copy-css-btn" class="border border-border text-text-muted hover:text-primary hover:border-primary text-xs px-2.5 py-1 rounded-md transition-colors">Copy</button>
        </div>
        <pre id="css-output" class="text-blue-400 text-xs font-mono overflow-x-auto whitespace-pre bg-bg-card border border-border rounded-lg p-3 min-h-[80px]"></pre>
      </div>

      <!-- Install command -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-base font-semibold">Install Dependencies</h2>
          <button id="copy-install-btn" class="border border-border text-text-muted hover:text-primary hover:border-primary text-xs px-2.5 py-1 rounded-md transition-colors">Copy</button>
        </div>
        <pre id="install-output" class="text-yellow-400 text-xs font-mono overflow-x-auto whitespace-pre bg-bg-card border border-border rounded-lg p-3"></pre>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Tailwind Config Generator" relatedTags={['tailwind', 'css', 'config', 'design-system', 'frontend']} />
</BaseLayout>

<script>
  interface ColorRow { id: string; name: string; value: string; }
  interface FontRow { id: string; name: string; stack: string; }
  interface ScreenRow { id: string; name: string; px: string; }

  let colors: ColorRow[] = [
    { id: 'c1', name: 'brand', value: '#6366f1' },
    { id: 'c2', name: 'accent', value: '#f59e0b' },
  ];
  let fonts: FontRow[] = [
    { id: 'fn1', name: 'sans', stack: 'Inter, ui-sans-serif, system-ui, sans-serif' },
  ];
  let screens: ScreenRow[] = [];

  function uid(): string { return Math.random().toString(36).slice(2, 8); }

  function renderRows<T extends {id: string}>(containerId: string, rows: T[], cols: Array<{key: keyof T, placeholder: string, type?: string, width?: string}>): void {
    const el = document.getElementById(containerId)!;
    if (rows.length === 0) {
      el.innerHTML = `<div class="text-center text-text-muted text-xs py-3 border border-dashed border-border rounded-lg">None added yet.</div>`;
      return;
    }
    el.innerHTML = rows.map(row => `
      <div class="flex gap-2 items-center" data-row-id="${row.id}">
        ${cols.map(col => {
          const val = row[col.key] as string;
          if (col.type === 'color') {
            return `<div class="flex items-center gap-1">
              <input type="color" value="${val}" data-prop="${String(col.key)}" class="w-8 h-8 rounded cursor-pointer border border-border" />
              <input type="text" value="${val}" data-prop-text="${String(col.key)}" placeholder="${col.placeholder}" class="w-24 bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs font-mono focus:outline-none focus:border-primary" />
            </div>`;
          }
          return `<input type="text" value="${val}" data-prop="${String(col.key)}" placeholder="${col.placeholder}"
            class="flex-1 bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:border-primary" ${col.width ? `style="max-width:${col.width}"` : ''} />`;
        }).join('')}
        <button data-remove="${row.id}" class="text-red-400 hover:text-red-500 text-lg w-7 h-7 flex items-center justify-center rounded hover:bg-red-500/10">×</button>
      </div>
    `).join('');

    el.querySelectorAll('[data-prop]').forEach(inp => {
      inp.addEventListener('input', (e) => {
        const t = e.target as HTMLInputElement;
        const rowEl = t.closest('[data-row-id]') as HTMLElement;
        const id = rowEl.dataset.rowId!;
        const prop = t.dataset.prop!;
        // sync color picker to text
        if (t.type === 'color') {
          const textInput = rowEl.querySelector(`[data-prop-text="${prop}"]`) as HTMLInputElement;
          if (textInput) textInput.value = t.value;
        }
        updateRow(containerId, id, prop, t.value);
      });
    });
    el.querySelectorAll('[data-prop-text]').forEach(inp => {
      inp.addEventListener('input', (e) => {
        const t = e.target as HTMLInputElement;
        const rowEl = t.closest('[data-row-id]') as HTMLElement;
        const id = rowEl.dataset.rowId!;
        const prop = t.dataset.propText!;
        const picker = rowEl.querySelector(`[data-prop="${prop}"][type="color"]`) as HTMLInputElement;
        if (picker && /^#[0-9a-fA-F]{6}$/.test(t.value)) picker.value = t.value;
        updateRow(containerId, id, prop, t.value);
      });
    });
    el.querySelectorAll('[data-remove]').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.remove!;
        if (containerId === 'colors-container') colors = colors.filter(r => r.id !== id);
        else if (containerId === 'fonts-container') fonts = fonts.filter(r => r.id !== id);
        else screens = screens.filter(r => r.id !== id);
        renderAll();
      });
    });
  }

  function updateRow(containerId: string, id: string, prop: string, value: string): void {
    if (containerId === 'colors-container') {
      const r = colors.find(x => x.id === id)!;
      (r as any)[prop] = value;
    } else if (containerId === 'fonts-container') {
      const r = fonts.find(x => x.id === id)!;
      (r as any)[prop] = value;
    } else {
      const r = screens.find(x => x.id === id)!;
      (r as any)[prop] = value;
    }
    generate();
  }

  function renderAll(): void {
    renderRows('colors-container', colors, [
      { key: 'name', placeholder: 'colorName' },
      { key: 'value', placeholder: '#3b82f6', type: 'color' },
    ]);
    renderRows('fonts-container', fonts, [
      { key: 'name', placeholder: 'sans' },
      { key: 'stack', placeholder: 'Inter, ui-sans-serif, sans-serif' },
    ]);
    renderRows('screens-container', screens, [
      { key: 'name', placeholder: '3xl', width: '80px' },
      { key: 'px', placeholder: '1920px', width: '100px' },
    ]);
    generate();
  }

  function getPlugins(): string[] {
    const plugins: string[] = [];
    if ((document.getElementById('plugin-forms') as HTMLInputElement).checked) plugins.push('@tailwindcss/forms');
    if ((document.getElementById('plugin-typography') as HTMLInputElement).checked) plugins.push('@tailwindcss/typography');
    if ((document.getElementById('plugin-daisyui') as HTMLInputElement).checked) plugins.push('daisyui');
    if ((document.getElementById('plugin-animate') as HTMLInputElement).checked) plugins.push('tailwindcss-animate');
    return plugins;
  }

  function generate(): void {
    const pathsRaw = (document.getElementById('content-paths') as HTMLTextAreaElement).value;
    const paths = pathsRaw.split('\n').map(l => l.trim()).filter(Boolean);
    const plugins = getPlugins();

    // tailwind.config.js
    const colorEntries = colors.map(c => `      ${c.name}: '${c.value}',`).join('\n');
    const fontEntries = fonts.map(f => `      ${f.name}: ['${f.stack.split(',').map(s => s.trim()).join("', '")}'],`).join('\n');
    const screenEntries = screens.map(s => `      ${s.name}: '${s.px || '1920px'}',`).join('\n');

    const hasColors = colors.length > 0;
    const hasFonts = fonts.length > 0;
    const hasScreens = screens.length > 0;
    const hasPlugins = plugins.length > 0;

    const pluginImports = plugins.map(p => {
      const varName = p.replace(/[@\/\-]/g, '_').replace(/^_+/, '');
      return `const ${varName} = require('${p}');`;
    }).join('\n');

    const pluginList = plugins.map(p => {
      const varName = p.replace(/[@\/\-]/g, '_').replace(/^_+/, '');
      return `    ${varName},`;
    }).join('\n');

    const extendParts: string[] = [];
    if (hasColors) extendParts.push(`    colors: {\n${colorEntries}\n    },`);
    if (hasFonts) extendParts.push(`    fontFamily: {\n${fontEntries}\n    },`);
    if (hasScreens) extendParts.push(`    screens: {\n${screenEntries}\n    },`);

    const configStr = `/** @type {import('tailwindcss').Config} */
${pluginImports ? pluginImports + '\n\n' : ''}module.exports = {
  content: [
${paths.map(p => `    '${p}',`).join('\n')}
  ],
  theme: {
    extend: {
${extendParts.join('\n')}
    },
  },${hasPlugins ? `\n  plugins: [\n${pluginList}\n  ],` : ''}
};`;

    document.getElementById('config-output')!.textContent = configStr;

    // globals.css
    const cssLines = ['@tailwind base;', '@tailwind components;', '@tailwind utilities;'];
    if (fonts.length > 0) {
      cssLines.push('');
      cssLines.push('/* Import your fonts in <head> or use next/font */');
      fonts.forEach(f => {
        cssLines.push(`/* Font: ${f.name} — ${f.stack.split(',')[0].trim()} */`);
      });
    }
    document.getElementById('css-output')!.textContent = cssLines.join('\n');

    // install
    const deps: string[] = [];
    if (plugins.includes('@tailwindcss/forms')) deps.push('@tailwindcss/forms');
    if (plugins.includes('@tailwindcss/typography')) deps.push('@tailwindcss/typography');
    if (plugins.includes('daisyui')) deps.push('daisyui');
    if (plugins.includes('tailwindcss-animate')) deps.push('tailwindcss-animate');
    const installStr = deps.length > 0
      ? `npm install -D ${deps.join(' ')}\n# or\nyarn add -D ${deps.join(' ')}`
      : '# No additional plugins selected\nnpm install -D tailwindcss postcss autoprefixer\nnpx tailwindcss init -p';
    document.getElementById('install-output')!.textContent = installStr;
  }

  function makeCopyBtn(btnId: string, sourceId: string) {
    document.getElementById(btnId)!.addEventListener('click', () => {
      const text = document.getElementById(sourceId)!.textContent ?? '';
      navigator.clipboard.writeText(text).then(() => {
        const btn = document.getElementById(btnId)!;
        btn.textContent = 'Copied!';
        setTimeout(() => btn.textContent = 'Copy', 1500);
      });
    });
  }
  makeCopyBtn('copy-config-btn', 'config-output');
  makeCopyBtn('copy-css-btn', 'css-output');
  makeCopyBtn('copy-install-btn', 'install-output');

  document.getElementById('add-color-btn')!.addEventListener('click', () => {
    colors.push({ id: uid(), name: `color${colors.length + 1}`, value: '#6366f1' });
    renderAll();
  });
  document.getElementById('add-font-btn')!.addEventListener('click', () => {
    fonts.push({ id: uid(), name: `font${fonts.length + 1}`, stack: 'Inter, sans-serif' });
    renderAll();
  });
  document.getElementById('add-screen-btn')!.addEventListener('click', () => {
    screens.push({ id: uid(), name: '3xl', px: '1920px' });
    renderAll();
  });

  document.getElementById('content-paths')!.addEventListener('input', generate);
  ['plugin-forms','plugin-typography','plugin-daisyui','plugin-animate'].forEach(id => {
    document.getElementById(id)!.addEventListener('change', generate);
  });

  renderAll();
</script>
