---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const workflowExample = `# 1. You have a feature branch with several commits:
#    c1: Add user model
#    c2: Add auth middleware
#    c3: Add login endpoint

# 2. Your reviewer asks for a small fix in the user model.
#    Make the fix, then stage the changes:
git add src/models/user.ts

# 3. Run git absorb — it figures out which prior commit owns this code:
git absorb
# Output: absorbed 1 hunk into fixup! Add user model

# 4. Autosquash to merge the fixup into the original commit:
git rebase --autosquash origin/main
# Result: a clean history with the fix baked into "Add user model"

# 5. Force-push the cleaned-up branch:
git push --force-with-lease`;

const faq = [
  { question: "What is git absorb?", answer: "git-absorb is a Git extension that automatically creates fixup commits for your staged changes. It analyzes which lines you changed, figures out which existing commit in your branch originally introduced those lines, and creates a 'git commit --fixup' pointing to that commit. You then run 'git rebase --autosquash' to merge the fixup into the original commit, resulting in a clean linear history." },
  { question: "What is a fixup commit?", answer: "A fixup commit is a special commit created with 'git commit --fixup=<hash>'. It is named 'fixup! Original commit message'. When you run 'git rebase -i --autosquash', Git automatically moves fixup commits immediately after their target commits and marks them to be squashed with no separate commit message. The result is the original commit with the fix incorporated, as if you had committed it correctly the first time." },
  { question: "How does git absorb differ from manually creating fixup commits?", answer: "Manually creating fixup commits requires you to identify the correct target commit hash, run 'git commit --fixup=<hash>' with that hash, then rebase. git absorb automates the identification step — it uses blame information to determine which commit originally wrote the lines you are now modifying, and creates the fixup commit automatically. For a branch with many commits, this saves significant time and reduces errors from targeting the wrong commit." },
  { question: "What is a typical git absorb workflow?", answer: "1. Make a series of commits on your feature branch. 2. Receive review feedback requiring small changes. 3. Stage the changes with 'git add'. 4. Run 'git absorb' — it creates one fixup commit per target commit. 5. Run 'git rebase --autosquash origin/main' to squash all fixup commits into their targets. 6. Force-push with '--force-with-lease'. The reviewer sees a clean, linear history without noisy 'address review feedback' commits." },
  { question: "What happens when git absorb cannot identify the target commit?", answer: "If git absorb cannot confidently determine which commit to fix up (because the changed lines are new, too ambiguous, or span multiple commits), it will leave those changes unstaged in the working tree and report that it could not absorb them. You can then manually stage them and create a normal commit or a manual fixup commit. git absorb will never make a wrong fixup — it only acts when it is confident." },
  { question: "Does git absorb work with merge commits or only linear history?", answer: "git absorb works best on linear (rebased) branches without merge commits. It looks at the commits between HEAD and the merge base with the main branch to find fixup targets. On branches with merge commits, the range it analyzes may be incorrect. Stick to a rebase-based workflow (squash/rebase rather than merge) for the best git absorb experience." },
];
---

<BaseLayout
  title="git-absorb — Automatic Fixup Commits for Staged Changes"
  description="git-absorb automatically creates git commit --fixup commits for your staged changes. It identifies which prior commit owns the changed lines and generates fixups for clean rebasing. Written in Rust."
  tool="git absorb, git fixup commits, git autosquash, git rebase fixup, automatic fixup commit, git-absorb rust"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "git-absorb — Automatic Fixup Commits for Staged Changes",
    "url": "https://devplaybook.cc/tools/git-absorb",
    "description": "git-absorb automatically creates git commit --fixup commits for your staged changes, identifying which prior commit owns each changed line.",
  })} />

  <h1 class="text-3xl font-bold mb-2">git-absorb</h1>
  <p class="text-text-muted mb-6">
    Automatically create <code class="bg-bg-card px-1 rounded text-sm">git commit --fixup</code> commits for your staged changes.
    git-absorb identifies which existing commit owns each changed line and generates the fixup — then
    <code class="bg-bg-card px-1 rounded text-sm">git rebase --autosquash</code> folds them in for a perfectly clean history.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Automatic fixup targeting</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Works with autosquash rebase</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Written in Rust</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Open source (BSD-3)</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is git-absorb?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    git-absorb is a Git extension written in Rust that automates the tedious part of maintaining a clean feature branch: correctly attributing review fixes to the right original commit. When a code reviewer asks for changes, you typically make those changes and then need to figure out which commit introduced the affected code, create a fixup commit targeting that commit, then rebase to clean up.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    git-absorb does the attribution automatically. It runs <code class="bg-bg-card px-1 rounded text-xs">git blame</code> on your staged changes, identifies which commits in your branch introduced those lines, and creates <code class="bg-bg-card px-1 rounded text-xs">git commit --fixup</code> commits pointing to them. Run <code class="bg-bg-card px-1 rounded text-xs">git rebase --autosquash</code> afterward and your history is clean.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Automatic fixup targeting</strong> — uses git blame to identify which commit owns each staged hunk</li>
    <li><strong>Safe — never wrong</strong> — if git-absorb is uncertain, it leaves changes unstaged rather than creating an incorrect fixup</li>
    <li><strong>Multiple fixups at once</strong> — stages across multiple files create multiple fixup commits targeting the correct parents in one pass</li>
    <li><strong>Works with autosquash</strong> — pairs directly with <code class="bg-bg-card px-1 rounded text-xs">git rebase -i --autosquash</code> for one-command cleanup</li>
    <li><strong>Configurable range</strong> — controls how many commits back git-absorb looks for fixup targets</li>
    <li><strong>Written in Rust</strong> — fast, dependency-free binary available on all major platforms</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Installation</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-2"># macOS (Homebrew)
brew install git-absorb

# Rust / Cargo (any platform)
cargo install git-absorb

# Nix
nix-env -iA nixpkgs.gitAndTools.git-absorb

# Arch Linux (AUR)
yay -S git-absorb</pre>
  <p class="text-text-muted text-sm mb-4">After installation, <code class="bg-bg-card px-1 rounded">git absorb</code> is available as a git subcommand in any repository.</p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Complete Workflow Example</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={workflowExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">git-absorb vs Manual Fixup Commits</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Step</th>
          <th class="border border-border px-3 py-2 text-left">Manual fixup</th>
          <th class="border border-border px-3 py-2 text-left">git absorb</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2">Find target commit</td><td class="border border-border px-3 py-2">git log / git blame manually</td><td class="border border-border px-3 py-2 text-green-400">Automatic</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Create fixup</td><td class="border border-border px-3 py-2">git commit --fixup=&lt;hash&gt;</td><td class="border border-border px-3 py-2 text-green-400">git absorb (automatic)</td></tr>
        <tr><td class="border border-border px-3 py-2">Multiple targets</td><td class="border border-border px-3 py-2">Repeat for each commit</td><td class="border border-border px-3 py-2 text-green-400">One command</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Merge fixups</td><td class="border border-border px-3 py-2">git rebase --autosquash</td><td class="border border-border px-3 py-2">git rebase --autosquash</td></tr>
        <tr><td class="border border-border px-3 py-2">Risk of wrong target</td><td class="border border-border px-3 py-2 text-red-400">Yes (human error)</td><td class="border border-border px-3 py-2 text-green-400">Very low (safe by default)</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Use Cases</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li>Incorporating code review feedback into the correct original commit without polluting history</li>
    <li>Cleaning up a feature branch before merging with a squash-friendly team workflow</li>
    <li>Fixing typos or minor errors from commits made earlier in the same branch</li>
    <li>Maintaining atomic, reviewable commits when a PR spans many logical changes</li>
    <li>Pairing with lazygit or other TUIs that support autosquash-based rebase workflows</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pros and Cons</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-green-400 mb-2">Pros</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✓ Eliminates the tedious "which commit do I fixup?" step</li>
        <li>✓ Handles multiple fixup targets in a single run</li>
        <li>✓ Safe — leaves ambiguous changes unstaged rather than guessing</li>
        <li>✓ Produces perfectly clean history after autosquash rebase</li>
        <li>✓ Fast Rust binary, minimal install footprint</li>
      </ul>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-red-400 mb-2">Cons</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✗ Only works on linear branch history (no merge commits)</li>
        <li>✗ Cannot absorb hunks in brand-new files (no blame target)</li>
        <li>✗ Requires rebase comfort — not for teams that use merge-only workflows</li>
        <li>✗ Less useful on short branches with only one or two commits</li>
        <li>✗ Rewriting history requires force-push on shared branches</li>
      </ul>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="git-absorb" relatedTags={['git', 'cli', 'devops', 'version-control', 'workflow']} />
</BaseLayout>
