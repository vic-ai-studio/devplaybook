---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PlaywrightTestGenerator from '../../components/PlaywrightTestGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is Playwright and how does it differ from Cypress?",
    answer: "Playwright is an E2E testing framework from Microsoft that supports Chromium, Firefox, and WebKit in a single test run. Unlike Cypress (which runs inside the browser), Playwright drives browsers externally via DevTools Protocol, enabling true multi-tab testing, native file uploads, and parallel browser testing. Playwright's async/await API is more idiomatic for TypeScript developers, and its Locator API has built-in auto-waiting so you rarely need explicit waits."
  },
  {
    question: "What is the Locator API and why is it preferred?",
    answer: "Playwright's Locator API (page.locator(), page.getByTestId(), page.getByRole(), page.getByText()) is the recommended way to find elements. Unlike page.$() (which returns a static ElementHandle that can go stale), Locators are lazy — they re-query the DOM on every action and automatically wait for the element to be actionable. This eliminates most timing-related flakiness. Use page.getByTestId() for data-testid attributes and page.getByRole() for accessible elements."
  },
  {
    question: "How does page.route() work for network mocking?",
    answer: "page.route(pattern, handler) intercepts network requests matching the glob pattern (e.g. '**/api/users'). In the handler, you can call route.fulfill({ status, body }) to return a fake response, route.abort() to simulate network errors, or route.continue() to pass through. This lets you test loading states, error handling, and edge cases without a real backend. Always set up routes before navigating to the page."
  },
  {
    question: "How do I run Playwright tests across all browsers?",
    answer: "Configure projects in playwright.config.ts: each project specifies a browser via devices (e.g. devices['Desktop Chrome']). Run npx playwright test to execute all projects, or npx playwright test --project=chromium for one browser. In CI, run them in parallel with workers: 4. The Playwright HTML reporter (npx playwright show-report) shows results per browser with screenshots and traces."
  },
  {
    question: "What is Playwright Tracing and when should I use it?",
    answer: "Playwright traces (trace: 'on-first-retry' or 'retain-on-failure' in playwright.config.ts) record a complete timeline of your test — screenshots, network requests, console logs, and DOM snapshots at every step. When a test fails in CI, download the trace.zip and open it with npx playwright show-trace trace.zip. You get a full interactive timeline to debug exactly where the test diverged from expectations."
  },
  {
    question: "How do I test mobile viewports with Playwright?",
    answer: "Use devices from @playwright/test: import { devices } from '@playwright/test'. Then in your playwright.config.ts projects, add { name: 'Mobile Chrome', use: { ...devices['Pixel 5'] } }. Within a test, override with await page.setViewportSize({ width: 375, height: 667 }). You can also emulate geolocation, timezone, and device pixel ratio. Run mobile tests in parallel with desktop tests using separate project configs."
  },
];
---

<BaseLayout
  title="Playwright Test Generator — Generate Playwright Tests in TypeScript"
  description="Generate Playwright end-to-end test code in TypeScript instantly. Configure browser target, test type (navigation, form, click, assertions), and locators. Get ready-to-run Playwright tests with page.goto, Locator API, and expect assertions. Free, runs in your browser."
  tool="Playwright Test Generator, Playwright TypeScript, E2E Test Generator, Playwright Locator, Browser Testing"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Playwright Test Generator",
    "url": "https://devplaybook.cc/tools/playwright-test-generator",
    "description": "Generate Playwright end-to-end test code in TypeScript instantly. Configure browser target, test type, and locators to get ready-to-run Playwright tests.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Playwright Test Generator</h1>
  <p class="text-text-muted mb-4">
    Generate <code class="text-primary font-mono">*.spec.ts</code> Playwright tests instantly.
    Select your browser target, test type, and locators — get complete TypeScript output using
    <code class="text-primary font-mono">page.goto</code>, the <code class="text-primary font-mono">Locator API</code>,
    <code class="text-primary font-mono">page.route()</code> mocking, and
    <code class="text-primary font-mono">expect</code> assertions. Ready to copy and run.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Chromium, Firefox, WebKit &amp; All 3</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Locator API (getByTestId, getByRole)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> page.route() network mocking</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript output</span>
  </div>
  <PlaywrightTestGenerator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Playwright Test Generator" relatedTags={['testing', 'playwright', 'e2e', 'typescript', 'developer-tools']} />
</BaseLayout>
