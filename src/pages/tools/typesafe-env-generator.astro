---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is T3-env?", answer: "T3-env (@t3-oss/env-core, @t3-oss/env-nextjs) is a TypeScript library that validates environment variables at build/runtime using Zod schemas. It provides type-safe access to env vars, catches missing or malformed variables early (at startup, not runtime), and separates server-side from client-side env vars." },
  { question: "Why should I validate environment variables?", answer: "Missing or malformed env vars are a common source of runtime errors that are hard to debug. Without validation, your app might silently use undefined values or crash with cryptic errors. Zod validation catches these issues at startup with clear error messages, and TypeScript types prevent typos in variable names throughout your codebase." },
  { question: "T3-env vs plain Zod schema — what is the difference?", answer: "Plain Zod: you call z.object().parse(process.env) yourself, which works but requires manual setup for server/client separation and Next.js compatibility. T3-env: wraps Zod with a createEnv() helper that handles Next.js client prefix rules (NEXT_PUBLIC_), build-time validation, and TypeScript intellisense — less boilerplate for Next.js projects." },
  { question: "How do I validate env vars in Next.js?", answer: "With @t3-oss/env-nextjs: create env.ts with createEnv({ server: {...}, client: {...}, runtimeEnv: process.env }). Import and use env.DATABASE_URL instead of process.env.DATABASE_URL. Client vars must be prefixed with NEXT_PUBLIC_. The schema runs at build time, so missing vars fail the build rather than failing at runtime." },
  { question: "What Zod types should I use for env vars?", answer: "z.string() for most values. z.string().url() for URLs. z.string().email() for emails. z.coerce.number() for numeric values (coerces the string from process.env to a number). z.enum(['true','false']).transform(v => v === 'true') or z.string().transform(v => v === 'true') for booleans. All env vars start as strings, so use z.coerce for numbers." },
  { question: "Can I use T3-env outside of Next.js?", answer: "Yes. Use @t3-oss/env-core for framework-agnostic usage. The API is the same — createEnv({ server: {...}, runtimeEnv: process.env }) — but without Next.js-specific client prefix handling. Works with any Node.js, Bun, or Deno project." },
];
---

<BaseLayout
  title="Typesafe Env Generator — Generate T3-env and Zod Environment Variable Schemas"
  description="Free T3-env schema generator. Add environment variables, choose types and required/optional — get T3-env createEnv() and plain Zod schemas for typesafe, validated env vars in Next.js and Node.js."
  tool="T3-env generator, Zod env schema, typesafe environment variables, Next.js env validation, createEnv schema builder, @t3-oss/env-nextjs"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Typesafe Env Generator",
    "url": "https://devplaybook.cc/tools/typesafe-env-generator",
    "description": "Generate T3-env createEnv() and plain Zod schemas for typesafe, validated environment variables.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Typesafe Env Generator</h1>
  <p class="text-text-muted mb-4">Generate validated, type-safe environment variable schemas. Add your env vars, choose types, and get both a <strong>T3-env</strong> <code class="bg-surface px-1 rounded text-sm">createEnv()</code> schema and a plain <strong>Zod</strong> schema — ready to drop into your Next.js or Node.js project.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> T3-env + Zod output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Server &amp; client separation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript-ready</span>
  </div>

  <div class="space-y-6">
    <!-- Add variable form -->
    <div class="bg-surface border border-border rounded-xl p-5">
      <h2 class="text-sm font-semibold mb-3 text-text-muted uppercase tracking-wide">Add Environment Variable</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 mb-3">
        <div>
          <label for="env-name" class="block text-xs font-medium mb-1">Variable Name</label>
          <input id="env-name" type="text" placeholder="DATABASE_URL"
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-accent" />
        </div>
        <div>
          <label for="env-type" class="block text-xs font-medium mb-1">Type</label>
          <select id="env-type" class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent">
            <option value="string">string</option>
            <option value="number">number (coerce)</option>
            <option value="boolean">boolean (coerce)</option>
            <option value="url">url</option>
            <option value="email">email</option>
            <option value="enum">enum</option>
          </select>
        </div>
        <div>
          <label for="env-default" class="block text-xs font-medium mb-1">Default Value <span class="text-text-muted">(optional)</span></label>
          <input id="env-default" type="text" placeholder="e.g. localhost"
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-accent" />
        </div>
        <div>
          <label for="env-enum-vals" class="block text-xs font-medium mb-1">Enum Values <span class="text-text-muted">(comma-separated)</span></label>
          <input id="env-enum-vals" type="text" placeholder="dev,staging,prod"
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-accent" />
        </div>
      </div>
      <div class="flex flex-wrap gap-4 mb-3">
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="env-required" checked class="accent-accent" /> Required
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input type="checkbox" id="env-client" class="accent-accent" /> Client-side (NEXT_PUBLIC_)
        </label>
      </div>
      <button id="env-add" class="bg-accent hover:bg-accent/80 text-white font-medium px-4 py-2 rounded-lg text-sm transition-colors">
        Add Variable
      </button>
    </div>

    <!-- Variable list -->
    <div class="bg-surface border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-semibold text-text-muted uppercase tracking-wide">Variables</h2>
        <button id="env-clear" class="text-xs text-red-400 border border-red-400/30 px-2 py-1 rounded hover:bg-red-400/10 transition-colors">Clear All</button>
      </div>
      <div id="env-var-list" class="space-y-2">
        <p id="env-empty-msg" class="text-xs text-text-muted">No variables added yet.</p>
      </div>
    </div>

    <!-- Tab switcher for output -->
    <div class="bg-surface border border-border rounded-xl p-5">
      <div class="flex gap-2 mb-4">
        <button id="tab-t3" class="px-4 py-1.5 rounded-lg text-sm font-medium bg-accent text-white transition-colors">T3-env</button>
        <button id="tab-zod" class="px-4 py-1.5 rounded-lg text-sm font-medium bg-background border border-border text-text-muted hover:border-accent transition-colors">Plain Zod</button>
        <div class="flex-1"></div>
        <button id="env-copy" class="text-xs bg-background border border-border hover:bg-accent/20 px-3 py-1 rounded-lg transition-colors">Copy</button>
      </div>
      <pre id="env-output" class="bg-background border border-border rounded-lg px-4 py-3 text-xs font-mono overflow-x-auto whitespace-pre leading-relaxed min-h-[200px]"></pre>
      <p class="text-xs text-text-muted mt-2">T3-env: <code class="bg-background px-1 rounded">npm install @t3-oss/env-nextjs zod</code>. Plain Zod: <code class="bg-background px-1 rounded">npm install zod</code>.</p>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Typesafe Env Generator" relatedTags={['typescript', 'nextjs', 'zod', 'validation', 'developer-tools']} />
</BaseLayout>

<script>
(function() {
  var vars = [];
  var activeTab = 't3';

  function el(id) { return document.getElementById(id); }

  var DEFAULT_VARS = [
    { name: 'DATABASE_URL', type: 'url', required: true, client: false, defaultVal: '', enumVals: '' },
    { name: 'NEXTAUTH_SECRET', type: 'string', required: true, client: false, defaultVal: '', enumVals: '' },
    { name: 'NEXT_PUBLIC_APP_URL', type: 'url', required: true, client: true, defaultVal: 'http://localhost:3000', enumVals: '' },
    { name: 'PORT', type: 'number', required: false, client: false, defaultVal: '3000', enumVals: '' },
    { name: 'NODE_ENV', type: 'enum', required: true, client: false, defaultVal: 'development', enumVals: 'development,test,production' },
  ];

  function getZodType(v) {
    var base = '';
    switch (v.type) {
      case 'string': base = 'z.string()'; break;
      case 'number': base = 'z.coerce.number()'; break;
      case 'boolean': base = "z.string().transform(v => v === 'true')"; break;
      case 'url': base = 'z.string().url()'; break;
      case 'email': base = 'z.string().email()'; break;
      case 'enum':
        var vals = v.enumVals ? v.enumVals.split(',').map(function(s) { return '"' + s.trim() + '"'; }) : ['"value"'];
        base = 'z.enum([' + vals.join(', ') + '])';
        break;
      default: base = 'z.string()';
    }
    if (!v.required && !v.defaultVal) base += '.optional()';
    if (v.defaultVal) base += '.default("' + v.defaultVal + '")';
    return base;
  }

  function generateT3() {
    if (vars.length === 0) return '// Add environment variables above to generate schema.';
    var serverVars = vars.filter(function(v) { return !v.client; });
    var clientVars = vars.filter(function(v) { return v.client; });
    var lines = [];
    lines.push("import { createEnv } from '@t3-oss/env-nextjs';");
    lines.push("import { z } from 'zod';");
    lines.push("");
    lines.push("export const env = createEnv({");
    lines.push("  /**");
    lines.push("   * Server-side environment variables schema.");
    lines.push("   * These variables are only available on the server.");
    lines.push("   */");
    lines.push("  server: {");
    serverVars.forEach(function(v) {
      lines.push("    " + v.name + ": " + getZodType(v) + ",");
    });
    if (serverVars.length === 0) lines.push("    // No server-side variables");
    lines.push("  },");
    lines.push("");
    lines.push("  /**");
    lines.push("   * Client-side environment variables schema.");
    lines.push("   * These variables are exposed to the browser and must be prefixed with NEXT_PUBLIC_.");
    lines.push("   */");
    lines.push("  client: {");
    clientVars.forEach(function(v) {
      var name = v.name.startsWith('NEXT_PUBLIC_') ? v.name : 'NEXT_PUBLIC_' + v.name;
      lines.push("    " + name + ": " + getZodType(v) + ",");
    });
    if (clientVars.length === 0) lines.push("    // No client-side variables");
    lines.push("  },");
    lines.push("");
    lines.push("  /**");
    lines.push("   * Destructure all variables from process.env to make sure they are not tree-shaken.");
    lines.push("   */");
    lines.push("  runtimeEnv: {");
    serverVars.forEach(function(v) {
      lines.push("    " + v.name + ": process.env." + v.name + ",");
    });
    clientVars.forEach(function(v) {
      var name = v.name.startsWith('NEXT_PUBLIC_') ? v.name : 'NEXT_PUBLIC_' + v.name;
      lines.push("    " + name + ": process.env." + name + ",");
    });
    lines.push("  },");
    lines.push("});");
    return lines.join('\n');
  }

  function generateZod() {
    if (vars.length === 0) return '// Add environment variables above to generate schema.';
    var lines = [];
    lines.push("import { z } from 'zod';");
    lines.push("");
    lines.push("const envSchema = z.object({");
    vars.forEach(function(v) {
      lines.push("  " + v.name + ": " + getZodType(v) + ",");
    });
    lines.push("});");
    lines.push("");
    lines.push("export const env = envSchema.parse(process.env);");
    lines.push("");
    lines.push("export type Env = z.infer<typeof envSchema>;");
    return lines.join('\n');
  }

  function render() {
    var list = el('env-var-list');
    var emptyMsg = el('env-empty-msg');
    list.innerHTML = '';
    if (vars.length === 0) {
      list.appendChild(emptyMsg);
      return;
    }
    vars.forEach(function(v, i) {
      var div = document.createElement('div');
      div.className = 'flex items-center justify-between bg-background border border-border rounded-lg px-3 py-2 text-xs font-mono';
      var badges = v.client ? ' <span class="text-blue-400">[client]</span>' : ' <span class="text-orange-400">[server]</span>';
      if (!v.required) badges += ' <span class="text-text-muted">[optional]</span>';
      div.innerHTML = '<span>'
        + '<span class="font-semibold text-accent">' + v.name + '</span>'
        + ' <span class="text-text-muted">:' + v.type + '</span>'
        + badges
        + (v.defaultVal ? ' <span class="text-green-400">= ' + v.defaultVal + '</span>' : '')
        + '</span>'
        + '<button class="text-red-400 hover:text-red-300 ml-2 text-xs remove-btn">Remove</button>';
      div.querySelector('.remove-btn').addEventListener('click', function() {
        vars.splice(i, 1);
        render();
        generateOutput();
      });
      list.appendChild(div);
    });
  }

  function generateOutput() {
    el('env-output').textContent = activeTab === 't3' ? generateT3() : generateZod();
  }

  el('env-add').addEventListener('click', function() {
    var nameEl = el('env-name') as HTMLInputElement;
    var name = nameEl.value.trim().toUpperCase().replace(/\s+/g, '_');
    if (!name) { nameEl.focus(); return; }
    vars.push({
      name: name,
      type: (el('env-type') as HTMLSelectElement).value,
      required: (el('env-required') as HTMLInputElement).checked,
      client: (el('env-client') as HTMLInputElement).checked,
      defaultVal: (el('env-default') as HTMLInputElement).value.trim(),
      enumVals: (el('env-enum-vals') as HTMLInputElement).value.trim(),
    });
    nameEl.value = '';
    (el('env-default') as HTMLInputElement).value = '';
    (el('env-enum-vals') as HTMLInputElement).value = '';
    render();
    generateOutput();
  });

  el('env-clear').addEventListener('click', function() {
    vars = [];
    render();
    generateOutput();
  });

  el('tab-t3').addEventListener('click', function() {
    activeTab = 't3';
    el('tab-t3').className = 'px-4 py-1.5 rounded-lg text-sm font-medium bg-accent text-white transition-colors';
    el('tab-zod').className = 'px-4 py-1.5 rounded-lg text-sm font-medium bg-background border border-border text-text-muted hover:border-accent transition-colors';
    generateOutput();
  });

  el('tab-zod').addEventListener('click', function() {
    activeTab = 'zod';
    el('tab-zod').className = 'px-4 py-1.5 rounded-lg text-sm font-medium bg-accent text-white transition-colors';
    el('tab-t3').className = 'px-4 py-1.5 rounded-lg text-sm font-medium bg-background border border-border text-text-muted hover:border-accent transition-colors';
    generateOutput();
  });

  el('env-copy').addEventListener('click', function() {
    var text = el('env-output').textContent;
    navigator.clipboard.writeText(text).then(function() {
      var btn = el('env-copy');
      btn.textContent = 'Copied!';
      setTimeout(function() { btn.textContent = 'Copy'; }, 1500);
    });
  });

  DEFAULT_VARS.forEach(function(v) { vars.push(v); });
  render();
  generateOutput();
})();
</script>
