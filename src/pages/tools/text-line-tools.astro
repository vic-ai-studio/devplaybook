---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What are common use cases for line manipulation tools?", answer: "Line manipulation is a common developer task: sorting imports alphabetically in code (many linters require sorted imports), removing duplicate entries from CSV exports, reversing log files to show newest entries first, filtering lines by keyword without writing a grep command, numbering lines for reference, and shuffling test data lines for randomization. These operations are common in shell scripts (sort, uniq, grep, nl commands) but having a browser-based tool is useful for quick one-off tasks." },
  { question: "What is natural sort order?", answer: "Natural sort order handles numbers within strings intelligently. Standard alphabetical (lexicographic) sort orders 'file10.txt' before 'file2.txt' because '1' < '2' as characters. Natural sort recognizes that 10 > 2 as numbers and orders 'file2.txt' before 'file10.txt'. This matches how humans expect file names and version numbers to sort. Natural sort is used in file explorers, version management, and anywhere humans name things with embedded numbers." },
  { question: "How do deduplication and unique line tools work?", answer: "Line deduplication compares each line to all other lines and removes duplicates, keeping the first occurrence by default. Case-insensitive deduplication treats 'Apple' and 'apple' as the same line. Adjacent deduplication (like Unix 'uniq') only removes consecutive duplicates — it is faster and used after sorting. Full deduplication removes all duplicates regardless of position using a set (hash table) to track seen lines in O(n) time." },
];
---

<BaseLayout
  title="Text Line Tools — Sort, Deduplicate, Reverse, Filter Lines"
  description="Manipulate text line by line: sort alphabetically or numerically, remove duplicates, reverse line order, filter by keyword, number lines, and shuffle. Instant, client-side."
  tool="text line sorter, remove duplicate lines, reverse lines order, filter lines text, number lines, sort text online, line manipulation tool"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Text Line Tools — Sort, Deduplicate, Reverse, Filter Lines",
    "url": "https://devplaybook.cc/tools/text-line-tools",
    "description": "Sort, deduplicate, reverse, filter, and number text lines. Instant client-side line manipulation tool for developers.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Text Line Tools</h1>
  <p class="text-text-muted mb-6">
    Manipulate text <strong>line by line</strong>: sort, deduplicate, reverse, filter, number, shuffle.
    Paste any multi-line text and apply operations instantly — no server, no upload.
  </p>

  <div class="grid md:grid-cols-2 gap-4 mb-4">
    <div>
      <label class="block text-sm font-medium mb-2">Input</label>
      <textarea
        id="inputText"
        class="w-full h-56 bg-bg-card border border-border rounded-xl p-3 text-sm font-mono resize-none focus:outline-none focus:ring-2 focus:ring-primary"
        placeholder="Paste multi-line text here..."
      ></textarea>
      <div class="text-xs text-text-muted mt-1" id="lineCount">0 lines</div>
    </div>
    <div>
      <label class="block text-sm font-medium mb-2">Output</label>
      <div class="relative">
        <textarea
          id="outputText"
          readonly
          class="w-full h-56 bg-bg-card border border-border rounded-xl p-3 text-sm font-mono resize-none focus:outline-none"
          placeholder="Result appears here..."
        ></textarea>
        <button id="copyBtn" class="absolute top-2 right-2 text-xs text-primary hover:underline">Copy</button>
      </div>
      <div class="text-xs text-text-muted mt-1" id="outputCount">0 lines</div>
    </div>
  </div>

  <div class="flex flex-wrap gap-2 mb-4">
    <button data-op="sort-asc" class="op-btn px-3 py-1.5 bg-bg-card border border-border rounded-lg text-sm hover:bg-primary/10 hover:border-primary transition-colors">Sort A→Z</button>
    <button data-op="sort-desc" class="op-btn px-3 py-1.5 bg-bg-card border border-border rounded-lg text-sm hover:bg-primary/10 hover:border-primary transition-colors">Sort Z→A</button>
    <button data-op="sort-natural" class="op-btn px-3 py-1.5 bg-bg-card border border-border rounded-lg text-sm hover:bg-primary/10 hover:border-primary transition-colors">Natural Sort</button>
    <button data-op="sort-length" class="op-btn px-3 py-1.5 bg-bg-card border border-border rounded-lg text-sm hover:bg-primary/10 hover:border-primary transition-colors">Sort by Length</button>
    <button data-op="dedup" class="op-btn px-3 py-1.5 bg-bg-card border border-border rounded-lg text-sm hover:bg-primary/10 hover:border-primary transition-colors">Remove Duplicates</button>
    <button data-op="dedup-ci" class="op-btn px-3 py-1.5 bg-bg-card border border-border rounded-lg text-sm hover:bg-primary/10 hover:border-primary transition-colors">Dedup (case-insensitive)</button>
    <button data-op="reverse" class="op-btn px-3 py-1.5 bg-bg-card border border-border rounded-lg text-sm hover:bg-primary/10 hover:border-primary transition-colors">Reverse Lines</button>
    <button data-op="shuffle" class="op-btn px-3 py-1.5 bg-bg-card border border-border rounded-lg text-sm hover:bg-primary/10 hover:border-primary transition-colors">Shuffle</button>
    <button data-op="number" class="op-btn px-3 py-1.5 bg-bg-card border border-border rounded-lg text-sm hover:bg-primary/10 hover:border-primary transition-colors">Number Lines</button>
    <button data-op="trim" class="op-btn px-3 py-1.5 bg-bg-card border border-border rounded-lg text-sm hover:bg-primary/10 hover:border-primary transition-colors">Trim Whitespace</button>
    <button data-op="remove-empty" class="op-btn px-3 py-1.5 bg-bg-card border border-border rounded-lg text-sm hover:bg-primary/10 hover:border-primary transition-colors">Remove Empty Lines</button>
    <button data-op="uppercase" class="op-btn px-3 py-1.5 bg-bg-card border border-border rounded-lg text-sm hover:bg-primary/10 hover:border-primary transition-colors">UPPERCASE</button>
    <button data-op="lowercase" class="op-btn px-3 py-1.5 bg-bg-card border border-border rounded-lg text-sm hover:bg-primary/10 hover:border-primary transition-colors">lowercase</button>
  </div>

  <div class="flex items-center gap-2 mb-6">
    <label class="text-sm font-medium whitespace-nowrap">Filter lines containing:</label>
    <input type="text" id="filterInput" placeholder="keyword..." class="flex-1 bg-bg-card border border-border rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-primary" />
    <button data-op="filter" class="op-btn px-3 py-1.5 bg-bg-card border border-border rounded-lg text-sm hover:bg-primary/10 hover:border-primary transition-colors">Filter</button>
    <button data-op="filter-out" class="op-btn px-3 py-1.5 bg-bg-card border border-border rounded-lg text-sm hover:bg-primary/10 hover:border-primary transition-colors">Exclude</button>
  </div>

  <ToolPageCta />
  <FaqSection faqs={faq} />
</BaseLayout>

<script>
function getLines(): string[] {
  return (document.getElementById('inputText') as HTMLTextAreaElement).value.split('\n');
}

function setOutput(lines: string[]) {
  (document.getElementById('outputText') as HTMLTextAreaElement).value = lines.join('\n');
  (document.getElementById('outputCount') as HTMLElement).textContent = `${lines.length} lines`;
}

document.getElementById('inputText')?.addEventListener('input', () => {
  const lines = getLines();
  (document.getElementById('lineCount') as HTMLElement).textContent = `${lines.length} lines`;
});

document.querySelectorAll('.op-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    let lines = getLines();
    const op = (btn as HTMLElement).dataset.op;
    const filter = (document.getElementById('filterInput') as HTMLInputElement).value;
    switch(op) {
      case 'sort-asc': lines = [...lines].sort((a,b) => a.localeCompare(b)); break;
      case 'sort-desc': lines = [...lines].sort((a,b) => b.localeCompare(a)); break;
      case 'sort-natural': lines = [...lines].sort((a,b) => a.localeCompare(b, undefined, {numeric:true, sensitivity:'base'})); break;
      case 'sort-length': lines = [...lines].sort((a,b) => a.length - b.length); break;
      case 'dedup': { const seen = new Set<string>(); lines = lines.filter(l => { if(seen.has(l)) return false; seen.add(l); return true; }); break; }
      case 'dedup-ci': { const seen = new Set<string>(); lines = lines.filter(l => { const k=l.toLowerCase(); if(seen.has(k)) return false; seen.add(k); return true; }); break; }
      case 'reverse': lines = [...lines].reverse(); break;
      case 'shuffle': { for(let i=lines.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[lines[i],lines[j]]=[lines[j],lines[i]];} break; }
      case 'number': lines = lines.map((l,i) => `${i+1}. ${l}`); break;
      case 'trim': lines = lines.map(l => l.trim()); break;
      case 'remove-empty': lines = lines.filter(l => l.trim() !== ''); break;
      case 'uppercase': lines = lines.map(l => l.toUpperCase()); break;
      case 'lowercase': lines = lines.map(l => l.toLowerCase()); break;
      case 'filter': lines = lines.filter(l => l.toLowerCase().includes(filter.toLowerCase())); break;
      case 'filter-out': lines = lines.filter(l => !l.toLowerCase().includes(filter.toLowerCase())); break;
    }
    setOutput(lines);
  });
});

document.getElementById('copyBtn')?.addEventListener('click', () => {
  const text = (document.getElementById('outputText') as HTMLTextAreaElement).value;
  navigator.clipboard.writeText(text);
  const btn = document.getElementById('copyBtn');
  if (btn) { btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = 'Copy', 2000); }
});
</script>
