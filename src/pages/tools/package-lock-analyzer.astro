---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PackageLockAnalyzer from '../../components/PackageLockAnalyzer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What information does this tool show from package-lock.json?", answer: "The analyzer shows: total package count (direct + transitive), dev-only dependency count, duplicate packages (same package with multiple versions), an estimated bundle size for production dependencies, and a license breakdown across all packages." },
  { question: "What are transitive dependencies?", answer: "Transitive (indirect) dependencies are packages that your direct dependencies depend on — not listed in your package.json but required for them to work. For example, if you install React, it transitively depends on scheduler and js-tokens. These are often the majority of packages in node_modules." },
  { question: "Why do I have duplicate packages?", answer: "Duplicate packages (same package, different versions) appear when two of your dependencies require incompatible versions of the same package. npm installs both versions in separate locations in node_modules. This increases bundle size. Tools like npm dedupe can sometimes flatten these." },
  { question: "What does lockfileVersion mean?", answer: "lockfileVersion indicates the format of your package-lock.json. Version 1 is from npm 5/6. Version 2 is from npm 7 (adds backwards-compatible packages field). Version 3 is the current format (npm 7+ with packages only). This tool supports v1, v2, and v3." },
  { question: "Should I commit package-lock.json?", answer: "Yes — always commit package-lock.json for applications. It ensures every developer and CI run gets exactly the same package versions, preventing 'works on my machine' issues. For libraries (npm packages you publish), you typically omit package-lock.json from the published artifact but still commit it to your repo." },
  { question: "How can I reduce my dependency count?", answer: "Audit large transitive deps with 'npm ls'. Remove unused packages with 'npx depcheck'. Consider replacing heavy packages (moment → date-fns, lodash → native methods). Use 'npm dedupe' to flatten duplicates. Tools like bundlephobia.com show the size cost of each package." },
];
---

<BaseLayout
  title="Package Lock Analyzer — Inspect package-lock.json"
  description="Analyze package-lock.json online. View total dependencies, direct vs transitive breakdown, duplicate package detection, estimated bundle size, and license summary. Paste your lockfile and get instant insights."
  tool="Package Lock Analyzer, package-lock.json, npm dependencies, dependency tree, duplicate packages, npm audit, bundle size"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Package Lock Analyzer</h1>
  <p class="text-text-muted mb-4">Paste your <code class="text-accent font-mono">package-lock.json</code> to get a full dependency breakdown: total packages, direct vs transitive split, duplicate versions, estimated bundle size, and license distribution. Supports lockfile v1, v2, and v3.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Lockfile v1 / v2 / v3</span>
  </div>
  <PackageLockAnalyzer client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Package Lock Analyzer" relatedTags={['npm', 'nodejs', 'dependencies', 'javascript', 'package-management']} />
</BaseLayout>
