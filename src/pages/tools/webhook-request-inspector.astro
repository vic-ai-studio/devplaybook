---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WebhookRequestInspector from '../../components/WebhookRequestInspector.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What can I paste into this tool?", answer: "You can paste either a raw HTTP request (method line + headers + body, as captured from a proxy or network tool) or just a raw JSON payload body. The tool auto-detects which format you're using based on whether the input starts with an HTTP method line or a JSON brace." },
  { question: "How do I capture a raw HTTP webhook request?", answer: "Use a proxy tool like Charles, Proxyman, or mitmproxy to intercept the incoming webhook, then copy the raw request. Alternatively, use a service like webhook.site or requestbin to capture the raw headers and body, then paste them here." },
  { question: "What does the Overview tab show?", answer: "The Overview tab shows a quick summary: HTTP method, header count, body size, content type, and HTTP version. It also highlights any authentication or webhook signature headers (Authorization, X-API-Key, X-Webhook-Signature, X-Hub-Signature) so you can verify they're present." },
  { question: "What is the curl equivalent tab?", answer: "The curl tab generates an equivalent curl command for the request you pasted. This is useful for re-sending the webhook payload manually for testing or debugging — just copy and run it in your terminal." },
  { question: "What's the JSON tree view?", answer: "When the request body is valid JSON, the Body tab shows an interactive tree view where you can expand and collapse nested objects and arrays. This is much easier to read than raw JSON for complex webhook payloads." },
  { question: "Is this data sent to any server?", answer: "No — everything runs in your browser. Your webhook payloads (which often contain sensitive event data) never leave your machine." },
];
---

<BaseLayout
  title="Webhook Request Inspector — Parse & Analyze HTTP Requests & Payloads"
  description="Inspect raw HTTP requests and webhook payloads. Parse headers, body, and method — generate curl commands, detect auth headers, and view JSON tree. Free."
  tool="Webhook Inspector, HTTP Request Parser, Webhook Payload Analyzer, Raw HTTP Parser, curl Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Webhook Request Inspector</h1>
  <p class="text-text-muted mb-4">Paste a <strong>raw HTTP request</strong> or <strong>JSON webhook payload</strong> to inspect it. Parses method, URL, all headers, and body — with an interactive JSON tree view, auth header detection, body size, and an equivalent <strong>curl command</strong>. Everything runs in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Raw HTTP or JSON input</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Interactive JSON tree view</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> curl command generator</span>
  </div>
  <WebhookRequestInspector client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Webhook Request Inspector" relatedTags={['api', 'webhooks', 'http', 'debugging', 'backend', 'json']} />
</BaseLayout>
