---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What are dynamic secrets in Vault and why are they better than static secrets?", answer: "Dynamic secrets are credentials that Vault generates on-demand with a short TTL (time-to-live). Instead of storing a long-lived database password, your application asks Vault for a database credential, Vault creates a new user in your database with the right permissions, returns the credentials, and automatically revokes them when the TTL expires. Benefits: no long-lived credentials to leak, every access is audited, compromised credentials auto-expire, and you can revoke all credentials for a specific lease if you detect a breach. Static secrets (stored passwords) create a single point of failure — one leak means rotating every system that uses that secret." },
  { question: "How does Vault Kubernetes auth work?", answer: "Vault Kubernetes auth lets pods authenticate to Vault using their Kubernetes Service Account Token (SAT). The flow: (1) Vault is configured with the K8s API server's URL and CA cert. (2) You create a Vault role that maps a Kubernetes service account + namespace to Vault policies. (3) A pod mounts its SAT automatically. (4) The app (or Vault Agent sidecar) sends the SAT to Vault's auth/kubernetes/login endpoint. (5) Vault validates the SAT against the K8s API, confirms the pod's service account matches the role binding, and returns a Vault token. No static credentials ever touch the cluster — authentication is based on the pod's identity." },
  { question: "What is the difference between Vault AppRole and Kubernetes auth?", answer: "AppRole is a universal auth method designed for machine-to-machine authentication outside of Kubernetes. It uses a RoleID (not secret, shareable) and SecretID (short-lived, single-use) to authenticate. The bootstrap problem: how does an app get the SecretID securely? This requires a trusted delivery mechanism (CI/CD pipeline secrets, separate bootstrap service). Kubernetes auth eliminates the bootstrap problem for K8s workloads by using the cluster's identity system. Use Kubernetes auth for anything running in Kubernetes. Use AppRole for CI/CD pipelines (GitHub Actions, Jenkins), VMs, and non-K8s services." },
  { question: "How do I handle secret rotation in Vault?", answer: "Vault handles rotation differently by secret type. For dynamic secrets (database, AWS, etc.), rotation is automatic — credentials expire and are regenerated on next request. For static secrets stored in the KV store, use Vault's secret rotation plugins or an external rotation script triggered by a Vault sentinel policy. For the Vault root token and unseal keys, use Vault's rekey operation. For transit secrets (encryption keys), use rotate-key which adds a new key version while keeping the old one for decryption. Most teams also set up Vault Agent with auto-auth on application hosts to cache and renew tokens, so applications never deal with token expiration directly." },
];
---

<BaseLayout
  title="HashiCorp Vault Secrets Management Guide — Dynamic Secrets, Kubernetes Auth"
  description="Complete Vault setup guide: install Vault, configure dynamic database secrets, Kubernetes auth integration, AppRole setup, and secret rotation. Practical examples for production."
  tool="HashiCorp Vault, secrets management, dynamic secrets, Vault Kubernetes auth, AppRole, secret rotation, Vault Agent"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "HashiCorp Vault Secrets Management Guide",
    "url": "https://devplaybook.cc/tools/vault-secrets-management-guide",
    "description": "Practical Vault guide: dynamic secrets for databases, Kubernetes authentication, AppRole setup, and automated secret rotation.",
  })} />

  <h1 class="text-3xl font-bold mb-2">HashiCorp Vault Secrets Management Guide</h1>
  <p class="text-text-muted mb-6">
    Move beyond static credentials with <strong>HashiCorp Vault</strong>. Configure dynamic database secrets, Kubernetes pod authentication, and automatic secret rotation — so your apps never store long-lived credentials.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Dynamic DB secrets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Kubernetes auth</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> AppRole setup</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Secret rotation</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Install Vault (Dev / Production)</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Install via package manager
brew tap hashicorp/tap &amp;&amp; brew install hashicorp/tap/vault   # macOS
sudo apt install vault                                        # Ubuntu/Debian

# Start in dev mode (in-memory, auto-unsealed, root token = root)
vault server -dev -dev-root-token-id="root"

# Production: start with config file
vault server -config=/etc/vault/vault.hcl

# /etc/vault/vault.hcl (minimal production config)
# storage "raft" &#123;
#   path    = "/opt/vault/data"
#   node_id = "vault-1"
# &#125;
# listener "tcp" &#123;
#   address     = "0.0.0.0:8200"
#   tls_cert_file = "/etc/vault/tls/vault.crt"
#   tls_key_file  = "/etc/vault/tls/vault.key"
# &#125;
# api_addr = "https://vault.example.com:8200"
# cluster_addr = "https://vault.example.com:8201"
# ui = true

export VAULT_ADDR='http://127.0.0.1:8200'
export VAULT_TOKEN='root'
vault status</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Dynamic Database Secrets</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Enable the database secrets engine
vault secrets enable database

# Configure PostgreSQL connection
vault write database/config/my-postgres \
  plugin_name=postgresql-database-plugin \
  allowed_roles="app-role" \
  connection_url="postgresql://&#123;&#123;username&#125;&#125;:&#123;&#123;password&#125;&#125;@postgres.example.com:5432/appdb" \
  username="vault-superuser" \
  password="superuser-password"

# Create a role with a creation SQL statement
vault write database/roles/app-role \
  db_name=my-postgres \
  creation_statements="CREATE ROLE \"&#123;&#123;name&#125;&#125;\" WITH LOGIN PASSWORD '&#123;&#123;password&#125;&#125;' VALID UNTIL '&#123;&#123;expiration&#125;&#125;'; GRANT SELECT, INSERT, UPDATE ON ALL TABLES IN SCHEMA public TO \"&#123;&#123;name&#125;&#125;\";" \
  default_ttl="1h" \
  max_ttl="24h"

# Generate dynamic credentials (app calls this at startup)
vault read database/creds/app-role

# Response:
# Key                Value
# ---                -----
# lease_id           database/creds/app-role/AbCdEf123456
# lease_duration     1h
# lease_renewable    true
# password           A1a-xxxxxxxxxxxxxxxx
# username           v-root-app-role-yyyyyyyyyyy</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Kubernetes Auth Integration</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Enable Kubernetes auth method
vault auth enable kubernetes

# Configure with the cluster's API server
vault write auth/kubernetes/config \
  kubernetes_host="https://kubernetes.default.svc" \
  kubernetes_ca_cert=@/var/run/secrets/kubernetes.io/serviceaccount/ca.crt \
  token_reviewer_jwt=@/var/run/secrets/kubernetes.io/serviceaccount/token

# Create a policy for the app
vault policy write app-policy - &lt;&lt;EOF
path "database/creds/app-role" &#123;
  capabilities = ["read"]
&#125;
path "secret/data/app/*" &#123;
  capabilities = ["read"]
&#125;
EOF

# Bind the policy to a Kubernetes service account
vault write auth/kubernetes/role/my-app \
  bound_service_account_names=my-app-sa \
  bound_service_account_namespaces=production \
  policies=app-policy \
  ttl=1h

# In Kubernetes: the app logs in using its mounted SAT
curl -s --request POST \
  --data "&#123;\"jwt\": \"$(cat /var/run/secrets/kubernetes.io/serviceaccount/token)\", \"role\": \"my-app\"&#125;" \
  $VAULT_ADDR/v1/auth/kubernetes/login | jq '.auth.client_token'</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">AppRole Authentication</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Enable AppRole auth
vault auth enable approle

# Create AppRole with bound policies
vault write auth/approle/role/ci-pipeline \
  secret_id_ttl=10m \
  token_num_uses=10 \
  token_ttl=20m \
  token_max_ttl=30m \
  secret_id_num_uses=1 \
  policies=deploy-policy

# Get the RoleID (not secret, can be in config)
vault read auth/approle/role/ci-pipeline/role-id
# role_id: 675a50e7-cfe0-be9a-7a5a-c1d19af7b7c9

# Get a SecretID (secret, single-use, short-lived)
vault write -f auth/approle/role/ci-pipeline/secret-id
# secret_id: ed0a642f-2acf-c2da-232f-1b21300d5f29

# Login with RoleID + SecretID
vault write auth/approle/login \
  role_id="675a50e7-cfe0-be9a-7a5a-c1d19af7b7c9" \
  secret_id="ed0a642f-2acf-c2da-232f-1b21300d5f29"</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Vault Agent — Auto-Auth Sidecar</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># vault-agent-config.hcl
vault &#123;
  address = "https://vault.example.com:8200"
&#125;

auto_auth &#123;
  method "kubernetes" &#123;
    mount_path = "auth/kubernetes"
    config &#123;
      role = "my-app"
    &#125;
  &#125;

  sink "file" &#123;
    config &#123;
      path = "/vault-token"
    &#125;
  &#125;
&#125;

template &#123;
  source      = "/etc/vault-templates/db-config.ctmpl"
  destination = "/app/config/database.yml"
  command     = "kill -HUP $(cat /app/pids/app.pid)"  # reload app on change
&#125;</pre>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="vault-secrets-management-guide" relatedTags={["vault", "security", "kubernetes", "devops", "secrets-management", "devsecops"]} />
</BaseLayout>
