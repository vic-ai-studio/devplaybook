---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShellScriptLinter from '../../components/ShellScriptLinter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What issues does this linter detect?", answer: "The linter catches common Bash/shell script problems including: unquoted variables (word splitting/globbing risk), use of backticks instead of $(), ls used for file listing (unsafe), useless cat (UUOC), missing set -e/-u at the top, rm -rf without guards, == vs = in [ ] tests, and function keyword portability issues." },
  { question: "What is SC2086 and why does it matter?", answer: "SC2086 is the ShellCheck rule for unquoted variables. When you write $var instead of \"$var\", the shell performs word splitting and glob expansion on the value. This means a variable containing spaces or wildcards can break your command in unexpected ways. Always quote: echo \"$filename\" not echo $filename." },
  { question: "Why should I use $() instead of backticks?", answer: "Backtick command substitution (`cmd`) is harder to read, can't be nested easily, and has different escaping rules. The $() form is cleaner, nestable ($(outer $(inner))), and universally supported in modern shells. ShellCheck labels this SC2006." },
  { question: "What does 'set -euo pipefail' do?", answer: "-e makes the script exit immediately if any command fails. -u treats unset variables as errors. -o pipefail makes pipelines fail if any command in the pipe fails (not just the last one). Together, these three options turn your script into a much safer, fail-fast mode that catches bugs earlier." },
  { question: "When should I use [[ ]] vs [ ] in Bash?", answer: "In Bash, prefer [[ ]] over [ ] for conditionals. Double brackets support == for string comparison, && and || inside the test, regex matching with =~, and don't require quoting in most cases. Single brackets [ ] follow POSIX rules: use = not ==, and always quote variables." },
  { question: "Why is 'ls | grep' considered bad practice?", answer: "ls output is not designed for programmatic parsing. Filenames can contain newlines, spaces, or special characters that break ls output. Use find with -name for filtering: find . -name '*.log'. This safely handles all filename edge cases." },
];
---

<BaseLayout
  title="Shell Script Linter — Online Bash & sh Linter"
  description="Lint Bash and shell scripts online. Detects unquoted variables, missing error handling, deprecated syntax, unsafe patterns, and portability issues. Shows line-by-line annotations with fix suggestions. Free, runs in your browser."
  tool="Shell Script Linter, Bash Linter, ShellCheck Online, sh Linter, Bash Script Validator, Shell Script Checker"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Shell Script Linter</h1>
  <p class="text-text-muted mb-4">Paste a Bash, sh, or zsh script to check for common errors and bad practices. Detects unquoted variables, unsafe patterns, missing <code class="text-accent font-mono">set -e</code>, useless cat, and more — with line annotations and fix suggestions.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> ShellCheck-style rules</span>
  </div>
  <ShellScriptLinter client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Shell Script Linter" relatedTags={['bash', 'shell', 'linux', 'devops', 'scripting', 'automation']} />
</BaseLayout>
