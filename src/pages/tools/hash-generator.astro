---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HashGenerator from '../../components/HashGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a hash and what is it used for?", answer: "A hash is a fixed-length string generated from input data using a mathematical algorithm. Hashes are used for verifying file integrity (checksums), storing passwords securely, digital signatures, and data deduplication. The same input always produces the same hash." },
  { question: "What is the difference between MD5, SHA-1, and SHA-256?", answer: "MD5 produces a 128-bit hash — fast but no longer secure for cryptographic use. SHA-1 produces a 160-bit hash — also considered weak. SHA-256 produces a 256-bit hash and is the current standard for security applications, used in TLS certificates, Bitcoin, and password hashing." },
  { question: "Can you reverse a hash back to the original text?", answer: "No. Hash functions are one-way — by design, you cannot derive the original input from a hash. However, common short strings can be found via rainbow tables or brute force, which is why passwords should use salted hashing algorithms like bcrypt or Argon2." },
  { question: "Is MD5 still safe to use?", answer: "MD5 is not safe for security purposes (digital signatures, certificates, password hashing) because collision attacks are practical. However, MD5 is still acceptable for non-security uses like checksums, cache keys, and data deduplication where collision resistance isn't critical." },
];
---

<BaseLayout
  title="Hash Generator — MD5, SHA-256, SHA-512 — Free Online Tool"
  description="Generate MD5, SHA-1, SHA-256, and SHA-512 cryptographic hashes from any text instantly. Use for file integrity verification, checksum comparison, password hashing research, and data deduplication. All hashing runs in-browser using the Web Crypto API — no data sent to servers. Free, instant, no signup required."
  tool="MD5 Generator, SHA-256 Hash, SHA-512 Hash, Hash Generator Online"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Hash Generator</h1>
  <p class="text-text-muted mb-4">Generate MD5, SHA-1, SHA-256, and SHA-512 hashes instantly. Useful for verifying file integrity, checksums, and password hashing research. Runs entirely in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <HashGenerator client:only="preact" />
  <!-- Real-World Use Cases -->
  <section class="mt-12 mb-8">
    <h2 class="text-2xl font-bold mb-6">Real-World Use Cases</h2>

    <div class="space-y-6">
      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">1. Verifying a Downloaded File's Integrity</h3>
        <p class="text-text-muted mb-3">You downloaded a binary from GitHub and the release page lists a SHA-256 checksum. Paste the file contents (or use the text representation) to generate the hash and compare it — if they match, the file hasn't been tampered with.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Input Text</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">Hello, World!</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">SHA-256 Output</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">dffd6021bb2bd5b0af676290809ec3a5{"\n"}3191dd81c7f70a4b28688a362182986f</pre>
          </div>
        </div>
      </div>

      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">2. Generating Cache-Busting Keys</h3>
        <p class="text-text-muted mb-3">Your CDN uses content hashes to bust browser caches. Hash your CSS or JS content to generate a unique key — when the content changes, the hash changes and the CDN serves the new version.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Input (CSS snippet)</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">body {"{"} font-family: Inter; {"}"}</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">MD5 (short, ideal for cache keys)</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">a7f3d8c1e9b24056f1a2b3c4d5e6f7a8{"\n"}{"\n"}→ Use as: style.a7f3d8c1.css</pre>
          </div>
        </div>
      </div>

      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">3. Comparing API Webhook Signatures</h3>
        <p class="text-text-muted mb-3">Services like Stripe and GitHub sign webhooks with HMAC-SHA256. Hash the request body with the signing secret and compare it with the <code class="font-mono text-sm bg-bg-card px-1 rounded">X-Signature</code> header to verify the webhook is authentic.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Webhook Body</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{"{"}"event": "payment.success", "amount": 2999{"}"}</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">SHA-256 Hash</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">e4d909c290d0fb1ca068ffaddf22cbd0{"\n"}...compare with X-Signature header</pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Step-by-Step Guide -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">How to Use — Step by Step</h2>
    <ol class="list-decimal list-inside space-y-3 text-text-muted">
      <li><strong>Enter or paste text</strong> — Type your text or paste content into the input field. The tool hashes it instantly as you type.</li>
      <li><strong>View all hash formats</strong> — MD5, SHA-1, SHA-256, and SHA-512 hashes are generated simultaneously so you can compare formats at a glance.</li>
      <li><strong>Copy the hash you need</strong> — Click the copy button next to the hash format required by your use case (SHA-256 for security, MD5 for cache keys).</li>
      <li><strong>Compare checksums</strong> — Paste an expected hash alongside the generated one. If they match character-for-character, the data is identical.</li>
      <li><strong>Stay secure</strong> — Remember: for password storage, always use bcrypt or Argon2 with salting — never raw SHA-256 or MD5.</li>
    </ol>
  </section>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Hash Generator" relatedTags={['security', 'hashing', 'checksum', 'encryption', 'password']} />
</BaseLayout>
