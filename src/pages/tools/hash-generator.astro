---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HashGenerator from '../../components/HashGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a hash and what is it used for?", answer: "A hash is a fixed-length string generated from input data using a mathematical algorithm. Hashes are used for verifying file integrity (checksums), storing passwords securely, digital signatures, and data deduplication. The same input always produces the same hash." },
  { question: "What is the difference between MD5, SHA-1, and SHA-256?", answer: "MD5 produces a 128-bit hash — fast but no longer secure for cryptographic use. SHA-1 produces a 160-bit hash — also considered weak. SHA-256 produces a 256-bit hash and is the current standard for security applications, used in TLS certificates, Bitcoin, and password hashing." },
  { question: "Can you reverse a hash back to the original text?", answer: "No. Hash functions are one-way — by design, you cannot derive the original input from a hash. However, common short strings can be found via rainbow tables or brute force, which is why passwords should use salted hashing algorithms like bcrypt or Argon2." },
  { question: "Is MD5 still safe to use?", answer: "MD5 is not safe for security purposes (digital signatures, certificates, password hashing) because collision attacks are practical. However, MD5 is still acceptable for non-security uses like checksums, cache keys, and data deduplication where collision resistance isn't critical." },
];
---

<BaseLayout
  title="Hash Generator — MD5, SHA-256, SHA-512 — Free Online Tool"
  description="Generate MD5, SHA-1, SHA-256, and SHA-512 cryptographic hashes from any text. All hashing is done in-browser with no data sent to servers. Free, instant, no signup."
  tool="MD5 Generator, SHA-256 Hash, SHA-512 Hash, Hash Generator Online"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Hash Generator</h1>
  <p class="text-text-muted mb-8">Generate MD5, SHA-1, SHA-256, and SHA-512 hashes instantly. Useful for verifying file integrity, checksums, and password hashing research. Runs entirely in your browser.</p>
  <HashGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Hash Generator" relatedTags={['security', 'hashing', 'checksum', 'encryption', 'password']} />
</BaseLayout>
