---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Azure Bicep Template Generator — Storage, App Service, Key Vault & More"
  description="Generate Azure Bicep templates for common resources. Select resource type (VM, Storage Account, App Service, Key Vault, VNet), configure parameters, and get production-ready Bicep code. Runs in your browser."
  tool="Azure Bicep generator, Azure IaC, Bicep template, Azure Storage Account Bicep, Azure App Service Bicep, Azure Key Vault Bicep, Azure VNet Bicep, ARM template alternative"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Azure Bicep Template Generator",
    "url": "https://devplaybook.cc/tools/azure-bicep-generator",
    "description": "Generate Azure Bicep templates for Storage Accounts, App Service Plans, Web Apps, Key Vaults, Virtual Networks, and SQL Servers. Production-ready code, runs in browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Azure Bicep Template Generator</h1>
  <p class="text-text-muted mb-4">Generate production-ready Azure Bicep templates for common resources. Select a resource type, configure the key parameters, and copy the complete Bicep module.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 6 resource types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Param declarations + resource block</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy to clipboard</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs entirely in your browser</span>
  </div>

  <!-- Resource Type -->
  <div class="mb-5">
    <label class="block text-sm font-medium mb-2">Resource Type</label>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
      <button class="res-type-btn px-3 py-2.5 rounded-lg text-sm font-medium border transition-colors border-primary bg-primary/10 text-primary text-left" data-type="storage">Storage Account</button>
      <button class="res-type-btn px-3 py-2.5 rounded-lg text-sm font-medium border transition-colors border-border text-text-muted hover:border-primary text-left" data-type="appserviceplan">App Service Plan</button>
      <button class="res-type-btn px-3 py-2.5 rounded-lg text-sm font-medium border transition-colors border-border text-text-muted hover:border-primary text-left" data-type="webapp">Web App</button>
      <button class="res-type-btn px-3 py-2.5 rounded-lg text-sm font-medium border transition-colors border-border text-text-muted hover:border-primary text-left" data-type="keyvault">Key Vault</button>
      <button class="res-type-btn px-3 py-2.5 rounded-lg text-sm font-medium border transition-colors border-border text-text-muted hover:border-primary text-left" data-type="vnet">Virtual Network</button>
      <button class="res-type-btn px-3 py-2.5 rounded-lg text-sm font-medium border transition-colors border-border text-text-muted hover:border-primary text-left" data-type="sqlserver">SQL Server</button>
    </div>
  </div>

  <!-- Common params -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
    <div>
      <label class="block text-sm font-medium mb-2">Resource Name / Param</label>
      <input id="b-name" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="myStorageAccount" value="myStorageAccount" />
    </div>
    <div>
      <label class="block text-sm font-medium mb-2">Location</label>
      <select id="b-location" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
        <option value="eastus">East US</option>
        <option value="westus2">West US 2</option>
        <option value="eastus2">East US 2</option>
        <option value="centralus">Central US</option>
        <option value="westeurope">West Europe</option>
        <option value="northeurope">North Europe</option>
        <option value="uksouth">UK South</option>
        <option value="southeastasia">Southeast Asia</option>
        <option value="japaneast">Japan East</option>
        <option value="australiaeast">Australia East</option>
      </select>
    </div>
  </div>

  <!-- Dynamic params section -->
  <div id="dynamic-params" class="mb-5"></div>

  <!-- Tags -->
  <div class="mb-5">
    <label class="block text-sm font-medium mb-2">Tags (key=value, comma-separated)</label>
    <input id="b-tags" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary" placeholder="environment=production, team=platform" value="environment=production" />
  </div>

  <div class="flex gap-3 mb-6 flex-wrap">
    <button id="btn-generate" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Generate Bicep</button>
    <button id="btn-clear" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Clear</button>
  </div>

  <!-- Output -->
  <div id="output-section" class="hidden">
    <h2 class="text-lg font-semibold mb-3">Generated Bicep Template</h2>
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <div class="flex items-center justify-between mb-3">
        <span id="output-filename" class="text-xs text-text-muted font-mono"></span>
        <button id="btn-copy" class="px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">Copy</button>
      </div>
      <pre id="bicep-output" class="font-mono text-sm whitespace-pre-wrap break-words text-blue-300 overflow-x-auto max-h-[600px] overflow-y-auto"></pre>
    </div>
    <div class="mt-4 p-4 bg-bg-card border border-border rounded-lg">
      <h3 class="text-sm font-semibold mb-2">Deploy Command</h3>
      <pre id="deploy-cmd" class="font-mono text-xs whitespace-pre-wrap text-green-300"></pre>
      <button id="btn-copy-cmd" class="mt-2 px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">Copy Command</button>
    </div>
  </div>

  <ToolPageCta />
</BaseLayout>

<script>
let currentType = 'storage';

const RESOURCE_CONFIGS = {
  storage: {
    paramName: 'myStorageAccount',
    filename: 'storage-account.bicep',
    extraParams: [
      { id: 'sku', label: 'SKU', type: 'select', options: ['Standard_LRS','Standard_GRS','Standard_RAGRS','Premium_LRS'], default: 'Standard_LRS' },
      { id: 'kind', label: 'Kind', type: 'select', options: ['StorageV2','BlobStorage','BlockBlobStorage','FileStorage'], default: 'StorageV2' },
      { id: 'accessTier', label: 'Access Tier', type: 'select', options: ['Hot','Cool'], default: 'Hot' },
      { id: 'httpsOnly', label: 'HTTPS Only', type: 'select', options: ['true','false'], default: 'true' },
    ]
  },
  appserviceplan: {
    paramName: 'myAppServicePlan',
    filename: 'app-service-plan.bicep',
    extraParams: [
      { id: 'skuName', label: 'SKU Name', type: 'select', options: ['F1','B1','B2','B3','S1','S2','S3','P1v3','P2v3','P3v3'], default: 'B1' },
      { id: 'skuTier', label: 'SKU Tier', type: 'select', options: ['Free','Shared','Basic','Standard','PremiumV3'], default: 'Basic' },
      { id: 'os', label: 'OS', type: 'select', options: ['linux','windows'], default: 'linux' },
      { id: 'capacity', label: 'Instances', type: 'text', default: '1', placeholder: '1' },
    ]
  },
  webapp: {
    paramName: 'myWebApp',
    filename: 'web-app.bicep',
    extraParams: [
      { id: 'serverFarmId', label: 'App Service Plan Resource ID', type: 'text', default: '', placeholder: '/subscriptions/.../resourceGroups/.../providers/Microsoft.Web/serverfarms/myplan' },
      { id: 'runtime', label: 'Runtime Stack', type: 'select', options: ['NODE|20-lts','NODE|18-lts','PYTHON|3.12','PYTHON|3.11','DOTNETCORE|8.0','JAVA|17','PHP|8.2'], default: 'NODE|20-lts' },
      { id: 'alwaysOn', label: 'Always On', type: 'select', options: ['true','false'], default: 'true' },
      { id: 'httpsOnly', label: 'HTTPS Only', type: 'select', options: ['true','false'], default: 'true' },
    ]
  },
  keyvault: {
    paramName: 'myKeyVault',
    filename: 'key-vault.bicep',
    extraParams: [
      { id: 'tenantId', label: 'Tenant ID', type: 'text', default: '', placeholder: 'xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx' },
      { id: 'sku', label: 'SKU', type: 'select', options: ['standard','premium'], default: 'standard' },
      { id: 'softDelete', label: 'Soft Delete Days', type: 'text', default: '90', placeholder: '90' },
      { id: 'purgeProtection', label: 'Purge Protection', type: 'select', options: ['true','false'], default: 'true' },
    ]
  },
  vnet: {
    paramName: 'myVirtualNetwork',
    filename: 'virtual-network.bicep',
    extraParams: [
      { id: 'addressPrefix', label: 'Address Space', type: 'text', default: '10.0.0.0/16', placeholder: '10.0.0.0/16' },
      { id: 'subnet1Name', label: 'Subnet 1 Name', type: 'text', default: 'default', placeholder: 'default' },
      { id: 'subnet1Prefix', label: 'Subnet 1 Prefix', type: 'text', default: '10.0.1.0/24', placeholder: '10.0.1.0/24' },
      { id: 'subnet2Name', label: 'Subnet 2 Name (optional)', type: 'text', default: '', placeholder: 'private' },
    ]
  },
  sqlserver: {
    paramName: 'mySqlServer',
    filename: 'sql-server.bicep',
    extraParams: [
      { id: 'adminLogin', label: 'Admin Login', type: 'text', default: 'sqladmin', placeholder: 'sqladmin' },
      { id: 'dbName', label: 'Database Name', type: 'text', default: 'mydb', placeholder: 'mydb' },
      { id: 'dbSku', label: 'Database SKU', type: 'select', options: ['Basic','S0','S1','S2','GP_S_Gen5_1','GP_Gen5_2'], default: 'S0' },
      { id: 'tlsVersion', label: 'Min TLS Version', type: 'select', options: ['1.0','1.1','1.2'], default: '1.2' },
    ]
  }
};

function switchType(type) {
  currentType = type;
  const config = RESOURCE_CONFIGS[type];
  document.querySelectorAll('.res-type-btn').forEach(b => {
    const active = b.dataset.type === type;
    b.classList.toggle('border-primary', active);
    b.classList.toggle('bg-primary/10', active);
    b.classList.toggle('text-primary', active);
    b.classList.toggle('border-border', !active);
    b.classList.toggle('text-text-muted', !active);
  });
  // Update name field default
  const nameEl = document.getElementById('b-name');
  if (nameEl) nameEl.value = config.paramName;
  renderDynamicParams(config);
}

function renderDynamicParams(config) {
  const container = document.getElementById('dynamic-params');
  if (!container) return;
  container.innerHTML = '';
  if (!config.extraParams || config.extraParams.length === 0) return;
  const grid = document.createElement('div');
  grid.className = 'grid grid-cols-1 sm:grid-cols-2 gap-4';
  config.extraParams.forEach(p => {
    const div = document.createElement('div');
    div.innerHTML = `<label class="block text-sm font-medium mb-2">${p.label}</label>`;
    if (p.type === 'select') {
      const sel = document.createElement('select');
      sel.id = `dp-${p.id}`;
      sel.className = 'w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary';
      p.options.forEach(o => {
        const opt = document.createElement('option');
        opt.value = o; opt.textContent = o;
        if (o === p.default) opt.selected = true;
        sel.appendChild(opt);
      });
      div.appendChild(sel);
    } else {
      const inp = document.createElement('input');
      inp.type = 'text'; inp.id = `dp-${p.id}`;
      inp.className = 'w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary';
      inp.value = p.default || '';
      inp.placeholder = p.placeholder || '';
      div.appendChild(inp);
    }
    grid.appendChild(div);
  });
  container.appendChild(grid);
}

document.querySelectorAll('.res-type-btn').forEach(b => b.addEventListener('click', () => switchType(b.dataset.type)));

function getParam(id) {
  return (document.getElementById(`dp-${id}`)?.value || '').trim();
}

function parseTags(raw) {
  const obj = {};
  raw.split(',').map(s => s.trim()).filter(Boolean).forEach(kv => {
    const eq = kv.indexOf('=');
    if (eq > 0) { obj[kv.slice(0,eq).trim()] = kv.slice(eq+1).trim(); }
  });
  return obj;
}

function tagsToHcl(tags) {
  const entries = Object.entries(tags);
  if (entries.length === 0) return '{}';
  const inner = entries.map(([k,v]) => `  ${k}: '${v}'`).join('\n');
  return `{\n${inner}\n}`;
}

function generate() {
  const name = (document.getElementById('b-name')?.value || '').trim() || 'myResource';
  const location = document.getElementById('b-location')?.value || 'eastus';
  const tagsRaw = (document.getElementById('b-tags')?.value || '').trim();
  const tags = parseTags(tagsRaw);
  const tagsHcl = tagsToHcl(tags);
  let bicep = '';
  let filename = RESOURCE_CONFIGS[currentType]?.filename || 'main.bicep';

  const header = `targetScope = 'resourceGroup'\n\nparam ${currentType}Name string = '${name}'\nparam location string = '${location}'\n`;
  const tagParam = `param tags object = ${tagsHcl}\n\n`;

  if (currentType === 'storage') {
    const sku = getParam('sku') || 'Standard_LRS';
    const kind = getParam('kind') || 'StorageV2';
    const accessTier = getParam('accessTier') || 'Hot';
    const httpsOnly = getParam('httpsOnly') !== 'false';
    bicep = `${header}param storageSkuName string = '${sku}'\nparam storageKind string = '${kind}'\nparam accessTier string = '${accessTier}'\n${tagParam}resource storageAccount 'Microsoft.Storage/storageAccounts@2023-01-01' = {
  name: ${currentType}Name
  location: location
  tags: tags
  sku: {
    name: storageSkuName
  }
  kind: storageKind
  properties: {
    accessTier: accessTier
    supportsHttpsTrafficOnly: ${httpsOnly}
    minimumTlsVersion: 'TLS1_2'
    allowBlobPublicAccess: false
    networkAcls: {
      defaultAction: 'Allow'
      bypass: 'AzureServices'
    }
  }
}

output storageAccountId string = storageAccount.id
output storageAccountName string = storageAccount.name
output primaryEndpoint string = storageAccount.properties.primaryEndpoints.blob
`;
  } else if (currentType === 'appserviceplan') {
    const skuName = getParam('skuName') || 'B1';
    const skuTier = getParam('skuTier') || 'Basic';
    const os = getParam('os') || 'linux';
    const capacity = getParam('capacity') || '1';
    bicep = `${header}param skuName string = '${skuName}'\nparam skuTier string = '${skuTier}'\nparam capacity int = ${capacity}\n${tagParam}resource appServicePlan 'Microsoft.Web/serverfarms@2023-01-01' = {
  name: ${currentType}Name
  location: location
  tags: tags
  sku: {
    name: skuName
    tier: skuTier
    capacity: capacity
  }
  kind: '${os === 'linux' ? 'linux' : 'app'}'
  properties: {
    reserved: ${os === 'linux'}
  }
}

output appServicePlanId string = appServicePlan.id
output appServicePlanName string = appServicePlan.name
`;
  } else if (currentType === 'webapp') {
    const serverFarmId = getParam('serverFarmId') || 'SERVER_FARM_RESOURCE_ID';
    const runtime = getParam('runtime') || 'NODE|20-lts';
    const alwaysOn = getParam('alwaysOn') !== 'false';
    const httpsOnly = getParam('httpsOnly') !== 'false';
    bicep = `${header}param serverFarmId string = '${serverFarmId}'\nparam linuxFxVersion string = '${runtime}'\n${tagParam}resource webApp 'Microsoft.Web/sites@2023-01-01' = {
  name: ${currentType}Name
  location: location
  tags: tags
  kind: 'app,linux'
  properties: {
    serverFarmId: serverFarmId
    httpsOnly: ${httpsOnly}
    siteConfig: {
      linuxFxVersion: linuxFxVersion
      alwaysOn: ${alwaysOn}
      minTlsVersion: '1.2'
      ftpsState: 'Disabled'
      http20Enabled: true
      appSettings: []
    }
  }
}

output webAppId string = webApp.id
output webAppName string = webApp.name
output defaultHostname string = webApp.properties.defaultHostName
`;
  } else if (currentType === 'keyvault') {
    const tenantId = getParam('tenantId') || 'TENANT_ID';
    const sku = getParam('sku') || 'standard';
    const softDelete = getParam('softDelete') || '90';
    const purge = getParam('purgeProtection') !== 'false';
    bicep = `${header}param tenantId string = '${tenantId}'\nparam skuName string = '${sku}'\nparam softDeleteRetentionInDays int = ${softDelete}\n${tagParam}resource keyVault 'Microsoft.KeyVault/vaults@2023-02-01' = {
  name: ${currentType}Name
  location: location
  tags: tags
  properties: {
    tenantId: tenantId
    sku: {
      family: 'A'
      name: skuName
    }
    enabledForDeployment: false
    enabledForDiskEncryption: false
    enabledForTemplateDeployment: true
    enableSoftDelete: true
    softDeleteRetentionInDays: softDeleteRetentionInDays
    enablePurgeProtection: ${purge}
    enableRbacAuthorization: true
    networkAcls: {
      defaultAction: 'Allow'
      bypass: 'AzureServices'
    }
  }
}

output keyVaultId string = keyVault.id
output keyVaultUri string = keyVault.properties.vaultUri
`;
  } else if (currentType === 'vnet') {
    const addrPrefix = getParam('addressPrefix') || '10.0.0.0/16';
    const sub1Name = getParam('subnet1Name') || 'default';
    const sub1Prefix = getParam('subnet1Prefix') || '10.0.1.0/24';
    const sub2Name = (getParam('subnet2Name') || '').trim();
    const sub2Block = sub2Name ? `    {\n      name: '${sub2Name}'\n      properties: {\n        addressPrefix: '10.0.2.0/24'\n      }\n    }` : '';
    bicep = `${header}param addressPrefix string = '${addrPrefix}'\nparam subnet1Name string = '${sub1Name}'\nparam subnet1Prefix string = '${sub1Prefix}'\n${tagParam}resource virtualNetwork 'Microsoft.Network/virtualNetworks@2023-06-01' = {
  name: ${currentType}Name
  location: location
  tags: tags
  properties: {
    addressSpace: {
      addressPrefixes: [
        addressPrefix
      ]
    }
    subnets: [
      {
        name: subnet1Name
        properties: {
          addressPrefix: subnet1Prefix
          privateEndpointNetworkPolicies: 'Disabled'
        }
      }${sub2Block ? '\n' + sub2Block : ''}
    ]
  }
}

output vnetId string = virtualNetwork.id
output vnetName string = virtualNetwork.name
output subnetIds array = [for subnet in virtualNetwork.properties.subnets: subnet.id]
`;
  } else if (currentType === 'sqlserver') {
    const adminLogin = getParam('adminLogin') || 'sqladmin';
    const dbName = getParam('dbName') || 'mydb';
    const dbSku = getParam('dbSku') || 'S0';
    const tls = getParam('tlsVersion') || '1.2';
    bicep = `${header}@secure()\nparam adminPassword string\nparam adminLogin string = '${adminLogin}'\nparam databaseName string = '${dbName}'\nparam databaseSku string = '${dbSku}'\n${tagParam}resource sqlServer 'Microsoft.Sql/servers@2023-05-01-preview' = {
  name: ${currentType}Name
  location: location
  tags: tags
  properties: {
    administratorLogin: adminLogin
    administratorLoginPassword: adminPassword
    minimalTlsVersion: '${tls}'
    publicNetworkAccess: 'Enabled'
  }
}

resource sqlDatabase 'Microsoft.Sql/servers/databases@2023-05-01-preview' = {
  parent: sqlServer
  name: databaseName
  location: location
  tags: tags
  sku: {
    name: databaseSku
  }
  properties: {
    collation: 'SQL_Latin1_General_CP1_CI_AS'
    maxSizeBytes: 2147483648
  }
}

output serverId string = sqlServer.id
output serverFqdn string = sqlServer.properties.fullyQualifiedDomainName
output databaseId string = sqlDatabase.id
`;
  }

  document.getElementById('bicep-output').textContent = bicep;
  document.getElementById('output-filename').textContent = filename;

  const deployCmd = `az deployment group create \\
  --resource-group <your-resource-group> \\
  --template-file ${filename} \\
  --parameters ${currentType}Name='${name}' location='${location}'`;
  document.getElementById('deploy-cmd').textContent = deployCmd;
  document.getElementById('output-section').classList.remove('hidden');
  setTimeout(() => document.getElementById('output-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
}

document.getElementById('btn-generate')?.addEventListener('click', generate);
document.getElementById('btn-clear')?.addEventListener('click', () => {
  document.getElementById('b-tags').value = 'environment=production';
  document.getElementById('output-section').classList.add('hidden');
  switchType(currentType);
});

document.getElementById('btn-copy')?.addEventListener('click', () => {
  const el = document.getElementById('bicep-output');
  if (!el) return;
  navigator.clipboard.writeText(el.textContent).then(() => {
    const b = document.getElementById('btn-copy');
    b.textContent = 'Copied!';
    setTimeout(() => b.textContent = 'Copy', 2000);
  });
});
document.getElementById('btn-copy-cmd')?.addEventListener('click', () => {
  const el = document.getElementById('deploy-cmd');
  if (!el) return;
  navigator.clipboard.writeText(el.textContent).then(() => {
    const b = document.getElementById('btn-copy-cmd');
    b.textContent = 'Copied!';
    setTimeout(() => b.textContent = 'Copy Command', 2000);
  });
});

// Init
switchType('storage');
</script>
