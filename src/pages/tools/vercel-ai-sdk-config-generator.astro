---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the Vercel AI SDK?", answer: "The Vercel AI SDK (ai package) is a TypeScript toolkit for building AI-powered applications with React, Next.js, Svelte, Vue, and Node.js. It provides useChat and useCompletion hooks for the frontend, and streamText/generateText/generateObject on the backend. It supports 20+ model providers through a unified interface." },
  { question: "What is the difference between useChat and useCompletion?", answer: "useChat manages multi-turn conversations with a messages array, handling the back-and-forth dialog history. useCompletion is for single-turn prompt → response flows. Use useChat for chatbots and agents; use useCompletion for text transformation, summarization, and single-shot generation tasks." },
  { question: "How does streaming work with Vercel AI SDK?", answer: "The SDK uses the Web Streams API. On the backend, return a StreamingTextResponse with a ReadableStream. On the frontend, useChat/useCompletion automatically handle incremental updates — no manual stream parsing needed. The useChat hook updates the messages array in real-time as chunks arrive." },
  { question: "Which providers does Vercel AI SDK support?", answer: "Core providers: OpenAI, Anthropic, Google Gemini, Mistral, Cohere, Hugging Face, AWS Bedrock, Azure OpenAI, and more via community providers. Switch providers by changing the model import — the API stays the same. This makes it easy to A/B test models or swap providers without rewriting your app." },
  { question: "How do I use generateObject for structured output?", answer: "Use generateObject with a Zod schema to get type-safe structured responses. The SDK automatically handles JSON mode or tool-based extraction depending on the model. Perfect for extracting data, generating forms, or any task needing predictable JSON output structure." },
];
---

<BaseLayout
  title="Vercel AI SDK Config Generator — Generate useChat & useCompletion Configurations"
  description="Generate Vercel AI SDK useChat, useCompletion, streamText, and generateObject configurations. Supports Next.js App Router, React, with OpenAI, Anthropic, Gemini providers."
  tool="Vercel AI SDK Config Generator, useChat Config Builder, useCompletion Generator, AI SDK Next.js Config, streamText Configuration"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Vercel AI SDK Config Generator</h1>
  <p class="text-text-muted mb-4">Generate complete Vercel AI SDK configurations for useChat, useCompletion, streamText, and generateObject. Pick your provider, hook, and options to get production-ready code.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> useChat & useCompletion</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 20+ providers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> App Router ready</span>
  </div>

  <!-- Config Type -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Configuration Type</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      {['useChat', 'useCompletion', 'streamText (server)', 'generateObject'].map((t, i) => (
        <label class="config-type-label flex items-center gap-2 cursor-pointer p-3 border border-border rounded-lg hover:border-primary/50 transition-colors">
          <input type="radio" name="config-type" value={['useChat','useCompletion','streamText','generateObject'][i]} class="config-type-radio" checked={i===0} />
          <span class="text-sm font-medium">{t}</span>
        </label>
      ))}
    </div>
  </div>

  <!-- Provider & Model -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Provider & Model</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Provider</label>
        <select id="provider" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="openai" selected>OpenAI</option>
          <option value="anthropic">Anthropic</option>
          <option value="google">Google (Gemini)</option>
          <option value="mistral">Mistral</option>
          <option value="cohere">Cohere</option>
          <option value="bedrock">AWS Bedrock</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Model</label>
        <input id="model" type="text" value="gpt-4o"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
      </div>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-4">
      <div>
        <label class="block text-xs text-text-muted mb-1">Max Tokens</label>
        <input id="max-tokens" type="number" value="1024" min="1"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Temperature</label>
        <input id="temperature" type="number" value="0.7" step="0.1" min="0" max="2"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">API Route</label>
        <input id="api-route" type="text" value="/api/chat"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">System Prompt</label>
        <input id="system-prompt" type="text" value="You are a helpful assistant."
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
    </div>
  </div>

  <!-- Options -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-3">Options</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <label class="flex items-center gap-2 cursor-pointer">
        <input id="opt-initial-msg" type="checkbox" checked class="rounded" />
        <span class="text-sm">initialMessages</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer">
        <input id="opt-on-finish" type="checkbox" checked class="rounded" />
        <span class="text-sm">onFinish callback</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer">
        <input id="opt-on-error" type="checkbox" checked class="rounded" />
        <span class="text-sm">onError handler</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer">
        <input id="opt-body" type="checkbox" class="rounded" />
        <span class="text-sm">Custom body</span>
      </label>
    </div>
  </div>

  <!-- Generated Code - Frontend -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-4">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-base font-semibold">Frontend Component</h2>
      <button id="copy-frontend" class="text-xs bg-primary/10 hover:bg-primary/20 text-primary px-3 py-1.5 rounded-lg transition-colors">Copy</button>
    </div>
    <pre id="frontend-output" class="bg-bg-card border border-border rounded-lg p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text leading-relaxed"></pre>
  </div>

  <!-- Generated Code - Backend -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-base font-semibold">API Route (Server)</h2>
      <button id="copy-backend" class="text-xs bg-primary/10 hover:bg-primary/20 text-primary px-3 py-1.5 rounded-lg transition-colors">Copy</button>
    </div>
    <pre id="backend-output" class="bg-bg-card border border-border rounded-lg p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text leading-relaxed"></pre>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Vercel AI SDK Config Generator" relatedTags={['vercel', 'ai', 'react', 'nextjs', 'sdk', 'streaming', 'openai']} />
</BaseLayout>

<script>
  function getVal(id: string): string {
    return (document.getElementById(id) as HTMLInputElement).value;
  }
  function isChecked(id: string): boolean {
    return (document.getElementById(id) as HTMLInputElement).checked;
  }
  function getConfigType(): string {
    return (document.querySelector('.config-type-radio:checked') as HTMLInputElement)?.value || 'useChat';
  }

  const PROVIDER_MODELS: Record<string, string[]> = {
    openai: ['gpt-4o', 'gpt-4o-mini', 'o4-mini', 'gpt-3.5-turbo'],
    anthropic: ['claude-sonnet-4-6', 'claude-opus-4-6', 'claude-haiku-4-5-20251001'],
    google: ['gemini-2.0-flash', 'gemini-2.5-pro-preview-05-06', 'gemini-1.5-pro'],
    mistral: ['mistral-large-latest', 'mistral-small-latest'],
    cohere: ['command-r-plus', 'command-r'],
    bedrock: ['anthropic.claude-3-5-sonnet-20241022-v2:0'],
  };

  const PROVIDER_PKG: Record<string, string> = {
    openai: '@ai-sdk/openai', anthropic: '@ai-sdk/anthropic', google: '@ai-sdk/google',
    mistral: '@ai-sdk/mistral', cohere: '@ai-sdk/cohere', bedrock: '@ai-sdk/amazon-bedrock',
  };

  const PROVIDER_FUNC: Record<string, string> = {
    openai: 'openai', anthropic: 'anthropic', google: 'google',
    mistral: 'mistral', cohere: 'cohere', bedrock: 'bedrock',
  };

  function generateFrontend(): string {
    const configType = getConfigType();
    const apiRoute = getVal('api-route');
    const hasInitial = isChecked('opt-initial-msg');
    const hasOnFinish = isChecked('opt-on-finish');
    const hasOnError = isChecked('opt-on-error');
    const hasBody = isChecked('opt-body');

    if (configType === 'useChat') {
      const opts: string[] = [`    api: '${apiRoute}',`];
      if (hasInitial) opts.push(`    initialMessages: [\n      { id: '1', role: 'assistant', content: 'Hello! How can I help you today?' }\n    ],`);
      if (hasBody) opts.push(`    body: { /* extra params passed to your API route */ },`);
      if (hasOnFinish) opts.push(`    onFinish: (message) => {\n      console.log('Completed:', message.content);\n    },`);
      if (hasOnError) opts.push(`    onError: (error) => {\n      console.error('Error:', error);\n    },`);

      return `'use client';
import { useChat } from 'ai/react';

export function Chat() {
  const { messages, input, handleInputChange, handleSubmit, isLoading, error } = useChat({
${opts.join('\n')}
  });

  return (
    <div className="flex flex-col h-screen max-w-2xl mx-auto p-4">
      <div className="flex-1 overflow-y-auto space-y-4">
        {messages.map(m => (
          <div key={m.id} className={\`flex \${m.role === 'user' ? 'justify-end' : 'justify-start'}\`}>
            <div className={\`rounded-lg px-4 py-2 max-w-[80%] \${
              m.role === 'user' ? 'bg-blue-500 text-white' : 'bg-gray-100 text-gray-900'
            }\`}>
              {m.content}
            </div>
          </div>
        ))}
        {isLoading && <div className="text-gray-400 animate-pulse">Thinking...</div>}
        {error && <div className="text-red-500 text-sm">{error.message}</div>}
      </div>
      <form onSubmit={handleSubmit} className="flex gap-2 mt-4">
        <input
          value={input}
          onChange={handleInputChange}
          placeholder="Type a message..."
          className="flex-1 border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
        />
        <button type="submit" disabled={isLoading}
          className="bg-blue-500 text-white px-4 py-2 rounded-lg disabled:opacity-50">
          Send
        </button>
      </form>
    </div>
  );
}`;
    }

    if (configType === 'useCompletion') {
      const opts: string[] = [`    api: '${apiRoute}',`];
      if (hasOnFinish) opts.push(`    onFinish: (prompt, completion) => {\n      console.log('Done:', completion);\n    },`);
      if (hasOnError) opts.push(`    onError: (error) => console.error('Error:', error),`);

      return `'use client';
import { useCompletion } from 'ai/react';

export function Completion() {
  const { completion, input, handleInputChange, handleSubmit, isLoading } = useCompletion({
${opts.join('\n')}
  });

  return (
    <div className="max-w-2xl mx-auto p-4">
      <form onSubmit={handleSubmit} className="flex gap-2 mb-4">
        <input
          value={input}
          onChange={handleInputChange}
          placeholder="Enter your prompt..."
          className="flex-1 border rounded-lg px-3 py-2"
        />
        <button type="submit" disabled={isLoading}
          className="bg-blue-500 text-white px-4 py-2 rounded-lg disabled:opacity-50">
          Generate
        </button>
      </form>
      {completion && (
        <div className="bg-gray-50 rounded-lg p-4 whitespace-pre-wrap">
          {completion}
        </div>
      )}
    </div>
  );
}`;
    }

    return `// ${configType} runs server-side — see the API route below.
// Import and use the result in your React Server Component:

import { generateText } from 'ai';
import { ${PROVIDER_FUNC[getVal('provider') || 'openai']} } from '${PROVIDER_PKG[getVal('provider') || 'openai']}';

export default async function Page() {
  const { text } = await generateText({
    model: ${PROVIDER_FUNC[getVal('provider') || 'openai']}('${getVal('model')}'),
    prompt: 'Hello, world!',
  });
  return <p>{text}</p>;
}`;
  }

  function generateBackend(): string {
    const configType = getConfigType();
    const provider = getVal('provider') || 'openai';
    const model = getVal('model');
    const maxTokens = getVal('max-tokens');
    const temperature = getVal('temperature');
    const systemPrompt = getVal('system-prompt');
    const pkg = PROVIDER_PKG[provider];
    const func = PROVIDER_FUNC[provider];

    if (configType === 'generateObject') {
      return `import { generateObject } from 'ai';
import { ${func} } from '${pkg}';
import { z } from 'zod';

export async function POST(req: Request) {
  const { prompt } = await req.json();

  const { object } = await generateObject({
    model: ${func}('${model}'),
    schema: z.object({
      title: z.string(),
      summary: z.string(),
      tags: z.array(z.string()),
      sentiment: z.enum(['positive', 'neutral', 'negative']),
    }),
    prompt,
  });

  return Response.json(object);
}`;
    }

    const isCompletion = configType === 'useCompletion';

    return `import { streamText } from 'ai';
import { ${func} } from '${pkg}';

export async function POST(req: Request) {
  const { ${isCompletion ? 'prompt' : 'messages'} } = await req.json();

  const result = await streamText({
    model: ${func}('${model}'),
    ${systemPrompt ? `system: '${systemPrompt.replace(/'/g, "\\'")}',\n    ` : ''}${isCompletion ? `prompt,` : 'messages,'}
    maxTokens: ${maxTokens},
    temperature: ${temperature},
  });

  return result.toDataStreamResponse();
}`;
  }

  function update() {
    document.getElementById('frontend-output')!.textContent = generateFrontend();
    document.getElementById('backend-output')!.textContent = generateBackend();
  }

  function updateProviderModels() {
    const provider = getVal('provider');
    const models = PROVIDER_MODELS[provider] || [];
    const modelInput = document.getElementById('model') as HTMLInputElement;
    if (models.length) modelInput.value = models[0];
    update();
  }

  document.getElementById('provider')!.addEventListener('change', updateProviderModels);

  document.querySelectorAll('.config-type-radio').forEach(el => el.addEventListener('change', update));

  ['copy-frontend', 'copy-backend'].forEach(id => {
    const outputId = id === 'copy-frontend' ? 'frontend-output' : 'backend-output';
    document.getElementById(id)!.addEventListener('click', () => {
      const code = (document.getElementById(outputId) as HTMLPreElement).textContent || '';
      navigator.clipboard.writeText(code).then(() => {
        const btn = document.getElementById(id)!;
        btn.textContent = 'Copied!';
        setTimeout(() => btn.textContent = 'Copy', 1500);
      });
    });
  });

  document.querySelectorAll('input, select, textarea').forEach(el => el.addEventListener('input', update));
  update();
</script>
