---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How much data do I actually need to fine-tune an LLM?", answer: "It depends on task complexity and desired quality. Simple classification tasks can work with 50–200 high-quality examples. Complex generation tasks (summarization, code generation) typically need 500–5,000 examples for good results and 5,000–50,000 for excellent results. Quality matters far more than raw quantity — 200 excellent examples outperform 2,000 mediocre ones." },
  { question: "What is the JSONL format for fine-tuning?", answer: "OpenAI's fine-tuning API accepts JSONL files where each line is a JSON object with a 'messages' array in chat format. Each message has a 'role' (system/user/assistant) and 'content' field. The assistant's response is what the model learns to produce. Each line = one training example." },
  { question: "How do I estimate training tokens?", answer: "Training tokens = sum of all tokens across all messages in all training examples. A 500-example dataset where each example has ~300 tokens would be approximately 150,000 training tokens. OpenAI charges per training token; Llama fine-tuning on your own hardware doesn't have a per-token cost." },
  { question: "What is the difference between LoRA and full fine-tuning?", answer: "Full fine-tuning updates all model weights — compute-intensive, requires large GPUs, but gives maximum flexibility. LoRA (Low-Rank Adaptation) adds small trainable matrices to attention layers, reducing trainable parameters by 99%+. LoRA is the standard for fine-tuning on consumer hardware and is often nearly as good as full fine-tuning for most tasks." },
  { question: "When should I fine-tune vs use prompt engineering?", answer: "Try prompt engineering first — it's faster and cheaper. Fine-tune when: (1) you need consistent format/style that prompting can't reliably achieve, (2) you're hitting token limits with few-shot examples, (3) latency is critical and you can't afford large prompts, or (4) you need off-distribution behavior the base model can't generalize to." },
  { question: "How many epochs should I train for?", answer: "Typically 3–5 epochs for fine-tuning. More epochs increase memorization risk. For small datasets (<500 examples), use fewer epochs (1–2) with early stopping. OpenAI's default is 3 epochs. Monitor validation loss — stop when it starts increasing (overfitting signal)." },
];

interface ModelConfig {
  name: string;
  provider: string;
  costPer1KTokens: number | null;
  canSelfHost: boolean;
  paramB: number;
  method: string;
}

const baseModels: ModelConfig[] = [
  { name: 'GPT-4o mini', provider: 'OpenAI', costPer1KTokens: 0.0008, canSelfHost: false, paramB: 8, method: 'Full fine-tune (via API)' },
  { name: 'GPT-3.5 Turbo', provider: 'OpenAI', costPer1KTokens: 0.0008, canSelfHost: false, paramB: 20, method: 'Full fine-tune (via API)' },
  { name: 'Llama 3.1 8B', provider: 'Meta (OSS)', costPer1KTokens: null, canSelfHost: true, paramB: 8, method: 'LoRA / QLoRA recommended' },
  { name: 'Llama 3.1 70B', provider: 'Meta (OSS)', costPer1KTokens: null, canSelfHost: true, paramB: 70, method: 'QLoRA required (24GB+ VRAM)' },
  { name: 'Mistral 7B', provider: 'Mistral (OSS)', costPer1KTokens: null, canSelfHost: true, paramB: 7, method: 'LoRA / QLoRA recommended' },
];

const taskTypes = [
  { id: 'classification', label: 'Classification', description: 'Categorize text into labels' },
  { id: 'summarization', label: 'Summarization', description: 'Condense long text to short' },
  { id: 'code-gen', label: 'Code Generation', description: 'Generate or complete code' },
  { id: 'chat', label: 'Chat / Conversation', description: 'Custom persona or domain chat' },
  { id: 'extraction', label: 'Information Extraction', description: 'Pull structured data from text' },
];

// Multiplier table: [task][quality] -> {min, recommended, max, avgTokensPerExample}
const dataRequirements: Record<string, Record<string, { min: number; rec: number; max: number; avgTok: number }>> = {
  'classification': {
    'good':      { min: 50,    rec: 150,   max: 500,   avgTok: 200 },
    'great':     { min: 200,   rec: 500,   max: 2000,  avgTok: 200 },
    'excellent': { min: 1000,  rec: 3000,  max: 10000, avgTok: 200 },
  },
  'summarization': {
    'good':      { min: 200,   rec: 500,   max: 1500,  avgTok: 600 },
    'great':     { min: 500,   rec: 2000,  max: 5000,  avgTok: 600 },
    'excellent': { min: 2000,  rec: 8000,  max: 25000, avgTok: 600 },
  },
  'code-gen': {
    'good':      { min: 100,   rec: 300,   max: 1000,  avgTok: 500 },
    'great':     { min: 500,   rec: 2000,  max: 8000,  avgTok: 500 },
    'excellent': { min: 2000,  rec: 10000, max: 50000, avgTok: 500 },
  },
  'chat': {
    'good':      { min: 100,   rec: 300,   max: 1000,  avgTok: 400 },
    'great':     { min: 500,   rec: 2000,  max: 8000,  avgTok: 400 },
    'excellent': { min: 2000,  rec: 8000,  max: 30000, avgTok: 400 },
  },
  'extraction': {
    'good':      { min: 100,   rec: 300,   max: 1000,  avgTok: 350 },
    'great':     { min: 500,   rec: 2000,  max: 6000,  avgTok: 350 },
    'excellent': { min: 2000,  rec: 8000,  max: 25000, avgTok: 350 },
  },
};
---

<BaseLayout
  title="Fine-Tune Data Calculator — LLM Training Data Requirements & Cost"
  description="Calculate how many fine-tuning examples you need for GPT-4o mini, Llama 3, or Mistral. Get training token estimates, cost projections, and JSONL format examples for OpenAI fine-tuning."
  tool="Fine-Tune Data Calculator, LLM Fine-Tuning Examples, OpenAI Fine-Tuning Cost, LoRA Training Data, GPT Fine-Tune Requirements"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Fine-Tune Data Calculator</h1>
  <p class="text-text-muted mb-4">Estimate the number of training examples, total tokens, and fine-tuning cost for your specific model, task, and quality target.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 base models</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Per-task data requirements</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> JSONL format examples</span>
  </div>

  <!-- Inputs -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
    <div>
      <label class="block text-sm font-medium mb-1.5">Base Model</label>
      <select id="model-select" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
        {baseModels.map(m => (
          <option value={m.name}>{m.name} ({m.provider})</option>
        ))}
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium mb-1.5">Task Type</label>
      <select id="task-select" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
        {taskTypes.map(t => (
          <option value={t.id}>{t.label} — {t.description}</option>
        ))}
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium mb-1.5">Desired Quality</label>
      <select id="quality-select" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
        <option value="good">Good — Works for most cases</option>
        <option value="great" selected>Great — Production-ready</option>
        <option value="excellent">Excellent — Top-tier performance</option>
      </select>
    </div>
  </div>

  <!-- Results -->
  <div id="results" class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
    <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
      <p class="text-xs text-text-muted mb-1">Min Examples</p>
      <p id="res-min" class="text-2xl font-bold">—</p>
    </div>
    <div class="bg-bg-card border border-primary/40 rounded-xl p-4 text-center">
      <p class="text-xs text-primary mb-1">Recommended</p>
      <p id="res-rec" class="text-2xl font-bold text-primary">—</p>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
      <p class="text-xs text-text-muted mb-1">Max (diminishing returns)</p>
      <p id="res-max" class="text-2xl font-bold">—</p>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4 text-center">
      <p class="text-xs text-text-muted mb-1">Est. Training Tokens</p>
      <p id="res-tokens" class="text-2xl font-bold">—</p>
    </div>
  </div>

  <!-- Cost panel -->
  <div id="cost-panel" class="bg-bg-card border border-border rounded-xl p-5 mb-8 hidden">
    <h3 class="font-semibold mb-3">Estimated Training Cost (OpenAI API)</h3>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="text-center">
        <p class="text-xs text-text-muted mb-1">Min examples cost</p>
        <p id="cost-min" class="text-xl font-bold text-primary">—</p>
      </div>
      <div class="text-center">
        <p class="text-xs text-text-muted mb-1">Recommended cost</p>
        <p id="cost-rec" class="text-xl font-bold text-primary">—</p>
      </div>
      <div class="text-center">
        <p class="text-xs text-text-muted mb-1">Max examples cost</p>
        <p id="cost-max" class="text-xl font-bold text-primary">—</p>
      </div>
    </div>
    <p class="text-xs text-text-muted mt-3">Cost = training tokens × $0.0008 per 1K tokens. Actual cost depends on number of epochs (default 3). Prices as of Q1 2025.</p>
  </div>

  <!-- Self-host note -->
  <div id="selfhost-panel" class="bg-bg-card border border-border rounded-xl p-5 mb-8 hidden">
    <h3 class="font-semibold mb-2">Open-Source Model — No API Training Cost</h3>
    <p class="text-sm text-text-muted mb-3">Self-hosted fine-tuning costs come from GPU compute. Typical estimates for reference:</p>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 text-sm">
      <div class="bg-bg-card border border-border rounded-lg p-3">
        <p class="font-medium mb-1">7B / 8B Model</p>
        <p class="text-xs text-text-muted">1× A100 40GB · LoRA · 1K examples · 3 epochs</p>
        <p class="text-primary font-semibold mt-1">~$2–8 on cloud GPU</p>
      </div>
      <div class="bg-bg-card border border-border rounded-lg p-3">
        <p class="font-medium mb-1">70B Model</p>
        <p class="text-xs text-text-muted">4× A100 80GB · QLoRA · 1K examples · 3 epochs</p>
        <p class="text-primary font-semibold mt-1">~$30–100 on cloud GPU</p>
      </div>
      <div class="bg-bg-card border border-border rounded-lg p-3">
        <p class="font-medium mb-1">Platforms</p>
        <p class="text-xs text-text-muted">Modal, RunPod, Lambda Labs, Together AI Fine-Tune</p>
        <p class="text-primary font-semibold mt-1">$0.75–$4 / GPU-hr</p>
      </div>
    </div>
  </div>

  <!-- JSONL format section -->
  <h2 class="text-lg font-bold mb-4">JSONL Format for OpenAI Fine-Tuning</h2>
  <p class="text-text-muted text-sm mb-3">Each line in your <code class="text-primary">.jsonl</code> file is one training example in this format:</p>

  <div class="bg-bg-card border border-border rounded-xl overflow-hidden mb-4">
    <div class="flex items-center justify-between px-4 py-2 border-b border-border">
      <span class="text-xs text-text-muted font-mono">training_data.jsonl</span>
      <button id="copy-jsonl" class="text-xs px-3 py-1 bg-primary text-white rounded hover:bg-primary/90 transition-colors">Copy</button>
    </div>
    <pre id="jsonl-code" class="p-4 text-xs overflow-x-auto text-text font-mono leading-relaxed"></pre>
  </div>

  <div class="bg-bg-card border border-border rounded-xl p-5 mb-8">
    <h3 class="font-semibold mb-3">Validation Checklist</h3>
    <ul class="text-sm text-text-muted space-y-1.5">
      <li class="flex items-start gap-2"><span class="text-green-500 mt-0.5">✓</span> Each line is a valid JSON object (not pretty-printed)</li>
      <li class="flex items-start gap-2"><span class="text-green-500 mt-0.5">✓</span> Every example has a <code class="text-primary">messages</code> array with at least one user + one assistant message</li>
      <li class="flex items-start gap-2"><span class="text-green-500 mt-0.5">✓</span> Last message in each example is from <code class="text-primary">assistant</code> (this is what the model learns)</li>
      <li class="flex items-start gap-2"><span class="text-green-500 mt-0.5">✓</span> No empty <code class="text-primary">content</code> fields</li>
      <li class="flex items-start gap-2"><span class="text-green-500 mt-0.5">✓</span> At least 10 examples in training file (OpenAI minimum)</li>
      <li class="flex items-start gap-2"><span class="text-green-500 mt-0.5">✓</span> Validation file: 10–20% of training size (recommended)</li>
    </ul>
    <div class="mt-3 pt-3 border-t border-border">
      <p class="text-xs text-text-muted">Validate your file: <code class="text-primary">openai tools fine_tunes.prepare_data -f training_data.jsonl</code></p>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Fine-Tune Data Calculator" relatedTags={['ai', 'llm', 'fine-tuning', 'openai', 'llama', 'training', 'machine-learning']} />
</BaseLayout>

<script>
  const modelSelect = document.getElementById('model-select') as HTMLSelectElement;
  const taskSelect = document.getElementById('task-select') as HTMLSelectElement;
  const qualitySelect = document.getElementById('quality-select') as HTMLSelectElement;

  const dataReqs: Record<string, Record<string, { min: number; rec: number; max: number; avgTok: number }>> = {
    'classification': {
      'good':      { min: 50,    rec: 150,   max: 500,   avgTok: 200 },
      'great':     { min: 200,   rec: 500,   max: 2000,  avgTok: 200 },
      'excellent': { min: 1000,  rec: 3000,  max: 10000, avgTok: 200 },
    },
    'summarization': {
      'good':      { min: 200,   rec: 500,   max: 1500,  avgTok: 600 },
      'great':     { min: 500,   rec: 2000,  max: 5000,  avgTok: 600 },
      'excellent': { min: 2000,  rec: 8000,  max: 25000, avgTok: 600 },
    },
    'code-gen': {
      'good':      { min: 100,   rec: 300,   max: 1000,  avgTok: 500 },
      'great':     { min: 500,   rec: 2000,  max: 8000,  avgTok: 500 },
      'excellent': { min: 2000,  rec: 10000, max: 50000, avgTok: 500 },
    },
    'chat': {
      'good':      { min: 100,   rec: 300,   max: 1000,  avgTok: 400 },
      'great':     { min: 500,   rec: 2000,  max: 8000,  avgTok: 400 },
      'excellent': { min: 2000,  rec: 8000,  max: 30000, avgTok: 400 },
    },
    'extraction': {
      'good':      { min: 100,   rec: 300,   max: 1000,  avgTok: 350 },
      'great':     { min: 500,   rec: 2000,  max: 6000,  avgTok: 350 },
      'excellent': { min: 2000,  rec: 8000,  max: 25000, avgTok: 350 },
    },
  };

  const modelCosts: Record<string, number | null> = {
    'GPT-4o mini': 0.0008,
    'GPT-3.5 Turbo': 0.0008,
    'Llama 3.1 8B': null,
    'Llama 3.1 70B': null,
    'Mistral 7B': null,
  };

  const jsonlExamples: Record<string, string> = {
    'classification': `{"messages": [{"role": "system", "content": "Classify the sentiment of the following text as POSITIVE, NEGATIVE, or NEUTRAL."}, {"role": "user", "content": "The new product launch exceeded all expectations."}, {"role": "assistant", "content": "POSITIVE"}]}
{"messages": [{"role": "system", "content": "Classify the sentiment of the following text as POSITIVE, NEGATIVE, or NEUTRAL."}, {"role": "user", "content": "Shipping took 3 weeks and the item arrived damaged."}, {"role": "assistant", "content": "NEGATIVE"}]}
{"messages": [{"role": "system", "content": "Classify the sentiment of the following text as POSITIVE, NEGATIVE, or NEUTRAL."}, {"role": "user", "content": "The package arrived on Tuesday."}, {"role": "assistant", "content": "NEUTRAL"}]}`,
    'summarization': `{"messages": [{"role": "system", "content": "Summarize the following document in 2-3 sentences."}, {"role": "user", "content": "Neural networks are computing systems inspired by biological neural networks that constitute animal brains. They are based on a collection of connected nodes which loosely model the neurons in a biological brain. Each connection can transmit a signal to other neurons. A neuron that receives a signal then processes it and can signal neurons connected to it."}, {"role": "assistant", "content": "Neural networks are computing systems modeled after biological brains, consisting of interconnected nodes that mimic neurons. These nodes process and transmit signals through connections, enabling the system to learn and recognize patterns. They form the foundation of modern machine learning and AI."}]}`,
    'code-gen': `{"messages": [{"role": "system", "content": "You are a Python expert. Write clean, type-annotated Python functions."}, {"role": "user", "content": "Write a function that takes a list of integers and returns the running average."}, {"role": "assistant", "content": "def running_average(numbers: list[int | float]) -> list[float]:\\n    \\"\\"\\"Return the running average of a list of numbers.\\"\\"\\"\\n    if not numbers:\\n        return []\\n    result = []\\n    total = 0.0\\n    for i, num in enumerate(numbers, 1):\\n        total += num\\n        result.append(total / i)\\n    return result"}]}`,
    'chat': `{"messages": [{"role": "system", "content": "You are Aria, a friendly customer support agent for TechCorp. You help customers with product questions, troubleshooting, and account issues. Always be concise and professional."}, {"role": "user", "content": "Hi, I can't log into my account."}, {"role": "assistant", "content": "I'm sorry to hear that! Let's get you back in. Could you tell me: are you seeing an error message, or is it just not accepting your password? Also, are you using the web app or mobile app?"}]}
{"messages": [{"role": "system", "content": "You are Aria, a friendly customer support agent for TechCorp."}, {"role": "user", "content": "How do I export my data?"}, {"role": "assistant", "content": "Great question! To export your data: go to Settings → Account → Data Export, then click \\"Request Export\\". You'll receive an email with a download link within 24 hours. The export includes all your projects, comments, and attachments in a ZIP file."}]}`,
    'extraction': `{"messages": [{"role": "system", "content": "Extract the following fields from the invoice text: invoice_number, date, total_amount, vendor_name. Return as JSON."}, {"role": "user", "content": "INVOICE\\nInvoice #: INV-2024-0892\\nDate: March 15, 2024\\nFrom: Acme Corp\\nTotal Due: $1,234.56"}, {"role": "assistant", "content": "{\\"invoice_number\\": \\"INV-2024-0892\\", \\"date\\": \\"2024-03-15\\", \\"total_amount\\": 1234.56, \\"vendor_name\\": \\"Acme Corp\\"}"}]}`,
  };

  function formatNum(n: number): string {
    if (n >= 1000000) return (n / 1000000).toFixed(1) + 'M';
    if (n >= 1000) return (n / 1000).toFixed(1) + 'K';
    return n.toLocaleString();
  }

  function formatCost(n: number): string {
    if (n < 1) return `$${n.toFixed(2)}`;
    if (n < 100) return `$${n.toFixed(2)}`;
    return `$${n.toLocaleString('en-US', { maximumFractionDigits: 0 })}`;
  }

  function update() {
    const model = modelSelect.value;
    const task = taskSelect.value;
    const quality = qualitySelect.value;
    const req = dataReqs[task]?.[quality];
    if (!req) return;

    document.getElementById('res-min')!.textContent = formatNum(req.min);
    document.getElementById('res-rec')!.textContent = formatNum(req.rec);
    document.getElementById('res-max')!.textContent = formatNum(req.max);

    const epochs = 3;
    const recTokens = req.rec * req.avgTok * epochs;
    document.getElementById('res-tokens')!.textContent = formatNum(recTokens);

    const costPerTok = modelCosts[model];
    const costPanel = document.getElementById('cost-panel')!;
    const selfhostPanel = document.getElementById('selfhost-panel')!;

    if (costPerTok !== null) {
      costPanel.classList.remove('hidden');
      selfhostPanel.classList.add('hidden');
      document.getElementById('cost-min')!.textContent = formatCost(req.min * req.avgTok * epochs / 1000 * costPerTok);
      document.getElementById('cost-rec')!.textContent = formatCost(req.rec * req.avgTok * epochs / 1000 * costPerTok);
      document.getElementById('cost-max')!.textContent = formatCost(req.max * req.avgTok * epochs / 1000 * costPerTok);
    } else {
      costPanel.classList.add('hidden');
      selfhostPanel.classList.remove('hidden');
    }

    // Update JSONL example
    const code = document.getElementById('jsonl-code')!;
    code.textContent = jsonlExamples[task] || '';
  }

  modelSelect.addEventListener('change', update);
  taskSelect.addEventListener('change', update);
  qualitySelect.addEventListener('change', update);

  document.getElementById('copy-jsonl')!.addEventListener('click', () => {
    const code = document.getElementById('jsonl-code')!;
    navigator.clipboard.writeText(code.textContent || '');
    const btn = document.getElementById('copy-jsonl')!;
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
  });

  update();
</script>
