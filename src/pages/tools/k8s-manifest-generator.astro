---
import BaseLayout from '../../layouts/BaseLayout.astro';
import K8sManifestGenerator from '../../components/K8sManifestGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a Kubernetes manifest?",
    answer: "A Kubernetes manifest is a YAML (or JSON) file that declares the desired state of a Kubernetes resource — such as a Deployment, Service, or ConfigMap. You submit manifests to the cluster with kubectl apply, and Kubernetes continuously reconciles the actual cluster state to match what the manifest describes. Manifests are the standard way to manage Kubernetes workloads in a declarative, version-controllable way."
  },
  {
    question: "What does kubectl apply -f do?",
    answer: "kubectl apply -f manifest.yaml sends the manifest to the Kubernetes API server, which creates or updates the resource to match the declared state. Unlike kubectl create (which fails if the resource already exists), apply is idempotent — running it multiple times on the same manifest produces the same result. It also records the configuration for future diffs. Use kubectl apply -f for all production workflows."
  },
  {
    question: "What is the difference between a ConfigMap and a Secret?",
    answer: "Both store key-value data that can be injected into Pods as environment variables or mounted as files. The key differences: ConfigMaps store plain text and are intended for non-sensitive configuration (feature flags, connection strings, etc.). Secrets store base64-encoded data and are designed for sensitive values (passwords, tokens, certificates). Kubernetes can encrypt Secrets at rest and restricts access via RBAC. Never put sensitive values in a ConfigMap."
  },
  {
    question: "What is the difference between ClusterIP, NodePort, and LoadBalancer?",
    answer: "ClusterIP (default) exposes the Service on an internal cluster IP — only reachable within the cluster. NodePort opens a port on every Node's IP (range 30000-32767) so the service is reachable from outside the cluster without a load balancer. LoadBalancer provisions an external cloud load balancer (AWS ELB, GCP LB, etc.) and assigns a public IP — the standard production method for exposing services externally. Use ClusterIP for internal microservices, LoadBalancer or Ingress for public traffic."
  },
  {
    question: "When should I use an Ingress instead of a LoadBalancer Service?",
    answer: "A LoadBalancer Service provisions one cloud load balancer per Service, which gets expensive with many services. An Ingress is a single entry point that routes HTTP/HTTPS traffic to multiple Services based on host name or URL path — using one load balancer for the whole cluster. Ingress also handles TLS termination centrally. Use Ingress when you have multiple HTTP services, need host/path-based routing, or want centralized TLS management. Ingress requires an Ingress Controller (nginx-ingress, Traefik, etc.) installed in the cluster."
  },
  {
    question: "What are resource requests and limits in a Deployment?",
    answer: "Requests tell the Kubernetes scheduler how much CPU and memory a container needs — used to decide which Node to schedule the Pod on. Limits cap the maximum resources a container can consume; exceeding the CPU limit causes throttling, and exceeding the memory limit causes the container to be OOMKilled and restarted. Best practice: always set both requests and limits. CPU values use millicores (500m = 0.5 CPU cores). Memory uses binary suffixes: Mi (mebibytes), Gi (gibibytes)."
  },
];
---

<BaseLayout
  title="Kubernetes Manifest Generator — Generate K8s YAML"
  description="Generate Kubernetes YAML manifests interactively. Create Deployments, Services, Ingresses, ConfigMaps, and Secrets with best-practice annotations. Copy or download ready-to-apply YAML."
  tool="Kubernetes manifest generator, K8s YAML generator, kubectl YAML, Kubernetes deployment generator, K8s Service YAML, Kubernetes ConfigMap generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Kubernetes Manifest Generator</h1>
  <p class="text-text-muted mb-4">Build Kubernetes YAML manifests interactively — no YAML memorization required. Configure Deployments, Services, Ingresses, ConfigMaps, and Secrets through a visual form, then copy or download the ready-to-apply YAML.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 resource types supported</span>
  </div>
  <K8sManifestGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Kubernetes Manifest Generator" relatedTags={['devops', 'kubernetes', 'cloud', 'infrastructure', 'docker']} />
</BaseLayout>
