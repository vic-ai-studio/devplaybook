---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "How do I record a Playwright test using the codegen command?", answer: "Run npx playwright codegen <url> in your terminal. A Chromium browser opens alongside a code inspector window. Every action you take is recorded as Playwright code in real time. Use --browser firefox or --browser webkit to record in different browsers. The --save-storage flag persists authentication cookies between recording sessions." },
  { question: "What is the difference between getByRole, getByText, and getByTestId?", answer: "Playwright recommended priority: getByRole (ARIA role + accessible name) > getByLabel > getByPlaceholder > getByText > getByTestId. getByRole is the most resilient because it reflects how users and assistive technology experience the page. Avoid CSS selectors and XPath — they break when styling or DOM structure changes." },
  { question: "How do I handle authentication in Playwright tests?", answer: "Use storageState to save and reuse sessions. Run a global setup file that logs in once and saves the browser state (cookies + localStorage) with page.context().storageState(). In playwright.config.ts, set storageState for authenticated projects. This avoids logging in before every test and speeds up the suite dramatically." },
  { question: "How do I wait for elements without using fixed sleeps?", answer: "Playwright has auto-waiting built in — most actions automatically wait for the element to be visible, stable, and enabled. Use await expect(locator).toBeVisible() for explicit waits. Use page.waitForResponse() for network calls and page.waitForURL() after navigation. Never use page.waitForTimeout() — it creates brittle tests that fail under slow CI conditions." },
  { question: "How do I run Playwright tests in CI/CD?", answer: "Install browsers in CI with npx playwright install --with-deps. Run tests headlessly (the default) with npx playwright test. Use --workers=4 to parallelize. The --reporter=html flag generates an HTML report — upload it as a CI artifact. Use shards (--shard=1/4) to split the suite across multiple runners for faster feedback." },
  { question: "What is Playwright page object model and should I use it?", answer: "The Page Object Model wraps each page into a class with methods for actions and assertions. Instead of repeating selectors, you call loginPage.fillCredentials(user, pass). For large suites POM reduces duplication. For small suites it adds unnecessary boilerplate. Playwright fixtures are the modern alternative — create fixtures that instantiate page objects, making them injectable into any test." },
];
---

<BaseLayout
  title="Playwright Test Recorder Guide — codegen, Selectors & Best Practices"
  description="Complete guide to Playwright test recording: codegen command, resilient selectors, authentication state reuse, auto-waiting, CI/CD integration, and page object model patterns."
  tool="Playwright test recorder, Playwright codegen, Playwright selectors, Playwright CI, end-to-end testing, e2e testing"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Playwright Test Recorder Guide",
    "url": "https://devplaybook.cc/tools/playwright-test-recorder",
    "description": "Complete guide to Playwright test recording: codegen, selectors, auth state, and CI integration.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Playwright Test Recorder Guide</h1>
  <p class="text-text-muted mb-6">
    Master Playwright's <strong>codegen</strong> command, write resilient selectors, handle authentication state, and ship reliable end-to-end tests to CI.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> codegen recording</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Resilient selectors</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auth state reuse</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CI/CD integration</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Recording Your First Test</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Playwright's <code class="bg-bg-card px-1 rounded text-primary font-mono text-sm">codegen</code> command opens a browser and records every interaction as runnable test code in real time.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Install Playwright (first time)
npm init playwright@latest

# Record against your local dev server
npx playwright codegen http://localhost:3000

# Record with Firefox
npx playwright codegen --browser firefox https://example.com

# Record and save authentication state (cookies, localStorage)
npx playwright codegen --save-storage=auth.json https://example.com/login</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Selector Priority — Most to Least Resilient</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Selector</th>
          <th class="border border-border px-3 py-2 text-left">Example</th>
          <th class="border border-border px-3 py-2 text-left">Resilience</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2">getByRole</td><td class="border border-border px-3 py-2 font-mono text-xs">getByRole('button', &#123; name: 'Submit' &#125;)</td><td class="border border-border px-3 py-2 text-green-400">Excellent</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">getByLabel</td><td class="border border-border px-3 py-2 font-mono text-xs">getByLabel('Email address')</td><td class="border border-border px-3 py-2 text-green-400">Excellent</td></tr>
        <tr><td class="border border-border px-3 py-2">getByPlaceholder</td><td class="border border-border px-3 py-2 font-mono text-xs">getByPlaceholder('Search...')</td><td class="border border-border px-3 py-2 text-yellow-400">Good</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">getByText</td><td class="border border-border px-3 py-2 font-mono text-xs">getByText('Sign in')</td><td class="border border-border px-3 py-2 text-yellow-400">Good</td></tr>
        <tr><td class="border border-border px-3 py-2">getByTestId</td><td class="border border-border px-3 py-2 font-mono text-xs">getByTestId('submit-btn')</td><td class="border border-border px-3 py-2 text-yellow-400">Good (needs markup)</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">CSS selector</td><td class="border border-border px-3 py-2 font-mono text-xs">locator('.btn-primary')</td><td class="border border-border px-3 py-2 text-red-400">Fragile</td></tr>
        <tr><td class="border border-border px-3 py-2">XPath</td><td class="border border-border px-3 py-2 font-mono text-xs">locator('//button[1]')</td><td class="border border-border px-3 py-2 text-red-400">Very fragile</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Complete Test with Auto-Waiting</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// tests/login.spec.ts
import &#123; test, expect &#125; from '@playwright/test';

test.describe('Login flow', () => &#123;
  test('successful login redirects to dashboard', async (&#123; page &#125;) => &#123;
    await page.goto('/login');
    await page.getByLabel('Email').fill('user@example.com');
    await page.getByLabel('Password').fill('secret123');
    await page.getByRole('button', &#123; name: 'Sign in' &#125;).click();

    // Auto-wait for navigation — no sleeps needed
    await page.waitForURL('/dashboard');
    await expect(page.getByRole('heading', &#123; name: 'Dashboard' &#125;)).toBeVisible();
  &#125;);

  test('invalid credentials shows error', async (&#123; page &#125;) => &#123;
    await page.goto('/login');
    await page.getByLabel('Email').fill('wrong@example.com');
    await page.getByLabel('Password').fill('wrongpass');
    await page.getByRole('button', &#123; name: 'Sign in' &#125;).click();

    await expect(page.getByText('Invalid credentials')).toBeVisible();
    await expect(page).toHaveURL('/login');
  &#125;);
&#125;);</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Authentication State Reuse</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// global-setup.ts — logs in once, saves session
import &#123; chromium &#125; from '@playwright/test';
export default async function globalSetup() &#123;
  const browser = await chromium.launch();
  const page = await browser.newPage();
  await page.goto('/login');
  await page.getByLabel('Email').fill(process.env.TEST_USER!);
  await page.getByLabel('Password').fill(process.env.TEST_PASS!);
  await page.getByRole('button', &#123; name: 'Sign in' &#125;).click();
  await page.waitForURL('/dashboard');
  await page.context().storageState(&#123; path: 'playwright/.auth/user.json' &#125;);
  await browser.close();
&#125;

// playwright.config.ts
export default defineConfig(&#123;
  globalSetup: './global-setup.ts',
  projects: [
    &#123; name: 'authenticated', use: &#123; storageState: 'playwright/.auth/user.json' &#125; &#125;,
  ],
&#125;);</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">GitHub Actions CI Setup</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># .github/workflows/playwright.yml
name: Playwright E2E Tests
on: [push, pull_request]
jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with: &#123; node-version: 20 &#125;
      - run: npm ci
      - run: npx playwright install --with-deps
      - run: npx playwright test --workers=4
        env:
          TEST_USER: $&#123;&#123; secrets.TEST_USER &#125;&#125;
          TEST_PASS: $&#123;&#123; secrets.TEST_PASS &#125;&#125;
      - uses: actions/upload-artifact@v4
        if: always()
        with:
          name: playwright-html-report
          path: playwright-report/
          retention-days: 14</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Common Pitfalls</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Using waitForTimeout</strong> — Fixed sleeps make tests flaky; use auto-waiting assertions instead</li>
    <li><strong>Hardcoded CSS selectors</strong> — They break on styling changes; prefer getByRole or getByLabel</li>
    <li><strong>Logging in before every test</strong> — Use storageState reuse; auth per-test multiplies runtime</li>
    <li><strong>Missing --with-deps in CI</strong> — Playwright browsers need OS-level deps; always use --with-deps on Linux</li>
    <li><strong>No artifacts on failure</strong> — Always upload playwright-report as a CI artifact for visual debugging</li>
    <li><strong>Testing implementation details</strong> — Assert visible outcomes (text, URL, ARIA state), not internal state</li>
  </ul>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Playwright Test Recorder Guide" relatedTags={['testing', 'playwright', 'e2e', 'automation', 'ci-cd']} />
</BaseLayout>
