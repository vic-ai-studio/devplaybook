---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DeveloperResumeBuilder from '../../components/DeveloperResumeBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Developer Resume Builder — ATS-Optimized, Free Online Tool"
  description="Build an ATS-optimized developer resume in minutes. Fill in your experience, skills, projects, and education — export to Markdown or JSON. No sign-up, runs in your browser."
  tool="Developer Resume Builder, Software Engineer Resume, ATS Resume Builder, Developer CV Generator"
>
  <h1 class="text-3xl font-bold mb-2">Developer Resume Builder</h1>
  <p class="text-text-muted mb-8">Build an ATS-friendly software engineer resume section by section. Fill in your experience with impact-driven bullet points, add projects and skills, then export as Markdown or JSON. Everything runs in your browser — nothing is sent to any server.</p>
  <DeveloperResumeBuilder client:load />
  <ToolPageCta currentTool="Developer Resume Builder" relatedTags={['resume', 'career', 'jobs', 'developer-tools']} />
</BaseLayout>
