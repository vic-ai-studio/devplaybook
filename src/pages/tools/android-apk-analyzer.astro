---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is Android APK Analyzer?",
    answer: "APK Analyzer is a built-in tool in Android Studio (Build > Analyze APK) that inspects the contents of an APK or AAB file. It shows the size of each component (DEX files, resources, native libraries, AndroidManifest.xml), lists all declared permissions, and shows the method count per DEX file. It's the first tool to open when investigating APK size issues."
  },
  {
    question: "What is the difference between APK and AAB?",
    answer: "APK (Android Package) is the traditional distribution format — a single file containing all code and resources for all device configurations. AAB (Android App Bundle) is Google's newer format that lets the Play Store generate optimized APKs per device. AAB results in smaller downloads because users only receive the code and resources for their specific device, language, and screen density. The Play Store now requires AAB for new apps."
  },
  {
    question: "How do I read AndroidManifest.xml permissions?",
    answer: "In APK Analyzer, click on AndroidManifest.xml to see the decoded XML. Look for <uses-permission> elements — each one is a permission your app declares. Review every permission: INTERNET (network), CAMERA, READ_CONTACTS, and ACCESS_FINE_LOCATION are the most sensitive. Remove any permissions not actively used, as users and app stores scrutinize the declared permission list."
  },
  {
    question: "What is ProGuard/R8 and how does it reduce APK size?",
    answer: "R8 is the Android code shrinker and obfuscator (it replaced ProGuard in Android Gradle Plugin 3.4). When enabled, R8 removes unused classes, methods, and fields (shrinking), renames identifiers to short names (obfuscation), and applies code optimizations. Together these can reduce DEX size by 30–60%. Enable with minifyEnabled = true in your release build configuration."
  },
  {
    question: "How do I reduce my APK/AAB size?",
    answer: "Key strategies: (1) Enable R8 shrinking with minifyEnabled = true. (2) Enable resource shrinking with shrinkResources = true. (3) Use Android App Bundle (AAB) instead of APK. (4) Compress and convert images to WebP. (5) Use vector drawables instead of raster images where possible. (6) Audit your dependencies — many bring in large transitive dependencies. (7) Use ABI splits or ABIs filter to exclude unnecessary native library architectures."
  },
  {
    question: "What is a DEX file and why does method count matter?",
    answer: "DEX (Dalvik Executable) is the bytecode format for Android apps. Each DEX file has a hard limit of 65,536 method references (the '64K limit'). When your app exceeds this, you need multidex, which splits code into multiple DEX files. Multidex increases startup time on older Android versions. R8 shrinking typically reduces your method count significantly, helping avoid or minimize multidex overhead."
  }
];
---
<BaseLayout
  title="Android APK Analyzer: Manifest, Permissions & Size Reduction Guide"
  description="Master Android APK Analyzer to inspect manifest permissions, DEX files, resources, and native libraries. Learn APK vs AAB, R8/ProGuard shrinking, and proven techniques to reduce your Android app size."
  tool="android-apk-analyzer"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"Android APK Analyzer: Manifest, Permissions & Size Reduction Guide","url":"https://devplaybook.cc/tools/android-apk-analyzer","description":"Master Android APK Analyzer to inspect manifest permissions, DEX files, and reduce your Android app size."})} />

  <h1 class="text-3xl font-bold mb-2">Android APK Analyzer: Manifest, Permissions & Size Guide</h1>
  <p class="text-text-muted mb-6">Use Android Studio's APK Analyzer to inspect what's inside your APK or AAB, understand permission declarations, read DEX class structure, and apply R8 shrinking to reduce app size for Google Play.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> APK vs AAB explained</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Manifest permission audit</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> R8/ProGuard shrinking</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Size reduction techniques</span>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-3">APK vs AAB: Which to Use</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 font-semibold">Feature</th>
          <th class="text-left py-2 pr-4 font-semibold">APK</th>
          <th class="text-left py-2 font-semibold">AAB (Android App Bundle)</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <tr>
          <td class="py-2 pr-4">Required by Play Store</td>
          <td class="py-2 pr-4">Legacy apps only</td>
          <td class="py-2">Yes, for new apps since 2021</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">Delivered size</td>
          <td class="py-2 pr-4">Same for all devices</td>
          <td class="py-2">Optimized per device (smaller)</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">Direct install</td>
          <td class="py-2 pr-4">Yes (adb install)</td>
          <td class="py-2">No (requires bundletool or Play Store)</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">Average size reduction</td>
          <td class="py-2 pr-4">Baseline</td>
          <td class="py-2">15–65% smaller download</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">Dynamic feature modules</td>
          <td class="py-2 pr-4">No</td>
          <td class="py-2">Yes</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Using APK Analyzer in Android Studio</h2>
  <p class="mb-4">Open APK Analyzer from the menu: <strong>Build > Analyze APK...</strong> and select your .apk or .aab file. You'll see a breakdown of every file and its raw and download size.</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm"># Build a release APK for analysis
cd android
./gradlew assembleRelease

# The APK is at:
# android/app/build/outputs/apk/release/app-release.apk

# Or build an AAB (for Play Store):
./gradlew bundleRelease
# android/app/build/outputs/bundle/release/app-release.aab

# Analyze from command line with bundletool
java -jar bundletool.jar dump manifest --bundle=app-release.aab
java -jar bundletool.jar dump resources --bundle=app-release.aab</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Reading AndroidManifest.xml Permissions</h2>
  <p class="mb-4">In APK Analyzer, click <code>AndroidManifest.xml</code> to see all declared permissions. Review each one for necessity:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm">&lt;!-- AndroidManifest.xml — permission examples --&gt;
&lt;manifest xmlns:android="http://schemas.android.com/apk/res/android"&gt;

  &lt;!-- Required for any network access --&gt;
  &lt;uses-permission android:name="android.permission.INTERNET" /&gt;

  &lt;!-- Runtime permission — user must approve --&gt;
  &lt;uses-permission android:name="android.permission.CAMERA" /&gt;

  &lt;!-- maxSdkVersion limits to older OS versions --&gt;
  &lt;uses-permission
    android:name="android.permission.READ_EXTERNAL_STORAGE"
    android:maxSdkVersion="32" /&gt;

  &lt;!-- Precise vs approximate location --&gt;
  &lt;uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" /&gt;
  &lt;!-- Only add FINE_LOCATION if you truly need GPS precision --&gt;

&lt;/manifest&gt;</code></pre>
  <p class="mb-4">Permissions added automatically by third-party libraries (called "permission leakage") are a common issue. Add <code>tools:node="remove"</code> to strip permissions added by libraries you can't modify:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm">&lt;manifest xmlns:tools="http://schemas.android.com/tools"&gt;
  &lt;!-- Remove a permission added by a library --&gt;
  &lt;uses-permission
    android:name="android.permission.READ_PHONE_STATE"
    tools:node="remove" /&gt;
&lt;/manifest&gt;</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Reducing APK Size with R8 and Resource Shrinking</h2>
  <p class="mb-4">Enable R8 code shrinking and resource shrinking in your release build configuration:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm">// android/app/build.gradle
android &#123;
    buildTypes &#123;
        release &#123;
            minifyEnabled true         // Enable R8 shrinking + obfuscation
            shrinkResources true       // Remove unused resources
            proguardFiles getDefaultProguardFile('proguard-android-optimize.txt'),
                          'proguard-rules.pro'
        &#125;
    &#125;

    // Exclude specific ABIs to reduce native library size
    // Include only the architectures you target
    splits &#123;
        abi &#123;
            enable true
            reset()
            include 'arm64-v8a', 'armeabi-v7a'  // Covers 99%+ of Android devices
            universalApk false
        &#125;
    &#125;
&#125;</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Analyze DEX Method Count</h2>
  <p class="mb-4">In APK Analyzer, click on a .dex file to see a tree view of all packages and their method counts. If you're approaching the 64K limit, R8 shrinking is the primary solution:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm"># Check method count from command line
# Install dx tool (part of Android SDK build-tools)
dx --dex --output=temp.dex classes.dex 2>&1 | grep "method count"

# Or use dexcount-gradle-plugin to get method count in CI
# In build.gradle:
# apply plugin: 'com.getkeepsafe.dexcount'
# Run: ./gradlew assembleRelease
# Check: app/build/outputs/dexcount/</code></pre>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="android-apk-analyzer" relatedTags={['android', 'mobile', 'react-native', 'performance', 'play-store']} />
</BaseLayout>
