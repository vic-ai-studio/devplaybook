---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GraphQLSchemaExplorer from '../../components/GraphQLSchemaExplorer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is a GraphQL SDL schema?",
    answer: "SDL stands for Schema Definition Language — the standard text format used to define a GraphQL API. It describes every type (Query, Mutation, Object, Input, Enum, etc.), their fields, and their relationships. SDL is what you write in .graphql files or pass to tools like Apollo Server or graphql-js to build an API."
  },
  {
    question: "How do I use this GraphQL Schema Explorer?",
    answer: "Paste your SDL schema into the text area at the top. The tool instantly parses it and lists all types in the sidebar, grouped by kind (Query, Mutation, Object, Input, Enum, Scalar, Interface/Union). Click any type to see all its fields, their return types, required/optional status, and any doc-comments attached. You can also search by type name and copy individual type SDL blocks."
  },
  {
    question: "What kinds of types does the explorer support?",
    answer: "All standard GraphQL type kinds are supported: root operation types (Query, Mutation, Subscription), Object types, Input types, Enum types, Scalar types, Interface types, and Union types. Doc-comments written with triple-quotes (\"\"\" ... \"\"\") or hash comments (# ...) are also extracted and displayed."
  },
  {
    question: "How are required vs optional fields shown?",
    answer: "Fields whose type ends with an exclamation mark (!) in SDL are marked as 'required' with a red badge. Fields without the ! suffix are marked 'optional' with a grey badge. This mirrors GraphQL's own non-null notation, helping you quickly identify which fields must always be present in a response or input."
  },
  {
    question: "Can I use this tool with schemas from Apollo, Hasura, or Prisma?",
    answer: "Yes. Any valid GraphQL SDL is compatible — whether it's hand-written, generated by Apollo Server's buildSchema, exported from Hasura's introspection endpoint (convert to SDL first), or output by Prisma's nexus/pothos schema builder. The tool parses the SDL text directly, so just paste whatever SDL string you have."
  },
  {
    question: "Does this tool send my schema to a server?",
    answer: "No. The entire parser and explorer runs 100% in your browser using JavaScript. Your schema text is never sent to any server. This makes it safe to paste internal, proprietary, or production schemas without any data-leakage risk."
  },
];
---

<BaseLayout
  title="GraphQL Schema Explorer — Visualize Types, Fields & Docs"
  description="Paste a GraphQL SDL schema and instantly explore all types, queries, mutations, subscriptions, fields, and descriptions. Free, runs entirely in your browser."
  tool="GraphQL Schema Explorer, GraphQL SDL Viewer, GraphQL Type Browser"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">GraphQL Schema Explorer</h1>
  <p class="text-text-muted mb-4">Paste any GraphQL SDL schema to browse all types, fields, and descriptions. Groups Query, Mutation, Subscription, Object, Input, Enum, Scalar, and Interface types in a searchable sidebar. Click any type to inspect its fields with required/optional markers and doc-comments.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Parses SDL in your browser — no server</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Shows required/optional field markers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Extracts doc-comments from triple-quotes or #</span>
  </div>
  <GraphQLSchemaExplorer client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="GraphQL Schema Explorer" relatedTags={['graphql', 'api', 'schema', 'development']} />
</BaseLayout>
