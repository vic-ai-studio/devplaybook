---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HttpSnippetGenerator from '../../components/HttpSnippetGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="HTTP Code Snippet Generator"
  description="Generate HTTP request code snippets for cURL, JavaScript Fetch, Axios, Python requests, Go, and PHP. Configure method, URL, headers, and body. One-click copy. No signup."
  tool="HTTP Snippet Generator, cURL Generator, Fetch Code Generator, API Code Snippet"
>
  <h1 class="text-3xl font-bold mb-2">HTTP Code Snippet Generator</h1>
  <p class="text-text-muted mb-8">Enter your HTTP request — method, URL, headers, and body — and instantly get code snippets for cURL, JavaScript <code>fetch</code>, Axios, Python <code>requests</code>, Go, and PHP. Perfect for API documentation and onboarding.</p>
  <HttpSnippetGenerator client:only="preact" />
  <ToolPageCta currentTool="HTTP Code Snippet Generator" relatedTags={['http', 'api', 'curl', 'fetch', 'code']} />
</BaseLayout>
