---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Great Expectations?", answer: "Great Expectations (GX) is an open-source Python library for data quality testing. You define 'expectations' — assertions about your data — and GX validates them against your actual data. It integrates with pandas, Spark, SQLAlchemy, and cloud data warehouses. It generates HTML Data Docs reports and can be embedded in Airflow/Prefect pipelines to gate deployments when data quality fails." },
  { question: "What is dbt testing and how does it work?", answer: "dbt (data build tool) has a built-in testing framework. Tests are defined in YAML files alongside your models. Generic tests (not_null, unique, accepted_values, relationships) are built-in. Custom singular tests are SQL queries that return rows when the test fails. dbt test runs all tests and fails the build if any fail, giving you a quality gate in your CI/CD pipeline." },
  { question: "What data quality rules should I implement first?", answer: "Start with the basics: 1) not_null on primary keys and required fields. 2) unique on primary keys. 3) accepted_values on enum/status columns. 4) range checks (min_value/max_value) on numeric fields like price, age. 5) regex patterns on structured strings like email, phone, postal code. 6) referential integrity (foreign key relationships). These cover 80% of data quality issues in production pipelines." },
  { question: "How do I handle data quality failures in production?", answer: "Options: 1) Fail-fast: halt the pipeline and alert on any failure (safest). 2) Soft alert: continue but send Slack/PagerDuty notification (for non-critical pipelines). 3) Quarantine: route bad rows to a dead-letter table for manual review. 4) Auto-repair: fix known issues (trim whitespace, fill nulls with defaults) before validation. Most teams start with fail-fast for critical pipelines and soft alerts for analytics." },
  { question: "What is the difference between schema validation and data quality checks?", answer: "Schema validation checks the structure (column names, data types, nullability). Data quality checks validate the content (values are within expected ranges, formats match patterns, referential integrity holds). Both are needed: schema validation catches structural drift (upstream systems changing column types), data quality checks catch business logic violations (negative prices, future birthdates, orphaned foreign keys)." },
];
---

<BaseLayout
  title="Data Quality Rule Builder — Great Expectations & dbt Test Generator"
  description="Define data quality rules for your columns — not_null, unique, min/max, regex, allowed values. Generate Great Expectations Python code or dbt test YAML instantly."
  tool="Data Quality Rule Builder, Great Expectations Generator, dbt Test YAML Generator, Data Validation Tool, Data Quality Checker"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Data Quality Rule Builder",
    "url": "https://devplaybook.cc/tools/data-quality-rule-builder",
    "description": "Build data quality rules and generate Great Expectations or dbt test code.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Data Quality Rule Builder</h1>
  <p class="text-text-muted mb-4">Define quality rules for each column in your dataset, then generate production-ready <strong>Great Expectations</strong> Python code or <strong>dbt test YAML</strong> with one click.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 6 rule types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Great Expectations output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> dbt YAML output</span>
  </div>

  <div class="space-y-5">
    <!-- Dataset config -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="font-semibold mb-4">Dataset Configuration</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-text-muted mb-1" for="dataset-name">Dataset / Table Name</label>
          <input id="dataset-name" type="text" value="orders"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-1" for="model-name">dbt Model Name</label>
          <input id="model-name" type="text" value="stg_orders"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
        </div>
      </div>
    </div>

    <!-- Add rule -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="font-semibold mb-4">Add Quality Rule</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-3">
        <div>
          <label class="block text-xs text-text-muted mb-1" for="col-name">Column Name</label>
          <input id="col-name" type="text" placeholder="e.g. order_id"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1" for="rule-type">Rule Type</label>
          <select id="rule-type" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40">
            <option value="not_null">not_null</option>
            <option value="unique">unique</option>
            <option value="min_value">min_value</option>
            <option value="max_value">max_value</option>
            <option value="regex">regex pattern</option>
            <option value="allowed_values">allowed_values</option>
          </select>
        </div>
        <div id="rule-param-wrap">
          <label class="block text-xs text-text-muted mb-1" for="rule-param" id="rule-param-label">Parameter</label>
          <input id="rule-param" type="text" placeholder=""
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          <div id="rule-param-hint" class="text-xs text-text-muted mt-1 hidden"></div>
        </div>
      </div>
      <button id="add-rule-btn" class="bg-primary text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-primary/80 transition-colors">+ Add Rule</button>
    </div>

    <!-- Rules list -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="font-semibold mb-3">Quality Rules</h2>
      <div id="rules-list">
        <p class="text-text-muted text-sm italic" id="no-rules-msg">No rules yet. Add your first rule above.</p>
      </div>
    </div>

    <!-- Output -->
    <div id="output-section" class="hidden space-y-4">
      <div class="flex gap-3">
        <button id="gen-ge-btn" class="bg-primary text-white px-5 py-2.5 rounded-lg font-semibold hover:bg-primary/80 transition-colors text-sm">Great Expectations</button>
        <button id="gen-dbt-btn" class="bg-bg border border-border px-5 py-2.5 rounded-lg font-semibold hover:bg-primary/10 hover:border-primary/40 transition-colors text-sm">dbt YAML</button>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-semibold" id="output-title">Great Expectations</h2>
          <button id="copy-output" class="text-xs px-3 py-1 rounded-lg border border-border hover:bg-primary/10 hover:border-primary/40 transition-colors">Copy</button>
        </div>
        <pre id="code-output" class="bg-bg rounded-lg p-4 text-xs font-mono text-primary overflow-x-auto whitespace-pre-wrap max-h-96"></pre>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Data Quality Rule Builder" relatedTags={['data-quality', 'dbt', 'great-expectations', 'data', 'testing', 'data-engineering']} />
</BaseLayout>

<script is:inline>
(function () {
  var rules = [];

  var PARAM_META = {
    not_null: { show: false, label: '', hint: '' },
    unique: { show: false, label: '', hint: '' },
    min_value: { show: true, label: 'Min Value', hint: 'e.g. 0' },
    max_value: { show: true, label: 'Max Value', hint: 'e.g. 1000000' },
    regex: { show: true, label: 'Regex Pattern', hint: 'e.g. ^[A-Za-z0-9._%+\\-]+@[A-Za-z0-9.\\-]+\\.[A-Za-z]{2,}$' },
    allowed_values: { show: true, label: 'Allowed Values', hint: 'Comma-separated: active,inactive,pending' },
  };

  document.getElementById('rule-type').addEventListener('change', function () {
    updateParamUI(this.value);
  });

  function updateParamUI(ruleType) {
    var meta = PARAM_META[ruleType] || { show: false };
    var wrap = document.getElementById('rule-param-wrap');
    var hint = document.getElementById('rule-param-hint');
    document.getElementById('rule-param-label').textContent = meta.label || 'Parameter';
    document.getElementById('rule-param').placeholder = meta.hint || '';
    if (!meta.show) {
      wrap.style.visibility = 'hidden';
    } else {
      wrap.style.visibility = 'visible';
      hint.textContent = meta.hint;
      hint.classList.remove('hidden');
    }
  }
  updateParamUI('not_null');

  function renderRules() {
    var list = document.getElementById('rules-list');
    var noMsg = document.getElementById('no-rules-msg');
    var outSection = document.getElementById('output-section');
    if (rules.length === 0) {
      list.innerHTML = '';
      list.appendChild(noMsg);
      noMsg.classList.remove('hidden');
      outSection.classList.add('hidden');
      return;
    }
    noMsg.classList.add('hidden');
    outSection.classList.remove('hidden');
    list.innerHTML = '<div class="overflow-x-auto"><table class="w-full text-xs"><thead><tr class="text-text-muted border-b border-border"><th class="text-left py-2 pr-4">Column</th><th class="text-left py-2 pr-4">Rule</th><th class="text-left py-2 pr-4">Parameter</th><th class="py-2"></th></tr></thead><tbody id="rules-tbody" class="divide-y divide-border"></tbody></table></div>';
    var tbody = document.getElementById('rules-tbody');
    rules.forEach(function (r, i) {
      var tr = document.createElement('tr');
      tr.innerHTML = '<td class="py-2 pr-4 font-mono">' + r.col + '</td>'
        + '<td class="py-2 pr-4"><span class="px-2 py-0.5 rounded bg-primary/10 text-primary">' + r.type + '</span></td>'
        + '<td class="py-2 pr-4 text-text-muted font-mono">' + (r.param || '—') + '</td>'
        + '<td class="py-2"><button class="text-red-400 hover:text-red-300" data-idx="' + i + '">Remove</button></td>';
      tr.querySelector('button').addEventListener('click', function (e) {
        rules.splice(parseInt(e.target.getAttribute('data-idx')), 1);
        renderRules();
      });
      tbody.appendChild(tr);
    });
  }

  document.getElementById('add-rule-btn').addEventListener('click', function () {
    var col = document.getElementById('col-name').value.trim();
    var type = document.getElementById('rule-type').value;
    var param = document.getElementById('rule-param').value.trim();
    var meta = PARAM_META[type] || {};
    if (!col) { alert('Please enter a column name.'); return; }
    if (meta.show && !param) { alert('Please enter a parameter for this rule type.'); return; }
    rules.push({ col: col, type: type, param: meta.show ? param : '' });
    document.getElementById('col-name').value = '';
    document.getElementById('rule-param').value = '';
    renderRules();
  });

  function buildGE(datasetName) {
    var lines = [
      'import great_expectations as gx',
      '',
      'context = gx.get_context()',
      "datasource = context.sources.add_pandas('my_datasource')",
      "asset = datasource.add_dataframe_asset('" + datasetName + "')",
      '',
      '# Get validator',
      'batch_request = asset.build_batch_request(dataframe=df)',
      "suite = context.add_expectation_suite('" + datasetName + "_suite')",
      'validator = context.get_validator(',
      '    batch_request=batch_request,',
      "    expectation_suite_name='" + datasetName + "_suite'",
      ')',
      '',
      '# ─── Expectations ───',
    ];
    rules.forEach(function (r) {
      switch (r.type) {
        case 'not_null':
          lines.push("validator.expect_column_values_to_not_be_null('" + r.col + "')");
          break;
        case 'unique':
          lines.push("validator.expect_column_values_to_be_unique('" + r.col + "')");
          break;
        case 'min_value':
          lines.push("validator.expect_column_values_to_be_between('" + r.col + "', min_value=" + r.param + ")");
          break;
        case 'max_value':
          lines.push("validator.expect_column_values_to_be_between('" + r.col + "', max_value=" + r.param + ")");
          break;
        case 'regex':
          lines.push("validator.expect_column_values_to_match_regex('" + r.col + "', regex=r'" + r.param + "')");
          break;
        case 'allowed_values':
          var vals = r.param.split(',').map(function (v) { return "'" + v.trim() + "'"; });
          lines.push("validator.expect_column_values_to_be_in_set('" + r.col + "', value_set=[" + vals.join(', ') + "])");
          break;
      }
    });
    lines.push('');
    lines.push('# Save and run');
    lines.push('validator.save_expectation_suite()');
    lines.push("results = context.run_checkpoint(checkpoint_name='" + datasetName + "_checkpoint')");
    lines.push('print(results)');
    return lines.join('\n');
  }

  function buildDbt(modelName) {
    var grouped = {};
    rules.forEach(function (r) {
      if (!grouped[r.col]) grouped[r.col] = [];
      grouped[r.col].push(r);
    });

    var lines = ['version: 2', '', 'models:', '  - name: ' + modelName, '    description: "Auto-generated quality rules"', '    columns:'];
    Object.keys(grouped).forEach(function (col) {
      lines.push('      - name: ' + col);
      lines.push('        tests:');
      grouped[col].forEach(function (r) {
        switch (r.type) {
          case 'not_null':
            lines.push('          - not_null');
            break;
          case 'unique':
            lines.push('          - unique');
            break;
          case 'min_value':
            lines.push('          - dbt_utils.expression_is_true:');
            lines.push("              expression: \"" + col + " >= " + r.param + "\"");
            break;
          case 'max_value':
            lines.push('          - dbt_utils.expression_is_true:');
            lines.push("              expression: \"" + col + " <= " + r.param + "\"");
            break;
          case 'regex':
            lines.push('          - dbt_utils.expression_is_true:');
            lines.push("              expression: \"REGEXP_LIKE(" + col + ", '" + r.param + "')\"");
            break;
          case 'allowed_values':
            var vals = r.param.split(',').map(function (v) { return "              - '" + v.trim() + "'"; });
            lines.push('          - accepted_values:');
            lines.push('              values:');
            vals.forEach(function (v) { lines.push(v); });
            break;
        }
      });
    });
    return lines.join('\n');
  }

  function generateCode(mode) {
    var datasetName = document.getElementById('dataset-name').value.trim() || 'my_dataset';
    var modelName = document.getElementById('model-name').value.trim() || 'my_model';
    var code = mode === 'ge' ? buildGE(datasetName) : buildDbt(modelName);
    document.getElementById('output-title').textContent = mode === 'ge' ? 'Great Expectations' : 'dbt Test YAML';
    document.getElementById('code-output').textContent = code;
    document.getElementById('copy-output').onclick = function () {
      navigator.clipboard.writeText(code).then(function () {
        var btn = document.getElementById('copy-output');
        btn.textContent = 'Copied!';
        setTimeout(function () { btn.textContent = 'Copy'; }, 2000);
      });
    };
  }

  document.getElementById('gen-ge-btn').addEventListener('click', function () { generateCode('ge'); });
  document.getElementById('gen-dbt-btn').addEventListener('click', function () { generateCode('dbt'); });

  // Seed examples
  rules = [
    { col: 'order_id', type: 'not_null', param: '' },
    { col: 'order_id', type: 'unique', param: '' },
    { col: 'amount', type: 'min_value', param: '0' },
    { col: 'amount', type: 'max_value', param: '1000000' },
    { col: 'status', type: 'allowed_values', param: 'active,completed,cancelled,pending' },
    { col: 'email', type: 'regex', param: '^[\\w.%+\\-]+@[\\w.\\-]+\\.[A-Za-z]{2,}$' },
  ];
  renderRules();
  generateCode('ge');
})();
</script>
