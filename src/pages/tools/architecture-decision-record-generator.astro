---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is an ADR?",
    answer: "An Architecture Decision Record (ADR) is a short document that captures an important architectural decision made during a project. It records what was decided, why it was decided (context, forces, options considered), and what the consequences are. ADRs create a decision log that helps future team members understand why the system is built the way it is — not just what was built."
  },
  {
    question: "What is MADR format?",
    answer: "MADR stands for Markdown Architectural Decision Records. It is a lightweight ADR template that uses standard Markdown, making it easy to store alongside code in version control. MADR structures each record with: title, status, context/problem statement, decision drivers, considered options (with pros and cons), the decision outcome, and consequences. It is designed to be readable on GitHub/GitLab and kept in a dedicated docs/decisions/ folder."
  },
  {
    question: "When should you write an ADR?",
    answer: "Write an ADR when making a decision that: (1) is hard to reverse or expensive to change later, (2) affects multiple teams or system boundaries, (3) involves significant trade-offs between competing options, (4) solves a recurring debate — once written, the ADR closes the debate. Common triggers: choosing a database, selecting a framework, deciding on an API style, defining a caching strategy, or adopting a deployment architecture."
  },
  {
    question: "What should go in the context section?",
    answer: "The context section explains the situation that led to this decision. Describe the problem you are solving, the forces at play (performance requirements, team skill set, operational constraints, compliance needs), and any relevant background. Avoid proposing solutions here — just describe the landscape clearly so a reader with no prior context understands why a decision was needed."
  },
  {
    question: "How many options should you consider?",
    answer: "Consider at least two options — 'do nothing' (status quo) should almost always be one of them. Three to four options is a practical sweet spot: enough to show you explored the space without becoming an exhaustive research paper. For each option, note the key pros and cons (two to four points each). The goal is to show your reasoning, not to be comprehensive — readers should be able to follow your logic quickly."
  }
];
---

<BaseLayout
  title="ADR Generator — Architecture Decision Record Template (MADR Format)"
  description="Generate Architecture Decision Records in MADR format. Fill in the context, options, and decision, then copy or download your ADR as a Markdown file ready to commit to your docs/decisions/ folder."
  tool="ADR generator, architecture decision record, MADR format, architectural decision log, ADR template, software architecture documentation, decision record markdown"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Architecture Decision Record Generator",
    "url": "https://devplaybook.cc/tools/architecture-decision-record-generator",
    "description": "Generate Architecture Decision Records (ADR) in MADR format. Fill the form and get a ready-to-commit Markdown file.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Architecture Decision Record Generator</h1>
  <p class="text-text-muted mb-4">Fill in the form to generate a well-structured ADR in <a href="https://adr.github.io/madr/" target="_blank" rel="noopener" class="text-primary underline underline-offset-2">MADR format</a>. Copy or download the Markdown file and commit it to your <code class="text-xs bg-bg-card border border-border rounded px-1 py-0.5">docs/decisions/</code> folder.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> MADR-compliant Markdown output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Dynamic options with pros &amp; cons</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live preview updates as you type</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Download as .md file</span>
  </div>

  <!-- Two-column layout: form + preview -->
  <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">

    <!-- LEFT: Form -->
    <div class="space-y-5">

      <!-- Title + Status -->
      <div class="bg-bg-card border border-border rounded-lg p-5 space-y-4">
        <h2 class="text-sm font-semibold">Basic Information</h2>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1.5">ADR Number <span class="text-text-muted font-normal">(e.g. 0001)</span></label>
          <input id="adr-number" type="text" value="0001" maxlength="6"
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary font-mono" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1.5">Title <span class="text-red-400">*</span></label>
          <input id="adr-title" type="text" placeholder="Use PostgreSQL for primary data store"
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1.5">Status</label>
          <div class="flex gap-2 flex-wrap" id="status-buttons">
            <button data-status="proposed"
              class="status-btn px-3 py-1.5 rounded-full text-xs font-medium border border-yellow-400/50 text-yellow-400 bg-yellow-400/10 ring-2 ring-yellow-400">
              Proposed
            </button>
            <button data-status="accepted"
              class="status-btn px-3 py-1.5 rounded-full text-xs font-medium border border-green-400/50 text-green-400 bg-transparent hover:bg-green-400/10 transition-colors">
              Accepted
            </button>
            <button data-status="deprecated"
              class="status-btn px-3 py-1.5 rounded-full text-xs font-medium border border-gray-400/50 text-text-muted bg-transparent hover:bg-gray-400/10 transition-colors">
              Deprecated
            </button>
            <button data-status="superseded"
              class="status-btn px-3 py-1.5 rounded-full text-xs font-medium border border-red-400/50 text-red-400 bg-transparent hover:bg-red-400/10 transition-colors">
              Superseded
            </button>
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1.5">Date</label>
          <input id="adr-date" type="date"
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1.5">Deciders <span class="text-text-muted font-normal">(comma separated)</span></label>
          <input id="adr-deciders" type="text" placeholder="Alice, Bob, Carol"
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
      </div>

      <!-- Context -->
      <div class="bg-bg-card border border-border rounded-lg p-5 space-y-4">
        <h2 class="text-sm font-semibold">Context &amp; Problem</h2>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1.5">Problem Statement <span class="text-red-400">*</span></label>
          <textarea id="adr-context" rows="4" placeholder="Describe the architectural issue motivating this decision. What forces are at play? What constraints exist?"
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary resize-none"></textarea>
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1.5">Decision Drivers <span class="text-text-muted font-normal">(one per line)</span></label>
          <textarea id="adr-drivers" rows="3" placeholder="* Need for horizontal scalability&#10;* Team expertise in SQL&#10;* Compliance requirement for ACID transactions"
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary resize-none font-mono text-xs"></textarea>
        </div>
      </div>

      <!-- Options -->
      <div class="bg-bg-card border border-border rounded-lg p-5">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-semibold">Considered Options</h2>
          <button id="btn-add-option"
            class="text-xs px-3 py-1.5 bg-background border border-border rounded-lg hover:border-primary transition-colors">
            + Add Option
          </button>
        </div>
        <div id="options-list" class="space-y-4"></div>
      </div>

      <!-- Decision -->
      <div class="bg-bg-card border border-border rounded-lg p-5 space-y-4">
        <h2 class="text-sm font-semibold">Decision Outcome</h2>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1.5">Chosen Option <span class="text-red-400">*</span></label>
          <input id="adr-chosen" type="text" placeholder='Option name, e.g. "PostgreSQL"'
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1.5">Justification</label>
          <textarea id="adr-justification" rows="3" placeholder="Because it best satisfies the decision drivers by…"
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary resize-none"></textarea>
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1.5">Consequences <span class="text-text-muted font-normal">(one per line — prefix + for good, - for bad, ~ for neutral)</span></label>
          <textarea id="adr-consequences" rows="4" placeholder="+ Good: Mature ecosystem with strong tooling&#10;- Bad: Operational overhead of managing a stateful service&#10;~ Neutral: Team will need to learn connection pooling"
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary resize-none font-mono text-xs"></textarea>
        </div>
      </div>

      <!-- Links -->
      <div class="bg-bg-card border border-border rounded-lg p-5 space-y-4">
        <h2 class="text-sm font-semibold">Links &amp; References <span class="text-xs font-normal text-text-muted">(optional)</span></h2>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1.5">Related ADRs / Links <span class="text-text-muted font-normal">(one per line)</span></label>
          <textarea id="adr-links" rows="3" placeholder="* Supersedes ADR-0003 — Use MySQL for all databases&#10;* Related to ADR-0007 — Deployment strategy"
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary resize-none font-mono text-xs"></textarea>
        </div>
      </div>
    </div>

    <!-- RIGHT: Live Preview -->
    <div class="xl:sticky xl:top-4 self-start">
      <div class="bg-bg-card border border-border rounded-lg overflow-hidden">
        <div class="flex items-center justify-between px-4 py-3 border-b border-border">
          <span class="text-sm font-medium">Live Preview</span>
          <div class="flex gap-2">
            <button id="btn-copy-md"
              class="px-3 py-1.5 bg-primary text-white rounded-lg text-xs font-medium hover:bg-primary/90 transition-colors">
              Copy Markdown
            </button>
            <button id="btn-download-md"
              class="px-3 py-1.5 bg-background border border-border rounded-lg text-xs hover:border-primary transition-colors">
              Download .md
            </button>
          </div>
        </div>
        <div class="relative">
          <pre id="md-preview"
            class="p-4 text-xs font-mono text-text-muted overflow-auto whitespace-pre-wrap break-words"
            style="max-height: 700px; min-height: 300px;"></pre>
        </div>
      </div>
    </div>
  </div>

  <!-- Copy toast -->
  <div id="copy-toast" class="hidden fixed bottom-6 left-1/2 -translate-x-1/2 bg-green-600 text-white text-sm px-5 py-2.5 rounded-full shadow-lg z-50">
    Copied to clipboard!
  </div>

  <ToolPageCta />
  <FaqSection faq={faq} />

</BaseLayout>

<script>
// =====================================================================
// ADR Generator — vanilla JS, self-contained
// =====================================================================

let currentStatus = 'proposed';
let optionCounter = 0;

const STATUS_STYLES = {
  proposed:   { ring: 'ring-yellow-400', bg: 'bg-yellow-400/10', text: 'text-yellow-400', border: 'border-yellow-400/50' },
  accepted:   { ring: 'ring-green-400',  bg: 'bg-green-400/10',  text: 'text-green-400',  border: 'border-green-400/50' },
  deprecated: { ring: 'ring-gray-400',   bg: 'bg-gray-400/10',   text: 'text-text-muted', border: 'border-gray-400/50' },
  superseded: { ring: 'ring-red-400',    bg: 'bg-red-400/10',    text: 'text-red-400',    border: 'border-red-400/50' },
};

function val(id) {
  const el = document.getElementById(id);
  return el ? el.value.trim() : '';
}

function generateMarkdown() {
  const number = val('adr-number') || '0001';
  const title = val('adr-title') || 'Untitled Decision';
  const date = val('adr-date') || new Date().toISOString().split('T')[0];
  const deciders = val('adr-deciders');
  const context = val('adr-context');
  const drivers = val('adr-drivers');
  const chosen = val('adr-chosen');
  const justification = val('adr-justification');
  const consequences = val('adr-consequences');
  const links = val('adr-links');

  const statusLabel = currentStatus.charAt(0).toUpperCase() + currentStatus.slice(1);

  // Collect options
  const optRows = document.querySelectorAll('.option-block');
  const options = Array.from(optRows).map(row => ({
    name: (row.querySelector('.opt-name')).value.trim() || 'Option',
    pros: (row.querySelector('.opt-pros')).value.trim(),
    cons: (row.querySelector('.opt-cons')).value.trim(),
  }));

  let md = '';
  md += `# ${number}. ${title}\n\n`;
  md += `Date: ${date}\n\n`;
  md += `## Status\n\n${statusLabel}\n\n`;

  if (deciders) {
    md += `## Deciders\n\n${deciders}\n\n`;
  }

  md += `## Context and Problem Statement\n\n`;
  md += context || '_Describe the context and problem here._';
  md += '\n\n';

  if (drivers.trim()) {
    md += `## Decision Drivers\n\n${formatBullets(drivers)}\n\n`;
  }

  if (options.length > 0) {
    md += `## Considered Options\n\n`;
    options.forEach(o => {
      md += `* ${o.name}\n`;
    });
    md += '\n';
  }

  md += `## Decision Outcome\n\n`;
  if (chosen) {
    md += `Chosen option: **"${chosen}"**`;
    if (justification) md += `, because ${justification}`;
    md += '\n\n';
  } else {
    md += '_State the chosen option and the reason for picking it._\n\n';
  }

  if (consequences.trim()) {
    md += `### Consequences\n\n${formatBullets(consequences)}\n\n`;
  }

  if (options.length > 0) {
    md += `## Pros and Cons of the Options\n\n`;
    options.forEach(o => {
      md += `### ${o.name}\n\n`;
      if (o.pros.trim()) {
        o.pros.split('\n').filter(l => l.trim()).forEach(l => {
          md += `* Good, because ${l.replace(/^\*?\s*/, '')}\n`;
        });
      }
      if (o.cons.trim()) {
        o.cons.split('\n').filter(l => l.trim()).forEach(l => {
          md += `* Bad, because ${l.replace(/^\*?\s*/, '')}\n`;
        });
      }
      md += '\n';
    });
  }

  if (links.trim()) {
    md += `## Links\n\n${formatBullets(links)}\n\n`;
  }

  return md;
}

function formatBullets(text) {
  return text.split('\n')
    .filter(l => l.trim())
    .map(l => l.startsWith('*') || l.startsWith('-') ? l : `* ${l}`)
    .join('\n');
}

function updatePreview() {
  const preview = document.getElementById('md-preview');
  if (preview) preview.textContent = generateMarkdown();
}

function addOption(name = '', pros = '', cons = '') {
  const list = document.getElementById('options-list');
  if (!list) return;
  const id = ++optionCounter;

  const block = document.createElement('div');
  block.className = 'option-block bg-background border border-border rounded-lg p-4 space-y-3';
  block.dataset.optId = id;
  block.innerHTML = `
    <div class="flex items-center justify-between">
      <label class="text-xs font-medium text-text-muted">Option Name</label>
      <button class="opt-remove text-xs text-red-400 hover:text-red-300 transition-colors">Remove</button>
    </div>
    <input type="text" value="${escapeAttr(name)}" placeholder='e.g. "PostgreSQL"'
      class="opt-name w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <div>
        <label class="block text-xs font-medium text-text-muted mb-1">Pros (one per line)</label>
        <textarea rows="3" placeholder="Mature ecosystem&#10;Strong ACID guarantees&#10;Great tooling" class="opt-pros w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-xs font-mono focus:outline-none focus:border-primary resize-none">${escapeHtml(pros)}</textarea>
      </div>
      <div>
        <label class="block text-xs font-medium text-text-muted mb-1">Cons (one per line)</label>
        <textarea rows="3" placeholder="Requires dedicated ops&#10;Higher memory usage" class="opt-cons w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-xs font-mono focus:outline-none focus:border-primary resize-none">${escapeHtml(cons)}</textarea>
      </div>
    </div>
  `;

  block.querySelector('.opt-remove')?.addEventListener('click', () => {
    block.remove();
    updatePreview();
  });

  block.querySelectorAll('input, textarea').forEach(el => {
    el.addEventListener('input', updatePreview);
  });

  list.appendChild(block);
  updatePreview();
}

function escapeHtml(s) {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}
function escapeAttr(s) {
  return s.replace(/"/g, '&quot;');
}

function showToast() {
  const toast = document.getElementById('copy-toast');
  toast?.classList.remove('hidden');
  setTimeout(() => toast?.classList.add('hidden'), 2500);
}

function wireInputs() {
  ['adr-number','adr-title','adr-date','adr-deciders','adr-context','adr-drivers',
   'adr-chosen','adr-justification','adr-consequences','adr-links'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', updatePreview);
  });
}

document.addEventListener('DOMContentLoaded', () => {
  // Set today's date
  const dateInput = document.getElementById('adr-date');
  if (dateInput) dateInput.value = new Date().toISOString().split('T')[0];

  wireInputs();

  // Example content
  const titleEl = document.getElementById('adr-title');
  if (titleEl) titleEl.value = 'Use PostgreSQL for primary data store';
  const ctxEl = document.getElementById('adr-context');
  if (ctxEl) ctxEl.value = 'The application needs a reliable relational database to store user accounts, posts, and transactional data. We need to choose a database system that the team can operate and that meets our scalability and consistency requirements.';
  const driversEl = document.getElementById('adr-drivers');
  if (driversEl) driversEl.value = '* ACID compliance is required for financial transactions\n* Team has strong SQL expertise\n* Must support JSON columns for flexible metadata';
  const chosenEl = document.getElementById('adr-chosen');
  if (chosenEl) chosenEl.value = 'PostgreSQL';
  const justEl = document.getElementById('adr-justification');
  if (justEl) justEl.value = 'it fulfills all decision drivers, has the strongest ACID guarantees, and the team is already proficient with it.';
  const consEl = document.getElementById('adr-consequences');
  if (consEl) consEl.value = '+ Good: Battle-tested with strong community support\n+ Good: Excellent JSON/JSONB support for semi-structured data\n- Bad: Requires stateful infrastructure and backup strategy\n~ Neutral: Team will need to configure connection pooling (PgBouncer)';

  // Default options
  addOption('PostgreSQL', 'ACID compliant\nMature ecosystem\nGood JSON support', 'Requires ops overhead\nMore complex than NoSQL for simple cases');
  addOption('MySQL', 'Widely known\nLarge hosting support', 'Weaker JSON support\nHistorically looser ACID semantics');
  addOption('MongoDB', 'Flexible schema\nGood horizontal scaling', 'No ACID transactions across collections (older versions)\nTeam unfamiliar with it');

  // Status buttons
  document.querySelectorAll('.status-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      currentStatus = btn.dataset.status || 'proposed';
      document.querySelectorAll('.status-btn').forEach(b => {
        const s = b.dataset.status || 'proposed';
        const style = STATUS_STYLES[s];
        b.className = `status-btn px-3 py-1.5 rounded-full text-xs font-medium border ${style.border} ${style.text} bg-transparent hover:${style.bg} transition-colors`;
      });
      const activeStyle = STATUS_STYLES[currentStatus];
      btn.className = `status-btn px-3 py-1.5 rounded-full text-xs font-medium border ${activeStyle.border} ${activeStyle.text} ${activeStyle.bg} ring-2 ${activeStyle.ring}`;
      updatePreview();
    });
  });

  // Add option button
  document.getElementById('btn-add-option')?.addEventListener('click', () => addOption());

  // Copy markdown
  document.getElementById('btn-copy-md')?.addEventListener('click', () => {
    navigator.clipboard.writeText(generateMarkdown()).then(showToast);
  });

  // Download .md
  document.getElementById('btn-download-md')?.addEventListener('click', () => {
    const md = generateMarkdown();
    const num = val('adr-number') || '0001';
    const slug = (val('adr-title') || 'decision').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    const filename = `${num}-${slug}.md`;
    const blob = new Blob([md], { type: 'text/markdown' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    a.click();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  });

  updatePreview();
});
</script>
