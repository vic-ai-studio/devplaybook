          <tr><td class="py-3 pr-4 font-medium text-text">Pipeline model</td><td class="py-3 pr-4 text-green-500">Explicit component graph</td><td class="py-3 pr-4">LCEL pipe chains</td><td class="py-3 pr-4">Index + query engines</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Hybrid retrieval</td><td class="py-3 pr-4 text-green-500">Native (DocumentJoiner)</td><td class="py-3 pr-4">Manual assembly</td><td class="py-3 pr-4">Good</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Testability</td><td class="py-3 pr-4 text-green-500">Excellent (unit test components)</td><td class="py-3 pr-4">Good</td><td class="py-3 pr-4">Good</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Agent support</td><td class="py-3 pr-4">Basic</td><td class="py-3 pr-4 text-green-500">Excellent</td><td class="py-3 pr-4">Good</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">LLM integrations</td><td class="py-3 pr-4">30+</td><td class="py-3 pr-4 text-green-500">100+</td><td class="py-3 pr-4">50+</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Enterprise features</td><td class="py-3 pr-4 text-green-500">Deepset Cloud, eval, fine-tune</td><td class="py-3 pr-4">LangSmith</td><td class="py-3 pr-4">LlamaCloud</td></tr>
          <tr><td class="py-3 pr-4 font-medium text-text">Best for</td><td class="py-3 pr-4">Enterprise NLP, production RAG</td><td class="py-3 pr-4">Agents, rapid prototyping</td><td class="py-3 pr-4">Complex document RAG</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <FaqSection faq={faq} />
