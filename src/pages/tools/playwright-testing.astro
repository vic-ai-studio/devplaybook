---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is Playwright and how does it differ from Cypress?", answer: "Playwright is an end-to-end browser automation library developed by Microsoft. Unlike Cypress, which runs inside the browser using JavaScript injection, Playwright controls browsers through the Chrome DevTools Protocol (Chromium), Firefox's remote protocol, and WebKit's inspector protocol — giving it true cross-browser support including Safari (WebKit). Playwright also supports multiple tabs, iframes, file downloads, and network interception natively." },
  { question: "Which browsers does Playwright support?", answer: "Playwright bundles three browser engines: Chromium (covering Chrome and Edge), Firefox, and WebKit (covering Safari). You can run tests against all three with a single test file. Playwright also supports headed mode (visible browser window), headless mode (CI), and a persistent context that preserves browser state between tests. Mobile device emulation is built in via device descriptors." },
  { question: "What is Playwright's auto-wait feature?", answer: "Playwright automatically waits for elements to be visible, enabled, and stable before interacting with them. When you call page.click() on a locator, Playwright polls until the element exists in the DOM, is visible, is not obscured, is enabled, and has stable position — then clicks it. This eliminates most explicit waitForSelector and sleep calls that plague Selenium test suites." },
  { question: "What is Playwright Codegen?", answer: "Playwright Codegen is a code recorder that generates Playwright test code by watching your manual interactions in a browser. Run npx playwright codegen https://example.com to open a browser where every click, type, and navigation generates the corresponding Playwright code in a panel. It's an excellent starting point for new test files, though generated code usually needs cleanup and assertions added." },
  { question: "How does Playwright's Trace Viewer work?", answer: "The Trace Viewer is a post-mortem debugging tool. When a test fails, Playwright can save a trace file containing a timeline of every action, screenshots before and after each step, DOM snapshots, network logs, and console output. Open it with npx playwright show-trace trace.zip or in the Playwright VS Code extension. Traces make CI failures debuggable without re-running the test." },
  { question: "Can Playwright test APIs without a browser?", answer: "Yes. Playwright's APIRequestContext lets you make HTTP requests directly, bypassing the browser. Use playwright.request.get(url) or request.post(url, { data: {} }) within your test fixtures. This is useful for seeding test data via API before UI tests, or for pure API contract testing as part of an E2E suite without the overhead of a full browser page." },
];
---

<BaseLayout
  title="Playwright E2E Testing Guide — Browser Automation Reference"
  description="Complete Playwright guide covering installation, locators, auto-wait, fixtures, trace viewer, codegen, and API testing. Compare Playwright vs Cypress vs Selenium. Free developer reference."
  tool="Playwright testing guide, Playwright locators, Playwright fixtures, Playwright trace viewer, E2E testing, browser automation"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Playwright E2E Testing Guide",
    "url": "https://devplaybook.cc/tools/playwright-testing",
    "description": "Complete guide to Playwright — Microsoft's modern E2E browser automation framework. Covers locators, auto-wait, fixtures, trace viewer, codegen, and API testing.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Playwright E2E Testing Guide</h1>
  <p class="text-text-muted mb-6">
    The complete reference for <strong>Playwright</strong> — Microsoft's modern end-to-end testing framework. Covers locators, auto-wait, fixtures, trace viewer, codegen, multi-browser support, and API testing.
  </p>

  <div class="flex items-center gap-3 mb-8 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Chromium, Firefox, WebKit</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auto-wait built-in</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Trace viewer</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Codegen recorder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> API testing support</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Playwright?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Playwright is a modern end-to-end browser automation framework developed by Microsoft. Released in 2020, it quickly became the preferred choice for teams that needed reliable cross-browser E2E tests without Selenium's verbosity or Cypress's single-tab limitation. Playwright controls real browser instances through low-level protocols — the Chrome DevTools Protocol for Chromium, Firefox's Remote Protocol, and WebKit's inspector — giving it deep access to browser internals.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    The framework's killer features are auto-waiting (no more flaky explicit waits), resilient locators (CSS selectors, ARIA roles, text), and first-class tooling: Trace Viewer for post-mortem debugging, Codegen for recording interactions as test code, and a VS Code extension for running and debugging tests with full IDE integration.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Installation</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Install Playwright with browser binaries
npm init playwright@latest

# Or manually
npm install --save-dev @playwright/test
npx playwright install

# playwright.config.ts
import { defineConfig, devices } from '@playwright/test';

export default defineConfig({
  testDir: './tests/e2e',
  use: {
    baseURL: 'http://localhost:3000',
    trace: 'on-first-retry',
    screenshot: 'only-on-failure',
  },
  projects: [
    { name: 'chromium', use: { ...devices['Desktop Chrome'] } },
    { name: 'firefox',  use: { ...devices['Desktop Firefox'] } },
    { name: 'webkit',   use: { ...devices['Desktop Safari'] } },
  ],
});</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Core Test Structure: page.goto &amp; Locators</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">import { test, expect } from '@playwright/test';

test('user can log in', async ({ page }) => {
  await page.goto('/login');

  // Prefer ARIA-role locators for resilience
  await page.getByLabel('Email').fill('user@example.com');
  await page.getByLabel('Password').fill('secret');
  await page.getByRole('button', { name: 'Sign in' }).click();

  // Assert navigation happened
  await expect(page).toHaveURL('/dashboard');
  await expect(page.getByRole('heading', { name: 'Dashboard' })).toBeVisible();
});

test('shows validation error for empty email', async ({ page }) => {
  await page.goto('/login');
  await page.getByRole('button', { name: 'Sign in' }).click();
  await expect(page.getByText('Email is required')).toBeVisible();
});</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Fixtures: Sharing Setup Across Tests</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// fixtures.ts
import { test as base, expect } from '@playwright/test';

type Fixtures = { authenticatedPage: Page };

export const test = base.extend&lt;Fixtures&gt;({
  authenticatedPage: async ({ page }, use) => {
    // Reusable login before each test
    await page.goto('/login');
    await page.getByLabel('Email').fill('test@example.com');
    await page.getByLabel('Password').fill('password');
    await page.getByRole('button', { name: 'Sign in' }).click();
    await page.waitForURL('/dashboard');

    await use(page); // test runs here

    // Teardown (optional)
    await page.goto('/logout');
  },
});

export { expect };

// In your test file
import { test, expect } from './fixtures';

test('dashboard loads user data', async ({ authenticatedPage: page }) => {
  await expect(page.getByText('Welcome back')).toBeVisible();
});</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Network Interception &amp; API Testing</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// Intercept network requests
test('handles API error gracefully', async ({ page }) => {
  await page.route('/api/users', route =>
    route.fulfill({ status: 500, body: 'Internal Server Error' })
  );

  await page.goto('/users');
  await expect(page.getByText('Something went wrong')).toBeVisible();
});

// Pure API testing (no browser)
test('POST /api/products returns 201', async ({ request }) => {
  const response = await request.post('/api/products', {
    data: { name: 'Widget', price: 9.99 },
    headers: { Authorization: &#96;Bearer &#36;{process.env.API_TOKEN}&#96; },
  });

  expect(response.status()).toBe(201);
  const body = await response.json();
  expect(body).toMatchObject({ id: expect.any(String), name: 'Widget' });
});</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Auto-wait</strong> — all actions wait for element readiness automatically, eliminating flaky sleeps</li>
    <li><strong>Trace Viewer</strong> — replay failing tests with full DOM snapshots and network logs</li>
    <li><strong>Codegen</strong> — record manual interactions as test code with <code class="bg-bg-card px-1 rounded text-xs">npx playwright codegen</code></li>
    <li><strong>Multi-browser</strong> — Chromium, Firefox, and WebKit in a single test file</li>
    <li><strong>Mobile emulation</strong> — device descriptors for responsive testing</li>
    <li><strong>Parallel execution</strong> — tests run in parallel workers by default</li>
    <li><strong>API testing</strong> — HTTP requests without a browser via request fixture</li>
    <li><strong>VS Code extension</strong> — run, debug, and record tests from the editor</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Use Cases</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Authentication flows</strong> — login, OAuth, session management, MFA</li>
    <li><strong>Form submissions</strong> — validation, file uploads, multi-step wizards</li>
    <li><strong>Cross-browser regression</strong> — ensure features work in Chrome, Firefox, and Safari</li>
    <li><strong>API contract testing</strong> — verify backend responses as part of E2E suite</li>
    <li><strong>Visual regression</strong> — screenshot comparison with <code class="bg-bg-card px-1 rounded text-xs">toHaveScreenshot()</code></li>
    <li><strong>Accessibility testing</strong> — ARIA role locators catch missing accessibility attributes</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Comparison: Playwright vs Alternatives</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse mb-6">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">Playwright</th>
          <th class="border border-border px-3 py-2 text-left">Cypress</th>
          <th class="border border-border px-3 py-2 text-left">Selenium</th>
          <th class="border border-border px-3 py-2 text-left">Puppeteer</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-border px-3 py-2">Browser support</td>
          <td class="border border-border px-3 py-2 text-green-400">Chromium+FF+WebKit</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Chrome+Firefox+Edge</td>
          <td class="border border-border px-3 py-2 text-green-400">All browsers</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Chromium only</td>
        </tr>
        <tr class="bg-bg-card/50">
          <td class="border border-border px-3 py-2">Auto-wait</td>
          <td class="border border-border px-3 py-2 text-green-400">Built-in</td>
          <td class="border border-border px-3 py-2 text-green-400">Built-in</td>
          <td class="border border-border px-3 py-2 text-red-400">Manual</td>
          <td class="border border-border px-3 py-2 text-red-400">Manual</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">Multi-tab support</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes</td>
        </tr>
        <tr class="bg-bg-card/50">
          <td class="border border-border px-3 py-2">Trace/debug tooling</td>
          <td class="border border-border px-3 py-2 text-green-400">Trace Viewer</td>
          <td class="border border-border px-3 py-2 text-green-400">Time-travel debug</td>
          <td class="border border-border px-3 py-2 text-red-400">Basic</td>
          <td class="border border-border px-3 py-2 text-red-400">None</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">API testing</td>
          <td class="border border-border px-3 py-2 text-green-400">Built-in</td>
          <td class="border border-border px-3 py-2 text-green-400">cy.request()</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
        </tr>
        <tr class="bg-bg-card/50">
          <td class="border border-border px-3 py-2">Language support</td>
          <td class="border border-border px-3 py-2 text-green-400">JS/TS/Python/Java/C#</td>
          <td class="border border-border px-3 py-2 text-yellow-400">JS/TS only</td>
          <td class="border border-border px-3 py-2 text-green-400">Many languages</td>
          <td class="border border-border px-3 py-2 text-yellow-400">JS/TS only</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pros &amp; Cons</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-green-400 mb-2">Pros</h3>
      <ul class="list-disc list-inside text-text-muted space-y-1 text-sm">
        <li>True cross-browser including WebKit/Safari</li>
        <li>Auto-wait eliminates most flakiness</li>
        <li>Trace Viewer makes CI failures debuggable</li>
        <li>Multi-tab and iframe support out of the box</li>
        <li>Supports multiple programming languages</li>
        <li>Strong Microsoft backing and rapid development</li>
      </ul>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-red-400 mb-2">Cons</h3>
      <ul class="list-disc list-inside text-text-muted space-y-1 text-sm">
        <li>Large binary downloads for browser engines</li>
        <li>Steeper learning curve than Cypress for beginners</li>
        <li>No component testing (Cypress has this)</li>
        <li>Test isolation is per-file, not per-test by default</li>
        <li>Less visual feedback during test execution than Cypress</li>
      </ul>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Playwright E2E Testing Guide" relatedTags={['playwright', 'e2e-testing', 'automation', 'testing', 'developer-tools']} />
</BaseLayout>
