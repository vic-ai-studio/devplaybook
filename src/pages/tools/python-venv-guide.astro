---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "Which Python virtual environment tool should I use in 2025?", answer: "For most new projects in 2025: use uv. It's 10-100x faster than pip, manages Python versions (no pyenv needed), creates virtual environments, and supports lock files. For library publishing to PyPI, Poetry's dependency groups and publish workflow remain excellent. For ML/GPU work that needs non-Python binaries (CUDA, GDAL), conda is still valuable. For simple scripts, the built-in venv is perfectly adequate." },
  { question: "What is the difference between venv and virtualenv?", answer: "venv is built into Python 3.3+ as a standard library module — no installation needed. virtualenv is a third-party tool that predates venv, offering more features like cross-Python-version environments and faster creation. For most use cases, the built-in venv is sufficient. virtualenv is commonly used under the hood by other tools like tox and pipenv." },
  { question: "Why is uv so much faster than pip?", answer: "uv is written in Rust by Astral (creators of ruff). It uses a parallel dependency resolver that downloads and installs packages concurrently, implements aggressive caching, and avoids Python startup overhead. A fresh install of a large package set that takes 30+ seconds with pip often completes in under 2 seconds with uv." },
  { question: "Should I commit my virtual environment to git?", answer: "No — never commit the venv/ or .venv/ folder to git. Virtual environments are local and platform-specific; they contain binary files and absolute paths that won't work on another machine. Add venv/, .venv/, env/ to .gitignore. Instead, commit requirements.txt (pip), pyproject.toml + poetry.lock (Poetry), or uv.lock (uv) so others can reproduce the exact environment." },
  { question: "What is the difference between requirements.txt and pyproject.toml?", answer: "requirements.txt is a flat list of pinned dependencies — simple and universal but lacks metadata about your project. pyproject.toml is the modern PEP 517/518 standard that combines project metadata, dependencies, build configuration, and tool settings (ruff, pytest, mypy) in one file. pip can read both; uv, Poetry, Hatch, and PDM all use pyproject.toml. New projects should prefer pyproject.toml." },
];

const tools = [
  {
    name: 'venv',
    tagline: 'Built-in — no install needed',
    speed: '🟡 Medium',
    lockFile: '❌',
    pyVersionMgmt: '❌',
    pypiPublish: '❌',
    idealFor: 'Simple scripts, learning Python, CI environments',
    create: 'python -m venv .venv',
    activate: 'source .venv/bin/activate  # Linux/Mac\n.venv\\Scripts\\activate  # Windows',
    install: 'pip install requests',
    freeze: 'pip freeze > requirements.txt',
    color: 'blue',
  },
  {
    name: 'uv',
    tagline: 'Rust-powered — 100x faster than pip',
    speed: '🟢 Very Fast',
    lockFile: '✅ uv.lock',
    pyVersionMgmt: '✅',
    pypiPublish: '✅',
    idealFor: 'All new projects, fast CI, replacing pip+venv+pyenv',
    create: 'uv venv .venv',
    activate: 'source .venv/bin/activate',
    install: 'uv add requests',
    freeze: 'uv lock',
    color: 'green',
  },
  {
    name: 'Poetry',
    tagline: 'Dependency management + packaging',
    speed: '🟡 Medium',
    lockFile: '✅ poetry.lock',
    pyVersionMgmt: '⚠️ via pyenv',
    pypiPublish: '✅ Excellent',
    idealFor: 'Library authors, complex dependency groups, PyPI publishing',
    create: 'poetry new my-project',
    activate: 'poetry shell',
    install: 'poetry add requests',
    freeze: 'poetry lock',
    color: 'purple',
  },
  {
    name: 'conda',
    tagline: 'Scientific computing & non-Python binaries',
    speed: '🔴 Slow',
    lockFile: '⚠️ environment.yml',
    pyVersionMgmt: '✅',
    pypiPublish: '❌',
    idealFor: 'ML/GPU projects (CUDA, PyTorch), bioinformatics, GDAL',
    create: 'conda create -n myenv python=3.11',
    activate: 'conda activate myenv',
    install: 'conda install numpy',
    freeze: 'conda env export > environment.yml',
    color: 'yellow',
  },
  {
    name: 'Pipenv',
    tagline: 'pip + venv + Pipfile in one',
    speed: '🟡 Medium',
    lockFile: '✅ Pipfile.lock',
    pyVersionMgmt: '⚠️ via pyenv',
    pypiPublish: '❌',
    idealFor: 'Teams familiar with npm-style workflow, legacy projects',
    create: 'pipenv install',
    activate: 'pipenv shell',
    install: 'pipenv install requests',
    freeze: 'pipenv lock',
    color: 'orange',
  },
];
---

<BaseLayout
  title="Python Virtual Environment Guide — venv vs uv vs Poetry vs conda 2025"
  description="Compare Python virtual environment tools: venv, uv, Poetry, conda, and Pipenv. Setup commands, pros/cons, lock file support, and which to choose for your project type in 2025."
  tool="Python venv guide, uv vs Poetry vs conda, Python virtual environment comparison, pip vs uv, Python environment manager 2025"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Python Virtual Environment Guide 2025</h1>
  <p class="text-text-muted mb-4">
    Compare <strong>venv, uv, Poetry, conda, and Pipenv</strong> — setup commands, lock file support, Python version management, and when to use each.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 tools compared</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Exact setup commands</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Use-case recommendations</span>
  </div>

  <!-- Recommendation widget -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-3">Get a Recommendation</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-4">
      <div>
        <label class="text-xs text-text-muted block mb-1">Project type</label>
        <select id="proj-type" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="app">Web app / backend service</option>
          <option value="lib">Library (publishing to PyPI)</option>
          <option value="ml">ML / data science</option>
          <option value="script">Script / automation</option>
          <option value="team">Team project</option>
        </select>
      </div>
      <div>
        <label class="text-xs text-text-muted block mb-1">Speed priority</label>
        <select id="speed-prio" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="high">Very important (fast CI)</option>
          <option value="medium">Moderate</option>
          <option value="low">Not critical</option>
        </select>
      </div>
      <div>
        <label class="text-xs text-text-muted block mb-1">GPU / non-Python deps?</label>
        <select id="has-gpu" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="no">No</option>
          <option value="yes">Yes (CUDA, PyTorch, GDAL...)</option>
        </select>
      </div>
    </div>
    <div id="recommendation" class="bg-primary/10 border border-primary/30 rounded-lg p-4 text-sm"></div>
  </div>

  <!-- Comparison table -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6 overflow-x-auto">
    <h2 class="text-base font-semibold mb-4">Comparison Table</h2>
    <table class="w-full text-sm min-w-[600px]">
      <thead>
        <tr class="border-b border-border text-left">
          <th class="pb-2 font-medium">Tool</th>
          <th class="pb-2 font-medium">Speed</th>
          <th class="pb-2 font-medium">Lock File</th>
          <th class="pb-2 font-medium">Py Version Mgmt</th>
          <th class="pb-2 font-medium">PyPI Publish</th>
          <th class="pb-2 font-medium">Best For</th>
        </tr>
      </thead>
      <tbody>
        {tools.map(t => (
          <tr class="border-b border-border/50 last:border-0">
            <td class="py-2.5 font-semibold font-mono">{t.name}</td>
            <td class="py-2.5">{t.speed}</td>
            <td class="py-2.5">{t.lockFile}</td>
            <td class="py-2.5">{t.pyVersionMgmt}</td>
            <td class="py-2.5">{t.pypiPublish}</td>
            <td class="py-2.5 text-text-muted text-xs">{t.idealFor}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Per-tool command cards -->
  <div class="mb-6">
    <div class="flex gap-2 mb-4 flex-wrap" id="tool-tabs">
      {tools.map((t, i) => (
        <button class={`px-4 py-1.5 rounded-lg text-sm font-medium border transition-colors tool-tab ${i === 0 ? 'bg-primary text-white border-primary' : 'border-border hover:bg-bg-page'}`} data-tool={i}>
          {t.name}
        </button>
      ))}
    </div>
    {tools.map((t, i) => (
      <div class={`tool-panel ${i !== 0 ? 'hidden' : ''}`} data-panel={i}>
        <div class="bg-bg-card border border-border rounded-xl p-5">
          <div class="flex items-start justify-between mb-4">
            <div>
              <h3 class="text-lg font-bold font-mono">{t.name}</h3>
              <p class="text-text-muted text-sm">{t.tagline}</p>
            </div>
            <span class="text-sm">{t.speed}</span>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {[
              { label: 'Create environment', code: t.create },
              { label: 'Activate', code: t.activate },
              { label: 'Install package', code: t.install },
              { label: 'Lock dependencies', code: t.freeze },
            ].map(({ label, code }) => (
              <div>
                <p class="text-xs text-text-muted mb-1">{label}</p>
                <pre class="bg-bg-page border border-border rounded-lg px-3 py-2 text-xs font-mono overflow-x-auto">{code}</pre>
              </div>
            ))}
          </div>
          <div class="mt-4 pt-4 border-t border-border">
            <p class="text-xs text-text-muted"><strong>Ideal for:</strong> {t.idealFor}</p>
          </div>
        </div>
      </div>
    ))}
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Python Virtual Environment Guide" relatedTags={['python', 'venv', 'uv', 'poetry', 'conda', 'backend']} />
</BaseLayout>

<script is:inline>
// Recommendation logic
const recommendations = {
  app: { no: { high: 'uv', medium: 'uv', low: 'uv' }, yes: { high: 'conda', medium: 'conda', low: 'conda' } },
  lib: { no: { high: 'uv', medium: 'Poetry', low: 'Poetry' }, yes: { high: 'uv', medium: 'Poetry', low: 'Poetry' } },
  ml: { no: { high: 'uv', medium: 'uv', low: 'Poetry' }, yes: { high: 'conda', medium: 'conda', low: 'conda' } },
  script: { no: { high: 'uv', medium: 'venv', low: 'venv' }, yes: { high: 'conda', medium: 'conda', low: 'venv' } },
  team: { no: { high: 'uv', medium: 'uv', low: 'Poetry' }, yes: { high: 'conda', medium: 'conda', low: 'conda' } },
};

const notes = {
  uv: 'uv is the recommended choice for most new Python projects in 2025. It replaces pip, venv, and pyenv with a single fast Rust-based tool.',
  Poetry: 'Poetry is ideal for library authors. Its dependency groups and pyproject.toml integration make publishing to PyPI straightforward.',
  conda: 'conda is best for scientific computing where you need non-Python binaries like CUDA, cuDNN, or GDAL alongside Python packages.',
  venv: 'The built-in venv is simple and always available. Pair it with pip and requirements.txt for minimal overhead.',
  Pipenv: 'Pipenv provides an npm-like experience. Consider uv instead for new projects — it\'s faster and more actively maintained.',
};

function updateRec() {
  const proj = document.getElementById('proj-type').value;
  const speed = document.getElementById('speed-prio').value;
  const gpu = document.getElementById('has-gpu').value;
  const rec = recommendations[proj]?.[gpu]?.[speed] || 'uv';
  document.getElementById('recommendation').innerHTML = `
    <p class="font-semibold mb-1">Recommended: <span class="text-primary font-mono">${rec}</span></p>
    <p class="text-text-muted text-xs">${notes[rec]}</p>
  `;
}

['proj-type', 'speed-prio', 'has-gpu'].forEach(id => {
  document.getElementById(id)?.addEventListener('change', updateRec);
});
updateRec();

// Tab switching
document.querySelectorAll('.tool-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.tool-tab').forEach(t => t.classList.remove('bg-primary', 'text-white', 'border-primary'));
    document.querySelectorAll('.tool-panel').forEach(p => p.classList.add('hidden'));
    tab.classList.add('bg-primary', 'text-white', 'border-primary');
    document.querySelector(`.tool-panel[data-panel="${tab.dataset.tool}"]`)?.classList.remove('hidden');
  });
});
</script>
