---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SvgPathAnalyzer from '../../components/SvgPathAnalyzer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is SVG path data?",
    answer: "SVG path data is the value of the 'd' attribute in an SVG <path> element. It's a mini-language of commands and coordinates that defines any shape — lines, curves, arcs, and complex polygons. For example, 'M 10 10 L 100 100 Z' moves to (10,10), draws a line to (100,100), and closes the path."
  },
  {
    question: "What do the path command letters mean?",
    answer: "M/m = Move To (start a new subpath), L/l = Line To (straight line), H/h = Horizontal Line, V/v = Vertical Line, C/c = Cubic Bézier curve (two control points), S/s = Smooth Cubic Bézier, Q/q = Quadratic Bézier (one control point), T/t = Smooth Quadratic Bézier, A/a = Elliptical Arc, Z/z = Close Path. Uppercase = absolute coordinates, lowercase = relative coordinates."
  },
  {
    question: "What is the difference between absolute and relative commands?",
    answer: "Uppercase commands (M, L, C…) use absolute coordinates — the position is measured from the SVG viewport origin (0,0). Lowercase commands (m, l, c…) use relative coordinates — the position is measured from the current pen position. For example, 'L 100 100' moves to (100,100), while 'l 100 100' moves 100 units right and 100 units down from wherever the pen currently is."
  },
  {
    question: "What is a cubic Bézier curve and how does it work?",
    answer: "A cubic Bézier (C command) takes 6 arguments: two control points and an end point — cp1x cp1y cp2x cp2y x y. The control points act like magnets pulling the curve. cp1 controls the curve near the start point, cp2 controls the curve near the end point. The more the control points deviate from the line between start and end, the more pronounced the curve."
  },
  {
    question: "How do I get the bounding box of a path?",
    answer: "This tool uses the browser's native SVGPathElement.getBBox() API to calculate the exact bounding box — the smallest axis-aligned rectangle that contains the entire path. This accounts for curves that extend beyond their control points. The result gives you minX, minY, width, and height."
  },
  {
    question: "How can I use this for icon or illustration work?",
    answer: "Use the command breakdown to understand existing SVG paths from icon libraries. The bounding box helps you calculate the correct viewBox for scaling. You can identify complex curve sequences (C/S combinations) that form smooth shapes, and simplified paths using only L/H/V for geometric icons. Understanding the command breakdown is also useful for animating paths with CSS or GSAP."
  },
];
---

<BaseLayout
  title="SVG Path Analyzer — Visualize & Break Down SVG Path Commands"
  description="Paste SVG path data (d attribute) to visualize the shape, get a full command breakdown (M/L/C/Q/A/Z), see argument details for each command, and calculate the exact bounding box. Free, runs 100% in your browser."
  tool="SVG Path Analyzer, SVG Path Parser, SVG Path Debugger, SVG d attribute parser, SVG command breakdown, Bézier curve analyzer"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "SVG Path Analyzer",
    "url": "https://devplaybook.cc/tools/svg-path-analyzer",
    "description": "Parse and analyze SVG path data. Shows command-by-command breakdown, visualizes the path, and calculates bounding box. Supports M, L, C, Q, A, Z and all other SVG path commands.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">SVG Path Analyzer</h1>
  <p class="text-text-muted mb-4">
    Paste any SVG path data to visualize the shape, break down each command (M, L, C, Q, A, Z and more),
    understand arguments for curves and arcs, and calculate the exact bounding box using the browser's native API.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All SVG path commands</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live path preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Bounding box calculation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <SvgPathAnalyzer client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SVG Path Analyzer" relatedTags={['svg', 'design', 'frontend', 'visualization', 'developer-tools']} />
</BaseLayout>
