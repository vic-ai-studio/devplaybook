---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LlmContextWindowCalculator from '../../components/LlmContextWindowCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is a context window in LLMs?",
    answer: "A context window is the maximum amount of text (measured in tokens) an LLM can process in a single call — it includes both your input (prompt, documents, history) and the model's output. If your input + output exceeds the context window, the model will either refuse, truncate your input, or produce degraded results. Larger context windows let you process longer documents and maintain longer conversations."
  },
  {
    question: "What is a token and how many tokens is a word?",
    answer: "A token is roughly 4 characters of English text — about 0.75 words. So 1000 words ≈ 1300 tokens. Code is more token-dense than prose because of punctuation, symbols, and identifiers. Chinese/Japanese characters are often 1 token each. For accurate token counts in production, use the official tokenizer libraries: tiktoken (OpenAI), claude-tokenizer, or the model provider's API."
  },
  {
    question: "How do I reduce token usage?",
    answer: "Remove unnecessary context from your prompt — only include what's relevant. Use system prompts efficiently. Compress chat history (summarize older turns instead of including full text). For RAG systems, retrieve only the most relevant chunks (top-k) rather than large document sections. Use caching (prompt caching in Claude, cached completion in OpenAI) to avoid re-processing repeated context."
  },
  {
    question: "What happens when I exceed the context window?",
    answer: "Most APIs return an error (400 Bad Request with a 'too many tokens' message). Some models silently truncate the beginning of your input — this is particularly dangerous because the model won't tell you it dropped context. Claude explicitly rejects oversized requests. Always check the token count before sending, especially for agentic systems that accumulate context over multiple turns."
  },
  {
    question: "Why is the price estimate for cost-per-call so low but high at scale?",
    answer: "Individual LLM calls are cheap — often fractions of a cent. But production apps make thousands to millions of calls per day. At 10,000 calls/day with a $0.003 average cost, that's $30/day or $900/month. Costs scale linearly with usage, so optimizing token efficiency (shorter prompts, output caching, right-sizing your model) has a compounding effect at scale."
  },
  {
    question: "How do I choose the right model for my use case?",
    answer: "For simple tasks (classification, extraction, short generation): use fast cheap models like GPT-4o mini, Claude Haiku, or Gemini Flash. For complex reasoning and long documents: use Claude Sonnet/Opus, GPT-4o, or Gemini Pro. For very long documents (>100K tokens): only Claude (200K) and Gemini (1M-2M) work. For cost-sensitive high-volume workloads: benchmark multiple models — cheaper models often match quality on well-structured prompts."
  },
];
---

<BaseLayout
  title="LLM Context Window Calculator — Token Counter & Cost Estimator"
  description="Calculate how many tokens your text uses against any LLM context window. Estimate API costs for GPT-4o, Claude, Gemini, Llama, Mistral, and DeepSeek. See usage %, warnings, and price at scale. Free."
  tool="LLM Token Calculator, Context Window Calculator, GPT token counter, Claude token estimator, LLM cost calculator, AI API pricing"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "LLM Context Window Calculator",
    "url": "https://devplaybook.cc/tools/llm-context-window-calculator",
    "description": "Estimate token count and API cost for any LLM. Supports GPT-4o, Claude 3.5/3.7, Gemini 2.0, Llama 3, Mistral, and DeepSeek. Shows context usage %, price per call, and scale estimates.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">LLM Context Window Calculator</h1>
  <p class="text-text-muted mb-4">
    Paste your text to see how it fits inside any LLM's context window.
    Get token count estimates, context usage percentage, cost per call, and scale projections for
    GPT-4o, Claude, Gemini, Llama, Mistral, DeepSeek, and more.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 17 models across 6 providers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Context usage % + warnings</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Input + output cost breakdown</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Daily & monthly scale estimates</span>
  </div>
  <LlmContextWindowCalculator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="LLM Context Window Calculator" relatedTags={['ai', 'llm', 'openai', 'anthropic', 'api', 'development']} />
</BaseLayout>
