---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is the performance difference between StyleSheet.create and inline styles?",
    answer: "StyleSheet.create registers styles with the native rendering system at app load time, assigns them integer IDs, and sends only those IDs across the bridge (or JSI) during rendering. Inline styles create a new object on every render, requiring the full style object to be passed each time. For frequently rendered components, StyleSheet.create is meaningfully faster — especially for lists with hundreds of items."
  },
  {
    question: "Does React Native support all CSS properties?",
    answer: "React Native supports a subset of CSS. Many common properties work (flexbox layout, padding, margin, colors, borders, transforms, opacity). Key differences: there is no CSS cascade or inheritance — styles do not flow from parent to child. 'display' only supports 'flex' and 'none' (no grid, block, inline-block). No z-index stacking context. No float, clear, or position: fixed. text-decoration and box-shadow have limited support."
  },
  {
    question: "Why does my style work on iOS but not Android?",
    answer: "Some React Native style properties are platform-specific. 'elevation' (Android shadow) vs 'shadowColor/shadowOffset/shadowOpacity/shadowRadius' (iOS shadow). 'fontVariant' behavior differs. Android has a smaller subset of font weights. Text input styling has significant platform differences. Use Platform.select() or platform-specific files (.ios.ts / .android.ts) to handle these differences."
  },
  {
    question: "What is StyleSheet.flatten and when should I use it?",
    answer: "StyleSheet.flatten merges an array of style objects into a single flat style object. It's useful when you need to read style values programmatically (e.g., extract a color value for an animation). It resolves registered StyleSheet IDs back to plain objects. Note: use it sparingly — calling it on arrays of registered styles defeats the performance benefits of StyleSheet.create."
  },
  {
    question: "How does flexbox work differently in React Native vs CSS?",
    answer: "React Native's flexbox defaults differ from CSS: flexDirection defaults to 'column' (not 'row'), alignContent defaults to 'flex-start' (not 'stretch'), and flexShrink defaults to 0 (not 1). All dimensions are unitless numbers representing dp (density-independent pixels) — never use 'px', 'em', or '%' except for explicit percentage strings. Flexbox applies to all elements by default — there is no need to add display: flex."
  },
  {
    question: "What invalid style properties cause silent failures?",
    answer: "Invalid style properties in React Native fail silently in development and production — the property is ignored with no error. Common mistakes: using 'display: block', 'float', 'position: fixed', 'box-shadow' (use shadow* properties), 'transition' (use Animated or Reanimated), 'cursor', 'overflow: scroll' (use ScrollView). In development mode, React Native logs a warning for unknown properties — check the Metro console."
  }
];
---
<BaseLayout
  title="React Native StyleSheet Validator: Catch Style Errors Early"
  description="Learn React Native StyleSheet best practices: StyleSheet.create vs inline styles performance, invalid CSS properties, platform-specific style differences, flex defaults, and common style gotchas that cause silent failures."
  tool="react-native-stylesheet-validator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"React Native StyleSheet Validator: Catch Style Errors Early","url":"https://devplaybook.cc/tools/react-native-stylesheet-validator","description":"Learn React Native StyleSheet best practices and avoid common style errors that cause silent failures."})} />

  <h1 class="text-3xl font-bold mb-2">React Native StyleSheet Validator: Catch Style Errors Early</h1>
  <p class="text-text-muted mb-6">Master React Native StyleSheet patterns: understand the performance difference between StyleSheet.create and inline styles, spot invalid CSS properties, and avoid the platform-specific style gotchas that cause subtle UI bugs.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> StyleSheet.create vs inline performance</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Invalid property reference</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Platform-specific style guide</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Flexbox defaults reference</span>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-3">StyleSheet.create vs Inline Styles</h2>
  <p class="mb-4">The performance difference is most significant in list items rendered hundreds of times per second during scroll:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm">import &#123; StyleSheet, View, Text &#125; from 'react-native';

// Bad: new object created on every render
const ListItem = (&#123; title &#125;) => (
  &lt;View style=&#123;&#123; padding: 16, backgroundColor: '#fff', borderRadius: 8 &#125;&#125;&gt;
    &lt;Text style=&#123;&#123; fontSize: 16, fontWeight: '600' &#125;&#125;&gt;&#123;title&#125;&lt;/Text&gt;
  &lt;/View&gt;
);

// Good: registered once, referenced by ID
const ListItem = (&#123; title &#125;) => (
  &lt;View style=&#123;styles.container&#125;&gt;
    &lt;Text style=&#123;styles.title&#125;&gt;&#123;title&#125;&lt;/Text&gt;
  &lt;/View&gt;
);

const styles = StyleSheet.create(&#123;
  container: &#123;
    padding: 16,
    backgroundColor: '#fff',
    borderRadius: 8,
  &#125;,
  title: &#123;
    fontSize: 16,
    fontWeight: '600',
  &#125;,
&#125;);</code></pre>

  <p class="mb-4">When combining static and dynamic styles, put the static part in StyleSheet.create and apply dynamic values as an additional inline style. This preserves the registration benefit for the static parts:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm">// Combining static and dynamic styles correctly
const Badge = (&#123; color, label &#125;) => (
  &lt;View style=&#123;[styles.badge, &#123; backgroundColor: color &#125;]&#125;&gt;
    &lt;Text style=&#123;styles.badgeText&#125;&gt;&#123;label&#125;&lt;/Text&gt;
  &lt;/View&gt;
);

const styles = StyleSheet.create(&#123;
  badge: &#123;
    paddingHorizontal: 8,
    paddingVertical: 4,
    borderRadius: 12,
  &#125;,
  badgeText: &#123;
    color: '#fff',
    fontSize: 12,
    fontWeight: '700',
  &#125;,
&#125;);</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Invalid Style Properties (Common Mistakes)</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 font-semibold">CSS Property</th>
          <th class="text-left py-2 pr-4 font-semibold">React Native Equivalent</th>
          <th class="text-left py-2 font-semibold">Notes</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <tr>
          <td class="py-2 pr-4"><code>box-shadow</code></td>
          <td class="py-2 pr-4"><code>shadowColor, shadowOffset, shadowOpacity, shadowRadius</code></td>
          <td class="py-2">iOS only; use elevation on Android</td>
        </tr>
        <tr>
          <td class="py-2 pr-4"><code>display: block</code></td>
          <td class="py-2 pr-4">Default (all elements are flex)</td>
          <td class="py-2">Only flex and none supported</td>
        </tr>
        <tr>
          <td class="py-2 pr-4"><code>float</code></td>
          <td class="py-2 pr-4">Not supported</td>
          <td class="py-2">Use flexbox layout</td>
        </tr>
        <tr>
          <td class="py-2 pr-4"><code>transition</code></td>
          <td class="py-2 pr-4">Animated API / Reanimated</td>
          <td class="py-2">No CSS transitions in RN</td>
        </tr>
        <tr>
          <td class="py-2 pr-4"><code>cursor: pointer</code></td>
          <td class="py-2 pr-4">Not supported on mobile</td>
          <td class="py-2">Use TouchableOpacity/Pressable</td>
        </tr>
        <tr>
          <td class="py-2 pr-4"><code>overflow: scroll</code></td>
          <td class="py-2 pr-4">Use ScrollView component</td>
          <td class="py-2">overflow: hidden and visible supported</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Flexbox Defaults in React Native</h2>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm">// React Native flex DEFAULTS (differ from CSS!)
const defaultStyles = &#123;
  flexDirection: 'column', // CSS default is 'row'
  alignContent: 'flex-start', // CSS default is 'stretch'
  flexShrink: 0, // CSS default is 1
  position: 'relative', // same as CSS
  display: 'flex', // always (no other option except 'none')
&#125;;

// Platform-specific shadows
const styles = StyleSheet.create(&#123;
  card: &#123;
    // iOS shadow
    shadowColor: '#000',
    shadowOffset: &#123; width: 0, height: 2 &#125;,
    shadowOpacity: 0.1,
    shadowRadius: 4,
    // Android shadow
    elevation: 4,
    // backgroundColor required for Android elevation to work
    backgroundColor: '#fff',
  &#125;,
&#125;);</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">StyleSheet.flatten for Reading Style Values</h2>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm">import &#123; StyleSheet &#125; from 'react-native';

const styles = StyleSheet.create(&#123;
  text: &#123; color: '#6366f1', fontSize: 16 &#125;,
&#125;);

// Read a style value programmatically
const flat = StyleSheet.flatten(styles.text);
console.log(flat.color); // '#6366f1'

// Flatten an array of styles
const merged = StyleSheet.flatten([
  styles.text,
  &#123; fontWeight: '700' &#125;,
]);
// Result: &#123; color: '#6366f1', fontSize: 16, fontWeight: '700' &#125;</code></pre>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="react-native-stylesheet-validator" relatedTags={['react-native', 'mobile', 'javascript', 'css', 'styling', 'performance']} />
</BaseLayout>
