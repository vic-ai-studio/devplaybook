---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JupyterToScriptConverter from '../../components/JupyterToScriptConverter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "Why convert a Jupyter notebook to a Python script?",
    answer: "Jupyter notebooks are great for exploration and visualization, but they have limitations in production: they can't be imported as modules, are difficult to version control cleanly (they store outputs in JSON), don't work well with CI/CD pipelines, and can have hidden state from out-of-order cell execution. Converting to a .py script makes code importable, diffable, testable with pytest, runnable from the command line via cron or task schedulers, and compatible with code review workflows."
  },
  {
    question: "What are magic commands and why remove them?",
    answer: "Magic commands are Jupyter-specific syntax: line magics start with % (e.g., %matplotlib inline, %timeit, %load_ext) and cell magics start with %% (e.g., %%bash, %%sql). Shell commands start with ! (e.g., !pip install, !ls). These are interpreted by the IPython kernel and are not valid Python syntax — they will raise SyntaxError if run as a plain .py file. Remove them when converting to a script, or replace %matplotlib inline with matplotlib.use('Agg') and !pip install X with a requirements.txt entry."
  },
  {
    question: "What does the # %% cell separator do?",
    answer: "The # %% comment is a special marker recognized by VS Code (with the Jupyter extension) and Spyder IDE as a 'code cell' boundary. This means your converted .py file can still be run interactively cell-by-cell inside VS Code — just like a notebook — without being a .ipynb file. Click 'Run Cell' above any # %% block to execute just that section. This gives you the best of both worlds: a clean .py file for version control and CI/CD, with notebook-like interactivity during development."
  },
  {
    question: "How do I run a converted script in production?",
    answer: "After conversion, run the script with: python script.py. For scheduled jobs, use cron (Linux/Mac) or Task Scheduler (Windows). For parameterized runs, consider Papermill (papermill notebook.ipynb output.ipynb -p param value) or replace hardcoded values with argparse. For ML pipelines, tools like Prefect, Airflow, or Dagster can orchestrate .py scripts as pipeline tasks. Always test the script in a clean virtual environment first to catch any missing dependency or implicit global state."
  },
];
---

<BaseLayout
  title="Jupyter Notebook to Python Script Converter — Convert .ipynb to .py Online"
  description="Convert Jupyter notebooks (.ipynb) to clean Python scripts. Remove magic commands, include markdown as comments, add cell separators. Paste notebook JSON and get .py output instantly."
  tool="jupyter to python converter, ipynb to py, jupyter notebook converter, convert notebook to script, jupyter script"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Jupyter Notebook to Python Script Converter",
    "url": "https://devplaybook.cc/tools/jupyter-to-script-converter",
    "description": "Convert Jupyter notebooks (.ipynb JSON) to clean Python scripts. Remove magic commands, optionally include markdown as comments, add VS Code cell separators.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Jupyter Notebook to Python Script Converter</h1>
  <p class="text-text-muted mb-4">
    Paste your <strong>.ipynb JSON</strong> to convert it to a clean Python script. Remove magic commands, include markdown cells as comments, and choose your cell separator style.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Magic command removal</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Markdown as comments</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> VS Code # %% cells</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Conversion stats</span>
  </div>
  <JupyterToScriptConverter client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Jupyter Notebook to Python Script Converter" relatedTags={['python', 'jupyter', 'data-science', 'developer-tools', 'notebook']} />
</BaseLayout>
