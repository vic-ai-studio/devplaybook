---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OpenApiSpecValidator from '../../components/OpenApiSpecValidator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What spec formats does this validator support?",
    answer: "It supports both OpenAPI 3.x (3.0.x and 3.1.x) and Swagger 2.0 specs in YAML or JSON format. The validator auto-detects the format from the 'openapi' or 'swagger' field at the root level."
  },
  {
    question: "What does this validator check?",
    answer: "It validates required fields (openapi/swagger version, info.title, info.version), checks that all paths start with /, detects duplicate paths and duplicate operationIds, flags missing path parameter definitions, warns about missing operationIds and server definitions, and counts paths, operations, and schemas."
  },
  {
    question: "What is the difference between errors, warnings, and info?",
    answer: "Errors are spec violations that will break tooling — missing required fields, duplicate operationIds, undefined path parameters. Warnings are best-practice issues that may cause problems with SDK generation or documentation. Info items are suggestions that improve spec quality but aren't required."
  },
  {
    question: "Why is operationId important?",
    answer: "operationId is a unique identifier for each API operation. It's used by code generators (openapi-generator, Speakeasy, Kiota) to name client methods, by documentation tools for deep links, and by mocking frameworks. Duplicate or missing operationIds cause failures in most tooling pipelines."
  },
  {
    question: "Does this validator send my spec to a server?",
    answer: "No — all validation runs entirely in your browser using JavaScript. Your API spec never leaves your machine. No data is transmitted."
  },
  {
    question: "What's the difference between this and Swagger Editor?",
    answer: "Swagger Editor provides a full IDE experience with schema-level JSON Schema validation. This tool focuses on structural correctness, operational best practices (operationId coverage, path parameter consistency, response definitions), and gives a quick lint report with path references — optimized for CI/CD checks and quick audits."
  },
];
---

<BaseLayout
  title="OpenAPI Spec Validator — Validate OpenAPI 3.x & Swagger 2.0 YAML/JSON"
  description="Paste your OpenAPI 3.x or Swagger 2.0 spec (YAML or JSON) to validate structure, check required fields, detect duplicate operationIds and paths, verify path parameters, and get categorized errors and warnings with path references. Free, runs in your browser."
  tool="OpenAPI Validator, Swagger Validator, OpenAPI Spec Linter, OpenAPI 3 Validation, Swagger 2.0 Validator, API Spec Checker"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "OpenAPI Spec Validator",
    "url": "https://devplaybook.cc/tools/openapi-spec-validator",
    "description": "Validate OpenAPI 3.x and Swagger 2.0 specs in YAML or JSON. Checks structure, required fields, paths, operationIds, and parameters. Runs 100% in browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">OpenAPI Spec Validator</h1>
  <p class="text-text-muted mb-4">
    Validate OpenAPI 3.x or Swagger 2.0 specs in YAML or JSON. Checks required fields, path structure,
    operationId uniqueness, path parameter definitions, and response coverage. Get categorized errors,
    warnings, and suggestions — with path references.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> OpenAPI 3.x + Swagger 2.0</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> YAML & JSON input</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Errors, warnings & suggestions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <OpenApiSpecValidator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="OpenAPI Spec Validator" relatedTags={['api', 'openapi', 'swagger', 'validation', 'rest-api', 'developer-tools']} />
</BaseLayout>
