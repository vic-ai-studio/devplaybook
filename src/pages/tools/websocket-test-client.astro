---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WebSocketTester from '../../components/WebSocketTester.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a WebSocket and how does it differ from HTTP?",
    answer: "WebSocket is a full-duplex communication protocol over a single TCP connection. Unlike HTTP, which is request-response (client always initiates), WebSocket allows both the server and client to send messages at any time. The connection starts with an HTTP upgrade handshake, then switches to the WebSocket protocol. This makes it ideal for real-time features like live dashboards, chat, gaming, and push notifications."
  },
  {
    question: "What is the difference between ws:// and wss://?",
    answer: "ws:// is unencrypted WebSocket — traffic can be intercepted in transit. wss:// is WebSocket over TLS (like HTTPS for HTTP). Always use wss:// in production. Browsers running on HTTPS pages block mixed-content ws:// connections, so if your app is on HTTPS, your WebSocket server must also use wss://."
  },
  {
    question: "Why is my WebSocket connection being blocked by CORS?",
    answer: "Unlike HTTP requests, WebSocket connections don't use the same CORS mechanism. The server controls access via the Origin header during the upgrade handshake. If the server rejects your origin, you'll see a 403 or connection refused. This tool sends your browser's origin, so the server sees a request from devplaybook.cc. For local testing, use a server that accepts all origins or run the tool from a matching origin."
  },
  {
    question: "What is a WebSocket close code?",
    answer: "When a WebSocket connection closes, a close code indicates why. Common codes: 1000 = normal closure, 1001 = endpoint going away (server restart), 1006 = abnormal closure (no close frame received, often a network error), 1011 = server internal error, 1013 = service restart, 1015 = TLS failure. Codes 4000–4999 are reserved for application-defined use. A 1006 code usually means the connection was dropped unexpectedly — check server logs."
  },
  {
    question: "How do I test a WebSocket server locally?",
    answer: "Start your WebSocket server (e.g., on ws://localhost:8080), then use this tool to connect. Note: browser security may block ws:// connections to localhost from an HTTPS page. Use a locally-run dev server or try the wss:// version with a self-signed cert. Alternatively, use a public echo server like wss://echo.websocket.events to verify the tool itself works before debugging your server."
  },
  {
    question: "What message formats do WebSocket servers typically use?",
    answer: "WebSocket carries raw bytes — the framing is binary or text. In practice, most APIs use JSON text frames. Some use MessagePack (binary), Protobuf, or plain text. This tool sends messages as UTF-8 text. If your server expects binary frames or a specific encoding, you may need a native client or a custom test script using Node.js's ws library."
  },
];
---

<BaseLayout
  title="WebSocket Test Client — Connect, Send & Log WebSocket Traffic"
  description="Free online WebSocket test client. Connect to any ws:// or wss:// server, send messages, receive responses, and log all traffic with timestamps. No install needed — runs entirely in your browser."
  tool="WebSocket Test Client, WebSocket Debugger, Test WebSocket Online, WebSocket Traffic Logger"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "WebSocket Test Client",
    "url": "https://devplaybook.cc/tools/websocket-test-client",
    "description": "Connect to any WebSocket server, send and receive messages, and log all traffic with timestamps. Free browser-based WebSocket debugging tool.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">WebSocket Test Client</h1>
  <p class="text-text-muted mb-4">
    Connect to any <code class="font-mono bg-surface px-1 rounded text-sm">ws://</code> or <code class="font-mono bg-surface px-1 rounded text-sm">wss://</code> server,
    send JSON or raw text messages, and inspect the full traffic log with timestamps and byte sizes.
    Use <code class="font-mono bg-surface px-1 rounded text-sm">Ctrl+Enter</code> to send quickly.
    The echo server at <code class="font-mono bg-surface px-1 rounded text-sm">wss://echo.websocket.events</code> is pre-filled so you can test instantly.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Real-time traffic log</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Timestamps + byte sizes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <WebSocketTester client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="WebSocket Test Client" relatedTags={['networking', 'websocket', 'debugging', 'real-time', 'developer-tools']} />
</BaseLayout>
