---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ElasticsearchQueryBuilder from '../../components/ElasticsearchQueryBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the Elasticsearch bool query?",
    answer: "The bool query is the primary way to combine multiple queries in Elasticsearch. It has four clauses: must (all must match, contributes to score), should (at least one should match, boosts score), filter (must match but does not affect score — cached), and must_not (must not match — cached)."
  },
  {
    question: "What is the difference between filter and must?",
    answer: "Both require documents to match, but filter skips relevance scoring and is cached by Elasticsearch, making it significantly faster for repeated queries. Use filter for structured data like status, date ranges, and IDs. Use must for full-text search where relevance matters."
  },
  {
    question: "When should I use term vs match?",
    answer: "Use term for exact value matching on keyword fields (IDs, status codes, tags). term is not analyzed — it compares exact values. Use match for full-text search on analyzed text fields (titles, descriptions) — it applies the same analyzer as the indexed field and splits the query into tokens."
  },
  {
    question: "What is a wildcard query and when should I use it?",
    answer: "Wildcard queries support * (any number of characters) and ? (single character) patterns, similar to SQL LIKE. Use them for prefix matching (log_*) or flexible string patterns. Avoid leading wildcards (*pattern) as they require scanning all terms and are very slow."
  },
  {
    question: "What does the range query support?",
    answer: "Range queries support gte (>=), lte (<=), gt (>), lt (<), and format parameters. They work on numeric fields, dates, and strings. Date ranges accept ISO 8601 format (2024-01-01) or relative expressions like now-7d/d (7 days ago, rounded to day)."
  },
  {
    question: "Does this tool send my data to a server?",
    answer: "No. All query building happens entirely in your browser. Nothing is sent to any server."
  },
];
---

<BaseLayout
  title="Elasticsearch Query Builder — Visual DSL Query Generator"
  description="Build Elasticsearch bool queries visually. Add must, should, filter, and must_not clauses with term, match, range, wildcard, and exists query types. Outputs ready-to-use JSON DSL."
  tool="Elasticsearch Query Builder, ES DSL Generator, Elasticsearch Bool Query Builder"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Elasticsearch Query Builder",
    "url": "https://devplaybook.cc/tools/elasticsearch-query-builder",
    "description": "Build Elasticsearch bool queries visually with must, should, filter, and must_not clauses. Supports term, match, range, wildcard, and exists query types.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Elasticsearch Query Builder</h1>
  <p class="text-text-muted mb-4">
    Build Elasticsearch DSL queries visually. Add <code class="font-mono bg-surface px-1 rounded text-sm">must</code>, <code class="font-mono bg-surface px-1 rounded text-sm">should</code>, <code class="font-mono bg-surface px-1 rounded text-sm">filter</code>, and <code class="font-mono bg-surface px-1 rounded text-sm">must_not</code> clauses with term, match, range, wildcard, and exists queries. Copy the JSON output directly into Elasticsearch.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Bool query builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 query types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <ElasticsearchQueryBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Elasticsearch Query Builder" relatedTags={['elasticsearch', 'search', 'database', 'nosql', 'developer-tools']} />
</BaseLayout>
