---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PortkeyAiGatewayConfig from '../../components/PortkeyAiGatewayConfig.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Portkey AI gateway?",
    answer: "Portkey is an AI gateway that sits between your application and LLM providers. It provides a unified API (compatible with OpenAI's SDK), automatic fallbacks, load balancing, request caching, observability, and cost tracking. Virtual keys let you manage multiple provider API keys centrally without exposing them in your code."
  },
  {
    question: "What's the difference between Fallback and Load Balance strategies?",
    answer: "Fallback tries providers in order — it only moves to the next provider if the current one fails (based on status codes like 429 or 503). Load Balance distributes requests across providers based on weights — useful for cost optimization (e.g. 70% cheap model, 30% expensive model). Use Fallback for reliability, Load Balance for cost optimization."
  },
  {
    question: "What are virtual keys?",
    answer: "Virtual keys are Portkey's abstraction over real provider API keys. You add your actual OpenAI/Anthropic keys to Portkey's vault, and Portkey gives you a virtual key (starting with portkey-vk-...). You use virtual keys in your config instead of real keys, so you can rotate/revoke real keys without changing your application code."
  },
  {
    question: "Does Portkey work with the OpenAI Python SDK?",
    answer: "Yes. Portkey is designed as a drop-in replacement. Just change `client = OpenAI(api_key=...)` to `client = Portkey(api_key=..., virtual_key=...)`. The rest of your code stays identical. The same works for Node.js with the OpenAI Node SDK."
  },
  {
    question: "When should I use semantic caching vs simple caching?",
    answer: "Simple caching does exact string matching — the same prompt returns the same cached response instantly. Semantic caching uses vector embeddings to match 'similar' prompts, so 'What's 2+2?' and 'What is 2 plus 2?' return the same cached result. Simple caching is great for API wrappers with predictable prompts. Semantic caching works well for chatbots and QA systems with paraphrased queries."
  },
];
---

<BaseLayout
  title="Portkey AI Gateway Config Generator — Configure Virtual Keys & Routing"
  description="Configure Portkey AI gateway with virtual keys, fallback strategies, load balancing weights, retry logic, and response caching. Generate a ready-to-use Portkey config JSON."
  tool="Portkey AI gateway config, Portkey config generator, AI gateway configuration, LLM gateway setup, Portkey virtual keys"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Portkey AI Gateway Config Generator",
    "url": "https://devplaybook.cc/tools/portkey-ai-gateway-config",
    "description": "Configure Portkey AI gateway with providers, routing strategy (fallback/load balance), retry logic, and caching. Download the config JSON instantly.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Portkey AI Gateway Config</h1>
  <p class="text-text-muted mb-4">
    Configure your Portkey AI gateway with multiple LLM providers, routing strategy (fallback or load balance), retry logic, and response caching. Generate a production-ready config JSON with Python usage example.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Fallback & load balance</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 8 LLM providers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Python code example</span>
  </div>
  <PortkeyAiGatewayConfig client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Portkey AI Gateway Config" relatedTags={['ai', 'llm', 'developer-tools', 'devops', 'openai', 'anthropic']} />
</BaseLayout>
