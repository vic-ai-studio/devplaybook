---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SvgToPng from '../../components/SvgToPng.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How does the SVG to PNG conversion work?", answer: "The tool uses the browser's native SVG rendering engine via the HTML5 Canvas API. It renders your SVG at the chosen scale factor and exports the canvas as a PNG image — no server involved." },
  { question: "What does 1x, 2x, 4x mean?", answer: "These are scale multipliers applied to the SVG's natural dimensions. 1x gives the original size, 2x doubles it (great for Retina/HiDPI displays), and 4x gives a large high-resolution image." },
  { question: "Can I upload an SVG file instead of pasting?", answer: "Yes. Click 'Upload SVG file' to open a file picker, or drag and drop an .svg file directly onto the text area." },
  { question: "Why might my SVG look different in the PNG output?", answer: "Some SVG features (external fonts, cross-origin images, certain filters) may not render correctly due to browser security sandboxing. Self-contained SVGs without external dependencies always convert perfectly." },
  { question: "Does it support transparent backgrounds?", answer: "Yes. Select 'None' for the background option to get a PNG with full transparency (alpha channel). You can also choose white or black as a solid background." },
];
---

<BaseLayout
  title="SVG to PNG Converter — Free Online Tool"
  description="Convert SVG to PNG in your browser. Choose 1x, 2x, or 4x output size, transparent or solid background. Paste or upload .svg files. No server — runs entirely client-side."
  tool="SVG to PNG, SVG converter, convert SVG to PNG, SVG export, rasterize SVG, SVG to image"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">SVG to PNG Converter</h1>
  <p class="text-text-muted mb-4">Convert SVG graphics to PNG images directly in your browser. Paste SVG code or upload a file, choose your output scale (1x, 2x, 4x for Retina), set a background color, and download. All client-side — nothing sent to any server.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Transparent background support</span>
  </div>
  <SvgToPng client:only="preact" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more free developer tools?</p>
    <a href="/tools" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Browse All Free Tools →</a>
  </div>
  <ToolPageCta currentTool="SVG to PNG Converter" relatedTags={['svg', 'png', 'image', 'converter', 'graphics']} />
</BaseLayout>
