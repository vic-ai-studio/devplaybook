---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TextEncryption from '../../components/TextEncryption.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is AES-256-GCM and why is it the gold standard?", answer: "AES (Advanced Encryption Standard) with 256-bit keys and GCM (Galois/Counter Mode) is the encryption algorithm used by governments, banks, and security-critical applications worldwide. AES-256 provides 256-bit symmetric key strength — computationally infeasible to brute-force. GCM mode adds authenticated encryption: it simultaneously encrypts your data and generates an authentication tag, so any tampering with the ciphertext is detected during decryption. This makes AES-256-GCM both confidential and tamper-proof." },
  { question: "How is the encryption key derived from my password?", answer: "Your password is never used directly as the AES key. Instead, it's run through PBKDF2 (Password-Based Key Derivation Function 2) with 100,000 iterations of HMAC-SHA256 and a random 16-byte salt. This slow derivation makes brute-force attacks against weak passwords much harder. The derived 256-bit key is only held in memory during the operation and never stored or transmitted." },
  { question: "What is the IV (Initialization Vector) and why does it matter?", answer: "The IV (or nonce) is a 12-byte random value that ensures the same plaintext encrypted with the same key produces a different ciphertext every time. Without a unique IV, identical plaintexts would produce identical ciphertexts, leaking information about your data patterns. This tool generates a new random IV for each encryption operation using the browser's cryptographically secure random number generator (crypto.getRandomValues)." },
  { question: "What format is the encrypted output?", answer: "The output is a base64-encoded token that embeds everything needed to decrypt: the salt (16 bytes), IV (12 bytes), GCM authentication tag (16 bytes), and the ciphertext. You only need the password and this single token to decrypt — no separate storage of salt or IV is needed. The base64 encoding makes the output safe to copy into text fields, URLs, and JSON." },
  { question: "Is this tool safe for encrypting sensitive data?", answer: "This tool uses the browser's built-in Web Crypto API (crypto.subtle) — the same API used by password managers and security tools. Your data is processed entirely in your browser; nothing is sent to any server. The algorithm (AES-256-GCM with PBKDF2 key derivation) is cryptographically sound. However, security also depends on your password strength — use a long, random passphrase for sensitive data." },
  { question: "Can I decrypt output from this tool in my own code?", answer: "Yes. The format is standard: 16-byte salt + 12-byte IV + 16-byte GCM tag + ciphertext, all base64-encoded. Derive the key using PBKDF2 (SHA-256, 100,000 iterations, 256-bit output), then decrypt with AES-256-GCM. Examples exist in Node.js (crypto module), Python (cryptography library), and any language with a Web Crypto-compatible API." },
];
---

<BaseLayout
  title="AES Encryptor / Decryptor — AES-256-GCM Encrypt Text Online"
  description="Encrypt and decrypt text using AES-256-GCM in your browser. Key derived via PBKDF2-SHA256 with 100,000 iterations. No data sent to any server — fully client-side using Web Crypto API."
  tool="AES encryptor decryptor, AES-256-GCM encryption online, browser AES encrypt, client-side text encryption, PBKDF2 key derivation"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "AES Encryptor / Decryptor",
    "url": "https://devplaybook.cc/tools/aes-encryptor",
    "description": "Encrypt and decrypt text using AES-256-GCM in your browser. PBKDF2 key derivation with 100,000 iterations. Runs entirely client-side via Web Crypto API.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">AES Encryptor / Decryptor</h1>
  <p class="text-text-muted mb-4">
    Encrypt and decrypt text using <strong>AES-256-GCM</strong> — the industry-standard authenticated encryption algorithm. Key is derived from your password via <code class="font-mono bg-surface px-1 rounded text-sm">PBKDF2-SHA256</code> with 100,000 iterations and a random salt. Runs entirely in your browser using the <code class="font-mono bg-surface px-1 rounded text-sm">crypto.subtle</code> Web Crypto API — your data never leaves your device.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> AES-256-GCM (authenticated encryption)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> PBKDF2 key derivation (100k iterations)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100% browser — no server calls</span>
  </div>
  <TextEncryption client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="AES Encryptor / Decryptor" relatedTags={['security', 'encryption', 'cryptography', 'aes', 'developer-tools']} />
</BaseLayout>
