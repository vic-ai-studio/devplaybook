---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HttpHeaderInspector from '../../components/HttpHeaderInspector.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What are HTTP security headers?", answer: "HTTP security headers are response headers that instruct browsers on security policies. Key ones include Content-Security-Policy (prevents XSS), Strict-Transport-Security (enforces HTTPS), X-Frame-Options (prevents clickjacking), X-Content-Type-Options (prevents MIME sniffing), and Referrer-Policy (controls referrer data)." },
  { question: "What is Content-Security-Policy?", answer: "CSP (Content-Security-Policy) is a header that tells browsers which resources are allowed to load. It can prevent XSS attacks by blocking inline scripts, limiting script sources to trusted domains. A strict CSP like \"default-src 'self'\" only allows resources from the same origin." },
  { question: "What is HSTS (Strict-Transport-Security)?", answer: "HSTS tells browsers to always use HTTPS for a domain, even if the user types http://. The max-age directive sets how long to remember this (31536000 = 1 year). includeSubDomains extends it to all subdomains. preload submits the domain to browser preload lists, so HTTPS is enforced from the very first visit." },
  { question: "Why should I hide the Server header?", answer: "The Server header reveals what web server software you're using (e.g., nginx/1.24.0, Apache/2.4.51). Attackers use this information to target known vulnerabilities. It's a good practice to remove or obscure this header in production." },
  { question: "What does X-Content-Type-Options: nosniff do?", answer: "Without this header, browsers may try to 'sniff' the content type of a response, potentially treating a text file as JavaScript and executing it. Setting X-Content-Type-Options: nosniff prevents this behavior, requiring browsers to trust the declared Content-Type." },
];
---

<BaseLayout
  title="HTTP Header Inspector — Analyze Response Headers & Security Score"
  description="Free HTTP response header inspector. Analyze any URL's response headers, check security header coverage (CSP, HSTS, X-Frame-Options), and identify missing security headers."
  tool="HTTP header inspector, response header checker, security header analyzer, HSTS checker, CSP checker, HTTP header tool"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">HTTP Header Inspector</h1>
  <p class="text-text-muted mb-4">Enter any URL to inspect its HTTP response headers. Highlights security headers (CSP, HSTS, X-Frame-Options, X-Content-Type-Options, Referrer-Policy), flags missing ones, and shows explanations for each header.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Security header score</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Missing header alerts</span>
  </div>
  <HttpHeaderInspector client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="HTTP Header Inspector" relatedTags={['http', 'security', 'api', 'web', 'headers', 'devtools']} />
</BaseLayout>
