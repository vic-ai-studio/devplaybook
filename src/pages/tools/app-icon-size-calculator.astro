---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What icon sizes does iOS require?",
    answer: "iOS requires multiple sizes for App Store, home screen, spotlight, and settings. Key sizes: 20pt (notifications), 29pt (settings), 40pt (spotlight), 60pt (app icon — 120px @2x, 180px @3x), and 1024px for App Store. With Xcode 14+, only the 1024x1024 source is needed — Xcode generates the rest."
  },
  {
    question: "What icon sizes does Android require?",
    answer: "Android uses density buckets: mdpi (1x, 48px), hdpi (1.5x, 72px), xhdpi (2x, 96px), xxhdpi (3x, 144px), xxxhdpi (4x, 192px). For adaptive icons (Android 8+), provide foreground and background layers at these same sizes. Play Store requires 512x512 high-res icon."
  },
  {
    question: "What is the difference between points (pt) and pixels (px)?",
    answer: "Points are logical units used in iOS design. On @1x, 1pt = 1px. On Retina (@2x), 1pt = 2px. On Super Retina (@3x), 1pt = 3px. So a 60pt icon is 120px on @2x and 180px on @3x. Android uses dp (density-independent pixels) with similar logic."
  },
  {
    question: "Should I use PNG or WebP for app icons?",
    answer: "iOS requires PNG for all app icons (no transparency on the main icon). Android supports both PNG and WebP — WebP offers better compression. The Play Store high-res icon must be a 32-bit PNG with alpha."
  },
  {
    question: "What is a maskable icon for PWA?",
    answer: "A maskable icon has extra padding so Android can apply adaptive icon shapes (circle, squircle) without clipping. Keep your design within the inner 80% of the icon. The safe zone is a circle inscribed in the icon area."
  }
];
---

<BaseLayout
  title="App Icon Size Calculator — iOS, Android & PWA Icon Sizes"
  description="See all required app icon sizes for iOS, Android, and PWA. Filter by platform and copy filenames for your build pipeline. Free browser tool."
  tool="app icon size calculator, iOS icon sizes, Android icon sizes, PWA icon sizes, app icon generator sizes, mobile app icons"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "App Icon Size Calculator",
    "url": "https://devplaybook.cc/tools/app-icon-size-calculator",
    "description": "Calculate all required app icon sizes for iOS, Android, and PWA. See every required output size with pixel values.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">App Icon Size Calculator</h1>
  <p class="text-text-muted mb-4">See every required icon size for iOS, Android, and PWA. Filter by platform and copy filenames for your build pipeline.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> iOS + Android + PWA</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All pixel sizes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy filename list</span>
  </div>

  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <div class="flex flex-wrap gap-2">
      <button data-platform="all" class="platform-btn px-3 py-1.5 rounded-lg text-sm font-medium bg-primary text-white transition-colors">All Platforms</button>
      <button data-platform="ios" class="platform-btn px-3 py-1.5 rounded-lg text-sm font-medium bg-surface border border-border hover:bg-bg-card transition-colors">iOS</button>
      <button data-platform="android" class="platform-btn px-3 py-1.5 rounded-lg text-sm font-medium bg-surface border border-border hover:bg-bg-card transition-colors">Android</button>
      <button data-platform="pwa" class="platform-btn px-3 py-1.5 rounded-lg text-sm font-medium bg-surface border border-border hover:bg-bg-card transition-colors">PWA</button>
    </div>
  </div>

  <div class="bg-bg-card border border-border rounded-lg overflow-hidden mb-4">
    <div class="flex items-center justify-between p-3 border-b border-border">
      <span class="text-sm font-medium">Required Sizes</span>
      <button id="btn-copy-sizes" class="px-3 py-1.5 bg-primary text-white rounded-lg text-xs font-medium hover:bg-primary/90 transition-colors">Copy Filenames</button>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-left text-xs text-text-muted border-b border-border">
            <th class="px-4 py-2 font-medium">Platform</th>
            <th class="px-4 py-2 font-medium">Usage</th>
            <th class="px-4 py-2 font-medium">Size (px)</th>
            <th class="px-4 py-2 font-medium">Scale</th>
            <th class="px-4 py-2 font-medium">Filename</th>
          </tr>
        </thead>
        <tbody id="sizes-table"></tbody>
      </table>
    </div>
  </div>

  <div class="grid grid-cols-3 gap-3 mb-4" id="platform-summary"></div>
  <p id="copy-msg" class="text-xs text-green-400 mb-4 hidden">Filenames copied!</p>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="App Icon Size Calculator" relatedTags={['mobile', 'ios', 'android', 'pwa', 'design']} />
</BaseLayout>

<script is:inline>
(function() {
  var SIZES = [
    { platform: 'ios', usage: 'App Store', px: 1024, scale: '1x', file: 'AppIcon-1024x1024.png' },
    { platform: 'ios', usage: 'Home Screen @3x iPhone', px: 180, scale: '3x', file: 'AppIcon-60@3x.png' },
    { platform: 'ios', usage: 'Home Screen @2x iPhone', px: 120, scale: '2x', file: 'AppIcon-60@2x.png' },
    { platform: 'ios', usage: 'Home Screen @2x iPad', px: 152, scale: '2x', file: 'AppIcon-76@2x.png' },
    { platform: 'ios', usage: 'Home Screen @1x iPad', px: 76, scale: '1x', file: 'AppIcon-76@1x.png' },
    { platform: 'ios', usage: 'iPad Pro @2x', px: 167, scale: '2x', file: 'AppIcon-83.5@2x.png' },
    { platform: 'ios', usage: 'Spotlight @3x', px: 120, scale: '3x', file: 'AppIcon-40@3x.png' },
    { platform: 'ios', usage: 'Spotlight @2x', px: 80, scale: '2x', file: 'AppIcon-40@2x.png' },
    { platform: 'ios', usage: 'Settings @3x', px: 87, scale: '3x', file: 'AppIcon-29@3x.png' },
    { platform: 'ios', usage: 'Settings @2x', px: 58, scale: '2x', file: 'AppIcon-29@2x.png' },
    { platform: 'ios', usage: 'Notification @3x', px: 60, scale: '3x', file: 'AppIcon-20@3x.png' },
    { platform: 'ios', usage: 'Notification @2x', px: 40, scale: '2x', file: 'AppIcon-20@2x.png' },
    { platform: 'android', usage: 'Play Store', px: 512, scale: 'Store', file: 'ic_launcher-playstore.png' },
    { platform: 'android', usage: 'xxxhdpi (4x)', px: 192, scale: '4x', file: 'mipmap-xxxhdpi/ic_launcher.png' },
    { platform: 'android', usage: 'xxhdpi (3x)', px: 144, scale: '3x', file: 'mipmap-xxhdpi/ic_launcher.png' },
    { platform: 'android', usage: 'xhdpi (2x)', px: 96, scale: '2x', file: 'mipmap-xhdpi/ic_launcher.png' },
    { platform: 'android', usage: 'hdpi (1.5x)', px: 72, scale: '1.5x', file: 'mipmap-hdpi/ic_launcher.png' },
    { platform: 'android', usage: 'mdpi (1x)', px: 48, scale: '1x', file: 'mipmap-mdpi/ic_launcher.png' },
    { platform: 'android', usage: 'Adaptive xxxhdpi', px: 432, scale: '4x', file: 'mipmap-xxxhdpi/ic_launcher_foreground.png' },
    { platform: 'android', usage: 'Adaptive xxhdpi', px: 324, scale: '3x', file: 'mipmap-xxhdpi/ic_launcher_foreground.png' },
    { platform: 'android', usage: 'Adaptive xhdpi', px: 216, scale: '2x', file: 'mipmap-xhdpi/ic_launcher_foreground.png' },
    { platform: 'pwa', usage: 'Android Chrome (required)', px: 192, scale: '-', file: 'icon-192x192.png' },
    { platform: 'pwa', usage: 'Splash screen (required)', px: 512, scale: '-', file: 'icon-512x512.png' },
    { platform: 'pwa', usage: 'Maskable icon', px: 512, scale: '-', file: 'icon-512x512-maskable.png' },
    { platform: 'pwa', usage: 'Small icon', px: 96, scale: '-', file: 'icon-96x96.png' },
    { platform: 'pwa', usage: 'Medium icon', px: 128, scale: '-', file: 'icon-128x128.png' },
    { platform: 'pwa', usage: 'Large icon', px: 384, scale: '-', file: 'icon-384x384.png' },
    { platform: 'pwa', usage: 'Favicon', px: 32, scale: '-', file: 'favicon-32x32.png' },
    { platform: 'pwa', usage: 'Favicon small', px: 16, scale: '-', file: 'favicon-16x16.png' }
  ];

  var COLORS = { ios: 'text-blue-400', android: 'text-green-400', pwa: 'text-purple-400' };
  var LABELS = { ios: 'iOS', android: 'Android', pwa: 'PWA' };
  var current = 'all';

  function render() {
    var filtered = current === 'all' ? SIZES : SIZES.filter(function(s) { return s.platform === current; });
    var tbody = document.getElementById('sizes-table');
    tbody.innerHTML = filtered.map(function(s) {
      return '<tr class="border-b border-border hover:bg-surface/50 transition-colors">' +
        '<td class="px-4 py-2 ' + COLORS[s.platform] + ' font-medium text-xs">' + LABELS[s.platform] + '</td>' +
        '<td class="px-4 py-2 text-text-muted text-xs">' + s.usage + '</td>' +
        '<td class="px-4 py-2 font-mono text-xs font-semibold">' + s.px + 'x' + s.px + '</td>' +
        '<td class="px-4 py-2 text-text-muted text-xs">' + s.scale + '</td>' +
        '<td class="px-4 py-2 font-mono text-xs text-accent">' + s.file + '</td>' +
        '</tr>';
    }).join('');

    var platforms = ['ios', 'android', 'pwa'];
    document.getElementById('platform-summary').innerHTML = platforms.map(function(p) {
      var count = SIZES.filter(function(s) { return s.platform === p; }).length;
      return '<div class="bg-bg-card border border-border rounded-lg p-3 text-center">' +
        '<div class="text-lg font-bold ' + COLORS[p] + '">' + count + '</div>' +
        '<div class="text-xs text-text-muted">' + LABELS[p] + ' sizes</div>' +
        '</div>';
    }).join('');
  }

  document.querySelectorAll('.platform-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      current = btn.dataset.platform;
      document.querySelectorAll('.platform-btn').forEach(function(b) {
        b.classList.remove('bg-primary', 'text-white');
        b.classList.add('bg-surface', 'border', 'border-border');
      });
      btn.classList.add('bg-primary', 'text-white');
      btn.classList.remove('bg-surface', 'border', 'border-border');
      render();
    });
  });

  document.getElementById('btn-copy-sizes').addEventListener('click', function() {
    var filtered = current === 'all' ? SIZES : SIZES.filter(function(s) { return s.platform === current; });
    var text = filtered.map(function(s) { return s.file; }).join('\n');
    navigator.clipboard.writeText(text).then(function() {
      var msg = document.getElementById('copy-msg');
      msg.classList.remove('hidden');
      setTimeout(function() { msg.classList.add('hidden'); }, 2000);
    });
  });

  render();
})();
</script>
