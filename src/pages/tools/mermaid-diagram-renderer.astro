---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MermaidRenderer from '../../components/MermaidRenderer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Mermaid?", answer: "Mermaid is a JavaScript-based diagramming tool that renders text definitions into diagrams. You write diagram syntax in a code-like format, and Mermaid generates flowcharts, sequence diagrams, ER diagrams, Gantt charts, class diagrams, and more. It's widely supported in GitHub, GitLab, Notion, and many documentation tools." },
  { question: "How do I create a flowchart in Mermaid?", answer: "Use the flowchart keyword followed by direction (TD=top-down, LR=left-right, RL=right-left, BT=bottom-top). Nodes use square brackets for rectangles, round brackets for rounded, curly braces for diamonds (decisions). Connect with --> for arrows or --- for lines. Example: flowchart TD; A[Start] --> B{Decision}; B -->|Yes| C[Done]" },
  { question: "What diagram types does Mermaid support?", answer: "Mermaid supports: flowchart, sequenceDiagram, classDiagram, stateDiagram, erDiagram, journey, gantt, pie, quadrantChart, requirementDiagram, gitGraph, C4Context, mindmap, and timeline. Each has its own syntax described in the Mermaid documentation." },
  { question: "Can I use Mermaid in GitHub README files?", answer: "Yes! GitHub natively renders Mermaid diagrams in Markdown files. Wrap your Mermaid code in a fenced code block with the 'mermaid' language identifier. This works in README.md, issues, pull requests, and wiki pages." },
  { question: "How do I download the diagram as an image?", answer: "Click the 'Download SVG' button above the preview. SVG is a vector format that scales perfectly at any size. To convert to PNG, open the SVG in a browser, right-click and save as PNG, or use a tool like Inkscape or the online svg2png converter." },
];
---

<BaseLayout
  title="Mermaid Diagram Renderer — Live Editor & SVG Preview"
  description="Free online Mermaid diagram editor. Write flowcharts, sequence diagrams, ER diagrams, Gantt charts, and more in real time. Download as SVG. Runs in your browser."
  tool="Mermaid diagram renderer, Mermaid live editor, flowchart generator, sequence diagram tool, ER diagram online, Mermaid to SVG"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Mermaid Diagram Renderer</h1>
  <p class="text-text-muted mb-4">Write Mermaid syntax and see your diagram rendered in real time. Supports flowcharts, sequence diagrams, entity-relationship diagrams, Gantt charts, class diagrams, and more. Download as SVG for use in docs, READMEs, or presentations.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live rendering as you type</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Export to SVG</span>
  </div>
  <MermaidRenderer client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Mermaid Diagram Renderer" relatedTags={['diagrams', 'documentation', 'visualization', 'architecture', 'devtools']} />
</BaseLayout>
