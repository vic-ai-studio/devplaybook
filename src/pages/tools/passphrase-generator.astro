---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PassphraseGenerator from '../../components/PassphraseGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a passphrase and how is it different from a password?",
    answer: "A passphrase is a sequence of random words (e.g., 'frost-blade-coral-drone') rather than a string of random characters. Passphrases are easier to remember and type while maintaining strong entropy. A 4-word passphrase from a 200-word list has ~28 bits of entropy; from a 7,776-word EFF list, it's ~51 bits per word — similar to a 9-character random password."
  },
  {
    question: "How many words should my passphrase have?",
    answer: "For most accounts: 4 words (~28 bits). For high-security accounts (email, banking, SSH keys): 6+ words (~40+ bits). NIST SP 800-63B recommends at least 15 characters for memorized secrets. A 6-word passphrase is typically 30-40 characters and far exceeds this threshold while remaining memorable."
  },
  {
    question: "Is this tool cryptographically secure?",
    answer: "Yes. All word selection uses crypto.getRandomValues() — the Web Crypto API backed by your OS's CSPRNG (Cryptographically Secure Pseudo-Random Number Generator). This is the same randomness source used by TLS, password managers, and OS key generation. Nothing is sent to any server."
  },
  {
    question: "What is the diceware method?",
    answer: "Diceware was invented by Arnold Reinhold in 1995. You roll physical dice to select words from a numbered list — each 5-die roll selects 1 of 7,776 words. The digital version (used here) replicates the same principle with crypto.getRandomValues() instead of dice. The key insight: randomness comes from the word selection process, not word complexity."
  },
  {
    question: "Should I add numbers or symbols to my passphrase?",
    answer: "Adding a number appended to the passphrase adds log2(100) ≈ 6.6 bits of entropy. This can help satisfy password policy requirements (must contain a number) while keeping the passphrase readable. Capitalizing words helps with similar policies. However, the words themselves provide most of the security — the main value of additions is policy compliance, not a dramatic security improvement."
  },
  {
    question: "When is a random password better than a passphrase?",
    answer: "Random passwords are better when: (1) you have a password manager and will never type it manually, (2) the system has a character limit too short for a passphrase, or (3) you need maximum entropy per character (base64 URL gives ~6 bits/char vs ~7.5 bits/word). For passwords you actually need to remember — master password, disk encryption, SSH key passphrase — passphrases are superior."
  },
];
---

<BaseLayout
  title="Passphrase Generator — Diceware-style Secure Passphrases"
  description="Generate cryptographically secure diceware-style passphrases. Choose word count (3–8), separator (hyphen, dot, space), capitalization, and number suffix. Entropy strength meter included. 100% client-side — nothing sent to any server."
  tool="Passphrase Generator, Diceware Generator, Random Passphrase, Secure Passphrase, Memorable Password Generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Passphrase Generator",
    "url": "https://devplaybook.cc/tools/passphrase-generator",
    "description": "Generate cryptographically secure diceware-style passphrases with configurable word count, separator, and entropy strength meter.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Passphrase Generator</h1>
  <p class="text-text-muted mb-4">
    Generate secure, memorable passphrases using the diceware method — random words selected with
    <code class="font-mono bg-surface px-1 rounded text-sm">crypto.getRandomValues()</code>.
    Easier to type than random passwords, harder to crack than weak passwords.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 3–8 word count</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Entropy strength meter</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Cryptographically secure</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <PassphraseGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Passphrase Generator" relatedTags={['security', 'password', 'random', 'generator', 'authentication']} />
</BaseLayout>
