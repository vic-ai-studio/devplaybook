---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the difference between pooled and direct connections in Neon?", answer: "Pooled connections use PgBouncer and are ideal for serverless/edge functions that open many short-lived connections (prevents connection exhaustion). Direct connections bypass PgBouncer and are better for long-running Node.js servers and migration tools like prisma migrate." },
  { question: "What is the Neon serverless driver?", answer: "@neondatabase/serverless is Neon's HTTP/WebSocket driver that works in edge runtimes (Cloudflare Workers, Vercel Edge) where TCP isn't available. Use the neon() tagged template literal for HTTP queries or Pool for WebSocket connection pooling." },
  { question: "How do I find my Neon connection string?", answer: "In Neon Console → your project → Connection Details. You'll see a postgres:// connection string. The hostname format is: ep-<name>.<region>.aws.neon.tech for direct, or <project>-pooler.neon.tech for pooled." },
  { question: "Should I use SSL with Neon?", answer: "Yes — always use sslmode=require for Neon connections. Neon enforces SSL. The connection strings generated by this tool include SSL by default. Some libraries require ssl: { rejectUnauthorized: false } in local dev with self-signed certs." },
  { question: "Can I use Neon with Prisma?", answer: "Yes. Use the direct connection string for prisma migrate and the pooled connection string for prisma.$queryRaw and normal queries at runtime. Set DATABASE_URL to pooled and DIRECT_URL to direct in schema.prisma." },
];
---

<BaseLayout
  title="Neon DB Connection String Builder — Serverless PostgreSQL"
  description="Build Neon PostgreSQL connection strings for pooled and direct modes. Generate connection strings for Node.js, @neondatabase/serverless, Prisma, and Drizzle ORM. Free, runs in browser."
  tool="Neon DB connection string, Neon PostgreSQL, Neon serverless driver, Neon Prisma, Neon connection URL"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Neon DB Connection String Builder</h1>
  <p class="text-text-muted mb-6">Build Neon PostgreSQL connection strings for pooled and direct modes. Generate ready-to-use code for Node.js, <code class="text-primary">@neondatabase/serverless</code>, Prisma, and Drizzle.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Pooled + Direct modes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Prisma + Drizzle snippets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> SSL options</span>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6 bg-bg-card border border-border rounded-xl p-4">
    <div>
      <label class="block text-sm font-medium mb-1">Project name / endpoint</label>
      <input id="project-name" type="text" value="my-project" placeholder="my-project" class="w-full bg-bg border border-border rounded-lg p-2 text-sm font-mono focus:outline-none focus:border-primary" />
      <p class="text-xs text-text-muted mt-1">From your Neon project URL</p>
    </div>
    <div>
      <label class="block text-sm font-medium mb-1">Region</label>
      <select id="region" class="w-full bg-bg border border-border rounded-lg p-2 text-sm focus:outline-none focus:border-primary">
        <option value="us-east-2">us-east-2 (AWS Ohio)</option>
        <option value="us-east-1">us-east-1 (AWS N. Virginia)</option>
        <option value="us-west-2">us-west-2 (AWS Oregon)</option>
        <option value="eu-central-1">eu-central-1 (AWS Frankfurt)</option>
        <option value="ap-southeast-1">ap-southeast-1 (AWS Singapore)</option>
        <option value="ap-southeast-2">ap-southeast-2 (AWS Sydney)</option>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium mb-1">Database name</label>
      <input id="db-name" type="text" value="neondb" placeholder="neondb" class="w-full bg-bg border border-border rounded-lg p-2 text-sm font-mono focus:outline-none focus:border-primary" />
    </div>
    <div>
      <label class="block text-sm font-medium mb-1">Role / username</label>
      <input id="role-name" type="text" value="neondb_owner" placeholder="neondb_owner" class="w-full bg-bg border border-border rounded-lg p-2 text-sm font-mono focus:outline-none focus:border-primary" />
    </div>
    <div>
      <label class="block text-sm font-medium mb-1">Password</label>
      <input id="password" type="text" value="your-password" placeholder="your-password" class="w-full bg-bg border border-border rounded-lg p-2 text-sm font-mono focus:outline-none focus:border-primary" />
      <p class="text-xs text-text-muted mt-1">Never commit real passwords</p>
    </div>
    <div>
      <label class="block text-sm font-medium mb-1">SSL mode</label>
      <select id="ssl-mode" class="w-full bg-bg border border-border rounded-lg p-2 text-sm focus:outline-none focus:border-primary">
        <option value="require">require (recommended)</option>
        <option value="verify-full">verify-full (stricter)</option>
        <option value="prefer">prefer</option>
        <option value="">none</option>
      </select>
    </div>
  </div>

  <div class="space-y-4 mb-8">
    <div>
      <div class="flex items-center justify-between mb-1">
        <label class="text-sm font-medium">Pooled connection string</label>
        <button class="copy-btn text-xs px-2 py-1 border border-border rounded hover:border-primary hover:text-primary transition-colors" data-target="pooled-url">Copy</button>
      </div>
      <code id="pooled-url" class="block bg-bg-card border border-border rounded-lg p-3 text-xs font-mono break-all text-primary"></code>
      <p class="text-xs text-text-muted mt-1">Use for runtime queries (Prisma DATABASE_URL, serverless functions)</p>
    </div>
    <div>
      <div class="flex items-center justify-between mb-1">
        <label class="text-sm font-medium">Direct connection string</label>
        <button class="copy-btn text-xs px-2 py-1 border border-border rounded hover:border-primary hover:text-primary transition-colors" data-target="direct-url">Copy</button>
      </div>
      <code id="direct-url" class="block bg-bg-card border border-border rounded-lg p-3 text-xs font-mono break-all text-primary"></code>
      <p class="text-xs text-text-muted mt-1">Use for migrations (Prisma DIRECT_URL, pg CLI)</p>
    </div>

    <div>
      <div class="flex items-center justify-between mb-1">
        <label class="text-sm font-medium">Prisma schema.prisma datasource</label>
        <button class="copy-btn text-xs px-2 py-1 border border-border rounded hover:border-primary hover:text-primary transition-colors" data-target="prisma-snippet">Copy</button>
      </div>
      <pre id="prisma-snippet" class="bg-bg-card border border-border rounded-lg p-3 text-xs font-mono overflow-auto whitespace-pre text-text"></pre>
    </div>

    <div>
      <div class="flex items-center justify-between mb-1">
        <label class="text-sm font-medium">@neondatabase/serverless (Edge/Serverless)</label>
        <button class="copy-btn text-xs px-2 py-1 border border-border rounded hover:border-primary hover:text-primary transition-colors" data-target="neon-snippet">Copy</button>
      </div>
      <pre id="neon-snippet" class="bg-bg-card border border-border rounded-lg p-3 text-xs font-mono overflow-auto whitespace-pre text-text"></pre>
    </div>

    <div>
      <div class="flex items-center justify-between mb-1">
        <label class="text-sm font-medium">Drizzle ORM (neon-http)</label>
        <button class="copy-btn text-xs px-2 py-1 border border-border rounded hover:border-primary hover:text-primary transition-colors" data-target="drizzle-snippet">Copy</button>
      </div>
      <pre id="drizzle-snippet" class="bg-bg-card border border-border rounded-lg p-3 text-xs font-mono overflow-auto whitespace-pre text-text"></pre>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Neon DB Connection String Builder" relatedTags={['database', 'postgresql', 'neon', 'serverless', 'prisma', 'drizzle']} />
</BaseLayout>

<script>
  function get(id: string): string { return (document.getElementById(id) as HTMLInputElement).value; }

  function update() {
    const project = get('project-name') || 'my-project';
    const region = get('region');
    const db = get('db-name') || 'neondb';
    const role = get('role-name') || 'neondb_owner';
    const pass = get('password') || 'your-password';
    const ssl = get('ssl-mode');

    const sslParam = ssl ? `?sslmode=${ssl}` : '';
    const encodedPass = encodeURIComponent(pass);

    const directHost = `ep-${project}.${region}.aws.neon.tech`;
    const pooledHost = `${project}-pooler.${region}.aws.neon.tech`;

    const directUrl = `postgresql://${role}:${encodedPass}@${directHost}/${db}${sslParam}`;
    const pooledUrl = `postgresql://${role}:${encodedPass}@${pooledHost}/${db}${sslParam}`;

    (document.getElementById('pooled-url') as HTMLElement).textContent = pooledUrl;
    (document.getElementById('direct-url') as HTMLElement).textContent = directUrl;

    (document.getElementById('prisma-snippet') as HTMLElement).textContent =
`datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

# .env
DATABASE_URL="${pooledUrl}"
DIRECT_URL="${directUrl}"`;

    (document.getElementById('neon-snippet') as HTMLElement).textContent =
`import { neon } from '@neondatabase/serverless';

const sql = neon(process.env.DATABASE_URL!);

// Simple query
const users = await sql\`SELECT * FROM users LIMIT 10\`;

// Parameterized
const user = await sql\`SELECT * FROM users WHERE id = \${userId}\`;`;

    (document.getElementById('drizzle-snippet') as HTMLElement).textContent =
`import { drizzle } from 'drizzle-orm/neon-http';
import { neon } from '@neondatabase/serverless';
import * as schema from './schema';

const sql = neon(process.env.DATABASE_URL!);
export const db = drizzle(sql, { schema });

// Usage
const users = await db.select().from(schema.users);`;
  }

  document.querySelectorAll('#project-name, #db-name, #role-name, #password, #region, #ssl-mode').forEach(el => {
    el.addEventListener('input', update);
  });

  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const target = (e.target as HTMLElement).getAttribute('data-target')!;
      const text = document.getElementById(target)!.textContent || '';
      navigator.clipboard.writeText(text);
      const el = e.target as HTMLButtonElement;
      el.textContent = 'Copied!';
      setTimeout(() => { el.textContent = 'Copy'; }, 1500);
    });
  });

  update();
</script>
