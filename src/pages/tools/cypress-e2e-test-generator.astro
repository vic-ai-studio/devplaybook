---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Cypress and how is it different from Playwright?",
    answer: "Cypress is a JavaScript E2E testing framework that runs directly inside the browser, giving it unique access to browser APIs, DOM, and network layer. It features real-time reloading, time-travel debugging, and automatic waiting. Playwright runs outside the browser and supports multiple browsers (Chrome, Firefox, Safari) cross-platform. Cypress is generally easier to start with; Playwright is more powerful for multi-browser testing."
  },
  {
    question: "What does cy.intercept() do?",
    answer: "cy.intercept() lets you intercept and stub HTTP requests made by your app. You can match by method and URL, return mock responses, and assert on request/response data. This is essential for testing API-dependent flows without hitting real backends. Example: cy.intercept('GET', '/api/users', { fixture: 'users.json' }).as('getUsers')"
  },
  {
    question: "How does Cypress handle asynchronous operations?",
    answer: "Cypress automatically waits for commands to complete and has built-in retry logic for assertions. You don't need explicit waits for DOM elements — cy.get() retries until the element appears or times out. Use cy.wait('@alias') to wait for a specific network request to complete. Avoid arbitrary cy.wait(1000) delays."
  },
  {
    question: "What is the best way to select elements in Cypress tests?",
    answer: "The recommended approach is to add 'data-cy' (or 'data-testid') attributes to elements in your HTML specifically for testing. Example: <button data-cy='submit-btn'>. Then use cy.get('[data-cy=submit-btn]'). This decouples tests from styling and structure changes. Avoid selecting by CSS classes or text content as they change frequently."
  },
  {
    question: "Where do I put Cypress test files?",
    answer: "By default, Cypress looks for E2E tests in 'cypress/e2e/' with the pattern '**/*.cy.{js,jsx,ts,tsx}'. For component tests it uses 'cypress/component/'. You can customize these paths in cypress.config.js. The generated .cy.js file from this tool should be placed in your 'cypress/e2e/' directory."
  },
  {
    question: "How do I run Cypress tests in CI?",
    answer: "Use 'npx cypress run' for headless execution in CI. Add '--browser chrome' to specify the browser, '--spec cypress/e2e/mytest.cy.js' to run a specific file, and '--record' with the CYPRESS_RECORD_KEY environment variable to record results to Cypress Cloud. The Cypress GitHub Action (cypress-io/github-action) handles caching and parallelization automatically."
  }
];
---

<BaseLayout
  title="Cypress E2E Test Generator — Generate Cypress Test Files Visually"
  description="Build Cypress E2E tests by adding test steps visually. Set URL, actions (visit/click/type/assert/intercept), and get a complete .cy.js test file ready to download or copy."
  tool="Cypress test generator, Cypress E2E test builder, Cypress cy.js generator, Cypress test file, Cypress automation, E2E test creator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Cypress E2E Test Generator",
    "url": "https://devplaybook.cc/tools/cypress-e2e-test-generator",
    "description": "Generate Cypress E2E test files visually. Add test steps and get a complete .cy.js file ready to use.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Cypress E2E Test Generator</h1>
  <p class="text-text-muted mb-4">Build Cypress E2E tests step by step. Set your base URL and test name, add actions — then copy or <strong>download</strong> the generated <code class="bg-bg-card px-1 rounded text-sm">.cy.js</code> file directly into your project.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> visit/click/type/assert/wait/intercept</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Full describe/it structure</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Download as .cy.js</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy to clipboard</span>
  </div>

  <!-- Config row -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div>
      <label class="block text-sm font-medium mb-1">Base URL</label>
      <input id="base-url" type="text" value="http://localhost:3000" class="w-full bg-bg-card border border-border rounded-lg p-2.5 text-sm font-mono focus:outline-none focus:border-primary" />
    </div>
    <div>
      <label class="block text-sm font-medium mb-1">Test Suite Name (describe)</label>
      <input id="suite-name" type="text" value="User Authentication" class="w-full bg-bg-card border border-border rounded-lg p-2.5 text-sm focus:outline-none focus:border-primary" />
    </div>
  </div>

  <!-- Tests -->
  <div id="tests-container" class="space-y-4 mb-4"></div>

  <button id="btn-add-test" class="px-3 py-2 bg-primary text-white rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors mb-6">+ Add Test (it block)</button>

  <!-- Output -->
  <div class="flex items-center justify-between mb-2">
    <h2 class="text-base font-semibold">Generated Test File</h2>
    <div class="flex gap-2">
      <button id="btn-copy-test" class="px-3 py-1.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Copy</button>
      <button id="btn-download-test" class="px-3 py-1.5 bg-primary text-white rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors">Download .cy.js</button>
    </div>
  </div>
  <pre id="test-output" class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono text-green-300 whitespace-pre overflow-x-auto min-h-[280px]"></pre>

  <ToolPageCta />
  <FaqSection faq={faq} />
</BaseLayout>

<script>
(function() {
  let testCount = 0;
  const testsContainer = document.getElementById('tests-container');
  const testOutput = document.getElementById('test-output');

  const ACTION_TYPES = ['visit','click','type','check','uncheck','select','clear',
    'assert-visible','assert-text','assert-value','assert-exist','assert-not-exist',
    'wait','intercept'];

  function addTest(defaults = {}) {
    testCount++;
    const tid = testCount;
    const div = document.createElement('div');
    div.className = 'bg-bg-card border border-border rounded-lg p-4';
    div.dataset.tid = String(tid);
    div.innerHTML = `
      <div class="flex items-center gap-3 mb-3">
        <input type="text" class="it-name flex-1 bg-surface border border-border rounded-lg p-2.5 text-sm focus:outline-none focus:border-primary"
          placeholder="should allow users to login" value="${defaults.name || ''}" />
        <button class="btn-rm-test text-xs text-red-400 border border-red-400/30 px-2 py-1.5 rounded hover:bg-red-400/10 transition-colors">Remove</button>
      </div>
      <div class="steps-container space-y-2 mb-3" data-tid="${tid}"></div>
      <button class="btn-add-step text-xs text-primary hover:underline" data-tid="${tid}">+ Add Step</button>
    `;
    testsContainer.appendChild(div);

    div.querySelector('.btn-rm-test').addEventListener('click', () => { div.remove(); generate(); });
    div.querySelector('.btn-add-step').addEventListener('click', () => addStep(tid));
    div.querySelector('.it-name').addEventListener('input', generate);

    if (defaults.steps) {
      defaults.steps.forEach(s => addStep(tid, s));
    }
    generate();
  }

  function addStep(tid, defaults = {}) {
    const container = testsContainer.querySelector(`.steps-container[data-tid="${tid}"]`);
    if (!container) return;
    const row = document.createElement('div');
    row.className = 'flex flex-wrap gap-2 items-center bg-surface border border-border rounded-lg p-2';

    const actionOpts = ACTION_TYPES.map(a =>
      `<option value="${a}" ${defaults.action === a ? 'selected' : ''}>${a}</option>`
    ).join('');

    row.innerHTML = `
      <select class="step-action bg-bg-card border border-border rounded p-1.5 text-xs focus:outline-none focus:border-primary min-w-[130px]">${actionOpts}</select>
      <input type="text" class="step-selector flex-1 min-w-[150px] bg-bg-card border border-border rounded p-1.5 text-xs font-mono focus:outline-none focus:border-primary"
        placeholder="Selector (e.g. [data-cy=email])" value="${defaults.selector || ''}" />
      <input type="text" class="step-value flex-1 min-w-[100px] bg-bg-card border border-border rounded p-1.5 text-xs font-mono focus:outline-none focus:border-primary"
        placeholder="Value / text / URL" value="${defaults.value || ''}" />
      <button class="btn-rm-step text-red-400 hover:text-red-300 text-xs px-1">✕</button>
    `;
    container.appendChild(row);

    row.querySelector('.btn-rm-step').addEventListener('click', () => { row.remove(); generate(); });
    row.querySelectorAll('input, select').forEach(el => {
      el.addEventListener('change', generate);
      el.addEventListener('input', generate);
    });
    generate();
  }

  function generateStepCode(action, selector, value) {
    const sel = selector || '[data-cy=element]';
    const val = value || '';
    switch (action) {
      case 'visit': return `    cy.visit('${val || '/'}')`;
      case 'click': return `    cy.get('${sel}').click()`;
      case 'type': return `    cy.get('${sel}').type('${val}')`;
      case 'check': return `    cy.get('${sel}').check()`;
      case 'uncheck': return `    cy.get('${sel}').uncheck()`;
      case 'select': return `    cy.get('${sel}').select('${val}')`;
      case 'clear': return `    cy.get('${sel}').clear()`;
      case 'assert-visible': return `    cy.get('${sel}').should('be.visible')`;
      case 'assert-text': return `    cy.get('${sel}').should('contain.text', '${val}')`;
      case 'assert-value': return `    cy.get('${sel}').should('have.value', '${val}')`;
      case 'assert-exist': return `    cy.get('${sel}').should('exist')`;
      case 'assert-not-exist': return `    cy.get('${sel}').should('not.exist')`;
      case 'wait': return `    cy.wait(${parseInt(val) || 1000})`;
      case 'intercept': return `    cy.intercept('GET', '${val || '/api/endpoint'}').as('${sel.replace(/\W/g,'') || 'apiCall'}')`;
      default: return `    // Unknown action: ${action}`;
    }
  }

  function generate() {
    const baseUrl = document.getElementById('base-url').value.trim() || 'http://localhost:3000';
    const suiteName = document.getElementById('suite-name').value.trim() || 'My Test Suite';
    let code = `/// <reference types="cypress" />\n\n`;
    code += `describe('${suiteName}', () => {\n`;
    code += `  beforeEach(() => {\n    cy.visit('${baseUrl}')\n  })\n\n`;

    const testDivs = testsContainer.querySelectorAll('[data-tid]');
    if (testDivs.length === 0) {
      code += `  it('should work', () => {\n    cy.visit('${baseUrl}')\n  })\n`;
    } else {
      testDivs.forEach(div => {
        const itName = div.querySelector('.it-name').value.trim() || 'should work';
        const tid = div.dataset.tid;
        code += `  it('${itName}', () => {\n`;
        div.querySelectorAll('.steps-container > div').forEach(row => {
          const action = row.querySelector('.step-action').value;
          const selector = row.querySelector('.step-selector').value.trim();
          const value = row.querySelector('.step-value').value.trim();
          code += generateStepCode(action, selector, value) + '\n';
        });
        code += `  })\n\n`;
      });
    }

    code += `})\n`;
    testOutput.textContent = code;
  }

  document.getElementById('btn-add-test').addEventListener('click', () => addTest());

  ['base-url','suite-name'].forEach(id => {
    document.getElementById(id).addEventListener('input', generate);
  });

  document.getElementById('btn-copy-test').addEventListener('click', function() {
    navigator.clipboard.writeText(testOutput.textContent || '');
    this.textContent = 'Copied!'; setTimeout(() => { this.textContent = 'Copy'; }, 2000);
  });

  document.getElementById('btn-download-test').addEventListener('click', () => {
    const code = testOutput.textContent || '';
    const suiteName = (document.getElementById('suite-name').value.trim() || 'my-test')
      .toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
    const blob = new Blob([code], { type: 'text/javascript' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = `${suiteName}.cy.js`; a.click();
    URL.revokeObjectURL(url);
  });

  // Preload example
  addTest({
    name: 'should allow user to login successfully',
    steps: [
      { action: 'visit', value: '/login' },
      { action: 'assert-visible', selector: '[data-cy=login-form]' },
      { action: 'type', selector: '[data-cy=email-input]', value: 'test@example.com' },
      { action: 'type', selector: '[data-cy=password-input]', value: 'password123' },
      { action: 'click', selector: '[data-cy=submit-btn]' },
      { action: 'assert-text', selector: '[data-cy=welcome-msg]', value: 'Welcome back' },
    ]
  });
  addTest({
    name: 'should show error for invalid credentials',
    steps: [
      { action: 'visit', value: '/login' },
      { action: 'type', selector: '[data-cy=email-input]', value: 'wrong@example.com' },
      { action: 'type', selector: '[data-cy=password-input]', value: 'wrongpass' },
      { action: 'click', selector: '[data-cy=submit-btn]' },
      { action: 'assert-visible', selector: '[data-cy=error-msg]' },
      { action: 'assert-text', selector: '[data-cy=error-msg]', value: 'Invalid credentials' },
    ]
  });
})();
</script>
