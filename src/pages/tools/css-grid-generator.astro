---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CssGrid from '../../components/CssGrid.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---
<BaseLayout
  title="CSS Grid Generator — Visual Grid Layout Builder"
  description="Build CSS Grid layouts visually. Configure grid-template-columns, rows, gaps, alignment, and item placement. Copy the generated CSS instantly. No signup needed."
  tool="CSS Grid Generator, CSS Grid Layout, CSS Grid Visualizer"
>
  <h1 class="text-3xl font-bold mb-2">CSS Grid Generator</h1>
  <p class="text-text-muted mb-4">Design CSS Grid layouts interactively. Set columns, rows, gaps, and alignment — then click items to control their placement. Copy the ready-to-use CSS in one click.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <CssGrid client:only="preact" />
  <ToolPageCta currentTool="CSS Grid Generator" relatedTags={['css', 'grid', 'layout', 'frontend']} />
</BaseLayout>
