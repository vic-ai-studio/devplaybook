---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CssGrid from '../../components/CssGrid.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How do I create a CSS Grid layout with this tool?", answer: "Set the number of columns and rows, adjust gap sizes, and choose alignment options. Click on individual grid items to control their column/row span and placement. The tool generates the corresponding CSS in real time — copy it into your stylesheet." },
  { question: "Does this generate responsive CSS Grid code?", answer: "The tool generates the base grid CSS. For responsive layouts, wrap the generated code in media queries or replace fixed column values with auto-fit/minmax patterns. The output gives you a solid starting point to build on." },
  { question: "What CSS properties does this tool support?", answer: "It covers grid-template-columns, grid-template-rows, gap (row-gap and column-gap), justify-items, align-items, and per-item placement via grid-column and grid-row. These are the most commonly used CSS Grid properties." },
  { question: "Can I use fr, px, and auto units?", answer: "Yes. You can mix fractional (fr), pixel (px), percentage (%), and auto units for both columns and rows. This lets you create flexible layouts with fixed sidebars, fluid content areas, and more." },
  { question: "Is this better than writing CSS Grid by hand?", answer: "It's faster for prototyping. Visually designing the layout helps you understand how grid-template-columns and item placement interact. Once you're comfortable, you can write CSS Grid by hand and use this tool for quick experiments." },
];
---

<BaseLayout
  title="CSS Grid Generator — Visual Grid Layout Builder Free Online"
  description="Build CSS Grid layouts visually. Configure grid-template-columns, rows, gaps, alignment, and item placement with fr, px, and auto units. Copy production-ready CSS instantly. Free online tool — no signup needed."
  tool="CSS Grid Generator, CSS Grid Layout, CSS Grid Visualizer, Grid Template Builder, CSS Layout Tool"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">CSS Grid Generator</h1>
  <p class="text-text-muted mb-4">Design CSS Grid layouts interactively — set columns, rows, gaps, and alignment, then click items to control their placement. Supports <code class="font-mono text-sm">fr</code>, <code class="font-mono text-sm">px</code>, and <code class="font-mono text-sm">auto</code> units. Copy the ready-to-use CSS in one click.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <CssGrid client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CSS Grid Generator" relatedTags={['css', 'grid', 'layout', 'frontend']} />
</BaseLayout>
