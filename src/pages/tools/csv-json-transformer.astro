---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What makes this CSV to JSON tool 'advanced'?", answer: "Unlike basic converters, this tool lets you map each column individually: rename the JSON key, toggle a column on or off, and set the type (string, number, boolean). This is useful when your CSV has columns you don't need, headers with spaces or special characters, or numeric columns that are incorrectly treated as strings." },
  { question: "How does the column type setting work?", answer: "When you set a column to 'number', values are parsed with parseFloat/parseInt. 'boolean' converts 'true', '1', 'yes', 'on' to true and everything else to false. 'string' keeps the value as-is. This lets you get properly typed JSON without post-processing." },
  { question: "Can I convert JSON back to CSV?", answer: "Yes. Switch to JSON → CSV mode by clicking the direction toggle. Paste a JSON array of objects and get clean CSV with headers from the first object's keys. Nested objects are flattened to a string representation." },
  { question: "What CSV delimiters are supported?", answer: "The tool auto-detects comma (,), semicolon (;), and tab (\t) delimiters by sampling the first line of your CSV. You can also manually select the delimiter from the dropdown if auto-detection picks the wrong one." },
  { question: "Is there a row limit for CSV conversion?", answer: "No hard limit — the conversion runs in your browser. Very large files (100k+ rows) may cause brief UI lag since JavaScript is single-threaded. For production data processing, use server-side tools like Python pandas or Node.js csv-parse." },
  { question: "Are my CSV or JSON files uploaded anywhere?", answer: "No. All processing runs entirely in your browser using vanilla JavaScript. Your data never leaves your machine, making this safe for files containing PII, credentials, or sensitive business data." },
];
---

<BaseLayout
  title="CSV JSON Transformer — Advanced CSV to JSON with Column Mapping"
  description="Advanced CSV to JSON converter with column mapping. Toggle columns, rename keys, set types (string/number/boolean). Bidirectional CSV↔JSON. Free, runs in your browser."
  tool="CSV to JSON converter, JSON to CSV, CSV column mapping, CSV transformer, convert CSV JSON online, CSV type casting"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "CSV JSON Transformer",
    "url": "https://devplaybook.cc/tools/csv-json-transformer",
    "description": "Advanced CSV to JSON converter with column mapping. Toggle columns on/off, rename JSON keys, set column types. Bidirectional CSV↔JSON conversion.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">CSV JSON Transformer</h1>
  <p class="text-text-muted mb-4">
    Advanced CSV ↔ JSON converter with column mapping. Toggle columns on/off, rename JSON keys,
    and set column types (string, number, boolean). Paste your CSV and configure the mapping before converting.
    Runs entirely in your browser — your data never leaves your machine.
  </p>
  <div class="flex items-center gap-3 mb-8 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Toggle columns on/off</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Rename JSON keys</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Type casting (string/number/bool)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Bidirectional CSV ↔ JSON</span>
  </div>

  <!-- Direction toggle -->
  <div class="flex gap-2 mb-6">
    <button id="btn-csv-to-json" class="bg-primary text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors">CSV → JSON</button>
    <button id="btn-json-to-csv" class="bg-bg-card border border-border text-text px-4 py-2 rounded-lg text-sm font-semibold hover:bg-bg-secondary transition-colors">JSON → CSV</button>
  </div>

  <!-- CSV mode -->
  <div id="csv-mode">
    <!-- Delimiter -->
    <div class="flex items-center gap-4 mb-4">
      <label class="text-sm font-medium">Delimiter:</label>
      <select id="delimiter-select" class="bg-bg-card border border-border rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40">
        <option value="auto">Auto-detect</option>
        <option value=",">Comma (,)</option>
        <option value=";">Semicolon (;)</option>
        <option value="	">Tab</option>
      </select>
      <button id="csv-example" class="text-xs text-primary hover:underline ml-auto">Load example</button>
    </div>

    <div class="bg-bg-card border border-border rounded-xl p-5 mb-4">
      <div class="flex items-center justify-between mb-3">
        <label class="font-semibold text-sm" for="csv-input">CSV Input</label>
        <span class="text-xs text-text-muted" id="csv-row-count"></span>
      </div>
      <textarea id="csv-input" rows="10"
        placeholder="id,name,age,active&#10;1,Alice,30,true&#10;2,Bob,25,false"
        class="w-full bg-bg border border-border rounded-lg px-3 py-3 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40 resize-y"></textarea>
    </div>

    <button id="parse-csv-btn" class="bg-bg-secondary border border-border text-text px-4 py-2 rounded-lg text-sm font-semibold hover:bg-bg-card transition-colors mb-4">
      Parse CSV & Configure Columns
    </button>

    <!-- Column mapping UI -->
    <div id="column-mapping" class="hidden bg-bg-card border border-border rounded-xl p-5 mb-4">
      <h3 class="font-semibold text-sm mb-3">Column Mapping</h3>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border text-text-muted text-xs uppercase tracking-wide">
              <th class="text-left py-2 pr-3 font-medium">Include</th>
              <th class="text-left py-2 pr-3 font-medium">CSV Column</th>
              <th class="text-left py-2 pr-3 font-medium">JSON Key</th>
              <th class="text-left py-2 font-medium">Type</th>
            </tr>
          </thead>
          <tbody id="column-rows"></tbody>
        </table>
      </div>
    </div>

    <div id="csv-error" class="hidden mb-4 p-3 bg-red-500/10 border border-red-500/20 rounded-lg text-sm text-red-400"></div>

    <div class="flex gap-3 mb-4">
      <button id="csv-convert-btn" class="bg-primary text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-primary/80 transition-colors hidden">
        Convert to JSON
      </button>
      <button id="csv-clear" class="text-sm text-text-muted hover:text-red-400 transition-colors">Clear</button>
    </div>

    <div id="csv-output-wrap" class="hidden bg-bg-card border border-border rounded-xl p-5 mb-8">
      <div class="flex items-center justify-between mb-3">
        <span class="font-semibold text-sm">JSON Output</span>
        <button id="csv-copy" class="text-xs text-primary hover:underline">Copy</button>
      </div>
      <textarea id="csv-json-output" rows="16" readonly
        class="w-full bg-bg border border-border rounded-lg px-3 py-3 text-sm font-mono resize-y text-text-muted focus:outline-none"></textarea>
    </div>
  </div>

  <!-- JSON to CSV mode -->
  <div id="json-mode" class="hidden">
    <div class="bg-bg-card border border-border rounded-xl p-5 mb-4">
      <div class="flex items-center justify-between mb-3">
        <label class="font-semibold text-sm" for="json-input">JSON Input (array of objects)</label>
        <button id="json-example" class="text-xs text-primary hover:underline">Load example</button>
      </div>
      <textarea id="json-input" rows="12"
        placeholder='[{"id":1,"name":"Alice","age":30},{"id":2,"name":"Bob","age":25}]'
        class="w-full bg-bg border border-border rounded-lg px-3 py-3 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40 resize-y"></textarea>
    </div>

    <div id="json-error" class="hidden mb-4 p-3 bg-red-500/10 border border-red-500/20 rounded-lg text-sm text-red-400"></div>

    <div class="flex gap-3 mb-4">
      <button id="json-convert-btn" class="bg-primary text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-primary/80 transition-colors">
        Convert to CSV
      </button>
      <button id="json-clear" class="text-sm text-text-muted hover:text-red-400 transition-colors">Clear</button>
    </div>

    <div id="json-output-wrap" class="hidden bg-bg-card border border-border rounded-xl p-5 mb-8">
      <div class="flex items-center justify-between mb-3">
        <span class="font-semibold text-sm">CSV Output</span>
        <button id="json-copy" class="text-xs text-primary hover:underline">Copy</button>
      </div>
      <textarea id="json-csv-output" rows="12" readonly
        class="w-full bg-bg border border-border rounded-lg px-3 py-3 text-sm font-mono resize-y text-text-muted focus:outline-none"></textarea>
    </div>
  </div>

  <AffiliateSection />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CSV JSON Transformer" relatedTags={['csv', 'json', 'converter', 'data', 'transformer']} />
</BaseLayout>

<script is:inline>
(function () {
  var mode = 'csv-to-json';
  var parsedHeaders = [];
  var parsedRows = [];

  // ── Delimiter detection ───────────────────────────────────────────────────────
  function detectDelimiter(line) {
    var counts = { ',': 0, ';': 0, '\t': 0 };
    for (var i = 0; i < line.length; i++) {
      if (counts.hasOwnProperty(line[i])) counts[line[i]]++;
    }
    var best = ',';
    var bestCount = counts[','];
    Object.keys(counts).forEach(function(d) {
      if (counts[d] > bestCount) { bestCount = counts[d]; best = d; }
    });
    return best;
  }

  // ── CSV parser ────────────────────────────────────────────────────────────────
  function parseCsv(raw, delim) {
    var lines = raw.trim().split('\n');
    if (!lines.length) return { headers: [], rows: [] };
    var d = delim === 'auto' ? detectDelimiter(lines[0]) : delim;
    var headers = splitCsvLine(lines[0], d);
    var rows = [];
    for (var i = 1; i < lines.length; i++) {
      var line = lines[i].trim();
      if (!line) continue;
      rows.push(splitCsvLine(line, d));
    }
    return { headers: headers, rows: rows };
  }

  function splitCsvLine(line, d) {
    var fields = [];
    var inQuote = false;
    var cur = '';
    for (var i = 0; i < line.length; i++) {
      var c = line[i];
      if (c === '"') {
        if (inQuote && line[i + 1] === '"') { cur += '"'; i++; }
        else inQuote = !inQuote;
      } else if (c === d && !inQuote) {
        fields.push(cur.trim());
        cur = '';
      } else {
        cur += c;
      }
    }
    fields.push(cur.trim());
    return fields;
  }

  // ── Type casting ──────────────────────────────────────────────────────────────
  function castValue(val, type) {
    if (type === 'number') {
      var n = Number(val);
      return isNaN(n) ? val : n;
    }
    if (type === 'boolean') {
      return /^(true|1|yes|on)$/i.test(val.trim());
    }
    return val;
  }

  // ── CSV examples ──────────────────────────────────────────────────────────────
  var CSV_EXAMPLE = [
    'id,name,email,age,active,score',
    '1,Alice Johnson,alice@example.com,30,true,98.5',
    '2,Bob Smith,bob@example.com,25,false,72.0',
    '3,Carol White,carol@example.com,35,true,88.3',
  ].join('\n');

  var JSON_EXAMPLE = JSON.stringify([
    { "id": 1, "name": "Alice Johnson", "email": "alice@example.com", "age": 30, "active": true },
    { "id": 2, "name": "Bob Smith", "email": "bob@example.com", "age": 25, "active": false },
    { "id": 3, "name": "Carol White", "email": "carol@example.com", "age": 35, "active": true },
  ], null, 2);

  // ── Mode switching ────────────────────────────────────────────────────────────
  function setMode(newMode) {
    mode = newMode;
    var isCsv = mode === 'csv-to-json';
    document.getElementById('csv-mode').classList.toggle('hidden', !isCsv);
    document.getElementById('json-mode').classList.toggle('hidden', isCsv);
    document.getElementById('btn-csv-to-json').className = isCsv
      ? 'bg-primary text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors'
      : 'bg-bg-card border border-border text-text px-4 py-2 rounded-lg text-sm font-semibold hover:bg-bg-secondary transition-colors';
    document.getElementById('btn-json-to-csv').className = !isCsv
      ? 'bg-primary text-white px-4 py-2 rounded-lg text-sm font-semibold transition-colors'
      : 'bg-bg-card border border-border text-text px-4 py-2 rounded-lg text-sm font-semibold hover:bg-bg-secondary transition-colors';
  }

  document.getElementById('btn-csv-to-json').addEventListener('click', function() { setMode('csv-to-json'); });
  document.getElementById('btn-json-to-csv').addEventListener('click', function() { setMode('json-to-csv'); });

  // ── CSV mode ──────────────────────────────────────────────────────────────────
  document.getElementById('csv-example').addEventListener('click', function() {
    document.getElementById('csv-input').value = CSV_EXAMPLE;
  });

  document.getElementById('csv-clear').addEventListener('click', function() {
    document.getElementById('csv-input').value = '';
    document.getElementById('column-mapping').classList.add('hidden');
    document.getElementById('csv-convert-btn').classList.add('hidden');
    document.getElementById('csv-output-wrap').classList.add('hidden');
    document.getElementById('csv-error').classList.add('hidden');
    document.getElementById('csv-row-count').textContent = '';
    parsedHeaders = []; parsedRows = [];
  });

  document.getElementById('parse-csv-btn').addEventListener('click', function() {
    var raw = document.getElementById('csv-input').value.trim();
    var errEl = document.getElementById('csv-error');
    errEl.classList.add('hidden');
    if (!raw) { errEl.textContent = 'Please paste CSV data first.'; errEl.classList.remove('hidden'); return; }

    var delim = document.getElementById('delimiter-select').value;
    var parsed = parseCsv(raw, delim);
    parsedHeaders = parsed.headers;
    parsedRows = parsed.rows;

    document.getElementById('csv-row-count').textContent = parsedRows.length + ' rows';

    // Build column mapping UI
    var tbody = document.getElementById('column-rows');
    tbody.innerHTML = '';
    parsedHeaders.forEach(function(h, idx) {
      var tr = document.createElement('tr');
      tr.className = 'border-b border-border/50';
      tr.innerHTML =
        '<td class="py-2 pr-3">' +
          '<input type="checkbox" checked class="col-include" data-idx="' + idx + '" />' +
        '</td>' +
        '<td class="py-2 pr-3 font-mono text-xs text-text-muted">' + escHtml(h) + '</td>' +
        '<td class="py-2 pr-3">' +
          '<input type="text" value="' + escHtml(h) + '" class="col-key bg-bg border border-border rounded px-2 py-1 text-xs font-mono w-full focus:outline-none focus:ring-1 focus:ring-primary/40" data-idx="' + idx + '" />' +
        '</td>' +
        '<td class="py-2">' +
          '<select class="col-type bg-bg border border-border rounded px-2 py-1 text-xs focus:outline-none focus:ring-1 focus:ring-primary/40" data-idx="' + idx + '">' +
            '<option value="string">string</option>' +
            '<option value="number">number</option>' +
            '<option value="boolean">boolean</option>' +
          '</select>' +
        '</td>';
      tbody.appendChild(tr);
    });

    document.getElementById('column-mapping').classList.remove('hidden');
    document.getElementById('csv-convert-btn').classList.remove('hidden');
  });

  function escHtml(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function getColumnConfig() {
    var config = [];
    var includes = document.querySelectorAll('.col-include');
    var keys = document.querySelectorAll('.col-key');
    var types = document.querySelectorAll('.col-type');
    for (var i = 0; i < includes.length; i++) {
      config.push({
        include: includes[i].checked,
        key: keys[i].value || parsedHeaders[i],
        type: types[i].value,
      });
    }
    return config;
  }

  document.getElementById('csv-convert-btn').addEventListener('click', function() {
    var errEl = document.getElementById('csv-error');
    errEl.classList.add('hidden');
    try {
      var config = getColumnConfig();
      var result = parsedRows.map(function(row) {
        var obj = {};
        config.forEach(function(col, idx) {
          if (!col.include) return;
          var val = row[idx] !== undefined ? row[idx] : '';
          obj[col.key] = castValue(val, col.type);
        });
        return obj;
      });
      var outEl = document.getElementById('csv-json-output');
      outEl.value = JSON.stringify(result, null, 2);
      document.getElementById('csv-output-wrap').classList.remove('hidden');
    } catch (e) {
      errEl.textContent = 'Error: ' + (e.message || String(e));
      errEl.classList.remove('hidden');
    }
  });

  document.getElementById('csv-copy').addEventListener('click', function() {
    var val = document.getElementById('csv-json-output').value;
    if (val) navigator.clipboard && navigator.clipboard.writeText(val);
    this.textContent = 'Copied!';
    var btn = this;
    setTimeout(function() { btn.textContent = 'Copy'; }, 2000);
  });

  // ── JSON to CSV mode ──────────────────────────────────────────────────────────
  document.getElementById('json-example').addEventListener('click', function() {
    document.getElementById('json-input').value = JSON_EXAMPLE;
  });

  document.getElementById('json-clear').addEventListener('click', function() {
    document.getElementById('json-input').value = '';
    document.getElementById('json-output-wrap').classList.add('hidden');
    document.getElementById('json-error').classList.add('hidden');
  });

  document.getElementById('json-convert-btn').addEventListener('click', function() {
    var raw = document.getElementById('json-input').value.trim();
    var errEl = document.getElementById('json-error');
    errEl.classList.add('hidden');

    if (!raw) { errEl.textContent = 'Please paste JSON data first.'; errEl.classList.remove('hidden'); return; }

    try {
      var arr = JSON.parse(raw);
      if (!Array.isArray(arr)) throw new Error('JSON must be an array of objects.');
      if (!arr.length) throw new Error('Array is empty.');
      var headers = Object.keys(arr[0]);
      var lines = [headers.map(csvEscape).join(',')];
      arr.forEach(function(row) {
        lines.push(headers.map(function(h) {
          var v = row[h];
          if (v === null || v === undefined) return '';
          if (typeof v === 'object') return csvEscape(JSON.stringify(v));
          return csvEscape(String(v));
        }).join(','));
      });
      document.getElementById('json-csv-output').value = lines.join('\n');
      document.getElementById('json-output-wrap').classList.remove('hidden');
    } catch (e) {
      errEl.textContent = 'Error: ' + (e.message || String(e));
      errEl.classList.remove('hidden');
    }
  });

  function csvEscape(s) {
    if (/[",\n\r]/.test(s)) return '"' + s.replace(/"/g, '""') + '"';
    return s;
  }

  document.getElementById('json-copy').addEventListener('click', function() {
    var val = document.getElementById('json-csv-output').value;
    if (val) navigator.clipboard && navigator.clipboard.writeText(val);
    this.textContent = 'Copied!';
    var btn = this;
    setTimeout(function() { btn.textContent = 'Copy'; }, 2000);
  });
})();
</script>
