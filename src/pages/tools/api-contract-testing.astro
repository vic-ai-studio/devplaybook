---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the difference between contract testing and integration testing?", answer: "Integration tests deploy both the consumer and provider together and test real interactions. They are slow, flaky, and require a shared environment. Contract tests decouple this: the consumer records its expectations (the contract) as a file, and the provider verifies it independently against its actual implementation without needing the consumer running. Contract tests are faster, more targeted, and enable independent deployments because each team can verify compatibility without orchestrating a shared test environment." },
  { question: "What is consumer-driven contract testing?", answer: "Consumer-driven contract testing means the consumer (the service making API calls) defines the contract — the minimum shape of requests and responses it needs. The provider then verifies that its implementation satisfies every consumer's contract. This approach prevents providers from breaking consumers they don't know about and gives providers a clear spec for what consumers actually use, rather than testing an assumed API surface." },
  { question: "What is Pact Broker?", answer: "Pact Broker is a central repository for storing, versioning, and sharing Pact contract files between consumer and provider teams. Without a broker, teams pass contract JSON files manually (via git or shared storage). The Pact Broker provides a UI for viewing compatibility matrices, webhooks to trigger provider verification when a new contract is published, 'can I deploy' queries to check if a version is safe to deploy, and network graphs of service dependencies." },
  { question: "What is the difference between Pact and schema-based contract testing?", answer: "Pact is consumer-driven: consumers generate contracts from real interactions in tests, capturing only what they actually use. Schema-based testing (OpenAPI + schemathesis/dredd) validates that the provider's actual responses conform to its declared OpenAPI specification. These approaches are complementary — schema testing catches spec drift from the provider's side, while Pact catches breaking changes from the consumer's perspective." },
  { question: "What is schemathesis?", answer: "Schemathesis is an OpenAPI contract testing tool that automatically generates test cases from your OpenAPI spec using property-based testing. It creates hundreds of valid and invalid inputs based on your schema definitions and runs them against your live API, looking for schema violations, 500 errors, crashes, and security issues like input that should be rejected but isn't. It is more thorough than hand-written tests because it explores edge cases you would not think to write manually." },
  { question: "How do I integrate contract testing into CI/CD?", answer: "For Pact: consumers run tests and publish contracts to Pact Broker on every PR. The Pact Broker triggers provider verification via webhook. Before deploying, both teams run pact-broker can-i-deploy to confirm compatibility. For OpenAPI: run schemathesis against the staging environment as a step in the provider's deployment pipeline. Gate deployments on test results. The goal is making it impossible to deploy a breaking change without knowing about it first." },
];
---
<BaseLayout
  title="API Contract Testing: Pact, OpenAPI & Consumer-Driven Guide"
  description="Complete API contract testing guide: consumer-driven contracts with Pact, provider verification, OpenAPI contract testing with schemathesis, Pact Broker setup, and CI/CD pipeline integration."
  tool="contract testing, Pact consumer-driven contracts, OpenAPI testing, schemathesis, dredd, API testing, Pact Broker"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "API Contract Testing: Pact, OpenAPI & Consumer-Driven Guide",
    "url": "https://devplaybook.cc/tools/api-contract-testing",
    "description": "Complete guide to API contract testing covering Pact consumer-driven contracts, provider verification, OpenAPI testing, and CI/CD integration.",
  })} />

  <h1 class="text-3xl font-bold mb-2">API Contract Testing: Pact, OpenAPI & Consumer-Driven Guide</h1>
  <p class="text-text-muted mb-6">Contract testing lets consumer and provider services verify compatibility independently — no shared environment, no end-to-end flakiness. This guide covers consumer-driven contracts with Pact, OpenAPI schema validation with schemathesis, and pipeline integration.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Pact consumer & provider setup</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> OpenAPI schemathesis testing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Pact Broker workflow</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CI/CD pipeline integration</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Contract Testing vs Integration Testing</h2>
  <div class="overflow-x-auto mb-8">
    <table class="w-full text-sm border border-border rounded-xl overflow-hidden">
      <thead class="bg-bg-card">
        <tr>
          <th class="text-left px-4 py-3 font-semibold">Criteria</th>
          <th class="text-left px-4 py-3 font-semibold">Contract Testing (Pact)</th>
          <th class="text-left px-4 py-3 font-semibold">Integration Testing</th>
          <th class="text-left px-4 py-3 font-semibold">Schema Testing (OpenAPI)</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <tr class="bg-bg-surface/50">
          <td class="px-4 py-3 font-medium">Environment needed</td>
          <td class="px-4 py-3 text-green-500">None (mock provider)</td>
          <td class="px-4 py-3 text-red-400">Both services running</td>
          <td class="px-4 py-3">Provider only</td>
        </tr>
        <tr>
          <td class="px-4 py-3 font-medium">Speed</td>
          <td class="px-4 py-3 text-green-500">Fast (unit-level)</td>
          <td class="px-4 py-3">Slow</td>
          <td class="px-4 py-3">Moderate</td>
        </tr>
        <tr class="bg-bg-surface/50">
          <td class="px-4 py-3 font-medium">Who defines spec</td>
          <td class="px-4 py-3 text-green-500">Consumer</td>
          <td class="px-4 py-3">Shared</td>
          <td class="px-4 py-3">Provider (OpenAPI)</td>
        </tr>
        <tr>
          <td class="px-4 py-3 font-medium">Catches breaking changes</td>
          <td class="px-4 py-3 text-green-500">Yes (per consumer)</td>
          <td class="px-4 py-3 text-green-500">Yes</td>
          <td class="px-4 py-3 text-green-500">Yes (spec drift)</td>
        </tr>
        <tr class="bg-bg-surface/50">
          <td class="px-4 py-3 font-medium">Independent deploys</td>
          <td class="px-4 py-3 text-green-500">Enabled</td>
          <td class="px-4 py-3 text-red-400">Requires coordination</td>
          <td class="px-4 py-3">Partial</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pact Consumer Test (Node.js / Jest)</h2>
  <p class="text-text-muted mb-4">The consumer defines the expected interaction. Pact spins up a mock provider, runs the consumer code against it, and saves the resulting contract as a JSON file:</p>
  <pre class="bg-bg-surface border border-border rounded-xl p-4 overflow-x-auto text-sm font-mono mb-6"><code>// consumer.pact.test.ts
import &#123; PactV3, MatchersV3 &#125; from '@pact-foundation/pact';
import &#123; getUserById &#125; from '../api/usersClient';

const &#123; like, string, integer &#125; = MatchersV3;

const provider = new PactV3(&#123;
  consumer: 'orders-service',
  provider: 'users-service',
  port: 8080,
  dir: './pacts',  // contract files saved here
&#125;);

describe('Users Service contract', () => &#123;
  it('returns a user by ID', async () => &#123;
    await provider
      .given('user 42 exists')
      .uponReceiving('a request for user 42')
      .withRequest(&#123;
        method: 'GET',
        path: '/users/42',
        headers: &#123; Authorization: like('Bearer token') &#125;,
      &#125;)
      .willRespondWith(&#123;
        status: 200,
        headers: &#123; 'Content-Type': string('application/json') &#125;,
        body: &#123;
          id: integer(42),
          name: string('Vic Chen'),
          email: string('vic@example.com'),
        &#125;,
      &#125;)
      .executeTest(async (mockServer) => &#123;
        const user = await getUserById(mockServer.url, '42');
        expect(user.id).toBe(42);
        expect(user.name).toBeDefined();
      &#125;);
  &#125;);
&#125;);
// After tests: ./pacts/orders-service-users-service.json is created</code></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pact Provider Verification</h2>
  <p class="text-text-muted mb-4">The provider loads contracts from the Pact Broker and verifies its real implementation satisfies every consumer's expectations:</p>
  <pre class="bg-bg-surface border border-border rounded-xl p-4 overflow-x-auto text-sm font-mono mb-6"><code>// provider.pact.test.ts — run in the users-service CI pipeline
import &#123; Verifier &#125; from '@pact-foundation/pact';
import &#123; app &#125; from '../src/app';
import http from 'http';

describe('Pact Provider Verification', () => &#123;
  let server: http.Server;
  let port: number;

  beforeAll(() => new Promise(resolve => &#123;
    server = app.listen(0, () => &#123;
      port = (server.address() as any).port;
      resolve(undefined);
    &#125;);
  &#125;));

  afterAll(() => server.close());

  it('verifies all consumer contracts', async () => &#123;
    await new Verifier(&#123;
      providerBaseUrl: `http://localhost:$&#123;port&#125;`,
      pactBrokerUrl: process.env.PACT_BROKER_URL,
      pactBrokerToken: process.env.PACT_BROKER_TOKEN,
      provider: 'users-service',
      publishVerificationResult: true,
      providerVersion: process.env.GIT_SHA,
      // State handlers — set up test data per consumer scenario
      stateHandlers: &#123;
        'user 42 exists': async () => &#123;
          await db.users.upsert(&#123; id: 42, name: 'Vic Chen', email: 'vic@example.com' &#125;);
        &#125;,
        'no users exist': async () => &#123;
          await db.users.deleteAll();
        &#125;,
      &#125;,
    &#125;).verifyProvider();
  &#125;);
&#125;);</code></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">OpenAPI Contract Testing with Schemathesis</h2>
  <p class="text-text-muted mb-4">Schemathesis generates hundreds of test cases from your OpenAPI spec and runs them against your live API, finding schema violations and crashes automatically:</p>
  <pre class="bg-bg-surface border border-border rounded-xl p-4 overflow-x-auto text-sm font-mono mb-6"><code># Install schemathesis
pip install schemathesis

# Test against a live staging API
schemathesis run https://staging-api.example.com/openapi.json \
  --checks all \
  --auth "Bearer $API_TOKEN" \
  --stateful=links \           # Follow OpenAPI link objects for stateful flows
  --max-examples=200 \         # Property-based test cases per endpoint
  --junit-xml=results.xml      # Output for CI

# Or test a local spec against a local server
schemathesis run ./openapi.yaml --url http://localhost:8080

# Example findings schemathesis catches:
# - 500 errors on valid inputs matching the spec
# - 200 responses with missing required fields
# - Accepting strings where the spec declares integer
# - Missing fields in error responses

# CI step in GitHub Actions
- name: API contract tests
  run: |
    schemathesis run $STAGING_URL/openapi.json \
      --auth "Bearer $&#123;&#123; secrets.API_TOKEN &#125;&#125;" \
      --checks all \
      --junit-xml=schemathesis-results.xml
  continue-on-error: false</code></pre>

  <ToolPageCta currentTool="api-contract-testing" relatedTags={['api', 'testing', 'backend', 'openapi', 'devops', 'microservices']} />
  <FaqSection faq={faq} />
</BaseLayout>
