---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How accurate is this token counter?", answer: "This tool uses character-based estimation which is accurate to within ~5-10% for most English text. For exact token counts, use the official tokenizer for each model (tiktoken for OpenAI, claude-tokenizer for Anthropic). Non-English text and code may vary more." },
  { question: "Why do different models have different token counts for the same text?", answer: "Each model uses a different tokenizer (vocabulary). GPT-4 and Claude use similar byte-pair encoding but with different vocabularies. The same sentence can produce 10-20% different token counts. Always test with the official tokenizer when budgeting for production." },
  { question: "What is a token?", answer: "A token is roughly 4 characters or 0.75 words in English. Common words are often single tokens. Rare words, code, and non-English text tend to use more tokens. Whitespace and punctuation are usually separate tokens." },
  { question: "Why is Claude priced per million tokens?", answer: "All major LLM APIs (OpenAI, Anthropic, Google) charge per million input and output tokens. Output tokens are typically 3–5x more expensive than input. Monitoring token usage helps you stay within budget for high-volume applications." },
];
---

<BaseLayout
  title="AI Token Counter — Count Tokens for GPT-4, Claude, Gemini"
  description="Count approximate tokens for GPT-4o, Claude 3.5, Gemini 1.5, and more. Paste text to see per-model token counts and estimated API cost. Free, runs in browser."
  tool="AI token counter, GPT-4 token count, Claude token counter, Gemini tokens, LLM token estimator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">AI Token Counter</h1>
  <p class="text-text-muted mb-6">Paste any text to see approximate token counts and estimated API costs for GPT-4o, Claude 3.5, Gemini 1.5, and more. All processing is client-side.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 8 models</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Input + output cost</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs in browser</span>
  </div>

  <div class="mb-4">
    <label class="block text-sm font-medium mb-2">Paste your text</label>
    <textarea
      id="input-text"
      rows="8"
      placeholder="Paste any text, prompt, or conversation here..."
      class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary resize-y"
    ></textarea>
    <div class="flex justify-between text-xs text-text-muted mt-1">
      <span id="char-count">0 characters · 0 words</span>
      <button id="clear-btn" class="text-text-muted hover:text-primary transition-colors">Clear</button>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-6">
    <div>
      <label class="block text-sm font-medium mb-1">Estimated output tokens</label>
      <input
        id="output-tokens"
        type="number"
        value="500"
        min="0"
        class="w-full bg-bg-card border border-border rounded-lg p-2 text-sm focus:outline-none focus:border-primary"
      />
      <p class="text-xs text-text-muted mt-1">For cost estimation of responses</p>
    </div>
    <div>
      <label class="block text-sm font-medium mb-1">Requests per month</label>
      <input
        id="monthly-requests"
        type="number"
        value="1000"
        min="1"
        class="w-full bg-bg-card border border-border rounded-lg p-2 text-sm focus:outline-none focus:border-primary"
      />
    </div>
  </div>

  <div id="results" class="overflow-x-auto mb-8">
    <table class="w-full text-sm min-w-[560px]">
      <thead>
        <tr class="text-text-muted text-xs uppercase border-b border-border">
          <th class="text-left pb-3 pr-4 font-medium">Model</th>
          <th class="text-right pb-3 pr-4 font-medium">Tokens</th>
          <th class="text-right pb-3 pr-4 font-medium">Input/1M</th>
          <th class="text-right pb-3 pr-4 font-medium">Output/1M</th>
          <th class="text-right pb-3 pr-4 font-medium">Per Request</th>
          <th class="text-right pb-3 font-medium">Monthly Est.</th>
        </tr>
      </thead>
      <tbody id="model-rows" class="divide-y divide-border"></tbody>
    </table>
  </div>

  <p class="text-xs text-text-muted mb-8">Token counts are approximations based on character ratios. Pricing as of Q1 2025 — verify at provider pricing pages before budgeting. Output cost assumes the estimated output tokens above.</p>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="AI Token Counter" relatedTags={['ai', 'openai', 'claude', 'gemini', 'llm', 'api']} />
</BaseLayout>

<script>
  const MODELS = [
    { name: 'GPT-4o', provider: 'OpenAI', charsPerToken: 4.0, inputPriceM: 5.00, outputPriceM: 15.00 },
    { name: 'GPT-4o Mini', provider: 'OpenAI', charsPerToken: 4.0, inputPriceM: 0.15, outputPriceM: 0.60 },
    { name: 'GPT-4 Turbo', provider: 'OpenAI', charsPerToken: 4.0, inputPriceM: 10.00, outputPriceM: 30.00 },
    { name: 'Claude 3.5 Sonnet', provider: 'Anthropic', charsPerToken: 4.1, inputPriceM: 3.00, outputPriceM: 15.00 },
    { name: 'Claude 3.5 Haiku', provider: 'Anthropic', charsPerToken: 4.1, inputPriceM: 0.80, outputPriceM: 4.00 },
    { name: 'Claude 3 Opus', provider: 'Anthropic', charsPerToken: 4.1, inputPriceM: 15.00, outputPriceM: 75.00 },
    { name: 'Gemini 1.5 Pro', provider: 'Google', charsPerToken: 4.2, inputPriceM: 3.50, outputPriceM: 10.50 },
    { name: 'Gemini 1.5 Flash', provider: 'Google', charsPerToken: 4.2, inputPriceM: 0.075, outputPriceM: 0.30 },
  ];

  const inputEl = document.getElementById('input-text') as HTMLTextAreaElement;
  const outputEl = document.getElementById('output-tokens') as HTMLInputElement;
  const monthlyEl = document.getElementById('monthly-requests') as HTMLInputElement;
  const charCountEl = document.getElementById('char-count')!;
  const tableBody = document.getElementById('model-rows')!;
  const clearBtn = document.getElementById('clear-btn')!;

  function fmt(n: number, decimals = 2): string {
    if (n < 0.01) return '<$0.01';
    return '$' + n.toFixed(decimals);
  }

  function fmtNum(n: number): string {
    return n.toLocaleString();
  }

  function update() {
    const text = inputEl.value;
    const chars = text.length;
    const words = text.trim() ? text.trim().split(/\s+/).length : 0;
    charCountEl.textContent = `${chars.toLocaleString()} characters · ${words.toLocaleString()} words`;

    const outputTokens = Math.max(0, parseInt(outputEl.value) || 0);
    const monthly = Math.max(1, parseInt(monthlyEl.value) || 1);

    tableBody.innerHTML = MODELS.map(m => {
      const inputTokens = Math.round(chars / m.charsPerToken);
      const inputCost = (inputTokens / 1_000_000) * m.inputPriceM;
      const outputCost = (outputTokens / 1_000_000) * m.outputPriceM;
      const perRequest = inputCost + outputCost;
      const monthlyEst = perRequest * monthly;

      return `<tr class="hover:bg-bg-card/50 transition-colors">
        <td class="py-3 pr-4">
          <span class="font-semibold">${m.name}</span>
          <span class="text-xs text-text-muted ml-2">${m.provider}</span>
        </td>
        <td class="py-3 pr-4 text-right tabular-nums font-medium">${fmtNum(inputTokens)}</td>
        <td class="py-3 pr-4 text-right tabular-nums text-text-muted">${fmt(m.inputPriceM, m.inputPriceM < 1 ? 3 : 2)}</td>
        <td class="py-3 pr-4 text-right tabular-nums text-text-muted">${fmt(m.outputPriceM, m.outputPriceM < 1 ? 3 : 2)}</td>
        <td class="py-3 pr-4 text-right tabular-nums">${perRequest < 0.0001 ? '<$0.0001' : '$' + perRequest.toFixed(4)}</td>
        <td class="py-3 text-right tabular-nums font-medium ${monthlyEst > 100 ? 'text-red-400' : monthlyEst > 10 ? 'text-yellow-400' : 'text-green-400'}">${fmt(monthlyEst)}</td>
      </tr>`;
    }).join('');
  }

  clearBtn.addEventListener('click', () => { inputEl.value = ''; update(); });
  inputEl.addEventListener('input', update);
  outputEl.addEventListener('input', update);
  monthlyEl.addEventListener('input', update);

  update();
</script>
