---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GraphqlQueryFormatter from '../../components/GraphqlQueryFormatter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What does the GraphQL Query Formatter do?",
    answer: "It takes any messy, minified, or poorly indented GraphQL query, mutation, subscription, or fragment and formats it into clean, readable output with consistent 2-space indentation and proper line breaks. It works entirely in your browser — nothing is sent to any server."
  },
  {
    question: "Does it support mutations and subscriptions, not just queries?",
    answer: "Yes. The formatter handles all four GraphQL operation types: query (or shorthand), mutation, subscription, and fragment. It also handles inline fragments (...on TypeName), field aliases (alias: fieldName), and arguments with variables ($var: Type)."
  },
  {
    question: "Why is formatted GraphQL easier to read?",
    answer: "Properly indented GraphQL makes the selection set hierarchy immediately visible — you can see at a glance which fields are nested under which type. It also makes diffing queries in version control much easier, and simplifies debugging when checking what data is being requested."
  },
  {
    question: "Can I use this to minify GraphQL instead of format it?",
    answer: "This tool formats (prettifies) GraphQL. For minification (removing whitespace to reduce payload size), the standard approach is a single-line join with spaces: query.replace(/\\s+/g, ' ').trim(). GraphQL clients like Apollo automatically handle query minification in production builds."
  },
  {
    question: "Does the formatter validate my GraphQL syntax?",
    answer: "The formatter does basic structural validation — it checks for balanced braces, valid operation keywords, and proper nesting. However, it does not validate field names, types, or directives against a schema. Use GraphQL Playground or your client's type-checking (e.g. gql`` tagged templates in TypeScript) for full schema validation."
  },
];
---

<BaseLayout
  title="GraphQL Query Formatter — Prettify & Format GraphQL Online Free"
  description="Paste messy GraphQL queries, mutations, subscriptions, or fragments and get clean, properly indented output. Syntax-highlighted, copy-ready. Runs 100% in your browser."
  tool="GraphQL Query Formatter, GraphQL Prettifier, Format GraphQL, GraphQL Beautifier, GraphQL indenter"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "GraphQL Query Formatter",
    "url": "https://devplaybook.cc/tools/graphql-query-formatter",
    "description": "Format and prettify GraphQL queries, mutations, subscriptions, and fragments with proper indentation. Free, runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">GraphQL Query Formatter</h1>
  <p class="text-text-muted mb-4">
    Paste any minified or messy GraphQL query, mutation, subscription, or fragment and get clean, properly indented output with syntax highlighting. Runs entirely in your browser — nothing sent to any server.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Queries, mutations & subscriptions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Syntax highlighting</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <GraphqlQueryFormatter client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="GraphQL Query Formatter" relatedTags={['graphql', 'api', 'formatting', 'query', 'developer-tools']} />
</BaseLayout>
