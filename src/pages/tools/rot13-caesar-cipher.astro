---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is ROT13?", answer: "ROT13 ('rotate by 13 places') is a simple Caesar cipher that substitutes each letter with the letter 13 positions ahead in the alphabet. Since the English alphabet has 26 letters, applying ROT13 twice returns the original text — it is its own inverse. ROT13 is used to obscure text (spoilers, punchlines, offensive content) rather than as serious encryption. It is trivially reversible and provides no security." },
  { question: "What is a Caesar cipher?", answer: "The Caesar cipher is a substitution cipher where each letter is shifted a fixed number of positions in the alphabet. Julius Caesar reportedly used a shift of 3 (A→D, B→E). A shift of 0 is no change; a shift of 13 is ROT13; a shift of 25 is the reverse alphabet. The Caesar cipher is easily broken by frequency analysis (the most common letter in English is E) or by trying all 25 possible shifts (brute force)." },
  { question: "Is Caesar cipher secure?", answer: "No. The Caesar cipher is one of the weakest ciphers — there are only 25 possible keys (shifts 1–25), making brute force trivial. Even without brute force, frequency analysis easily breaks it: in English text, E is the most frequent letter (~12.7%), so the most frequent letter in the ciphertext reveals the shift. Modern encryption (AES, RSA, ChaCha20) uses mathematical problems that are computationally infeasible to brute force." },
  { question: "What is ROT47?", answer: "ROT47 is like ROT13 but for a wider range of printable ASCII characters (characters 33–126, including digits, punctuation, and letters). It rotates by 47 positions within that range, also being self-inverse. ROT47 obfuscates digits and symbols that ROT13 leaves unchanged, making it better for obscuring mixed text." },
];
---

<BaseLayout
  title="ROT13 & Caesar Cipher — Encode and Decode Text"
  description="Encode or decode text with ROT13 or any Caesar cipher shift (1-25). ROT13 is self-inverse — apply twice to restore original. Instant, client-side."
  tool="ROT13 encoder decoder, Caesar cipher tool, text rotation cipher, ROT47, substitution cipher, encode text ROT13"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "ROT13 & Caesar Cipher — Encode and Decode Text",
    "url": "https://devplaybook.cc/tools/rot13-caesar-cipher",
    "description": "Encode or decode text with ROT13 or any Caesar cipher shift from 1 to 25. Instant client-side transformation.",
  })} />

  <h1 class="text-3xl font-bold mb-2">ROT13 & Caesar Cipher</h1>
  <p class="text-text-muted mb-6">
    Encode or decode text using <strong>ROT13</strong> (shift 13) or any <strong>Caesar cipher</strong> shift from 1 to 25.
    ROT13 is self-inverse — applying it twice restores the original text.
  </p>

  <div class="mb-4 flex items-center gap-4 flex-wrap">
    <div class="flex items-center gap-2">
      <label class="text-sm font-medium">Shift:</label>
      <input
        type="range" id="shiftSlider" min="1" max="25" value="13"
        class="w-32 accent-primary"
      />
      <span id="shiftValue" class="text-sm font-mono bg-bg-card border border-border rounded px-2 py-0.5 min-w-[2.5rem] text-center">13</span>
    </div>
    <button id="rot13Btn" class="px-4 py-1.5 bg-primary text-white rounded-lg text-sm hover:bg-primary/90 transition-colors">ROT13</button>
    <button id="rot47Btn" class="px-4 py-1.5 bg-bg-card border border-border rounded-lg text-sm hover:bg-primary/10 transition-colors">ROT47</button>
  </div>

  <div class="grid md:grid-cols-2 gap-4 mb-6">
    <div>
      <label class="block text-sm font-medium mb-2">Input</label>
      <textarea
        id="inputText"
        class="w-full h-48 bg-bg-card border border-border rounded-xl p-3 text-sm font-mono resize-none focus:outline-none focus:ring-2 focus:ring-primary"
        placeholder="Enter text to encode / decode..."
      ></textarea>
    </div>
    <div>
      <label class="block text-sm font-medium mb-2">Output</label>
      <div class="relative">
        <textarea
          id="outputText"
          readonly
          class="w-full h-48 bg-bg-card border border-border rounded-xl p-3 text-sm font-mono resize-none focus:outline-none"
          placeholder="Result appears here..."
        ></textarea>
        <button id="copyBtn" class="absolute top-2 right-2 text-xs text-primary hover:underline">Copy</button>
      </div>
    </div>
  </div>

  <div class="bg-bg-card border border-border rounded-xl p-4 mb-6">
    <h3 class="text-sm font-medium mb-3">Caesar Cipher Alphabet (current shift)</h3>
    <div class="overflow-x-auto">
      <table class="text-xs font-mono">
        <tr id="plainRow" class="text-text-muted"></tr>
        <tr id="cipherRow" class="text-primary font-bold"></tr>
      </table>
    </div>
  </div>

  <ToolPageCta />
  <FaqSection faqs={faq} />
</BaseLayout>

<script>
function caesarShift(text: string, shift: number): string {
  return text.split('').map(ch => {
    if (/[a-z]/.test(ch)) return String.fromCharCode(((ch.charCodeAt(0) - 97 + shift) % 26) + 97);
    if (/[A-Z]/.test(ch)) return String.fromCharCode(((ch.charCodeAt(0) - 65 + shift) % 26) + 65);
    return ch;
  }).join('');
}

function rot47(text: string): string {
  return text.split('').map(ch => {
    const code = ch.charCodeAt(0);
    if (code >= 33 && code <= 126) return String.fromCharCode(((code - 33 + 47) % 94) + 33);
    return ch;
  }).join('');
}

function updateAlphabetTable(shift: number) {
  const letters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
  const plain = document.getElementById('plainRow');
  const cipher = document.getElementById('cipherRow');
  if (!plain || !cipher) return;
  plain.innerHTML = letters.map(l => `<td class="px-1.5 py-0.5 border border-border/30">${l}</td>`).join('');
  cipher.innerHTML = letters.map(l => {
    const shifted = String.fromCharCode(((l.charCodeAt(0) - 65 + shift) % 26) + 65);
    return `<td class="px-1.5 py-0.5 border border-border/30">${shifted}</td>`;
  }).join('');
}

function updateOutput() {
  const input = (document.getElementById('inputText') as HTMLTextAreaElement).value;
  const shift = parseInt((document.getElementById('shiftSlider') as HTMLInputElement).value);
  (document.getElementById('outputText') as HTMLTextAreaElement).value = caesarShift(input, shift);
  updateAlphabetTable(shift);
}

document.getElementById('inputText')?.addEventListener('input', updateOutput);
document.getElementById('shiftSlider')?.addEventListener('input', () => {
  const val = (document.getElementById('shiftSlider') as HTMLInputElement).value;
  const label = document.getElementById('shiftValue');
  if (label) label.textContent = val;
  updateOutput();
});
document.getElementById('rot13Btn')?.addEventListener('click', () => {
  (document.getElementById('shiftSlider') as HTMLInputElement).value = '13';
  const label = document.getElementById('shiftValue');
  if (label) label.textContent = '13';
  updateOutput();
});
document.getElementById('rot47Btn')?.addEventListener('click', () => {
  const input = (document.getElementById('inputText') as HTMLTextAreaElement).value;
  (document.getElementById('outputText') as HTMLTextAreaElement).value = rot47(input);
});
document.getElementById('copyBtn')?.addEventListener('click', () => {
  const text = (document.getElementById('outputText') as HTMLTextAreaElement).value;
  navigator.clipboard.writeText(text);
  const btn = document.getElementById('copyBtn');
  if (btn) { btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = 'Copy', 2000); }
});

updateAlphabetTable(13);
</script>
