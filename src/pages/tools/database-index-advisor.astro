---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is a database index and why does it matter?", answer: "A database index is a data structure (usually a B-tree) that stores a sorted copy of column values alongside pointers to the full rows. Indexes allow the DB engine to find rows without scanning the entire table, reducing query time from O(n) to O(log n). Without indexes on WHERE, JOIN, and ORDER BY columns, large tables suffer full table scans." },
  { question: "What is a B-tree index and when should I use it?", answer: "B-tree is the default index type in PostgreSQL and MySQL, suitable for equality (=), range (<, >, BETWEEN), and ORDER BY operations on any data type with a natural sort order. Use B-tree for most columns. It handles about 95% of indexing needs efficiently." },
  { question: "When should I use a GIN or GiST index?", answer: "GIN (Generalized Inverted Index) is optimal for array containment, JSONB operators (@>, ?, ?|), and full-text search (tsvector). GiST (Generalized Search Tree) is ideal for geometric/PostGIS data, range types, and full-text. Use GIN for JSON and full-text, GiST for spatial and range queries." },
  { question: "What is a partial index and when is it useful?", answer: "A partial index includes only rows matching a WHERE condition, e.g., CREATE INDEX idx ON orders(user_id) WHERE status = 'pending'. This creates a much smaller, faster index for queries that always filter on that condition. Great for soft-deleted records, status filters, or active-only queries." },
  { question: "How does column order in composite indexes matter?", answer: "In a composite index (col1, col2, col3), the leftmost prefix rule applies: the index can be used for queries filtering on col1, col1+col2, or col1+col2+col3. Queries filtering only on col2 or col3 cannot use the index. Put high-cardinality equality columns first, then range columns, then sort columns." }
];
---

<BaseLayout
  title="Database Index Strategy Advisor — Get Recommended Indexes"
  description="Get index recommendations for your database tables. Input column names, types, and cardinality. Receive CREATE INDEX statements, index type recommendations, and optimization tips."
  tool="database index advisor, SQL index recommender, CREATE INDEX generator, database index strategy, PostgreSQL index advisor"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Database Index Strategy Advisor",
    "url": "https://devplaybook.cc/tools/database-index-advisor",
    "description": "Get database index recommendations. Input columns and query patterns to receive CREATE INDEX statements and indexing strategy tips.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Database Index Strategy Advisor</h1>
  <p class="text-text-muted mb-4">
    Input your table name, columns, and query patterns to get recommended index types, CREATE INDEX statements,
    and indexing best practices for PostgreSQL, MySQL, and SQLite.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> B-tree / GIN / GiST / Hash</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Composite index ordering</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Partial index suggestions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> CREATE INDEX statements</span>
  </div>

  <!-- Table setup -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-4">
      <div>
        <label class="block text-xs text-text-muted mb-1">Table Name</label>
        <input id="table-name" type="text" value="orders" class="w-full bg-surface border border-border rounded px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Database</label>
        <select id="db-type" class="w-full bg-surface border border-border rounded px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="postgresql">PostgreSQL</option>
          <option value="mysql">MySQL</option>
          <option value="sqlite">SQLite</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Approx. Row Count</label>
        <select id="row-count" class="w-full bg-surface border border-border rounded px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="small">Small (&lt; 10K rows)</option>
          <option value="medium" selected>Medium (10K–1M rows)</option>
          <option value="large">Large (&gt; 1M rows)</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Columns -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-sm font-semibold">Columns</h2>
      <button id="add-col" class="px-3 py-1.5 text-xs border border-dashed border-border rounded hover:border-primary transition-colors text-text-muted">+ Add Column</button>
    </div>
    <div class="mb-1 hidden sm:grid gap-2 text-xs text-text-muted font-semibold px-1" style="grid-template-columns:1fr 110px 90px 130px 48px">
      <span>Column Name</span><span>Data Type</span><span>Cardinality</span><span>Query Usage</span><span></span>
    </div>
    <div id="cols-container" class="space-y-2"></div>
  </div>

  <!-- Generate -->
  <button id="gen-btn" class="w-full py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors mb-4">
    Generate Index Recommendations
  </button>

  <!-- Results -->
  <div id="results" class="hidden">
    <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-semibold">Recommended Indexes</h2>
        <button id="copy-indexes" class="px-4 py-1.5 bg-primary text-white rounded text-sm font-medium hover:bg-primary/90 transition-colors">Copy All</button>
      </div>
      <div id="index-list" class="space-y-3"></div>
    </div>
    <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
      <h2 class="text-sm font-semibold mb-3">Strategy Notes</h2>
      <div id="strategy-notes" class="space-y-2"></div>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Database Index Strategy Advisor" relatedTags={["database", "postgresql", "mysql", "sql", "performance", "indexing"]} />
</BaseLayout>

<script is:inline>
(function () {
  var COL_TYPES = ["varchar","text","integer","bigint","boolean","timestamp","uuid","jsonb","float","decimal","enum"];
  var QUERY_TYPES = [
    { val:"eq", label:"Equality (=)" },
    { val:"range", label:"Range (<, >, BETWEEN)" },
    { val:"sort", label:"ORDER BY / sort" },
    { val:"fts", label:"Full-text search" },
    { val:"json", label:"JSONB / array ops" },
    { val:"join", label:"JOIN key" }
  ];

  var cols = [
    { id:uid(), name:"user_id", type:"integer", card:"high", usage:["eq","join"] },
    { id:uid(), name:"status", type:"varchar", card:"low", usage:["eq"] },
    { id:uid(), name:"created_at", type:"timestamp", card:"high", usage:["range","sort"] },
    { id:uid(), name:"search_text", type:"text", card:"high", usage:["fts"] }
  ];

  function uid(){ return Math.random().toString(36).slice(2,9); }
  function esc(s){ return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;"); }
  function findCol(id){ return cols.find(function(c){ return c.id===id; }); }

  function hCol(c){
    var typeOpts = COL_TYPES.map(function(t){ return "<option value='"+t+"'"+(c.type===t?" selected":"")+">"+t+"</option>"; }).join("");
    var usageChecks = QUERY_TYPES.map(function(q){
      var checked = c.usage.indexOf(q.val) >= 0;
      return "<label class='flex items-center gap-1 text-xs cursor-pointer'><input type='checkbox' class='col-usage' data-cid='"+c.id+"' data-u='"+q.val+"'"+(checked?" checked":"")+">"+q.label+"</label>";
    }).join("");
    var cardOpts = ["low","medium","high"].map(function(v){
      return "<option value='"+v+"'"+(c.card===v?" selected":"")+">"+v[0].toUpperCase()+v.slice(1)+"</option>";
    }).join("");
    return "<div class='grid gap-2 items-start p-2 bg-surface rounded border border-border' style='grid-template-columns:1fr 110px 90px 1fr 48px' data-cid='"+c.id+"'>" +
      "<input type='text' value='"+esc(c.name)+"' class='col-name bg-surface border border-border rounded px-2 py-1 text-xs font-mono focus:outline-none focus:border-primary' data-cid='"+c.id+"' />" +
      "<select class='col-type bg-bg-card border border-border rounded px-1 py-1 text-xs focus:outline-none focus:border-primary' data-cid='"+c.id+"'>"+typeOpts+"</select>" +
      "<select class='col-card bg-bg-card border border-border rounded px-1 py-1 text-xs focus:outline-none focus:border-primary' data-cid='"+c.id+"'>"+cardOpts+"</select>" +
      "<div class='flex flex-wrap gap-x-3 gap-y-1 pl-1'>"+usageChecks+"</div>" +
      "<button class='del-col text-xs text-red-400 border border-border rounded px-1 py-1 hover:text-red-300 transition-colors self-center' data-cid='"+c.id+"'>Del</button>" +
      "</div>";
  }

  function render(){
    document.getElementById("cols-container").innerHTML = cols.map(hCol).join("");
    attach();
  }

  function attach(){
    var c = document.getElementById("cols-container");
    c.querySelectorAll(".col-name").forEach(function(el){ el.oninput=function(e){ var col=findCol(e.target.dataset.cid); if(col) col.name=e.target.value; }; });
    c.querySelectorAll(".col-type").forEach(function(el){ el.onchange=function(e){ var col=findCol(e.target.dataset.cid); if(col) col.type=e.target.value; }; });
    c.querySelectorAll(".col-card").forEach(function(el){ el.onchange=function(e){ var col=findCol(e.target.dataset.cid); if(col) col.card=e.target.value; }; });
    c.querySelectorAll(".col-usage").forEach(function(el){
      el.onchange=function(e){
        var col=findCol(e.target.dataset.cid); if(!col) return;
        if(e.target.checked){ if(col.usage.indexOf(e.target.dataset.u)<0) col.usage.push(e.target.dataset.u); }
        else { col.usage=col.usage.filter(function(u){ return u!==e.target.dataset.u; }); }
      };
    });
    c.querySelectorAll(".del-col").forEach(function(el){ el.onclick=function(e){ cols=cols.filter(function(c){ return c.id!==e.target.dataset.cid; }); render(); }; });
  }

  function recommendIndexType(col, dbType){
    if(col.usage.indexOf("fts") >= 0){
      return dbType === "postgresql" ? "GIN (tsvector)" : "FULLTEXT";
    }
    if((col.usage.indexOf("json") >= 0) && dbType === "postgresql"){
      return "GIN (jsonb_ops)";
    }
    if(col.card === "low" && col.usage.indexOf("eq") >= 0 && col.usage.indexOf("range") < 0){
      return dbType === "postgresql" ? "B-tree (partial candidates)" : "B-tree";
    }
    if(col.type === "uuid" && col.usage.indexOf("eq") >= 0){
      return dbType === "postgresql" ? "B-tree (or Hash for equality-only)" : "B-tree";
    }
    return "B-tree";
  }

  function genCreateIndex(table, col, dbType, idx){
    var idxName = "idx_"+table+"_"+col.name.toLowerCase().replace(/\s+/g,"_");
    var fts = col.usage.indexOf("fts") >= 0;
    var json = col.usage.indexOf("json") >= 0;

    if(fts && dbType === "postgresql"){
      return "-- Full-text index on "+col.name+"\nCREATE INDEX "+idxName+"_fts ON "+table+" USING GIN (to_tsvector('english', "+col.name+"));";
    }
    if(fts && dbType === "mysql"){
      return "-- Full-text index on "+col.name+"\nALTER TABLE "+table+" ADD FULLTEXT INDEX "+idxName+"_fts ("+col.name+");";
    }
    if(json && dbType === "postgresql"){
      return "-- JSONB index on "+col.name+"\nCREATE INDEX "+idxName+"_gin ON "+table+" USING GIN ("+col.name+");";
    }
    if(col.card === "low" && col.usage.indexOf("eq") >= 0 && dbType === "postgresql"){
      return "-- Partial index example (customize WHERE clause)\nCREATE INDEX "+idxName+" ON "+table+" ("+col.name+") WHERE "+col.name+" IS NOT NULL;";
    }
    return "CREATE INDEX "+idxName+" ON "+table+" ("+col.name+");";
  }

  function generate(){
    var table = document.getElementById("table-name").value.trim() || "my_table";
    var dbType = document.getElementById("db-type").value;
    var rowCount = document.getElementById("row-count").value;

    if(cols.length === 0){ alert("Add at least one column."); return; }

    var indexHtml = [];
    var allSQL = [];

    // Check for composite index candidates (eq + sort, eq + range)
    var eqCols = cols.filter(function(c){ return c.usage.indexOf("eq") >= 0 || c.usage.indexOf("join") >= 0; });
    var sortCols = cols.filter(function(c){ return c.usage.indexOf("sort") >= 0; });
    var rangeCols = cols.filter(function(c){ return c.usage.indexOf("range") >= 0; });

    if(eqCols.length >= 2){
      var names = eqCols.slice(0,3).map(function(c){ return c.name; });
      var compSQL = "-- Composite index for equality lookups\nCREATE INDEX idx_"+table+"_composite ON "+table+" ("+names.join(", ")+");";
      allSQL.push(compSQL);
      indexHtml.push("<div class='bg-surface rounded-lg p-3'>" +
        "<div class='flex items-center gap-2 mb-1'><span class='px-2 py-0.5 text-xs bg-blue-500/20 text-blue-400 rounded font-medium'>Composite</span><span class='text-xs text-text-muted'>High priority</span></div>" +
        "<pre class='text-xs font-mono text-foreground/90 whitespace-pre-wrap'>"+esc(compSQL)+"</pre>" +
        "<p class='text-xs text-text-muted mt-1'>Tip: Put high-cardinality equality columns first, then range/sort columns.</p>" +
        "</div>");
    }

    if(eqCols.length >= 1 && sortCols.length >= 1){
      var eq1 = eqCols[0].name;
      var sort1 = sortCols[0].name;
      if(eq1 !== sort1){
        var covSQL = "-- Equality + sort composite\nCREATE INDEX idx_"+table+"_"+eq1.toLowerCase()+"_"+sort1.toLowerCase()+" ON "+table+" ("+eq1+", "+sort1+");";
        allSQL.push(covSQL);
        indexHtml.push("<div class='bg-surface rounded-lg p-3'>" +
          "<div class='flex items-center gap-2 mb-1'><span class='px-2 py-0.5 text-xs bg-purple-500/20 text-purple-400 rounded font-medium'>Sort+Filter</span><span class='text-xs text-text-muted'>Covers WHERE + ORDER BY</span></div>" +
          "<pre class='text-xs font-mono text-foreground/90 whitespace-pre-wrap'>"+esc(covSQL)+"</pre>" +
          "</div>");
      }
    }

    cols.forEach(function(col, i){
      var indexType = recommendIndexType(col, dbType);
      var sql = genCreateIndex(table, col, dbType, i);
      allSQL.push(sql);
      var tagClass = indexType.startsWith("GIN") ? "bg-green-500/20 text-green-400" :
                     indexType.startsWith("GiST") ? "bg-teal-500/20 text-teal-400" :
                     indexType.startsWith("FULLTEXT") ? "bg-green-500/20 text-green-400" :
                     "bg-surface text-text-muted border border-border";
      indexHtml.push("<div class='bg-surface rounded-lg p-3'>" +
        "<div class='flex items-center gap-2 mb-1'>" +
        "<span class='text-sm font-mono font-semibold'>"+esc(col.name)+"</span>" +
        "<span class='px-2 py-0.5 text-xs rounded font-medium "+tagClass+"'>"+indexType+"</span>" +
        "<span class='text-xs text-text-muted'>card: "+col.card+"</span>" +
        "</div>" +
        "<pre class='text-xs font-mono text-foreground/90 whitespace-pre-wrap'>"+esc(sql)+"</pre>" +
        "</div>");
    });

    document.getElementById("index-list").innerHTML = indexHtml.join("");
    document.getElementById("copy-indexes").onclick = function(){
      navigator.clipboard.writeText(allSQL.join("\n\n")).then(function(){
        var b=document.getElementById("copy-indexes"); b.textContent="Copied!"; setTimeout(function(){b.textContent="Copy All";},1500);
      });
    };

    // Strategy notes
    var notes = [];
    if(rowCount === "small") notes.push({ icon:"&#8505;", text:"Small table (&lt;10K rows): indexes may not improve performance — the query planner may prefer seq scans. Index for future growth." });
    if(rangeCols.length > 0) notes.push({ icon:"&#9888;", text:"Range query columns ("+rangeCols.map(function(c){return c.name;}).join(", ")+"): B-tree handles range well. Place range columns after equality columns in composites." });
    var lowCardCols = cols.filter(function(c){ return c.card==="low" && c.usage.indexOf("eq")>=0; });
    if(lowCardCols.length > 0) notes.push({ icon:"&#9888;", text:"Low-cardinality columns ("+lowCardCols.map(function(c){return c.name;}).join(", ")+"): indexes on boolean or status columns may not help unless combined with high-cardinality columns in a composite, or used as partial indexes." });
    var hasFts = cols.some(function(c){ return c.usage.indexOf("fts")>=0; });
    if(hasFts && dbType === "postgresql") notes.push({ icon:"&#9888;", text:"Full-text search: consider a dedicated tsvector generated column with a GIN index for better performance with complex queries." });
    notes.push({ icon:"&#10003;", text:"Always run EXPLAIN ANALYZE after adding indexes to confirm the planner uses them. Monitor pg_stat_user_indexes (PostgreSQL) or SHOW INDEX FROM table (MySQL) to find unused indexes." });

    document.getElementById("strategy-notes").innerHTML = notes.map(function(n){
      var isOk = n.icon === "&#10003;";
      return "<div class='flex items-start gap-2 p-3 rounded-lg "+(isOk?"bg-green-500/10":"bg-blue-500/10")+"'>" +
        "<span class='mt-0.5 text-sm "+(isOk?"text-green-400":"text-blue-400")+"'>"+n.icon+"</span>" +
        "<span class='text-sm'>"+n.text+"</span></div>";
    }).join("");

    document.getElementById("results").classList.remove("hidden");
    document.getElementById("results").scrollIntoView({ behavior:"smooth", block:"nearest" });
  }

  document.getElementById("add-col").onclick = function(){
    cols.push({ id:uid(), name:"column_"+cols.length, type:"varchar", card:"medium", usage:["eq"] });
    render();
  };
  document.getElementById("gen-btn").onclick = generate;
  render();
})();
</script>
