---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How do I choose between GPT-4o and Claude 3.5 Sonnet?", answer: "GPT-4o excels at multimodal tasks (vision, audio) and has a massive ecosystem with plugins. Claude 3.5 Sonnet generally outperforms on coding, long-context tasks (200K context), and instruction following. For pure text generation at lower cost, Claude Haiku or GPT-4o-mini are strong choices." },
  { question: "What does 'context window' mean for practical use?", answer: "The context window is how many tokens the model can 'see' at once — input + output combined. A 128K context = roughly 90,000-100,000 words. Larger context lets you process entire codebases, long documents, or extended conversations without truncation. Models with 1M+ contexts (Gemini 1.5 Pro) can process entire books." },
  { question: "How is latency measured for LLMs?", answer: "Two key metrics: Time To First Token (TTFT) — how long before the response starts streaming; and Tokens Per Second (TPS) — throughput once streaming begins. For real-time chat, low TTFT matters most. For batch processing, TPS is more important. API providers show significant latency variance by region and load." },
  { question: "What is the difference between open-source and proprietary LLMs?", answer: "Proprietary models (GPT-4, Claude, Gemini) are accessed via API, managed by vendors, and typically lead on benchmarks. Open-source models (Llama 3, Mistral, Qwen) can be self-hosted for privacy, customized via fine-tuning, and have no per-token costs beyond compute. Self-hosting Llama 3 70B requires a high-end GPU server." },
  { question: "Which model is best for coding tasks?", answer: "For coding: Claude 3.5 Sonnet and GPT-4o are generally top-tier. For cost-sensitive coding: GPT-4o-mini or Claude Haiku. For autonomous coding agents: models with large context windows and strong tool-use (GPT-4o, Claude 3.5 Sonnet) are preferred. Codestral from Mistral is specialized for code generation." },
];
---

<BaseLayout
  title="AI Model Comparison Matrix 2025 — GPT-4o vs Claude vs Gemini vs Llama"
  description="Compare AI language models side-by-side. Filter by price, context window, speed, and capabilities. Find the best LLM for your use case."
  tool="AI Model Comparison, LLM Comparison Matrix, GPT-4o vs Claude, Best AI Model 2025, LLM Selection Tool"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">AI Model Comparison Matrix</h1>
  <p class="text-text-muted mb-4">Compare AI language models side-by-side on price, context, speed, and capabilities. Filter to find the best model for your use case.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 20+ models compared</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Real pricing data</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Use-case matching</span>
  </div>

  <!-- Filters -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Filter & Sort</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Provider</label>
        <select id="filter-provider" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="all">All Providers</option>
          <option value="openai">OpenAI</option>
          <option value="anthropic">Anthropic</option>
          <option value="google">Google</option>
          <option value="meta">Meta (Open Source)</option>
          <option value="mistral">Mistral</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Use Case</label>
        <select id="filter-usecase" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="all">All Use Cases</option>
          <option value="coding">Coding</option>
          <option value="reasoning">Reasoning</option>
          <option value="chat">Chat / Customer Service</option>
          <option value="vision">Vision / Multimodal</option>
          <option value="long-context">Long Context</option>
          <option value="fast">Speed-Critical</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Max Input Price ($/1M tokens)</label>
        <select id="filter-price" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="999">Any Price</option>
          <option value="1">Under $1</option>
          <option value="3">Under $3</option>
          <option value="10">Under $10</option>
          <option value="20">Under $20</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Sort By</label>
        <select id="sort-by" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="name">Name</option>
          <option value="price-asc">Price (Low→High)</option>
          <option value="price-desc">Price (High→Low)</option>
          <option value="context">Context Window</option>
          <option value="score">Overall Score</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Monthly Budget Calculator -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Monthly Cost Estimator</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Daily API Calls</label>
        <input id="daily-calls" type="number" value="1000" min="1"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Avg Input Tokens / Call</label>
        <input id="avg-input" type="number" value="500" min="1"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Avg Output Tokens / Call</label>
        <input id="avg-output" type="number" value="200" min="1"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
    </div>
    <div id="cost-preview" class="text-sm text-text-muted"></div>
  </div>

  <!-- Model Table -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5 overflow-x-auto">
    <h2 class="text-base font-semibold mb-4">Model Comparison <span id="model-count" class="text-text-muted font-normal text-sm"></span></h2>
    <table class="w-full text-sm min-w-[900px]">
      <thead>
        <tr class="border-b border-border text-left text-text-muted">
          <th class="pb-2 pr-3 font-medium">Model</th>
          <th class="pb-2 pr-3 font-medium">Provider</th>
          <th class="pb-2 pr-3 font-medium">Context</th>
          <th class="pb-2 pr-3 font-medium">Input $/1M</th>
          <th class="pb-2 pr-3 font-medium">Output $/1M</th>
          <th class="pb-2 pr-3 font-medium">Strengths</th>
          <th class="pb-2 pr-3 font-medium">Score</th>
          <th class="pb-2 font-medium">Est. Monthly</th>
        </tr>
      </thead>
      <tbody id="model-table-body" class="divide-y divide-border"></tbody>
    </table>
  </div>

  <ToolPageCta />
  <FaqSection faq={faq} />
</BaseLayout>

<script>
const MODELS = [
  { name: "GPT-4o", provider: "openai", context: 128000, inputPrice: 2.50, outputPrice: 10.00, usecases: ["coding","reasoning","vision","chat"], score: 95, strengths: "Multimodal, function calling, massive ecosystem" },
  { name: "GPT-4o mini", provider: "openai", context: 128000, inputPrice: 0.15, outputPrice: 0.60, usecases: ["chat","fast","coding"], score: 82, strengths: "Cost-effective, fast, GPT-4 class for simple tasks" },
  { name: "o1", provider: "openai", context: 128000, inputPrice: 15.00, outputPrice: 60.00, usecases: ["reasoning","coding"], score: 97, strengths: "Best-in-class reasoning, complex problem solving" },
  { name: "o1-mini", provider: "openai", context: 128000, inputPrice: 3.00, outputPrice: 12.00, usecases: ["reasoning","coding","fast"], score: 88, strengths: "Fast reasoning, STEM tasks, affordable" },
  { name: "GPT-3.5 Turbo", provider: "openai", context: 16385, inputPrice: 0.50, outputPrice: 1.50, usecases: ["chat","fast"], score: 72, strengths: "Ultra-low cost, legacy integrations" },
  { name: "Claude 3.5 Sonnet", provider: "anthropic", context: 200000, inputPrice: 3.00, outputPrice: 15.00, usecases: ["coding","reasoning","long-context","chat"], score: 96, strengths: "Best coding, 200K context, instruction following" },
  { name: "Claude 3.5 Haiku", provider: "anthropic", context: 200000, inputPrice: 0.80, outputPrice: 4.00, usecases: ["chat","fast","coding"], score: 85, strengths: "Fast, affordable, 200K context" },
  { name: "Claude 3 Opus", provider: "anthropic", context: 200000, inputPrice: 15.00, outputPrice: 75.00, usecases: ["reasoning","long-context"], score: 93, strengths: "Complex analysis, nuanced writing, safety" },
  { name: "Gemini 1.5 Pro", provider: "google", context: 1000000, inputPrice: 1.25, outputPrice: 5.00, usecases: ["long-context","vision","reasoning"], score: 90, strengths: "1M context, video/audio, competitive pricing" },
  { name: "Gemini 1.5 Flash", provider: "google", context: 1000000, inputPrice: 0.075, outputPrice: 0.30, usecases: ["fast","long-context","chat"], score: 83, strengths: "Ultra-cheap, 1M context, multimodal" },
  { name: "Gemini 2.0 Flash", provider: "google", context: 1000000, inputPrice: 0.10, outputPrice: 0.40, usecases: ["fast","long-context","reasoning","vision"], score: 89, strengths: "Latest Gemini, improved reasoning, fast" },
  { name: "Llama 3.3 70B", provider: "meta", context: 128000, inputPrice: 0.23, outputPrice: 0.40, usecases: ["coding","reasoning","chat"], score: 86, strengths: "Open source, self-hostable, strong benchmark" },
  { name: "Llama 3.1 8B", provider: "meta", context: 128000, inputPrice: 0.05, outputPrice: 0.08, usecases: ["fast","chat"], score: 73, strengths: "Ultra-cheap, runs on consumer GPU, open source" },
  { name: "Llama 3.1 405B", provider: "meta", context: 128000, inputPrice: 1.79, outputPrice: 1.79, usecases: ["coding","reasoning"], score: 91, strengths: "Most powerful open-source, GPT-4 class" },
  { name: "Mistral Large 2", provider: "mistral", context: 128000, inputPrice: 2.00, outputPrice: 6.00, usecases: ["coding","reasoning","chat"], score: 88, strengths: "Strong multilingual, European data compliance" },
  { name: "Mistral Small 3", provider: "mistral", context: 32000, inputPrice: 0.10, outputPrice: 0.30, usecases: ["fast","chat"], score: 78, strengths: "Fast, cheap, European-hosted option" },
  { name: "Codestral", provider: "mistral", context: 256000, inputPrice: 0.20, outputPrice: 0.60, usecases: ["coding"], score: 87, strengths: "Specialized code model, 256K context, fill-in-middle" },
  { name: "Qwen 2.5 72B", provider: "other", context: 128000, inputPrice: 0.40, outputPrice: 0.40, usecases: ["coding","reasoning","chat"], score: 85, strengths: "Open source, strong on Chinese/multilingual" },
  { name: "DeepSeek V3", provider: "other", context: 128000, inputPrice: 0.27, outputPrice: 1.10, usecases: ["coding","reasoning"], score: 89, strengths: "Top coding benchmark, very low price" },
  { name: "DeepSeek R1", provider: "other", context: 128000, inputPrice: 0.55, outputPrice: 2.19, usecases: ["reasoning","coding"], score: 92, strengths: "o1-level reasoning, open-source variant available" },
];

let filtered = [...MODELS];

function formatContext(n) {
  if (n >= 1000000) return (n/1000000).toFixed(0) + 'M';
  return (n/1000).toFixed(0) + 'K';
}

function calcMonthlyCost(inputPrice, outputPrice) {
  const daily = parseInt(document.getElementById('daily-calls').value) || 1000;
  const inp = parseInt(document.getElementById('avg-input').value) || 500;
  const out = parseInt(document.getElementById('avg-output').value) || 200;
  const monthlyInputTokens = daily * 30 * inp / 1_000_000;
  const monthlyOutputTokens = daily * 30 * out / 1_000_000;
  return (monthlyInputTokens * inputPrice + monthlyOutputTokens * outputPrice).toFixed(2);
}

function getScoreColor(score) {
  if (score >= 93) return 'text-green-400';
  if (score >= 85) return 'text-blue-400';
  if (score >= 75) return 'text-yellow-400';
  return 'text-text-muted';
}

function renderTable() {
  const tbody = document.getElementById('model-table-body');
  const count = document.getElementById('model-count');
  count.textContent = `(${filtered.length} models)`;

  tbody.innerHTML = filtered.map(m => `
    <tr class="hover:bg-bg-elevated transition-colors">
      <td class="py-2.5 pr-3 font-medium">${m.name}</td>
      <td class="py-2.5 pr-3 text-text-muted capitalize">${m.provider === 'other' ? 'Other' : m.provider.charAt(0).toUpperCase()+m.provider.slice(1)}</td>
      <td class="py-2.5 pr-3">${formatContext(m.context)}</td>
      <td class="py-2.5 pr-3 text-green-400">$${m.inputPrice.toFixed(2)}</td>
      <td class="py-2.5 pr-3 text-yellow-400">$${m.outputPrice.toFixed(2)}</td>
      <td class="py-2.5 pr-3 text-text-muted text-xs max-w-[200px]">${m.strengths}</td>
      <td class="py-2.5 pr-3 font-semibold ${getScoreColor(m.score)}">${m.score}/100</td>
      <td class="py-2.5 font-medium">$${calcMonthlyCost(m.inputPrice, m.outputPrice)}</td>
    </tr>
  `).join('');

  // Cost preview
  const preview = document.getElementById('cost-preview');
  const daily = parseInt(document.getElementById('daily-calls').value) || 1000;
  const inp = parseInt(document.getElementById('avg-input').value) || 500;
  const out = parseInt(document.getElementById('avg-output').value) || 200;
  const totalMonthlyTokens = daily * 30 * (inp + out);
  preview.textContent = `At ${daily.toLocaleString()} calls/day with ${inp} input + ${out} output tokens each = ${(totalMonthlyTokens/1_000_000).toFixed(1)}M tokens/month. Cheapest option: $${calcMonthlyCost(0.075, 0.30)}/mo (Gemini 1.5 Flash).`;
}

function applyFilters() {
  const provider = document.getElementById('filter-provider').value;
  const usecase = document.getElementById('filter-usecase').value;
  const price = parseFloat(document.getElementById('filter-price').value);
  const sort = document.getElementById('sort-by').value;

  filtered = MODELS.filter(m => {
    if (provider !== 'all' && m.provider !== provider) return false;
    if (usecase !== 'all' && !m.usecases.includes(usecase)) return false;
    if (m.inputPrice > price) return false;
    return true;
  });

  filtered.sort((a, b) => {
    if (sort === 'price-asc') return a.inputPrice - b.inputPrice;
    if (sort === 'price-desc') return b.inputPrice - a.inputPrice;
    if (sort === 'context') return b.context - a.context;
    if (sort === 'score') return b.score - a.score;
    return a.name.localeCompare(b.name);
  });

  renderTable();
}

['filter-provider','filter-usecase','filter-price','sort-by','daily-calls','avg-input','avg-output'].forEach(id => {
  document.getElementById(id)?.addEventListener('change', applyFilters);
  document.getElementById(id)?.addEventListener('input', applyFilters);
});

applyFilters();
</script>
