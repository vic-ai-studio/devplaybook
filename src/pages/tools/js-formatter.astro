---
import BaseLayout from "../../layouts/BaseLayout.astro";
import JsFormatter from "../../components/JsFormatter.tsx";
import ToolPageCta from "../../components/ToolPageCta.astro";
import FaqSection from "../../components/FaqSection.astro";

const faq = [
  { question: "What is the difference between formatting and minifying JavaScript?", answer: "Formatting (beautifying) adds consistent indentation and line breaks to make code readable. Minifying removes whitespace, comments, and optionally shortens variable names to reduce file size — improving load times. Use formatted code in development, minified in production." },
  { question: "Does this formatter support TypeScript and JSX?", answer: "Yes. The formatter handles TypeScript type annotations, interface declarations, generics, and JSX syntax. It formats the code structurally without stripping types or transforming JSX — the output is valid TypeScript/JSX ready to paste back into your project." },
  { question: "Will minifying my JavaScript break it?", answer: "This tool performs whitespace-only minification — it removes spaces, tabs, and newlines without altering logic or renaming variables. This is safe and reversible. Full identifier-mangling minification (like Terser) requires a build tool, as it modifies variable names." },
  { question: "What indentation style does this formatter use?", answer: "The formatter uses 2-space indentation by default, which is the most common convention for JavaScript/TypeScript projects. The output follows standard formatting patterns compatible with Prettier default config." },
  { question: "Can I format multiple files at once?", answer: "This tool formats one snippet at a time. For bulk formatting across a codebase, use Prettier (prettier --write) or ESLint with the --fix flag. This tool is best for quick formatting of code snippets from API responses, logs, or pasted examples." },
];
---

<BaseLayout
  title="JavaScript Formatter & Minifier — Free Online JS Beautifier"
  description="Format and beautify JavaScript, TypeScript, or JSX code online. Or minify JS to reduce bundle size. Handles strings, template literals, comments, and nested blocks. Copy-ready output. Runs in your browser."
  tool="JavaScript Formatter, JS Beautifier, JS Minifier, JavaScript Pretty Print, Code Formatter, JSX Formatter, TypeScript Formatter"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">JavaScript Formatter & Minifier</h1>
  <p class="text-text-muted mb-4">Paste messy JavaScript to auto-indent and format for readability, or minify to strip whitespace and comments for smaller bundles. Preserves strings and template literals. Works with JS, TS, and JSX.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Supports JS, TS, and JSX</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <JsFormatter client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="JavaScript Formatter & Minifier" relatedTags={["javascript", "formatting", "minifier", "code", "development"]} />
</BaseLayout>
