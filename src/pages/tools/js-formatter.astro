---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsFormatter from '../../components/JsFormatter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="JavaScript Formatter & Minifier — Free Online Tool"
  description="Format and beautify JavaScript code with proper indentation, or minify it to reduce bundle size. Handles strings, template literals, comments, and nested blocks. Runs in your browser."
  tool="JavaScript Formatter, JS Beautifier, JS Minifier, JavaScript Pretty Print, Code Formatter"
>
  <h1 class="text-3xl font-bold mb-2">JavaScript Formatter & Minifier</h1>
  <p class="text-text-muted mb-8">Paste messy JavaScript to auto-indent and format for readability, or minify to strip whitespace and comments for smaller bundles. Preserves strings and template literals. Works with JS, TS, and JSX.</p>
  <JsFormatter client:only="preact" />
  <ToolPageCta currentTool="JavaScript Formatter & Minifier" relatedTags={['javascript', 'formatting', 'minifier', 'code', 'development']} />
</BaseLayout>
