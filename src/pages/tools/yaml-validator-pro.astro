---
import BaseLayout from '../../layouts/BaseLayout.astro';
import YamlValidator from '../../components/YamlValidator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "How does the YAML validator detect errors by line number?",
    answer: "The parser tracks line numbers as it processes your YAML. When it encounters invalid syntax — such as a tab character used for indentation, a mismatched mapping key, or an illegal scalar value — it reports the exact line number along with a description of the problem so you can jump straight to the issue."
  },
  {
    question: "What does the JSON preview mode show?",
    answer: "JSON preview converts your valid YAML to an equivalent JSON structure and displays it side-by-side. This is useful for verifying how YAML anchors and aliases resolve, confirming that nested mappings and sequences parsed correctly, and preparing YAML configs for APIs that expect JSON."
  },
  {
    question: "What are YAML schema hints?",
    answer: "Schema hints flag common YAML patterns that may behave unexpectedly: values like 'yes', 'no', 'on', 'off' that YAML 1.1 parses as booleans, bare numbers that might be read as integers, and keys that look like they should be quoted. These hints help you write YAML that behaves predictably across parsers."
  },
  {
    question: "Why does YAML use spaces instead of tabs?",
    answer: "The YAML specification explicitly forbids tabs for indentation because tab width is inconsistent across editors and environments, which would make the structure ambiguous. YAML parsers raise an error if tabs are found at the start of a line. Use 2 or 4 spaces consistently."
  },
  {
    question: "What is the difference between YAML block and flow style?",
    answer: "Block style uses newlines and indentation for structure (the common multi-line format). Flow style uses inline braces {} and brackets [] similar to JSON. Both are valid YAML. This validator handles both styles and highlights mixed-style issues that can confuse certain parsers."
  },
  {
    question: "Is my YAML data sent to any server?",
    answer: "No. All validation and parsing runs entirely in your browser. Your YAML data — including configuration files, secrets references, and Kubernetes manifests — never leaves your machine."
  },
];
---

<BaseLayout
  title="YAML Validator Pro — Line Errors, JSON Preview, Schema Hints"
  description="Advanced YAML validator with line-number error reporting, JSON preview, and schema hints. Detects tab indentation, boolean traps (yes/no/on/off), and malformed structures. Free, runs 100% in your browser."
  tool="YAML Validator Pro, YAML Lint online, YAML to JSON preview, YAML schema validator, YAML error checker, YAML formatter"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "YAML Validator Pro",
    "url": "https://devplaybook.cc/tools/yaml-validator-pro",
    "description": "Advanced YAML validator with line-number error reporting, JSON preview, and schema hints for common YAML pitfalls. Free, runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">YAML Validator Pro</h1>
  <p class="text-text-muted mb-4">
    Paste YAML to validate syntax and get errors by exact line number. Preview the parsed output as JSON, and catch subtle pitfalls like tab indentation, boolean traps (<code class="bg-bg-secondary px-1 rounded text-sm">yes</code>/<code class="bg-bg-secondary px-1 rounded text-sm">no</code>/<code class="bg-bg-secondary px-1 rounded text-sm">on</code>/<code class="bg-bg-secondary px-1 rounded text-sm">off</code>), and unquoted special values.
    Works for Kubernetes manifests, GitHub Actions, Docker Compose, and any YAML config.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Line-number error reporting</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> JSON preview of parsed output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Schema hints for common pitfalls</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <YamlValidator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="YAML Validator Pro" relatedTags={['yaml', 'json', 'formatting', 'validation', 'kubernetes', 'devops']} />
</BaseLayout>
