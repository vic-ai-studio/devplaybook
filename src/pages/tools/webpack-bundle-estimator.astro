---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WebpackBundleEstimator from '../../components/WebpackBundleEstimator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How accurate are these bundle size estimates?", answer: "Sizes come from bundlephobia.com which measures the actual minified + gzipped output for each package. The tree-shaking and partial import savings are approximations (40% and 70% reduction respectively) — actual savings depend on your webpack/rollup config, which parts you import, and whether the library is written as ESM. Use these as planning estimates, not exact figures." },
  { question: "What is tree-shaking and does it work for all packages?", answer: "Tree-shaking is dead-code elimination — your bundler removes exports you never import. It only works on ESM (ES Modules) packages with a module field in package.json. Packages like moment, jquery, and most CJS-only packages cannot be tree-shaken. Lodash-es (the ESM version of lodash) is fully tree-shakeable; lodash (CJS) is not." },
  { question: "What does 'partial import' mean in this tool?", answer: "Partial import means you only import specific functions, not the entire library. For example, import format from 'date-fns/format' instead of import { format } from 'date-fns'. This is especially effective for large utility libraries like lodash, date-fns, and Material UI where you may only use 5-10% of the API surface." },
  { question: "How should I interpret the load time estimates?", answer: "These estimates assume the JS must be downloaded from scratch (no cache). Real-world load time depends on CDN caching (repeat visitors get cached bundles), HTTP/2 multiplexing, and how the JS is chunked. Focus on the 3G estimate as a worst-case mobile scenario — if it is over 5 seconds, consider code-splitting." },
  { question: "What is webpack-bundle-analyzer and how do I use it?", answer: "webpack-bundle-analyzer generates a visual treemap of your actual bundle. Install it: npm install --save-dev webpack-bundle-analyzer. Add to webpack.config.js: const BundleAnalyzerPlugin = require('webpack-bundle-analyzer').BundleAnalyzerPlugin. Then add new BundleAnalyzerPlugin() to your plugins array. Run webpack to open the visual report showing exactly which packages take the most space." },
  { question: "How do I reduce my JavaScript bundle size?", answer: "1. Code-split with dynamic import() so each route only loads what it needs. 2. Replace heavy libraries with lightweight alternatives (moment→dayjs, lodash→lodash-es, MUI→shadcn/radix). 3. Use partial imports for utility libraries. 4. Enable tree-shaking (ESM-only packages). 5. Use a CDN for large stable dependencies. 6. Audit with webpack-bundle-analyzer to find duplicate packages." },
];
---

<BaseLayout
  title="Webpack Bundle Size Estimator — Calculate JS Bundle Weight"
  description="Estimate your JavaScript bundle size before you build. Add npm packages, enable tree-shaking and partial imports, see total gzipped size and load time on 3G/4G/WiFi. Free developer tool."
  tool="webpack bundle size estimator, JavaScript bundle size calculator, npm bundle calculator, tree shaking calculator, bundle weight estimator, JS bundle optimizer"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Webpack Bundle Size Estimator",
    "url": "https://devplaybook.cc/tools/webpack-bundle-estimator",
    "description": "Estimate JavaScript bundle size by adding npm packages. Accounts for tree-shaking and partial imports. Shows total gzipped size and network load time on 3G, 4G, and WiFi.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Webpack Bundle Size Estimator</h1>
  <p class="text-text-muted mb-4">
    Estimate your JavaScript bundle size before you build. Add npm packages, toggle tree-shaking and partial imports,
    and see total gzipped weight with load time estimates across network speeds.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Real bundlephobia data</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Tree-shaking estimation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Network load time preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Quick presets (React, Vue, etc.)</span>
  </div>
  <WebpackBundleEstimator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Webpack Bundle Size Estimator" relatedTags={['javascript', 'webpack', 'performance', 'bundling', 'npm', 'developer-tools']} />
</BaseLayout>
