---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "How do I create a responsive grid in Tailwind CSS?",
    answer: "Use responsive prefixes with grid-cols: grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4. This gives 1 column on mobile, 2 on small screens, and 4 on large screens. Combined with gap-4 for spacing, this pattern handles most responsive layout needs without writing custom CSS."
  },
  {
    question: "What is grid-cols-[repeat(auto-fill,minmax(200px,1fr))]?",
    answer: "This uses Tailwind's arbitrary value syntax to define a fluid grid that automatically creates as many columns as fit, each at least 200px wide. auto-fill fills the row with as many columns as possible (even empty ones), while auto-fit collapses empty columns. Combined with minmax, this creates a responsive layout without breakpoint-specific classes."
  },
  {
    question: "How do I make a grid item span multiple columns?",
    answer: "Use col-span-{n} classes: col-span-2 makes an item span 2 columns, col-span-full makes it span all columns. For rows, use row-span-{n}. These can also be responsive: sm:col-span-2 lg:col-span-3. Start position can be set with col-start-{n}."
  },
  {
    question: "What is the difference between gap, gap-x, and gap-y in Tailwind?",
    answer: "gap sets both row and column gaps equally. gap-x sets only horizontal (column) gaps. gap-y sets only vertical (row) gaps. For example, gap-x-4 gap-y-8 creates narrower horizontal gaps than vertical ones — useful for card layouts where items need more vertical breathing room."
  },
  {
    question: "When should I use Tailwind grid vs flex?",
    answer: "Use grid for two-dimensional layouts (rows AND columns), equal-height rows, and complex spanning. Use flex for one-dimensional layouts (row OR column), content-sized items that wrap, and navigation bars. Grid is better for page layouts and card grids; flex is better for inline components and spacing within a row."
  }
];
---

<BaseLayout
  title="Tailwind CSS Grid Generator — Visual Grid Builder with Live Preview"
  description="Generate Tailwind CSS grid classes visually. Configure columns, rows, gap spacing, and column spans with a live preview. Copy ready-to-use Tailwind classes and HTML. Free browser tool."
  tool="tailwind grid generator, tailwind css grid, tailwind grid builder, tailwind grid layout, tailwind css grid columns"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Tailwind CSS Grid Generator",
    "url": "https://devplaybook.cc/tools/tailwind-grid-generator",
    "description": "Visual Tailwind CSS grid builder. Configure columns, rows, gap, and spans. Get live preview and copy ready-to-use Tailwind classes.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Tailwind CSS Grid Generator</h1>
  <p class="text-text-muted mb-4">
    Build responsive CSS grid layouts visually with Tailwind CSS classes.
    Configure columns, rows, gaps, and column spans — see a live preview and copy the classes instantly.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Visual grid builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Responsive classes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy HTML & classes</span>
  </div>

  <!-- Controls -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      <div>
        <label class="block text-xs text-text-muted mb-1.5" for="cols-input">Columns (1-12)</label>
        <input type="range" id="cols-input" min="1" max="12" value="3" class="w-full accent-primary" />
        <div class="flex justify-between text-xs text-text-muted mt-1"><span>1</span><span id="cols-val" class="font-medium text-foreground">3</span><span>12</span></div>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1.5" for="rows-input">Items (1-12)</label>
        <input type="range" id="rows-input" min="1" max="12" value="6" class="w-full accent-primary" />
        <div class="flex justify-between text-xs text-text-muted mt-1"><span>1</span><span id="rows-val" class="font-medium text-foreground">6</span><span>12</span></div>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1.5" for="gap-select">Gap</label>
        <select id="gap-select" class="w-full bg-surface border border-border rounded-lg px-2 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="gap-0">gap-0 (0px)</option>
          <option value="gap-1">gap-1 (4px)</option>
          <option value="gap-2">gap-2 (8px)</option>
          <option value="gap-3">gap-3 (12px)</option>
          <option value="gap-4" selected>gap-4 (16px)</option>
          <option value="gap-6">gap-6 (24px)</option>
          <option value="gap-8">gap-8 (32px)</option>
          <option value="gap-10">gap-10 (40px)</option>
          <option value="gap-x-4 gap-y-2">gap-x-4 gap-y-2</option>
          <option value="gap-x-6 gap-y-4">gap-x-6 gap-y-4</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1.5" for="responsive-select">Responsive</label>
        <select id="responsive-select" class="w-full bg-surface border border-border rounded-lg px-2 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="none">No breakpoints</option>
          <option value="sm" selected>sm (640px+)</option>
          <option value="md">md (768px+)</option>
          <option value="lg">lg (1024px+)</option>
        </select>
      </div>
    </div>

    <!-- Item span controls -->
    <div class="mt-4">
      <label class="block text-xs text-text-muted mb-2">Column span for specific items (click item in preview to edit)</label>
      <div id="span-controls" class="flex flex-wrap gap-2"></div>
    </div>

    <!-- Quick presets -->
    <div class="mt-4 flex flex-wrap gap-2">
      <span class="text-xs text-text-muted self-center">Presets:</span>
      {[
        {label:'Blog layout',cols:3,items:6,gap:'gap-6',resp:'lg'},
        {label:'Card grid',cols:4,items:8,gap:'gap-4',resp:'sm'},
        {label:'Dashboard',cols:3,items:5,gap:'gap-4',resp:'md'},
        {label:'Gallery',cols:4,items:12,gap:'gap-2',resp:'sm'},
        {label:'Two-col',cols:2,items:4,gap:'gap-8',resp:'md'},
      ].map(p => (
        <button class="preset-btn px-2.5 py-1 bg-surface border border-border rounded text-xs hover:border-primary transition-colors text-text-muted" data-preset={JSON.stringify(p)}>{p.label}</button>
      ))}
    </div>
  </div>

  <!-- Preview -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-sm font-medium">Live Preview</h2>
      <span class="text-xs text-text-muted">Click any item to set col-span</span>
    </div>
    <div id="grid-preview" class="min-h-32 border border-dashed border-border rounded-lg p-3"></div>
  </div>

  <!-- Code output -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-sm font-medium">Generated Classes</h2>
      <div class="flex gap-2">
        <button id="copy-classes" class="px-3 py-1.5 bg-surface border border-border rounded text-xs hover:border-primary transition-colors">Copy classes</button>
        <button id="copy-html" class="px-3 py-1.5 bg-primary text-white rounded text-xs hover:bg-primary/90 transition-colors">Copy HTML</button>
      </div>
    </div>
    <div class="mb-3">
      <div class="text-xs text-text-muted mb-1">Container classes</div>
      <code id="classes-output" class="block bg-surface rounded-lg px-3 py-2 text-sm font-mono text-accent"></code>
    </div>
    <div>
      <div class="text-xs text-text-muted mb-1">Full HTML snippet</div>
      <pre id="html-output" class="bg-surface rounded-lg px-3 py-2 text-xs font-mono overflow-x-auto text-foreground/80 whitespace-pre"></pre>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Tailwind CSS Grid Generator" relatedTags={['tailwind', 'css', 'grid', 'layout', 'frontend']} />
</BaseLayout>

<script is:inline>
(function() {
  let cols = 3, items = 6, gap = 'gap-4', responsive = 'sm';
  let itemSpans = {}; // { idx: 2 }
  let selectedItem = null;

  const GAP_PX = {
    'gap-0': 0, 'gap-1': 4, 'gap-2': 8, 'gap-3': 12,
    'gap-4': 16, 'gap-6': 24, 'gap-8': 32, 'gap-10': 40,
    'gap-x-4 gap-y-2': 16, 'gap-x-6 gap-y-4': 24
  };

  function getContainerClasses() {
    const colClass = responsive === 'none'
      ? `grid-cols-${cols}`
      : `grid-cols-1 ${responsive}:grid-cols-${cols}`;
    return `grid ${colClass} ${gap}`;
  }

  function renderPreview() {
    const preview = document.getElementById('grid-preview');
    const colors = ['bg-primary/20 border-primary/40','bg-purple-500/20 border-purple-500/40','bg-green-500/20 border-green-500/40','bg-yellow-400/20 border-yellow-400/40','bg-red-500/20 border-red-500/40','bg-pink-500/20 border-pink-500/40'];

    const gapVal = GAP_PX[gap] || 16;
    const gapStyle = `gap: ${gapVal}px`;
    const colsStyle = `grid-template-columns: repeat(${cols}, minmax(0, 1fr))`;

    let html = `<div style="display:grid; ${colsStyle}; ${gapStyle}">`;
    for (let i = 0; i < items; i++) {
      const span = itemSpans[i] || 1;
      const spanStyle = span > 1 ? `grid-column: span ${span} / span ${span}` : '';
      const color = colors[i % colors.length];
      const isSelected = selectedItem === i;
      html += `<div data-idx="${i}" class="preview-item ${color} border rounded-lg flex items-center justify-center text-xs font-medium cursor-pointer transition-all ${isSelected ? 'ring-2 ring-primary' : 'hover:opacity-80'}" style="min-height:60px; ${spanStyle}">
        Item ${i + 1}${span > 1 ? ` (span ${span})` : ''}
      </div>`;
    }
    html += '</div>';
    preview.innerHTML = html;

    preview.querySelectorAll('.preview-item').forEach(el => {
      el.addEventListener('click', () => {
        selectedItem = parseInt(el.dataset.idx);
        renderSpanControls();
        renderPreview();
      });
    });
  }

  function renderSpanControls() {
    const area = document.getElementById('span-controls');
    if (selectedItem === null) {
      area.innerHTML = '<span class="text-xs text-text-muted">Click an item in the preview to set its span</span>';
      return;
    }
    const currentSpan = itemSpans[selectedItem] || 1;
    let html = `<span class="text-xs text-text-muted self-center">Item ${selectedItem + 1} span:</span>`;
    for (let s = 1; s <= cols; s++) {
      html += `<button class="span-btn px-2.5 py-1 rounded text-xs border transition-colors ${s === currentSpan ? 'bg-primary/20 border-primary text-primary' : 'bg-surface border-border text-text-muted hover:border-primary'}" data-span="${s}">col-span-${s}</button>`;
    }
    area.innerHTML = html;
    area.querySelectorAll('.span-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const s = parseInt(btn.dataset.span);
        if (s === 1) delete itemSpans[selectedItem];
        else itemSpans[selectedItem] = s;
        render();
      });
    });
  }

  function renderOutput() {
    const containerClasses = getContainerClasses();
    document.getElementById('classes-output').textContent = containerClasses;

    let html = `<div class="${containerClasses}">\n`;
    for (let i = 0; i < items; i++) {
      const span = itemSpans[i];
      const spanClass = span && span > 1 ? ` col-span-${span}` : '';
      html += `  <div class="...${spanClass}">Item ${i + 1}</div>\n`;
    }
    html += '</div>';
    document.getElementById('html-output').textContent = html;
  }

  function render() {
    renderPreview();
    renderSpanControls();
    renderOutput();
  }

  // Controls
  const colsInput = document.getElementById('cols-input');
  const rowsInput = document.getElementById('rows-input');
  colsInput.addEventListener('input', () => {
    cols = parseInt(colsInput.value);
    document.getElementById('cols-val').textContent = cols;
    // Clear spans that exceed new col count
    Object.keys(itemSpans).forEach(k => { if (itemSpans[k] > cols) delete itemSpans[k]; });
    render();
  });
  rowsInput.addEventListener('input', () => {
    items = parseInt(rowsInput.value);
    document.getElementById('rows-val').textContent = items;
    render();
  });
  document.getElementById('gap-select').addEventListener('change', e => { gap = e.target.value; render(); });
  document.getElementById('responsive-select').addEventListener('change', e => { responsive = e.target.value; render(); });

  // Presets
  document.querySelectorAll('.preset-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const p = JSON.parse(btn.dataset.preset);
      cols = p.cols; items = p.items; gap = p.gap; responsive = p.resp;
      colsInput.value = cols; rowsInput.value = items;
      document.getElementById('cols-val').textContent = cols;
      document.getElementById('rows-val').textContent = items;
      document.getElementById('gap-select').value = gap;
      document.getElementById('responsive-select').value = responsive;
      itemSpans = {};
      selectedItem = null;
      render();
    });
  });

  // Copy buttons
  document.getElementById('copy-classes').addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('classes-output').textContent)
      .then(() => {
        const btn = document.getElementById('copy-classes');
        btn.textContent = 'Copied!';
        setTimeout(() => btn.textContent = 'Copy classes', 1500);
      });
  });
  document.getElementById('copy-html').addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('html-output').textContent)
      .then(() => {
        const btn = document.getElementById('copy-html');
        btn.textContent = 'Copied!';
        setTimeout(() => btn.textContent = 'Copy HTML', 1500);
      });
  });

  render();
})();
</script>
