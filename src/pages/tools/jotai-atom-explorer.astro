---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is Jotai?", answer: "Jotai is a primitive, flexible atomic state management library for React. The word 'jotai' means 'state' in Japanese. Unlike Zustand (store-based) or Redux (global reducer), Jotai builds state from small atomic units called atoms. Components subscribe to specific atoms, and only re-render when those atoms change — naturally preventing unnecessary updates." },
  { question: "What is an atom in Jotai?", answer: "An atom is the smallest unit of state in Jotai. You create one with atom(initialValue). Any component can read and write it with useAtom(atomName), similar to React's useState. Atoms are stored in a Provider (or default global store) and automatically garbage collected when no components subscribe to them." },
  { question: "What is a derived atom?", answer: "A derived atom computes its value from other atoms. Create one by passing a read function to atom(): const derivedAtom = atom(get => get(countAtom) * 2). Derived atoms are read-only by default. For read-write derived atoms, pass both read and write functions. They memoize and only recompute when their dependencies change." },
  { question: "What is atomWithStorage?", answer: "atomWithStorage is a utility from jotai/utils that synchronizes atom state with localStorage, sessionStorage, or AsyncStorage. Import it and use: const themeAtom = atomWithStorage('theme', 'light'). The value persists across page reloads and syncs across tabs. It also handles serialization automatically." },
  { question: "How does Jotai differ from Recoil?", answer: "Both use the atomic model. Jotai is simpler: no atom keys required (preventing key conflicts), smaller bundle (~3KB vs ~20KB for Recoil), and better TypeScript support. Recoil has more built-in utilities (selectors, effects, snapshots) but is Facebook-specific and less actively maintained. Jotai is generally preferred for new projects." },
  { question: "When should I use Jotai vs Zustand?", answer: "Use Jotai when you have many small, independent state pieces with fine-grained subscriptions — like individual UI elements, feature flags per component, or derived computed values. Use Zustand when you have domain state with actions (e.g., a shopping cart, auth store) where related state and logic belong together. They can coexist in the same app." },
];
---

<BaseLayout
  title="Jotai Atom Explorer — Jotai Derived Atom Builder & Dependency Visualizer"
  description="Design Jotai atoms visually. Create primitive atoms, build derived computed atoms, configure atomWithStorage, and see dependency graphs. Generates TypeScript Jotai code for React."
  tool="Jotai Atom Explorer, Jotai Derived Atom Builder, Jotai Dependency Visualizer, atomWithStorage Generator, Jotai TypeScript Code Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Jotai Atom Explorer</h1>
  <p class="text-text-muted mb-4">Design your Jotai atom structure visually. Add primitive atoms, build derived atoms with dependencies, and generate clean TypeScript code with usage examples.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Primitive & derived atoms</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> atomWithStorage support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Dependency graph</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-5">
    <!-- Atom Builder -->
    <div class="space-y-4">
      <!-- Primitive Atoms -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-base font-semibold">Primitive Atoms</h2>
          <button id="add-primitive" class="text-xs bg-primary/10 text-primary border border-primary/30 rounded-lg px-3 py-1.5 hover:bg-primary/20 transition-colors">+ Add</button>
        </div>
        <div id="primitive-list" class="space-y-2"></div>
      </div>

      <!-- Derived Atoms -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-base font-semibold">Derived Atoms</h2>
          <button id="add-derived" class="text-xs bg-primary/10 text-primary border border-primary/30 rounded-lg px-3 py-1.5 hover:bg-primary/20 transition-colors">+ Add</button>
        </div>
        <div id="derived-list" class="space-y-2"></div>
      </div>

      <!-- Dependency Graph -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">Dependency Graph</h2>
        <div id="dep-graph" class="text-xs font-mono space-y-1 text-text-muted"></div>
      </div>
    </div>

    <!-- Code Output -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-base font-semibold">Generated Code</h2>
        <button id="copy-btn" class="text-xs bg-primary/10 text-primary border border-primary/30 rounded-lg px-3 py-1.5 hover:bg-primary/20 transition-colors">Copy</button>
      </div>
      <pre id="code-output" class="text-xs font-mono bg-bg-card border border-border rounded-lg p-4 overflow-auto max-h-[600px] whitespace-pre-wrap text-text-muted"></pre>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Jotai Atom Explorer" relatedTags={['react', 'state-management', 'typescript', 'jotai', 'frontend']} />
</BaseLayout>

<script>
  type AtomType = 'primitive' | 'storage' | 'async';
  type ValueType = 'string' | 'number' | 'boolean' | 'string[]' | 'object';

  interface PrimitiveAtom {
    name: string;
    valueType: ValueType;
    defaultVal: string;
    atomType: AtomType;
    storageKey?: string;
  }

  interface DerivedAtom {
    name: string;
    deps: string[];
    formula: string;
    writable: boolean;
    writeLogic: string;
  }

  const primitives: PrimitiveAtom[] = [
    { name: 'countAtom', valueType: 'number', defaultVal: '0', atomType: 'primitive' },
    { name: 'nameAtom', valueType: 'string', defaultVal: "'Alice'", atomType: 'primitive' },
    { name: 'themeAtom', valueType: 'string', defaultVal: "'light'", atomType: 'storage', storageKey: 'theme' },
  ];

  const deriveds: DerivedAtom[] = [
    { name: 'doubleCountAtom', deps: ['countAtom'], formula: 'get(countAtom) * 2', writable: false, writeLogic: '' },
    { name: 'greetingAtom', deps: ['nameAtom', 'countAtom'], formula: '`Hello ${get(nameAtom)}, count: ${get(countAtom)}`', writable: false, writeLogic: '' },
  ];

  const typeMap: Record<string, string> = {
    string: 'string', number: 'number', boolean: 'boolean', 'string[]': 'string[]', object: 'Record<string, unknown>',
  };
  const defaultMap: Record<string, string> = {
    string: "''", number: '0', boolean: 'false', 'string[]': '[]', object: '{}',
  };

  function renderPrimitives() {
    const el = document.getElementById('primitive-list')!;
    el.innerHTML = primitives.map((p, i) => `
      <div class="border border-border rounded-lg p-3 space-y-2">
        <div class="flex gap-2 items-center">
          <input type="text" value="${p.name}" data-pidx="${i}" data-pkey="name"
            class="prim-input flex-1 bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs font-mono focus:outline-none focus:border-primary" />
          <select data-pidx="${i}" data-pkey="atomType" class="prim-input bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:border-primary">
            <option value="primitive" ${p.atomType === 'primitive' ? 'selected' : ''}>atom()</option>
            <option value="storage" ${p.atomType === 'storage' ? 'selected' : ''}>atomWithStorage</option>
            <option value="async" ${p.atomType === 'async' ? 'selected' : ''}>async atom</option>
          </select>
          <button data-del-prim="${i}" class="text-red-500 hover:text-red-400 text-xs px-1">✕</button>
        </div>
        <div class="flex gap-2">
          <select data-pidx="${i}" data-pkey="valueType" class="prim-input flex-1 bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:border-primary">
            ${['string','number','boolean','string[]','object'].map(t =>
              `<option value="${t}" ${p.valueType === t ? 'selected' : ''}>${t}</option>`
            ).join('')}
          </select>
          <input type="text" value="${p.defaultVal}" placeholder="default" data-pidx="${i}" data-pkey="defaultVal"
            class="prim-input flex-1 bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs font-mono focus:outline-none focus:border-primary" />
          ${p.atomType === 'storage' ? `<input type="text" value="${p.storageKey || p.name.replace('Atom','')}" placeholder="storageKey" data-pidx="${i}" data-pkey="storageKey" class="prim-input flex-1 bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs font-mono focus:outline-none focus:border-primary" />` : ''}
        </div>
      </div>
    `).join('');
  }

  function renderDerived() {
    const primNames = primitives.map(p => p.name);
    const el = document.getElementById('derived-list')!;
    el.innerHTML = deriveds.map((d, i) => `
      <div class="border border-border rounded-lg p-3 space-y-2">
        <div class="flex gap-2 items-center">
          <input type="text" value="${d.name}" data-didx="${i}" data-dkey="name"
            class="der-input flex-1 bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs font-mono focus:outline-none focus:border-primary" />
          <button data-del-der="${i}" class="text-red-500 hover:text-red-400 text-xs px-1">✕</button>
        </div>
        <div>
          <div class="text-xs text-text-muted mb-1">Dependencies:</div>
          <div class="flex flex-wrap gap-1">
            ${primNames.map(n => `
              <label class="flex items-center gap-1 text-xs cursor-pointer border border-border rounded px-2 py-1 ${d.deps.includes(n) ? 'bg-primary/10 border-primary/50 text-primary' : ''}">
                <input type="checkbox" data-didx="${i}" data-dep="${n}" class="dep-check" ${d.deps.includes(n) ? 'checked' : ''} />
                ${n}
              </label>
            `).join('')}
          </div>
        </div>
        <input type="text" value="${d.formula}" placeholder="get(depAtom) + 1" data-didx="${i}" data-dkey="formula"
          class="der-input w-full bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs font-mono focus:outline-none focus:border-primary" />
        <label class="flex items-center gap-2 text-xs cursor-pointer">
          <input type="checkbox" data-didx="${i}" data-dkey="writable" class="der-check" ${d.writable ? 'checked' : ''} />
          <span>Writable (read-write derived atom)</span>
        </label>
        ${d.writable ? `<input type="text" value="${d.writeLogic}" placeholder="(get, set, update) => set(depAtom, update)" data-didx="${i}" data-dkey="writeLogic" class="der-input w-full bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs font-mono focus:outline-none focus:border-primary" />` : ''}
      </div>
    `).join('');
  }

  function updateDepGraph() {
    const el = document.getElementById('dep-graph')!;
    const lines: string[] = [];
    for (const d of deriveds) {
      lines.push(`${d.name}`);
      for (const dep of d.deps) lines.push(`  └─ ${dep}`);
    }
    el.innerHTML = lines.map(l => `<div>${l}</div>`).join('') || '<div class="text-text-muted">No derived atoms</div>';
  }

  function generateCode(): string {
    const imports: string[] = ["import { atom, useAtom, useAtomValue, useSetAtom } from 'jotai';"];
    const hasStorage = primitives.some(p => p.atomType === 'storage');
    const hasAsync = primitives.some(p => p.atomType === 'async');
    if (hasStorage) imports.push("import { atomWithStorage } from 'jotai/utils';");

    const primCode = primitives.map(p => {
      const tsType = `${typeMap[p.valueType] || p.valueType}`;
      if (p.atomType === 'storage') {
        return `export const ${p.name} = atomWithStorage<${tsType}>('${p.storageKey || p.name}', ${p.defaultVal});`;
      }
      if (p.atomType === 'async') {
        return `export const ${p.name} = atom<Promise<${tsType}>>(async () => {\n  const res = await fetch('/api/data');\n  return res.json();\n});`;
      }
      return `export const ${p.name} = atom<${tsType}>(${p.defaultVal});`;
    }).join('\n');

    const derCode = deriveds.map(d => {
      if (d.writable && d.writeLogic) {
        return `export const ${d.name} = atom(\n  (get) => ${d.formula},\n  ${d.writeLogic}\n);`;
      }
      return `export const ${d.name} = atom((get) => ${d.formula || 'undefined'});`;
    }).join('\n');

    const usageAtoms = primitives.slice(0, 2);
    const usageDerived = deriveds[0];

    const usageCode = `
// Component usage
function MyComponent() {
${usageAtoms.map(p => `  const [${p.name.replace('Atom','')}, set${p.name.replace('Atom','')[0].toUpperCase() + p.name.replace('Atom','').slice(1)}] = useAtom(${p.name});`).join('\n')}
${usageDerived ? `  const ${usageDerived.name.replace('Atom','')} = useAtomValue(${usageDerived.name}); // read-only derived` : ''}

  return (
    <div>
${usageAtoms.map(p => `      <div>${p.name.replace('Atom','')} = {${p.name.replace('Atom','')}}</div>`).join('\n')}
    </div>
  );
}`;

    return [imports.join('\n'), '', primCode, '', derCode, usageCode].join('\n');
  }

  function update() {
    renderDerived();
    updateDepGraph();
    document.getElementById('code-output')!.textContent = generateCode();
  }

  document.getElementById('add-primitive')!.addEventListener('click', () => {
    primitives.push({ name: `atom${primitives.length + 1}`, valueType: 'string', defaultVal: "''", atomType: 'primitive' });
    renderPrimitives();
    update();
  });

  document.getElementById('add-derived')!.addEventListener('click', () => {
    deriveds.push({ name: `derivedAtom${deriveds.length + 1}`, deps: [], formula: '', writable: false, writeLogic: '' });
    update();
  });

  document.getElementById('primitive-list')!.addEventListener('input', (e) => {
    const t = e.target as HTMLElement;
    const idx = parseInt(t.getAttribute('data-pidx') || '0');
    const key = t.getAttribute('data-pkey') as keyof PrimitiveAtom;
    if (key && idx >= 0 && primitives[idx]) {
      (primitives[idx] as any)[key] = (t as HTMLInputElement).value;
      if (key === 'valueType') {
        primitives[idx].defaultVal = defaultMap[(t as HTMLInputElement).value] || "''";
        renderPrimitives();
      }
      update();
    }
  });

  document.getElementById('primitive-list')!.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    const idx = t.getAttribute('data-del-prim');
    if (idx !== null) { primitives.splice(parseInt(idx), 1); renderPrimitives(); update(); }
  });

  document.getElementById('derived-list')!.addEventListener('input', (e) => {
    const t = e.target as HTMLElement;
    const didx = parseInt(t.getAttribute('data-didx') || '0');
    const key = t.getAttribute('data-dkey') as keyof DerivedAtom;
    if (key && didx >= 0 && deriveds[didx]) {
      (deriveds[didx] as any)[key] = (t as HTMLInputElement).value;
      if (key === 'writable') (deriveds[didx] as any)[key] = (t as HTMLInputElement).checked;
      update();
    }
  });

  document.getElementById('derived-list')!.addEventListener('change', (e) => {
    const t = e.target as HTMLElement;
    const didx = parseInt(t.getAttribute('data-didx') || '0');
    const dep = t.getAttribute('data-dep');
    if (dep !== null && didx >= 0 && deriveds[didx]) {
      const checked = (t as HTMLInputElement).checked;
      if (checked) { if (!deriveds[didx].deps.includes(dep)) deriveds[didx].deps.push(dep); }
      else { deriveds[didx].deps = deriveds[didx].deps.filter(d => d !== dep); }
      update();
    }
  });

  document.getElementById('derived-list')!.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    const idx = t.getAttribute('data-del-der');
    if (idx !== null) { deriveds.splice(parseInt(idx), 1); update(); }
  });

  document.getElementById('copy-btn')!.addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('code-output')!.textContent || '');
    const btn = document.getElementById('copy-btn')!;
    btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = 'Copy', 1500);
  });

  renderPrimitives();
  update();
</script>
