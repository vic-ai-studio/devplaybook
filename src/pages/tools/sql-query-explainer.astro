---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SqlQueryExplainer from '../../components/SqlQueryExplainer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the order of SQL clause execution?",
    answer: "SQL executes clauses in this logical order: FROM → JOIN → WHERE → GROUP BY → HAVING → SELECT → DISTINCT → ORDER BY → LIMIT. This is different from the order you write them. Understanding execution order explains why you can't use SELECT aliases in WHERE (WHERE runs before SELECT), but you can use them in ORDER BY (which runs after SELECT)."
  },
  {
    question: "What is the difference between WHERE and HAVING?",
    answer: "WHERE filters individual rows BEFORE aggregation — it cannot use aggregate functions. HAVING filters groups AFTER aggregation — it can reference aggregate functions like SUM(), COUNT(). Rule: if the condition uses an aggregate function, it must be in HAVING. If not, prefer WHERE (better performance, runs earlier)."
  },
  {
    question: "What is the difference between INNER JOIN, LEFT JOIN, and FULL JOIN?",
    answer: "INNER JOIN returns only rows where the ON condition matches in BOTH tables. LEFT JOIN returns all rows from the left table plus matching rows from the right (NULLs for no match). RIGHT JOIN is the mirror of LEFT JOIN. FULL OUTER JOIN returns all rows from both tables, with NULLs where no match exists. CROSS JOIN produces every combination of rows (Cartesian product)."
  },
  {
    question: "What is a CTE (WITH clause) and when should I use it?",
    answer: "A CTE (Common Table Expression) creates a named temporary result set within a query. Use CTEs to: (1) Break complex queries into readable steps. (2) Reference the same subquery multiple times without duplication. (3) Write recursive queries (e.g., tree traversal). CTEs in PostgreSQL 12+ are inlined by default (treated as subqueries), which allows the optimizer to push WHERE filters through them."
  },
  {
    question: "How can I improve slow SQL query performance?",
    answer: "Key optimizations: (1) Add indexes on columns used in WHERE, JOIN, and ORDER BY. (2) Avoid functions on indexed columns in WHERE (prevents index use). (3) Use EXPLAIN ANALYZE to see the query plan. (4) Replace SELECT * with specific columns. (5) Add covering indexes for frequently queried column sets. (6) Avoid N+1 queries — use JOINs or batch loading instead. (7) For large tables, partition by date or other high-cardinality columns."
  },
  {
    question: "What is the difference between UNION and UNION ALL?",
    answer: "UNION combines results from two SELECT statements and removes duplicates (expensive — requires sorting/hashing). UNION ALL combines results without removing duplicates (faster — no deduplication). Use UNION ALL unless you specifically need to remove duplicates. Both require the same number of columns with compatible types in each SELECT."
  },
];
---

<BaseLayout
  title="SQL Query Explainer — Understand SELECT, JOIN, WHERE, GROUP BY Clauses"
  description="Paste any SQL query and get a plain-English explanation of each clause: SELECT, FROM, JOIN, WHERE, GROUP BY, HAVING, ORDER BY, LIMIT. Includes performance tips. Runs in your browser."
  tool="SQL query explainer, SQL clause breakdown, understand SQL query, SQL WHERE GROUP BY explainer, SQL for beginners"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "SQL Query Explainer",
    "url": "https://devplaybook.cc/tools/sql-query-explainer",
    "description": "Paste a SQL query and get plain-English explanations of each clause with performance tips. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">SQL Query Explainer</h1>
  <p class="text-text-muted mb-4">
    Paste any <code class="font-mono bg-bg-card px-1 rounded text-sm">SELECT</code> query and get a plain-English breakdown of
    each clause — SELECT, FROM, JOIN, WHERE, GROUP BY, HAVING, ORDER BY, LIMIT.
    Each explanation includes performance tips and common pitfalls.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All major SQL clauses</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Performance tips</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs in browser</span>
  </div>
  <SqlQueryExplainer client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SQL Query Explainer" relatedTags={['sql', 'database', 'postgres', 'mysql', 'sqlite', 'backend']} />
</BaseLayout>
