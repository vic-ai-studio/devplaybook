---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JestMockGenerator from '../../components/JestMockGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the difference between jest.mock() and jest.spyOn()?",
    answer: "jest.mock() replaces an entire module with a mocked version — great for isolating tests from external dependencies. jest.spyOn() wraps an existing method on an object, letting you observe calls and optionally change behavior while preserving the original. Use jest.mock() for heavy isolation, jest.spyOn() for lighter observation with restore capability."
  },
  {
    question: "When should I use mockReturnValue vs mockImplementation?",
    answer: "Use mockReturnValue when the mock simply needs to return a fixed value — it's concise and readable. Use mockImplementation when you need conditional logic, access to arguments, or multiple return paths. Use mockReturnValueOnce for chained sequential values: mock.mockReturnValueOnce('first').mockReturnValueOnce('second')."
  },
  {
    question: "How do I mock async functions?",
    answer: "Use mockResolvedValue (equivalent to mockReturnValue(Promise.resolve(value))) or mockRejectedValue (equivalent to mockReturnValue(Promise.reject(error))). For async spies, use jest.spyOn(object, 'method').mockResolvedValue(data). In tests, use await to resolve the promise and assert the result."
  },
  {
    question: "How do I mock a class constructor and its methods?",
    answer: "Call jest.mock('./MyClass') to auto-mock the class. Then use MyClass as jest.MockedClass<typeof MyClass> to access mock methods. Override methods via MyClass.prototype.method = jest.fn() or use mockImplementation on the constructor to return a custom object. Always call mockClear() in beforeEach to reset call counts."
  },
  {
    question: "What does mockRestore() do and when should I use it?",
    answer: "mockRestore() restores a jest.spyOn() spy back to its original implementation. It only works on spies created with jest.spyOn() — not manual jest.fn() mocks. Call it in afterEach to prevent test pollution. If you forget to restore, later tests may interact with stale spies. jest.restoreAllMocks() in afterEach restores all spies at once."
  },
  {
    question: "How do I reset or clear mocks between tests?",
    answer: "Use jest.clearAllMocks() to clear call history (calls, instances, results) without removing implementations. jest.resetAllMocks() also removes mock implementations, returning jest.fn(). jest.restoreAllMocks() restores spies created with jest.spyOn(). Configure these automatically in jest.config.js with clearMocks, resetMocks, or restoreMocks: true."
  },
];
---

<BaseLayout
  title="Jest Mock Generator — Generate jest.mock, Spy, Class & Timer Mocks"
  description="Generate Jest mock code for modules, classes, functions, spies, and fake timers. Supports TypeScript type assertions, mockReturnValue, mockResolvedValue, and spy behaviors."
  tool="Jest Mock Generator, Jest Spy Generator, Jest Timer Mock, jest.mock Generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Jest Mock Generator",
    "url": "https://devplaybook.cc/tools/jest-mock-generator",
    "description": "Generate Jest mock code for modules, classes, functions, and spies. Supports TypeScript, all mock behaviors, and fake timers.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Jest Mock Generator</h1>
  <p class="text-text-muted mb-4">
    Generate Jest mock and spy code instantly. Choose module mocks, class mocks, function mocks,
    spies with custom behaviors, or fake timer setups — with optional TypeScript type assertions.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Module / Class / Function / Spy / Timer</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All mock behaviors</span>
  </div>
  <JestMockGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Jest Mock Generator" relatedTags={['testing', 'jest', 'javascript', 'typescript', 'developer-tools']} />
</BaseLayout>
