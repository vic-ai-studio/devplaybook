---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DockerRunCommandBuilder from '../../components/DockerRunCommandBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What does the -d flag do in docker run?",
    answer: "The -d (detached) flag runs the container in the background and prints the container ID. Without it, the container runs in the foreground and attaches your terminal to its output. Use -d for long-running services like web servers or databases."
  },
  {
    question: "What is the difference between --rm and stopping a container?",
    answer: "The --rm flag automatically deletes the container's filesystem once it exits. Without --rm, stopped containers remain on disk and can be restarted or inspected later. Use --rm for one-off tasks and short-lived containers to avoid accumulating stopped containers."
  },
  {
    question: "How do port mappings work with -p?",
    answer: "The -p flag maps a host port to a container port using the format host:container (e.g., -p 8080:80). Traffic arriving on port 8080 of your host machine is forwarded to port 80 inside the container. You can publish multiple ports by repeating the -p flag."
  },
  {
    question: "When should I use a named volume vs a bind mount?",
    answer: "Bind mounts (e.g., -v ./data:/data) map a specific path on your host into the container, making them ideal for development where you want live code changes. Named volumes (e.g., -v mydata:/data) are managed by Docker and are better for production data persistence because they are independent of the host directory structure."
  },
  {
    question: "What restart policies are available and when should I use them?",
    answer: "Docker offers four restart policies: 'no' (never restart, the default), 'always' (restart regardless of exit code, including on daemon start), 'unless-stopped' (like always but respects manual stops), and 'on-failure' (only restart on non-zero exit codes). Use 'unless-stopped' for services you always want running, and 'on-failure' for tasks that should retry on errors but not run indefinitely."
  },
];
---

<BaseLayout
  title="Docker Run Command Builder — Generate docker run Commands Online"
  description="Build complete docker run commands with a visual form. Set ports, volumes, environment variables, restart policies, and flags instantly. Free, runs in your browser."
  tool="Docker Run Command Builder, docker run generator, Docker CLI builder, docker run command"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Docker Run Command Builder",
    "url": "https://devplaybook.cc/tools/docker-run-command-builder",
    "description": "Build complete docker run commands visually. Configure port mappings, volume mounts, environment variables, restart policies, and runtime flags without memorising syntax.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Docker Run Command Builder</h1>
  <p class="text-text-muted mb-4">
    Build a complete <code class="font-mono text-sm bg-bg-secondary px-1 py-0.5 rounded">docker run</code> command visually — no syntax memorisation required. Configure port mappings, volume mounts, environment variables, restart policies, and flags like <code class="font-mono text-sm bg-bg-secondary px-1 py-0.5 rounded">-d</code>, <code class="font-mono text-sm bg-bg-secondary px-1 py-0.5 rounded">--rm</code>, and <code class="font-mono text-sm bg-bg-secondary px-1 py-0.5 rounded">-it</code>. The command updates live as you type.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live command preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Ports, volumes, env vars & flags</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <DockerRunCommandBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Docker Run Command Builder" relatedTags={['docker', 'containers', 'devops', 'cli']} />
</BaseLayout>
