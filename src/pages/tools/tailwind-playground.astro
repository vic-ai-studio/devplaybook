---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TailwindPlayground from '../../components/TailwindPlayground.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is the Tailwind CSS Playground?",
    answer: "The Tailwind CSS Playground is a browser-based live editor where you write HTML with Tailwind utility classes and instantly see the rendered output in a split-pane preview. No install or build step required — Tailwind loads from the official CDN.",
  },
  {
    question: "Do I need to install Tailwind CSS to use this tool?",
    answer: "No. The playground loads Tailwind CSS directly from the official CDN (cdn.tailwindcss.com) inside the preview iframe. All rendering happens in your browser — nothing is sent to a server.",
  },
  {
    question: "Can I use custom Tailwind configuration or plugins?",
    answer: "The playground uses the standard Tailwind CDN build which includes all core utilities and variants. Custom tailwind.config.js or plugins are not supported in this browser-based environment, but all built-in utility classes work out of the box.",
  },
  {
    question: "How do I use the templates?",
    answer: "Click any template button (Card, Flex Layout, Form, Hero) to load a pre-built starting point into the editor. You can then modify the HTML and classes to see live updates in the preview panel.",
  },
  {
    question: "Can I copy my finished HTML?",
    answer: "Yes. Click the Copy button in the editor panel header to copy all the current HTML to your clipboard. The copied code includes all Tailwind class names, ready to paste into your project.",
  },
  {
    question: "What Tailwind version does this use?",
    answer: "The playground uses the latest stable Tailwind CSS v3 from the CDN. This includes all v3 utility classes, the JIT engine behavior, and all built-in variants (hover, focus, dark mode, responsive breakpoints, etc.).",
  },
];
---

<BaseLayout
  title="Tailwind CSS Playground — Live Editor with Real-Time Preview"
  description="Write HTML with Tailwind CSS classes and see a live preview instantly. No install needed. Pick from starter templates, copy your code, and ship faster."
  tool="Tailwind CSS Playground, Tailwind Live Editor, Tailwind Preview, Tailwind Online, CSS Playground"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Tailwind CSS Playground</h1>
  <p class="text-text-muted mb-4">
    Write HTML with Tailwind utility classes and see a live preview instantly — no install, no build step. Pick a starter template or write from scratch. When you're happy with the result, copy the code and drop it straight into your project.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Powered by Tailwind CDN</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live split-pane preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 4 starter templates</span>
  </div>
  <TailwindPlayground client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Tailwind CSS Playground" relatedTags={['css', 'tailwind', 'frontend', 'ui', 'html']} />
</BaseLayout>
