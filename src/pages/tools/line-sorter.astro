---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LineSorter from '../../components/LineSorter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Line Sorter & Deduplicator"
  description="Sort lines alphabetically, by length, in reverse order, or shuffle randomly. Remove duplicates, trim whitespace, and delete empty lines. Instant copy."
  tool="Line Sorter, Text Sorter, Remove Duplicates, Alphabetical Sort, Shuffle Lines"
>
  <h1 class="text-3xl font-bold mb-2">Line Sorter & Deduplicator</h1>
  <p class="text-text-muted mb-8">Sort lines A–Z, Z–A, by length, or shuffle randomly. Remove duplicate lines, trim leading/trailing whitespace, and delete empty lines. Perfect for cleaning up lists, logs, and config values.</p>
  <LineSorter client:only="preact" />
  <ToolPageCta currentTool="Line Sorter & Deduplicator" relatedTags={['text', 'sorting', 'dedupe', 'list', 'data']} />
</BaseLayout>
