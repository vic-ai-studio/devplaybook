---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SvgOptimizer from '../../components/SvgOptimizer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "Why should I optimize SVG files?", answer: "SVG files exported from design tools like Inkscape, Illustrator, or Figma contain metadata, comments, editor data, and redundant attributes that bloat file sizes. Optimization typically reduces file size by 30-70% with no visual quality loss, improving page load speed and Core Web Vitals." },
  { question: "What does the optimizer remove?", answer: "The optimizer removes XML declarations, HTML comments, metadata elements (title, desc), editor-specific data (Inkscape/Illustrator namespaces), empty attributes, default attribute values (like fill-opacity='1'), and collapses unnecessary whitespace. It also shortens color values (#ffffff → #fff)." },
  { question: "Will optimization affect my SVG's appearance?", answer: "No. All optimizations are semantics-preserving — they remove data that doesn't affect visual rendering. However, if your SVG relies on metadata (like accessible titles for screen readers), you may want to disable the 'Remove metadata' option." },
  { question: "Why not use SVGO?", answer: "SVGO is the gold-standard CLI tool for SVG optimization and supports more advanced transforms like path merging and precision reduction. This browser-based tool covers the most common optimizations without requiring Node.js. For maximum compression on production assets, use SVGO CLI in your build pipeline." },
];
---

<BaseLayout
  title="SVG Optimizer / Minifier — Reduce SVG File Size Online"
  description="Optimize and minify SVG files in your browser. Removes comments, metadata, editor data, and whitespace. Typically reduces SVG size by 30-70%. Free, 100% client-side."
  tool="SVG Optimizer, SVG Minifier, SVG Compressor, Optimize SVG Online"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">SVG Optimizer / Minifier</h1>
  <p class="text-text-muted mb-4">Paste your SVG and get a clean, optimized version in seconds. Removes bloat from Inkscape, Illustrator, and Figma exports — comments, metadata, editor namespaces, redundant attributes. Preview the result before copying. <span class="text-xs text-text-muted">100% in-browser, no upload.</span></p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Your SVG never leaves the browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live preview</span>
  </div>
  <SvgOptimizer client:load />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SVG Optimizer" relatedTags={['svg', 'frontend', 'performance', 'design', 'css']} />
</BaseLayout>
