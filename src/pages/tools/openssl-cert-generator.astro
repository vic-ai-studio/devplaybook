---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="OpenSSL Cert Generator — Build OpenSSL Commands Visually"
  description="Generate OpenSSL commands for creating self-signed certs, CSRs, CA certificates, and converting certificate formats. Visual GUI for openssl req, x509, pkcs12, and more. Free online tool."
  tool="OpenSSL Command Generator, SSL Certificate Generator, Self-Signed Cert, CSR Generator, OpenSSL GUI, TLS Certificate Tool, PKCS12 Converter"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "OpenSSL Cert Generator",
    "url": "https://devplaybook.cc/tools/openssl-cert-generator",
    "description": "Visual builder for OpenSSL commands — generate self-signed certs, CSRs, CA certs, and conversions.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">OpenSSL Cert Generator</h1>
  <p class="text-text-muted mb-8">
    Build <code class="font-mono bg-surface px-1 rounded">openssl</code> commands visually — no memorizing flags.
    Generate self-signed certificates, CSRs, CA certs, and format conversions.
    Copy the ready-to-run commands for your terminal.
  </p>

  <!-- Operation tabs -->
  <div class="flex gap-2 flex-wrap mb-6" id="op-tabs">
    {['Self-Signed Cert', 'CSR (Certificate Request)', 'CA Certificate', 'Sign Cert with CA', 'Format Conversion', 'Inspect Certificate'].map((tab, i) => (
      <button data-tab={i}
        class={`px-3 py-1.5 rounded-lg text-sm font-medium transition-colors ${i === 0 ? 'bg-primary text-white' : 'bg-bg-card border border-border text-text-muted hover:text-foreground'}`}>
        {tab}
      </button>
    ))}
  </div>

  <!-- Tab panels -->
  <div id="panels">

    <!-- 0: Self-Signed Cert -->
    <div data-panel="0" class="space-y-5">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold mb-4 text-sm uppercase tracking-wide text-text-muted">Certificate Details</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="ss-cn">Common Name (CN) / Domain</label>
            <input id="ss-cn" type="text" value="example.com" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          </div>
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="ss-days">Validity (days)</label>
            <input id="ss-days" type="number" value="365" min="1" max="3650" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          </div>
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="ss-bits">Key Size (bits)</label>
            <select id="ss-bits" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40">
              <option value="2048">2048 (recommended)</option>
              <option value="4096">4096 (high security)</option>
              <option value="521">521 (EC P-521)</option>
            </select>
          </div>
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="ss-keytype">Key Type</label>
            <select id="ss-keytype" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40">
              <option value="rsa">RSA</option>
              <option value="ec">EC (Elliptic Curve)</option>
            </select>
          </div>
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="ss-org">Organization (O)</label>
            <input id="ss-org" type="text" placeholder="My Company" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          </div>
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="ss-country">Country (C) — 2-letter code</label>
            <input id="ss-country" type="text" value="US" maxlength="2" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          </div>
          <div class="sm:col-span-2">
            <label class="text-xs text-text-muted mb-1 block" for="ss-san">Subject Alternative Names (SANs)</label>
            <input id="ss-san" type="text" placeholder="DNS:example.com,DNS:www.example.com,IP:127.0.0.1"
              class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
            <p class="text-xs text-text-muted mt-1">Comma-separated. Format: <code class="font-mono">DNS:domain</code>, <code class="font-mono">IP:address</code></p>
          </div>
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="ss-keyfile">Key filename</label>
            <input id="ss-keyfile" type="text" value="server.key" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          </div>
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="ss-certfile">Cert filename</label>
            <input id="ss-certfile" type="text" value="server.crt" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          </div>
        </div>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-5" id="ss-output-panel">
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Commands</h2>
          <button class="copy-btn text-xs bg-primary text-white px-3 py-1.5 rounded-lg hover:bg-primary/80 transition-colors" data-target="ss-output">Copy</button>
        </div>
        <pre id="ss-output" class="bg-bg border border-border rounded-lg p-4 text-sm font-mono whitespace-pre-wrap text-green-400 min-h-[80px]"></pre>
      </div>
    </div>

    <!-- 1: CSR -->
    <div data-panel="1" class="space-y-5 hidden">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold mb-4 text-sm uppercase tracking-wide text-text-muted">CSR Details</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="csr-cn">Common Name (CN) / Domain</label>
            <input id="csr-cn" type="text" value="example.com" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          </div>
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="csr-org">Organization (O)</label>
            <input id="csr-org" type="text" placeholder="My Company" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          </div>
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="csr-ou">Org Unit (OU)</label>
            <input id="csr-ou" type="text" placeholder="Engineering" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          </div>
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="csr-country">Country (C)</label>
            <input id="csr-country" type="text" value="US" maxlength="2" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          </div>
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="csr-keyfile">Key filename</label>
            <input id="csr-keyfile" type="text" value="server.key" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          </div>
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="csr-csrfile">CSR filename</label>
            <input id="csr-csrfile" type="text" value="server.csr" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          </div>
        </div>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Commands</h2>
          <button class="copy-btn text-xs bg-primary text-white px-3 py-1.5 rounded-lg hover:bg-primary/80 transition-colors" data-target="csr-output">Copy</button>
        </div>
        <pre id="csr-output" class="bg-bg border border-border rounded-lg p-4 text-sm font-mono whitespace-pre-wrap text-green-400 min-h-[80px]"></pre>
      </div>
    </div>

    <!-- 2: CA Cert -->
    <div data-panel="2" class="space-y-5 hidden">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold mb-4 text-sm uppercase tracking-wide text-text-muted">CA Certificate Details</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="ca-cn">CA Common Name</label>
            <input id="ca-cn" type="text" value="My Local CA" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          </div>
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="ca-days">Validity (days)</label>
            <input id="ca-days" type="number" value="3650" min="1" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          </div>
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="ca-keyfile">CA Key filename</label>
            <input id="ca-keyfile" type="text" value="ca.key" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          </div>
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="ca-certfile">CA Cert filename</label>
            <input id="ca-certfile" type="text" value="ca.crt" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          </div>
        </div>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Commands</h2>
          <button class="copy-btn text-xs bg-primary text-white px-3 py-1.5 rounded-lg hover:bg-primary/80 transition-colors" data-target="ca-output">Copy</button>
        </div>
        <pre id="ca-output" class="bg-bg border border-border rounded-lg p-4 text-sm font-mono whitespace-pre-wrap text-green-400 min-h-[80px]"></pre>
      </div>
    </div>

    <!-- 3: Sign Cert with CA -->
    <div data-panel="3" class="space-y-5 hidden">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold mb-4 text-sm uppercase tracking-wide text-text-muted">Sign CSR with CA</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="sign-csr">CSR filename</label>
            <input id="sign-csr" type="text" value="server.csr" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          </div>
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="sign-cakey">CA Key filename</label>
            <input id="sign-cakey" type="text" value="ca.key" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          </div>
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="sign-cacert">CA Cert filename</label>
            <input id="sign-cacert" type="text" value="ca.crt" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          </div>
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="sign-days">Validity (days)</label>
            <input id="sign-days" type="number" value="365" min="1" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          </div>
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="sign-out">Output Cert filename</label>
            <input id="sign-out" type="text" value="server.crt" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          </div>
        </div>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Commands</h2>
          <button class="copy-btn text-xs bg-primary text-white px-3 py-1.5 rounded-lg hover:bg-primary/80 transition-colors" data-target="sign-output">Copy</button>
        </div>
        <pre id="sign-output" class="bg-bg border border-border rounded-lg p-4 text-sm font-mono whitespace-pre-wrap text-green-400 min-h-[80px]"></pre>
      </div>
    </div>

    <!-- 4: Format Conversion -->
    <div data-panel="4" class="space-y-5 hidden">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold mb-4 text-sm uppercase tracking-wide text-text-muted">Format Conversion</h2>
        <div class="mb-4">
          <label class="text-xs text-text-muted mb-1 block" for="conv-type">Conversion Type</label>
          <select id="conv-type" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40">
            <option value="pem-to-pkcs12">PEM → PKCS#12 (.pfx/.p12)</option>
            <option value="pkcs12-to-pem">PKCS#12 (.pfx/.p12) → PEM</option>
            <option value="der-to-pem">DER → PEM</option>
            <option value="pem-to-der">PEM → DER</option>
            <option value="crt-to-p7b">CRT → PKCS#7 (.p7b)</option>
          </select>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4" id="conv-fields"></div>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Command</h2>
          <button class="copy-btn text-xs bg-primary text-white px-3 py-1.5 rounded-lg hover:bg-primary/80 transition-colors" data-target="conv-output">Copy</button>
        </div>
        <pre id="conv-output" class="bg-bg border border-border rounded-lg p-4 text-sm font-mono whitespace-pre-wrap text-green-400 min-h-[80px]"></pre>
      </div>
    </div>

    <!-- 5: Inspect -->
    <div data-panel="5" class="space-y-5 hidden">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold mb-4 text-sm uppercase tracking-wide text-text-muted">Inspect Certificate / CSR / Key</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="insp-file">File to inspect</label>
            <input id="insp-file" type="text" value="server.crt" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          </div>
          <div>
            <label class="text-xs text-text-muted mb-1 block" for="insp-type">File type</label>
            <select id="insp-type" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40">
              <option value="x509">Certificate (.crt/.pem)</option>
              <option value="req">CSR (.csr)</option>
              <option value="rsa">RSA Private Key (.key)</option>
              <option value="pkcs12">PKCS#12 (.pfx/.p12)</option>
            </select>
          </div>
        </div>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Commands</h2>
          <button class="copy-btn text-xs bg-primary text-white px-3 py-1.5 rounded-lg hover:bg-primary/80 transition-colors" data-target="insp-output">Copy</button>
        </div>
        <pre id="insp-output" class="bg-bg border border-border rounded-lg p-4 text-sm font-mono whitespace-pre-wrap text-green-400 min-h-[80px]"></pre>
      </div>
    </div>

  </div>

  <div class="mt-4 p-4 bg-bg-card border border-border rounded-xl text-xs text-text-muted">
    <strong>Install OpenSSL:</strong>
    <code class="font-mono bg-bg px-1 rounded">brew install openssl</code> (macOS) ·
    <code class="font-mono bg-bg px-1 rounded">apt install openssl</code> (Ubuntu) ·
    Already included on most Linux distros and macOS.
    Windows: use <a href="https://slproweb.com/products/Win32OpenSSL.html" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">Win32 OpenSSL</a> or WSL.
  </div>

  <ToolPageCta currentTool="OpenSSL Cert Generator" relatedTags={['security', 'ssl', 'tls', 'devops', 'cli', 'certificates']} />
</BaseLayout>

<script is:inline>
(function () {
  function el(id) { return document.getElementById(id); }
  function val(id) { return (el(id) || {}).value || ''; }

  // Tab switching
  const tabs = document.querySelectorAll('#op-tabs button');
  const panels = document.querySelectorAll('#panels > div');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const t = parseInt(tab.dataset.tab);
      tabs.forEach((b, i) => {
        b.className = i === t
          ? 'px-3 py-1.5 rounded-lg text-sm font-medium transition-colors bg-primary text-white'
          : 'px-3 py-1.5 rounded-lg text-sm font-medium transition-colors bg-bg-card border border-border text-text-muted hover:text-foreground';
      });
      panels.forEach((p, i) => { p.classList.toggle('hidden', i !== t); });
      buildAll();
    });
  });

  // Copy buttons
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = el(btn.dataset.target);
      if (!target) return;
      navigator.clipboard.writeText(target.textContent).then(() => {
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
      });
    });
  });

  // --- BUILDERS ---

  function buildSubject(cn, org, country) {
    const parts = [];
    if (country) parts.push(`C=${country.toUpperCase()}`);
    if (org) parts.push(`O=${org}`);
    if (cn) parts.push(`CN=${cn}`);
    return parts.length ? '/'+parts.join('/') : '/CN=example.com';
  }

  function buildSelfSigned() {
    const cn = val('ss-cn') || 'example.com';
    const days = val('ss-days') || '365';
    const bits = val('ss-bits') || '2048';
    const keytype = val('ss-keytype') || 'rsa';
    const org = val('ss-org');
    const country = val('ss-country');
    const san = val('ss-san');
    const keyfile = val('ss-keyfile') || 'server.key';
    const certfile = val('ss-certfile') || 'server.crt';
    const subj = buildSubject(cn, org, country);
    const lines = [];

    if (keytype === 'rsa') {
      if (san) {
        lines.push(`# Step 1: Generate RSA private key`);
        lines.push(`openssl genrsa -out ${keyfile} ${bits}`);
        lines.push(``);
        lines.push(`# Step 2: Create self-signed cert with SANs`);
        lines.push(`openssl req -new -x509 \\`);
        lines.push(`  -key ${keyfile} \\`);
        lines.push(`  -out ${certfile} \\`);
        lines.push(`  -days ${days} \\`);
        lines.push(`  -subj "${subj}" \\`);
        lines.push(`  -addext "subjectAltName=${san}"`);
      } else {
        lines.push(`# Generate RSA key + self-signed cert (single command)`);
        lines.push(`openssl req -x509 -newkey rsa:${bits} \\`);
        lines.push(`  -keyout ${keyfile} \\`);
        lines.push(`  -out ${certfile} \\`);
        lines.push(`  -days ${days} \\`);
        lines.push(`  -nodes \\`);
        lines.push(`  -subj "${subj}"`);
      }
    } else {
      // EC
      lines.push(`# Step 1: Generate EC private key`);
      lines.push(`openssl ecparam -name prime256v1 -genkey -noout -out ${keyfile}`);
      lines.push(``);
      lines.push(`# Step 2: Create self-signed cert`);
      lines.push(`openssl req -new -x509 \\`);
      lines.push(`  -key ${keyfile} \\`);
      lines.push(`  -out ${certfile} \\`);
      lines.push(`  -days ${days} \\`);
      lines.push(`  -subj "${subj}"`);
      if (san) {
        lines.push(`  -addext "subjectAltName=${san}"`);
      }
    }
    el('ss-output').textContent = lines.join('\n');
  }

  function buildCSR() {
    const cn = val('csr-cn') || 'example.com';
    const org = val('csr-org');
    const ou = val('csr-ou');
    const country = val('csr-country');
    const keyfile = val('csr-keyfile') || 'server.key';
    const csrfile = val('csr-csrfile') || 'server.csr';

    const subjParts = [];
    if (country) subjParts.push(`C=${country.toUpperCase()}`);
    if (org) subjParts.push(`O=${org}`);
    if (ou) subjParts.push(`OU=${ou}`);
    subjParts.push(`CN=${cn}`);
    const subj = '/' + subjParts.join('/');

    const lines = [
      `# Step 1: Generate private key`,
      `openssl genrsa -out ${keyfile} 2048`,
      ``,
      `# Step 2: Generate CSR`,
      `openssl req -new \\`,
      `  -key ${keyfile} \\`,
      `  -out ${csrfile} \\`,
      `  -subj "${subj}"`,
      ``,
      `# Verify CSR contents`,
      `openssl req -in ${csrfile} -noout -text`,
    ];
    el('csr-output').textContent = lines.join('\n');
  }

  function buildCA() {
    const cn = val('ca-cn') || 'My Local CA';
    const days = val('ca-days') || '3650';
    const keyfile = val('ca-keyfile') || 'ca.key';
    const certfile = val('ca-certfile') || 'ca.crt';
    const lines = [
      `# Step 1: Generate CA private key (4096-bit for security)`,
      `openssl genrsa -out ${keyfile} 4096`,
      ``,
      `# Step 2: Create self-signed CA certificate`,
      `openssl req -new -x509 \\`,
      `  -key ${keyfile} \\`,
      `  -out ${certfile} \\`,
      `  -days ${days} \\`,
      `  -subj "/CN=${cn}" \\`,
      `  -extensions v3_ca`,
      ``,
      `# Verify CA cert`,
      `openssl x509 -in ${certfile} -noout -text | grep -E "Subject:|Issuer:|Not (Before|After)"`,
    ];
    el('ca-output').textContent = lines.join('\n');
  }

  function buildSign() {
    const csr = val('sign-csr') || 'server.csr';
    const cakey = val('sign-cakey') || 'ca.key';
    const cacert = val('sign-cacert') || 'ca.crt';
    const days = val('sign-days') || '365';
    const out = val('sign-out') || 'server.crt';
    const lines = [
      `# Sign the CSR with your CA`,
      `openssl x509 -req \\`,
      `  -in ${csr} \\`,
      `  -CA ${cacert} \\`,
      `  -CAkey ${cakey} \\`,
      `  -CAcreateserial \\`,
      `  -out ${out} \\`,
      `  -days ${days} \\`,
      `  -sha256`,
      ``,
      `# Verify the signed certificate`,
      `openssl verify -CAfile ${cacert} ${out}`,
    ];
    el('sign-output').textContent = lines.join('\n');
  }

  function buildConversion() {
    const type = val('conv-type');
    const fields = el('conv-fields');
    fields.innerHTML = '';

    function addField(id, label, placeholder) {
      fields.innerHTML += `
        <div>
          <label class="text-xs text-text-muted mb-1 block" for="${id}">${label}</label>
          <input id="${id}" type="text" placeholder="${placeholder}" value="${placeholder}"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
        </div>`;
    }

    if (type === 'pem-to-pkcs12') {
      addField('cv-cert', 'Certificate (PEM)', 'server.crt');
      addField('cv-key', 'Private Key (PEM)', 'server.key');
      addField('cv-out', 'Output PKCS#12 file', 'server.p12');
    } else if (type === 'pkcs12-to-pem') {
      addField('cv-p12', 'PKCS#12 file (.pfx/.p12)', 'server.p12');
      addField('cv-out', 'Output PEM file', 'server.pem');
    } else if (type === 'der-to-pem') {
      addField('cv-der', 'DER file', 'server.der');
      addField('cv-out', 'Output PEM file', 'server.crt');
    } else if (type === 'pem-to-der') {
      addField('cv-pem', 'PEM file', 'server.crt');
      addField('cv-out', 'Output DER file', 'server.der');
    } else if (type === 'crt-to-p7b') {
      addField('cv-cert', 'Certificate (PEM)', 'server.crt');
      addField('cv-out', 'Output P7B file', 'server.p7b');
    }

    // Attach listeners to new fields
    fields.querySelectorAll('input').forEach(i => i.addEventListener('input', buildConversionOutput));
    buildConversionOutput();
  }

  function buildConversionOutput() {
    const type = val('conv-type');
    let cmd = '';
    if (type === 'pem-to-pkcs12') {
      const cert = (el('cv-cert') || {}).value || 'server.crt';
      const key = (el('cv-key') || {}).value || 'server.key';
      const out = (el('cv-out') || {}).value || 'server.p12';
      cmd = `openssl pkcs12 -export \\\n  -in ${cert} \\\n  -inkey ${key} \\\n  -out ${out}`;
    } else if (type === 'pkcs12-to-pem') {
      const p12 = (el('cv-p12') || {}).value || 'server.p12';
      const out = (el('cv-out') || {}).value || 'server.pem';
      cmd = `openssl pkcs12 -in ${p12} -nodes -out ${out}`;
    } else if (type === 'der-to-pem') {
      const der = (el('cv-der') || {}).value || 'server.der';
      const out = (el('cv-out') || {}).value || 'server.crt';
      cmd = `openssl x509 -in ${der} -inform DER -out ${out} -outform PEM`;
    } else if (type === 'pem-to-der') {
      const pem = (el('cv-pem') || {}).value || 'server.crt';
      const out = (el('cv-out') || {}).value || 'server.der';
      cmd = `openssl x509 -in ${pem} -inform PEM -out ${out} -outform DER`;
    } else if (type === 'crt-to-p7b') {
      const cert = (el('cv-cert') || {}).value || 'server.crt';
      const out = (el('cv-out') || {}).value || 'server.p7b';
      cmd = `openssl crl2pkcs7 -nocrl -certfile ${cert} -out ${out}`;
    }
    el('conv-output').textContent = cmd;
  }

  function buildInspect() {
    const file = val('insp-file') || 'server.crt';
    const type = val('insp-type') || 'x509';
    let lines = [];
    if (type === 'x509') {
      lines = [
        `# View full certificate details`,
        `openssl x509 -in ${file} -noout -text`,
        ``,
        `# Quick summary (subject, issuer, dates)`,
        `openssl x509 -in ${file} -noout -subject -issuer -dates`,
        ``,
        `# Verify certificate fingerprint (SHA-256)`,
        `openssl x509 -in ${file} -noout -fingerprint -sha256`,
      ];
    } else if (type === 'req') {
      lines = [
        `# View CSR details`,
        `openssl req -in ${file} -noout -text`,
        ``,
        `# View subject only`,
        `openssl req -in ${file} -noout -subject`,
      ];
    } else if (type === 'rsa') {
      lines = [
        `# View RSA key details`,
        `openssl rsa -in ${file} -noout -text`,
        ``,
        `# Check key modulus (should match cert)`,
        `openssl rsa -in ${file} -noout -modulus | md5sum`,
      ];
    } else if (type === 'pkcs12') {
      lines = [
        `# View PKCS#12 contents`,
        `openssl pkcs12 -in ${file} -noout -info`,
        ``,
        `# Extract cert and key (no encryption on output)`,
        `openssl pkcs12 -in ${file} -nodes -out extracted.pem`,
      ];
    }
    el('insp-output').textContent = lines.join('\n');
  }

  function buildAll() {
    buildSelfSigned();
    buildCSR();
    buildCA();
    buildSign();
    buildConversion();
    buildInspect();
  }

  // Wire events for all panels
  ['ss-cn','ss-days','ss-bits','ss-keytype','ss-org','ss-country','ss-san','ss-keyfile','ss-certfile'].forEach(id => {
    const e = el(id); if (e) e.addEventListener('input', buildSelfSigned);
    if (e && e.tagName === 'SELECT') e.addEventListener('change', buildSelfSigned);
  });
  ['csr-cn','csr-org','csr-ou','csr-country','csr-keyfile','csr-csrfile'].forEach(id => {
    const e = el(id); if (e) e.addEventListener('input', buildCSR);
  });
  ['ca-cn','ca-days','ca-keyfile','ca-certfile'].forEach(id => {
    const e = el(id); if (e) e.addEventListener('input', buildCA);
  });
  ['sign-csr','sign-cakey','sign-cacert','sign-days','sign-out'].forEach(id => {
    const e = el(id); if (e) e.addEventListener('input', buildSign);
  });
  el('conv-type').addEventListener('change', buildConversion);
  ['insp-file','insp-type'].forEach(id => {
    const e = el(id); if (e) e.addEventListener('input', buildInspect);
    if (e && e.tagName === 'SELECT') e.addEventListener('change', buildInspect);
  });

  buildAll();
})();
</script>
