---

<BaseLayout
  title="npm Package Comparator — Compare npm Packages Side by Side"
  description="Compare 2-3 npm packages side by side. See weekly downloads, GitHub stars, version, last publish date, bundle size, and license. Make informed package decisions. Free browser tool."
  tool="npm compare, npm package comparison, npm vs, compare npm packages, npm package stats, npm downloads comparison"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "npm Package Comparator",
    "url": "https://devplaybook.cc/tools/npm-package-comparator",
    "description": "Compare npm packages side by side. See downloads, stars, bundle size, and license to make informed package decisions.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">npm Package Comparator</h1>
  <p class="text-text-muted mb-4">
    Compare 2-3 npm packages side by side — weekly downloads, GitHub stars, bundle size, license, and more.
    Make informed decisions when choosing between competing libraries.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Compare up to 3 packages</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Downloads, stars, size, license</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Popular package database</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> npmjs.com links</span>
  </div>

  <!-- Package inputs -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <div class="flex flex-col sm:flex-row gap-2 mb-3">
      <input id="pkg1" type="text" placeholder="Package 1 (e.g. axios)" class="flex-1 bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
      <input id="pkg2" type="text" placeholder="Package 2 (e.g. ky)" class="flex-1 bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
      <input id="pkg3" type="text" placeholder="Package 3 (optional)" class="flex-1 bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
      <button id="compare-btn" class="px-4 py-2 bg-primary text-white rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors shrink-0">Compare</button>
    </div>
    <div class="flex flex-wrap gap-2">
      <span class="text-xs text-text-muted self-center">Quick compare:</span>
      {[
        {a:'axios',b:'ky',c:'got',label:'HTTP clients'},
        {a:'moment',b:'dayjs',c:'date-fns',label:'Date libs'},
        {a:'jest',b:'vitest',c:'',label:'Test runners'},
        {a:'zod',b:'yup',c:'joi',label:'Validation'},
        {a:'react',b:'vue',c:'svelte',label:'UI frameworks'},
        {a:'lodash',b:'ramda',c:'',label:'Utility libs'},
        {a:'redux',b:'zustand',c:'jotai',label:'State mgmt'},
        {a:'vite',b:'webpack',c:'esbuild',label:'Bundlers'},
      ].map(p => (
        <button class="quick-compare px-2.5 py-1 bg-surface border border-border rounded text-xs hover:border-primary transition-colors text-text-muted" data-a={p.a} data-b={p.b} data-c={p.c}>{p.label}</button>
      ))}
    </div>
  </div>

  <!-- Results -->
  <div id="results" class="hidden mb-4"></div>

  <!-- Not-found message -->
  <div id="not-found" class="hidden bg-yellow-400/10 border border-yellow-400/30 rounded-lg p-3 mb-4 text-sm text-yellow-300"></div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="npm Package Comparator" relatedTags={['npm', 'javascript', 'packages', 'comparison', 'developer-tools']} />
</BaseLayout>

