    'mongoose': { downloads: 2200000, stars: 26500, version: '8.3.0', lastPublish: '2024-03-25', license: 'MIT', types: 'bundled', size: 'N/A (ORM)' },
    'redux': { downloads: 8200000, stars: 60500, version: '5.0.1', lastPublish: '2024-01-03', license: 'MIT', types: 'bundled', size: '13KB' },
    'zustand': { downloads: 5300000, stars: 42000, version: '4.5.2', lastPublish: '2024-03-05', license: 'MIT', types: 'bundled', size: '2KB' },
    'mobx': { downloads: 2800000, stars: 27200, version: '6.12.3', lastPublish: '2024-02-26', license: 'MIT', types: 'bundled', size: '25KB' },
    'jotai': { downloads: 1900000, stars: 18000, version: '2.8.0', lastPublish: '2024-03-27', license: 'MIT', types: 'bundled', size: '3KB' },
  };

  function formatNum(n) {
    if (n >= 1000000) return (n/1000000).toFixed(1) + 'M';
    if (n >= 1000) return (n/1000).toFixed(0) + 'K';
    return n.toString();
  }

  function downloadBar(n, max) {
    const pct = Math.max(3, (n/max)*100);
    return `<div class="flex items-center gap-2 mt-1"><div class="flex-1 bg-surface rounded-full h-1.5"><div class="bg-primary h-1.5 rounded-full" style="width:${pct}%"></div></div></div>`;
  }

  function starsBar(n, max) {
    const pct = Math.max(3, (n/max)*100);
    return `<div class="flex items-center gap-2 mt-1"><div class="flex-1 bg-surface rounded-full h-1.5"><div class="bg-yellow-400 h-1.5 rounded-full" style="width:${pct}%"></div></div></div>`;
  }

  function compare(pkgs) {
    const results = document.getElementById('results');
    const notFound = document.getElementById('not-found');
    const found = pkgs.map(p => ({ name: p, data: DB[p.toLowerCase()] }));
    const missing = found.filter(f => !f.data).map(f => f.name);

    if (missing.length > 0) {
      notFound.textContent = `Package(s) not in local database: ${missing.join(', ')}. Try a known package from the quick compare buttons.`;
      notFound.classList.remove('hidden');
    } else {
      notFound.classList.add('hidden');
    }

    const valid = found.filter(f => f.data);
    if (valid.length < 2) { results.classList.add('hidden'); return; }
    results.classList.remove('hidden');

    const maxDl = Math.max(...valid.map(v => v.data.downloads));
    const maxSt = Math.max(...valid.map(v => v.data.stars));

    const colClass = valid.length === 2 ? 'grid-cols-2' : 'grid-cols-3';
    const rows = [
      { label: 'Weekly Downloads', key: 'downloads', render: (d) => `<span class="font-medium">${formatNum(d.downloads)}/wk</span>${downloadBar(d.downloads, maxDl)}` },
      { label: 'GitHub Stars', key: 'stars', render: (d) => `<span class="font-medium">⭐ ${formatNum(d.stars)}</span>${starsBar(d.stars, maxSt)}` },
      { label: 'Version', key: 'version', render: (d) => `<span class="font-mono text-xs">${d.version}</span>` },
      { label: 'Last Publish', key: 'lastPublish', render: (d) => `<span class="text-xs">${d.lastPublish}</span>` },
      { label: 'TypeScript', key: 'types', render: (d) => `<span class="text-xs ${d.types === 'bundled' ? 'text-green-500' : 'text-yellow-400'}">${d.types}</span>` },
      { label: 'Bundle Size', key: 'size', render: (d) => `<span class="text-xs font-mono">${d.size}</span>` },
      { label: 'License', key: 'license', render: (d) => `<span class="text-xs">${d.license}</span>` },
    ];

    let html = `<div class="bg-bg-card border border-border rounded-lg overflow-hidden">`;

    // Header row
    html += `<div class="grid ${colClass} border-b border-border">`;
    valid.forEach(v => {
      html += `<div class="p-4 border-r border-border last:border-r-0">
        <a href="https://www.npmjs.com/package/${v.name}" target="_blank" rel="noopener" class="font-mono font-bold text-accent hover:underline">${v.name}</a>
        <a href="https://npmjs.com/package/${v.name}" target="_blank" rel="noopener" class="block text-xs text-text-muted hover:text-accent mt-0.5">npmjs.com →</a>
      </div>`;
    });
    html += '</div>';

    // Data rows
    rows.forEach(row => {
      html += `<div class="grid ${colClass} border-b border-border last:border-b-0">`;
      valid.forEach(v => {
        html += `<div class="p-3 border-r border-border last:border-r-0">
          <div class="text-xs text-text-muted mb-1">${row.label}</div>
          ${row.render(v.data)}
        </div>`;
      });
      html += '</div>';
    });

    html += '</div>';

    // Winner row
    const maxDownloads = valid.reduce((a, b) => a.data.downloads > b.data.downloads ? a : b);
    html += `<div class="mt-3 bg-green-500/10 border border-green-500/30 rounded-lg p-3 text-sm">
      <span class="text-green-500 font-medium">Most downloaded:</span>
      <span class="font-mono ml-2">${maxDownloads.name}</span>
      <span class="text-text-muted ml-1">(${formatNum(maxDownloads.data.downloads)}/week)</span>
    </div>`;

    results.innerHTML = html;
  }

  document.getElementById('compare-btn').addEventListener('click', () => {
    const pkgs = [
      document.getElementById('pkg1').value.trim(),
      document.getElementById('pkg2').value.trim(),
      document.getElementById('pkg3').value.trim(),
    ].filter(Boolean);
    if (pkgs.length < 2) {
      document.getElementById('not-found').textContent = 'Enter at least 2 package names to compare.';
      document.getElementById('not-found').classList.remove('hidden');
      return;
    }
    compare(pkgs);
  });

  document.querySelectorAll('.quick-compare').forEach(btn => {
    btn.addEventListener('click', () => {
      const pkgs = [btn.dataset.a, btn.dataset.b, btn.dataset.c].filter(Boolean);
      document.getElementById('pkg1').value = pkgs[0] || '';
      document.getElementById('pkg2').value = pkgs[1] || '';
      document.getElementById('pkg3').value = pkgs[2] || '';
      compare(pkgs);
    });
  });

  ['pkg1','pkg2','pkg3'].forEach(id => {
    document.getElementById(id).addEventListener('keydown', e => {
      if (e.key === 'Enter') document.getElementById('compare-btn').click();
    });
  });

  // Default comparison on load
  compare(['axios', 'ky', 'got']);
})();
</script>
