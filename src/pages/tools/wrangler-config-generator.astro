---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WranglerConfigGenerator from '../../components/WranglerConfigGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is wrangler.toml?",
    answer: "wrangler.toml is the configuration file for Cloudflare Workers and Pages projects. It tells Wrangler (Cloudflare's CLI) how to build, deploy, and configure your worker — including its name, entry point, bindings (KV, D1, R2, Durable Objects), environment variables, and routing rules."
  },
  {
    question: "What's the difference between Workers and Pages in Wrangler?",
    answer: "Cloudflare Workers are serverless scripts that run at the edge. Cloudflare Pages is a full-stack platform for deploying frontend apps with optional Functions (which are also Workers under the hood). For Pages, you set pages_build_output_dir instead of main. For Workers, you point main to your TypeScript/JavaScript entry file."
  },
  {
    question: "What is the compatibility_date?",
    answer: "The compatibility_date field controls which version of Cloudflare's runtime APIs your Worker uses. Cloudflare introduces breaking changes on new dates — setting this date pins your Worker to a specific runtime behavior. Always use a recent date for new projects. Changing it later may require code updates, so test after bumping."
  },
  {
    question: "When should I use node_compat = true?",
    answer: "Enable node_compat when your Worker imports Node.js built-in modules like path, crypto, buffer, or stream. Cloudflare polyfills many Node.js APIs in its runtime. Without this flag, imports like import { createHash } from 'crypto' will fail. Note: not all Node.js APIs are supported — check Cloudflare's compatibility matrix."
  },
  {
    question: "How do I get my KV namespace ID or D1 database ID?",
    answer: "Run `wrangler kv:namespace create MY_NAMESPACE` to create a KV namespace and get its ID. For D1, run `wrangler d1 create my-database`. Both commands output the IDs you need. For production, you need a separate namespace ID; for local dev, Wrangler uses a local SQLite/in-memory store unless you provide a preview_id."
  },
];
---

<BaseLayout
  title="Wrangler Config Generator — Generate wrangler.toml for Cloudflare Workers"
  description="Generate a complete wrangler.toml configuration for Cloudflare Workers and Pages. Add KV namespaces, D1 databases, R2 buckets, environment variables, and routing rules. Download instantly."
  tool="Wrangler config generator, wrangler.toml generator, Cloudflare Workers config, Cloudflare Pages config, KV namespace config, D1 database config"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Wrangler Config Generator",
    "url": "https://devplaybook.cc/tools/wrangler-config-generator",
    "description": "Generate wrangler.toml configuration files for Cloudflare Workers and Pages projects.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Wrangler Config Generator</h1>
  <p class="text-text-muted mb-4">
    Generate a complete <code class="font-mono text-sm bg-bg-card px-1 rounded">wrangler.toml</code> for Cloudflare Workers or Pages. Configure KV namespaces, D1 databases, R2 buckets, environment variables, and routes — then download or copy the config.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Workers, Pages & Durable Objects</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> KV / D1 / R2 bindings</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Download-ready wrangler.toml</span>
  </div>
  <WranglerConfigGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Wrangler Config Generator" relatedTags={['cloudflare', 'workers', 'devops', 'edge-computing', 'developer-tools']} />
</BaseLayout>
