---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JestConfigGenerator from '../../components/JestConfigGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is jest.config.ts and when do I need it?",
    answer: "jest.config.ts is the TypeScript version of Jest's configuration file. You need it whenever you want to customize how Jest finds and runs your tests — changing the test environment, adding coverage, mapping path aliases, or configuring transforms. If you're using TypeScript in your project, jest.config.ts gives you full type safety on your Jest configuration via the Config type from 'jest'."
  },
  {
    question: "Should I use ts-jest or babel-jest for TypeScript projects?",
    answer: "ts-jest is the recommended choice for TypeScript projects. It runs TypeScript files directly using the TypeScript compiler, giving you real type-checking in tests. babel-jest is faster because it strips types without checking them (using @babel/preset-typescript), but it won't catch type errors in your test files. For new TypeScript projects, use ts-jest unless build speed is a bottleneck."
  },
  {
    question: "What test environment should I choose for React?",
    answer: "Use jsdom for React component tests — it simulates a browser DOM inside Node.js and is required by @testing-library/react. For React testing with Next.js, the framework configures this automatically. Use the node environment only for pure utility functions, API handlers, or non-DOM code. happy-dom is a faster alternative to jsdom but has less complete browser compatibility."
  },
  {
    question: "What is moduleNameMapper used for?",
    answer: "moduleNameMapper serves two purposes: (1) mapping path aliases like '@/' to their real directories so Jest can resolve imports the same way TypeScript does; (2) mocking non-JS imports like CSS files and images that Jest cannot parse. If your project uses tsconfig.json paths (e.g. '@/*': ['./src/*']), you must mirror those in moduleNameMapper, or use the ts-jest pathsToModuleNameMapper utility."
  },
  {
    question: "How do I integrate Jest coverage with CI/CD?",
    answer: "Add --coverage to your test command (jest --coverage) in CI. Use --coverageReporters=lcov,text-summary to get both machine-readable (lcov) and human-readable output. Set coverageThreshold in jest.config.ts to fail the build when coverage drops below your minimums — this enforces coverage as a quality gate. Upload the lcov.info file to Codecov or Coveralls for PR coverage annotations."
  },
  {
    question: "How do I test ESM (ES module) packages in Jest?",
    answer: "Jest uses CommonJS by default and cannot import ESM packages directly. The fix is to add transformIgnorePatterns to tell Jest to transform specific node_modules: transformIgnorePatterns: ['/node_modules/(?!(your-esm-package)/)'] . For packages like chalk v5, nanoid v3+, or any pure ESM library, add them to the exception list. Alternatively, pin to the last CJS version of the package (e.g. chalk@4)."
  },
];
---

<BaseLayout
  title="Jest Config Generator — Generate jest.config.ts Visually"
  description="Generate a complete jest.config.ts or jest.config.js visually. Configure test environment, TypeScript preset, coverage thresholds, path aliases, and module mapping. Copy ready-to-use Jest configuration. Free, runs in your browser."
  tool="Jest Config Generator, jest.config.ts, Jest Setup, Jest Coverage, ts-jest, Jest Testing"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Jest Config Generator",
    "url": "https://devplaybook.cc/tools/jest-config-generator",
    "description": "Generate a complete jest.config.ts visually. Configure test environment (node/jsdom/happy-dom), TypeScript preset, coverage provider, thresholds, and path aliases.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Jest Config Generator</h1>
  <p class="text-text-muted mb-4">
    Generate a production-ready <code class="text-accent font-mono">jest.config.ts</code> visually.
    Choose your framework, TypeScript preset, test environment, and coverage thresholds — get a
    copy-paste config with the correct install command.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> React / Vue / Node / Next.js</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> ts-jest + TypeScript support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Coverage thresholds</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Path alias mapper</span>
  </div>
  <JestConfigGenerator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Jest Config Generator" relatedTags={['testing', 'jest', 'javascript', 'typescript', 'developer-tools']} />
</BaseLayout>
