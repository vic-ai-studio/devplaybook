---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NpmPackageSizeChecker from '../../components/NpmPackageSizeChecker.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "Why does bundle size matter?", answer: "Every kilobyte your users download slows page load times, especially on mobile and slow networks. Smaller bundles mean faster Time to Interactive (TTI), better Core Web Vitals scores, and improved SEO rankings. A single large package can double your app's bundle size." },
  { question: "What is the difference between minified and gzipped size?", answer: "Minified size is the package after whitespace and comments are removed. Gzipped size is what's actually transferred over the network — modern servers compress responses with gzip or brotli. Gzipped size is the number that matters most for performance." },
  { question: "How can I reduce my npm package size?", answer: "Use tree-shakeable packages (look for ES module exports), import only what you need (e.g., 'import get from lodash/get' vs 'import _ from lodash'), choose lighter alternatives (dayjs vs moment), use dynamic imports for code splitting, and audit with tools like bundlephobia before adding new dependencies." },
  { question: "Can I check a specific version of a package?", answer: "Yes! Enter the package name with the version, e.g. 'axios@0.21.0' or 'react@17.0.2'. This lets you compare bundle sizes between versions to see if upgrading will affect your bundle." },
];
---

<BaseLayout
  title="npm Package Size Checker — Bundle Size Before You Install"
  description="Check the bundle size of any npm package before installing it. See minified + gzipped size, dependency count, and download time estimates. Powered by Bundlephobia. Free."
  tool="npm Package Size, Bundle Size Checker, Bundlephobia, npm Bundle Analyzer"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">npm Package Size Checker</h1>
  <p class="text-text-muted mb-4">Check how much any npm package adds to your bundle — before you install it. See minified size, gzipped size, dependency count, and download time estimates across network speeds. <span class="text-xs text-text-muted">Powered by Bundlephobia.</span></p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Supports specific versions (e.g. axios@0.21.0)</span>
  </div>
  <NpmPackageSizeChecker client:load />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="npm Package Size Checker" relatedTags={['javascript', 'nodejs', 'performance', 'frontend', 'webpack']} />
</BaseLayout>
