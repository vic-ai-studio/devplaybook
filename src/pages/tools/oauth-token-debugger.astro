---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OAuthTokenDebugger from '../../components/OAuthTokenDebugger.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is an OAuth 2.0 access token?",
    answer: "An OAuth 2.0 access token is a credential issued by an authorization server that grants a client access to specific resources on behalf of a user. Modern OAuth implementations typically use JWT (JSON Web Token) as the token format — a compact, self-contained structure with header, payload, and signature. The payload contains claims like user ID (sub), expiry (exp), issuer (iss), and granted scopes.",
  },
  {
    question: "Is it safe to paste my token into this tool?",
    answer: "Yes — this debugger runs entirely in your browser using JavaScript. Your token is never sent to any server or third party. However, as a best practice, avoid pasting real production tokens that grant access to sensitive systems. Rotate tokens after debugging sessions if in doubt.",
  },
  {
    question: "What are OAuth 2.0 scopes?",
    answer: "Scopes are space-separated strings in the scope claim that define what the token is authorized to do. Standard OIDC scopes include openid (establishes identity layer), profile (name, picture), and email. Application-specific scopes follow formats like read:users or write:orders. The token holder can only perform actions covered by the granted scopes.",
  },
  {
    question: "What is the difference between an access token and an ID token?",
    answer: "An access token is used to authorize API calls — it proves the bearer is allowed to perform certain actions. An ID token (OIDC) is used to authenticate — it proves who the user is and contains identity claims (name, email, picture). ID tokens contain the at_hash claim and are typically shorter-lived. Access tokens are sent with API requests; ID tokens are consumed by the client to establish a user session.",
  },
  {
    question: "Why can't I verify the signature here?",
    answer: "JWT signature verification requires either your HMAC secret key (for HS256) or the issuer's public key (for RS256/ES256). These keys should never be exposed in a browser. This tool decodes the header and payload (which are just base64url-encoded) but cannot cryptographically verify the signature without the key. For production verification, use your backend with a library like jsonwebtoken (Node.js) or python-jose (Python).",
  },
  {
    question: "What does 'exp' mean and why is token expiry important?",
    answer: "exp (expiration time) is a Unix timestamp (seconds since January 1, 1970). Any token with an exp value in the past is considered expired and should be rejected by resource servers. Access tokens are typically short-lived (minutes to hours) to limit damage if stolen. Always check token expiry before using it in API calls to avoid 401 Unauthorized errors.",
  },
];
---

<BaseLayout
  title="OAuth 2.0 Token Debugger — Decode JWT, Scopes & Claims"
  description="Free OAuth 2.0 token debugger. Paste any JWT or OAuth access token to decode header, payload, and claims — inspect scopes, expiry, issuer, and token type. Runs 100% in your browser, nothing sent to any server."
  tool="OAuth token debugger, JWT decoder, OAuth 2.0 token inspector, decode JWT online, JWT claims viewer, OIDC token debugger, OAuth scope checker, JWT expiry checker"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "OAuth 2.0 Token Debugger",
    "url": "https://devplaybook.cc/tools/oauth-token-debugger",
    "description": "Decode and inspect OAuth 2.0 and JWT tokens in your browser. View all claims, check expiry status, inspect granted scopes, and identify token type — no data sent to any server.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">OAuth 2.0 Token Debugger</h1>
  <p class="text-text-muted mb-4">
    Decode any OAuth 2.0 access token, OIDC ID token, or JWT. Inspect all claims with descriptions, check expiry status, view granted scopes, and detect token type — entirely client-side.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Highlights expired tokens</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Scope breakdown with descriptions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Detects OIDC vs OAuth token type</span>
  </div>
  <OAuthTokenDebugger client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="OAuth 2.0 Token Debugger" relatedTags={['auth', 'jwt', 'oauth', 'security', 'api', 'tokens']} />
</BaseLayout>
