---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What SQL types are supported?", answer: "This tool handles the most common SQL column types: VARCHAR, TEXT, CHAR, and NVARCHAR map to string; INT, INTEGER, BIGINT, SMALLINT, TINYINT, SERIAL, BIGSERIAL, and NUMERIC/DECIMAL map to number; BOOLEAN and BOOL map to boolean; TIMESTAMP, DATETIME, DATE, and TIME map to Date in the TypeScript interface; JSON and JSONB map to unknown. Any unrecognized type also maps to unknown." },
  { question: "How does NOT NULL affect the TypeScript output?", answer: "Columns with NOT NULL constraint become required fields in the TypeScript interface (no ? optional modifier). Columns that allow NULL (no NOT NULL, or explicitly NULL) become optional fields with the type unioned with null, e.g. name?: string | null. This mirrors how database queries return nullable columns." },
  { question: "What is the Zod schema used for?", answer: "Zod is a TypeScript-first schema validation library. The generated z.object({...}) schema lets you validate API inputs, database query results, or form data at runtime. For example, you can use it in tRPC inputs, Next.js API routes, or Fastify request validation. The generated Zod schema mirrors the TypeScript interface — required fields use the base type and optional fields use .nullable().optional()." },
  { question: "Can I paste multiple CREATE TABLE statements?", answer: "Yes. The parser handles multiple CREATE TABLE statements in one paste. Each table generates its own TypeScript interface and Zod schema block. The output blocks are separated by blank lines. Table names are converted to PascalCase for the interface name and camelCase for the Zod variable name." },
];
---

<BaseLayout
  title="SQL to TypeScript Types — Convert CREATE TABLE to TypeScript Interface + Zod"
  description="Paste a SQL CREATE TABLE statement and get a TypeScript interface and Zod schema instantly. Supports VARCHAR, INT, BOOLEAN, TIMESTAMP, JSON types with NOT NULL and DEFAULT handling."
  tool="SQL to TypeScript, CREATE TABLE to TypeScript interface, SQL Zod schema generator, SQL type converter, TypeScript database types"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "SQL to TypeScript Types Converter",
    "url": "https://devplaybook.cc/tools/sql-to-typescript-types",
    "description": "Convert SQL CREATE TABLE statements to TypeScript interfaces and Zod schemas. Handles common SQL types, NOT NULL, and DEFAULT values.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">SQL to TypeScript Types</h1>
  <p class="text-text-muted mb-4">
    Paste a SQL <code class="font-mono text-primary">CREATE TABLE</code> statement and instantly get a TypeScript interface and Zod validation schema.
    Handles common SQL types, <code class="font-mono text-primary">NOT NULL</code> constraints, and <code class="font-mono text-primary">DEFAULT</code> values.
    Supports PostgreSQL, MySQL, and SQLite dialects. Runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-8 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript interface output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Zod z.object schema output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> NOT NULL → required vs optional</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multiple tables at once</span>
  </div>

  <!-- Input / Output -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
    <!-- Input -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <label class="font-semibold text-sm" for="sql-input">SQL Input</label>
        <button id="sql-example" class="text-xs text-primary hover:underline">Load example</button>
      </div>
      <textarea id="sql-input" rows="18"
        placeholder="CREATE TABLE users (&#10;  id SERIAL PRIMARY KEY,&#10;  email VARCHAR(255) NOT NULL,&#10;  name TEXT,&#10;  created_at TIMESTAMP NOT NULL DEFAULT NOW()&#10;);"
        class="w-full bg-bg border border-border rounded-lg px-3 py-3 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40 resize-y"></textarea>
    </div>
    <!-- Output -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <span class="font-semibold text-sm">TypeScript + Zod Output</span>
        <button id="sql-copy" class="text-xs text-primary hover:underline hidden">Copy</button>
      </div>
      <div id="sql-error" class="hidden mb-3 p-3 bg-red-500/10 border border-red-500/20 rounded-lg text-sm text-red-400"></div>
      <textarea id="ts-output" rows="18" readonly
        placeholder="TypeScript interface and Zod schema will appear here..."
        class="w-full bg-bg border border-border rounded-lg px-3 py-3 text-sm font-mono resize-y text-text-muted focus:outline-none"></textarea>
    </div>
  </div>

  <div class="flex gap-3 mb-8">
    <button id="sql-convert" class="bg-primary text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-primary/80 transition-colors">
      Convert to TypeScript
    </button>
    <button id="sql-clear" class="text-sm text-text-muted hover:text-red-400 transition-colors">Clear</button>
  </div>

  <!-- Type mapping table -->
  <div class="bg-bg-card border border-border rounded-xl p-6 mb-8">
    <h2 class="font-bold text-sm uppercase tracking-wide text-text-muted mb-4">SQL → TypeScript Type Mapping</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border">
            <th class="text-left py-2 pr-4 text-text-muted font-medium">SQL Type</th>
            <th class="text-left py-2 pr-4 text-text-muted font-medium">TypeScript</th>
            <th class="text-left py-2 text-text-muted font-medium">Zod</th>
          </tr>
        </thead>
        <tbody class="font-mono text-xs text-text-muted">
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-sans text-text">VARCHAR, TEXT, CHAR</td><td class="pr-4">string</td><td>z.string()</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-sans text-text">INT, INTEGER, BIGINT, SERIAL</td><td class="pr-4">number</td><td>z.number()</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-sans text-text">BOOLEAN, BOOL</td><td class="pr-4">boolean</td><td>z.boolean()</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-sans text-text">TIMESTAMP, DATE, DATETIME</td><td class="pr-4">Date</td><td>z.string().datetime()</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-sans text-text">JSON, JSONB</td><td class="pr-4">unknown</td><td>z.unknown()</td></tr>
          <tr><td class="py-2 pr-4 font-sans text-text">Other / Unknown</td><td class="pr-4">unknown</td><td>z.unknown()</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <AffiliateSection />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SQL to TypeScript Types" relatedTags={['sql', 'typescript', 'zod', 'database', 'schema', 'postgresql']} />
</BaseLayout>

<script is:inline>
(function () {
  var EXAMPLE = [
    'CREATE TABLE users (',
    '  id SERIAL PRIMARY KEY,',
    '  email VARCHAR(255) NOT NULL,',
    '  username VARCHAR(100) NOT NULL UNIQUE,',
    '  full_name TEXT,',
    '  is_active BOOLEAN NOT NULL DEFAULT true,',
    '  created_at TIMESTAMP NOT NULL DEFAULT NOW(),',
    '  updated_at TIMESTAMP,',
    '  metadata JSONB',
    ');',
    '',
    'CREATE TABLE posts (',
    '  id BIGINT PRIMARY KEY,',
    '  user_id INTEGER NOT NULL,',
    '  title VARCHAR(500) NOT NULL,',
    '  body TEXT,',
    '  published_at TIMESTAMP,',
    '  view_count INTEGER NOT NULL DEFAULT 0',
    ');',
  ].join('\n');

  function sqlTypeToTs(sqlType) {
    var t = sqlType.toUpperCase().replace(/\(.*\)/, '').trim();
    if (/^(VARCHAR|TEXT|CHAR|NVARCHAR|NTEXT|CLOB|TINYTEXT|MEDIUMTEXT|LONGTEXT)$/.test(t)) return 'string';
    if (/^(INT|INTEGER|BIGINT|SMALLINT|TINYINT|MEDIUMINT|SERIAL|BIGSERIAL|SMALLSERIAL|NUMERIC|DECIMAL|FLOAT|DOUBLE|REAL|MONEY)$/.test(t)) return 'number';
    if (/^(BOOLEAN|BOOL|BIT)$/.test(t)) return 'boolean';
    if (/^(TIMESTAMP|DATETIME|DATE|TIME|TIMESTAMPTZ)$/.test(t)) return 'Date';
    if (/^(JSON|JSONB)$/.test(t)) return 'unknown';
    if (/^(UUID)$/.test(t)) return 'string';
    return 'unknown';
  }

  function sqlTypeToZod(sqlType) {
    var t = sqlType.toUpperCase().replace(/\(.*\)/, '').trim();
    if (/^(VARCHAR|TEXT|CHAR|NVARCHAR|NTEXT|CLOB|TINYTEXT|MEDIUMTEXT|LONGTEXT|UUID)$/.test(t)) return 'z.string()';
    if (/^(INT|INTEGER|BIGINT|SMALLINT|TINYINT|MEDIUMINT|SERIAL|BIGSERIAL|SMALLSERIAL|NUMERIC|DECIMAL|FLOAT|DOUBLE|REAL|MONEY)$/.test(t)) return 'z.number()';
    if (/^(BOOLEAN|BOOL|BIT)$/.test(t)) return 'z.boolean()';
    if (/^(TIMESTAMP|DATETIME|DATE|TIME|TIMESTAMPTZ)$/.test(t)) return 'z.string().datetime()';
    if (/^(JSON|JSONB)$/.test(t)) return 'z.unknown()';
    return 'z.unknown()';
  }

  function toPascalCase(str) {
    return str.replace(/_([a-z])/g, function (_, c) { return c.toUpperCase(); })
              .replace(/^([a-z])/, function (_, c) { return c.toUpperCase(); });
  }

  function toCamelCase(str) {
    return str.replace(/_([a-z])/g, function (_, c) { return c.toUpperCase(); });
  }

  function parseCreateTable(sql) {
    // Extract all CREATE TABLE blocks
    var tableRe = /CREATE\s+TABLE\s+(?:IF\s+NOT\s+EXISTS\s+)?["'`]?(\w+)["'`]?\s*\(([^;]+)\)/gi;
    var results = [];
    var match;
    while ((match = tableRe.exec(sql)) !== null) {
      var tableName = match[1];
      var body = match[2];

      // Split into column lines (skip constraints like PRIMARY KEY (...), UNIQUE (...), etc.)
      var lines = body.split('\n').map(function (l) { return l.trim(); }).filter(function (l) {
        return l && !/^(PRIMARY\s+KEY|UNIQUE|CONSTRAINT|INDEX|KEY|CHECK|FOREIGN\s+KEY)/i.test(l);
      });

      var columns = [];
      lines.forEach(function (line) {
        // Remove trailing comma
        line = line.replace(/,\s*$/, '').trim();
        if (!line) return;
        // Parse: colname TYPE [constraints...]
        var parts = line.match(/^["'`]?(\w+)["'`]?\s+(\S+(?:\s*\([^)]*\))?)(.*)?$/i);
        if (!parts) return;
        var colName = parts[1];
        var colType = parts[2];
        var rest = (parts[3] || '').toUpperCase();
        var notNull = /NOT\s+NULL/.test(rest) || /PRIMARY\s+KEY/.test(rest) || /SERIAL/.test(colType.toUpperCase());
        columns.push({ name: colName, type: colType, notNull: notNull });
      });

      if (columns.length) results.push({ tableName: tableName, columns: columns });
    }
    return results;
  }

  function generateOutput(tables) {
    var blocks = [];
    blocks.push("import { z } from 'zod';");
    blocks.push('');

    tables.forEach(function (table) {
      var interfaceName = toPascalCase(table.tableName);
      var zodName = toCamelCase(table.tableName) + 'Schema';

      // TypeScript interface
      var tsLines = ['export interface ' + interfaceName + ' {'];
      table.columns.forEach(function (col) {
        var tsType = sqlTypeToTs(col.type);
        if (col.notNull) {
          tsLines.push('  ' + col.name + ': ' + tsType + ';');
        } else {
          tsLines.push('  ' + col.name + '?: ' + tsType + ' | null;');
        }
      });
      tsLines.push('}');

      // Zod schema
      var zodLines = ['export const ' + zodName + ' = z.object({'];
      table.columns.forEach(function (col) {
        var zodType = sqlTypeToZod(col.type);
        if (col.notNull) {
          zodLines.push('  ' + col.name + ': ' + zodType + ',');
        } else {
          zodLines.push('  ' + col.name + ': ' + zodType + '.nullable().optional(),');
        }
      });
      zodLines.push('});');
      zodLines.push('');
      zodLines.push('export type ' + interfaceName + 'Zod = z.infer<typeof ' + zodName + '>;');

      blocks.push(tsLines.join('\n'));
      blocks.push('');
      blocks.push(zodLines.join('\n'));
      blocks.push('');
    });

    return blocks.join('\n').trim();
  }

  document.getElementById('sql-example').addEventListener('click', function () {
    document.getElementById('sql-input').value = EXAMPLE;
  });

  document.getElementById('sql-clear').addEventListener('click', function () {
    document.getElementById('sql-input').value = '';
    document.getElementById('ts-output').value = '';
    document.getElementById('sql-error').classList.add('hidden');
    document.getElementById('sql-copy').classList.add('hidden');
  });

  document.getElementById('sql-convert').addEventListener('click', function () {
    var raw = document.getElementById('sql-input').value.trim();
    var errEl = document.getElementById('sql-error');
    var outEl = document.getElementById('ts-output');
    var copyBtn = document.getElementById('sql-copy');
    errEl.classList.add('hidden');
    outEl.value = '';
    copyBtn.classList.add('hidden');

    if (!raw) {
      errEl.textContent = 'Please paste a SQL CREATE TABLE statement first.';
      errEl.classList.remove('hidden');
      return;
    }

    try {
      var tables = parseCreateTable(raw);
      if (!tables.length) {
        errEl.textContent = 'No valid CREATE TABLE statement found. Make sure the SQL is well-formed.';
        errEl.classList.remove('hidden');
        return;
      }
      outEl.value = generateOutput(tables);
      copyBtn.classList.remove('hidden');
    } catch (e) {
      errEl.textContent = 'Parse error: ' + (e.message || String(e));
      errEl.classList.remove('hidden');
    }
  });

  document.getElementById('sql-copy').addEventListener('click', function () {
    var val = document.getElementById('ts-output').value;
    if (val) navigator.clipboard && navigator.clipboard.writeText(val);
    this.textContent = 'Copied!';
    var btn = this;
    setTimeout(function () { btn.textContent = 'Copy'; }, 2000);
  });
})();
</script>
