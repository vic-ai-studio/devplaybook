---
import BaseLayout from '../../layouts/BaseLayout.astro';
import VaultPolicyGenerator from '../../components/VaultPolicyGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What are HashiCorp Vault policies?",
    answer: "Vault policies are HCL (or JSON) documents that describe what paths in Vault a token can access and what capabilities it has. Policies follow the principle of least privilege — tokens get no permissions by default. Policies are attached to tokens via auth method roles. For example, a Kubernetes service account mapped to a Vault role can only access the secrets your policy allows."
  },
  {
    question: "What do the different capabilities mean?",
    answer: "create — POST/write new data. read — GET data. update — PUT/PATCH existing data. delete — DELETE data. list — enumerate keys at a path (does not read values). sudo — access root-protected paths (rare, use sparingly). deny — explicitly deny access, overriding any allows. For read-only access, use [read, list]. For full access, use [create, read, update, delete, list]."
  },
  {
    question: "How do Vault path wildcards work?",
    answer: "Vault paths support two wildcards: * matches any sequence of characters within a single path segment (e.g. secret/data/myapp/* matches secret/data/myapp/db-password but not secret/data/myapp/db/password). The + glob matches exactly one path segment. Prefix matching with a trailing * is the most common pattern — e.g. secret/data/prod/* grants access to all secrets under the prod namespace."
  },
  {
    question: "What is the 'deny' capability used for?",
    answer: "deny overrides all other capabilities, including those from other policies attached to the same token. It's used to explicitly block access to sensitive sub-paths when a parent wildcard would otherwise grant access. For example, you might grant secret/data/* with [read] but then add secret/data/admin/* with [deny] to carve out admin secrets."
  },
  {
    question: "How do I apply a Vault policy?",
    answer: "Save the HCL to a file (e.g. policy.hcl), then run: vault policy write my-policy policy.hcl. To attach it to a role (e.g. Kubernetes auth): vault write auth/kubernetes/role/my-role bound_service_account_names=my-sa bound_service_account_namespaces=default policies=my-policy. To attach to AppRole: vault write auth/approle/role/my-role policies=my-policy."
  },
  {
    question: "Does this tool send my policy to a server?",
    answer: "No. All HCL generation runs entirely in your browser using JavaScript. Your policy configuration never leaves your machine."
  },
];
---

<BaseLayout
  title="Vault Policy Generator — Generate HashiCorp Vault HCL Policies Online"
  description="Generate HashiCorp Vault HCL policy files from a visual rule builder. Configure paths, capabilities (create/read/update/delete/list/sudo/deny), and presets for common use cases. Free, runs in browser."
  tool="Vault policy generator, HashiCorp Vault HCL policy, Vault ACL policy builder, Vault capabilities generator, Vault policy editor"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Vault Policy Generator",
    "url": "https://devplaybook.cc/tools/vault-policy-generator",
    "description": "Generate HashiCorp Vault HCL policy files visually. Configure paths and capabilities with presets for read-only access, app service accounts, PKI, and database credentials.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Vault Policy Generator</h1>
  <p class="text-text-muted mb-4">
    Build <a href="https://developer.hashicorp.com/vault/docs/concepts/policies" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">HashiCorp Vault</a> HCL policy files visually.
    Add path rules, toggle capabilities, and use presets for common patterns like read-only secrets, app service accounts, PKI cert issuers, and database credentials.
    Runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 4 built-in presets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All 7 capabilities</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> HCL output with CLI command</span>
  </div>
  <VaultPolicyGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Vault Policy Generator" relatedTags={['vault', 'security', 'infrastructure', 'devops', 'secrets', 'hashicorp']} />
</BaseLayout>
