---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="AI Doc Generator — Pro Tool | DevPlaybook"
  description="Auto-generate JSDoc, Markdown README, OpenAPI specs, or inline comments from your code using AI. Supports JavaScript, TypeScript, Python, and Go projects."
  tool="AI Documentation Generator, JSDoc Generator, README Generator, OpenAPI Generator"
>
  <!-- Pro Gate loading -->
  <div id="pro-loading" class="max-w-2xl mx-auto py-16 text-center text-text-muted">
    Checking your account...
  </div>

  <!-- Not Pro: Upgrade Gate -->
  <div id="pro-gate" class="hidden max-w-2xl mx-auto py-16 px-4 text-center">
    <div class="text-6xl mb-6">📝</div>
    <h1 class="text-3xl font-bold mb-3">AI Doc Generator is a <span class="text-primary">Pro</span> feature</h1>
    <p class="text-text-muted text-lg mb-8">
      Stop writing docs by hand. Paste your code and get JSDoc, README, OpenAPI specs, or inline comments instantly.
    </p>
    <div class="bg-bg-card border border-border rounded-2xl p-8 mb-8 text-left">
      <h2 class="font-semibold mb-4">Pro includes:</h2>
      <ul class="space-y-2 text-text-muted text-sm">
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> AI Doc Generator (this tool)</li>
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> AI Code Review</li>
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> AI SQL Builder</li>
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> All premium templates & future tools</li>
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> 7-day free trial, cancel anytime</li>
      </ul>
    </div>
    <a href="/pricing" class="inline-block bg-primary hover:bg-primary-dark text-white font-bold px-10 py-4 rounded-xl transition-colors text-lg">
      Start Free Trial — $9/mo
    </a>
    <p class="text-text-muted text-sm mt-4">
      Already subscribed? <a href="/signin" class="text-primary hover:underline">Sign in</a>
    </p>
  </div>

  <!-- Pro Tool UI -->
  <div id="pro-tool" class="hidden">
    <div class="flex items-center gap-3 mb-2">
      <h1 class="text-3xl font-bold">AI Doc Generator</h1>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-primary/20 text-primary border border-primary/30">PRO</span>
    </div>
    <p class="text-text-muted mb-8">Paste code to auto-generate JSDoc comments, Markdown README, OpenAPI spec, or inline code comments.</p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Input -->
      <div class="flex flex-col gap-4">
        <div>
          <label class="block text-sm font-medium mb-2">Documentation Format</label>
          <div class="grid grid-cols-2 gap-2 mb-4">
            {[
              { value: 'markdown', label: '📄 Markdown README', desc: 'Full README with API reference' },
              { value: 'jsdoc', label: '/** JSDoc */', desc: 'JSDoc comment blocks' },
              { value: 'openapi', label: '🔗 OpenAPI YAML', desc: 'OpenAPI 3.0 specification' },
              { value: 'inline', label: '// Inline', desc: 'Comments inside the code' },
            ].map(opt => (
              <label class="cursor-pointer">
                <input type="radio" name="doc-format" value={opt.value} class="sr-only peer" checked={opt.value === 'markdown'} />
                <div class="p-3 rounded-xl border border-border peer-checked:border-primary peer-checked:bg-primary/10 transition-colors">
                  <div class="text-sm font-medium">{opt.label}</div>
                  <div class="text-xs text-text-muted mt-0.5">{opt.desc}</div>
                </div>
              </label>
            ))}
          </div>
          <label class="block text-sm font-medium mb-2" for="doc-code-input">Code</label>
          <textarea
            id="doc-code-input"
            rows="16"
            placeholder="Paste your code here..."
            class="w-full px-4 py-3 rounded-xl bg-bg border border-border text-text placeholder:text-text-muted focus:outline-none focus:border-primary transition-colors font-mono text-sm resize-y"
          ></textarea>
        </div>
        <button
          id="generate-btn"
          class="w-full py-3 px-6 rounded-xl bg-primary hover:bg-primary-dark text-white font-bold transition-colors duration-200 disabled:opacity-50"
        >
          Generate Documentation
        </button>
        <p id="generate-error" class="text-xs text-red-400 hidden"></p>
      </div>

      <!-- Output -->
      <div class="flex flex-col gap-4">
        <div class="flex items-center justify-between">
          <label class="block text-sm font-medium">Generated Docs</label>
          <button id="copy-docs-btn" class="text-xs text-text-muted hover:text-primary transition-colors hidden">Copy</button>
        </div>
        <div id="docs-placeholder" class="flex-1 min-h-[460px] rounded-xl bg-bg border border-border flex items-center justify-center text-text-muted text-sm">
          Generated documentation will appear here
        </div>
        <div id="docs-loading" class="hidden flex-1 min-h-[460px] rounded-xl bg-bg border border-border flex items-center justify-center text-text-muted text-sm">
          <div class="text-center">
            <div class="animate-pulse text-3xl mb-3">📝</div>
            <p>Generating documentation...</p>
          </div>
        </div>
        <textarea
          id="docs-output"
          class="hidden flex-1 min-h-[460px] rounded-xl bg-bg border border-border p-4 text-sm font-mono resize-y focus:outline-none focus:border-primary transition-colors"
          readonly
        ></textarea>
      </div>
    </div>

    <div class="mt-8 p-4 bg-bg-card border border-border rounded-xl text-xs text-text-muted">
      <strong>Pro tip:</strong> For OpenAPI generation, include your route handler code with request/response shapes. For JSDoc, include the full function with parameter names.
    </div>
  </div>

  <ToolPageCta currentTool="AI Doc Generator" relatedTags={['ai', 'documentation', 'development']} />
</BaseLayout>

<script is:inline>
  async function init() {
    let session;
    try {
      const res = await fetch('/api/auth/session');
      session = await res.json();
    } catch {
      session = { loggedIn: false };
    }

    document.getElementById('pro-loading').classList.add('hidden');

    if (!session.loggedIn || !session.isPro) {
      document.getElementById('pro-gate').classList.remove('hidden');
      return;
    }

    document.getElementById('pro-tool').classList.remove('hidden');

    const btn = document.getElementById('generate-btn');
    const codeInput = document.getElementById('doc-code-input');
    const errorMsg = document.getElementById('generate-error');
    const placeholder = document.getElementById('docs-placeholder');
    const loading = document.getElementById('docs-loading');
    const output = document.getElementById('docs-output');
    const copyBtn = document.getElementById('copy-docs-btn');

    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(output.value).then(() => {
        copyBtn.textContent = 'Copied!';
        setTimeout(() => { copyBtn.textContent = 'Copy'; }, 2000);
      });
    });

    btn.addEventListener('click', async () => {
      const code = codeInput.value.trim();
      const format = document.querySelector('input[name="doc-format"]:checked')?.value || 'markdown';

      if (!code) { errorMsg.textContent = 'Please paste some code first.'; errorMsg.classList.remove('hidden'); return; }
      errorMsg.classList.add('hidden');

      btn.disabled = true;
      btn.textContent = 'Generating...';
      placeholder.classList.add('hidden');
      output.classList.add('hidden');
      loading.classList.remove('hidden');

      try {
        const res = await fetch('/api/ai/doc-generator', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code, format }),
        });
        const data = await res.json();

        if (!res.ok) {
          if (res.status === 403) {
            errorMsg.textContent = 'Pro subscription required. Refresh to check your status.';
          } else if (res.status === 401) {
            errorMsg.textContent = 'Session expired — please sign in again.';
          } else {
            errorMsg.textContent = data.error || 'Something went wrong.';
          }
          errorMsg.classList.remove('hidden');
          loading.classList.add('hidden');
          placeholder.classList.remove('hidden');
        } else {
          output.value = data.docs;
          loading.classList.add('hidden');
          output.classList.remove('hidden');
          copyBtn.classList.remove('hidden');
        }
      } catch {
        errorMsg.textContent = 'Network error — please try again.';
        errorMsg.classList.remove('hidden');
        loading.classList.add('hidden');
        placeholder.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Generate Documentation';
      }
    });
  }

  init();
</script>
