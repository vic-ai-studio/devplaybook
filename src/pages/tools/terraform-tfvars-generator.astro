---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TerraformTfvarsGenerator from '../../components/TerraformTfvarsGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a terraform.tfvars file?",
    answer: "A .tfvars file provides actual values for variables declared in your Terraform modules. Instead of hardcoding values in variable declarations or passing them on the command line, you put them in terraform.tfvars (auto-loaded) or a named file like prod.tfvars (loaded with -var-file). This separates configuration from code."
  },
  {
    question: "What's the difference between terraform.tfvars and variables.tf?",
    answer: "variables.tf declares the variable schema — name, type, description, and optional defaults. terraform.tfvars provides the actual values for those variables. Keep variables.tf in source control; use .tfvars for environment-specific values (add prod.tfvars to .gitignore to avoid committing secrets)."
  },
  {
    question: "How do I handle sensitive variables like passwords?",
    answer: "Mark the variable as sensitive = true in variables.tf. Then set the value via the TF_VAR_name environment variable (e.g. export TF_VAR_db_password=secret) instead of putting it in a .tfvars file. For team use, store secrets in HashiCorp Vault, AWS Secrets Manager, or your CI/CD secrets store."
  },
  {
    question: "How do I use different .tfvars for different environments?",
    answer: "Create separate files: staging.tfvars, prod.tfvars. Apply with: terraform apply -var-file=prod.tfvars. Or use Terraform Workspaces combined with a lookup pattern. Avoid sharing the same state file between environments — use separate state backends (S3 buckets, Terraform Cloud workspaces) per environment."
  },
  {
    question: "What Terraform variable types are supported?",
    answer: "string (quoted text), number (integer or float), bool (true/false), list(string) (ordered collection), map(string) (key-value pairs), object (structured type with named attributes). For complex types, you can also use set(string), list(object({...})), and optional() attributes in Terraform 1.3+."
  },
  {
    question: "Should I commit .tfvars files to git?",
    answer: "It depends. Non-sensitive .tfvars (region, instance_type, feature flags) are fine to commit and useful for documentation. Sensitive .tfvars with passwords, API keys, or certificates should NOT be committed — add *.tfvars to .gitignore or use a .tfvars.example with placeholder values and document how to fill them in."
  },
];
---

<BaseLayout
  title="Terraform tfvars Generator — Generate terraform.tfvars & variables.tf Online"
  description="Free Terraform tfvars generator. Add variable names, types, descriptions, and defaults to generate terraform.tfvars and variables.tf files instantly. Supports string, number, bool, list, map types."
  tool="Terraform tfvars generator, terraform variables generator, terraform.tfvars maker, variables.tf generator, Terraform HCL generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Terraform tfvars Generator",
    "url": "https://devplaybook.cc/tools/terraform-tfvars-generator",
    "description": "Generate terraform.tfvars and variables.tf files from variable definitions. Supports string, number, bool, list, map types. Free, runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Terraform tfvars Generator</h1>
  <p class="text-text-muted mb-4">
    Define your Terraform variables — name, type, description, default value — and instantly generate <code class="font-mono bg-surface px-1 rounded text-sm">terraform.tfvars</code> or <code class="font-mono bg-surface px-1 rounded text-sm">variables.tf</code>. Handles sensitive variables, all HCL types, and multi-environment patterns.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 6 variable types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Sensitive variable support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Generates tfvars + variables.tf</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <TerraformTfvarsGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Terraform tfvars Generator" relatedTags={['terraform', 'infrastructure', 'devops', 'iac', 'cloud', 'aws']} />
</BaseLayout>
