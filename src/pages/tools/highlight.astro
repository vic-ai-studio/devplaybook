---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const installExample = `# Install Highlight.io SDK
npm install @highlight-run/node @highlight-run/next
# or React
npm install highlight.run

# Python
pip install highlight-io

# Go
go get github.com/highlight/highlight/sdk/highlight-go`;

const reactSetup = `// React / Next.js setup
import { H } from 'highlight.run';
import { ErrorBoundary } from '@highlight-run/react';

H.init('<YOUR_PROJECT_ID>', {
  environment: 'production',
  version: '1.0.0',
  networkRecording: {
    enabled: true,
    recordHeadersAndBody: true,
    urlBlocklist: ['/api/auth', '/api/token'],
  },
  tracingOrigins: ['api.myapp.com'],
});

// Wrap your app
export default function App({ Component, pageProps }) {
  return (
    <ErrorBoundary>
      <Component {...pageProps} />
    </ErrorBoundary>
  );
}

// Identify users (attach session to user)
H.identify('user@email.com', {
  id: 'user-123',
  name: 'Jane Doe',
  plan: 'pro',
});

// Custom events and metrics
H.track('Checkout Completed', { total: 89.99, currency: 'USD' });
H.metrics([{ name: 'LCP', value: 1200, tags: [{ name: 'page', value: '/checkout' }] }]);`;

const nodeBackend = `// Node.js backend — errors + logs + tracing
import { H } from '@highlight-run/node';

H.init({ projectID: '<YOUR_PROJECT_ID>' });

// Express error handler
app.use(H.Handlers.errorHandler());

// Manual error capture
try {
  await processPayment(order);
} catch (error) {
  H.consumeError(error, 'user@email.com', { orderId: order.id });
  throw error;
}

// Console logs are captured automatically when SDK is initialized
// Or use H.log() for structured logs
H.log('Payment processed', 'info', { amount: 99.99, userId: 'u-123' });`;

const selfHostedExample = `# Self-hosted Highlight.io (Docker Compose)
git clone https://github.com/highlight/highlight
cd highlight/docker
docker compose up

# Access:
# - Highlight UI:   http://localhost:3000
# - Backend API:    http://localhost:8082
# - OpenTelemetry:  http://localhost:4318  (OTLP HTTP)

# Configure SDK to use self-hosted backend
H.init('<PROJECT_ID>', {
  backendUrl: 'https://highlight.internal.yourcompany.com',
  otlpEndpoint: 'https://otel.internal.yourcompany.com',
});`;

const faq = [
  { question: "What is Highlight.io?", answer: "Highlight.io is an open-source monitoring platform that combines session replay (record exactly what users did before an error), error monitoring, logging, and distributed tracing in a single tool. It is designed for full-stack observability: when a user reports a bug, you can watch their session replay, see the exact JavaScript error with stack trace, view the backend logs from that request, and jump to the distributed trace — all from one incident view. It competes with LogRocket, Sentry, and Datadog RUM." },
  { question: "What is session replay in Highlight.io?", answer: "Session replay records a pixel-perfect reproduction of what users experienced in their browser — mouse movements, clicks, scroll positions, DOM changes, network requests, and console logs. When an error occurs, Highlight links it to the session replay so you can watch the 30 seconds before the error. Session replay is privacy-preserving: you can mask sensitive fields (passwords, credit card inputs) in the SDK config, and Highlight uses DOM snapshots rather than video recording, meaning no screen capture permissions are required." },
  { question: "How does Highlight.io handle errors?", answer: "Highlight automatically captures unhandled JavaScript errors, React/Vue/Angular component errors via ErrorBoundary integration, and Node.js uncaught exceptions. Each error includes: full stack trace with source maps applied (showing original TypeScript/minified code translated back to readable source), session replay link, user identity, browser/OS info, network requests timeline, and console logs from the session. Backend errors are correlated to frontend sessions via trace context propagation." },
  { question: "What is the difference between Highlight.io and Sentry?", answer: "Both monitor errors, but Highlight adds session replay and full-stack log correlation. Sentry focuses on error tracking with excellent language/framework support and a mature alerting system. Highlight focuses on the full user journey — session replay + errors + logs + traces in one incident view. Highlight is fully open-source (Apache 2.0) and self-hostable with no telemetry sent to Highlight's servers. Sentry has an open-source version but the full product is commercial. Choose Highlight when session replay and log correlation matter; choose Sentry for the broadest framework support and alert integrations." },
  { question: "How does Highlight.io integrate with OpenTelemetry?", answer: "Highlight accepts OpenTelemetry traces via OTLP (HTTP port 4318) and correlates them with frontend sessions and error reports. The Highlight backend SDK automatically injects trace context into responses so the frontend session is linked to backend traces. You can send logs to Highlight via the OTLP logs endpoint as well. For infrastructure metrics, Highlight integrates with Prometheus — you can view Grafana-style metrics alongside your traces in the Highlight UI." },
  { question: "How do I self-host Highlight.io?", answer: "Highlight is fully self-hostable via Docker Compose. Clone the repository, run docker compose up in the docker directory, and access the UI at localhost:3000. Self-hosted Highlight requires a few services: frontend (Next.js), backend API (Go), ClickHouse (traces and logs), PostgreSQL (user/project metadata), Redis (sessions), and the OpenTelemetry collector. For production, plan for at least 4 cores and 8GB RAM for a small team, scaling up with ClickHouse based on data volume." },
];
---

<BaseLayout
  title="Highlight.io — Open-Source Full-Stack Monitoring with Session Replay"
  description="Highlight.io combines session replay, error monitoring, logging, and distributed tracing in one open-source platform. Watch what users did before an error, then follow the full-stack trace."
  tool="Highlight.io, session replay, error monitoring, full-stack observability, open-source monitoring, LogRocket alternative, Sentry alternative, distributed tracing frontend"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Highlight.io — Open-Source Full-Stack Monitoring with Session Replay",
    "url": "https://devplaybook.cc/tools/highlight",
    "description": "Highlight.io combines session replay, error monitoring, logging, and distributed tracing in a single open-source platform for full-stack observability.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Highlight.io</h1>
  <p class="text-text-muted mb-6">
    An <strong>open-source full-stack monitoring platform</strong> that combines session replay, error
    monitoring, logs, and distributed tracing in one unified view. When a user hits an error, you see
    their session replay, the JavaScript stack trace, backend logs, and the distributed trace — all
    correlated and linked together.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Session replay</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Error monitoring + stack traces</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Logs + distributed tracing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Open source + self-hostable</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Highlight.io?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Highlight.io is a Y Combinator-backed open-source project that takes a "full-stack first" approach to monitoring. The core insight: when debugging a user-reported bug, developers need to answer "what exactly happened?" — which requires both the frontend session (what did the user click?) and the backend trace (which service failed and why?). Highlight links both via trace context propagation, so a single click takes you from session replay to the failing backend span.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    Unlike Sentry (error-first) or LogRocket (session-replay-first), Highlight treats all four signals equally: session replay, errors, logs, and traces are all first-class citizens linked to the same user session. The platform is fully open-source (Apache 2.0) and self-hostable on your own infrastructure with zero data leaving your environment.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Installation</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={installExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">React / Next.js Setup</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={reactSetup}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Node.js Backend</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={nodeBackend}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Self-Hosted Setup</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={selfHostedExample}></pre>

  <ToolPageCta />
  <FaqSection faqs={faq} />
</BaseLayout>
