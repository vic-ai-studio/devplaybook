---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CountdownTimer from '../../components/CountdownTimer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Countdown Timer"
  description="Free online countdown timer. Set a duration (5 min, 30 min, custom) or count down to a specific date and time. Works offline, no signup needed."
  tool="Countdown Timer, Online Timer, Date Countdown, Event Countdown Clock"
>
  <h1 class="text-3xl font-bold mb-2">Countdown Timer</h1>
  <p class="text-text-muted mb-8">Set a countdown by duration (minutes, hours) or by a specific target date and time. Great for meetings, deadlines, release dates, and sprints. Works offline — all runs in your browser.</p>
  <CountdownTimer client:only="preact" />
  <ToolPageCta currentTool="Countdown Timer" relatedTags={['timer', 'productivity', 'time', 'planning']} />
</BaseLayout>
