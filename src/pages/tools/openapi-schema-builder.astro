---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="OpenAPI 3.0 Schema Builder — JSON Schema Snippet Generator"
  description="Build OpenAPI 3.0 schema snippets for request bodies, responses, and components. Select field types, add required/nullable options, and export as YAML or JSON."
  tool="OpenAPI schema builder, JSON Schema generator, OpenAPI 3.0, request body schema, response schema, Swagger schema"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "OpenAPI 3.0 Schema Builder",
    "url": "https://devplaybook.cc/tools/openapi-schema-builder",
    "description": "Build OpenAPI 3.0 schema snippets for request bodies, responses, and components. Select field types, add required/nullable options, and export as YAML or JSON.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">OpenAPI 3.0 Schema Builder</h1>
  <p class="text-text-muted mb-4">
    Build valid OpenAPI 3.0 schema snippets for request bodies, responses, and components.
    Add fields with types, required/nullable flags, and export as <code class="font-mono bg-surface px-1 rounded text-sm">YAML</code> or <code class="font-mono bg-surface px-1 rounded text-sm">JSON</code>.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Object field builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Required &amp; nullable flags</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> YAML &amp; JSON output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy &amp; download</span>
  </div>

  <div class="space-y-5">

    <!-- Schema Config -->
    <div class="bg-surface border border-border rounded-xl p-5 space-y-4">
      <h2 class="text-sm font-semibold text-text-muted uppercase tracking-wide">Schema Config</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1">Schema Name</label>
          <input id="schema-name" type="text" placeholder="UserResponse"
            class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1">Schema Type</label>
          <select id="schema-type"
            class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
            <option value="object" selected>object</option>
            <option value="array">array</option>
            <option value="string">string</option>
            <option value="integer">integer</option>
            <option value="number">number</option>
            <option value="boolean">boolean</option>
          </select>
        </div>
      </div>

      <!-- Non-object config -->
      <div id="scalar-config" class="hidden grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1">Format <span class="text-text-muted font-normal">(optional)</span></label>
          <input id="scalar-format" type="text" placeholder="e.g. email, uuid, date-time"
            class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1">Example</label>
          <input id="scalar-example" type="text" placeholder="e.g. user@example.com"
            class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-xs font-medium text-text-muted mb-1">Description</label>
          <input id="scalar-description" type="text" placeholder="A short description"
            class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
        </div>
      </div>
    </div>

    <!-- Object Field Builder -->
    <div id="fields-section" class="bg-surface border border-border rounded-xl p-5 space-y-4">
      <div class="flex items-center justify-between">
        <h2 class="text-sm font-semibold text-text-muted uppercase tracking-wide">Properties</h2>
        <button id="add-field-btn"
          class="px-4 py-2 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">
          + Add Field
        </button>
      </div>
      <div id="fields-container" class="space-y-2">
        <!-- rows injected by JS -->
      </div>
      <p class="text-xs text-text-muted">Each property maps to an OpenAPI schema field under <code class="bg-bg-card px-1 rounded">properties:</code>.</p>
    </div>

    <!-- Format Tabs + Actions -->
    <div class="flex flex-wrap items-center gap-3">
      <div class="flex rounded-lg border border-border overflow-hidden text-sm">
        <button id="tab-yaml" class="px-4 py-2 bg-primary text-white font-medium transition-colors">YAML</button>
        <button id="tab-json" class="px-4 py-2 bg-bg-card text-text-muted hover:bg-surface transition-colors">JSON</button>
      </div>
      <button id="generate-btn"
        class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90">
        Generate Schema
      </button>
      <button id="load-example-btn"
        class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">
        Load Example
      </button>
      <button id="reset-btn"
        class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">
        Reset
      </button>
    </div>

    <!-- Output -->
    <div id="output-section" class="hidden bg-surface border border-border rounded-xl p-5 space-y-3">
      <div class="flex items-center justify-between">
        <h2 id="output-label" class="text-sm font-semibold text-text-muted uppercase tracking-wide">Schema YAML</h2>
        <div class="flex gap-2">
          <button id="copy-btn"
            class="px-4 py-2 bg-bg-card border border-border rounded-lg text-xs hover:border-primary transition-colors">
            Copy
          </button>
          <button id="download-btn"
            class="px-4 py-2 bg-bg-card border border-border rounded-lg text-xs hover:border-primary transition-colors">
            Download
          </button>
        </div>
      </div>
      <pre id="output" class="font-mono text-sm whitespace-pre-wrap break-words overflow-x-auto max-h-[500px] overflow-y-auto bg-bg-card border border-border rounded-lg p-4 text-foreground"></pre>
    </div>

  </div>

  <ToolPageCta currentTool="OpenAPI 3.0 Schema Builder" relatedTags={['api', 'openapi', 'json', 'yaml', 'developer-tools']} />
</BaseLayout>

<script is:inline>
(function () {
  let fieldCounter = 0;
  const fields = [];
  let outputFormat = 'yaml';

  // ── Schema type toggle ────────────────────────────────────────────────────────
  const schemaTypeEl = document.getElementById('schema-type');
  const scalarConfig = document.getElementById('scalar-config');
  const fieldsSection = document.getElementById('fields-section');

  function updateTypeView() {
    const isObject = schemaTypeEl.value === 'object';
    const isArray  = schemaTypeEl.value === 'array';
    scalarConfig.classList.toggle('hidden', isObject || isArray);
    fieldsSection.classList.toggle('hidden', !isObject && !isArray);
  }

  schemaTypeEl.addEventListener('change', updateTypeView);
  updateTypeView();

  // ── Format tabs ───────────────────────────────────────────────────────────────
  document.getElementById('tab-yaml').addEventListener('click', () => {
    outputFormat = 'yaml';
    document.getElementById('tab-yaml').classList.replace('bg-bg-card', 'bg-primary');
    document.getElementById('tab-yaml').classList.replace('text-text-muted', 'text-white');
    document.getElementById('tab-json').classList.replace('bg-primary', 'bg-bg-card');
    document.getElementById('tab-json').classList.replace('text-white', 'text-text-muted');
  });
  document.getElementById('tab-json').addEventListener('click', () => {
    outputFormat = 'json';
    document.getElementById('tab-json').classList.replace('bg-bg-card', 'bg-primary');
    document.getElementById('tab-json').classList.replace('text-text-muted', 'text-white');
    document.getElementById('tab-yaml').classList.replace('bg-primary', 'bg-bg-card');
    document.getElementById('tab-yaml').classList.replace('text-white', 'text-text-muted');
  });

  // ── Field rows ────────────────────────────────────────────────────────────────
  const FIELD_TYPES = ['string','integer','number','boolean','array','object'];

  function addField(preset) {
    fieldCounter++;
    const id = fieldCounter;
    const f = preset || {
      id,
      name: '',
      type: 'string',
      format: '',
      required: false,
      nullable: false,
      description: '',
      example: '',
    };
    f.id = id;
    fields.push(f);
    renderFieldRow(f);
  }

  function renderFieldRow(f) {
    const container = document.getElementById('fields-container');
    const div = document.createElement('div');
    div.id = 'field-row-' + f.id;
    div.className = 'grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-8 gap-2 items-end p-3 bg-bg-card border border-border rounded-lg';

    const typeOptions = FIELD_TYPES.map(t =>
      `<option value="${t}" ${t === f.type ? 'selected' : ''}>${t}</option>`
    ).join('');

    div.innerHTML = `
      <div class="col-span-2 sm:col-span-1 lg:col-span-2">
        <label class="block text-xs text-text-muted mb-1">Field Name</label>
        <input data-field="name" type="text" value="${f.name}" placeholder="fieldName"
          class="w-full bg-surface border border-border rounded-lg p-2 text-xs focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Type</label>
        <select data-field="type"
          class="w-full bg-surface border border-border rounded-lg p-2 text-xs focus:outline-none focus:border-primary">
          ${typeOptions}
        </select>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Format</label>
        <input data-field="format" type="text" value="${f.format}" placeholder="email, uuid…"
          class="w-full bg-surface border border-border rounded-lg p-2 text-xs focus:outline-none focus:border-primary" />
      </div>
      <div class="col-span-2 lg:col-span-1">
        <label class="block text-xs text-text-muted mb-1">Example</label>
        <input data-field="example" type="text" value="${f.example}" placeholder="42"
          class="w-full bg-surface border border-border rounded-lg p-2 text-xs focus:outline-none focus:border-primary" />
      </div>
      <div class="col-span-2 lg:col-span-1">
        <label class="block text-xs text-text-muted mb-1">Description</label>
        <input data-field="description" type="text" value="${f.description}" placeholder="Optional"
          class="w-full bg-surface border border-border rounded-lg p-2 text-xs focus:outline-none focus:border-primary" />
      </div>
      <div class="flex items-end gap-3 pb-1">
        <label class="flex items-center gap-1 text-xs text-text-muted cursor-pointer">
          <input data-field="required" type="checkbox" class="w-3 h-3 accent-primary" ${f.required ? 'checked' : ''} />
          req
        </label>
        <label class="flex items-center gap-1 text-xs text-text-muted cursor-pointer">
          <input data-field="nullable" type="checkbox" class="w-3 h-3 accent-primary" ${f.nullable ? 'checked' : ''} />
          null
        </label>
        <button data-remove="${f.id}" class="ml-auto px-2 py-1.5 text-xs text-red-400 hover:text-red-300 border border-red-400/30 rounded-lg hover:border-red-400/60 transition-colors">✕</button>
      </div>
    `;

    div.querySelectorAll('[data-field]').forEach(el => {
      el.addEventListener('change', () => {
        const field = el.dataset.field;
        f[field] = el.type === 'checkbox' ? el.checked : el.value;
      });
      el.addEventListener('input', () => {
        if (el.type !== 'checkbox') f[el.dataset.field] = el.value;
      });
    });

    div.querySelector('[data-remove]').addEventListener('click', () => {
      const idx = fields.findIndex(x => x.id === f.id);
      if (idx !== -1) fields.splice(idx, 1);
      div.remove();
    });

    container.appendChild(div);
  }

  // ── YAML helpers ──────────────────────────────────────────────────────────────
  function yamlStr(v) {
    if (v === null || v === undefined || v === '') return null;
    const s = String(v);
    if (/[:{}\[\],&*#?|<>=!%@`'"\\n]/.test(s) || s.trim() !== s) {
      return "'" + s.replace(/'/g, "''") + "'";
    }
    return s;
  }

  function inferExampleValue(type, example) {
    if (example !== '') return example;
    return null;
  }

  // ── Build schema object ───────────────────────────────────────────────────────
  function buildSchemaObj() {
    const name = document.getElementById('schema-name').value.trim() || 'MySchema';
    const type = schemaTypeEl.value;

    const schema = { type };

    if (type === 'object') {
      const required = fields.filter(f => f.required && f.name.trim()).map(f => f.name.trim());
      if (required.length) schema.required = required;

      schema.properties = {};
      fields.forEach(f => {
        if (!f.name.trim()) return;
        const prop = { type: f.type };
        if (f.format) prop.format = f.format;
        if (f.nullable) prop.nullable = true;
        if (f.description) prop.description = f.description;
        if (f.example !== '') {
          // Try to coerce numeric/boolean examples
          if (f.type === 'integer' || f.type === 'number') {
            const num = Number(f.example);
            prop.example = isNaN(num) ? f.example : num;
          } else if (f.type === 'boolean') {
            prop.example = f.example === 'true' || f.example === true;
          } else {
            prop.example = f.example;
          }
        }
        schema.properties[f.name.trim()] = prop;
      });
    } else if (type === 'array') {
      schema.items = { type: 'string' };
    } else {
      const fmt = document.getElementById('scalar-format').value.trim();
      const ex  = document.getElementById('scalar-example').value.trim();
      const desc= document.getElementById('scalar-description').value.trim();
      if (fmt)  schema.format      = fmt;
      if (desc) schema.description = desc;
      if (ex)   schema.example     = (type === 'integer' || type === 'number') ? (Number(ex) || ex) : ex;
    }

    return { name, schema };
  }

  // ── YAML serializer (subset) ──────────────────────────────────────────────────
  function toYAML(name, schema) {
    const lines = [];
    lines.push(name + ':');

    function emitObj(obj, indent) {
      const pad = '  '.repeat(indent);
      Object.entries(obj).forEach(([k, v]) => {
        if (k === 'properties') {
          lines.push(pad + 'properties:');
          Object.entries(v).forEach(([pk, pv]) => {
            lines.push(pad + '  ' + pk + ':');
            emitObj(pv, indent + 2);
          });
        } else if (k === 'required' && Array.isArray(v)) {
          lines.push(pad + 'required:');
          v.forEach(r => lines.push(pad + '  - ' + r));
        } else if (k === 'items' && typeof v === 'object') {
          lines.push(pad + 'items:');
          emitObj(v, indent + 1);
        } else if (typeof v === 'boolean') {
          lines.push(pad + k + ': ' + v);
        } else if (typeof v === 'number') {
          lines.push(pad + k + ': ' + v);
        } else if (typeof v === 'string') {
          const ys = yamlStr(v);
          lines.push(pad + k + ': ' + ys);
        } else if (v !== null && v !== undefined) {
          lines.push(pad + k + ': ' + JSON.stringify(v));
        }
      });
    }

    emitObj(schema, 1);
    return lines.join('\n') + '\n';
  }

  function toJSONSnippet(name, schema) {
    const obj = {};
    obj[name] = schema;
    return JSON.stringify(obj, null, 2);
  }

  // ── Generate & show ───────────────────────────────────────────────────────────
  function generateAndShow() {
    const { name, schema } = buildSchemaObj();
    let out;
    if (outputFormat === 'yaml') {
      out = toYAML(name, schema);
      document.getElementById('output-label').textContent = 'Schema YAML';
    } else {
      out = toJSONSnippet(name, schema);
      document.getElementById('output-label').textContent = 'Schema JSON';
    }
    document.getElementById('output').textContent = out;
    document.getElementById('output-section').classList.remove('hidden');
    document.getElementById('output-section').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  // ── Load Example ──────────────────────────────────────────────────────────────
  function loadExample() {
    document.getElementById('schema-name').value = 'UserResponse';
    schemaTypeEl.value = 'object';
    updateTypeView();

    fields.length = 0;
    document.getElementById('fields-container').innerHTML = '';
    fieldCounter = 0;

    addField({ id: 0, name: 'id', type: 'integer', format: '', required: true, nullable: false, description: 'Unique user identifier', example: '42' });
    addField({ id: 0, name: 'email', type: 'string', format: 'email', required: true, nullable: false, description: 'User email address', example: 'user@example.com' });
    addField({ id: 0, name: 'name', type: 'string', format: '', required: false, nullable: true, description: 'Display name', example: 'John Doe' });

    generateAndShow();
  }

  // ── Reset ─────────────────────────────────────────────────────────────────────
  function resetAll() {
    document.getElementById('schema-name').value = '';
    schemaTypeEl.value = 'object';
    updateTypeView();
    document.getElementById('scalar-format').value = '';
    document.getElementById('scalar-example').value = '';
    document.getElementById('scalar-description').value = '';
    fields.length = 0;
    document.getElementById('fields-container').innerHTML = '';
    fieldCounter = 0;
    document.getElementById('output-section').classList.add('hidden');
  }

  // ── Event listeners ───────────────────────────────────────────────────────────
  document.getElementById('add-field-btn').addEventListener('click', () => addField(null));
  document.getElementById('generate-btn').addEventListener('click', generateAndShow);
  document.getElementById('load-example-btn').addEventListener('click', loadExample);
  document.getElementById('reset-btn').addEventListener('click', resetAll);

  document.getElementById('copy-btn').addEventListener('click', () => {
    const text = document.getElementById('output').textContent;
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById('copy-btn');
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
    });
  });

  document.getElementById('download-btn').addEventListener('click', () => {
    const text = document.getElementById('output').textContent;
    const isYaml = outputFormat === 'yaml';
    const blob = new Blob([text], { type: isYaml ? 'text/yaml' : 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    const name = (document.getElementById('schema-name').value.trim() || 'schema').toLowerCase().replace(/\s+/g, '-');
    a.download = name + (isYaml ? '.yaml' : '.json');
    a.click();
    URL.revokeObjectURL(url);
  });

  // ── Init: start with one empty field ─────────────────────────────────────────
  addField(null);
})();
</script>
