---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is llama.cpp?", answer: "llama.cpp is a C/C++ implementation of LLM inference that runs on virtually any hardware — from a Raspberry Pi to a data center GPU. Created by Georgi Gerganov, it introduced the GGUF model format and pioneered efficient CPU-based LLM inference. llama.cpp is the inference backbone used by Ollama, KoboldCpp, LM Studio, GPT4All, and dozens of other tools." },
  { question: "What is GGUF format?", answer: "GGUF (GGML Universal Format) is the standard quantized model format created for llama.cpp. It packs model weights, configuration, tokenizer, and metadata into a single file with a clean header format. GGUF replaced the older GGML format in 2023 and has become the dominant format for distributing quantized LLMs. Quantization levels like Q4_K_M, Q5_K_S, and Q8_0 compress model weights to 4–8 bits, reducing file size and RAM by 50–75% with minimal quality loss." },
  { question: "What do quantization levels like Q4_K_M mean?", answer: "Quantization levels have a naming convention: Q = quantization, the number = bits per weight (4 = 4-bit, 5 = 5-bit, 8 = 8-bit), K = k-quants (a smarter quantization method that quantizes different layers differently), and S/M/L = size of the quantization groups (Small/Medium/Large). Q4_K_M is 4-bit with medium-size k-quant groups — the most popular choice balancing file size (~4 GB for 7B) and quality. Q8_0 is near-lossless but twice as large." },
  { question: "How do I run llama.cpp as an OpenAI-compatible server?", answer: "Build llama.cpp and run the llama-server binary: ./llama-server -m model.gguf --port 8080 -c 8192 --host 0.0.0.0. This starts an OpenAI-compatible server at /v1/chat/completions. Use --n-gpu-layers N to offload N transformer layers to GPU. Set N to 999 to offload everything. The server also provides a built-in chat UI at http://localhost:8080." },
  { question: "What Python bindings are available for llama.cpp?", answer: "llama-cpp-python is the official Python binding for llama.cpp. Install with pip install llama-cpp-python. It wraps the C++ library and provides both a low-level ctypes API and a high-level API compatible with the OpenAI SDK. For GPU support: CMAKE_ARGS='-DGGML_CUDA=on' pip install llama-cpp-python (NVIDIA) or CMAKE_ARGS='-DGGML_METAL=on' pip install llama-cpp-python (Apple Silicon)." },
  { question: "llama.cpp vs Ollama — what's the difference?", answer: "Ollama is built on top of llama.cpp — it uses llama.cpp as its inference engine but adds a model registry, CLI, automatic model management, and a cleaner API. Use llama.cpp directly when you need maximum control: custom compile flags, specific quantization experiments, embedding models, raw performance benchmarking, or embedding into a C/C++ application. Use Ollama when you want convenience and don't need llama.cpp-specific features." },
];
---

<BaseLayout
  title="llama.cpp: Efficient Local LLM Inference on CPU &amp; GPU (2026)"
  description="llama.cpp enables efficient LLM inference on any hardware using GGUF models and quantization. Complete guide to building, running the server, Python bindings, and Metal/CUDA backends."
  tool="llama.cpp, GGUF, local inference, CPU LLM, quantization, llama-cpp-python, local AI tools, private LLM"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"llama.cpp: Efficient Local LLM Inference on CPU & GPU","url":"https://devplaybook.cc/tools/llamacpp","description":"llama.cpp is the foundational C++ LLM inference library powering most local AI tools — complete guide for 2026."})} />

  <h1 class="text-3xl font-bold mb-2">llama.cpp: Efficient Local LLM Inference on CPU &amp; GPU</h1>
  <p class="text-text-muted mb-6">llama.cpp is the engine powering most local AI tools — Ollama, KoboldCpp, LM Studio, GPT4All all run on it. Use it directly for maximum control over inference, custom quantization, embedding models, and integration into C/C++ or Python applications running on any hardware from a MacBook to a GPU cluster.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs on CPU, CUDA, Metal, Vulkan, OpenCL</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GGUF model format (all quantization levels)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> OpenAI-compatible server mode</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Python bindings (llama-cpp-python)</span>
  </div>

  <ToolPageCta />

  <!-- Building llama.cpp -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Building llama.cpp</h2>
    <p class="text-text-muted text-sm mb-4">llama.cpp is a C++ project built with CMake. Choose the right build flags for your hardware:</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># Clone the repository
git clone https://github.com/ggerganov/llama.cpp
cd llama.cpp

# CPU-only build (universal, works everywhere)
cmake -B build
cmake --build build --config Release -j$(nproc)

# NVIDIA GPU (CUDA) — requires CUDA toolkit
cmake -B build -DGGML_CUDA=ON
cmake --build build --config Release -j$(nproc)

# Apple Silicon (Metal) — best macOS performance
cmake -B build -DGGML_METAL=ON
cmake --build build --config Release

# AMD GPU (ROCm/HIP) — Linux only
cmake -B build -DGGML_HIPBLAS=ON
cmake --build build --config Release

# Vulkan — cross-platform GPU (Intel, AMD, NVIDIA)
cmake -B build -DGGML_VULKAN=ON
cmake --build build --config Release

# Binaries are in build/bin/
# Key binaries: llama-cli, llama-server, llama-embedding</code></pre>
  </div>

  <!-- GGUF quantization guide -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">GGUF Quantization: Choosing the Right Level</h2>
    <p class="text-text-muted text-sm mb-4">GGUF quantization compresses model weights to reduce file size and RAM usage. Here's a practical guide to choosing the right quantization for your hardware and quality requirements:</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># Quantization comparison for Llama 3.2 7B:
# ──────────────────────────────────────────────────────────────
# Format     Size    RAM     Quality   Speed     Recommended
# Q2_K       2.7 GB  ~5 GB   ★★☆☆☆    Fastest   Low RAM only
# Q3_K_M     3.3 GB  ~6 GB   ★★★☆☆    Fast      Constrained RAM
# Q4_0       3.8 GB  ~6 GB   ★★★☆☆    Fast      Legacy, prefer Q4_K_M
# Q4_K_M     4.1 GB  ~7 GB   ★★★★☆    Fast      ← BEST BALANCE
# Q4_K_S     3.9 GB  ~7 GB   ★★★★☆    Fast      Slightly smaller than _M
# Q5_K_M     4.8 GB  ~8 GB   ★★★★☆    Moderate  High quality
# Q5_K_S     4.7 GB  ~8 GB   ★★★★☆    Moderate  Good for coding
# Q6_K       5.5 GB  ~8 GB   ★★★★★    Moderate  Near-lossless
# Q8_0       7.7 GB  ~10 GB  ★★★★★    Moderate  Near-lossless
# F16        14.1 GB ~16 GB  ★★★★★    Slowest   Reference quality

# Quantize your own model from HuggingFace:
# Step 1: Convert to GGUF
python convert_hf_to_gguf.py /path/to/hf/model --outtype f16

# Step 2: Quantize
./build/bin/llama-quantize model-f16.gguf model-Q4_K_M.gguf Q4_K_M</code></pre>
  </div>

  <!-- Server mode -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Server Mode (OpenAI-Compatible API)</h2>
    <p class="text-text-muted text-sm mb-4">The <code class="bg-bg-card border border-border rounded px-1.5 py-0.5 text-xs font-mono">llama-server</code> binary starts an HTTP server with an OpenAI-compatible API and a built-in chat UI:</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># Start the server with GPU offloading
./build/bin/llama-server \
  --model models/llama-3.2-7b-instruct-q4_k_m.gguf \
  --port 8080 \
  --host 0.0.0.0 \
  --ctx-size 8192 \
  --n-gpu-layers 35 \    # Offload 35 layers to GPU (set 999 for all)
  --threads 8 \          # CPU threads for CPU layers
  --batch-size 512 \     # Prompt processing batch size
  --parallel 2           # Number of parallel request slots

# Chat UI: http://localhost:8080
# OpenAI API: http://localhost:8080/v1/chat/completions

# Use with Python openai SDK:
from openai import OpenAI
client = OpenAI(base_url="http://localhost:8080/v1", api_key="llamacpp")
resp = client.chat.completions.create(
    model="llama-3.2-7b",
    messages=[&#123;"role": "user", "content": "Explain PagedAttention"&#125;]
)
print(resp.choices[0].message.content)</code></pre>
  </div>

  <!-- Python bindings -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Python Bindings: llama-cpp-python</h2>
    <p class="text-text-muted text-sm mb-4">llama-cpp-python wraps the C++ library for direct use in Python scripts. It also includes a built-in OpenAI-compatible server.</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># Install (CPU)
pip install llama-cpp-python

# Install with CUDA support
CMAKE_ARGS="-DGGML_CUDA=on" pip install llama-cpp-python

# Install with Metal support (macOS)
CMAKE_ARGS="-DGGML_METAL=on" pip install llama-cpp-python

# Basic usage
from llama_cpp import Llama

llm = Llama(
    model_path="./models/llama-3.2-7b-q4_k_m.gguf",
    n_ctx=8192,          # Context window
    n_gpu_layers=35,     # GPU layers (0 = CPU only, -1 = all)
    n_threads=8,         # CPU threads
    verbose=False
)

# Chat completion
response = llm.create_chat_completion(
    messages=[
        &#123;"role": "system", "content": "You are a helpful assistant."&#125;,
        &#123;"role": "user", "content": "Write a Python decorator for timing functions"&#125;
    ],
    max_tokens=512,
    temperature=0.7
)
print(response["choices"][0]["message"]["content"])

# Start built-in OpenAI server
python -m llama_cpp.server --model model.gguf --port 8000</code></pre>
  </div>

  <!-- Comparison -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-4">llama.cpp vs Ollama</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-text-muted text-xs uppercase border-b border-border">
            <th class="text-left pb-2 pr-4">Feature</th>
            <th class="text-left pb-2 pr-4">llama.cpp (direct)</th>
            <th class="text-left pb-2">Ollama</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border text-xs">
          <tr><td class="py-2 pr-4 font-medium">Inference engine</td><td class="py-2 pr-4 text-green-500">IS the engine</td><td class="py-2 text-yellow-500">Built on llama.cpp</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Ease of use</td><td class="py-2 pr-4 text-yellow-500">Technical (build required)</td><td class="py-2 text-green-500">Very easy</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Model quantization control</td><td class="py-2 pr-4 text-green-500">Full (quantize your own)</td><td class="py-2 text-yellow-500">Use pre-built GGUF</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Embedding models</td><td class="py-2 pr-4 text-green-500">llama-embedding binary</td><td class="py-2 text-green-500">Yes (ollama pull)</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Python integration</td><td class="py-2 pr-4 text-green-500">llama-cpp-python</td><td class="py-2 text-yellow-500">Via openai SDK</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Custom compile flags</td><td class="py-2 pr-4 text-green-500">Full control</td><td class="py-2 text-red-400">Fixed build</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Best for</td><td class="py-2 pr-4">Research, custom builds, C++ apps</td><td class="py-2">Developer convenience</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="llama.cpp" relatedTags={['ai', 'llm', 'local-ai', 'gguf', 'inference', 'cpu', 'python']} />
</BaseLayout>
