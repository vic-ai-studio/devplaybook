---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SitemapGenerator from '../../components/SitemapGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a sitemap.xml?", answer: "A sitemap.xml is an XML file that lists all the pages on your website along with metadata like last modification date, change frequency, and priority. It helps search engines discover and index your content faster, especially for large sites or pages that aren't easily discoverable through internal links." },
  { question: "What is the priority field?", answer: "Priority is a value from 0.0 to 1.0 that indicates the importance of a page relative to other pages on your site. A value of 1.0 means highest priority, 0.5 is the default. Note: Google has stated it largely ignores the priority field, but Bing and other search engines may use it. It doesn't affect absolute ranking, only crawl preference within your own site." },
  { question: "What does changefreq mean?", answer: "changefreq is a hint to crawlers about how often the page is likely to change. Options are: always, hourly, daily, weekly, monthly, yearly, and never. This is advisory only — search engines are not required to follow it and may crawl more or less frequently based on their own signals. Use 'daily' for blog indexes and 'monthly' for static pages." },
  { question: "How do I submit my sitemap to Google?", answer: "Go to Google Search Console (search.google.com/search-console), add your property, then go to Sitemaps > Add a new sitemap and enter the URL of your sitemap (e.g. https://example.com/sitemap.xml). You can also add a Sitemap directive to your robots.txt file to automatically hint all crawlers." },
  { question: "How many URLs can a sitemap contain?", answer: "A single sitemap file can contain a maximum of 50,000 URLs and must be no larger than 50 MB (uncompressed). If your site exceeds these limits, use a sitemap index file that references multiple individual sitemaps. Most static site generators and CMS platforms handle this automatically." },
];
---

<BaseLayout
  title="Sitemap Generator — Free XML Sitemap Builder"
  description="Free XML sitemap generator. Add URLs with priority, change frequency, and last-modified date. Bulk import URLs, copy XML, or download your sitemap.xml. Runs entirely in your browser — no server required."
  tool="Sitemap Generator, XML Sitemap Builder, Sitemap Creator, Sitemap XML, Sitemap URL List, SEO Sitemap, Google Sitemap, sitemap.xml Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">XML Sitemap Generator</h1>
  <p class="text-text-muted mb-4">Build a valid XML sitemap for your website. Add URLs one by one or bulk import a list. Set priority, change frequency, and last-modified date for each page. Copy or download the finished sitemap.xml — everything runs in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Bulk URL import</span>
  </div>
  <SitemapGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="XML Sitemap Generator" relatedTags={['seo', 'web', 'xml', 'devops']} />
</BaseLayout>
