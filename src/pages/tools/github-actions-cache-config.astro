---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="GitHub Actions Cache Config Generator — actions/cache Builder"
  description="Generate GitHub Actions workflow steps using actions/cache for npm, yarn, pnpm, pip, Maven, Gradle, Go, and Cargo. Includes cache key strategy and restore-keys patterns."
  tool="GitHub Actions cache, actions/cache, npm cache, pip cache, workflow cache, CI cache optimization"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "GitHub Actions Cache Config Generator",
    "url": "https://devplaybook.cc/tools/github-actions-cache-config",
    "description": "Generate GitHub Actions workflow steps using actions/cache for npm, yarn, pnpm, pip, Maven, Gradle, Go modules, and Cargo with optimal cache key strategies.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">GitHub Actions Cache Config Generator</h1>
  <p class="text-text-muted mb-4">
    Generate <code class="bg-surface px-1 rounded text-sm">actions/cache@v4</code> steps for your CI workflow.
    Pick your package manager, OS, and cache scope — get production-ready YAML with optimal key strategies and restore-keys fallbacks.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 12 package managers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Optimal cache key strategy</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Full job / step / workflow output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <div class="space-y-5">

    <!-- Configuration Panel -->
    <div class="bg-surface border border-border rounded-xl p-5 space-y-5">
      <h2 class="text-sm font-semibold text-text-muted uppercase tracking-wide">Configuration</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">

        <!-- Package Manager -->
        <div>
          <label for="pkg-manager" class="block text-xs font-medium text-text-muted mb-1">Package Manager</label>
          <select id="pkg-manager" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
            <option value="npm">npm</option>
            <option value="yarn">yarn</option>
            <option value="pnpm">pnpm</option>
            <option value="pip">pip</option>
            <option value="pipenv">pipenv</option>
            <option value="poetry">poetry</option>
            <option value="maven">Maven</option>
            <option value="gradle">Gradle</option>
            <option value="go">Go modules</option>
            <option value="cargo">Cargo (Rust)</option>
            <option value="gems">Ruby gems (Bundler)</option>
            <option value="composer">Composer (PHP)</option>
          </select>
        </div>

        <!-- OS -->
        <div>
          <label for="os-target" class="block text-xs font-medium text-text-muted mb-1">Runner OS</label>
          <select id="os-target" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
            <option value="ubuntu-latest">ubuntu-latest</option>
            <option value="macos-latest">macos-latest</option>
            <option value="windows-latest">windows-latest</option>
            <option value="matrix">matrix (all)</option>
          </select>
        </div>

        <!-- Cache Scope -->
        <div>
          <label for="cache-scope" class="block text-xs font-medium text-text-muted mb-1">Cache Scope</label>
          <select id="cache-scope" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
            <option value="project">Project-level</option>
            <option value="global">Global (~/ home)</option>
            <option value="monorepo">Monorepo (root lockfile)</option>
          </select>
        </div>

        <!-- Key Prefix -->
        <div>
          <label for="key-prefix" class="block text-xs font-medium text-text-muted mb-1">Cache Key Prefix <span class="text-text-muted font-normal">(optional)</span></label>
          <input id="key-prefix" type="text" placeholder="e.g. v2"
            class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" />
        </div>

        <!-- Node version pin -->
        <div id="node-version-row">
          <label for="node-version" class="block text-xs font-medium text-text-muted mb-1">Node.js Version <span class="text-text-muted font-normal">(for setup step)</span></label>
          <select id="node-version" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
            <option value="18">18 (LTS)</option>
            <option value="20" selected>20 (LTS)</option>
            <option value="22">22</option>
          </select>
        </div>

        <!-- Python version pin -->
        <div id="python-version-row" class="hidden">
          <label for="python-version" class="block text-xs font-medium text-text-muted mb-1">Python Version <span class="text-text-muted font-normal">(for setup step)</span></label>
          <select id="python-version" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
            <option value="3.10">3.10</option>
            <option value="3.11">3.11</option>
            <option value="3.12" selected>3.12</option>
            <option value="3.13">3.13</option>
          </select>
        </div>

      </div>

      <!-- Options row -->
      <div class="flex flex-wrap gap-5">
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input id="include-cache-hit" type="checkbox" class="w-4 h-4 accent-primary" checked />
          Include <code class="bg-bg-card px-1 rounded text-xs">cache-hit</code> output usage
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input id="include-setup-step" type="checkbox" class="w-4 h-4 accent-primary" checked />
          Include setup step (setup-node / setup-python / etc.)
        </label>
        <label class="flex items-center gap-2 text-sm cursor-pointer">
          <input id="include-install-step" type="checkbox" class="w-4 h-4 accent-primary" checked />
          Include install step after cache
        </label>
      </div>
    </div>

    <!-- Output format tabs -->
    <div class="bg-surface border border-border rounded-xl overflow-hidden">
      <div class="flex border-b border-border">
        <button class="fmt-tab px-5 py-3 text-sm font-medium border-b-2 border-primary text-foreground" data-fmt="full-job">Full job</button>
        <button class="fmt-tab px-5 py-3 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-foreground transition-colors" data-fmt="cache-step">Cache step only</button>
        <button class="fmt-tab px-5 py-3 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-foreground transition-colors" data-fmt="workflow">Full workflow</button>
      </div>

      <div class="p-5 space-y-3">
        <div class="flex items-center justify-between">
          <span id="output-label" class="text-xs text-text-muted font-mono">workflow.yml</span>
          <div class="flex gap-2">
            <button id="copy-btn"
              class="px-4 py-2 bg-bg-card border border-border rounded-lg text-xs hover:border-primary transition-colors">
              Copy
            </button>
            <button id="download-btn"
              class="px-4 py-2 bg-bg-card border border-border rounded-lg text-xs hover:border-primary transition-colors">
              Download
            </button>
          </div>
        </div>
        <pre id="output" class="font-mono text-sm whitespace-pre-wrap break-words overflow-x-auto max-h-[500px] overflow-y-auto bg-bg-card border border-border rounded-lg p-4 text-foreground"></pre>
      </div>
    </div>

    <!-- Package manager cheat sheet -->
    <div class="bg-surface border border-border rounded-xl p-5">
      <h2 class="text-sm font-semibold text-text-muted uppercase tracking-wide mb-4">Cache Path Reference</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 text-xs">
        <div class="bg-bg-card rounded-lg p-3 border border-border">
          <code class="text-primary font-semibold">npm</code>
          <p class="text-text-muted mt-1 font-mono">~/.npm</p>
          <p class="text-text-muted mt-0.5">Key: hashFiles('**/package-lock.json')</p>
        </div>
        <div class="bg-bg-card rounded-lg p-3 border border-border">
          <code class="text-primary font-semibold">yarn</code>
          <p class="text-text-muted mt-1 font-mono">$(yarn cache dir)</p>
          <p class="text-text-muted mt-0.5">Key: hashFiles('**/yarn.lock')</p>
        </div>
        <div class="bg-bg-card rounded-lg p-3 border border-border">
          <code class="text-primary font-semibold">pnpm</code>
          <p class="text-text-muted mt-1 font-mono">$(pnpm store path)</p>
          <p class="text-text-muted mt-0.5">Key: hashFiles('**/pnpm-lock.yaml')</p>
        </div>
        <div class="bg-bg-card rounded-lg p-3 border border-border">
          <code class="text-primary font-semibold">pip</code>
          <p class="text-text-muted mt-1 font-mono">~/.cache/pip</p>
          <p class="text-text-muted mt-0.5">Key: hashFiles('**/requirements*.txt')</p>
        </div>
        <div class="bg-bg-card rounded-lg p-3 border border-border">
          <code class="text-primary font-semibold">Maven</code>
          <p class="text-text-muted mt-1 font-mono">~/.m2/repository</p>
          <p class="text-text-muted mt-0.5">Key: hashFiles('**/pom.xml')</p>
        </div>
        <div class="bg-bg-card rounded-lg p-3 border border-border">
          <code class="text-primary font-semibold">Gradle</code>
          <p class="text-text-muted mt-1 font-mono">~/.gradle/caches</p>
          <p class="text-text-muted mt-0.5">Key: hashFiles('**/*.gradle*')</p>
        </div>
        <div class="bg-bg-card rounded-lg p-3 border border-border">
          <code class="text-primary font-semibold">Go modules</code>
          <p class="text-text-muted mt-1 font-mono">~/go/pkg/mod</p>
          <p class="text-text-muted mt-0.5">Key: hashFiles('**/go.sum')</p>
        </div>
        <div class="bg-bg-card rounded-lg p-3 border border-border">
          <code class="text-primary font-semibold">Cargo (Rust)</code>
          <p class="text-text-muted mt-1 font-mono">~/.cargo/registry</p>
          <p class="text-text-muted mt-0.5">Key: hashFiles('**/Cargo.lock')</p>
        </div>
        <div class="bg-bg-card rounded-lg p-3 border border-border">
          <code class="text-primary font-semibold">Bundler</code>
          <p class="text-text-muted mt-1 font-mono">vendor/bundle</p>
          <p class="text-text-muted mt-0.5">Key: hashFiles('**/Gemfile.lock')</p>
        </div>
      </div>
    </div>

  </div>

  <ToolPageCta currentTool="GitHub Actions Cache Config Generator" relatedTags={['github', 'devops', 'ci-cd', 'automation', 'workflow', 'caching']} />
</BaseLayout>

<script is:inline>
(function () {
  // ── Package manager metadata ──────────────────────────────────────────────────
  const PM = {
    npm: {
      label: 'npm',
      cachePath: { project: '~/.npm', global: '~/.npm', monorepo: '~/.npm' },
      lockfile: '**/package-lock.json',
      installCmd: 'npm ci',
      setupAction: 'actions/setup-node@v4',
      setupWith: (ver) => `node-version: '${ver}'`,
      ecosystem: 'node',
      cacheId: 'npm-cache',
    },
    yarn: {
      label: 'yarn',
      cachePath: { project: "$(yarn cache dir)", global: "$(yarn cache dir)", monorepo: "$(yarn cache dir)" },
      lockfile: '**/yarn.lock',
      installCmd: 'yarn install --frozen-lockfile',
      setupAction: 'actions/setup-node@v4',
      setupWith: (ver) => `node-version: '${ver}'`,
      ecosystem: 'node',
      cacheId: 'yarn-cache',
      pathCmd: true,
    },
    pnpm: {
      label: 'pnpm',
      cachePath: { project: "$(pnpm store path --silent)", global: "$(pnpm store path --silent)", monorepo: "$(pnpm store path --silent)" },
      lockfile: '**/pnpm-lock.yaml',
      installCmd: 'pnpm install --frozen-lockfile',
      setupAction: 'actions/setup-node@v4',
      setupWith: (ver) => `node-version: '${ver}'`,
      ecosystem: 'node',
      cacheId: 'pnpm-cache',
      pathCmd: true,
      pnpmSetup: true,
    },
    pip: {
      label: 'pip',
      cachePath: { project: '~/.cache/pip', global: '~/.cache/pip', monorepo: '~/.cache/pip' },
      lockfile: '**/requirements*.txt',
      installCmd: 'pip install -r requirements.txt',
      setupAction: 'actions/setup-python@v5',
      setupWith: (ver) => `python-version: '${ver}'`,
      ecosystem: 'python',
      cacheId: 'pip-cache',
    },
    pipenv: {
      label: 'pipenv',
      cachePath: { project: '~/.local/share/virtualenvs', global: '~/.local/share/virtualenvs', monorepo: '~/.local/share/virtualenvs' },
      lockfile: '**/Pipfile.lock',
      installCmd: 'pipenv install --deploy',
      setupAction: 'actions/setup-python@v5',
      setupWith: (ver) => `python-version: '${ver}'`,
      ecosystem: 'python',
      cacheId: 'pipenv-cache',
    },
    poetry: {
      label: 'poetry',
      cachePath: { project: '~/.cache/pypoetry', global: '~/.cache/pypoetry', monorepo: '~/.cache/pypoetry' },
      lockfile: '**/poetry.lock',
      installCmd: 'poetry install --no-root',
      setupAction: 'actions/setup-python@v5',
      setupWith: (ver) => `python-version: '${ver}'`,
      ecosystem: 'python',
      cacheId: 'poetry-cache',
    },
    maven: {
      label: 'Maven',
      cachePath: { project: '~/.m2/repository', global: '~/.m2/repository', monorepo: '~/.m2/repository' },
      lockfile: '**/pom.xml',
      installCmd: 'mvn dependency:resolve --no-transfer-progress',
      setupAction: 'actions/setup-java@v4',
      setupWith: () => `java-version: '21'\n          distribution: 'temurin'`,
      ecosystem: 'java',
      cacheId: 'maven-cache',
    },
    gradle: {
      label: 'Gradle',
      cachePath: { project: '~/.gradle/caches\n          ~/.gradle/wrapper', global: '~/.gradle/caches\n          ~/.gradle/wrapper', monorepo: '~/.gradle/caches\n          ~/.gradle/wrapper' },
      lockfile: '**/*.gradle*\n            **/gradle-wrapper.properties',
      installCmd: './gradlew dependencies',
      setupAction: 'actions/setup-java@v4',
      setupWith: () => `java-version: '21'\n          distribution: 'temurin'`,
      ecosystem: 'java',
      cacheId: 'gradle-cache',
    },
    go: {
      label: 'Go modules',
      cachePath: { project: '~/go/pkg/mod', global: '~/go/pkg/mod\n          ~/.cache/go-build', monorepo: '~/go/pkg/mod' },
      lockfile: '**/go.sum',
      installCmd: 'go mod download',
      setupAction: 'actions/setup-go@v5',
      setupWith: () => `go-version: '1.22'`,
      ecosystem: 'go',
      cacheId: 'go-cache',
    },
    cargo: {
      label: 'Cargo (Rust)',
      cachePath: { project: '~/.cargo/registry\n          ~/.cargo/git\n          target', global: '~/.cargo/registry\n          ~/.cargo/git', monorepo: '~/.cargo/registry\n          ~/.cargo/git' },
      lockfile: '**/Cargo.lock',
      installCmd: 'cargo build --release',
      setupAction: null,
      setupWith: () => '',
      ecosystem: 'rust',
      cacheId: 'cargo-cache',
    },
    gems: {
      label: 'Ruby gems',
      cachePath: { project: 'vendor/bundle', global: '~/.bundle', monorepo: 'vendor/bundle' },
      lockfile: '**/Gemfile.lock',
      installCmd: 'bundle install',
      setupAction: 'ruby/setup-ruby@v1',
      setupWith: () => `ruby-version: '3.3'\n          bundler-cache: false`,
      ecosystem: 'ruby',
      cacheId: 'gems-cache',
    },
    composer: {
      label: 'Composer (PHP)',
      cachePath: { project: '~/.composer/cache', global: '~/.composer/cache', monorepo: '~/.composer/cache' },
      lockfile: '**/composer.lock',
      installCmd: 'composer install --prefer-dist --no-progress',
      setupAction: 'shivammathur/setup-php@v2',
      setupWith: () => `php-version: '8.3'`,
      ecosystem: 'php',
      cacheId: 'composer-cache',
    },
  };

  let currentFmt = 'full-job';

  // ── Show/hide setup version fields based on package manager ──────────────────
  function updateVersionVisibility() {
    const pm = document.getElementById('pkg-manager').value;
    const meta = PM[pm];
    const nodeRow = document.getElementById('node-version-row');
    const pythonRow = document.getElementById('python-version-row');
    nodeRow.classList.toggle('hidden', meta.ecosystem !== 'node');
    pythonRow.classList.toggle('hidden', meta.ecosystem !== 'python');
  }

  // ── Build key prefix ──────────────────────────────────────────────────────────
  function buildKey(pm, os, scope, prefix, meta) {
    const osExpr = os === 'matrix' ? '${{ matrix.os }}' : '${{ runner.os }}';
    const parts = [];
    if (prefix) parts.push(prefix);
    parts.push(osExpr);
    parts.push(pm);
    const lockfileGlob = meta.lockfile.includes('\n') ? meta.lockfile.split('\n')[0].trim() : meta.lockfile;
    parts.push(`\${{ hashFiles('${scope === 'monorepo' ? lockfileGlob.replace('**/', '') : lockfileGlob}') }}`);
    return parts.join('-');
  }

  function buildRestoreKey(pm, os, prefix) {
    const osExpr = os === 'matrix' ? '${{ matrix.os }}' : '${{ runner.os }}';
    const parts = [];
    if (prefix) parts.push(prefix);
    parts.push(osExpr);
    parts.push(pm + '-');
    return parts.join('-');
  }

  // ── Path command steps ────────────────────────────────────────────────────────
  function buildPathStep(pm, meta, cacheIdVar) {
    if (!meta.pathCmd) return null;
    if (pm === 'yarn') {
      return `      - name: Get yarn cache directory path
        id: yarn-cache-dir-path
        run: echo "dir=$(yarn cache dir)" >> $GITHUB_OUTPUT`;
    }
    if (pm === 'pnpm') {
      return `      - name: Get pnpm store directory
        id: pnpm-store-path
        shell: bash
        run: echo "dir=$(pnpm store path --silent)" >> $GITHUB_OUTPUT`;
    }
    return null;
  }

  // ── Build cache step YAML ─────────────────────────────────────────────────────
  function buildCacheStep(pm, os, scope, prefix, includeCacheHit, meta) {
    const cacheKey = buildKey(pm, os, scope, prefix, meta);
    const restoreKey = buildRestoreKey(pm, os, prefix);
    const cacheId = meta.cacheId;

    let cachePath = meta.cachePath[scope] || meta.cachePath.project;
    if (meta.pathCmd) {
      if (pm === 'yarn') cachePath = `\${{ steps.yarn-cache-dir-path.outputs.dir }}`;
      if (pm === 'pnpm') cachePath = `\${{ steps.pnpm-store-path.outputs.dir }}`;
    }

    let step = `      - name: Cache ${meta.label} dependencies
        uses: actions/cache@v4`;
    if (includeCacheHit) {
      step += `\n        id: ${cacheId}`;
    }
    step += `\n        with:
          path: ${cachePath}
          key: ${cacheKey}
          restore-keys: |
            ${restoreKey}`;
    return step;
  }

  // ── Build setup step ──────────────────────────────────────────────────────────
  function buildSetupStep(pm, meta) {
    if (!meta.setupAction) return null;
    const nodeVer = document.getElementById('node-version').value;
    const pythonVer = document.getElementById('python-version').value;
    const withStr = meta.setupWith(meta.ecosystem === 'node' ? nodeVer : pythonVer);

    let step = `      - name: Set up ${meta.label}
        uses: ${meta.setupAction}
        with:
          ${withStr}`;

    if (pm === 'pnpm') {
      step = `      - name: Set up pnpm
        uses: pnpm/action-setup@v4
        with:
          version: 9\n` + step;
    }
    return step;
  }

  // ── Build install step ────────────────────────────────────────────────────────
  function buildInstallStep(pm, meta, includeCacheHit) {
    let step = `      - name: Install dependencies`;
    if (includeCacheHit) {
      step += `\n        if: steps.${meta.cacheId}.outputs.cache-hit != 'true'`;
    }
    step += `\n        run: ${meta.installCmd}`;
    return step;
  }

  // ── Generate output ───────────────────────────────────────────────────────────
  function generate() {
    const pm = document.getElementById('pkg-manager').value;
    const os = document.getElementById('os-target').value;
    const scope = document.getElementById('cache-scope').value;
    const prefix = document.getElementById('key-prefix').value.trim();
    const includeCacheHit = document.getElementById('include-cache-hit').checked;
    const includeSetup = document.getElementById('include-setup-step').checked;
    const includeInstall = document.getElementById('include-install-step').checked;
    const meta = PM[pm];

    const pathStep = buildPathStep(pm, meta, meta.cacheId);
    const cacheStep = buildCacheStep(pm, os, scope, prefix, includeCacheHit, meta);
    const setupStep = includeSetup ? buildSetupStep(pm, meta) : null;
    const installStep = includeInstall ? buildInstallStep(pm, meta, includeCacheHit) : null;

    const osVal = os === 'matrix' ? '${{ matrix.os }}' : os;

    if (currentFmt === 'cache-step') {
      const parts = [];
      if (pathStep) parts.push(pathStep);
      parts.push(cacheStep);
      return parts.join('\n\n') + '\n';
    }

    if (currentFmt === 'full-job') {
      const steps = [];
      steps.push(`      - name: Checkout code
        uses: actions/checkout@v4`);
      if (setupStep) steps.push(setupStep);
      if (pathStep) steps.push(pathStep);
      steps.push(cacheStep);
      if (installStep) steps.push(installStep);
      steps.push(`      - name: Build
        run: echo "Add your build command here"`);

      let job = `jobs:
  build:
    runs-on: ${osVal}\n`;

      if (os === 'matrix') {
        job = `jobs:
  build:
    runs-on: \${{ matrix.os }}
    strategy:
      matrix:
        os: [ubuntu-latest, macos-latest, windows-latest]\n`;
      }

      return job + `    steps:\n` + steps.join('\n\n') + '\n';
    }

    // full workflow
    const steps = [];
    steps.push(`      - name: Checkout code
        uses: actions/checkout@v4`);
    if (setupStep) steps.push(setupStep);
    if (pathStep) steps.push(pathStep);
    steps.push(cacheStep);
    if (installStep) steps.push(installStep);
    steps.push(`      - name: Build
        run: echo "Add your build command here"

      - name: Test
        run: echo "Add your test command here"`);

    let runsOn = osVal;
    let strategyBlock = '';
    if (os === 'matrix') {
      runsOn = '${{ matrix.os }}';
      strategyBlock = `    strategy:
      matrix:
        os: [ubuntu-latest, macos-latest, windows-latest]
`;
    }

    return `name: CI

on:
  push:
    branches: [main, develop]
  pull_request:
    branches: [main]

jobs:
  build:
    runs-on: ${runsOn}
${strategyBlock}    steps:
${steps.join('\n\n')}
`;
  }

  // ── Update output label ───────────────────────────────────────────────────────
  function updateLabel() {
    const labels = { 'cache-step': 'cache step (YAML)', 'full-job': 'job (YAML)', 'workflow': 'workflow.yml' };
    document.getElementById('output-label').textContent = labels[currentFmt] || 'workflow.yml';
  }

  function refresh() {
    document.getElementById('output').textContent = generate();
    updateLabel();
  }

  // ── Tab switching ─────────────────────────────────────────────────────────────
  document.querySelectorAll('.fmt-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.fmt-tab').forEach(b => {
        b.classList.remove('border-primary', 'text-foreground');
        b.classList.add('border-transparent', 'text-text-muted');
      });
      btn.classList.add('border-primary', 'text-foreground');
      btn.classList.remove('border-transparent', 'text-text-muted');
      currentFmt = btn.dataset.fmt;
      refresh();
    });
  });

  // ── Live update on any change ─────────────────────────────────────────────────
  const watchIds = [
    'pkg-manager', 'os-target', 'cache-scope', 'key-prefix',
    'node-version', 'python-version',
    'include-cache-hit', 'include-setup-step', 'include-install-step',
  ];
  watchIds.forEach(id => {
    const el = document.getElementById(id);
    if (!el) return;
    el.addEventListener('change', () => { updateVersionVisibility(); refresh(); });
    el.addEventListener('input', refresh);
  });

  // ── Copy & Download ───────────────────────────────────────────────────────────
  document.getElementById('copy-btn').addEventListener('click', () => {
    const text = document.getElementById('output').textContent;
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById('copy-btn');
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
    });
  });

  document.getElementById('download-btn').addEventListener('click', () => {
    const text = document.getElementById('output').textContent;
    const fname = currentFmt === 'workflow' ? 'ci.yml' : 'cache-step.yml';
    const blob = new Blob([text], { type: 'text/yaml' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = fname;
    a.click();
    URL.revokeObjectURL(url);
  });

  // ── Init ──────────────────────────────────────────────────────────────────────
  updateVersionVisibility();
  refresh();
})();
</script>
