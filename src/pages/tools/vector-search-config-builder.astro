               FROM ${name}
               ORDER BY embedding ${op} %s
               LIMIT %s""",
            (query_vector, query_vector, top_k)
        )

    results = cur.fetchall()
    cur.close()

    for row in results:
        doc_id, content, source, category, similarity = row
        print(f"Similarity: {similarity:.4f} | ID: {doc_id}")
        print(f"Text: {content[:100]}")
        print()

    return results

