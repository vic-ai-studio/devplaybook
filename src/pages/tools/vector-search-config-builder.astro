  function generateCode() {
    const gen = generators[currentProvider]?.[currentTab];
    if (!gen) return;
    const code = gen();
    (document.getElementById('code-output') as HTMLElement).textContent = code;
    const langMap: Record<CodeTab, string> = { setup: 'python', upsert: 'python', query: 'python', env: 'shell (.env)' };
    (document.getElementById('code-lang-badge') as HTMLElement).textContent = langMap[currentTab];
    updateStorage();
  }

  function updateStorage() {
    const count = parseInt(getVal('vector-count')) || 0;
    const dims = parseInt(getVal('dimensions')) || 1536;
    const bytesPerDim = parseInt(getVal('precision')) || 4;
    const metaBytes = parseInt(getVal('metadata-size')) || 256;
    const hnswOverhead = 64;

    const rawBytes = count * dims * bytesPerDim;
    const metaTotal = count * metaBytes;
    const hnswBytes = count * hnswOverhead;
    const totalBytes = rawBytes + metaTotal + hnswBytes;

    const fmt = (bytes: number): string => {
      if (bytes < 1024) return `${bytes} B`;
      if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
      if (bytes < 1024 * 1024 * 1024) return `${(bytes / 1024 / 1024).toFixed(1)} MB`;
      return `${(bytes / 1024 / 1024 / 1024).toFixed(2)} GB`;
    };

    const el = document.getElementById('storage-result')!;
    el.innerHTML = `
      <div class="bg-black/20 rounded-lg p-3"><div class="text-text-muted text-xs mb-1">Vector data</div><div class="font-mono">${fmt(rawBytes)}</div></div>
      <div class="bg-black/20 rounded-lg p-3"><div class="text-text-muted text-xs mb-1">Metadata</div><div class="font-mono">${fmt(metaTotal)}</div></div>
      <div class="bg-black/20 rounded-lg p-3"><div class="text-text-muted text-xs mb-1">HNSW index</div><div class="font-mono">${fmt(hnswBytes)}</div></div>
      <div class="bg-black/20 rounded-lg p-3 border border-primary/30"><div class="text-text-muted text-xs mb-1">Total estimate</div><div class="font-mono text-primary font-bold">${fmt(totalBytes)}</div></div>
    `;
  }

  // Provider buttons
  document.querySelectorAll('.provider-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.provider-btn').forEach(b => {
        b.className = 'provider-btn border border-border bg-black/20 rounded-lg px-3 py-3 hover:border-primary hover:text-primary transition-colors text-center';
      });
      btn.className = 'provider-btn active-provider border border-primary bg-primary/10 text-primary rounded-lg px-3 py-3 hover:bg-primary/20 transition-colors text-center';
      currentProvider = (btn as HTMLElement).dataset.provider as Provider;
      generateCode();
    });
  });

  // Code tabs
  ['setup', 'upsert', 'query', 'env'].forEach(tab => {
    document.getElementById(`tab-${tab}`)!.addEventListener('click', () => {
      currentTab = tab as CodeTab;
      ['setup', 'upsert', 'query', 'env'].forEach(t => {
        const el = document.getElementById(`tab-${t}`)!;
        el.className = t === tab
          ? 'code-tab bg-primary text-white px-3 py-1.5 rounded-lg text-xs font-medium'
          : 'code-tab bg-black/20 border border-border px-3 py-1.5 rounded-lg text-xs font-medium hover:border-primary transition-colors';
      });
      generateCode();
    });
  });

  document.getElementById('generate-btn')!.addEventListener('click', generateCode);

  document.getElementById('copy-code')!.addEventListener('click', () => {
    const text = (document.getElementById('code-output') as HTMLElement).textContent || '';
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById('copy-code')!;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy Code'; }, 2000);
    });
  });

  // Model table click — set dimensions
  document.querySelectorAll('.model-row').forEach(row => {
    row.addEventListener('click', () => {
      const dims = (row as HTMLElement).dataset.dims;
      if (dims) {
        const sel = document.getElementById('dimensions') as HTMLSelectElement;
        const opt = Array.from(sel.options).find(o => o.value === dims);
        if (opt) sel.value = dims;
        generateCode();
      }
    });
  });

  // Storage inputs
  ['vector-count', 'dimensions', 'precision', 'metadata-size'].forEach(id => {
    document.getElementById(id)!.addEventListener('input', updateStorage);
  });

  // Initial render
  generateCode();
</script>
