---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What vector dimensions should I use for OpenAI embeddings?",
    answer: "text-embedding-3-small and text-embedding-3-large support configurable dimensions via Matryoshka Representation Learning (MRL). For most RAG applications, text-embedding-3-small at 1536 dims is the default and offers the best cost/performance balance. You can reduce to 512 dims for ~2.5× storage savings with minor quality loss. text-embedding-ada-002 is fixed at 1536 dims. For production with millions of documents, consider int8 quantization to cut storage costs by 75%."
  },
  {
    question: "When should I use cosine similarity vs dot product vs euclidean?",
    answer: "Cosine similarity measures the angle between vectors (scale-invariant) — best for semantic search where you care about meaning, not vector magnitude. Use cosine for text embeddings from any provider. Dot product is equivalent to cosine when vectors are normalized (unit length), and is faster to compute — Pinecone normalizes by default. Euclidean distance measures straight-line distance in vector space — useful for image embeddings or cases where magnitude encodes information. For text search, always start with cosine."
  },
  {
    question: "What is the difference between Pinecone, Weaviate, Qdrant, and ChromaDB?",
    answer: "Pinecone is a fully managed cloud vector database — zero infrastructure, generous free tier (1 index, 100K vectors), ideal for prototypes and production. Weaviate is open-source (self-host) or managed cloud, with built-in ML inference and GraphQL API — best for hybrid search (vector + BM25). Qdrant is a high-performance open-source vector DB with advanced filtering, payload indexing, and quantization — great for on-premises or Docker deployments. ChromaDB is an embedded Python library (no server needed) — best for local development, notebooks, and small-scale apps."
  },
  {
    question: "How do I calculate storage requirements for vector indexes?",
    answer: "Storage per vector = dimensions × bytes_per_float. float32 = 4 bytes/dim, float16 = 2 bytes/dim, int8 = 1 byte/dim. For 1M vectors at 1536 dims float32: 1,000,000 × 1536 × 4 = ~5.86 GB raw. Add metadata/payload overhead (typically 20-30%). Plus the HNSW graph structure adds ~60 bytes per vector. Real-world 1M vector index at 1536 dims ≈ 8-12 GB total. Managed services charge based on pod type — a Pinecone p1.x1 pod holds ~1M 1536-dim vectors at ~$70/month."
  },
  {
    question: "What is pgvector and when should I use it instead of a dedicated vector database?",
    answer: "pgvector is a PostgreSQL extension that adds vector storage and similarity search directly to your existing Postgres database. Use pgvector when: you're already running PostgreSQL and want to avoid adding another service, your vector count is under 1-2M (beyond that, dedicated vector DBs outperform), or you need ACID transactions combining vector and relational data. Limitations: slower than dedicated vector DBs at scale, no built-in quantization, limited indexing options (HNSW and IVFFlat). For new projects without an existing Postgres stack, Qdrant or Pinecone are generally better choices."
  }
];

const modelDimensions = [
  { model: "text-embedding-3-small", provider: "OpenAI", dims: 1536, costPer1M: 0.02, notes: "Best price/perf, MRL configurable (512/1024/1536)", configurable: true },
  { model: "text-embedding-3-large", provider: "OpenAI", dims: 3072, costPer1M: 0.13, notes: "Highest quality, MRL configurable (256/1024/3072)", configurable: true },
  { model: "text-embedding-ada-002", provider: "OpenAI", dims: 1536, costPer1M: 0.10, notes: "Legacy, fixed dimensions, widely supported", configurable: false },
  { model: "all-MiniLM-L6-v2", provider: "HuggingFace (local)", dims: 384, costPer1M: 0, notes: "Fast, small, great for local/offline use", configurable: false },
  { model: "all-mpnet-base-v2", provider: "HuggingFace (local)", dims: 768, costPer1M: 0, notes: "Higher quality than MiniLM, still fast", configurable: false },
  { model: "nomic-embed-text", provider: "Nomic / local", dims: 768, costPer1M: 0, notes: "Strong open-source, Ollama compatible", configurable: false },
  { model: "voyage-3", provider: "Voyage AI", dims: 1024, costPer1M: 0.06, notes: "Competitive MTEB, good for RAG retrieval", configurable: false },
  { model: "voyage-3-lite", provider: "Voyage AI", dims: 512, costPer1M: 0.02, notes: "Budget option, smaller vectors", configurable: false },
  { model: "embed-english-v3.0", provider: "Cohere", dims: 1024, costPer1M: 0.10, notes: "Multilingual available (embed-multilingual-v3)", configurable: false },
  { model: "BGE-large-en-v1.5", provider: "BAAI (local)", dims: 1024, costPer1M: 0, notes: "Top open-source MTEB, CPU-friendly", configurable: false },
  { model: "jina-embeddings-v2-base", provider: "Jina AI", dims: 768, costPer1M: 0.02, notes: "8192 token input context, long documents", configurable: false },
];
---

<BaseLayout
  title="Vector Search Config Builder — Pinecone, Weaviate, Qdrant, pgvector"
  description="Generate complete vector database configuration code for Pinecone, Weaviate, Qdrant, ChromaDB, and pgvector. Includes Python SDK setup, .env config, index creation, upsert, and query examples. Includes embedding model dimension reference and storage calculator."
  tool="Vector Search Config Builder, Pinecone Config Generator, Weaviate Setup, Qdrant Config, ChromaDB Setup, pgvector Config, Vector Database Builder"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Vector Search Config Builder</h1>
  <p class="text-text-muted mb-4">Generate complete setup code for any vector database provider. Configure dimensions, metrics, and index settings — get Python SDK code, .env config, and storage estimates instantly.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 vector DB providers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Python SDK code</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> .env configuration</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Storage estimator</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Model dimension table</span>
  </div>

  <!-- Provider Selection -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-3">Select Provider</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-2">
      <button class="provider-btn active-provider border border-primary bg-primary/10 text-primary rounded-lg px-3 py-3 hover:bg-primary/20 transition-colors text-center" data-provider="pinecone">
        <div class="text-sm font-semibold">Pinecone</div>
        <div class="text-xs opacity-75 mt-0.5">Managed cloud</div>
      </button>
      <button class="provider-btn border border-border bg-black/20 rounded-lg px-3 py-3 hover:border-primary hover:text-primary transition-colors text-center" data-provider="weaviate">
        <div class="text-sm font-semibold">Weaviate</div>
        <div class="text-xs opacity-75 mt-0.5">Open-source / cloud</div>
      </button>
      <button class="provider-btn border border-border bg-black/20 rounded-lg px-3 py-3 hover:border-primary hover:text-primary transition-colors text-center" data-provider="qdrant">
        <div class="text-sm font-semibold">Qdrant</div>
        <div class="text-xs opacity-75 mt-0.5">High performance</div>
      </button>
      <button class="provider-btn border border-border bg-black/20 rounded-lg px-3 py-3 hover:border-primary hover:text-primary transition-colors text-center" data-provider="chroma">
        <div class="text-sm font-semibold">ChromaDB</div>
        <div class="text-xs opacity-75 mt-0.5">Embedded Python</div>
      </button>
      <button class="provider-btn border border-border bg-black/20 rounded-lg px-3 py-3 hover:border-primary hover:text-primary transition-colors text-center" data-provider="pgvector">
        <div class="text-sm font-semibold">pgvector</div>
        <div class="text-xs opacity-75 mt-0.5">PostgreSQL extension</div>
      </button>
    </div>
  </div>

  <!-- Index Configuration -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Index Configuration</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Index / Collection Name</label>
        <input id="index-name" type="text" value="my-embeddings"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Embedding Dimensions</label>
        <select id="dimensions" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="128">128 (lightweight / custom)</option>
          <option value="384">384 (all-MiniLM-L6-v2)</option>
          <option value="512">512 (voyage-3-lite)</option>
          <option value="768">768 (all-mpnet, nomic, BGE-base)</option>
          <option value="1024">1024 (voyage-3, Cohere, BGE-large)</option>
          <option value="1536" selected>1536 (OpenAI ada-002 / te3-small)</option>
          <option value="3072">3072 (OpenAI te3-large)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Similarity Metric</label>
        <select id="metric" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="cosine" selected>cosine (recommended for text)</option>
          <option value="euclidean">euclidean (L2 distance)</option>
          <option value="dotproduct">dotproduct (fastest, needs normalized vectors)</option>
        </select>
      </div>
      <div id="index-type-group">
        <label class="block text-sm font-medium mb-1.5">Index Type</label>
        <select id="index-type" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="hnsw" selected>HNSW (best recall, high memory)</option>
          <option value="ivf_flat">IVF Flat (good balance)</option>
          <option value="flat">Flat (exact search, small datasets)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Cloud / Host</label>
        <select id="cloud-provider" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="aws-us-east-1">AWS us-east-1</option>
          <option value="aws-us-west-2">AWS us-west-2</option>
          <option value="gcp-us-central1">GCP us-central1</option>
          <option value="azure-eastus">Azure eastus</option>
          <option value="localhost">localhost (self-hosted)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Namespace / Tenant</label>
        <input id="namespace" type="text" value="default"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
    </div>
  </div>

  <!-- Storage Estimator -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Storage Estimator</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Number of Vectors</label>
        <input id="vector-count" type="number" value="100000" min="1"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Float Precision</label>
        <select id="precision" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="4" selected>float32 (4 bytes/dim)</option>
          <option value="2">float16 (2 bytes/dim)</option>
          <option value="1">int8 quantized (1 byte/dim)</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Avg Metadata Size (bytes)</label>
        <input id="metadata-size" type="number" value="256" min="0"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
    </div>
    <div id="storage-result" class="grid grid-cols-2 md:grid-cols-4 gap-3 text-sm"></div>
  </div>

  <!-- Code Output Tabs -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <div class="flex items-center justify-between mb-4 flex-wrap gap-2">
      <div class="flex gap-2 flex-wrap">
        <button id="tab-setup" class="code-tab bg-primary text-white px-3 py-1.5 rounded-lg text-xs font-medium">Setup + Index</button>
        <button id="tab-upsert" class="code-tab bg-black/20 border border-border px-3 py-1.5 rounded-lg text-xs font-medium hover:border-primary transition-colors">Upsert</button>
        <button id="tab-query" class="code-tab bg-black/20 border border-border px-3 py-1.5 rounded-lg text-xs font-medium hover:border-primary transition-colors">Query</button>
        <button id="tab-env" class="code-tab bg-black/20 border border-border px-3 py-1.5 rounded-lg text-xs font-medium hover:border-primary transition-colors">.env</button>
      </div>
      <button id="copy-code" class="bg-primary text-white px-3 py-1.5 rounded-lg text-xs hover:opacity-90 font-medium">Copy Code</button>
    </div>
    <div class="flex items-center justify-between mb-2">
      <span id="code-lang-badge" class="text-xs text-text-muted font-mono">python</span>
    </div>
    <pre id="code-output" class="bg-black/30 rounded-lg p-4 text-xs font-mono overflow-x-auto whitespace-pre-wrap text-green-300 min-h-56"></pre>
    <button id="generate-btn" class="mt-4 bg-primary text-white px-5 py-2 rounded-lg hover:opacity-90 font-medium text-sm">Generate Code</button>
  </div>

  <!-- Embedding Model Reference Table -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-3">Embedding Model Dimension Reference</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border text-text-muted text-xs">
            <th class="text-left py-2 pr-4">Model</th>
            <th class="text-left py-2 pr-4">Provider</th>
            <th class="text-right py-2 pr-4">Dims</th>
            <th class="text-right py-2 pr-4">Cost/1M tokens</th>
            <th class="text-left py-2">Notes</th>
          </tr>
        </thead>
        <tbody id="model-table-body">
          {modelDimensions.map(m => (
            <tr class="border-b border-border/40 hover:bg-black/10 cursor-pointer model-row" data-dims={m.dims.toString()}>
              <td class="py-2 pr-4 font-mono text-xs text-primary">{m.model}</td>
              <td class="py-2 pr-4 text-text-muted text-xs">{m.provider}</td>
              <td class="py-2 pr-4 text-right font-mono">{m.dims.toLocaleString()}</td>
              <td class="py-2 pr-4 text-right text-text-muted">{m.costPer1M === 0 ? 'Free' : `$${m.costPer1M.toFixed(2)}`}</td>
              <td class="py-2 text-text-muted text-xs">{m.notes}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="text-xs text-text-muted mt-2">Click a row to use that model's dimensions in the config above.</p>
  </div>

  <ToolPageCta />
</BaseLayout>

<script>
  type Provider = 'pinecone' | 'weaviate' | 'qdrant' | 'chroma' | 'pgvector';
  type CodeTab = 'setup' | 'upsert' | 'query' | 'env';

  let currentProvider: Provider = 'pinecone';
  let currentTab: CodeTab = 'setup';

  function getVal(id: string): string {
    return (document.getElementById(id) as HTMLInputElement | HTMLSelectElement)?.value || '';
  }

  // Code generators per provider
  const generators: Record<Provider, Record<CodeTab, () => string>> = {
    pinecone: {
      setup: () => {
        const name = getVal('index-name');
        const dims = getVal('dimensions');
        const metric = getVal('metric') === 'euclidean' ? 'euclidean' : getVal('metric') === 'dotproduct' ? 'dotproduct' : 'cosine';
        const cloud = getVal('cloud-provider').startsWith('aws') ? 'aws' : getVal('cloud-provider').startsWith('gcp') ? 'gcp' : 'azure';
        const region = getVal('cloud-provider').split('-').slice(1).join('-') || 'us-east-1';
        return `# Install: pip install pinecone-client
import os
from pinecone import Pinecone, ServerlessSpec

# Initialize Pinecone client
pc = Pinecone(api_key=os.environ["PINECONE_API_KEY"])

# Create serverless index
INDEX_NAME = "${name}"
DIMENSIONS = ${dims}
METRIC = "${metric}"

if INDEX_NAME not in pc.list_indexes().names():
    pc.create_index(
        name=INDEX_NAME,
        dimension=DIMENSIONS,
        metric=METRIC,
        spec=ServerlessSpec(
            cloud="${cloud}",
            region="${region}"
        )
    )
    print(f"Index '{INDEX_NAME}' created successfully")
else:
    print(f"Index '{INDEX_NAME}' already exists")

# Connect to the index
index = pc.Index(INDEX_NAME)

# Describe index stats
stats = index.describe_index_stats()
print(f"Total vectors: {stats.total_vector_count}")
print(f"Dimensions: {stats.dimension}")`;
      },
      upsert: () => {
        const name = getVal('index-name');
        const ns = getVal('namespace');
        return `import os
from pinecone import Pinecone
import openai

pc = Pinecone(api_key=os.environ["PINECONE_API_KEY"])
index = pc.Index("${name}")
oai = openai.OpenAI(api_key=os.environ["OPENAI_API_KEY"])

def embed(texts: list[str]) -> list[list[float]]:
    """Generate embeddings using OpenAI."""
    response = oai.embeddings.create(
        model="text-embedding-3-small",
        input=texts
    )
    return [item.embedding for item in response.data]

# Batch upsert example
documents = [
    {"id": "doc-1", "text": "Machine learning is a subset of AI", "source": "wiki"},
    {"id": "doc-2", "text": "Neural networks are inspired by the brain", "source": "wiki"},
    {"id": "doc-3", "text": "Transformers use attention mechanisms", "source": "paper"},
]

BATCH_SIZE = 100
NAMESPACE = "${ns}"

for i in range(0, len(documents), BATCH_SIZE):
    batch = documents[i:i + BATCH_SIZE]
    texts = [doc["text"] for doc in batch]
    embeddings = embed(texts)

    vectors = [
        {
            "id": doc["id"],
            "values": embedding,
            "metadata": {"text": doc["text"], "source": doc["source"]}
        }
        for doc, embedding in zip(batch, embeddings)
    ]

    index.upsert(vectors=vectors, namespace=NAMESPACE)
    print(f"Upserted {len(vectors)} vectors (batch {i // BATCH_SIZE + 1})")

print("Upsert complete")`;
      },
      query: () => {
        const name = getVal('index-name');
        const ns = getVal('namespace');
        return `import os
from pinecone import Pinecone
import openai

pc = Pinecone(api_key=os.environ["PINECONE_API_KEY"])
index = pc.Index("${name}")
oai = openai.OpenAI(api_key=os.environ["OPENAI_API_KEY"])

def query_similar(query: str, top_k: int = 5, filter: dict = None):
    """Query the vector index for semantically similar documents."""
    # Generate query embedding
    response = oai.embeddings.create(
        model="text-embedding-3-small",
        input=[query]
    )
    query_vector = response.data[0].embedding

    # Query the index
    results = index.query(
        vector=query_vector,
        top_k=top_k,
        namespace="${ns}",
        include_metadata=True,
        filter=filter  # Optional metadata filter, e.g. {"source": {"$eq": "wiki"}}
    )

    # Parse results
    matches = []
    for match in results.matches:
        matches.append({
            "id": match.id,
            "score": match.score,
            "text": match.metadata.get("text", ""),
            "metadata": match.metadata
        })

    return matches

# Example query
results = query_similar(
    query="How do neural networks learn?",
    top_k=3,
    filter={"source": {"\\$eq": "wiki"}}  # Optional filter
)

for r in results:
    print(f"Score: {r['score']:.4f} | ID: {r['id']}")
    print(f"Text: {r['text'][:100]}...")
    print()`;
      },
      env: () => {
        const name = getVal('index-name');
        return `# .env — Pinecone Configuration
# Copy this to your project root and fill in your API keys

# Pinecone
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=${name}
PINECONE_NAMESPACE=${getVal('namespace')}

# Embedding model (OpenAI)
OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=${getVal('dimensions')}

# Application
VECTOR_METRIC=${getVal('metric')}
QUERY_TOP_K=5

# Load with python-dotenv:
# pip install python-dotenv
# from dotenv import load_dotenv; load_dotenv()`;
      }
    },

    weaviate: {
      setup: () => {
        const name = getVal('index-name').replace(/-/g, '_').replace(/^(.)/, c => c.toUpperCase());
        const dims = getVal('dimensions');
        const metric = getVal('metric') === 'euclidean' ? 'l2-squared' : 'cosine';
        const cloud = getVal('cloud-provider');
        const isLocal = cloud === 'localhost';
        return `# Install: pip install weaviate-client
import os
import weaviate
import weaviate.classes as wvc
from weaviate.classes.config import Property, DataType, Configure, VectorDistances

# Initialize client${isLocal ? `
client = weaviate.connect_to_local(
    host="localhost",
    port=8080,
    grpc_port=50051
)` : `
client = weaviate.connect_to_weaviate_cloud(
    cluster_url=os.environ["WEAVIATE_URL"],
    auth_credentials=wvc.init.Auth.api_key(os.environ["WEAVIATE_API_KEY"])
)`}

COLLECTION_NAME = "${name}"
DIMENSIONS = ${dims}

# Create collection
if not client.collections.exists(COLLECTION_NAME):
    client.collections.create(
        name=COLLECTION_NAME,
        vectorizer_config=Configure.Vectorizer.none(),  # BYO embeddings
        vector_index_config=Configure.VectorIndex.hnsw(
            distance_metric=VectorDistances.${metric.toUpperCase().replace('-', '_')},
            ef_construction=128,
            max_connections=64
        ),
        properties=[
            Property(name="text", data_type=DataType.TEXT),
            Property(name="source", data_type=DataType.TEXT),
            Property(name="created_at", data_type=DataType.DATE),
        ]
    )
    print(f"Collection '{COLLECTION_NAME}' created")

collection = client.collections.get(COLLECTION_NAME)
print(f"Collection ready: {collection.name}")
client.close()`;
      },
      upsert: () => {
        const name = getVal('index-name').replace(/-/g, '_').replace(/^(.)/, c => c.toUpperCase());
        return `import os
import weaviate
import weaviate.classes as wvc
from weaviate.classes.data import DataObject
import openai

client = weaviate.connect_to_weaviate_cloud(
    cluster_url=os.environ["WEAVIATE_URL"],
    auth_credentials=wvc.init.Auth.api_key(os.environ["WEAVIATE_API_KEY"])
)
oai = openai.OpenAI(api_key=os.environ["OPENAI_API_KEY"])
collection = client.collections.get("${name}")

documents = [
    {"text": "Machine learning is a subset of AI", "source": "wiki"},
    {"text": "Neural networks are inspired by the brain", "source": "wiki"},
]

# Batch insert with explicit vectors
with collection.batch.dynamic() as batch:
    for i, doc in enumerate(documents):
        # Generate embedding
        emb_response = oai.embeddings.create(
            model="text-embedding-3-small",
            input=[doc["text"]]
        )
        vector = emb_response.data[0].embedding

        batch.add_object(
            properties={"text": doc["text"], "source": doc["source"]},
            vector=vector,
            uuid=weaviate.util.generate_uuid5(doc["text"])
        )
        print(f"Added object {i + 1}/{len(documents)}")

