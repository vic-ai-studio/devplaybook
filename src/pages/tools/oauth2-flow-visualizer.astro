---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OAuth2FlowVisualizer from '../../components/OAuth2FlowVisualizer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is OAuth2 and when should I use it?",
    answer: "OAuth2 is an authorization framework that lets users grant third-party applications limited access to their accounts without sharing credentials. Use it when you need to let users sign in with Google/GitHub, when your app needs to access user data from another service (calendar, repositories), or when building APIs that third-party developers will integrate with. OAuth2 handles authorization; add OpenID Connect (OIDC) on top for authentication and user identity."
  },
  {
    question: "Which OAuth2 flow should I use for my app?",
    answer: "Authorization Code + PKCE: for SPAs, mobile apps, and any public client — this is the modern standard. Authorization Code (with client secret): for server-side apps where the secret stays on the server. Client Credentials: for machine-to-machine (M2M) APIs, backend services, and cron jobs — no user involved. Device Code: for CLI tools, smart TVs, and IoT devices without a browser. Implicit flow is deprecated — never use it for new apps."
  },
  {
    question: "What is PKCE and why is it required for SPAs?",
    answer: "PKCE (Proof Key for Code Exchange) prevents authorization code interception attacks. In SPAs and mobile apps, you cannot safely store a client secret — the code is visible to users. PKCE replaces the client secret with a cryptographic challenge: the app generates a random verifier, hashes it (code_challenge), sends the hash with the auth request, then sends the verifier when exchanging the code for tokens. The server verifies the verifier matches the challenge — an intercepted code is useless without the verifier."
  },
  {
    question: "What is the difference between access tokens and refresh tokens?",
    answer: "Access tokens are short-lived credentials (typically 15 minutes to 1 hour) sent with every API request as a Bearer token. Refresh tokens are long-lived (days to weeks) and used only to get new access tokens when they expire. Store access tokens in memory (not localStorage) to reduce XSS risk. Store refresh tokens in httpOnly cookies for web apps. When an access token expires, use the refresh token to get a new one without prompting the user to log in again."
  },
  {
    question: "How do I implement OAuth2 in a Next.js app?",
    answer: "Use next-auth (Auth.js) — it handles the OAuth2/OIDC flow, session management, and token refresh automatically for 50+ providers. Configure providers in route.ts under app/api/auth/[...nextauth]/route.ts. For custom OAuth: store the code_verifier in a server-side session during the redirect, exchange the code server-side in a route handler (never in client components), and store tokens securely in httpOnly cookies or your database."
  },
  {
    question: "What is OpenID Connect (OIDC) and how does it relate to OAuth2?",
    answer: "OIDC is an identity layer built on top of OAuth2. OAuth2 handles authorization (can this app access this resource?), but says nothing about user identity. OIDC adds an ID token (JWT) containing user claims (sub, email, name, picture) and standardizes the /userinfo endpoint. When you add openid to the OAuth2 scope, you get both an access token (for API calls) and an ID token (for authentication). Most identity providers (Google, Microsoft, GitHub) support OIDC."
  },
];
---

<BaseLayout
  title="OAuth2 Flow Visualizer — Authorization Code, PKCE, Client Credentials"
  description="Visualize OAuth2 authorization flows step by step. Compare Authorization Code, PKCE, Implicit, Client Credentials, and Device Code flows. Includes JavaScript code examples. Free, runs in your browser."
  tool="oauth2 flow visualizer, oauth2 authorization code flow, pkce flow diagram, client credentials flow, oauth2 explained, oauth2 diagram"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "OAuth2 Flow Visualizer",
    "url": "https://devplaybook.cc/tools/oauth2-flow-visualizer",
    "description": "Visualize OAuth2 authorization flows. Step-by-step diagrams for Authorization Code, PKCE, Implicit, Client Credentials, and Device Code flows with JavaScript code examples.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">OAuth2 Flow Visualizer</h1>
  <p class="text-text-muted mb-4">
    Understand <strong>OAuth2 authorization flows</strong> with interactive step-by-step diagrams. Compare Authorization Code, PKCE, Client Credentials, Device Code, and the deprecated Implicit flow. Includes JavaScript code examples for each flow.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 OAuth2 flows</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Step-by-step diagram</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> JS code examples</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Token explanations</span>
  </div>
  <OAuth2FlowVisualizer client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="OAuth2 Flow Visualizer" relatedTags={['authentication', 'oauth', 'security', 'api', 'javascript', 'developer-tools']} />
</BaseLayout>
