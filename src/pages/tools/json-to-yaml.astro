---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonYamlConverter from '../../components/JsonYamlConverter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is YAML?", answer: "YAML (YAML Ain't Markup Language) is a human-readable data serialization format. It uses indentation to represent structure and is commonly used for configuration files (Docker Compose, Kubernetes, GitHub Actions, Ansible)." },
  { question: "When should I use YAML instead of JSON?", answer: "Use YAML for configuration files that humans write and read — it's more concise and supports comments. Use JSON for API responses and data interchange — it's stricter and universally supported." },
  { question: "Can YAML represent everything JSON can?", answer: "Yes. YAML is a superset of JSON. Every valid JSON document is also valid YAML. The converter handles objects, arrays, strings, numbers, booleans, and null values." },
  { question: "Does the converter handle nested structures?", answer: "Yes. Nested objects and arrays are correctly converted using YAML's indentation-based structure. The JSON → YAML direction handles arbitrary depth." },
];
---

<BaseLayout
  title="JSON to YAML Converter — Free Online Tool"
  description="Convert JSON to YAML or YAML to JSON instantly. Handles nested objects, arrays, and all value types. Free online converter, runs in your browser."
  tool="JSON to YAML converter, YAML to JSON converter, JSON YAML online, convert JSON YAML"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">JSON ↔ YAML Converter</h1>
  <p class="text-text-muted mb-4">Convert between JSON and YAML formats instantly. Useful for converting API responses to config files, or vice versa. Handles nested structures, arrays, and all scalar types. Runs entirely in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No data leaves your machine</span>
  </div>
  <JsonYamlConverter client:only="preact" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more free developer tools?</p>
    <a href="/tools" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Browse All Free Tools →</a>
  </div>
  <ToolPageCta currentTool="JSON to YAML Converter" relatedTags={['json', 'yaml', 'converter', 'config']} />
</BaseLayout>
