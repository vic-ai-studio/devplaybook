---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Protocol Buffers (protobuf)?", answer: "Protocol Buffers (protobuf) is Google's language-neutral, platform-neutral, extensible mechanism for serializing structured data. You define your data structure once in a .proto file, then use generated code to write and read structured data to and from various data streams. It's faster and smaller than JSON or XML, and widely used in gRPC microservices." },
  { question: "How does this Protobuf to JSON converter work?", answer: "This tool parses your .proto message definition in the browser — no server calls are made. It reads field names and types, then generates a sample JSON object with appropriate placeholder values for each field type. Nested messages become nested JSON objects, and repeated fields become JSON arrays." },
  { question: "What proto field types are supported?", answer: "The converter supports all common scalar types: string, int32, int64, uint32, uint64, sint32, sint64, fixed32, fixed64, sfixed32, sfixed64, bool, double, float, and bytes. It also handles repeated fields (arrays), nested message types, and enum fields (shown as 0)." },
  { question: "What is the difference between proto2 and proto3?", answer: "Proto3 is the newer version and the default for most new projects. It removes required fields, makes all fields optional by default, and uses 0/empty as default values. Proto2 supports required/optional/repeated labels. This tool supports both syntaxes for field parsing, though the sample output follows proto3 conventions." },
  { question: "Can this tool convert a real protobuf binary to JSON?", answer: "No — this tool converts .proto schema definitions to a sample JSON structure. To convert actual binary protobuf data to JSON at runtime, use tools like protoc, grpc-gateway, or libraries like google-protobuf (JavaScript) or protobuf (Python)." },
  { question: "Why use protobuf instead of JSON?", answer: "Protobuf is 3-10x smaller than equivalent JSON and 5-10x faster to serialize/deserialize. It enforces a schema, catches type errors at compile time, and generates strongly-typed code in many languages. The tradeoff is that binary data is not human-readable without a .proto definition." },
];
---

<BaseLayout
  title="Protobuf to JSON Converter — Convert .proto to Sample JSON"
  description="Convert Protocol Buffer (.proto) message definitions to sample JSON. Paste your .proto schema and get a JSON object with correct field names and types. Free, runs in your browser."
  tool="protobuf to JSON, proto to JSON, .proto converter, protocol buffers JSON, proto schema to JSON sample, grpc JSON"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Protobuf to JSON Converter",
    "url": "https://devplaybook.cc/tools/protobuf-to-json",
    "description": "Convert Protocol Buffer (.proto) message definitions to sample JSON objects. Handles all scalar types, repeated fields, nested messages, and enums.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Protobuf to JSON Converter</h1>
  <p class="text-text-muted mb-4">
    Paste a Protocol Buffer <code class="bg-bg-secondary px-1 rounded text-sm">.proto</code> message definition
    and get a sample JSON object with correct field names and appropriate type values.
    Supports all scalar types, repeated fields, nested messages, and enums.
    Runs entirely in your browser — nothing is sent to a server.
  </p>
  <div class="flex items-center gap-3 mb-8 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All proto scalar types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Repeated fields → arrays</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Nested messages → objects</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <!-- Converter -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
    <!-- Input -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <label class="font-semibold text-sm" for="proto-input">.proto Input</label>
        <button id="proto-example" class="text-xs text-primary hover:underline">Load example</button>
      </div>
      <textarea id="proto-input" rows="20"
        placeholder="message User {&#10;  string name = 1;&#10;  int32 age = 2;&#10;  bool active = 3;&#10;}"
        class="w-full bg-bg border border-border rounded-lg px-3 py-3 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40 resize-y"></textarea>
    </div>
    <!-- Output -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <span class="font-semibold text-sm">Sample JSON Output</span>
        <button id="proto-copy" class="text-xs text-primary hover:underline hidden">Copy</button>
      </div>
      <div id="proto-error" class="hidden mb-3 p-3 bg-red-500/10 border border-red-500/20 rounded-lg text-sm text-red-400"></div>
      <textarea id="json-output" rows="20" readonly
        placeholder="Sample JSON will appear here..."
        class="w-full bg-bg border border-border rounded-lg px-3 py-3 text-sm font-mono resize-y text-text-muted focus:outline-none"></textarea>
    </div>
  </div>

  <!-- Message selector -->
  <div id="message-selector-wrap" class="hidden mb-4">
    <label class="text-sm font-semibold mr-2" for="message-select">Convert message:</label>
    <select id="message-select" class="bg-bg-card border border-border rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40"></select>
  </div>

  <div class="flex gap-3 mb-8">
    <button id="proto-convert" class="bg-primary text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-primary/80 transition-colors">
      Convert to JSON
    </button>
    <button id="proto-clear" class="text-sm text-text-muted hover:text-red-400 transition-colors">Clear</button>
  </div>

  <!-- Type reference -->
  <div class="bg-bg-card border border-border rounded-xl p-6 mb-8">
    <h2 class="font-bold text-sm uppercase tracking-wide text-text-muted mb-4">Proto Type → JSON Value Reference</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border">
            <th class="text-left py-2 pr-4 text-text-muted font-medium">Proto Type</th>
            <th class="text-left py-2 pr-4 text-text-muted font-medium">JSON Value</th>
            <th class="text-left py-2 text-text-muted font-medium">Notes</th>
          </tr>
        </thead>
        <tbody class="text-xs text-text-muted">
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-mono">string</td><td class="pr-4 font-mono">"string"</td><td>UTF-8 text</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-mono">int32 / sint32</td><td class="pr-4 font-mono">0</td><td>Signed 32-bit integer</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-mono">int64 / sint64</td><td class="pr-4 font-mono">"0"</td><td>String-encoded for JSON safety</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-mono">uint32 / fixed32</td><td class="pr-4 font-mono">0</td><td>Unsigned 32-bit integer</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-mono">uint64 / fixed64</td><td class="pr-4 font-mono">"0"</td><td>String-encoded for JSON safety</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-mono">bool</td><td class="pr-4 font-mono">false</td><td>Boolean</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-mono">double / float</td><td class="pr-4 font-mono">0.0</td><td>Floating point</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-mono">bytes</td><td class="pr-4 font-mono">"base64string"</td><td>Base64-encoded</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4 font-mono">repeated T</td><td class="pr-4 font-mono">[sample]</td><td>JSON array with one sample item</td></tr>
          <tr><td class="py-2 pr-4 font-mono">message M</td><td class="pr-4 font-mono">&#123; ... &#125;</td><td>Nested JSON object</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <AffiliateSection />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Protobuf to JSON Converter" relatedTags={['protobuf', 'json', 'grpc', 'converter', 'api', 'schema']} />
</BaseLayout>

<script is:inline>
(function () {
  // ── Proto parser ─────────────────────────────────────────────────────────────
  var SCALAR_DEFAULTS = {
    'string': 'string',
    'bool': false,
    'double': 0.0,
    'float': 0.0,
    'int32': 0,
    'int64': '0',
    'uint32': 0,
    'uint64': '0',
    'sint32': 0,
    'sint64': '0',
    'fixed32': 0,
    'fixed64': '0',
    'sfixed32': 0,
    'sfixed64': '0',
    'bytes': 'base64string',
  };

  function parseMessages(raw) {
    // Remove single-line comments
    var src = raw.replace(/\/\/.*/g, '').replace(/\/\*[\s\S]*?\*\//g, '');
    var messages = {};
    var enums = {};

    // Parse enums
    var enumRe = /\benum\s+(\w+)\s*\{([^}]*)\}/g;
    var em;
    while ((em = enumRe.exec(src)) !== null) {
      enums[em[1]] = true;
    }

    // Parse messages (top-level only for simplicity)
    var msgRe = /\bmessage\s+(\w+)\s*\{([\s\S]*?)\}/g;
    var m;
    while ((m = msgRe.exec(src)) !== null) {
      var name = m[1];
      var body = m[2];
      messages[name] = parseFields(body, messages, enums);
    }
    return messages;
  }

  function parseFields(body, messages, enums) {
    var obj = {};
    var lines = body.split('\n');
    for (var i = 0; i < lines.length; i++) {
      var line = lines[i].trim();
      if (!line || line.startsWith('//') || line.startsWith('option ') || line.startsWith('reserved ')) continue;

      // repeated type name = N;
      var repMatch = line.match(/^repeated\s+(\S+)\s+(\w+)\s*=/);
      if (repMatch) {
        var repType = repMatch[1];
        var repName = repMatch[2];
        obj[repName] = [getSample(repType, messages, enums)];
        continue;
      }

      // optional/required/type name = N;
      var fieldMatch = line.match(/^(?:optional\s+|required\s+)?(\S+)\s+(\w+)\s*=/);
      if (fieldMatch) {
        var fType = fieldMatch[1];
        var fName = fieldMatch[2];
        if (fType === 'repeated' || fType === 'optional' || fType === 'required') continue; // already handled or malformed
        obj[fName] = getSample(fType, messages, enums);
      }
    }
    return obj;
  }

  function getSample(type, messages, enums) {
    if (SCALAR_DEFAULTS.hasOwnProperty(type)) return SCALAR_DEFAULTS[type];
    if (enums && enums[type]) return 0;
    if (messages && messages[type]) return messages[type];
    // Unknown nested message or map — return empty object
    return {};
  }

  // ── Example ──────────────────────────────────────────────────────────────────
  var EXAMPLE = [
    'syntax = "proto3";',
    '',
    'message Address {',
    '  string street = 1;',
    '  string city = 2;',
    '  string country = 3;',
    '  string zip_code = 4;',
    '}',
    '',
    'message User {',
    '  int32 id = 1;',
    '  string name = 2;',
    '  string email = 3;',
    '  bool active = 4;',
    '  int64 created_at = 5;',
    '  Address address = 6;',
    '  repeated string roles = 7;',
    '  bytes avatar = 8;',
    '  double score = 9;',
    '}',
    '',
    'message ListUsersResponse {',
    '  repeated User users = 1;',
    '  int32 total = 2;',
    '  string next_page_token = 3;',
    '}',
  ].join('\n');

  // ── UI ────────────────────────────────────────────────────────────────────────
  var parsedMessages = {};

  document.getElementById('proto-example').addEventListener('click', function() {
    document.getElementById('proto-input').value = EXAMPLE;
  });

  document.getElementById('proto-clear').addEventListener('click', function() {
    document.getElementById('proto-input').value = '';
    document.getElementById('json-output').value = '';
    document.getElementById('proto-error').classList.add('hidden');
    document.getElementById('proto-copy').classList.add('hidden');
    document.getElementById('message-selector-wrap').classList.add('hidden');
    document.getElementById('message-select').innerHTML = '';
    parsedMessages = {};
  });

  document.getElementById('proto-convert').addEventListener('click', function() {
    var raw = document.getElementById('proto-input').value.trim();
    var errEl = document.getElementById('proto-error');
    var outEl = document.getElementById('json-output');
    var copyBtn = document.getElementById('proto-copy');
    var selectorWrap = document.getElementById('message-selector-wrap');
    var selector = document.getElementById('message-select');

    errEl.classList.add('hidden');
    outEl.value = '';
    copyBtn.classList.add('hidden');
    selectorWrap.classList.add('hidden');

    if (!raw) {
      errEl.textContent = 'Please paste a .proto definition first.';
      errEl.classList.remove('hidden');
      return;
    }

    try {
      parsedMessages = parseMessages(raw);
      var names = Object.keys(parsedMessages);
      if (names.length === 0) throw new Error('No message definitions found. Make sure your .proto contains at least one "message" block.');

      if (names.length > 1) {
        selector.innerHTML = '';
        names.forEach(function(n) {
          var opt = document.createElement('option');
          opt.value = n;
          opt.textContent = n;
          selector.appendChild(opt);
        });
        selectorWrap.classList.remove('hidden');
      }

      outEl.value = JSON.stringify(parsedMessages[names[0]], null, 2);
      copyBtn.classList.remove('hidden');
    } catch (e) {
      errEl.textContent = 'Parse error: ' + (e.message || String(e));
      errEl.classList.remove('hidden');
    }
  });

  document.getElementById('message-select').addEventListener('change', function() {
    var name = this.value;
    if (parsedMessages[name]) {
      document.getElementById('json-output').value = JSON.stringify(parsedMessages[name], null, 2);
    }
  });

  document.getElementById('proto-copy').addEventListener('click', function() {
    var val = document.getElementById('json-output').value;
    if (val) navigator.clipboard && navigator.clipboard.writeText(val);
    this.textContent = 'Copied!';
    var btn = this;
    setTimeout(function() { btn.textContent = 'Copy'; }, 2000);
  });
})();
</script>
