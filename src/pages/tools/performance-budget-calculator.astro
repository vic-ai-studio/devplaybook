---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PerformanceBudgetCalculator from '../../components/PerformanceBudgetCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is a web performance budget?", answer: "A performance budget is a set of limits on metrics that affect web performance — most commonly resource sizes (JavaScript, CSS, images) and Core Web Vitals. Teams use budgets to enforce performance standards in CI/CD pipelines: a PR that exceeds the budget fails the build. This prevents gradual performance degradation over time." },
  { question: "What are the recommended JavaScript bundle size budgets?", answer: "Google recommends keeping total JavaScript under 300KB (compressed). For a fast Time to Interactive on 3G, aim for under 170KB. In practice, a reasonable budget for a modern SPA is 200KB compressed JS, 50KB CSS, and 400KB images per page. Adjust based on your actual traffic — a developer tools site has a different audience than an e-commerce store." },
  { question: "What are Core Web Vitals and why do they matter for SEO?", answer: "Core Web Vitals (LCP, FID/INP, CLS) are Google's user experience signals used directly in search ranking. LCP (Largest Contentful Paint) measures perceived load speed, FID/INP measures interactivity, and CLS measures visual stability. Pages scoring 'Good' on all three have a ranking advantage. As of 2024, INP (Interaction to Next Paint) has replaced FID as an official CWV." },
  { question: "How do I estimate page load time from file sizes?", answer: "Rough formula: load time (ms) = (total size in KB × 8) / connection speed in Kbps × 1000. A 500KB page on 4G (25 Mbps) takes about 160ms for raw transfer — but actual Time to Interactive is 3-10× longer due to DNS, TCP, TLS handshake, parsing, and rendering. Use this calculator for budgeting guidance, not precise predictions." },
  { question: "What tools can measure my actual Core Web Vitals?", answer: "Use Google PageSpeed Insights for field and lab data, Chrome DevTools (Lighthouse panel) for local testing, and Web Vitals Chrome extension for real-time measurement. For CI/CD integration, use Lighthouse CI. For production monitoring, Google Search Console's Core Web Vitals report shows real-user data." },
];
---

<BaseLayout
  title="Web Performance Budget Calculator — JS/CSS/Image Size + Core Web Vitals"
  description="Set performance budgets for JavaScript, CSS, images, and fonts. Enter actual sizes to get a pass/fail report. Define Core Web Vitals targets (LCP, FID, CLS, FCP, TTFB) with Good/Poor thresholds. Free, runs in your browser."
  tool="Performance Budget Calculator, Web Performance Budget, Core Web Vitals Calculator, LCP FID CLS Budget, JavaScript Bundle Size Budget"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Web Performance Budget Calculator</h1>
  <p class="text-text-muted mb-4">Define resource size budgets (JS, CSS, images, fonts) and Core Web Vitals targets. Enter your actual sizes to instantly see pass/fail status, estimated load times, and what's over budget.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Resource size budgets with pass/fail</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Core Web Vitals thresholds</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 3G/4G/Cable load time estimate</span>
  </div>
  <PerformanceBudgetCalculator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Web Performance Budget Calculator" relatedTags={['performance', 'web-vitals', 'optimization', 'analytics', 'developer-tools']} />
</BaseLayout>
