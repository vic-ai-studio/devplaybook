---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is a deep link?",
    answer: "A deep link is a URI that opens a specific location inside a mobile app rather than just launching the app home screen. For example, myapp://product/123 opens the product detail screen for item 123. Deep links work via URL schemes registered in the app's Info.plist (iOS) or AndroidManifest.xml (Android)."
  },
  {
    question: "What is the difference between URI schemes and Universal Links?",
    answer: "URI schemes (myapp://) are custom protocols registered by the app. They work on device but cannot be opened from a standard browser link without a fallback. Universal Links (iOS) and App Links (Android) use HTTPS URLs that open the app if installed, or fall back to the website if not — they require a verified association file on your server."
  },
  {
    question: "How do I test deep links on iOS?",
    answer: "On iOS simulator: use xcrun simctl openurl booted 'myapp://path'. On a real device: paste the URI into Safari address bar (not Google app), or use a notes app link. In Xcode, use the 'Open URL' scheme in the Run dialog. For Universal Links, use the Notes app — type the URL, long press, and tap Open."
  },
  {
    question: "How do I test deep links on Android?",
    answer: "Use adb: adb shell am start -W -a android.intent.action.VIEW -d 'myapp://path' com.example.app. In Android Studio, use the deeplink attribute in the navigation editor. On device, open Chrome and type the URI in the address bar. For App Links, use: adb shell am start -a android.intent.action.VIEW -c android.intent.category.BROWSABLE -d 'https://yoursite.com/path'"
  },
  {
    question: "What is a deferred deep link?",
    answer: "A deferred deep link routes a new user who does not have the app installed to the App Store/Play Store, then opens the intended deep link after install and first launch. This is used in marketing campaigns. Branch.io, Firebase Dynamic Links (deprecated), and Adjust all provide deferred deep linking as a service."
  }
];
---

<BaseLayout
  title="Deep Link Tester — Build and Test Mobile App Deep Links"
  description="Build and test mobile app deep links and URI schemes. Generate deep link URLs, adb commands, and xcrun test commands for iOS and Android. Free browser tool."
  tool="deep link tester, URI scheme builder, mobile deep link, app link tester, universal link tester, Android deep link, iOS deep link"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Deep Link Tester",
    "url": "https://devplaybook.cc/tools/deep-link-tester",
    "description": "Build and test mobile app deep links and URI schemes. Generate deep link URLs with adb and xcrun test commands for iOS and Android.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Deep Link Tester</h1>
  <p class="text-text-muted mb-4">Build mobile app deep link URIs, Universal Links, and App Links. Get ready-to-run test commands for iOS (xcrun) and Android (adb).</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> URI scheme builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> adb + xcrun commands</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Query param encoder</span>
  </div>

  <!-- Builder -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4 space-y-3">
    <h2 class="text-sm font-semibold">Build Deep Link</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <div>
        <label class="block text-xs text-text-muted mb-1">Link Type</label>
        <select id="f-type" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="custom">Custom URI Scheme</option>
          <option value="universal">Universal Link / App Link (HTTPS)</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1" id="scheme-label">Scheme (e.g. myapp)</label>
        <input id="f-scheme" type="text" placeholder="myapp" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
      </div>
    </div>
    <div>
      <label class="block text-xs text-text-muted mb-1">Path (e.g. /product/123)</label>
      <input id="f-path" type="text" placeholder="/product/123" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
    </div>

    <!-- Query params -->
    <div>
      <div class="flex items-center justify-between mb-2">
        <label class="text-xs text-text-muted">Query Parameters</label>
        <button id="btn-add-param" class="text-xs text-primary hover:underline">+ Add param</button>
      </div>
      <div id="params-list" class="space-y-2"></div>
    </div>
  </div>

  <!-- Output -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <div class="flex items-center justify-between mb-2">
      <h2 class="text-sm font-semibold">Deep Link URL</h2>
      <button id="btn-copy-url" class="px-3 py-1.5 bg-primary text-white rounded-lg text-xs font-medium hover:bg-primary/90 transition-colors">Copy URL</button>
    </div>
    <div id="output-url" class="bg-surface rounded-lg px-3 py-2 text-sm font-mono text-accent break-all mb-1"></div>
    <p id="msg-url" class="text-xs text-green-400 hidden">Copied!</p>
  </div>

  <!-- Test commands -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-sm font-semibold">iOS — xcrun simctl</h2>
        <button id="btn-copy-ios" class="px-3 py-1.5 bg-surface border border-border rounded-lg text-xs font-medium hover:bg-bg-card transition-colors">Copy</button>
      </div>
      <pre id="cmd-ios" class="bg-surface rounded-lg p-3 text-xs font-mono text-text-muted whitespace-pre-wrap break-all"></pre>
    </div>
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-sm font-semibold">Android — adb</h2>
        <button id="btn-copy-adb" class="px-3 py-1.5 bg-surface border border-border rounded-lg text-xs font-medium hover:bg-bg-card transition-colors">Copy</button>
      </div>
      <pre id="cmd-adb" class="bg-surface rounded-lg p-3 text-xs font-mono text-text-muted whitespace-pre-wrap break-all"></pre>
    </div>
  </div>

  <!-- Presets -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-semibold mb-2">Common Presets</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2" id="presets"></div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Deep Link Tester" relatedTags={['mobile', 'ios', 'android', 'testing', 'react-native']} />
</BaseLayout>

<script is:inline>
(function() {
  var PRESETS = [
    { label: 'Product page', scheme: 'myapp', path: '/product/123', params: [{ k: 'ref', v: 'home' }] },
    { label: 'User profile', scheme: 'myapp', path: '/user/456', params: [] },
    { label: 'Promo campaign', scheme: 'myapp', path: '/promo', params: [{ k: 'code', v: 'SUMMER' }, { k: 'source', v: 'email' }] },
    { label: 'Universal Link', scheme: 'https://app.example.com', path: '/invite/abc', params: [{ k: 'token', v: 'xyz' }], universal: true }
  ];

  var params = [];

  function getLink() {
    var type = document.getElementById('f-type').value;
    var scheme = document.getElementById('f-scheme').value.trim();
    var path = document.getElementById('f-path').value.trim() || '/';
    if (!path.startsWith('/')) path = '/' + path;

    var qs = params
      .filter(function(p) { return p.k; })
      .map(function(p) { return encodeURIComponent(p.k) + '=' + encodeURIComponent(p.v); })
      .join('&');

    var url;
    if (type === 'universal') {
      var host = scheme || 'app.example.com';
      host = host.replace(/^https?:\/\//, '');
      url = 'https://' + host + path + (qs ? '?' + qs : '');
    } else {
      var s = (scheme || 'myapp').replace(/:\/\/$/, '');
      url = s + ':/' + path + (qs ? '?' + qs : '');
    }
    return url;
  }

  function render() {
    var url = getLink();
    document.getElementById('output-url').textContent = url;
    document.getElementById('cmd-ios').textContent = 'xcrun simctl openurl booted \'' + url + '\'';
    document.getElementById('cmd-adb').textContent = 'adb shell am start \\\n  -a android.intent.action.VIEW \\\n  -c android.intent.category.BROWSABLE \\\n  -d \'' + url + '\'';
  }

  function renderParams() {
    var list = document.getElementById('params-list');
    list.innerHTML = params.map(function(p, i) {
      return '<div class="flex gap-2 items-center" data-idx="' + i + '">' +
        '<input type="text" placeholder="key" value="' + (p.k || '') + '" data-field="k" class="flex-1 bg-surface border border-border rounded-lg px-3 py-2 text-xs font-mono focus:outline-none focus:border-primary" />' +
        '<span class="text-text-muted text-xs">=</span>' +
        '<input type="text" placeholder="value" value="' + (p.v || '') + '" data-field="v" class="flex-1 bg-surface border border-border rounded-lg px-3 py-2 text-xs font-mono focus:outline-none focus:border-primary" />' +
        '<button data-remove="' + i + '" class="text-red-400 hover:text-red-300 text-lg leading-none px-1">x</button>' +
        '</div>';
    }).join('');

    list.querySelectorAll('input').forEach(function(inp) {
      inp.addEventListener('input', function() {
        var idx = parseInt(inp.closest('[data-idx]').dataset.idx);
        params[idx][inp.dataset.field] = inp.value;
        render();
      });
    });

    list.querySelectorAll('[data-remove]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        params.splice(parseInt(btn.dataset.remove), 1);
        renderParams();
        render();
      });
    });
  }

  document.getElementById('btn-add-param').addEventListener('click', function() {
    params.push({ k: '', v: '' });
    renderParams();
  });

  ['f-type', 'f-scheme', 'f-path'].forEach(function(id) {
    document.getElementById(id).addEventListener('input', render);
    document.getElementById(id).addEventListener('change', render);
  });

  document.getElementById('f-type').addEventListener('change', function() {
    var isUniversal = this.value === 'universal';
    document.getElementById('scheme-label').textContent = isUniversal ? 'Host (e.g. app.example.com)' : 'Scheme (e.g. myapp)';
    document.getElementById('f-scheme').placeholder = isUniversal ? 'app.example.com' : 'myapp';
  });

  function copyText(text, msgId) {
    navigator.clipboard.writeText(text).then(function() {
      var el = document.getElementById(msgId);
      if (el) { el.classList.remove('hidden'); setTimeout(function() { el.classList.add('hidden'); }, 2000); }
    });
  }

  document.getElementById('btn-copy-url').addEventListener('click', function() { copyText(getLink(), 'msg-url'); });
  document.getElementById('btn-copy-ios').addEventListener('click', function() { copyText(document.getElementById('cmd-ios').textContent, null); });
  document.getElementById('btn-copy-adb').addEventListener('click', function() { copyText(document.getElementById('cmd-adb').textContent, null); });

  // Presets
  document.getElementById('presets').innerHTML = PRESETS.map(function(p, i) {
    return '<button data-preset="' + i + '" class="text-left px-3 py-2 bg-surface border border-border rounded-lg text-xs hover:bg-bg-card transition-colors">' + p.label + '</button>';
  }).join('');

  document.querySelectorAll('[data-preset]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var p = PRESETS[parseInt(btn.dataset.preset)];
      document.getElementById('f-type').value = p.universal ? 'universal' : 'custom';
      document.getElementById('f-scheme').value = p.scheme;
      document.getElementById('f-path').value = p.path;
      params = (p.params || []).map(function(x) { return { k: x.k, v: x.v }; });
      renderParams();
      render();
    });
  });

  render();
})();
</script>
