---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ApiKeyGenerator from '../../components/ApiKeyGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What key formats does this tool support?",
    answer: "Six formats: Hex (0-9, a-f), Base64 URL-safe (A-Z, a-z, 0-9, -, _), UUID v4 (standard 8-4-4-4-12 format), JWT-style (three dot-separated base64url segments), Alphanumeric (A-Z, a-z, 0-9), and Numeric (0-9 only). Each has different entropy per character — hex gives 4 bits/char, base64 gives 6 bits/char."
  },
  {
    question: "Is this tool cryptographically secure?",
    answer: "Yes. All keys are generated using crypto.getRandomValues() — the Web Crypto API backed by your OS's CSPRNG. This is the same source used by TLS, password managers, and secure token libraries. Nothing is sent to any server."
  },
  {
    question: "How long should my API key be?",
    answer: "For most use cases, 128-bit (32 hex chars or 22 base64url chars) is the minimum. 256-bit (64 hex chars) is recommended for long-lived keys or sensitive APIs. UUID v4 provides 122 bits of entropy. JWT-style tokens in this tool provide ~512 bits."
  },
  {
    question: "What is a good prefix format for API keys?",
    answer: "Prefixes help identify key type and owner at a glance. Common patterns: sk_ (secret key, e.g. Stripe), pk_ (public key), sk-live_ / sk-test_ (environment scoping), or a service abbreviation like myapp_. Prefixes don't add entropy but improve operability."
  },
  {
    question: "When should I use UUID vs hex vs base64?",
    answer: "UUID is best when you need a standard interoperable identifier (databases, REST resources, logs). Hex is readable, easy to debug, and works in any context. Base64 URL is compact — 32 chars gives 192 bits of entropy vs 128 bits for hex of the same length. Use base64url for tokens stored in headers or URLs."
  },
  {
    question: "How do I store API keys securely?",
    answer: "Never commit keys to source control. Store them in environment variables, a secrets manager (AWS Secrets Manager, HashiCorp Vault, Doppler), or your CI/CD platform's secret store. On the server side, store only a bcrypt/SHA-256 hash of the key and verify against it — never store plaintext."
  },
];
---

<BaseLayout
  title="API Key Generator — Secure Hex, UUID, JWT-style & Base64 Keys"
  description="Generate cryptographically secure API keys in your browser. Choose from hex, UUID v4, JWT-style, base64url, alphanumeric, or numeric formats. Add prefixes, grouping, and generate up to 20 keys at once."
  tool="API Key Generator, Secure Token Generator, UUID Generator, Random Key Generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "API Key Generator",
    "url": "https://devplaybook.cc/tools/api-key-generator",
    "description": "Generate cryptographically secure API keys in your browser using crypto.getRandomValues(). Supports hex, UUID v4, JWT-style, base64url, alphanumeric, and numeric formats.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">API Key Generator</h1>
  <p class="text-text-muted mb-4">
    Generate cryptographically secure API keys, tokens, and secrets — entirely in your browser.
    Choose format, length, prefix, and grouping. Uses <code class="font-mono bg-surface px-1 rounded text-sm">crypto.getRandomValues()</code> — nothing is sent to any server.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 6 key formats</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Cryptographically secure</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <ApiKeyGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="API Key Generator" relatedTags={['security', 'api', 'authentication', 'tokens', 'developer-tools']} />
</BaseLayout>
