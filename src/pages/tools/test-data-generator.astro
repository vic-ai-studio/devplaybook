---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TestDataGenerator from '../../components/TestDataGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "Is the generated data safe to use in production?",
    answer: "No — test data is intentionally fake and should only be used in development, staging, or automated test environments. Never seed a production database with generated records, as names, emails, and phone numbers are fabricated from static arrays and do not belong to real people."
  },
  {
    question: "Does this tool send data to any server?",
    answer: "No. All data generation happens entirely in your browser using a seeded pseudo-random number generator (PRNG). No network requests are made, nothing is logged, and no generated data ever leaves your machine."
  },
  {
    question: "What is the password field format?",
    answer: "The password field generates a bcrypt-style placeholder string in the format $2b$NN$<53-char-hash>. This mimics the output of real bcrypt hashing libraries (like bcryptjs or passlib) but is not a real hash — it is just a realistic-looking placeholder for UI and schema testing."
  },
  {
    question: "Why does the CSV output expand address into multiple columns?",
    answer: "CSV and SQL formats require flat key-value rows with no nested objects. When the address field is selected, it is automatically expanded into four separate columns: address_street, address_city, address_state, and address_zip. JSON and TypeScript outputs preserve the nested address object."
  },
  {
    question: "How do I use the SQL output in my database?",
    answer: "The SQL output generates a single INSERT INTO users (...) VALUES ... statement. Copy it directly into your database client (psql, MySQL Workbench, DBeaver, etc.) and run it. You may need to rename the table or column names to match your actual schema. Column types should be VARCHAR or TEXT for most fields, INTEGER for age."
  },
  {
    question: "Can I generate more than 100 records?",
    answer: "The tool caps at 100 records per generation to keep the browser UI responsive. If you need thousands of records, generate in multiple batches and concatenate the output files, or use a server-side library like Faker.js (Node.js) or Faker (Python) for large-scale datasets."
  },
];
---

<BaseLayout
  title="Test Data Generator — Generate Fake JSON, CSV, SQL & TypeScript Test Data"
  description="Generate realistic fake test data instantly in your browser. Choose fields like name, email, address, UUID, and more. Export as JSON array, CSV, SQL INSERT, or TypeScript. No server, no signup."
  tool="Test Data Generator, Fake Data Generator, Mock Data Generator, JSON Data Generator, CSV Data Generator, SQL Seed Data"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Test Data Generator",
    "url": "https://devplaybook.cc/tools/test-data-generator",
    "description": "Generate realistic fake test data (JSON, CSV, SQL INSERT, TypeScript) in your browser. Fields include UUID, name, email, phone, address, company, job title, avatar, and timestamps.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Test Data Generator</h1>
  <p class="text-text-muted mb-4">
    Generate realistic fake records for development, unit tests, and database seeding.
    Pick your fields, choose JSON, CSV, SQL, or TypeScript output, then download or copy instantly —
    entirely in your browser, no server required.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 17 field types including UUID, address, avatar</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> JSON, CSV, SQL INSERT, TypeScript export</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100% browser-side, zero network calls</span>
  </div>
  <TestDataGenerator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Test Data Generator" relatedTags={['testing', 'javascript', 'typescript', 'developer-tools', 'data-generation']} />
</BaseLayout>
