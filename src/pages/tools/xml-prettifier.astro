---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is XML prettifying / formatting?", answer: "XML prettifying takes minified or poorly-formatted XML and outputs it with consistent indentation, line breaks, and readable structure. It's the same as 'beautifying' or 'formatting' XML. The resulting XML is semantically identical to the input — only whitespace changes." },
  { question: "How does this XML prettifier work?", answer: "The tool parses your XML using the browser's built-in DOMParser, then serializes it back with proper indentation using a recursive tree walker. This approach handles all valid XML including namespaces, CDATA sections, processing instructions, and comments. It runs 100% in your browser with no server calls." },
  { question: "What is the difference between XML and HTML?", answer: "XML is a strict markup language where all tags must be closed, attribute values must be quoted, and tag names are case-sensitive. HTML is more lenient (e.g., self-closing void elements are optional). XML is used for data exchange (RSS, SOAP, SVG, config files) while HTML is the language of web pages." },
  { question: "Can I use this to validate XML?", answer: "The tool uses DOMParser which will catch well-formedness errors (unclosed tags, mismatched tags, invalid characters). If your XML has errors, the error will be shown. However, this is not a full schema validator — it checks XML well-formedness, not validity against a DTD or XSD schema." },
  { question: "What do the element count and attribute count stats mean?", answer: "Element count is the total number of XML elements (tags) in the document. Attribute count is the total number of attributes across all elements. These quick stats help you understand the document structure at a glance." },
  { question: "What is CDATA in XML?", answer: "CDATA (Character Data) sections let you include text that would normally need to be escaped (like < and &) without escaping it. They're delimited by <![CDATA[ and ]]>. Common in RSS feeds and SOAP messages to wrap HTML content or code snippets inside XML." },
];
---

<BaseLayout
  title="XML Prettifier — Format and Beautify XML Online Free"
  description="Format and prettify XML online. Paste minified or messy XML and get clean indented output. Shows element count and attribute count. Free, runs in your browser, no signup."
  tool="XML prettifier, XML formatter, XML beautifier, format XML online, pretty print XML, XML indent online"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "XML Prettifier",
    "url": "https://devplaybook.cc/tools/xml-prettifier",
    "description": "Format and prettify XML online. Converts minified XML to readable indented output and shows element and attribute counts.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">XML Prettifier</h1>
  <p class="text-text-muted mb-4">
    Paste minified or messy XML and get clean, indented, readable output.
    Also shows element count and attribute count to help understand document structure.
    Uses your browser's native XML parser — nothing is sent to a server.
  </p>
  <div class="flex items-center gap-3 mb-8 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Native browser XML parser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Handles namespaces &amp; CDATA</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Element &amp; attribute counts</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <!-- Indent size selector -->
  <div class="flex items-center gap-4 mb-4">
    <label class="text-sm font-medium">Indent:</label>
    <select id="indent-select" class="bg-bg-card border border-border rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40">
      <option value="2">2 spaces</option>
      <option value="4" selected>4 spaces</option>
      <option value="tab">Tab</option>
    </select>
    <button id="xml-example" class="text-xs text-primary hover:underline ml-auto">Load example</button>
  </div>

  <!-- Converter -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
    <!-- Input -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <label class="font-semibold text-sm" for="xml-input">XML Input</label>
        <span class="text-xs text-text-muted" id="input-size"></span>
      </div>
      <textarea id="xml-input" rows="20"
        placeholder="&lt;?xml version=&quot;1.0&quot;?&gt;&lt;root&gt;&lt;item id=&quot;1&quot;&gt;&lt;name&gt;Test&lt;/name&gt;&lt;/item&gt;&lt;/root&gt;"
        class="w-full bg-bg border border-border rounded-lg px-3 py-3 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40 resize-y"></textarea>
    </div>
    <!-- Output -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <span class="font-semibold text-sm">Formatted XML</span>
        <button id="xml-copy" class="text-xs text-primary hover:underline hidden">Copy</button>
      </div>
      <div id="xml-error" class="hidden mb-3 p-3 bg-red-500/10 border border-red-500/20 rounded-lg text-sm text-red-400"></div>
      <textarea id="xml-output" rows="20" readonly
        placeholder="Formatted XML will appear here..."
        class="w-full bg-bg border border-border rounded-lg px-3 py-3 text-sm font-mono resize-y text-text-muted focus:outline-none"></textarea>
    </div>
  </div>

  <!-- Stats bar -->
  <div id="xml-stats" class="hidden flex flex-wrap gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-lg px-4 py-2 text-sm">
      <span class="text-text-muted">Elements: </span>
      <span id="stat-elements" class="font-semibold text-text">0</span>
    </div>
    <div class="bg-bg-card border border-border rounded-lg px-4 py-2 text-sm">
      <span class="text-text-muted">Attributes: </span>
      <span id="stat-attrs" class="font-semibold text-text">0</span>
    </div>
    <div class="bg-bg-card border border-border rounded-lg px-4 py-2 text-sm">
      <span class="text-text-muted">Root element: </span>
      <span id="stat-root" class="font-mono font-semibold text-text"></span>
    </div>
    <div class="bg-bg-card border border-border rounded-lg px-4 py-2 text-sm">
      <span class="text-text-muted">Output size: </span>
      <span id="stat-size" class="font-semibold text-text"></span>
    </div>
  </div>

  <div class="flex gap-3 mb-8">
    <button id="xml-format" class="bg-primary text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-primary/80 transition-colors">
      Prettify XML
    </button>
    <button id="xml-minify" class="bg-bg-card border border-border text-text px-4 py-2 rounded-lg text-sm font-semibold hover:bg-bg-secondary transition-colors">
      Minify
    </button>
    <button id="xml-clear" class="text-sm text-text-muted hover:text-red-400 transition-colors">Clear</button>
  </div>

  <!-- Quick reference -->
  <div class="bg-bg-card border border-border rounded-xl p-6 mb-8">
    <h2 class="font-bold text-sm uppercase tracking-wide text-text-muted mb-4">XML Structure Reference</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-xs font-mono text-text-muted">
      <div>
        <p class="font-sans font-medium text-text mb-2">Element</p>
        <pre class="bg-bg rounded-lg p-3 overflow-x-auto">&lt;element&gt;content&lt;/element&gt;</pre>
      </div>
      <div>
        <p class="font-sans font-medium text-text mb-2">Attribute</p>
        <pre class="bg-bg rounded-lg p-3 overflow-x-auto">&lt;item id="1" type="a" /&gt;</pre>
      </div>
      <div>
        <p class="font-sans font-medium text-text mb-2">Comment</p>
        <pre class="bg-bg rounded-lg p-3 overflow-x-auto">&lt;!-- comment text --&gt;</pre>
      </div>
      <div>
        <p class="font-sans font-medium text-text mb-2">CDATA</p>
        <pre class="bg-bg rounded-lg p-3 overflow-x-auto">&lt;![CDATA[ raw &lt;data&gt; ]]&gt;</pre>
      </div>
      <div>
        <p class="font-sans font-medium text-text mb-2">Namespace</p>
        <pre class="bg-bg rounded-lg p-3 overflow-x-auto">&lt;ns:tag xmlns:ns="uri" /&gt;</pre>
      </div>
      <div>
        <p class="font-sans font-medium text-text mb-2">Processing Instruction</p>
        <pre class="bg-bg rounded-lg p-3 overflow-x-auto">&lt;?xml version="1.0"?&gt;</pre>
      </div>
    </div>
  </div>

  <AffiliateSection />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="XML Prettifier" relatedTags={['xml', 'formatter', 'prettifier', 'data', 'converter']} />
</BaseLayout>

<script is:inline>
(function () {
  // ── XML prettifier ────────────────────────────────────────────────────────────
  function getIndent(indentVal) {
    if (indentVal === 'tab') return '\t';
    return ' '.repeat(parseInt(indentVal, 10));
  }

  function countNodes(node, counts) {
    if (node.nodeType === 1) { // ELEMENT_NODE
      counts.elements++;
      counts.attrs += node.attributes ? node.attributes.length : 0;
    }
    var children = node.childNodes;
    for (var i = 0; i < children.length; i++) {
      countNodes(children[i], counts);
    }
  }

  function serializeNode(node, depth, indent) {
    var pad = indent.repeat(depth);
    var childPad = indent.repeat(depth + 1);

    if (node.nodeType === 8) { // COMMENT_NODE
      return pad + '<!--' + node.nodeValue + '-->';
    }
    if (node.nodeType === 7) { // PROCESSING_INSTRUCTION_NODE
      return pad + '<?' + node.target + ' ' + node.data + '?>';
    }
    if (node.nodeType === 4) { // CDATA_SECTION_NODE
      return pad + '<![CDATA[' + node.nodeValue + ']]>';
    }
    if (node.nodeType === 3) { // TEXT_NODE
      var text = node.nodeValue.trim();
      if (!text) return null;
      return pad + escXml(text);
    }
    if (node.nodeType === 9) { // DOCUMENT_NODE
      var parts = [];
      for (var ci = 0; ci < node.childNodes.length; ci++) {
        var s = serializeNode(node.childNodes[ci], 0, indent);
        if (s !== null) parts.push(s);
      }
      return parts.join('\n');
    }
    if (node.nodeType !== 1) return null; // skip unknown

    // Build opening tag
    var tag = node.nodeName;
    var attrs = '';
    if (node.attributes) {
      for (var ai = 0; ai < node.attributes.length; ai++) {
        var a = node.attributes[ai];
        attrs += ' ' + a.name + '="' + escXml(a.value) + '"';
      }
    }

    var children = node.childNodes;
    var childParts = [];
    for (var i = 0; i < children.length; i++) {
      var c = serializeNode(children[i], depth + 1, indent);
      if (c !== null) childParts.push(c);
    }

    if (childParts.length === 0) {
      return pad + '<' + tag + attrs + ' />';
    }

    // Single text-only child — keep on one line
    if (childParts.length === 1 && children.length === 1 && children[0].nodeType === 3) {
      var txt = children[0].nodeValue.trim();
      return pad + '<' + tag + attrs + '>' + escXml(txt) + '</' + tag + '>';
    }

    return pad + '<' + tag + attrs + '>\n' + childParts.join('\n') + '\n' + pad + '</' + tag + '>';
  }

  function escXml(s) {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function prettifyXml(raw, indentVal) {
    var parser = new DOMParser();
    var doc = parser.parseFromString(raw, 'application/xml');
    // Check for parse errors
    var parseError = doc.getElementsByTagName('parsererror');
    if (parseError.length > 0) {
      throw new Error(parseError[0].textContent.split('\n')[0] || 'Invalid XML');
    }
    var indent = getIndent(indentVal);
    // Add XML declaration if present in original
    var declaration = '';
    if (raw.trimStart().startsWith('<?xml')) {
      var declMatch = raw.match(/^<\?xml[^?]*\?>/);
      if (declMatch) declaration = declMatch[0] + '\n';
    }
    var serialized = serializeNode(doc, 0, indent);
    // Remove declaration from serialized if we're prepending it
    if (declaration && serialized.startsWith('<?xml')) {
      serialized = serialized.replace(/^<\?xml[^\n]*\n?/, '');
    }
    return (declaration + serialized).trim();
  }

  function minifyXml(raw) {
    var parser = new DOMParser();
    var doc = parser.parseFromString(raw, 'application/xml');
    var parseError = doc.getElementsByTagName('parsererror');
    if (parseError.length > 0) throw new Error(parseError[0].textContent.split('\n')[0] || 'Invalid XML');
    // Use XMLSerializer for minification
    var xs = new XMLSerializer();
    return xs.serializeToString(doc).replace(/>\s+</g, '><').trim();
  }

  // ── Example XML ───────────────────────────────────────────────────────────────
  var EXAMPLE = '<?xml version="1.0" encoding="UTF-8"?><catalog><book id="bk101" category="fiction"><author>Gambardella, Matthew</author><title>XML Developer\'s Guide</title><genre>Computer</genre><price>44.95</price><publish_date>2000-10-01</publish_date><description>An in-depth look at creating applications with XML.</description></book><book id="bk102" category="fiction"><author>Ralls, Kim</author><title>Midnight Rain</title><genre>Fantasy</genre><price>5.95</price><publish_date>2000-12-16</publish_date><description>A former architect battles corporate zombies and evil shareholders.</description></book></catalog>';

  document.getElementById('xml-example').addEventListener('click', function() {
    document.getElementById('xml-input').value = EXAMPLE;
    document.getElementById('input-size').textContent = EXAMPLE.length + ' chars';
  });

  document.getElementById('xml-input').addEventListener('input', function() {
    var len = this.value.length;
    document.getElementById('input-size').textContent = len ? len + ' chars' : '';
  });

  document.getElementById('xml-clear').addEventListener('click', function() {
    document.getElementById('xml-input').value = '';
    document.getElementById('xml-output').value = '';
    document.getElementById('xml-error').classList.add('hidden');
    document.getElementById('xml-copy').classList.add('hidden');
    document.getElementById('xml-stats').classList.add('hidden');
    document.getElementById('input-size').textContent = '';
  });

  function doFormat(minify) {
    var raw = document.getElementById('xml-input').value.trim();
    var errEl = document.getElementById('xml-error');
    var outEl = document.getElementById('xml-output');
    var copyBtn = document.getElementById('xml-copy');
    var statsEl = document.getElementById('xml-stats');

    errEl.classList.add('hidden');
    outEl.value = '';
    copyBtn.classList.add('hidden');
    statsEl.classList.add('hidden');

    if (!raw) {
      errEl.textContent = 'Please paste some XML first.';
      errEl.classList.remove('hidden');
      return;
    }

    try {
      var result;
      if (minify) {
        result = minifyXml(raw);
      } else {
        var indentVal = document.getElementById('indent-select').value;
        result = prettifyXml(raw, indentVal);
      }
      outEl.value = result;
      copyBtn.classList.remove('hidden');

      if (!minify) {
        // Count stats
        var parser = new DOMParser();
        var doc = parser.parseFromString(raw, 'application/xml');
        var counts = { elements: 0, attrs: 0 };
        countNodes(doc, counts);
        document.getElementById('stat-elements').textContent = counts.elements;
        document.getElementById('stat-attrs').textContent = counts.attrs;
        document.getElementById('stat-root').textContent = doc.documentElement ? doc.documentElement.nodeName : 'n/a';
        document.getElementById('stat-size').textContent = result.length + ' chars';
        statsEl.classList.remove('hidden');
      }
    } catch (e) {
      errEl.textContent = 'XML error: ' + (e.message || String(e));
      errEl.classList.remove('hidden');
    }
  }

  document.getElementById('xml-format').addEventListener('click', function() { doFormat(false); });
  document.getElementById('xml-minify').addEventListener('click', function() { doFormat(true); });

  document.getElementById('xml-copy').addEventListener('click', function() {
    var val = document.getElementById('xml-output').value;
    if (val) navigator.clipboard && navigator.clipboard.writeText(val);
    this.textContent = 'Copied!';
    var btn = this;
    setTimeout(function() { btn.textContent = 'Copy'; }, 2000);
  });
})();
</script>
