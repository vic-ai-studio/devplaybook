---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CssFormatter from "../../components/CssFormatter.tsx";
import ToolPageCta from "../../components/ToolPageCta.astro";
import FaqSection from "../../components/FaqSection.astro";

const faq = [
  { question: "Why format CSS code?", answer: "Formatted CSS is easier to read, diff in version control, and maintain. Consistent indentation makes it clear which declarations belong to which selectors, especially inside nested @media queries, @keyframes, and @supports blocks." },
  { question: "What is the difference between CSS formatting and minifying?", answer: "Formatting adds indentation and line breaks for readability. Minifying strips all whitespace, comments, and redundant characters to produce the smallest possible CSS file — reducing bandwidth and improving page load speed. Use formatted CSS in development, minified in production." },
  { question: "Does this tool support @media queries, @keyframes, and @supports?", answer: "Yes. The formatter correctly handles all CSS at-rules including @media, @keyframes, @supports, @layer, and @import. Nested rules are indented appropriately and closing braces are aligned with their opening selector." },
  { question: "Can I format SCSS or Less with this tool?", answer: "This tool is optimized for standard CSS syntax. SCSS and Less use CSS-compatible syntax for basic rules, so simple SCSS/Less may format correctly. However, SCSS-specific syntax like nesting with & or variables ($var) may not format perfectly — use a dedicated SCSS formatter for those." },
  { question: "How much file size reduction does CSS minification typically achieve?", answer: "CSS minification typically reduces file size by 20-40% for hand-written CSS. Files with many comments or verbose formatting may see larger reductions. Combined with gzip compression (which most servers apply), the actual bytes transferred are reduced by 70-90%." },
];
---

<BaseLayout
  title="CSS Formatter & Minifier — Free Online CSS Beautifier"
  description="Format and beautify CSS with consistent indentation, or minify it to reduce file size. Handles @media, @keyframes, @supports, and nested rules. Shows compression savings. Runs in your browser."
  tool="CSS Formatter, CSS Beautifier, CSS Minifier, CSS Pretty Print, Format CSS Online, CSS Indentation"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">CSS Formatter & Minifier</h1>
  <p class="text-text-muted mb-4">Paste messy CSS to format it with proper indentation and spacing, or minify it to strip all whitespace and reduce file size. Supports @media queries, @keyframes, and @supports blocks.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <CssFormatter client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CSS Formatter & Minifier" relatedTags={["css", "formatting", "minifier", "web", "styling", "development"]} />
</BaseLayout>
