---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CssFormatter from '../../components/CssFormatter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="CSS Formatter & Minifier — Free Online Tool"
  description="Format and beautify CSS with consistent indentation, or minify it to reduce file size. Handles @media, @keyframes, nested rules, and comments. Runs in your browser."
  tool="CSS Formatter, CSS Beautifier, CSS Minifier, CSS Pretty Print"
>
  <h1 class="text-3xl font-bold mb-2">CSS Formatter & Minifier</h1>
  <p class="text-text-muted mb-8">Paste messy CSS to format it with proper indentation and spacing, or minify it to strip all whitespace and reduce file size. Supports @media queries, @keyframes, and @supports blocks.</p>
  <CssFormatter client:only="preact" />
  <ToolPageCta currentTool="CSS Formatter & Minifier" relatedTags={['css', 'formatting', 'minifier', 'web', 'styling', 'development']} />
</BaseLayout>
