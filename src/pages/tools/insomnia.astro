---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const installNote = `# Download Insomnia from the official site
# https://insomnia.rest/download
# Available for macOS, Windows, and Linux (.deb, .rpm, AppImage)

# Install the Insomnia CLI (inso) for CI/CD automation
npm install -g insomnia-inso

# Verify CLI installation
inso --version`;

const insoExample = `# Run unit tests from a collection using inso CLI
inso run test "My API Tests" --env "Staging" --reporter junit

# Lint an OpenAPI specification file
inso lint spec openapi/my-api.yaml

# Export a design document to OpenAPI YAML
inso export spec "My API" --output openapi/my-api.yaml

# Run tests non-interactively in CI
inso run test "Regression Suite" \
  --env "CI Environment" \
  --ci \
  --reporter junit \
  --output results/junit.xml`;

const envExample = `// Insomnia environment — stored per workspace
// Switch environments via the dropdown in the top bar

{
  "base_url": "https://api.example.com",
  "api_key": "{{ process.env.API_KEY }}",   // injects from process env in inso CLI
  "user_id": 42,
  "timeout": 5000
}

// Reference in request URL:
// GET {{ base_url }}/users/{{ user_id }}

// Reference in headers:
// Authorization: Bearer {{ api_key }}`;

const pluginExample = `// insomnia-plugin-add-timestamp/index.js
// A simple Insomnia plugin that injects a request timestamp header

module.exports.requestHooks = [
  async (context) => {
    context.request.setHeader(
      'X-Request-Time',
      new Date().toISOString()
    );
  }
];

// package.json for the plugin
{
  "name": "insomnia-plugin-add-timestamp",
  "version": "1.0.0",
  "insomnia": {
    "name": "Add Timestamp Header",
    "description": "Injects X-Request-Time on every request"
  }
}`;

const testExample = `// Insomnia unit test — written in the Test tab of a request
const response = await insomnia.send();

expect(response.status).to.equal(200);
expect(response.headers['content-type']).to.include('application/json');

const body = JSON.parse(response.body);
expect(body).to.have.property('id');
expect(body.id).to.be.a('number');
expect(body.name).to.be.a('string').with.length.above(0);`;

const faq = [
  {
    question: "What is Insomnia?",
    answer: "Insomnia is a desktop API client by Kong that supports REST, GraphQL, gRPC, and WebSocket. It provides a rich GUI for building and organizing HTTP requests, managing environments, writing unit tests, and designing APIs with OpenAPI. The inso CLI enables running collections and linting specs in CI/CD pipelines."
  },
  {
    question: "How does Insomnia compare to Postman?",
    answer: "Insomnia and Postman are both full-featured desktop API clients. Insomnia is known for its clean, minimal interface and strong gRPC support — an area where Postman has historically been weaker. Postman has a larger plugin marketplace and more mature team collaboration features. Insomnia's design (OpenAPI) mode gives it an advantage for API-first development workflows. Both have free tiers with optional cloud sync."
  },
  {
    question: "What is the inso CLI and how do I use it?",
    answer: "inso (Insomnia CLI) is a Node.js command-line tool for automating Insomnia operations. You can run unit tests (inso run test), lint OpenAPI specs (inso lint spec), and export design documents (inso export spec). It reads from local Insomnia workspace export files or the cloud-synced workspace and is designed for CI/CD integration with JUnit XML output."
  },
  {
    question: "Does Insomnia support OpenAPI / API design?",
    answer: "Yes. Insomnia has a Design mode where you can write or import OpenAPI 3.x specifications. The spec editor has live validation, syntax highlighting, and a rendered preview. You can generate request collections directly from the spec and keep the spec in sync as you add requests. The inso CLI can lint and export these specs as part of your pipeline."
  },
  {
    question: "How does Insomnia handle authentication?",
    answer: "Insomnia supports OAuth 2.0, OAuth 1.0, Bearer Token, Basic Auth, Digest Auth, NTLM, AWS v4 signing, and API Keys as first-class auth types configurable per-request or inherited at the folder level. For OAuth 2.0, it can open a browser to complete the authorization code flow and automatically refresh tokens. Auth configurations can reference environment variables for secrets."
  },
  {
    question: "Can Insomnia sync collections across machines?",
    answer: "Yes. Insomnia offers cloud sync through your Insomnia account (free tier includes basic sync, paid plans include team sharing and E2E encryption). Alternatively, you can store the workspace export file in a Git repository and use Git Sync, which commits workspace changes directly to a repo — providing version history, branching, and team collaboration without a cloud account."
  },
];
---

<BaseLayout
  title="Insomnia — REST and GraphQL API Client by Kong"
  description="Insomnia is a powerful desktop API client supporting REST, GraphQL, gRPC, and WebSocket. Features OpenAPI design mode, environment management, plugins, unit testing, and the inso CLI for CI/CD."
  tool="insomnia, api client, rest client, graphql client, grpc testing, openapi design, inso cli, kong insomnia"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Insomnia — REST and GraphQL API Client by Kong",
    "url": "https://devplaybook.cc/tools/insomnia",
    "description": "Insomnia is a desktop API client supporting REST, GraphQL, gRPC, and WebSocket with OpenAPI design mode, environment management, and the inso CLI for CI/CD automation.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Insomnia</h1>
  <p class="text-text-muted mb-6">
    A feature-rich desktop API client by Kong for REST, GraphQL, gRPC, and WebSocket development.
    Design APIs with OpenAPI, manage environments, write unit tests, and automate
    collection runs with the <code class="bg-bg-card px-1 rounded text-sm">inso</code> CLI.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> REST, GraphQL, gRPC, WebSocket</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> OpenAPI design mode</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Environment management</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Unit testing built-in</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> inso CLI for CI/CD</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Plugin system</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Insomnia?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Insomnia is a desktop API development environment maintained by Kong. It provides a clean, minimal interface for sending HTTP/REST, GraphQL, gRPC, and WebSocket requests. Beyond basic request management, Insomnia includes an OpenAPI design editor, a plugin system for custom behavior, built-in unit testing, and Git-based sync for version-controlled collaboration.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    The <code class="bg-bg-card px-1 rounded text-xs">inso</code> CLI makes Insomnia a CI-friendly tool — you can run test suites, lint OpenAPI specs, and export design documents directly from your pipeline. Combined with Git Sync, Insomnia collections live alongside your codebase and are treated as versioned artifacts.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Multi-protocol requests</strong> — REST, GraphQL, gRPC, WebSocket, and Server-Sent Events</li>
    <li><strong>OpenAPI design mode</strong> — write or import OpenAPI 3.x specs with live validation and request generation</li>
    <li><strong>Environment management</strong> — nested environments (base + override) with template variables and process.env injection for CLI</li>
    <li><strong>Unit testing</strong> — write Chai-based tests in the Test tab and run them with inso in CI</li>
    <li><strong>Plugin system</strong> — extend Insomnia with request/response hooks, custom themes, and authentication helpers via npm packages</li>
    <li><strong>inso CLI</strong> — run tests, lint specs, and export documents from the terminal; integrates with any CI system</li>
    <li><strong>Git Sync</strong> — version-control your workspace by committing changes directly to a Git repository</li>
    <li><strong>Authentication helpers</strong> — OAuth 2.0, Bearer, Basic, AWS v4, and more — with browser-based OAuth flow support</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Installation</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={installNote}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Using the inso CLI</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    The <code class="bg-bg-card px-1 rounded text-xs">inso</code> CLI reads from an Insomnia workspace export file or a Git-synced workspace directory. Use it to run tests and lint specs as part of your automated pipeline.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={insoExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Environment Variables</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Insomnia uses a template syntax with double curly braces <code class="bg-bg-card px-1 rounded text-xs">{"{{ variable }}"}</code> to reference environment values anywhere in a request — URL, headers, body, or auth fields.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={envExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Writing Unit Tests</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Open any request, click the Test tab, and write Chai-style assertions. Tests run in the app UI or via <code class="bg-bg-card px-1 rounded text-xs">inso run test</code> in CI. Group related tests under named test suites for organized reporting.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={testExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Plugin System</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Install plugins from npm (<code class="bg-bg-card px-1 rounded text-xs">insomnia-plugin-*</code>) via Preferences or build your own. Plugins can add request/response lifecycle hooks, custom auth methods, and new themes.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={pluginExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Insomnia vs Postman</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">Insomnia</th>
          <th class="border border-border px-3 py-2 text-left">Postman</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2">gRPC support</td><td class="border border-border px-3 py-2 text-green-400">Yes (native)</td><td class="border border-border px-3 py-2">Limited</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">OpenAPI design mode</td><td class="border border-border px-3 py-2 text-green-400">Yes (built-in)</td><td class="border border-border px-3 py-2">Via API Network</td></tr>
        <tr><td class="border border-border px-3 py-2">Git Sync</td><td class="border border-border px-3 py-2 text-green-400">Yes (built-in)</td><td class="border border-border px-3 py-2">Partial (paid)</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Mock server</td><td class="border border-border px-3 py-2">No</td><td class="border border-border px-3 py-2 text-green-400">Yes</td></tr>
        <tr><td class="border border-border px-3 py-2">Plugin marketplace</td><td class="border border-border px-3 py-2">Small (npm)</td><td class="border border-border px-3 py-2 text-green-400">Large</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">UI cleanliness</td><td class="border border-border px-3 py-2 text-green-400">Minimal, fast</td><td class="border border-border px-3 py-2">Feature-dense</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pros and Cons</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-green-400 mb-2">Pros</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✓ Clean, fast interface that stays out of your way</li>
        <li>✓ First-class gRPC support</li>
        <li>✓ OpenAPI design mode with live validation</li>
        <li>✓ Git Sync for version-controlled collaboration</li>
        <li>✓ inso CLI enables full CI/CD integration</li>
      </ul>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-red-400 mb-2">Cons</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✗ No built-in mock server</li>
        <li>✗ Smaller plugin ecosystem than Postman</li>
        <li>✗ E2E encrypted cloud sync requires a paid plan</li>
        <li>✗ Desktop-only — no web app equivalent</li>
        <li>✗ Team sharing features require a paid plan</li>
      </ul>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="insomnia" relatedTags={['api', 'testing', 'rest', 'graphql', 'grpc', 'openapi', 'cli']} />
</BaseLayout>
