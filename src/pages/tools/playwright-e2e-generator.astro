---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PlaywrightE2EGenerator from '../../components/PlaywrightE2EGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Playwright and how does it differ from Cypress?",
    answer: "Playwright is a Microsoft-maintained end-to-end testing framework supporting Chromium, Firefox, and WebKit. Unlike Cypress, Playwright supports multiple browsers natively and can run tests in parallel across different browsers. It also supports testing in Node.js, Python, Java, and .NET. Playwright is generally faster due to its multi-worker model and has first-class support for network interception, mobile emulation, and component testing."
  },
  {
    question: "What is the difference between locator() and $() in Playwright?",
    answer: "locator() is the modern, recommended approach — it returns a Locator object that lazily resolves elements at action time and automatically retries. page.$() is the older ElementHandle approach that resolves immediately and does not auto-retry. Always prefer locator() for resilient tests. Locators also support chaining: page.locator('.form').locator('input[type=email]') scopes the inner selector to the parent."
  },
  {
    question: "How do I handle dynamic content and waiting in Playwright?",
    answer: "Playwright auto-waits for elements to be visible and actionable before interacting. You rarely need explicit waits. For network requests, use await page.waitForResponse() or await page.waitForRequest(). For specific state, use await locator.waitFor({ state: 'visible' }). Avoid time-based waits (page.waitForTimeout) — they make tests slow and brittle. Use page.waitForLoadState('networkidle') only as a last resort for complex SPAs."
  },
  {
    question: "How do I run Playwright tests in CI/CD?",
    answer: "Playwright works well in CI. For GitHub Actions, use the official action: npx playwright install --with-deps in your setup step. Set CI=true to run in non-interactive mode. Use npx playwright test --reporter=github for GitHub annotation output. Playwright also generates HTML reports: npx playwright show-report. Store the playwright-report/ directory as a CI artifact for test failure debugging."
  },
  {
    question: "What are Playwright fixtures and why use them?",
    answer: "Fixtures are reusable setup/teardown units in Playwright. The built-in page fixture gives you a clean browser page for each test. You can create custom fixtures for common setup like logging in: test.extend({ loggedInPage: async ({ page }, use) => { await loginAs(page, 'user@example.com'); await use(page); } }). Fixtures compose naturally and are automatically scoped to test, worker, or session lifetime."
  },
  {
    question: "How do I debug failing Playwright tests?",
    answer: "Use --debug flag to open Playwright Inspector: npx playwright test --debug. The inspector lets you step through tests and inspect selectors. Use trace viewer for CI failures: configure trace: 'on-first-retry' in playwright.config.ts, then view with npx playwright show-trace trace.zip. Use page.pause() to freeze execution at a specific point during development. The --headed flag runs tests with a visible browser."
  },
];
---

<BaseLayout
  title="Playwright E2E Test Generator — Build Tests Visually"
  description="Generate Playwright end-to-end test code visually. Add click, fill, expect, and navigate steps with a step builder. Outputs TypeScript or JavaScript test code ready to run. Free, runs in your browser."
  tool="playwright test generator, e2e test generator, playwright automation, playwright test builder, playwright code generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Playwright E2E Test Generator",
    "url": "https://devplaybook.cc/tools/playwright-e2e-generator",
    "description": "Generate Playwright end-to-end test code from URL and selector inputs. Visual step builder with click, fill, expect, navigate actions.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Playwright E2E Test Generator</h1>
  <p class="text-text-muted mb-4">
    Build <strong>Playwright end-to-end tests</strong> step by step. Add click, fill, expect, navigate, and other actions visually, then copy the generated TypeScript or JavaScript test code. No setup needed — runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript & JavaScript</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Visual step builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-ready output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All Playwright actions</span>
  </div>
  <PlaywrightE2EGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Playwright E2E Test Generator" relatedTags={['testing', 'playwright', 'e2e', 'automation', 'javascript', 'typescript']} />
</BaseLayout>
