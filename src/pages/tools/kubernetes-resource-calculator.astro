---
import BaseLayout from '../../layouts/BaseLayout.astro';
import KubernetesResourceCalculator from '../../components/KubernetesResourceCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the difference between CPU requests and limits in Kubernetes?",
    answer: "CPU requests are what Kubernetes uses to schedule a pod onto a node — the scheduler ensures the node has at least that many free millicores. CPU limits cap how much CPU the container can consume after it's running. Exceeding the limit causes CPU throttling (not a crash), which degrades performance. Best practice: set the limit to ~2–5× the request to allow bursting."
  },
  {
    question: "What happens when a container exceeds its memory limit?",
    answer: "When a container exceeds its memory limit, the Linux kernel OOM (Out Of Memory) killer terminates the container with exit code 137. Kubernetes then restarts it according to the pod's restartPolicy. Unlike CPU throttling, memory over-limit is a hard kill. Always set memory limits to prevent one container from starving others on the same node."
  },
  {
    question: "What are millicores (m) in Kubernetes CPU?",
    answer: "Millicores represent 1/1000 of a CPU core. 1000m = 1 vCPU = 1 AWS vCPU or GCP vCPU. Common values: 100m (0.1 vCPU, for lightweight services), 500m (0.5 vCPU, for medium workloads), 1000m (1 vCPU, for CPU-intensive apps). If your node has 4 cores, it has 4000m total allocatable CPU."
  },
  {
    question: "How does HPA (HorizontalPodAutoscaler) use resource requests?",
    answer: "HPA calculates CPU utilization as a percentage of the pod's CPU request, not the limit. If your request is 100m and your target is 70%, HPA scales up when actual CPU usage exceeds 70m. This is why setting accurate requests is critical — too low causes premature scaling, too high causes underutilization."
  },
  {
    question: "What is a Namespace ResourceQuota and why use it?",
    answer: "A ResourceQuota limits the total resources consumed by all pods in a namespace. It prevents a single team or deployment from consuming the entire cluster's capacity. Quotas can cap total CPU requests/limits, memory requests/limits, and number of pods. They are enforced at admission time — pods that exceed the quota are rejected."
  },
  {
    question: "What are good starting values for CPU and memory limits?",
    answer: "For most web APIs: start with 100m CPU request / 500m CPU limit and 128Mi memory request / 512Mi memory limit. Run load tests, check actual usage with `kubectl top pods`, then adjust. As a rule of thumb: set request to ~50–70% of your measured P95 usage, and limit to ~150–200% of request to allow for traffic spikes without OOM kills."
  },
];
---

<BaseLayout
  title="Kubernetes Resource Calculator — CPU & Memory Requests/Limits"
  description="Calculate CPU and memory requests and limits for Kubernetes pods. Set millicores, Mi/Gi memory, HPA replicas, and get a ready-to-paste Pod spec YAML with resource quotas."
  tool="kubernetes resource calculator, k8s cpu memory limits, pod resource requests, kubernetes yaml generator, kubernetes HPA"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Kubernetes Resource Calculator",
    "url": "https://devplaybook.cc/tools/kubernetes-resource-calculator",
    "description": "Calculate CPU and memory requests and limits for Kubernetes pods. Set millicores, Mi/Gi memory, HPA replicas, and get a ready-to-paste Pod spec YAML with resource quotas.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Kubernetes Resource Calculator</h1>
  <p class="text-text-muted mb-4">
    Configure CPU and memory <code class="font-mono bg-bg-card px-1 rounded text-sm">requests</code> and{' '}
    <code class="font-mono bg-bg-card px-1 rounded text-sm">limits</code> for your Kubernetes pods.
    Set millicores, Mi/Gi memory, HPA replica bounds, and get production-ready YAML with a Namespace ResourceQuota.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Pod spec YAML</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> HPA config</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Namespace ResourceQuota</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Total resource summary</span>
  </div>
  <KubernetesResourceCalculator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Kubernetes Resource Calculator" relatedTags={['kubernetes', 'k8s', 'devops', 'docker', 'cloud', 'yaml']} />
</BaseLayout>
