---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GoFormatter from '../../components/GoFormatter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is gofmt and why should I use it?",
    answer: "gofmt is the official Go code formatter created by the Go team. Unlike most languages where style is a matter of preference, the Go community treats gofmt output as the canonical style — all Go code is expected to be formatted with it. Using gofmt eliminates style debates, makes code reviews faster, and ensures your code passes CI checks in projects that enforce formatting. This online tool applies the same rules so you can format Go code instantly without installing Go locally."
  },
  {
    question: "Why does Go use tabs instead of spaces for indentation?",
    answer: "The Go team made a deliberate choice to use tabs for indentation. The reasoning: tab width is configurable per editor, so developers who prefer 2-space visual indentation can set their editor to display tabs as 2 columns, while others use 4 or 8. This respects personal preferences without creating different physical files. Spaces lock in a specific visual width for everyone, causing disagreements. gofmt enforces tabs, so all correctly formatted Go code uses tabs."
  },
  {
    question: "Why must the opening brace be on the same line in Go?",
    answer: "Go's grammar actually requires this — it is not just a style choice. Go uses semicolons as statement terminators, but they are inserted automatically by the lexer at the end of lines that end with certain tokens. If you put the opening brace on a new line after a function or if-statement, the lexer inserts a semicolon after the closing parenthesis, causing a syntax error. This is why Go's brace style is enforced at the language level, not just by convention."
  },
  {
    question: "What is import grouping in Go?",
    answer: "The gofmt convention groups imports into two blocks separated by a blank line: stdlib packages first (fmt, net/http, os, etc.), then third-party packages (github.com/..., k8s.io/..., etc.). Some teams add a third group for internal packages. The goimports tool can do this grouping automatically. This online formatter separates stdlib from third-party imports and inserts the blank line separator between groups."
  },
  {
    question: "Does this replace running gofmt locally?",
    answer: "This tool is ideal for quick formatting checks, learning gofmt rules, or formatting code snippets without a local Go installation. For production code, you should still run gofmt (or goimports which extends gofmt) as part of your editor setup or CI pipeline. The online formatter implements the core gofmt rules in pure JavaScript, so it handles the vast majority of cases accurately, but very complex expressions or edge cases may differ slightly from the official gofmt binary."
  },
  {
    question: "What is the difference between gofmt and goimports?",
    answer: "gofmt handles formatting: indentation with tabs, brace placement, operator spacing, and blank lines. goimports does everything gofmt does, plus it automatically manages your import block — adding missing imports and removing unused ones based on the symbols used in your code. For local development, goimports is generally preferred. This online tool implements gofmt-style formatting rules; import management requires Go type analysis and cannot run in the browser."
  },
];
---

<BaseLayout
  title="Go Code Formatter — gofmt Style Online"
  description="Format Go code instantly in your browser using gofmt rules. Tab indentation, brace placement, operator spacing, import grouping — no installation required."
  tool="Go Formatter, gofmt Online, Go Code Style, Golang Formatter, Go Indentation"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Go Code Formatter</h1>
  <p class="text-text-muted mb-4">Paste your Go code to auto-format it with gofmt-style rules — tab indentation, correct brace placement, operator spacing, and grouped imports — entirely in your browser.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Tab indentation &amp; brace placement</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Operator spacing &amp; import grouping</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Side-by-side diff view</span>
  </div>

  <GoFormatter client:only="preact" />

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Go Code Formatter" relatedTags={['go', 'golang', 'formatting', 'code-quality', 'development']} />
</BaseLayout>
