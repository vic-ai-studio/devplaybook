---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CronExpressionParser from '../../components/CronExpressionParser.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What does a cron expression parser do?",
    answer: "A cron expression parser reads a cron expression (5 space-separated fields: minute, hour, day-of-month, month, day-of-week) and explains it in plain English. It validates each field, describes what the expression means, and calculates the next scheduled run times."
  },
  {
    question: "What are the 5 fields in a cron expression?",
    answer: "The 5 fields are: Minute (0–59), Hour (0–23), Day of Month (1–31), Month (1–12), and Day of Week (0–6, where 0=Sunday). Each field can use * (any), numbers, ranges (1-5), steps (*/5), or comma-separated values (1,3,5)."
  },
  {
    question: "How do I parse '0 9 * * 1-5'?",
    answer: "The expression '0 9 * * 1-5' means: at minute 0, hour 9, every day of month, every month, Monday through Friday. In plain English: every weekday at 9:00 AM."
  },
  {
    question: "What does */5 mean in a cron expression?",
    answer: "The */5 syntax means 'every 5 units'. In the minute field, */5 means every 5 minutes (0, 5, 10, 15, ..., 55). In the hour field, */6 would mean every 6 hours (0, 6, 12, 18)."
  },
  {
    question: "Is this cron parser compatible with GitHub Actions and AWS EventBridge?",
    answer: "This parser uses the standard 5-field Unix cron format. GitHub Actions adds a 6th field for seconds in some contexts, and AWS EventBridge uses a slightly different syntax with ? for day-of-month or day-of-week. For most common expressions, this tool works well as a reference."
  },
  {
    question: "Does this tool send my cron expressions to a server?",
    answer: "No. All parsing and calculation runs entirely in your browser using JavaScript. No data is sent to any server."
  },
];
---

<BaseLayout
  title="Cron Expression Parser — Decode & Explain Cron Schedules Online"
  description="Parse and explain cron expressions in plain English. See next 5 run times, field-by-field breakdown, and preset examples. Free online cron parser — runs 100% in your browser, no signup needed."
  tool="Cron Expression Parser, Cron Decoder, Cron Explainer, Parse Cron Expression, Cron Schedule Parser, Cron Next Run"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Cron Expression Parser",
    "url": "https://devplaybook.cc/tools/cron-expression-parser",
    "description": "Parse and decode cron expressions instantly. Get a plain-English description, field-by-field breakdown, and the next 5 scheduled run times. Runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Cron Expression Parser</h1>
  <p class="text-text-muted mb-4">
    Paste any <strong>cron expression</strong> to parse it instantly — get a plain-English description,
    field-by-field breakdown, and the <strong>next 5 scheduled run times</strong>.
    Works with Linux crontab, GitHub Actions, AWS EventBridge, and more.
    No signup, no server — runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Plain-English description</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Next 5 run times</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <CronExpressionParser client:load />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Cron Expression Parser" relatedTags={['automation', 'devops', 'ci-cd', 'bash', 'scheduling']} />
</BaseLayout>
