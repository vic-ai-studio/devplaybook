---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CronExpressionParser from '../../components/CronExpressionParser.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What does a cron expression parser do?",
    answer: "A cron expression parser reads a cron expression (5 space-separated fields: minute, hour, day-of-month, month, day-of-week) and explains it in plain English. It validates each field, describes what the expression means, and calculates the next scheduled run times."
  },
  {
    question: "What are the 5 fields in a cron expression?",
    answer: "The 5 fields are: Minute (0–59), Hour (0–23), Day of Month (1–31), Month (1–12), and Day of Week (0–6, where 0=Sunday). Each field can use * (any), numbers, ranges (1-5), steps (*/5), or comma-separated values (1,3,5)."
  },
  {
    question: "How do I parse '0 9 * * 1-5'?",
    answer: "The expression '0 9 * * 1-5' means: at minute 0, hour 9, every day of month, every month, Monday through Friday. In plain English: every weekday at 9:00 AM."
  },
  {
    question: "What does */5 mean in a cron expression?",
    answer: "The */5 syntax means 'every 5 units'. In the minute field, */5 means every 5 minutes (0, 5, 10, 15, ..., 55). In the hour field, */6 would mean every 6 hours (0, 6, 12, 18)."
  },
  {
    question: "Is this cron parser compatible with GitHub Actions and AWS EventBridge?",
    answer: "This parser uses the standard 5-field Unix cron format. GitHub Actions adds a 6th field for seconds in some contexts, and AWS EventBridge uses a slightly different syntax with ? for day-of-month or day-of-week. For most common expressions, this tool works well as a reference."
  },
  {
    question: "Does this tool send my cron expressions to a server?",
    answer: "No. All parsing and calculation runs entirely in your browser using JavaScript. No data is sent to any server."
  },
];
---

<BaseLayout
  title="Cron Expression Parser — Decode & Explain Cron Schedules Online"
  description="Parse and explain cron expressions in plain English with a field-by-field breakdown and next 5 scheduled run times. Decode Linux crontab, GitHub Actions, and AWS EventBridge schedules instantly. Includes preset examples for common jobs like daily backups, hourly syncs, and weekday-only tasks. Free online cron parser — runs 100% in your browser, no signup needed."
  tool="Cron Expression Parser, Cron Decoder, Cron Explainer, Parse Cron Expression, Cron Schedule Parser, Cron Next Run"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Cron Expression Parser",
    "url": "https://devplaybook.cc/tools/cron-expression-parser",
    "description": "Parse and decode cron expressions instantly. Get a plain-English description, field-by-field breakdown, and the next 5 scheduled run times. Runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Cron Expression Parser</h1>
  <p class="text-text-muted mb-4">
    Paste any <strong>cron expression</strong> to parse it instantly — get a plain-English description,
    field-by-field breakdown, and the <strong>next 5 scheduled run times</strong>.
    Works with Linux crontab, GitHub Actions, AWS EventBridge, and more.
    No signup, no server — runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Plain-English description</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Next 5 run times</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <CronExpressionParser client:load />
  <!-- Real-World Use Cases -->
  <section class="mt-12 mb-8">
    <h2 class="text-2xl font-bold mb-6">Real-World Use Cases</h2>

    <div class="space-y-6">
      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">1. Verifying a GitHub Actions Schedule</h3>
        <p class="text-text-muted mb-3">Your CI/CD workflow runs on a cron schedule. Paste the expression from your <code class="font-mono text-sm bg-bg-card px-1 rounded">.github/workflows/deploy.yml</code> to confirm it runs when you expect — avoiding surprise 3 AM deployments.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Input Expression</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">30 9 * * 1-5</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Parsed Output</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`At 09:30, Monday through Friday\n\nNext 3 runs (UTC):\n  Mon Apr 06 2026 09:30\n  Tue Apr 07 2026 09:30\n  Wed Apr 08 2026 09:30`}</pre>
          </div>
        </div>
      </div>

      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">2. Debugging a Database Backup That Runs Too Often</h3>
        <p class="text-text-muted mb-3">Your <code class="font-mono text-sm bg-bg-card px-1 rounded">pg_dump</code> backup is hammering the server every minute instead of every hour. Paste the crontab expression to spot the mistake and see the correct one.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Wrong Expression</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`* * * * *\n→ "Every minute" (oops!)`}</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Correct Expression</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`0 * * * *\n→ "At minute 0 of every hour"\n\nNext: 15:00, 16:00, 17:00...`}</pre>
          </div>
        </div>
      </div>

      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">3. Setting Up a Monthly Report Email</h3>
        <p class="text-text-muted mb-3">You want a report generated at 8 AM on the 1st of every month. Build the expression and verify the next 5 runs to confirm it aligns with your business calendar.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Input Expression</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">0 8 1 * *</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Parsed Output</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`At 08:00 on day 1 of every month\n\nNext 3 runs:\n  May 01 2026 08:00\n  Jun 01 2026 08:00\n  Jul 01 2026 08:00`}</pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Step-by-Step Guide -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">How to Use — Step by Step</h2>
    <ol class="list-decimal list-inside space-y-3 text-text-muted">
      <li><strong>Paste your cron expression</strong> — Copy it from your crontab, CI config, or scheduler settings and paste into the input field.</li>
      <li><strong>Read the plain-English description</strong> — The parser translates the 5 fields into a human-readable sentence like "Every weekday at 9:30 AM."</li>
      <li><strong>Check the field breakdown</strong> — Each field (minute, hour, day, month, weekday) is decoded individually so you can spot mistakes.</li>
      <li><strong>Review next run times</strong> — The tool calculates and displays the next 5 scheduled execution times in your timezone.</li>
      <li><strong>Use presets</strong> — Try common presets (every 5 min, hourly, daily at midnight, weekdays at 9 AM) as starting points, then tweak for your needs.</li>
    </ol>
  </section>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Cron Expression Parser" relatedTags={['automation', 'devops', 'ci-cd', 'bash', 'scheduling']} />
</BaseLayout>
