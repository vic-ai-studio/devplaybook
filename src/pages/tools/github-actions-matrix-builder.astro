---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GitHubActionsMatrixBuilder from '../../components/GitHubActionsMatrixBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a GitHub Actions matrix strategy?",
    answer: "A matrix strategy lets you run a job across multiple configurations simultaneously. Instead of writing separate jobs for each OS or language version, you declare a matrix and GitHub Actions spawns parallel jobs for each combination — e.g., 3 OS × 3 Node versions = 9 parallel jobs."
  },
  {
    question: "What does fail-fast do?",
    answer: "With fail-fast enabled (default), GitHub Actions cancels all in-progress jobs in the matrix as soon as any one job fails. Disabling it (fail-fast: false) lets all combinations run to completion, which is useful for understanding the full scope of a failure across environments."
  },
  {
    question: "How do I limit the number of parallel jobs?",
    answer: "Use max-parallel to cap how many jobs run simultaneously. This is useful when you have limited self-hosted runners, want to avoid exhausting rate-limited external services, or need to control costs on pay-per-minute billing."
  },
  {
    question: "Can I add custom steps to the generated workflow?",
    answer: "Yes — the generated YAML includes a sensible steps template for your chosen language. Edit the steps section to add caching, linting, test reporting, deployment steps, or any other custom logic. The matrix variables (matrix.os, matrix.node-version, etc.) are available in all steps."
  },
  {
    question: "How do I add include/exclude rules to my matrix?",
    answer: "After generating the base YAML, add an include or exclude block under strategy.matrix. For example, exclude: [{os: windows-latest, node-version: '18'}] prevents that specific combination from running. Include lets you add extra variables to specific combinations."
  },
  {
    question: "What is the maximum matrix size in GitHub Actions?",
    answer: "GitHub Actions supports up to 256 jobs per matrix. Beyond that, you'll need to split into multiple workflows or use dynamic matrix generation via fromJSON. For most projects, keeping the matrix under 20 combinations is recommended for practical CI times."
  },
];
---

<BaseLayout
  title="GitHub Actions Matrix Builder — Generate CI Matrix Strategy YAML"
  description="Generate GitHub Actions matrix strategy workflows for cross-platform and multi-version CI. Choose OS combinations, Node/Python/Java/Go versions, and get ready-to-use YAML."
  tool="GitHub Actions Matrix Builder, CI Matrix Generator, GitHub Workflow Generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "GitHub Actions Matrix Builder",
    "url": "https://devplaybook.cc/tools/github-actions-matrix-builder",
    "description": "Generate GitHub Actions matrix strategy YAML for cross-platform CI. Select OS combinations and language versions to produce ready-to-use workflow files.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">GitHub Actions Matrix Builder</h1>
  <p class="text-text-muted mb-4">
    Generate GitHub Actions <code class="font-mono bg-surface px-1 rounded text-sm">matrix</code> strategy workflows for cross-platform CI.
    Pick OS combinations, language versions, and options — get production-ready YAML instantly.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Ubuntu / Windows / macOS</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Node / Python / Java / Go</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Instant YAML output</span>
  </div>
  <GitHubActionsMatrixBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="GitHub Actions Matrix Builder" relatedTags={['ci-cd', 'github', 'automation', 'devops', 'developer-tools']} />
</BaseLayout>
