---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is k6?", answer: "k6 is an open-source developer-centric load testing tool that lets you write test scripts in JavaScript. It runs from the CLI and outputs detailed metrics like request duration, error rates, virtual users, and throughput. It's widely used for performance and stress testing APIs and web services." },
  { question: "What are Virtual Users (VUs)?", answer: "Virtual Users simulate concurrent users making requests. Each VU runs your test scenario in a loop for the test duration. Higher VUs mean more concurrent load. Start with low numbers (10–50) to establish a baseline before pushing to higher limits." },
  { question: "What is the difference between constant and ramping stages?", answer: "Constant load runs a fixed number of VUs for the entire duration. Ramping stages let you gradually increase or decrease VUs over time — useful for finding the breaking point of your service without immediately hammering it at peak load." },
  { question: "What HTTP methods should I test?", answer: "Test the methods your API actually uses. GET for reads (usually high volume), POST for creates, PUT/PATCH for updates, DELETE for removals. For realistic load tests, combine multiple methods to simulate actual user behavior." },
  { question: "How do I run the generated script?", answer: "Install k6 (brew install k6 on macOS, or download from k6.io), save the script to a .js file, then run: k6 run script.js. Add --out csv=results.csv to export metrics. For cloud execution, use k6 cloud run script.js." },
];
---

<BaseLayout
  title="k6 Script Generator — Visual Load Test Builder — Free Online Tool"
  description="Build k6 load test scripts visually. Configure VUs, duration, stages, HTTP methods, headers, and thresholds — get a ready-to-run k6 JavaScript script. Free, no signup."
  tool="k6 script generator, load test generator, k6 load testing, performance test script, k6 tutorial"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">k6 Script Generator</h1>
  <p class="text-text-muted mb-4">Build k6 load test scripts visually. Configure virtual users, duration, HTTP requests, and thresholds — then copy the ready-to-run JavaScript for k6.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Vanilla JS, runs in browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Ready-to-run k6 output</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Left: Config -->
    <div class="space-y-4">

      <!-- Target URL -->
      <div class="bg-surface border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">Target URL</h2>
        <input id="k6-url" type="text" placeholder="https://api.example.com/endpoint" autocomplete="off"
          class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent" />
      </div>

      <!-- Load Profile -->
      <div class="bg-surface border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">Load Profile</h2>
        <div class="flex gap-2 mb-3">
          <button id="k6-mode-constant" class="k6-mode-btn flex-1 py-2 rounded-lg text-sm font-medium border transition-colors">Constant</button>
          <button id="k6-mode-ramping" class="k6-mode-btn flex-1 py-2 rounded-lg text-sm font-medium border transition-colors">Ramping Stages</button>
        </div>

        <!-- Constant -->
        <div id="k6-constant-config">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs text-text-muted mb-1">Virtual Users</label>
              <input id="k6-vus" type="number" value="10" min="1" max="10000"
                class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">Duration</label>
              <input id="k6-duration" type="text" value="30s" placeholder="30s, 5m, 1h"
                class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent" />
            </div>
          </div>
        </div>

        <!-- Ramping -->
        <div id="k6-ramping-config" class="hidden">
          <div id="k6-stages-list" class="space-y-2 mb-3"></div>
          <button id="k6-add-stage" class="text-sm text-accent hover:text-accent/80 transition-colors">+ Add Stage</button>
        </div>
      </div>

      <!-- HTTP Request -->
      <div class="bg-surface border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">HTTP Request</h2>
        <div class="grid grid-cols-2 gap-3 mb-3">
          <div>
            <label class="block text-xs text-text-muted mb-1">Method</label>
            <select id="k6-method" class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent">
              <option>GET</option>
              <option>POST</option>
              <option>PUT</option>
              <option>PATCH</option>
              <option>DELETE</option>
            </select>
          </div>
          <div>
            <label class="block text-xs text-text-muted mb-1">Check Status</label>
            <select id="k6-check-status" class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent">
              <option value="200">200 OK</option>
              <option value="201">201 Created</option>
              <option value="204">204 No Content</option>
              <option value="any">Any 2xx</option>
              <option value="none">No check</option>
            </select>
          </div>
        </div>

        <div id="k6-body-section">
          <label class="block text-xs text-text-muted mb-1">Request Body (JSON)</label>
          <textarea id="k6-body" rows="3" placeholder='{"key": "value"}'
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-accent resize-none"></textarea>
        </div>

        <div class="mt-3">
          <label class="block text-xs text-text-muted mb-1">Headers (key: value, one per line)</label>
          <textarea id="k6-headers" rows="2" placeholder="Authorization: Bearer token&#10;Content-Type: application/json"
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-accent resize-none"></textarea>
        </div>
      </div>

      <!-- Thresholds -->
      <div class="bg-surface border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">Thresholds</h2>
        <label class="flex items-center gap-2 mb-2 cursor-pointer text-sm">
          <input type="checkbox" id="k6-thresh-p95" class="accent-accent" checked />
          p95 response time &lt; <input id="k6-thresh-p95-val" type="number" value="500" min="1"
            class="w-16 bg-background border border-border rounded px-2 py-0.5 text-xs focus:outline-none focus:border-accent mx-1" /> ms
        </label>
        <label class="flex items-center gap-2 mb-2 cursor-pointer text-sm">
          <input type="checkbox" id="k6-thresh-err" class="accent-accent" checked />
          Error rate &lt; <input id="k6-thresh-err-val" type="number" value="1" min="0" max="100" step="0.1"
            class="w-16 bg-background border border-border rounded px-2 py-0.5 text-xs focus:outline-none focus:border-accent mx-1" /> %
        </label>
        <label class="flex items-center gap-2 cursor-pointer text-sm">
          <input type="checkbox" id="k6-thresh-p99" class="accent-accent" />
          p99 response time &lt; <input id="k6-thresh-p99-val" type="number" value="1000" min="1"
            class="w-16 bg-background border border-border rounded px-2 py-0.5 text-xs focus:outline-none focus:border-accent mx-1" /> ms
        </label>
      </div>

    </div>

    <!-- Right: Output -->
    <div class="bg-surface border border-border rounded-xl p-5 flex flex-col">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-base font-semibold">Generated k6 Script</h2>
        <button id="k6-copy" class="text-xs bg-background border border-border hover:bg-accent/20 px-3 py-1.5 rounded-lg transition-colors">Copy Script</button>
      </div>
      <pre id="k6-output" class="flex-1 bg-background border border-border rounded-lg p-4 text-xs font-mono overflow-auto whitespace-pre min-h-[500px] text-text-muted leading-relaxed"></pre>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="k6 Script Generator" relatedTags={['performance', 'testing', 'api', 'load-testing', 'developer-tools']} />
</BaseLayout>

<script>
(function () {
  let mode = 'constant';
  let stages = [
    { duration: '10s', target: 10 },
    { duration: '30s', target: 50 },
    { duration: '10s', target: 0 },
  ];

  // Mode toggle
  const btnConstant = document.getElementById('k6-mode-constant');
  const btnRamping = document.getElementById('k6-mode-ramping');
  const constantConfig = document.getElementById('k6-constant-config');
  const rampingConfig = document.getElementById('k6-ramping-config');

  function setMode(m) {
    mode = m;
    if (m === 'constant') {
      btnConstant.classList.add('bg-accent', 'text-white', 'border-accent');
      btnConstant.classList.remove('border-border', 'text-text-muted');
      btnRamping.classList.remove('bg-accent', 'text-white', 'border-accent');
      btnRamping.classList.add('border-border', 'text-text-muted');
      constantConfig.classList.remove('hidden');
      rampingConfig.classList.add('hidden');
    } else {
      btnRamping.classList.add('bg-accent', 'text-white', 'border-accent');
      btnRamping.classList.remove('border-border', 'text-text-muted');
      btnConstant.classList.remove('bg-accent', 'text-white', 'border-accent');
      btnConstant.classList.add('border-border', 'text-text-muted');
      rampingConfig.classList.remove('hidden');
      constantConfig.classList.add('hidden');
      renderStages();
    }
    update();
  }

  btnConstant.addEventListener('click', () => setMode('constant'));
  btnRamping.addEventListener('click', () => setMode('ramping'));
  setMode('constant');

  // Stages
  function renderStages() {
    const list = document.getElementById('k6-stages-list');
    list.innerHTML = stages.map((s, i) => `
      <div class="flex items-center gap-2">
        <span class="text-xs text-text-muted w-16">Stage ${i + 1}</span>
        <input type="text" value="${s.duration}" placeholder="10s"
          class="w-20 bg-background border border-border rounded px-2 py-1 text-xs focus:outline-none focus:border-accent stage-dur"
          data-idx="${i}" />
        <span class="text-xs text-text-muted">→</span>
        <input type="number" value="${s.target}" min="0" placeholder="VUs"
          class="w-16 bg-background border border-border rounded px-2 py-1 text-xs focus:outline-none focus:border-accent stage-vus"
          data-idx="${i}" />
        <span class="text-xs text-text-muted">VUs</span>
        <button class="text-red-400 hover:text-red-300 text-xs ml-auto stage-remove" data-idx="${i}">×</button>
      </div>
    `).join('');

    list.querySelectorAll('.stage-dur').forEach(el => {
      el.addEventListener('input', (e) => {
        stages[+e.target.dataset.idx].duration = e.target.value;
        update();
      });
    });
    list.querySelectorAll('.stage-vus').forEach(el => {
      el.addEventListener('input', (e) => {
        stages[+e.target.dataset.idx].target = +e.target.value || 0;
        update();
      });
    });
    list.querySelectorAll('.stage-remove').forEach(el => {
      el.addEventListener('click', (e) => {
        stages.splice(+e.target.dataset.idx, 1);
        renderStages(); update();
      });
    });
  }

  document.getElementById('k6-add-stage').addEventListener('click', () => {
    stages.push({ duration: '30s', target: 10 });
    renderStages(); update();
  });

  // Show/hide body for GET/DELETE
  document.getElementById('k6-method').addEventListener('change', function () {
    const show = ['POST', 'PUT', 'PATCH'].includes(this.value);
    document.getElementById('k6-body-section').style.opacity = show ? '1' : '0.4';
    update();
  });

  // Live update on all inputs
  ['k6-url', 'k6-vus', 'k6-duration', 'k6-method', 'k6-check-status', 'k6-body', 'k6-headers',
   'k6-thresh-p95', 'k6-thresh-p95-val', 'k6-thresh-err', 'k6-thresh-err-val', 'k6-thresh-p99', 'k6-thresh-p99-val'
  ].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('input', update);
    if (el) el.addEventListener('change', update);
  });

  function buildHeaders() {
    const raw = (document.getElementById('k6-headers').value || '').trim();
    if (!raw) return null;
    const lines = raw.split('\n').filter(l => l.includes(':'));
    const obj = {};
    lines.forEach(l => {
      const idx = l.indexOf(':');
      const k = l.slice(0, idx).trim();
      const v = l.slice(idx + 1).trim();
      if (k) obj[k] = v;
    });
    return Object.keys(obj).length ? obj : null;
  }

  function update() {
    const url = document.getElementById('k6-url').value.trim() || 'https://api.example.com/endpoint';
    const method = document.getElementById('k6-method').value;
    const checkStatus = document.getElementById('k6-check-status').value;
    const body = document.getElementById('k6-body').value.trim();
    const headers = buildHeaders();

    const p95On = document.getElementById('k6-thresh-p95').checked;
    const p95Val = document.getElementById('k6-thresh-p95-val').value;
    const errOn = document.getElementById('k6-thresh-err').checked;
    const errVal = document.getElementById('k6-thresh-err-val').value;
    const p99On = document.getElementById('k6-thresh-p99').checked;
    const p99Val = document.getElementById('k6-thresh-p99-val').value;

    const lines = [];
    lines.push('import http from \'k6/http\';');
    lines.push('import { check, sleep } from \'k6\';');
    lines.push('');

    // Options
    lines.push('export const options = {');

    if (mode === 'constant') {
      const vus = document.getElementById('k6-vus').value || '10';
      const duration = document.getElementById('k6-duration').value || '30s';
      lines.push(`  vus: ${vus},`);
      lines.push(`  duration: '${duration}',`);
    } else {
      lines.push('  stages: [');
      stages.forEach(s => {
        lines.push(`    { duration: '${s.duration}', target: ${s.target} },`);
      });
      lines.push('  ],');
    }

    const thresholds = [];
    if (p95On) thresholds.push(`    'http_req_duration': ['p(95)<${p95Val}'],`);
    if (p99On) thresholds.push(`    'http_req_duration': ['p(99)<${p99Val}'],`);
    if (errOn) thresholds.push(`    'http_req_failed': ['rate<${parseFloat(errVal) / 100}'],`);

    if (thresholds.length) {
      lines.push('  thresholds: {');
      // deduplicate http_req_duration
      const seen = {};
      thresholds.forEach(t => {
        const key = t.trim().split(':')[0].replace(/'/g, '');
        if (!seen[key]) { seen[key] = []; }
        seen[key].push(t.trim().split(':').slice(1).join(':').trim().replace(/,$/, ''));
      });
      Object.entries(seen).forEach(([k, vals]) => {
        lines.push(`    '${k}': [${vals.map(v => v.replace(/^\[/, '').replace(/\],$/, '').replace(/]$/, '')).map(v => `'${v.replace(/'/g, '')}'`).join(', ')}],`);
      });
      lines.push('  },');
    }

    lines.push('};');
    lines.push('');

    // Headers object
    const hasBody = ['POST', 'PUT', 'PATCH'].includes(method) && body;
    const allHeaders = { ...(headers || {}) };
    if (hasBody && !allHeaders['Content-Type']) allHeaders['Content-Type'] = 'application/json';
    const headerEntries = Object.entries(allHeaders);

    if (headerEntries.length) {
      lines.push('const HEADERS = {');
      headerEntries.forEach(([k, v]) => lines.push(`  '${k}': '${v}',`));
      lines.push('};');
      lines.push('');
    }

    // Default function
    lines.push('export default function () {');
    const paramsArg = headerEntries.length ? ', { headers: HEADERS }' : '';

    if (hasBody) {
      lines.push(`  const payload = JSON.stringify(${body});`);
      lines.push(`  const res = http.${method.toLowerCase()}('${url}', payload, { headers: { ...${headerEntries.length ? 'HEADERS' : '{}'}, 'Content-Type': 'application/json' } });`);
    } else {
      lines.push(`  const res = http.${method.toLowerCase()}('${url}'${paramsArg});`);
    }

    if (checkStatus !== 'none') {
      lines.push('');
      lines.push('  check(res, {');
      if (checkStatus === 'any') {
        lines.push('    \'status is 2xx\': (r) => r.status >= 200 && r.status < 300,');
      } else {
        lines.push(`    'status is ${checkStatus}': (r) => r.status === ${checkStatus},`);
      }
      lines.push('  });');
    }

    lines.push('');
    lines.push('  sleep(1);');
    lines.push('}');

    document.getElementById('k6-output').textContent = lines.join('\n');
  }

  document.getElementById('k6-copy').addEventListener('click', () => {
    const text = document.getElementById('k6-output').textContent;
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById('k6-copy');
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy Script', 1500);
    });
  });

  update();
})();
</script>
