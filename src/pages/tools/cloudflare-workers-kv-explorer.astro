---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CloudflareKVExplorer from '../../components/CloudflareKVExplorer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is Cloudflare Workers KV?",
    answer: "Cloudflare Workers KV is a globally distributed key-value store accessible from Cloudflare Workers. Values are replicated across Cloudflare's 300+ PoPs and served with low latency reads (~5ms median). KV supports string, JSON, ArrayBuffer, and ReadableStream values, with optional metadata and TTL. It uses eventual consistency — writes propagate globally within ~60 seconds, so it's ideal for read-heavy workloads like config, feature flags, and user session data."
  },
  {
    question: "What are the limits of Cloudflare Workers KV?",
    answer: "Key limits: max 512 bytes. Value limits: max 25MB. Metadata: max 1024 bytes. TTL minimum: 60 seconds. List returns up to 1000 keys per call with cursor-based pagination. The free tier provides 100K reads/day and 1K writes/day. Paid plans offer higher limits. KV is not suitable for workloads requiring strong consistency, real-time updates, or heavy write throughput — use Cloudflare D1 (SQL) or Durable Objects for those."
  },
  {
    question: "What is the difference between expiration and expirationTtl?",
    answer: "expirationTtl specifies seconds from now until the key expires (relative). expiration specifies an absolute Unix timestamp (seconds since epoch). For example, expirationTtl: 3600 means the key expires in 1 hour. expiration: 1735689600 means the key expires at that specific Unix timestamp. The minimum value for either is 60 seconds. Keys that have expired are immediately unavailable but may not be purged from storage instantly."
  },
  {
    question: "How do I set up a KV namespace in wrangler?",
    answer: "First create the namespace: 'wrangler kv:namespace create MY_NAMESPACE'. This returns a namespace ID. Add it to wrangler.toml: [[kv_namespaces]] binding = \"MY_KV\" id = \"<namespace-id>\". For local dev/preview, create a separate preview namespace: 'wrangler kv:namespace create MY_NAMESPACE --preview' and add the preview_id. In your Worker code, access it as env.MY_KV which has the full KVNamespace TypeScript interface."
  },
  {
    question: "What caching strategies work best with KV?",
    answer: "KV reads are already fast (~5-50ms globally) but you can layer the Cache API on top for sub-millisecond repeated reads within the same PoP (cache.match / cache.put). For stale-while-revalidate, use ctx.waitUntil() to update KV asynchronously after returning the cached response. For TTL-based invalidation, put values with expirationTtl so they auto-expire. For strong invalidation, include a version in the key (e.g., 'config:v3:settings') and update atomically."
  },
];
---

<BaseLayout
  title="Cloudflare Workers KV Explorer — KV Code Generator & Reference"
  description="Generate Cloudflare Workers KV code snippets instantly. Configure namespace, key, operation (get/put/delete/list), TTL, and metadata. Includes wrangler.toml config and caching strategy patterns."
  tool="Cloudflare Workers KV, KV code generator, wrangler kv, cloudflare edge storage, Workers KV examples"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Cloudflare Workers KV Explorer</h1>
  <p class="text-text-muted mb-4">Generate complete Cloudflare Workers KV code snippets. Configure operations, TTL, metadata, and caching strategies — with wrangler.toml binding config included.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> get / put / delete / list</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Metadata & TTL options</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> wrangler.toml config</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Caching strategy patterns</span>
  </div>

  <CloudflareKVExplorer client:only="preact" />

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Cloudflare Workers KV Explorer" relatedTags={['cloudflare', 'edge', 'workers', 'kv', 'serverless', 'storage', 'wrangler']} />
</BaseLayout>
