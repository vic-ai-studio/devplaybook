---
import BaseLayout from '../../layouts/BaseLayout.astro';
import XmlFormatter from '../../components/XmlFormatter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What does XML formatting do?", answer: "XML formatting (beautifying) adds consistent indentation and line breaks to make XML human-readable. Minifying does the opposite — it removes all whitespace to reduce file size for transmission or storage." },
  { question: "How does the XML validator detect errors?", answer: "The formatter uses the browser's built-in DOMParser with 'application/xml' MIME type. If the XML is malformed, the parser returns a parsererror element with a description of the problem." },
  { question: "What is the difference between XML and HTML?", answer: "XML is a strict markup language where all tags must be closed and properly nested. HTML is more forgiving. XML is used for configuration files, data exchange (REST/SOAP APIs), SVG, and more." },
  { question: "Does self-closing tag formatting work?", answer: "Yes. Elements with no child content are serialized as self-closing tags (e.g., <br/>) to produce compact, valid XML output." },
];
---

<BaseLayout
  title="XML Formatter & Validator — Free Online Tool"
  description="Format, validate, and minify XML online. Detect syntax errors instantly and pretty-print with configurable indentation. Free, 100% browser-side."
  tool="XML formatter, XML beautifier, XML validator, XML minifier, pretty print XML, format XML online"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">XML Formatter & Validator</h1>
  <p class="text-text-muted mb-4">Format messy XML with clean indentation or minify it to reduce size. Invalid XML is caught instantly with a clear error message. All processing runs in your browser — nothing sent to any server.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No data leaves your machine</span>
  </div>
  <XmlFormatter client:only="preact" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more free developer tools?</p>
    <a href="/tools" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Browse All Free Tools →</a>
  </div>
  <ToolPageCta currentTool="XML Formatter" relatedTags={['xml', 'formatter', 'validator', 'data']} />
</BaseLayout>
