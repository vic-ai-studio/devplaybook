---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PinoLoggerConfig from '../../components/PinoLoggerConfig.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is Pino and why is it fast?", answer: "Pino is a structured JSON logger for Node.js, widely regarded as one of the fastest loggers available. Its speed comes from minimizing object allocation during log calls, using a worker thread (asynchronous) for I/O when possible, and serializing log records to JSON strings as efficiently as possible. Unlike Winston, Pino separates concerns — the logger writes to stdout and a separate process (pino-pretty, log rotation, cloud transport) handles formatting." },
  { question: "What is pino-pretty and when should I use it?", answer: "pino-pretty is a development-time formatter that converts Pino's compact JSON output into a human-readable colorized format. Install it as a dev dependency: npm install -D pino-pretty. Use it only in development — in production, keep raw JSON output which is faster and directly ingestable by log aggregators (Datadog, Loki, CloudWatch). Configure it as a transport: { target: 'pino-pretty', options: { colorize: true } }." },
  { question: "How do I use Pino in a Fastify or Express app?", answer: "For Fastify: pass logger: true (or logger: { level: 'info' }) in the Fastify constructor — Fastify uses Pino internally. For Express: import pino and pino-http, then use app.use(pinoHttp({ logger: pinoInstance })). The pinoHttp middleware automatically logs each request/response pair including status code, response time, and content length." },
  { question: "What is the redact option in Pino?", answer: "redact removes or masks sensitive fields from log output. Pass redact: ['password', 'req.headers.authorization', 'user.email'] to replace those paths with '[Redacted]'. Use 'req.headers.authorization' to hide Bearer tokens, '*.password' to redact passwords at any depth. Redaction uses fast-redact under the hood and runs at serialization time with near-zero overhead." },
  { question: "How does Pino's child logger work?", answer: "const child = logger.child({ requestId: '123' }) creates a new logger that inherits the parent's config but adds fixed fields to every log line. This is the idiomatic way to add context — in web servers, create a child logger per request with { requestId, userId } so every log from that request automatically includes that context without passing it manually to every function." },
  { question: "What is the difference between Pino levels?", answer: "Pino has 6 levels in ascending severity: trace (5) for verbose debugging, debug (10) for development diagnostics, info (20) for normal operation events, warn (30) for degraded but functioning states, error (40) for failures that need attention, fatal (50) for critical failures that crash the app. Setting level: 'info' suppresses trace and debug. In production, use 'info' or 'warn'. In development, use 'debug' or 'trace'." },
];
---

<BaseLayout
  title="Pino Logger Config Builder — Node.js Structured Logging Setup"
  description="Configure Pino structured logger for Node.js visually. Set log level, pretty-print, transport, redact paths, serializers, and more. Get copy-ready pino config code. Free tool."
  tool="Pino Logger, pino config, Node.js logging, structured logging, pino-pretty, log configuration, JSON logging"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Pino Logger Config Builder",
    "url": "https://devplaybook.cc/tools/pino-logger-config",
    "description": "Build Pino structured logger configurations visually. Configure log level, transports, pretty-print, redaction paths, and serializers. Get Node.js code ready to paste into your app.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Pino Logger Config Builder</h1>
  <p class="text-text-muted mb-4">Configure <strong>Pino</strong> structured logging for Node.js. Set log level, transport, pretty-print, redaction paths, and serializers — get copy-ready Node.js code instantly.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All transport types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Redact sensitive fields</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> pino-pretty support</span>
  </div>
  <PinoLoggerConfig client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Pino Logger Config Builder" relatedTags={['nodejs', 'logging', 'backend', 'typescript', 'pino', 'monitoring']} />
</BaseLayout>
