---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is PromQL?", answer: "PromQL (Prometheus Query Language) is the functional expression language used to query Prometheus metrics. It lets you select and aggregate time series data in real time. PromQL queries return instant vectors, range vectors, scalars, or strings." },
  { question: "What are label matchers and which operators are available?", answer: "Label matchers filter which time series are selected. The four operators are: = (exact match), != (not equal), =~ (regex match), and !~ (regex not match). For example, {job=\\\"api-server\\\", status=~\\\"5..\\\"} selects series where job is api-server and status matches 5xx." },
  { question: "What is the difference between rate() and irate()?", answer: "rate() calculates the per-second average rate over the full range window, smoothing out spikes. irate() uses only the last two data points, making it more responsive to sudden spikes but noisier. Use rate() for most alerting and irate() for burst detection." },
  { question: "When should I use increase() instead of rate()?", answer: "Use increase() when you want the total count of events over a time window. increase(http_requests_total[1h]) gives requests in the last hour; rate(http_requests_total[5m]) gives requests/sec averaged over 5 minutes." },
  { question: "What do the by() and without() clauses do?", answer: "by() keeps only listed labels and aggregates everything else together. without() drops listed labels and keeps all others. They are inverses of each other. Use by(job) for per-job totals; use without(instance) to remove high-cardinality labels." },
  { question: "How do I build a histogram quantile query?", answer: "Use histogram_quantile(phi, rate(metric_bucket[range])). For example: histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m])) gives the p95 latency. The metric must be a Prometheus histogram type with _bucket suffix." },
];
---

<BaseLayout
  title="Prometheus Query Builder — Visual PromQL Query Generator"
  description="Build PromQL queries visually. Add metric name, label filters, aggregation functions, and time ranges. Generate ready-to-use Prometheus queries with a copy button. Free, runs in your browser."
  tool="Prometheus Query Builder, PromQL Generator, Prometheus Visual Query Editor, PromQL Builder"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Prometheus Query Builder</h1>
  <p class="text-text-muted mb-4">Build PromQL queries visually. Select a metric, add label filters, choose an aggregation and range, then copy your ready-to-use query. No PromQL memorization required.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Live PromQL preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> rate / irate / histogram_quantile</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Dynamic label filters</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Recording rule output</span>
  </div>

  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-3">Quick-select Common Metrics</h2>
    <div class="flex flex-wrap gap-2">
      <button data-metric="http_requests_total" data-agg="rate" class="quick-metric text-xs bg-black/20 border border-border px-2.5 py-1 rounded-lg hover:border-primary transition-colors">http_requests_total</button>
      <button data-metric="http_request_duration_seconds" data-agg="histogram_quantile" class="quick-metric text-xs bg-black/20 border border-border px-2.5 py-1 rounded-lg hover:border-primary transition-colors">http_request_duration_seconds (p95)</button>
      <button data-metric="container_cpu_usage_seconds_total" data-agg="rate" class="quick-metric text-xs bg-black/20 border border-border px-2.5 py-1 rounded-lg hover:border-primary transition-colors">container_cpu_usage_seconds_total</button>
      <button data-metric="container_memory_usage_bytes" data-agg="avg" class="quick-metric text-xs bg-black/20 border border-border px-2.5 py-1 rounded-lg hover:border-primary transition-colors">container_memory_usage_bytes</button>
      <button data-metric="up" data-agg="none" class="quick-metric text-xs bg-black/20 border border-border px-2.5 py-1 rounded-lg hover:border-primary transition-colors">up (availability)</button>
      <button data-metric="process_cpu_seconds_total" data-agg="rate" class="quick-metric text-xs bg-black/20 border border-border px-2.5 py-1 rounded-lg hover:border-primary transition-colors">process_cpu_seconds_total</button>
      <button data-metric="go_goroutines" data-agg="avg" class="quick-metric text-xs bg-black/20 border border-border px-2.5 py-1 rounded-lg hover:border-primary transition-colors">go_goroutines</button>
      <button data-metric="node_memory_MemAvailable_bytes" data-agg="min" class="quick-metric text-xs bg-black/20 border border-border px-2.5 py-1 rounded-lg hover:border-primary transition-colors">node_memory_MemAvailable_bytes</button>
    </div>
  </div>

  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Query Builder</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Metric Name</label>
        <input id="metric-name" type="text" value="http_requests_total"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Aggregation Function</label>
        <select id="agg-func" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="none">None (raw selector)</option>
          <option value="rate" selected>rate()</option>
          <option value="irate">irate()</option>
          <option value="increase">increase()</option>
          <option value="sum">sum()</option>
          <option value="avg">avg()</option>
          <option value="min">min()</option>
          <option value="max">max()</option>
          <option value="count">count()</option>
          <option value="histogram_quantile">histogram_quantile() p95</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Range (for rate / irate / increase)</label>
        <select id="range-val" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="1m">1m</option>
          <option value="5m" selected>5m</option>
          <option value="15m">15m</option>
          <option value="30m">30m</option>
          <option value="1h">1h</option>
          <option value="6h">6h</option>
          <option value="24h">24h</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Group By Labels (comma-separated)</label>
        <input id="by-labels" type="text" placeholder="job, instance, status_code"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">Without Labels (comma-separated)</label>
        <input id="without-labels" type="text" placeholder="instance"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
      </div>
      <div class="flex items-center gap-3 pt-5">
        <input type="checkbox" id="recording-rule" />
        <label for="recording-rule" class="text-sm font-medium cursor-pointer">Generate as Recording Rule</label>
      </div>
    </div>
    <div class="mb-2">
      <div class="flex items-center justify-between mb-2">
        <label class="block text-sm font-medium">Label Filters</label>
        <button id="add-filter" class="text-xs bg-primary text-white px-2.5 py-1 rounded-lg hover:opacity-90">+ Add Filter</button>
      </div>
      <div id="filters-list" class="space-y-2"></div>
    </div>
  </div>

  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-base font-semibold">Generated PromQL Query</h2>
      <button id="copy-btn" class="text-xs bg-primary text-white px-3 py-1.5 rounded-lg hover:opacity-90">Copy Query</button>
    </div>
    <pre id="query-output" class="bg-black/20 rounded-lg p-4 text-sm font-mono overflow-x-auto whitespace-pre text-green-300 min-h-[60px]"></pre>
    <p id="query-explanation" class="text-xs text-text-muted mt-3"></p>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Prometheus Query Builder" relatedTags={['prometheus', 'observability', 'monitoring', 'grafana', 'devops', 'metrics', 'promql']} />
</BaseLayout>

<script is:inline>
  var filterCount = 0;

  function addFilter(key, op, val) {
    filterCount++;
    var id = "filter-" + filterCount;
    var row = document.createElement("div");
    row.id = id;
    row.className = "flex items-center gap-2";
    var opOpts = ["=","!=","=~","!~"].map(function(o){ return "<option value=\"" + o + "\"" + (o === (op||"=") ? " selected" : "") + ">" + o + "</option>"; }).join("");
    row.innerHTML =
      "<input type=\"text\" value=\"" + (key||"") + "\" placeholder=\"label name\" class=\"filter-key w-1/3 bg-bg-card border border-border rounded-lg px-2.5 py-1.5 text-xs font-mono focus:outline-none focus:border-primary\" />" +
      "<select class=\"filter-op bg-bg-card border border-border rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:border-primary\">" + opOpts + "</select>" +
      "<input type=\"text\" value=\"" + (val||"") + "\" placeholder=\"value\" class=\"filter-val flex-1 bg-bg-card border border-border rounded-lg px-2.5 py-1.5 text-xs font-mono focus:outline-none focus:border-primary\" />" +
      "<button class=\"remove-filter text-red-400 hover:text-red-600 text-lg leading-none px-1\">&#215;</button>";
    row.querySelector(".remove-filter").addEventListener("click", function(){ row.remove(); buildQuery(); });
    row.querySelectorAll("input, select").forEach(function(el){ el.addEventListener("input", buildQuery); });
    document.getElementById("filters-list").appendChild(row);
  }

  function getFilters() {
    var result = [];
    document.querySelectorAll("#filters-list > div").forEach(function(row) {
      var k = row.querySelector(".filter-key").value.trim();
      var o = row.querySelector(".filter-op").value;
      var v = row.querySelector(".filter-val").value.trim();
      if (k && v) result.push({ key: k, op: o, val: v });
    });
    return result;
  }

  function buildQuery() {
    var metric  = document.getElementById("metric-name").value.trim() || "metric";
    var aggFunc = document.getElementById("agg-func").value;
    var range   = document.getElementById("range-val").value;
    var byLbls  = document.getElementById("by-labels").value.trim();
    var woLbls  = document.getElementById("without-labels").value.trim();
    var isRule  = document.getElementById("recording-rule").checked;
    var filters = getFilters();

    var selectors = filters.map(function(f){ return f.key + f.op + "\"" + f.val + "\""; }).join(", ");
    var selector  = metric + (selectors ? "{" + selectors + "}" : "");

    var rateNeeds = ["rate","irate","increase"].indexOf(aggFunc) !== -1;
    var histNeeds = aggFunc === "histogram_quantile";
    var aggNeeds  = ["sum","avg","min","max","count"].indexOf(aggFunc) !== -1;

    var inner = rateNeeds ? aggFunc + "(" + selector + "[" + range + "])" :
                histNeeds ? "rate(" + selector.replace(/_total$/, "_bucket").replace(/_seconds$/, "_seconds_bucket") + "[" + range + "])" :
                selector;

    var grouping = byLbls ? " by(" + byLbls + ")" : woLbls ? " without(" + woLbls + ")" : "";
    var query;

    if (histNeeds) {
      query = "histogram_quantile(0.95,\n  sum by(le" + (byLbls ? ", " + byLbls : "") + ")(\n    " + inner + "\n  )\n)";
    } else if (aggNeeds) {
      query = aggFunc + grouping + "(\n  " + inner + "\n)";
    } else if (rateNeeds && grouping) {
      query = "sum" + grouping + "(\n  " + inner + "\n)";
    } else {
      query = inner;
    }

    var out = isRule
      ? "# Recording rule\nrecord: " + metric.replace(/_total$/,"").replace(/_seconds$/,"_duration") + ":rate" + range + "\nexpr: |\n  " + query.replace(/\n/g, "\n  ")
      : query;

    document.getElementById("query-output").textContent = out;

    var exps = { none: "Selects raw time series without aggregation.", rate: "Per-second average rate over " + range + ". Best for counters.", irate: "Per-second rate using last 2 samples — sensitive to spikes.", increase: "Total counter increase over " + range + ".", sum: "Sum of all matching time series.", avg: "Average across all matching time series.", min: "Minimum value across matching time series.", max: "Maximum value across matching time series.", count: "Number of matching time series.", histogram_quantile: "95th percentile latency from histogram buckets over " + range + "." };
    document.getElementById("query-explanation").textContent = exps[aggFunc] || "";
  }

  document.getElementById("add-filter").addEventListener("click", function(){ addFilter("","=",""); buildQuery(); });

  document.querySelectorAll(".quick-metric").forEach(function(btn){
    btn.addEventListener("click", function(){
      document.getElementById("metric-name").value = btn.getAttribute("data-metric");
      var agg = btn.getAttribute("data-agg");
      if (agg) document.getElementById("agg-func").value = agg;
      buildQuery();
    });
  });

  document.querySelectorAll("input, select").forEach(function(el){ el.addEventListener("input", buildQuery); });

  document.getElementById("copy-btn").addEventListener("click", function(){
    var text = document.getElementById("query-output").textContent;
    navigator.clipboard.writeText(text).then(function(){
      var btn = document.getElementById("copy-btn");
      btn.textContent = "Copied!"; setTimeout(function(){ btn.textContent = "Copy Query"; }, 2000);
    }).catch(function(){
      var ta = document.createElement("textarea"); ta.value = text; document.body.appendChild(ta); ta.select(); document.execCommand("copy"); document.body.removeChild(ta);
      var btn = document.getElementById("copy-btn");
      btn.textContent = "Copied!"; setTimeout(function(){ btn.textContent = "Copy Query"; }, 2000);
    });
  });

  addFilter("job", "=", "api-server");
  buildQuery();
</script>
