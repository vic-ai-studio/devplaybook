---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PrometheusQueryBuilder from '../../components/PrometheusQueryBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is PromQL?",
    answer: "PromQL (Prometheus Query Language) is the functional expression language used to query Prometheus metrics. It lets you select and aggregate time series data in real time. PromQL queries return either instant vectors (a single value per series), range vectors (a set of values over a time window), scalars, or strings."
  },
  {
    question: "What are label matchers and which operators are available?",
    answer: "Label matchers filter which time series are selected from a metric. The four operators are: = (exact match), != (not equal), =~ (regex match), and !~ (regex not match). For example, {job=\"api-server\", status_code=~\"5..\"} selects all series where job is exactly 'api-server' and status_code matches the regex 5xx."
  },
  {
    question: "What is the difference between rate() and irate()?",
    answer: "rate() calculates the per-second average rate of increase over the entire range window, making it suitable for dashboards and alerting because it smooths out spikes. irate() calculates the per-second rate using only the last two data points in the range window, making it more responsive to sudden spikes but more noisy. Use rate() for most alerting rules and irate() when you want to detect brief traffic bursts."
  },
  {
    question: "When should I use increase() instead of rate()?",
    answer: "Use increase() when you want the total count of events over a time window rather than a per-second rate. For example, increase(http_requests_total[1h]) gives the number of requests in the last hour, while rate(http_requests_total[5m]) gives requests per second averaged over 5 minutes. increase() is rate() multiplied by the duration of the range window."
  },
  {
    question: "How does histogram_quantile() work?",
    answer: "histogram_quantile(φ, metric_bucket[range]) calculates quantiles (percentiles) from a Prometheus histogram metric. φ is a value between 0 and 1 — for example, 0.95 means the 95th percentile. The metric must be a histogram type (ending in _bucket). Combine with rate() for accurate percentile calculations over moving windows, e.g. histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))."
  },
  {
    question: "What do the by() and without() clauses do?",
    answer: "by() and without() control how aggregation functions group time series. by(job, instance) keeps only the listed labels and aggregates everything else together — useful when you want per-job totals. without(instance) drops the listed labels and keeps all others — useful when you want to remove high-cardinality labels like instance from a sum. They are the inverse of each other."
  },
];
---

<BaseLayout
  title="Prometheus Query Builder — Visual PromQL Generator"
  description="Build Prometheus PromQL queries visually. Select metrics, add label matchers, choose aggregations and time ranges. Generate ready-to-use PromQL and Grafana panel JSON instantly. Free, runs in your browser."
  tool="prometheus query builder, PromQL generator, prometheus metrics query, grafana query builder, promql visual editor, prometheus label matcher"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Prometheus Query Builder",
    "url": "https://devplaybook.cc/tools/prometheus-query-builder",
    "description": "Build Prometheus PromQL queries visually with label matchers, aggregation functions, rate intervals, and grouping. Generates PromQL and Grafana panel JSON.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Prometheus Query Builder</h1>
  <p class="text-text-muted mb-4">
    Build <strong>PromQL queries</strong> visually — add label matchers, choose an aggregation function, set rate intervals and grouping, then copy the ready-to-use query or export a <strong>Grafana panel JSON</strong>. No PromQL memorisation required.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live PromQL preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> rate / irate / histogram_quantile</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Grafana panel JSON export</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <PrometheusQueryBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more free developer tools?</p>
    <a href="/tools" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Browse All Free Tools →</a>
  </div>
  <ToolPageCta currentTool="Prometheus Query Builder" relatedTags={['prometheus', 'observability', 'monitoring', 'grafana', 'devops', 'metrics']} />
</BaseLayout>
