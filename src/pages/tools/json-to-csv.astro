---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonToCsv from '../../components/JsonToCsv.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="JSON to CSV Converter"
  description="Convert a JSON array to CSV format instantly. Choose comma, tab, semicolon, or pipe delimiter. Supports nested objects and arrays. Download as .csv. Free tool."
  tool="JSON to CSV Converter, JSON to Spreadsheet, JSON Array to CSV, Data Export"
>
  <h1 class="text-3xl font-bold mb-2">JSON to CSV Converter</h1>
  <p class="text-text-muted mb-8">Paste a JSON array and convert it to CSV format. Choose your delimiter (comma, tab, semicolon, pipe), copy the result, or download as a .csv file. All processing is client-side — nothing is uploaded.</p>
  <JsonToCsv client:only="preact" />
  <ToolPageCta currentTool="JSON to CSV Converter" relatedTags={['json', 'csv', 'data', 'api', 'database']} />
</BaseLayout>
