---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Big O notation?", answer: "Big O notation describes the upper bound of an algorithm's time or space requirements as the input size n grows toward infinity. It ignores constants and lower-order terms to focus on the dominant growth factor. O(1) is constant, O(log n) is logarithmic, O(n) is linear, O(n log n) is log-linear, O(n²) is quadratic, O(2ⁿ) is exponential." },
  { question: "What's the difference between best, average, and worst case?", answer: "Worst case (most common for Big O) describes the maximum time/space for any input of size n. Average case (often Θ notation) describes expected performance across typical inputs. Best case (Ω notation) describes the minimum. For example, quicksort has O(n²) worst case but O(n log n) average case. Big O typically refers to worst case unless specified." },
  { question: "Why ignore constants in Big O?", answer: "Constants depend on hardware, compiler, and implementation details, so they're not useful for comparing algorithms at scale. O(2n) and O(1000n) are both O(n) because both grow linearly — for large enough n, the constant factor matters less than the growth rate. When constants are large and n is small, profiling actual code is more useful than asymptotic analysis." },
  { question: "What is the difference between time and space complexity?", answer: "Time complexity measures how many operations an algorithm performs relative to input size. Space complexity measures how much memory it uses. An algorithm can trade one for the other — memoization (dynamic programming) reduces time from O(2ⁿ) to O(n) but uses O(n) space. Always analyse both when choosing an algorithm." },
  { question: "How do I identify nested loops?", answer: "Each nested loop multiplies the complexity. A single loop over n elements is O(n). Two nested loops are O(n²). Three nested loops are O(n³). Loops that halve their range each iteration are O(log n). A loop over n with an inner binary search is O(n log n). The key is identifying whether inner loops depend on the outer loop variable." },
];
---

<BaseLayout
  title="Big O Analyzer — Algorithm Complexity Explainer"
  description="Identify the Big O time and space complexity of common algorithm patterns. Paste code or describe your algorithm to get complexity analysis, growth chart, and plain-English explanation. Runs in your browser."
  tool="Big O Analyzer, time complexity, space complexity, algorithm analysis, Big O notation, O(n), O(log n), O(n squared), complexity calculator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Big O Analyzer",
    "url": "https://devplaybook.cc/tools/big-o-analyzer",
    "description": "Identify Big O time and space complexity from code patterns. Get growth chart comparison and plain-English explanations. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Big O Complexity Analyzer</h1>
  <p class="text-text-muted mb-4">Paste code snippets to detect <strong>time and space complexity</strong> from common patterns — nested loops, recursion, binary search, hash maps. Or browse the reference table for all Big O classes with explanations and real-world examples.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Pattern-based complexity detection</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Growth chart comparison</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Full reference table</span>
  </div>

  <!-- Tabs -->
  <div class="flex border-b border-border mb-5">
    <button class="tab-btn active px-4 py-2.5 text-sm font-medium border-b-2 border-primary text-primary" data-tab="analyzer">Analyzer</button>
    <button class="tab-btn px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-foreground" data-tab="reference">Reference Table</button>
    <button class="tab-btn px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-foreground" data-tab="growth">Growth Chart</button>
  </div>

  <!-- Analyzer Tab -->
  <div id="tab-analyzer" class="tab-content">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <div class="flex items-center justify-between mb-3">
          <label class="text-sm font-semibold">Paste Code Snippet</label>
          <button id="btn-example-bigo" class="text-xs text-primary hover:underline">Load Example</button>
        </div>
        <textarea id="bigo-input" class="w-full bg-bg-page border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary resize-y" rows="14" placeholder="// Paste a function or describe algorithm patterns...&#10;// e.g. nested loops, recursion, binary search"></textarea>
        <button id="btn-analyze-bigo" class="mt-3 w-full px-4 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Analyze</button>
      </div>

      <div class="space-y-4">
        <div class="bg-bg-card border border-border rounded-lg p-4">
          <h2 class="text-sm font-semibold mb-3">Detected Complexity</h2>
          <div class="flex gap-4 mb-3">
            <div class="flex-1 bg-bg-page rounded-lg p-3 text-center">
              <div class="text-xs text-text-muted mb-1">Time</div>
              <div id="time-complexity" class="text-2xl font-bold font-mono text-primary">—</div>
            </div>
            <div class="flex-1 bg-bg-page rounded-lg p-3 text-center">
              <div class="text-xs text-text-muted mb-1">Space</div>
              <div id="space-complexity" class="text-2xl font-bold font-mono text-blue-400">—</div>
            </div>
          </div>
          <div id="complexity-explanation" class="text-sm text-text-muted">Run analysis to see results.</div>
        </div>

        <div id="patterns-found" class="bg-bg-card border border-border rounded-lg p-4">
          <h2 class="text-sm font-semibold mb-3">Patterns Detected</h2>
          <div id="pattern-list" class="space-y-1.5 text-sm text-text-muted">
            <p class="text-xs italic">No patterns detected yet.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Reference Table Tab -->
  <div id="tab-reference" class="tab-content hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="border-b border-border">
            <th class="text-left p-3 font-semibold">Notation</th>
            <th class="text-left p-3 font-semibold">Name</th>
            <th class="text-left p-3 font-semibold">n=100</th>
            <th class="text-left p-3 font-semibold">n=10,000</th>
            <th class="text-left p-3 font-semibold">Example</th>
          </tr>
        </thead>
        <tbody id="ref-table-body" class="divide-y divide-border"></tbody>
      </table>
    </div>
  </div>

  <!-- Growth Chart Tab -->
  <div id="tab-growth" class="tab-content hidden">
    <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
      <h2 class="text-sm font-semibold mb-3">Growth Comparison (n = 1 to 20)</h2>
      <canvas id="growth-canvas" width="700" height="320" class="w-full rounded"></canvas>
    </div>
    <p class="text-xs text-text-muted">Chart shows operations count for n = 1 to 20. O(2ⁿ) and O(n!) are capped for readability.</p>
  </div>

  <ToolPageCta currentTool="Big O Analyzer" relatedTags={['algorithms', 'data-structures', 'performance', 'computer-science', 'javascript']} />
  <FaqSection faq={faq} />
</BaseLayout>

<script>
const EXAMPLE_BIGO = `// Binary search — O(log n) time, O(1) space
function binarySearch(arr, target) {
  let left = 0, right = arr.length - 1;
  while (left <= right) {
    const mid = Math.floor((left + right) / 2);
    if (arr[mid] === target) return mid;
    if (arr[mid] < target) left = mid + 1;
    else right = mid - 1;
  }
  return -1;
}

// Two-sum with hash map — O(n) time, O(n) space
function twoSum(nums, target) {
  const map = new Map();
  for (let i = 0; i < nums.length; i++) {
    const complement = target - nums[i];
    if (map.has(complement)) return [map.get(complement), i];
    map.set(nums[i], i);
  }
  return [];
}`;

const COMPLEXITY_TABLE = [
  { notation: 'O(1)', name: 'Constant', n100: '1', n10k: '1', color: '#22c55e', example: 'Hash map lookup, array index access' },
  { notation: 'O(log n)', name: 'Logarithmic', n100: '7', n10k: '14', color: '#3b82f6', example: 'Binary search, balanced BST operations' },
  { notation: 'O(n)', name: 'Linear', n100: '100', n10k: '10,000', color: '#60a5fa', example: 'Linear search, single loop, array sum' },
  { notation: 'O(n log n)', name: 'Log-linear', n100: '664', n10k: '132,877', color: '#facc15', example: 'Merge sort, heap sort, quicksort avg' },
  { notation: 'O(n²)', name: 'Quadratic', n100: '10,000', n10k: '100M', color: '#f97316', example: 'Bubble/insertion sort, nested loops' },
  { notation: 'O(n³)', name: 'Cubic', n100: '1M', n10k: '1T', color: '#ef4444', example: 'Naïve matrix multiplication, 3 nested loops' },
  { notation: 'O(2ⁿ)', name: 'Exponential', n100: '1.27×10³⁰', n10k: '∞', color: '#a855f7', example: 'Recursive Fibonacci, subset enumeration' },
  { notation: 'O(n!)', name: 'Factorial', n100: '9.3×10¹⁵⁷', n10k: '∞', color: '#ec4899', example: 'Brute-force TSP, permutation generation' },
];

// Pattern rules for detection
const PATTERNS: { regex: RegExp; time: string; space: string; label: string; note: string }[] = [
  { regex: /new\s+(?:Map|Set|HashMap|dict)\s*\(/i, time: 'O(n)', space: 'O(n)', label: 'Hash map/set allocation', note: 'Using a hash map for lookup takes O(1) per op but O(n) space' },
  { regex: /\.sort\s*\(/i, time: 'O(n log n)', space: 'O(log n)', label: 'Array.sort()', note: 'V8 TimSort: O(n log n) average, O(log n) stack space' },
  { regex: /\bfor\b.*\bfor\b/s, time: 'O(n²)', space: 'O(1)', label: 'Nested loops detected', note: 'Two nested loops over the same input = O(n²)' },
  { regex: /\bfor\b.*\bfor\b.*\bfor\b/s, time: 'O(n³)', space: 'O(1)', label: 'Triple nested loops', note: 'Three nested loops = O(n³), consider restructuring' },
  { regex: /(?:Math\.floor|Math\.ceil).*\/\s*2|>> 1/, time: 'O(log n)', space: 'O(1)', label: 'Halving pattern (binary search style)', note: 'Dividing range in half each step = O(log n)' },
  { regex: /\brecurse|return\s+\w+\s*\(.*-\s*1\s*\)|return\s+\w+\(n\s*-\s*1\)/, time: 'O(2ⁿ)', space: 'O(n)', label: 'Recursive calls (branching)', note: 'Multiple recursive branches = exponential without memoization' },
  { regex: /memo|cache|dp\[|memoize/i, time: 'O(n)', space: 'O(n)', label: 'Memoization / DP detected', note: 'Memoization reduces exponential recursion to O(n) time with O(n) space' },
];

function analyzeCode() {
  const code = (document.getElementById('bigo-input') as HTMLTextAreaElement).value;
  if (!code.trim()) return;

  let bestTime = 'O(n)', bestSpace = 'O(1)', notes: string[] = [];

  const order = ['O(n!)', 'O(2ⁿ)', 'O(n³)', 'O(n²)', 'O(n log n)', 'O(n)', 'O(log n)', 'O(1)'];

  for (const p of PATTERNS) {
    if (p.regex.test(code)) {
      notes.push(`<div class="flex items-start gap-2 py-1.5 border-b border-border last:border-0"><span class="text-yellow-400 flex-shrink-0 mt-0.5">→</span><div><div class="font-medium text-foreground">${p.label}</div><div class="text-xs text-text-muted">${p.note}</div></div></div>`);
      if (order.indexOf(p.time) < order.indexOf(bestTime)) bestTime = p.time;
      if (order.indexOf(p.space) < order.indexOf(bestSpace)) bestSpace = p.space;
    }
  }

  const EXPLANATIONS: Record<string, string> = {
    'O(1)': 'Constant time — performance does not change regardless of input size.',
    'O(log n)': 'Logarithmic — input is halved each step. Very efficient for large inputs.',
    'O(n)': 'Linear — processes each element once. Scales well.',
    'O(n log n)': 'Log-linear — efficient sorting class. Good for large datasets.',
    'O(n²)': 'Quadratic — doubles work for each doubling of input. Avoid for n > 10,000.',
    'O(n³)': 'Cubic — extremely slow for large inputs. Only acceptable for small n.',
    'O(2ⁿ)': 'Exponential — grows very fast. Use memoization or dynamic programming.',
    'O(n!)': 'Factorial — only practical for tiny inputs (n < 12).',
  };

  document.getElementById('time-complexity')!.textContent = bestTime;
  document.getElementById('space-complexity')!.textContent = bestSpace;
  document.getElementById('complexity-explanation')!.textContent = EXPLANATIONS[bestTime] || '';

  const list = document.getElementById('pattern-list')!;
  list.innerHTML = notes.length ? notes.join('') : '<p class="text-xs">No known complexity patterns detected.</p>';
}

// Build reference table
function buildTable() {
  const tbody = document.getElementById('ref-table-body')!;
  tbody.innerHTML = COMPLEXITY_TABLE.map(row => `
    <tr class="hover:bg-bg-card/50 transition-colors">
      <td class="p-3 font-mono font-bold" style="color:${row.color}">${row.notation}</td>
      <td class="p-3 text-foreground">${row.name}</td>
      <td class="p-3 text-text-muted">${row.n100}</td>
      <td class="p-3 text-text-muted">${row.n10k}</td>
      <td class="p-3 text-text-muted text-xs">${row.example}</td>
    </tr>
  `).join('');
}

// Growth chart
function drawChart() {
  const canvas = document.getElementById('growth-canvas') as HTMLCanvasElement;
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;
  const W = canvas.width, H = canvas.height;
  const PAD = { top: 20, right: 120, bottom: 40, left: 50 };
  const chartW = W - PAD.left - PAD.right;
  const chartH = H - PAD.top - PAD.bottom;

  const isDark = document.documentElement.classList.contains('dark') || window.matchMedia('(prefers-color-scheme: dark)').matches;
  const bg = isDark ? '#1a1a2e' : '#f8f9fa';
  const gridColor = isDark ? '#2a2a3e' : '#e0e0e0';
  const textColor = isDark ? '#9ca3af' : '#6b7280';

  ctx.fillStyle = bg;
  ctx.fillRect(0, 0, W, H);

  const funcs = [
    { label: 'O(1)', fn: (_n: number) => 1, color: '#22c55e' },
    { label: 'O(log n)', fn: (n: number) => Math.log2(n), color: '#3b82f6' },
    { label: 'O(n)', fn: (n: number) => n, color: '#60a5fa' },
    { label: 'O(n log n)', fn: (n: number) => n * Math.log2(n), color: '#facc15' },
    { label: 'O(n²)', fn: (n: number) => n * n, color: '#f97316' },
    { label: 'O(2ⁿ)', fn: (n: number) => Math.min(Math.pow(2, n), 500), color: '#a855f7' },
  ];

  const N = 20;
  const maxVal = 500;

  // Grid
  ctx.strokeStyle = gridColor;
  ctx.lineWidth = 0.5;
  for (let g = 0; g <= 5; g++) {
    const y = PAD.top + chartH - (g / 5) * chartH;
    ctx.beginPath();
    ctx.moveTo(PAD.left, y);
    ctx.lineTo(PAD.left + chartW, y);
    ctx.stroke();
    ctx.fillStyle = textColor;
    ctx.font = '10px monospace';
    ctx.fillText(String(Math.round(g / 5 * maxVal)), PAD.left - 40, y + 4);
  }

  // X axis labels
  for (let n = 1; n <= N; n += 5) {
    const x = PAD.left + ((n - 1) / (N - 1)) * chartW;
    ctx.fillStyle = textColor;
    ctx.font = '10px monospace';
    ctx.fillText(String(n), x - 4, PAD.top + chartH + 18);
  }

  // Lines
  for (const f of funcs) {
    ctx.beginPath();
    ctx.strokeStyle = f.color;
    ctx.lineWidth = 2;
    for (let n = 1; n <= N; n++) {
      const val = Math.min(f.fn(n), maxVal);
      const x = PAD.left + ((n - 1) / (N - 1)) * chartW;
      const y = PAD.top + chartH - (val / maxVal) * chartH;
      n === 1 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    }
    ctx.stroke();

    // Legend
    const li = funcs.indexOf(f);
    ctx.fillStyle = f.color;
    ctx.fillRect(PAD.left + chartW + 10, PAD.top + li * 22, 12, 3);
    ctx.fillStyle = textColor;
    ctx.font = '11px monospace';
    ctx.fillText(f.label, PAD.left + chartW + 26, PAD.top + li * 22 + 4);
  }
}

// Tabs
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const tab = (btn as HTMLElement).dataset.tab!;
    document.querySelectorAll('.tab-btn').forEach(b => {
      b.classList.remove('active', 'border-primary', 'text-primary');
      b.classList.add('border-transparent', 'text-text-muted');
    });
    btn.classList.add('active', 'border-primary', 'text-primary');
    btn.classList.remove('border-transparent', 'text-text-muted');
    document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
    document.getElementById(`tab-${tab}`)?.classList.remove('hidden');
    if (tab === 'growth') drawChart();
  });
});

document.getElementById('btn-analyze-bigo')?.addEventListener('click', analyzeCode);
document.getElementById('btn-example-bigo')?.addEventListener('click', () => {
  (document.getElementById('bigo-input') as HTMLTextAreaElement).value = EXAMPLE_BIGO;
  analyzeCode();
});

buildTable();
</script>
