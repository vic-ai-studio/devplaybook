---

<BaseLayout
  title="Mobile Safe Area Calculator — iOS & Android Safe Area Insets for React Native"
  description="Calculate safe area insets for iOS and Android devices. View top, bottom, left, and right insets for iPhone Dynamic Island, notch, and Android punch-hole devices. Get React Native code."
  tool="mobile safe area calculator, iOS safe area insets, Android safe area, React Native safe area, iPhone Dynamic Island insets, safe area context"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Mobile Safe Area Calculator</h1>
  <p class="text-text-muted mb-4">View safe area insets for popular iOS and Android devices. Get React Native code for handling notches, Dynamic Island, and home indicators.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 12 popular devices</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Dynamic Island + notch data</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> React Native code snippets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Visual inset diagram</span>
  </div>

  <div class="space-y-5">
    <!-- Filter -->
    <div class="flex flex-wrap gap-2">
      <button class="filter-btn active px-4 py-2 text-sm rounded-lg bg-primary text-white" data-os="all">All Devices</button>
      <button class="filter-btn px-4 py-2 text-sm rounded-lg bg-bg border border-border hover:border-primary hover:text-primary transition-colors" data-os="iOS">iOS / iPadOS</button>
      <button class="filter-btn px-4 py-2 text-sm rounded-lg bg-bg border border-border hover:border-primary hover:text-primary transition-colors" data-os="Android">Android</button>
    </div>

    <!-- Device table -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="font-semibold mb-4">Safe Area Insets by Device</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm" id="device-table">
          <thead>
            <tr class="text-text-muted text-xs uppercase tracking-wide border-b border-border">
              <th class="text-left py-2 pr-4">Device</th>
              <th class="text-center py-2 pr-4">OS</th>
              <th class="text-center py-2 pr-4">Notch Type</th>
              <th class="text-center py-2 pr-4">Top (pt)</th>
              <th class="text-center py-2 pr-4">Bottom (pt)</th>
              <th class="text-center py-2 pr-4">Width × Height</th>
              <th class="text-center py-2">Select</th>
            </tr>
          </thead>
          <tbody id="device-tbody" class="divide-y divide-border"></tbody>
        </table>
      </div>
    </div>

    <!-- Visual + code for selected device -->
    <div id="device-detail" class="hidden grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold mb-4" id="detail-name">Device</h2>
        <!-- Visual phone diagram -->
        <div class="flex justify-center">
          <div class="relative bg-bg border-2 border-border rounded-3xl" id="phone-body" style="width:160px;height:280px;">
            <div class="absolute inset-0 rounded-3xl overflow-hidden">
              <div class="absolute top-0 left-0 right-0 bg-yellow-500/20 flex items-center justify-center text-xs" id="top-inset-bar" style="height:30px">
                <span class="font-mono font-bold text-yellow-400" id="top-val">—</span>
              </div>
              <div class="absolute bottom-0 left-0 right-0 bg-blue-500/20 flex items-center justify-center text-xs" id="bottom-inset-bar" style="height:20px">
                <span class="font-mono font-bold text-blue-400" id="bottom-val">—</span>
              </div>
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="text-xs text-text-muted text-center px-4">
                  <div class="text-green-400 font-semibold mb-1">Safe Area</div>
                  <div id="safe-dims" class="font-mono text-xs"></div>
                </div>
              </div>
            </div>
            <!-- Notch indicator -->
            <div id="notch-indicator" class="absolute top-2 left-1/2 -translate-x-1/2 bg-bg-card border border-border rounded-full text-xs text-text-muted px-2 py-0.5 hidden"></div>
          </div>
        </div>
        <!-- Inset values -->
        <div class="mt-4 grid grid-cols-2 gap-2">
          <div class="bg-bg border border-border rounded-lg p-3 text-center">
            <div class="text-lg font-bold text-yellow-400" id="detail-top">—</div>
            <div class="text-xs text-text-muted">Top (pt)</div>
          </div>
          <div class="bg-bg border border-border rounded-lg p-3 text-center">
            <div class="text-lg font-bold text-blue-400" id="detail-bottom">—</div>
            <div class="text-xs text-text-muted">Bottom (pt)</div>
          </div>
          <div class="bg-bg border border-border rounded-lg p-3 text-center">
            <div class="text-lg font-bold text-primary" id="detail-left">—</div>
            <div class="text-xs text-text-muted">Left (pt)</div>
          </div>
          <div class="bg-bg border border-border rounded-lg p-3 text-center">
            <div class="text-lg font-bold text-primary" id="detail-right">—</div>
            <div class="text-xs text-text-muted">Right (pt)</div>
          </div>
        </div>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold mb-3">React Native Code</h2>
        <pre id="rn-code" class="bg-bg rounded-lg p-4 text-xs font-mono overflow-x-auto text-green-400 whitespace-pre-wrap"></pre>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Mobile Safe Area Calculator" relatedTags={['react-native', 'mobile', 'expo', 'ios', 'android', 'javascript']} />
</BaseLayout>

<script is:inline>
(function () {
  var DEVICES = JSON.parse(document.getElementById('device-data').textContent);

  var filterBtns = document.querySelectorAll('.filter-btn');
  var deviceTbody = document.getElementById('device-tbody');
  var deviceDetail = document.getElementById('device-detail');
  var currentFilter = 'all';
  var selectedDevice = null;

  function renderTable() {
    var filtered = currentFilter === 'all' ? DEVICES : DEVICES.filter(function (d) { return d.os === currentFilter; });
    deviceTbody.innerHTML = filtered.map(function (d, i) {
      var notchColors = { 'dynamic-island': 'text-purple-400', 'notch': 'text-orange-400', 'punch-hole': 'text-blue-400', 'none': 'text-text-muted' };
      var isSelected = selectedDevice && selectedDevice.name === d.name;
      return '<tr class="hover:bg-bg/50 ' + (isSelected ? 'bg-primary/5' : '') + '">' +
        '<td class="py-2.5 pr-4 font-medium">' + d.name + '</td>' +
        '<td class="text-center py-2.5 pr-4 text-xs">' + d.os + '</td>' +
        '<td class="text-center py-2.5 pr-4 text-xs ' + (notchColors[d.notch] || '') + '">' + d.notch + '</td>' +
        '<td class="text-center py-2.5 pr-4 font-mono text-yellow-400 font-bold">' + d.top + '</td>' +
        '<td class="text-center py-2.5 pr-4 font-mono text-blue-400 font-bold">' + d.bottom + '</td>' +
        '<td class="text-center py-2.5 pr-4 text-xs text-text-muted">' + d.width + ' × ' + d.height + '</td>' +
        '<td class="text-center py-2.5"><button class="select-device text-xs bg-primary/10 text-primary border border-primary/30 px-2 py-1 rounded hover:bg-primary/20 transition-colors" data-idx="' + DEVICES.indexOf(d) + '">Details</button></td>' +
        '</tr>';
    }).join('');

    deviceTbody.querySelectorAll('.select-device').forEach(function (btn) {
      btn.addEventListener('click', function () {
        selectedDevice = DEVICES[+btn.dataset.idx];
        renderDetail();
        renderTable();
      });
    });
  }

  function renderDetail() {
    if (!selectedDevice) return;
    var d = selectedDevice;
    deviceDetail.classList.remove('hidden');
    document.getElementById('detail-name').textContent = d.name + ' (' + d.os + ')';
    document.getElementById('detail-top').textContent = d.top;
    document.getElementById('detail-bottom').textContent = d.bottom;
    document.getElementById('detail-left').textContent = d.left;
    document.getElementById('detail-right').textContent = d.right;
    document.getElementById('top-val').textContent = d.top + 'pt';
    document.getElementById('bottom-val').textContent = d.bottom + 'pt';
    document.getElementById('top-inset-bar').style.height = Math.max(10, d.top / 2) + 'px';
    document.getElementById('bottom-inset-bar').style.height = Math.max(8, d.bottom / 2) + 'px';
    var safeH = d.height - d.top - d.bottom;
    document.getElementById('safe-dims').textContent = d.width + ' × ' + safeH + ' pt';

    var notchEl = document.getElementById('notch-indicator');
    if (d.notch !== 'none') {
      notchEl.classList.remove('hidden');
      notchEl.textContent = d.notch === 'dynamic-island' ? 'Dynamic Island' : d.notch;
    } else {
      notchEl.classList.add('hidden');
    }

    document.getElementById('rn-code').textContent =
      "import { useSafeAreaInsets } from 'react-native-safe-area-context';\n\n" +
      "// " + d.name + " expected insets:\n// top: " + d.top + ", bottom: " + d.bottom + ", left: " + d.left + ", right: " + d.right + "\n\n" +
      "function MyScreen() {\n" +
      "  const insets = useSafeAreaInsets();\n\n" +
      "  return (\n" +
      "    <View\n" +
      "      style={{\n" +
      "        flex: 1,\n" +
      "        paddingTop: insets.top,      // " + d.top + "pt on " + d.name + "\n" +
      "        paddingBottom: insets.bottom, // " + d.bottom + "pt\n" +
      "        paddingLeft: insets.left,\n" +
      "        paddingRight: insets.right,\n" +
      "      }}\n" +
      "    >\n" +
      "      {/* Your content here */}\n" +
      "    </View>\n" +
      "  );\n" +
      "}\n\n" +
      "// Or use SafeAreaView (simpler):\nimport { SafeAreaView } from 'react-native-safe-area-context';\n\n" +
      "function SimpleScreen() {\n  return <SafeAreaView style={{ flex: 1 }}>{/* content */}</SafeAreaView>;\n}";
  }

  filterBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      currentFilter = btn.dataset.os;
      filterBtns.forEach(function (b) {
        b.className = 'filter-btn px-4 py-2 text-sm rounded-lg bg-bg border border-border hover:border-primary hover:text-primary transition-colors';
        b.dataset.os;
      });
      btn.className = 'filter-btn active px-4 py-2 text-sm rounded-lg bg-primary text-white';
      renderTable();
    });
  });

  // Select first device by default
  selectedDevice = DEVICES[0];
  renderTable();
  renderDetail();
})();
</script>

