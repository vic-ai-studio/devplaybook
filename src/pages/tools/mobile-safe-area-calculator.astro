  { name: 'iPhone 15 Pro Max', top: 59, bottom: 34, left: 0, right: 0, width: 430, height: 932, notch: 'dynamic-island', os: 'iOS' },
  { name: 'iPhone 14 Pro', top: 59, bottom: 34, left: 0, right: 0, width: 393, height: 852, notch: 'dynamic-island', os: 'iOS' },
  { name: 'iPhone 13 / 14', top: 47, bottom: 34, left: 0, right: 0, width: 390, height: 844, notch: 'notch', os: 'iOS' },
  { name: 'iPhone SE (3rd gen)', top: 20, bottom: 0, left: 0, right: 0, width: 375, height: 667, notch: 'none', os: 'iOS' },
  { name: 'iPad Pro 12.9"', top: 24, bottom: 20, left: 0, right: 0, width: 1024, height: 1366, notch: 'none', os: 'iPadOS' },
  { name: 'Samsung S24 Ultra', top: 45, bottom: 30, left: 0, right: 0, width: 412, height: 915, notch: 'punch-hole', os: 'Android' },
  { name: 'Samsung S24', top: 45, bottom: 24, left: 0, right: 0, width: 360, height: 780, notch: 'punch-hole', os: 'Android' },
  { name: 'Pixel 9 Pro', top: 45, bottom: 24, left: 0, right: 0, width: 393, height: 851, notch: 'punch-hole', os: 'Android' },
  { name: 'Pixel 8a', top: 45, bottom: 24, left: 0, right: 0, width: 412, height: 892, notch: 'punch-hole', os: 'Android' },
