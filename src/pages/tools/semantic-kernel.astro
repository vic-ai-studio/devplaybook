---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Microsoft Semantic Kernel?",
    answer: "Semantic Kernel (SK) is Microsoft's open-source LLM orchestration framework for building AI applications in C#, Python, and Java. It is the foundation of Microsoft's own AI products (Copilot, Azure AI) and provides an enterprise-grade Kernel/Plugin/Planner architecture for composing LLM calls, tool use, memory, and complex multi-step AI workflows. It integrates natively with Azure OpenAI, OpenAI, Hugging Face, and other LLM providers."
  },
  {
    question: "What is the Kernel in Semantic Kernel?",
    answer: "The Kernel is the central orchestrator in Semantic Kernel. It holds the configured AI services (LLMs, embedding models), registered plugins, memory stores, and execution settings. All AI interactions go through the Kernel — you invoke functions, run planners, and manage memory through it. Think of it as the dependency injection container and execution engine combined."
  },
  {
    question: "What are Semantic Kernel Plugins?",
    answer: "Plugins are collections of functions (both semantic and native) that the Kernel can invoke. A semantic function is defined by a prompt template that calls an LLM. A native function is a regular C# or Python method decorated with @kernel_function. Plugins can be imported from OpenAI function calling definitions, OpenAPI specs, or defined inline. The AI can use plugins as tools — similar to LangChain tools or LlamaIndex tools."
  },
  {
    question: "What is the Semantic Kernel Planner?",
    answer: "The Planner allows the LLM to automatically create and execute multi-step plans by composing available plugins and functions. FunctionChoiceBehavior.Auto lets the LLM decide which functions to call in sequence. The older StepwisePlanner and HandlebarsPlanner generated explicit execution plans. Planners are SK's equivalent of LangChain's ReAct agents — the LLM reasons about which tools to use to fulfill a user request."
  },
  {
    question: "How does Semantic Kernel memory work?",
    answer: "Semantic Kernel provides a memory abstraction that stores text + embeddings in a vector store. You save memories with kernel.memory.save_information() and retrieve similar memories with kernel.memory.search(). SK integrates with Azure AI Search, Chroma, Qdrant, Weaviate, Redis, Postgres (pgvector), and Pinecone as memory backends. Memory enables semantic recall across conversations — remembering user preferences, past interactions, or knowledge base content."
  },
  {
    question: "Semantic Kernel vs LangChain: which should I choose?",
    answer: "Choose Semantic Kernel if: you work in the Microsoft/Azure ecosystem (Azure OpenAI, Azure AI Search, .NET), need enterprise C# support, or are building Copilot-style AI features in Microsoft products. Choose LangChain if: you work primarily in Python, need the widest LLM integrations and community ecosystem, or are building general-purpose AI applications outside the Azure stack. Both support Python — the key differentiator is the Microsoft ecosystem integration and C# support."
  },
];
