---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is LocalAI?", answer: "LocalAI is an open-source, self-hosted API server that acts as a drop-in replacement for the OpenAI API. It runs locally on your own hardware and supports text generation (LLMs), image generation (Stable Diffusion), speech-to-text (Whisper), and text-to-speech — all from a single API surface. Any application that uses the OpenAI SDK can point at LocalAI without code changes." },
  { question: "How does LocalAI differ from Ollama?", answer: "Both expose OpenAI-compatible APIs, but LocalAI is designed for multi-modal production use cases. Ollama focuses exclusively on text LLMs and is simpler to set up. LocalAI supports image generation (Stable Diffusion), speech-to-text (Whisper), text-to-speech, function calling, and can run multiple backends (llama.cpp, whisper.cpp, bark, diffusers) simultaneously from one server." },
  { question: "What backends does LocalAI support?", answer: "LocalAI is a backend orchestrator. For LLMs: llama.cpp (GGUF), GPT4All, bert.cpp, and Hugging Face Transformers. For image generation: diffusers (Stable Diffusion), DALL-E proxy. For speech: whisper.cpp (STT), bark/piper (TTS). Each model is configured with a YAML file that specifies which backend and parameters to use. Backends are loaded on demand." },
  { question: "What is a LocalAI model YAML config file?", answer: "Each model in LocalAI has a companion .yaml configuration file that defines the model path, backend, context size, GPU layers, prompt template, and API endpoint name. This lets you give models friendly names, configure parameters per-model, and expose the same model under different names with different settings. Store YAML configs in the models/ directory alongside the model files." },
  { question: "Can LocalAI generate images?", answer: "Yes. LocalAI implements the OpenAI Images API (/v1/images/generations). Configure a Stable Diffusion model (GGUF or .safetensors) with a YAML file specifying the diffusers backend. Then call it exactly like the OpenAI image generation API: POST /v1/images/generations with a prompt and image size. Generated images are returned as base64 or saved files." },
  { question: "How do I install LocalAI?", answer: "Docker is the recommended installation method. Pull ghcr.io/mudler/localai:latest (or the GPU-specific tag for CUDA/ROCm). Mount a models/ directory, and LocalAI will serve any model files it finds there. For production deployments, the AIO (all-in-one) image includes pre-downloaded popular models. LocalAI also has a one-shot installer script for bare-metal Linux installations." },
];
---

<BaseLayout
  title="LocalAI: OpenAI-Compatible API for Local LLM Inference (2026)"
  description="LocalAI is a free, open-source drop-in replacement for the OpenAI API. Run LLMs, image generation, and speech-to-text locally with Docker. Complete setup and configuration guide."
  tool="LocalAI, OpenAI compatible API, local inference, private AI API, self-hosted OpenAI, local LLM server"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"LocalAI: OpenAI-Compatible API for Local LLM Inference","url":"https://devplaybook.cc/tools/localai","description":"LocalAI is a drop-in OpenAI API replacement for local LLM, image gen, and speech inference — complete 2026 guide."})} />

  <h1 class="text-3xl font-bold mb-2">LocalAI: OpenAI-Compatible API for Local LLM Inference</h1>
  <p class="text-text-muted mb-6">LocalAI is the most comprehensive self-hosted OpenAI API replacement. Swap <code class="bg-bg-card border border-border rounded px-1.5 py-0.5 text-sm font-mono">api.openai.com</code> for <code class="bg-bg-card border border-border rounded px-1.5 py-0.5 text-sm font-mono">localhost:8080</code> and your existing apps run entirely on local hardware — supporting chat, image generation, speech, and embeddings with zero code changes.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Drop-in OpenAI API replacement</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> LLM + image gen + speech in one server</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multiple backends (llama.cpp, Whisper, Stable Diffusion)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Docker-first deployment</span>
  </div>

  <ToolPageCta />

  <!-- Docker setup -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Docker Installation</h2>
    <p class="text-text-muted text-sm mb-4">LocalAI provides Docker images for CPU, NVIDIA CUDA, and AMD ROCm. The AIO (all-in-one) image bundles popular models; the base image lets you bring your own.</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># CPU-only (works on any machine)
docker run -d \
  -p 8080:8080 \
  -v $(pwd)/models:/build/models \
  --name localai \
  ghcr.io/mudler/localai:latest

# NVIDIA GPU (CUDA 12)
docker run -d \
  --gpus all \
  -p 8080:8080 \
  -v $(pwd)/models:/build/models \
  --name localai \
  ghcr.io/mudler/localai:latest-gpu-nvidia-cuda-12

# All-in-one image (includes models, ready immediately)
docker run -d \
  -p 8080:8080 \
  --name localai-aio \
  ghcr.io/mudler/localai:latest-aio-cpu

# Verify LocalAI is running
curl http://localhost:8080/v1/models

# One-shot installer for bare-metal Linux
curl https://localai.io/install.sh | sh</code></pre>
  </div>

  <!-- Model YAML config -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Model Configuration with YAML Files</h2>
    <p class="text-text-muted text-sm mb-4">Each model needs a YAML config file in the <code class="bg-bg-card border border-border rounded px-1.5 py-0.5 text-xs font-mono">models/</code> directory. The filename (without .yaml) becomes the model's API name.</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># models/llama3.yaml — LLM configuration
name: llama3
backend: llama-cpp
model: llama-3.2-7b-instruct-q4_k_m.gguf
context_size: 8192
gpu_layers: 35          # number of layers to offload to GPU (0 = CPU only)
threads: 8
f16: true
parameters:
  temperature: 0.7
  top_p: 0.9
  top_k: 40
template:
  chat: &quot;{{.Input}}&quot;   # adjust per model's expected format

---
# models/whisper.yaml — Speech-to-text configuration
name: whisper-1
backend: whisper
model: ggml-base.en.bin  # whisper.cpp model file

---
# models/stablediffusion.yaml — Image generation
name: stable-diffusion
backend: diffusers
model: stabilityai/stable-diffusion-xl-base-1.0
cuda: true

# Then use normally:
# curl http://localhost:8080/v1/chat/completions -d '&#123;"model":"llama3",...&#125;'
# curl http://localhost:8080/v1/audio/transcriptions -F file=@audio.mp3 -F model=whisper-1
# curl http://localhost:8080/v1/images/generations -d '&#123;"model":"stable-diffusion","prompt":"..."&#125;'</code></pre>
  </div>

  <!-- Multi-modal usage -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Multi-Modal API Examples</h2>
    <p class="text-text-muted text-sm mb-4">LocalAI implements the full OpenAI API surface. Here are examples using the Python openai SDK pointed at LocalAI:</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code">import openai

client = openai.OpenAI(
    base_url="http://localhost:8080/v1",
    api_key="localai"  # any non-empty string
)

# Text generation
response = client.chat.completions.create(
    model="llama3",
    messages=[&#123;"role": "user", "content": "Explain Docker networking"&#125;]
)
print(response.choices[0].message.content)

# Speech-to-text (Whisper)
with open("meeting.mp3", "rb") as audio:
    transcript = client.audio.transcriptions.create(
        model="whisper-1",
        file=audio
    )
print(transcript.text)

# Image generation (Stable Diffusion)
image = client.images.generate(
    model="stable-diffusion",
    prompt="A futuristic server room, cinematic lighting, 4K",
    n=1,
    size="512x512"
)
print(image.data[0].url)</code></pre>
  </div>

  <!-- Comparison -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-4">LocalAI vs Ollama</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-text-muted text-xs uppercase border-b border-border">
            <th class="text-left pb-2 pr-4">Feature</th>
            <th class="text-left pb-2 pr-4">LocalAI</th>
            <th class="text-left pb-2">Ollama</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border text-xs">
          <tr><td class="py-2 pr-4 font-medium">LLM inference</td><td class="py-2 pr-4 text-green-500">Yes</td><td class="py-2 text-green-500">Yes</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Image generation</td><td class="py-2 pr-4 text-green-500">Yes (Stable Diffusion)</td><td class="py-2 text-red-400">No</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Speech-to-text</td><td class="py-2 pr-4 text-green-500">Yes (Whisper)</td><td class="py-2 text-red-400">No</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Text-to-speech</td><td class="py-2 pr-4 text-green-500">Yes (bark/piper)</td><td class="py-2 text-red-400">No</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Setup complexity</td><td class="py-2 pr-4 text-yellow-500">Moderate (YAML config)</td><td class="py-2 text-green-500">Very simple</td></tr>
          <tr><td class="py-2 pr-4 font-medium">OpenAI drop-in</td><td class="py-2 pr-4 text-green-500">Full API surface</td><td class="py-2 text-yellow-500">Chat + completions</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Best for</td><td class="py-2 pr-4">Multi-modal local AI</td><td class="py-2">Simple local LLM apps</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="LocalAI" relatedTags={['ai', 'llm', 'local-ai', 'openai', 'self-hosted', 'docker', 'inference']} />
</BaseLayout>
