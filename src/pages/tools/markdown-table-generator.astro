---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MarkdownTableGenerator from '../../components/MarkdownTableGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a Markdown table?",
    answer: "A Markdown table is a way to represent tabular data in plain text using pipe characters (|) and hyphens (-). It's part of GitHub Flavored Markdown (GFM) and supported by most modern Markdown renderers including GitHub, GitLab, Notion, Obsidian, VS Code, and many static site generators."
  },
  {
    question: "How do I align columns in a Markdown table?",
    answer: "Column alignment is set in the separator row (the second row with dashes). Use :--- for left alignment, ---: for right alignment, :---: for center alignment, and --- for default (left) alignment. Click the alignment button in each column header to cycle through options."
  },
  {
    question: "What is the maximum number of rows and columns?",
    answer: "This generator supports up to 20 rows and 10 columns. For larger tables, consider using a spreadsheet and exporting to CSV, then converting to Markdown."
  },
  {
    question: "Why do column widths vary in the output?",
    answer: "The generator auto-pads each column so the pipes align vertically. This makes the raw Markdown readable even before rendering. Both padded and unpadded tables render identically in Markdown viewers."
  },
  {
    question: "Can I import an existing Markdown table?",
    answer: "Yes — paste your existing Markdown table in the Import section and click outside the box. The generator will parse the headers, rows, and column count automatically."
  },
];
---

<BaseLayout
  title="Markdown Table Generator — Free Online Tool"
  description="Generate Markdown tables instantly. Set rows, columns, alignment (left/center/right), and copy the output. Import existing Markdown tables to edit. Works with GitHub, GitLab, Notion, Obsidian, and any GFM-compatible renderer."
  tool="Markdown Table Generator, GitHub Markdown Table, GFM Table, Markdown Table Formatter, Table to Markdown"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Markdown Table Generator</h1>
  <p class="text-text-muted mb-4">
    Create GitHub Flavored Markdown tables visually — set rows, columns, and per-column alignment.
    Copy the formatted output or import an existing table to edit. Works with GitHub, GitLab, Notion, Obsidian, VS Code, and any GFM renderer.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auto-pads columns for readability</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Import existing tables</span>
  </div>
  <MarkdownTableGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Markdown Table Generator" relatedTags={['markdown', 'tables', 'documentation', 'github']} />
</BaseLayout>
