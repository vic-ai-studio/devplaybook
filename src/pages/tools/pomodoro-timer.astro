---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PomodoroTimer from '../../components/PomodoroTimer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Pomodoro Timer — Free Online Focus Timer"
  description="Free Pomodoro timer for developers. 25/5/15-minute work and break intervals, sound notifications via Web Audio API, session counter. Offline-ready, no signup."
  tool="Pomodoro Timer, Focus Timer, Productivity Timer, 25/5 Timer"
>
  <h1 class="text-3xl font-bold mb-2">Pomodoro Timer</h1>
  <p class="text-text-muted mb-8">
    Stay focused with the Pomodoro Technique. Work 25 minutes, break 5, then a long 15-minute break every 4 sessions.
    Sound notifications, offline-ready, tracks your sessions.
  </p>
  <PomodoroTimer client:only="preact" />
  <ToolPageCta currentTool="Pomodoro Timer" relatedTags={['productivity', 'focus', 'time-management', 'developer-tools']} />
</BaseLayout>
