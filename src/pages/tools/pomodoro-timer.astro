---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PomodoroTimer from '../../components/PomodoroTimer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the Pomodoro Technique?", answer: "The Pomodoro Technique is a time management method: work for 25 minutes (one 'pomodoro'), take a 5-minute break, and after every 4 pomodoros take a longer 15-minute break. It helps maintain focus and prevent burnout during deep work." },
  { question: "How does this Pomodoro timer work?", answer: "Click Start to begin a 25-minute work session. When it ends, a sound notification plays and the timer switches to a 5-minute break. After 4 work sessions, you get a 15-minute long break. The session counter tracks your progress throughout the day." },
  { question: "Can I customize the timer intervals?", answer: "The default intervals follow the classic Pomodoro Technique (25/5/15 minutes). The timer is optimized for these proven intervals, which research shows are effective for sustained concentration." },
  { question: "Does the timer work offline?", answer: "Yes. Once loaded, the timer runs entirely in your browser using the Web Audio API for notifications. No internet connection is needed — it works offline and never sends data to any server." },
  { question: "Why is this useful for developers?", answer: "Coding requires deep focus. The Pomodoro Technique helps you commit to uninterrupted 25-minute blocks — ideal for debugging, writing features, or reviewing code. The forced breaks reduce eye strain and mental fatigue." },
];
---

<BaseLayout
  title="Pomodoro Timer — Free Online Focus Timer for Developers"
  description="Free Pomodoro timer for developers. 25/5/15-minute work and break intervals with sound notifications via Web Audio API, session counter, and offline support. Stay focused during deep coding sessions. No signup needed."
  tool="Pomodoro Timer, Focus Timer, Productivity Timer, 25/5 Timer, Developer Productivity, Time Management Tool"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Pomodoro Timer</h1>
  <p class="text-text-muted mb-4">
    Stay focused with the Pomodoro Technique — work 25 minutes, break 5, then a long 15-minute break every 4 sessions.
    Sound notifications, session tracking, and offline support. Built for deep coding sessions.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <PomodoroTimer client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Pomodoro Timer" relatedTags={['productivity', 'focus', 'time-management', 'developer-tools']} />
</BaseLayout>
