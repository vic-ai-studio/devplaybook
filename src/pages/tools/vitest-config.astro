---
import BaseLayout from '../../layouts/BaseLayout.astro';
import VitestConfig from '../../components/VitestConfig.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is vitest.config.ts?",
    answer: "vitest.config.ts is the configuration file for Vitest, the Vite-native test framework. It uses defineConfig from 'vitest/config' and lets you set the test environment, coverage options, global helpers, and setup files. If your project already has a vite.config.ts, Vitest can extend it — so you often only need a separate vitest.config.ts when you want test-specific settings that differ from your build config."
  },
  {
    question: "Which environment should I pick?",
    answer: "node (default) is fastest and suits pure logic, utilities, and API code. jsdom simulates a browser DOM inside Node.js and is required for testing React/Vue components with @testing-library. happy-dom is a faster but less complete DOM implementation — good for component tests when speed matters more than 100% browser fidelity."
  },
  {
    question: "What does globals: true do?",
    answer: "With globals: true, Vitest injects describe, it, test, expect, beforeEach, afterEach, etc. as global variables. You don't need to import them in each test file — this matches the Jest default behavior. Without globals, you write: import { describe, it, expect } from 'vitest'. The explicit import style is recommended for new projects because it's more explicit and plays better with editors and type-checking."
  },
  {
    question: "What's the difference between v8 and istanbul coverage?",
    answer: "v8 uses Node.js's built-in V8 engine coverage — zero instrumentation overhead, install with npm install -D @vitest/coverage-v8. istanbul instruments your source code by injecting counters at every branch — it's slower but more precise for complex conditional logic, install with npm install -D @vitest/coverage-istanbul. For most projects v8 is the right choice; switch to istanbul if you need accurate branch-level reporting."
  },
  {
    question: "How do I add coverage thresholds?",
    answer: "Add a thresholds block inside coverage: { thresholds: { lines: 80, branches: 70, functions: 80, statements: 80 } }. Vitest will exit with a non-zero code if any threshold is not met, failing your CI pipeline. For the full configuration, use the Vitest Config Generator tool which includes threshold sliders."
  },
];
---

<BaseLayout
  title="Vitest Config — Quick vitest.config.ts Generator"
  description="Quick generator for a minimal vitest.config.ts. Pick your test environment, enable globals, configure coverage provider, and copy in one click. Free, runs in your browser."
  tool="Vitest Config, vitest.config.ts, Vitest Setup, Vitest Coverage, Vite Testing"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Vitest Config Generator",
    "url": "https://devplaybook.cc/tools/vitest-config",
    "description": "Quick generator for a minimal vitest.config.ts. Configure test environment, globals, coverage, and setup files.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Vitest Config</h1>
  <p class="text-text-muted mb-4">
    Generate a clean <code class="text-accent font-mono">vitest.config.ts</code> in seconds.
    Toggle your environment, globals, and coverage — the config updates live. Copy and drop it in your project.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> node / jsdom / happy-dom</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> globals toggle</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> v8 + istanbul coverage</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live preview</span>
  </div>
  <VitestConfig client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Vitest Config" relatedTags={['testing', 'vitest', 'vite', 'javascript', 'typescript', 'developer-tools']} />
</BaseLayout>
