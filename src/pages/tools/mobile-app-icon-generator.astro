---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is the minimum icon size I need to create for iOS and Android?",
    answer: "For iOS, design your master icon at 1024x1024 pixels (the App Store marketing icon), and Xcode or your build tool generates all smaller sizes from it. For Android, the Play Store requires a 512x512 PNG hi-res icon, and your adaptive icon foreground layer should be 1024x1024 with a transparent background. In practice, create one 1024x1024 source file and use a tool like expo-image-asset-generator, app-icon-resizer, or the online appicon.co to generate all required size variants automatically."
  },
  {
    question: "What is an Android adaptive icon and why does it matter?",
    answer: "Adaptive icons (introduced in Android 8.0 / API 26) separate the icon into a foreground layer and a background layer. The Android launcher can then apply device-specific shapes (circle, squircle, rounded square, etc.) and animations. The foreground image should be 1024x1024 with transparent background, with your logo centered within the inner safe zone (about 66% of the total size, roughly 672x672 pixels). The background can be a solid color or an image. Without an adaptive icon, your app shows an unmasked square icon on Android 8+ devices."
  },
  {
    question: "What is a maskable icon for PWAs?",
    answer: "A maskable icon is a PWA icon format where the image is designed to fill the entire icon area, allowing browsers/OSes to apply any shape mask (circle, squircle, etc.) and have the icon still look good. The key concept is the 'safe zone' — keep all important visual content within a centered circle that covers 80% of the icon area (400x400px within a 512x512 icon). Outside this circle may be cropped. Use the Maskable.app tool to preview how your icon looks with different masks before publishing."
  },
  {
    question: "Can I use a transparent background in my iOS app icon?",
    answer: "No. Apple explicitly prohibits transparency in iOS app icons. The App Store will reject icons with alpha channels. Your 1024x1024 source file must have a fully opaque background. If you're using Expo, it will warn you during the build. Use a solid color background or a gradient. Also avoid icons that look like the iOS system icons to prevent App Store review rejection on trademark grounds."
  },
  {
    question: "How do I automate icon generation in my CI/CD pipeline?",
    answer: "Several npm tools automate this. For React Native/Expo projects, 'expo-image-asset-generator' reads your source icon and generates all platform-specific sizes. For standalone automation, use 'sharp-cli' (npm install -g sharp-cli) to resize images programmatically in a shell script: 'sharp -i icon.png -o icon-60x60.png resize 60 60'. For comprehensive generation, the 'icon-generator' npm package outputs iOS AppIcon.appiconset, Android mipmap folders, and PWA manifest icons in one command."
  },
  {
    question: "What are all the iOS icon sizes required by Apple?",
    answer: "For a universal iOS app targeting iOS 14+, the required sizes in the AppIcon.appiconset are: 20pt (1x, 2x, 3x), 29pt (1x, 2x, 3x), 40pt (1x, 2x, 3x), 60pt (2x, 3x for iPhone), 76pt (1x, 2x for iPad), 83.5pt (2x for iPad Pro), and 1024pt (1x for App Store). In pixels these translate to 20, 29, 40, 58, 60, 76, 80, 87, 120, 152, 167, 180, and 1024 pixels. Modern Xcode projects using a single 1024x1024 'All Sizes' option in the asset catalog can auto-generate these, but you may still need to provide explicit sizes for older targets."
  }
];
---
<BaseLayout
  title="Mobile App Icon Generator — iOS & Android Icon Size Requirements"
  description="Complete guide to app icon sizes for iOS and Android: all required dimensions, asset catalog structure, adaptive icons, maskable icons, PWA icons, and automation tools."
  tool="mobile-app-icon-generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Mobile App Icon Generator</h1>
  <p class="text-text-muted mb-6">Complete reference for iOS and Android app icon requirements. All required sizes, adaptive icon setup, PWA maskable icons, asset catalog structure, and automation scripts.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span>✅ iOS & Android Sizes</span>
    <span>✅ Adaptive Icons</span>
    <span>✅ PWA Maskable Icons</span>
    <span>✅ Automation Scripts</span>
  </div>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Why Icon Requirements Are Strict</h2>
  <p class="mb-4">App stores and mobile operating systems have precise icon requirements because icons appear at many different sizes across the system: the home screen, the app switcher, the Settings app, Spotlight search, notifications, and the store listing itself. Each context has a specific pixel dimension, and providing the wrong size or format results in blurry icons, rejection during App Store review, or visual artifacts on device.</p>
  <p class="mb-4">The safest workflow is to design a single high-resolution master asset and use automation to produce every required variant. This guide covers the complete size requirements for iOS, Android, and PWA, plus the tools and scripts to automate the generation process.</p>

  <h2 class="text-2xl font-semibold mt-8 mb-3">iOS Icon Size Requirements</h2>
  <p class="mb-4">Apple uses a point-based system where 1 point equals 1 pixel on non-Retina displays, 2 pixels on Retina (@2x), and 3 pixels on Super Retina (@3x). All icons must be PNG with no transparency and no rounded corners (the OS applies rounding automatically).</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm"># iOS AppIcon.appiconset — all required sizes (pixels)
# iPhone
icon_20pt_2x.png    →  40x40    (Notification, iOS 9+)
icon_20pt_3x.png    →  60x60    (Notification, iOS 9+)
icon_29pt_1x.png    →  29x29    (Settings)
icon_29pt_2x.png    →  58x58    (Settings)
icon_29pt_3x.png    →  87x87    (Settings)
icon_40pt_2x.png    →  80x80    (Spotlight)
icon_40pt_3x.png    →  120x120  (Spotlight)
icon_60pt_2x.png    →  120x120  (Home Screen, iPhone Retina)
icon_60pt_3x.png    →  180x180  (Home Screen, iPhone Super Retina)

# iPad
icon_20pt_1x.png    →  20x20    (Notification)
icon_20pt_2x.png    →  40x40    (Notification)
icon_29pt_1x.png    →  29x29    (Settings)
icon_29pt_2x.png    →  58x58    (Settings)
icon_40pt_1x.png    →  40x40    (Spotlight)
icon_40pt_2x.png    →  80x80    (Spotlight)
icon_76pt_1x.png    →  76x76    (Home Screen, iPad)
icon_76pt_2x.png    →  152x152  (Home Screen, iPad Retina)
icon_83.5pt_2x.png  →  167x167  (Home Screen, iPad Pro)

# App Store
icon_1024pt_1x.png  →  1024x1024 (App Store listing)</code></pre>
  <p class="mb-4">Modern Xcode 15+ projects can use a single 1024x1024 image with "Single Size" in the asset catalog, letting Xcode auto-scale. However, explicitly providing all sizes ensures the sharpest rendering on every device.</p>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Android Icon Size Requirements</h2>
  <p class="mb-4">Android uses density-based resource qualifiers. The standard launcher icon is placed in <code>mipmap</code> directories (not <code>drawable</code>) because mipmap resources are never stripped by the build system, even when packaging for specific densities.</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm"># Android mipmap directories and icon sizes
android/app/src/main/res/
  mipmap-mdpi/
    ic_launcher.png           →  48x48   (baseline)
    ic_launcher_round.png     →  48x48
  mipmap-hdpi/
    ic_launcher.png           →  72x72
    ic_launcher_round.png     →  72x72
  mipmap-xhdpi/
    ic_launcher.png           →  96x96
    ic_launcher_round.png     →  96x96
  mipmap-xxhdpi/
    ic_launcher.png           →  144x144
    ic_launcher_round.png     →  144x144
  mipmap-xxxhdpi/
    ic_launcher.png           →  192x192
    ic_launcher_round.png     →  192x192
  mipmap-anydpi-v26/
    ic_launcher.xml           →  Adaptive icon XML
    ic_launcher_round.xml     →  Adaptive icon XML (same as above)

# Adaptive icon foreground and background
res/drawable/
  ic_launcher_foreground.png  →  1024x1024 (transparent background, logo centered in 672x672 safe zone)
  ic_launcher_background.png  →  1024x1024 (or use a color in XML)

# Play Store
play_store_512.png            →  512x512  (hi-res icon for store listing)</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Adaptive Icon XML Structure</h2>
  <p class="mb-4">For Android 8.0+ (API 26+), define your adaptive icon in XML that references the foreground and background layers:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm">&lt;!-- res/mipmap-anydpi-v26/ic_launcher.xml --&gt;
&lt;?xml version="1.0" encoding="utf-8"?&gt;
&lt;adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android"&gt;
    &lt;background android:drawable="@color/ic_launcher_background" /&gt;
    &lt;foreground android:drawable="@drawable/ic_launcher_foreground" /&gt;
    &lt;!-- monochrome layer for Android 13+ themed icons --&gt;
    &lt;monochrome android:drawable="@drawable/ic_launcher_foreground" /&gt;
&lt;/adaptive-icon&gt;

&lt;!-- res/values/colors.xml --&gt;
&lt;resources&gt;
    &lt;color name="ic_launcher_background"&gt;#FFFFFF&lt;/color&gt;
&lt;/resources&gt;</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">PWA Icon Requirements</h2>
  <p class="mb-4">Progressive Web Apps need icons declared in the Web App Manifest. Provide icons at multiple sizes for different device contexts, and include at least one maskable icon:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm">// public/manifest.json
{
  "name": "My App",
  "short_name": "MyApp",
  "icons": [
    { "src": "/icons/icon-72x72.png",   "sizes": "72x72",   "type": "image/png" },
    { "src": "/icons/icon-96x96.png",   "sizes": "96x96",   "type": "image/png" },
    { "src": "/icons/icon-128x128.png", "sizes": "128x128", "type": "image/png" },
    { "src": "/icons/icon-144x144.png", "sizes": "144x144", "type": "image/png" },
    { "src": "/icons/icon-152x152.png", "sizes": "152x152", "type": "image/png" },
    { "src": "/icons/icon-192x192.png", "sizes": "192x192", "type": "image/png" },
    { "src": "/icons/icon-384x384.png", "sizes": "384x384", "type": "image/png" },
    { "src": "/icons/icon-512x512.png", "sizes": "512x512", "type": "image/png" },
    {
      "src": "/icons/icon-maskable-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "theme_color": "#ffffff",
  "background_color": "#ffffff",
  "display": "standalone"
}</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Automation with Sharp CLI</h2>
  <p class="mb-4">Generate all icon sizes from a single source file using a Node.js script with the sharp image processing library:</p>
  <pre class="bg-surface rounded-lg p-4 overflow-x-auto mb-4"><code class="text-sm">// scripts/generate-icons.mjs
import sharp from 'sharp';
import { mkdirSync } from 'fs';

const SOURCE = './assets/icon-source-1024.png';

const iosSizes = [20, 29, 40, 58, 60, 76, 80, 87, 120, 152, 167, 180, 1024];
const androidSizes = [48, 72, 96, 144, 192, 512];
const pwaSizes = [72, 96, 128, 144, 152, 192, 384, 512];

mkdirSync('./output/ios', { recursive: true });
mkdirSync('./output/android', { recursive: true });
mkdirSync('./output/pwa', { recursive: true });

for (const size of iosSizes) {
  await sharp(SOURCE)
    .resize(size, size)
    .toFile(`./output/ios/icon-${size}x${size}.png`);
  console.log(`iOS: ${size}x${size}`);
}

for (const size of androidSizes) {
  await sharp(SOURCE)
    .resize(size, size)
    .toFile(`./output/android/icon-${size}x${size}.png`);
}

for (const size of pwaSizes) {
  await sharp(SOURCE)
    .resize(size, size)
    .toFile(`./output/pwa/icon-${size}x${size}.png`);
}

console.log('All icons generated successfully.');</code></pre>

  <h2 class="text-2xl font-semibold mt-8 mb-3">Icon Design Best Practices</h2>
  <p class="mb-4">Technical requirements aside, icon design directly impacts download conversion rates in the App Store and Play Store. Key principles to follow:</p>
  <ul class="list-disc list-inside mb-4 space-y-1">
    <li><strong>Keep it simple</strong> — Icons are viewed at 60px on most home screens. Avoid text and fine details that won't read at small sizes.</li>
    <li><strong>Use bold, distinct colors</strong> — High contrast helps the icon stand out on both light and dark wallpapers. Test on both.</li>
    <li><strong>Avoid generic metaphors</strong> — Thousands of apps use a globe, a chat bubble, or a gear. Choose a shape unique to your brand.</li>
    <li><strong>Design within the safe zone</strong> — For Android adaptive icons, keep the core logo within the inner 66% to prevent cropping on any mask shape.</li>
    <li><strong>Test at actual sizes</strong> — Zoom out your design tool to 60x60px and verify the icon is still recognizable.</li>
    <li><strong>Consistency across platforms</strong> — Use the same brand colors and logo mark across iOS, Android, and PWA icons, even if the shape adapts per platform.</li>
  </ul>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="mobile-app-icon-generator" relatedTags={['mobile', 'ios', 'android', 'design', 'assets', 'app-store', 'icons']} />
</BaseLayout>
