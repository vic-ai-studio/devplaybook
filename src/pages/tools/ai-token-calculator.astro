---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AiTokenCalculator from '../../components/AiTokenCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="AI Token Cost Calculator — GPT-4o, Claude, Gemini"
  description="Calculate API token costs for GPT-4o, Claude 3.5 Sonnet, Gemini 1.5 Pro, and more. Enter token count, characters, or words and instantly see cost per call, total, and monthly projections."
  tool="AI Token Calculator, LLM Cost Estimator, OpenAI Cost Calculator, Claude Pricing, Gemini Token Cost"
>
  <h1 class="text-3xl font-bold mb-2">AI Token Cost Calculator</h1>
  <p class="text-text-muted mb-8">Estimate API costs for GPT-4o, Claude, Gemini, and more. Enter token counts or raw text size and get instant per-call and monthly cost projections.</p>
  <AiTokenCalculator client:load />
  <ToolPageCta currentTool="AI Token Calculator" relatedTags={['ai', 'api', 'openai', 'claude', 'llm', 'cost']} />
</BaseLayout>
