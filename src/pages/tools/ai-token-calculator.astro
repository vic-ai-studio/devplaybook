---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AiTokenCalculator from '../../components/AiTokenCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a token in the context of AI models?", answer: "A token is a chunk of text that LLMs process — roughly 4 characters or 0.75 words in English. Models like GPT-4o and Claude charge per token for both input (your prompt) and output (the response). Understanding token count helps you estimate and control API costs." },
  { question: "How are input and output tokens priced differently?", answer: "Most AI providers charge more for output tokens than input tokens. For example, GPT-4o charges $2.50 per 1M input tokens but $10 per 1M output tokens. This is because generating text is more compute-intensive than reading it." },
  { question: "Which AI model is the most cost-effective?", answer: "It depends on your use case. GPT-4o mini and Claude 3.5 Haiku are the cheapest for simple tasks. GPT-4o and Claude 3.5 Sonnet offer the best quality-to-cost ratio for complex tasks. Use this calculator to compare costs across models for your specific token usage." },
  { question: "How do I estimate my monthly API costs?", answer: "Enter your average tokens per request, multiply by expected daily requests, and the calculator projects your monthly cost. Factor in both input and output tokens — a chatbot with long conversations will have higher costs than a summarization tool with short outputs." },
  { question: "Does this calculator reflect the latest pricing?", answer: "We update pricing regularly, but AI providers change rates frequently. Always verify current prices on the provider's official pricing page before committing to a budget. This tool gives you a reliable estimate for comparison and planning." },
];
---

<BaseLayout
  title="AI Token Cost Calculator — GPT-4o, Claude, Gemini"
  description="Calculate API token costs for GPT-4o, Claude 3.5 Sonnet, Gemini 1.5 Pro, and more. Enter token count, characters, or words and instantly see cost per call, total, and monthly projections. Free, no signup."
  tool="AI Token Calculator, LLM Cost Estimator, OpenAI Cost Calculator, Claude Pricing, Gemini Token Cost"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">AI Token Cost Calculator</h1>
  <p class="text-text-muted mb-4">Estimate API costs for GPT-4o, Claude, Gemini, and more. Enter token counts or raw text size and get instant per-call and monthly cost projections.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <AiTokenCalculator client:load />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="AI Token Calculator" relatedTags={['ai', 'api', 'openai', 'claude', 'llm', 'cost']} />
</BaseLayout>
