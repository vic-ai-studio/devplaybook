---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const installExample = `# Create a new project with Playwright pre-configured
npm init playwright@latest

# Add Playwright to an existing project
npm install --save-dev @playwright/test

# Install browser binaries (Chromium, Firefox, WebKit)
npx playwright install

# Run tests
npx playwright test

# Run tests with UI mode (interactive, time-travel debugging)
npx playwright test --ui

# Generate tests using the codegen tool
npx playwright codegen https://example.com`;

const testExample = `// tests/auth.spec.ts
import { test, expect } from '@playwright/test';

test.describe('Authentication', () => {
  test('user can log in with valid credentials', async ({ page }) => {
    await page.goto('/login');

    // Fill in the login form
    await page.getByLabel('Email').fill('user@example.com');
    await page.getByLabel('Password').fill('s3cret');
    await page.getByRole('button', { name: 'Sign in' }).click();

    // Playwright auto-waits for navigation to complete
    await expect(page).toHaveURL('/dashboard');
    await expect(page.getByRole('heading', { name: 'Dashboard' })).toBeVisible();
  });

  test('shows error for wrong password', async ({ page }) => {
    await page.goto('/login');
    await page.getByLabel('Email').fill('user@example.com');
    await page.getByLabel('Password').fill('wrong');
    await page.getByRole('button', { name: 'Sign in' }).click();

    await expect(page.getByText('Invalid credentials')).toBeVisible();
  });
});`;

const fixtureExample = `// fixtures/auth.ts — a custom fixture that pre-authenticates
import { test as base, expect } from '@playwright/test';

type AuthFixtures = {
  authenticatedPage: Page;
};

export const test = base.extend<AuthFixtures>({
  authenticatedPage: async ({ page }, use) => {
    // Log in once, share the authenticated browser state
    await page.goto('/login');
    await page.getByLabel('Email').fill('admin@example.com');
    await page.getByLabel('Password').fill('adminpass');
    await page.getByRole('button', { name: 'Sign in' }).click();
    await page.waitForURL('/dashboard');
    await use(page);
  },
});

// Use in tests
test('admin can delete a user', async ({ authenticatedPage }) => {
  await authenticatedPage.goto('/users');
  // ...
});`;

const apiTestExample = `// API testing with Playwright — no browser needed
import { test, expect } from '@playwright/test';

test('GET /api/users returns a list', async ({ request }) => {
  const response = await request.get('/api/users');
  expect(response.status()).toBe(200);

  const users = await response.json();
  expect(Array.isArray(users)).toBe(true);
  expect(users.length).toBeGreaterThan(0);
  expect(users[0]).toHaveProperty('id');
});

test('POST /api/users creates a new user', async ({ request }) => {
  const response = await request.post('/api/users', {
    data: { name: 'Alice', email: 'alice@example.com' }
  });
  expect(response.status()).toBe(201);
  const user = await response.json();
  expect(user.email).toBe('alice@example.com');
});`;

const configExample = `// playwright.config.ts
import { defineConfig, devices } from '@playwright/test';

export default defineConfig({
  testDir: './tests',
  fullyParallel: true,          // run tests in parallel
  forbidOnly: !!process.env.CI, // fail CI if test.only is left in
  retries: process.env.CI ? 2 : 0,
  workers: process.env.CI ? 1 : undefined,
  reporter: 'html',

  use: {
    baseURL: 'http://localhost:3000',
    trace: 'on-first-retry', // capture traces on retry
    screenshot: 'only-on-failure',
  },

  projects: [
    { name: 'chromium', use: { ...devices['Desktop Chrome'] } },
    { name: 'firefox',  use: { ...devices['Desktop Firefox'] } },
    { name: 'webkit',   use: { ...devices['Desktop Safari'] } },
    { name: 'Mobile Chrome', use: { ...devices['Pixel 5'] } },
  ],
});`;

const faq = [
  {
    question: "What is Playwright?",
    answer: "Playwright is an end-to-end testing framework developed by Microsoft. It automates Chromium, Firefox, and WebKit browsers using a single API, supports auto-waiting, parallel execution, the Trace Viewer for debugging, a codegen tool for recording tests, and built-in API testing. Tests are written in TypeScript, JavaScript, Python, Java, or C#."
  },
  {
    question: "How does Playwright's auto-waiting work?",
    answer: "Playwright automatically waits for elements to be actionable before interacting with them. When you call page.click() or page.fill(), Playwright waits for the element to be visible, enabled, and stable (not animating) before acting. This eliminates most explicit waits and sleeps that make tests fragile. You can configure a global timeout and per-action timeouts in the config."
  },
  {
    question: "What is the Playwright Trace Viewer?",
    answer: "The Trace Viewer is a debugging tool that records a full trace of a test run — every action, network request, console log, and DOM snapshot — and lets you replay it in a browser-based timeline. Enable it with trace: 'on-first-retry' in the config (so it only runs on failing retries, keeping storage low). View traces with npx playwright show-report or by uploading to the Playwright CI portal."
  },
  {
    question: "How does Playwright codegen work?",
    answer: "Running npx playwright codegen <URL> opens a browser with an inspector overlay. As you interact with the page — clicking, typing, navigating — Playwright records each action and generates test code in real time. The generated code uses recommended locator strategies (getByRole, getByLabel, getByText) rather than fragile CSS selectors. It is a useful starting point but generated tests typically need refinement."
  },
  {
    question: "Can Playwright test APIs without a browser?",
    answer: "Yes. Playwright includes a built-in APIRequestContext (accessed via the request fixture in tests) that lets you make HTTP requests and assert on responses — no browser required. This is useful for testing REST API endpoints, verifying backend state after a UI action, or running mixed browser + API test scenarios in the same test file."
  },
  {
    question: "How does Playwright compare to Cypress?",
    answer: "Playwright runs tests out-of-process (a separate Node process controlling the browser) while Cypress runs inside the browser. Playwright natively supports Chromium, Firefox, and WebKit; Cypress primarily targets Chrome-based browsers (Firefox and WebKit support is experimental). Playwright has better multi-tab, iframe, and multi-origin support. Cypress has a more polished interactive dashboard and an established cloud recording service. Both are excellent choices for modern E2E testing."
  },
];
---

<BaseLayout
  title="Playwright — End-to-End Testing Framework by Microsoft"
  description="Playwright is a powerful E2E testing framework supporting Chromium, Firefox, and WebKit. Features auto-waiting, Trace Viewer, codegen, API testing, and parallel execution across all browsers."
  tool="playwright, end-to-end testing, e2e testing, browser automation, microsoft playwright, playwright test, cross-browser testing"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Playwright — End-to-End Testing Framework by Microsoft",
    "url": "https://devplaybook.cc/tools/playwright",
    "description": "Playwright is an E2E testing framework by Microsoft supporting Chromium, Firefox, and WebKit with auto-waiting, Trace Viewer, codegen, and API testing.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Playwright</h1>
  <p class="text-text-muted mb-6">
    End-to-end testing framework by Microsoft that supports Chromium, Firefox, and WebKit.
    Auto-waiting, parallel execution, the Trace Viewer for debugging, a codegen recorder,
    and built-in API testing — all in one modern testing toolkit.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Chromium, Firefox, WebKit</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auto-waiting</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Trace Viewer</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Codegen recorder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> API testing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Parallel execution</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Playwright?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Playwright is an open-source end-to-end testing framework developed by Microsoft. It automates real browser instances — Chromium (Chrome/Edge), Firefox, and WebKit (Safari) — via a single, consistent API. Unlike older automation tools, Playwright was designed from the ground up for modern web applications: single-page apps, server-rendered apps, multi-tab flows, iframes, and web components.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    Tests run in parallel by default, use smart auto-waiting to eliminate flakiness, and can target mobile device emulation. The Trace Viewer records a full timeline of every test action for deterministic debugging. Codegen records user interactions and produces test code automatically. Playwright supports TypeScript, JavaScript, Python, Java, and C#.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Auto-waiting</strong> — waits for elements to be visible, enabled, and stable before acting — no explicit waits needed</li>
    <li><strong>Cross-browser</strong> — Chromium, Firefox, and WebKit with a single test suite; mobile device emulation included</li>
    <li><strong>Trace Viewer</strong> — captures screenshots, DOM snapshots, and network activity for every test step; replay in the browser</li>
    <li><strong>Codegen</strong> — record interactions in a real browser and generate test code using accessible locators</li>
    <li><strong>Fixtures</strong> — composable, reusable test setup (auth state, mock services, custom page objects) via test.extend()</li>
    <li><strong>API testing</strong> — built-in HTTP client for testing REST APIs without a browser in the same test suite</li>
    <li><strong>Parallelism</strong> — tests run in parallel by default; workers and sharding configurable for large CI suites</li>
    <li><strong>Component testing</strong> — test React, Vue, and Svelte components in isolation with @playwright/experimental-ct-*</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Installation</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={installExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Writing Tests</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Tests are organized with <code class="bg-bg-card px-1 rounded text-xs">test.describe</code> blocks and individual <code class="bg-bg-card px-1 rounded text-xs">test()</code> cases. Use accessible locators (<code class="bg-bg-card px-1 rounded text-xs">getByRole</code>, <code class="bg-bg-card px-1 rounded text-xs">getByLabel</code>) rather than CSS selectors for resilient tests.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={testExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Fixtures for Reusable Setup</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Fixtures replace beforeEach hooks with composable, type-safe setup. An auth fixture logs in once and passes the authenticated page to each test that needs it — without repeating the login steps.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={fixtureExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">API Testing</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    The <code class="bg-bg-card px-1 rounded text-xs">request</code> fixture gives you a full HTTP client for testing APIs without launching a browser. Useful for testing REST endpoints or verifying back-end state after a UI action.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={apiTestExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Configuration</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    <code class="bg-bg-card px-1 rounded text-xs">playwright.config.ts</code> controls browsers, parallelism, retries, base URL, tracing, and screenshot policies. Define multiple projects to test across browsers and viewports in one run.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={configExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Playwright vs Cypress</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">Playwright</th>
          <th class="border border-border px-3 py-2 text-left">Cypress</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2">Browser support</td><td class="border border-border px-3 py-2 text-green-400">Chrome, Firefox, WebKit</td><td class="border border-border px-3 py-2">Chrome-based (FF/WebKit experimental)</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Multi-tab / multi-origin</td><td class="border border-border px-3 py-2 text-green-400">Yes</td><td class="border border-border px-3 py-2">Limited</td></tr>
        <tr><td class="border border-border px-3 py-2">Test languages</td><td class="border border-border px-3 py-2 text-green-400">TS, JS, Python, Java, C#</td><td class="border border-border px-3 py-2">JS / TS only</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Interactive debugger</td><td class="border border-border px-3 py-2">UI mode / Trace Viewer</td><td class="border border-border px-3 py-2 text-green-400">Built-in Test Runner GUI</td></tr>
        <tr><td class="border border-border px-3 py-2">Component testing</td><td class="border border-border px-3 py-2">Experimental</td><td class="border border-border px-3 py-2 text-green-400">Stable</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Parallelism (free)</td><td class="border border-border px-3 py-2 text-green-400">Yes (built-in)</td><td class="border border-border px-3 py-2">Requires Cypress Cloud</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pros and Cons</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-green-400 mb-2">Pros</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✓ True cross-browser: Chrome, Firefox, and WebKit in one suite</li>
        <li>✓ Auto-waiting eliminates most flaky test issues</li>
        <li>✓ Trace Viewer makes post-mortem debugging straightforward</li>
        <li>✓ Multi-language support (Python, Java, C# in addition to TS/JS)</li>
        <li>✓ Free parallelism without a cloud service</li>
      </ul>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-red-400 mb-2">Cons</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✗ Component testing is still experimental</li>
        <li>✗ Interactive test runner less polished than Cypress GUI</li>
        <li>✗ Steeper initial learning curve compared to Cypress</li>
        <li>✗ No built-in cloud recording dashboard (third-party integrations exist)</li>
        <li>✗ Browser binaries (~300 MB) add to CI download time</li>
      </ul>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="playwright" relatedTags={['testing', 'e2e', 'browser', 'automation', 'typescript', 'ci-cd']} />
</BaseLayout>
