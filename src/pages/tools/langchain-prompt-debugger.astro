---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LangchainPromptDebugger from '../../components/LangchainPromptDebugger.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What are LangChain prompt templates?",
    answer: "LangChain PromptTemplate uses {variable_name} placeholders in prompt strings. At runtime, you call template.format(variable_name='value') to produce the final prompt. This makes prompts reusable, testable, and composable. ChatPromptTemplate works similarly but supports message roles (system, human, ai) for chat models."
  },
  {
    question: "How are tokens counted in this tool?",
    answer: "Tokens are estimated at ~4 characters per token, which is a common approximation for English text with OpenAI and Anthropic models. Actual token counts depend on the tokenizer: GPT models use tiktoken (BPE), Claude uses a similar approach, and Gemini uses SentencePiece. For exact counts, use the Tokenizer Counter tool or the model's API."
  },
  {
    question: "What is the difference between PromptTemplate and ChatPromptTemplate?",
    answer: "PromptTemplate produces a single string prompt suitable for completion models. ChatPromptTemplate produces a list of messages with roles (SystemMessage, HumanMessage, AIMessage) for chat models like GPT-4 and Claude. Use ChatPromptTemplate for all modern chat-based LLMs — it gives the model better context about each message's role."
  },
  {
    question: "How do I avoid prompt injection attacks?",
    answer: "Prompt injection happens when user-controlled input contains instructions that override your system prompt. Mitigations include: (1) wrapping user input in delimiters like XML tags <user_input>...</user_input>, (2) explicitly instructing the model to ignore instructions within user input, (3) using separate system and user message roles in ChatPromptTemplate, and (4) validating/sanitizing inputs before injecting them."
  },
  {
    question: "What context window limits should I know?",
    answer: "GPT-3.5 Turbo: 16K tokens. GPT-4o: 128K tokens. Claude 3.5 Sonnet: 200K tokens. Gemini 1.5 Pro: 1M tokens. Exceeding these limits causes API errors. Always leave buffer room for the completion output (typically 1K–4K tokens). This tool highlights when your filled prompt approaches common model limits."
  },
  {
    question: "How do I chain multiple prompts in LangChain?",
    answer: "Use LangChain Expression Language (LCEL) to chain components: `chain = prompt | llm | StrOutputParser()`. You can pipe the output of one chain as input to another: `chain = prompt1 | llm | prompt2 | llm`. For complex workflows, use LangGraph for stateful, graph-based chains with branching and loops."
  },
];
---

<BaseLayout
  title="LangChain Prompt Debugger — Test & Debug Prompt Templates with Variable Injection"
  description="Debug LangChain prompt templates with live variable injection, token counting, and context window analysis. Preview filled prompts, count tokens for GPT-4o/Claude/Gemini, and check context window usage. Runs in your browser."
  tool="langchain prompt debugger, prompt template tester, prompt variable injection, langchain PromptTemplate, AI prompt debugging"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "LangChain Prompt Debugger",
    "url": "https://devplaybook.cc/tools/langchain-prompt-debugger",
    "description": "Debug LangChain prompt templates with live variable injection, token counting, and context window analysis. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">LangChain Prompt Debugger</h1>
  <p class="text-text-muted mb-4">
    Test and debug <code class="font-mono bg-bg-card px-1 rounded text-sm">PromptTemplate</code> strings with live variable injection.
    Extract <code class="font-mono bg-bg-card px-1 rounded text-sm">{'{variable}'}</code> slots automatically,
    fill them in, preview the final prompt, and check token counts against model context windows.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auto variable extraction</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Token count estimate</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Context window check</span>
  </div>
  <LangchainPromptDebugger client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="LangChain Prompt Debugger" relatedTags={['ai', 'llm', 'langchain', 'openai', 'claude', 'prompts', 'python']} />
</BaseLayout>
