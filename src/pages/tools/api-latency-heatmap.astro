---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ApiLatencyHeatmap from '../../components/ApiLatencyHeatmap.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="API Latency Heatmap — Visualize Response Times Online"
  description="Visualize API endpoint response times as a color-coded heatmap. Green under 100ms, yellow 100–300ms, orange 300–500ms, red over 500ms. See avg, P95, and max latency per endpoint. Runs entirely in your browser."
  tool="API Latency Heatmap, response time heatmap, API latency visualizer, endpoint performance chart"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "API Latency Heatmap",
    "url": "https://devplaybook.cc/tools/api-latency-heatmap",
    "description": "Visualize API endpoint response times as a color-coded heatmap. Color-coded: green <100ms, yellow 100–300ms, orange 300–500ms, red >500ms. Shows avg, P95, and max latency.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">API Latency Heatmap</h1>
  <p class="text-text-muted mb-6">
    Input response times for multiple API endpoints and visualize them as a color-coded heatmap.
    Instantly spot slow endpoints, latency spikes, and performance regressions.
    Color thresholds: <span class="text-green-400 font-medium">green &lt;100ms</span>,
    <span class="text-yellow-400 font-medium">yellow 100–300ms</span>,
    <span class="text-orange-400 font-medium">orange 300–500ms</span>,
    <span class="text-red-400 font-medium">red &gt;500ms</span>.
    Everything runs in your browser — no data sent anywhere.
  </p>
  <div class="flex items-center gap-4 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Color-coded by latency threshold</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Avg, P95 &amp; Max per endpoint</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Add and edit endpoints</span>
  </div>
  <ApiLatencyHeatmap client:only="preact" />
  <ToolPageCta currentTool="API Latency Heatmap" relatedTags={['api-testing', 'performance', 'monitoring', 'debugging', 'devops']} />
</BaseLayout>
