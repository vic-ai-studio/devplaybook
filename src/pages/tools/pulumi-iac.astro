---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What makes Pulumi different from Terraform?", answer: "Pulumi uses general-purpose programming languages (TypeScript, Python, Go, C#, Java) instead of a domain-specific language like HCL. This gives you real loops, conditionals, functions, classes, package managers, and IDE support out of the box. Pulumi also uses an explicit resource model with async/await, making it easy to express dependencies. Terraform's HCL is simpler to learn and has a larger community and provider ecosystem, but Pulumi is often more productive for complex infrastructure because you write real code." },
  { question: "How does Pulumi manage state?", answer: "Pulumi stores state in a backend that tracks which cloud resources belong to your stack. By default it uses the Pulumi Cloud (managed service, free tier available) which provides collaboration, secrets encryption, history, and policy enforcement. You can also use self-managed backends: AWS S3, Azure Blob Storage, Google Cloud Storage, or a local filesystem. Each Pulumi stack (dev/staging/prod) gets its own state file. pulumi stack ls lists stacks, pulumi state export exports state for inspection or repair." },
  { question: "What is a Pulumi Stack and how do environments work?", answer: "A Pulumi Stack is an isolated instance of your program — think of it as an environment. You can have stacks named dev, staging, and prod, each with different config values and potentially different cloud accounts or regions. Config is set with pulumi config set key value and accessed in code with config.require('key'). Secrets are encrypted: pulumi config set --secret dbPassword mySecret. Stacks can export values (stack outputs) that other stacks can read via StackReference, enabling stack composition." },
  { question: "Does Pulumi support multiple cloud providers?", answer: "Yes. Pulumi has providers for over 100 cloud platforms and services including AWS, Azure, Google Cloud, Kubernetes, Cloudflare, Datadog, MongoDB Atlas, GitHub, and more. You can use multiple providers in the same program — for example, provision an AWS RDS database, configure a Datadog monitor, and create a GitHub Actions secret all in one Pulumi program. This makes Pulumi particularly powerful for multi-cloud or cloud-plus-SaaS infrastructure." },
  { question: "What is the Pulumi Automation API?", answer: "The Automation API is a programmatic interface to the Pulumi engine that lets you embed infrastructure management inside your own applications and scripts. Instead of running pulumi up from the CLI, you call pulumi.automation.LocalWorkspace.createOrSelectStack() from TypeScript or Python, set config values, and call stack.up(). This enables use cases like infrastructure-as-a-feature (SaaS apps that provision cloud resources per customer), custom deployment UIs, and CI/CD systems that need fine-grained programmatic control." },
  { question: "What is Pulumi CrossGuard (Policy as Code)?", answer: "CrossGuard is Pulumi's policy-as-code framework. You write policies in TypeScript or Python that run during pulumi preview and pulumi up to enforce organizational standards — for example, blocking S3 buckets without encryption, requiring resource tags, or preventing public security groups. Policies are packaged into Policy Packs and can be applied to individual stacks or enforced organization-wide via Pulumi Cloud. This replaces ad-hoc review checklists with automated, testable guardrails." },
];
---

<BaseLayout
  title="Pulumi IaC Guide — Modern Infrastructure as Code with TypeScript & Python"
  description="Complete guide to Pulumi: multi-cloud IaC with TypeScript, Python, Go, and C#. State management, stacks, Automation API, Policy as Code, and comparison with Terraform and AWS CDK."
  tool="Pulumi, infrastructure as code, Pulumi TypeScript, Pulumi vs Terraform, Pulumi Python, multi-cloud IaC"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Pulumi IaC Guide — Modern Infrastructure as Code with TypeScript & Python",
    "url": "https://devplaybook.cc/tools/pulumi-iac",
    "description": "Complete guide to Pulumi: multi-cloud IaC with TypeScript, Python, Go, and C#. State management, stacks, Automation API, Policy as Code, and comparison with Terraform and AWS CDK.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Pulumi — Modern Infrastructure as Code</h1>
  <p class="text-text-muted mb-6">
    Provision <strong>any cloud infrastructure</strong> using TypeScript, Python, Go, C#, or Java.
    Pulumi brings real programming languages, package managers, and IDE tooling to infrastructure.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript / Python / Go / C# / Java</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100+ cloud providers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Automation API</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Policy as Code</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Pulumi?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Pulumi is an open-source infrastructure-as-code platform founded in 2017 that fundamentally rethinks how developers define cloud resources. Rather than inventing a new configuration language, Pulumi lets you write infrastructure code using TypeScript, Python, Go, C#, or Java — the same languages you already use for your applications. This means real loops, functions, classes, conditionals, package managers (npm, pip, go mod), unit tests, and all the IDE tooling you depend on daily.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    Pulumi supports over 100 cloud providers through a rich provider ecosystem including AWS, Azure, Google Cloud, Kubernetes, Cloudflare, MongoDB Atlas, GitHub, and many SaaS platforms. A single Pulumi program can provision resources across multiple providers, making it uniquely suited for organizations running workloads across clouds or managing cloud infrastructure alongside SaaS configuration.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>General-purpose languages</strong> — TypeScript, Python, Go, C#, Java with full IDE support</li>
    <li><strong>Multi-cloud</strong> — one platform for AWS, Azure, GCP, Kubernetes, and 100+ providers</li>
    <li><strong>State management</strong> — Pulumi Cloud (managed), S3, Azure Blob, GCS, or local backends</li>
    <li><strong>Stack config &amp; secrets</strong> — per-environment config with encrypted secret values</li>
    <li><strong>Automation API</strong> — embed Pulumi engine in your applications for programmatic deployments</li>
    <li><strong>CrossGuard Policy as Code</strong> — enforce organizational policies automatically during deployments</li>
    <li><strong>StackReference</strong> — compose stacks together and share outputs across environments</li>
    <li><strong>pulumi preview</strong> — dry-run that shows exactly what will change before deploying</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Getting Started: TypeScript Program</h2>
  <p class="text-text-muted mb-3 leading-relaxed">Install the Pulumi CLI and create a new project:</p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">curl -fsSL https://get.pulumi.com | sh
pulumi new aws-typescript
npm install</pre>

  <p class="text-text-muted mb-3 leading-relaxed">Define an S3 bucket, Lambda function, and API Gateway:</p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// index.ts
import * as pulumi from "@pulumi/pulumi";
import * as aws from "@pulumi/aws";

const config = new pulumi.Config();
const environment = config.require("environment");

// S3 bucket for file storage
const bucket = new aws.s3.Bucket("data-bucket", &#123;
  acl: "private",
  versioning: &#123; enabled: true &#125;,
  serverSideEncryptionConfiguration: &#123;
    rule: &#123;
      applyServerSideEncryptionByDefault: &#123;
        sseAlgorithm: "AES256",
      &#125;,
    &#125;,
  &#125;,
  tags: &#123; Environment: environment, ManagedBy: "Pulumi" &#125;,
&#125;);

// IAM role for Lambda
const lambdaRole = new aws.iam.Role("lambda-role", &#123;
  assumeRolePolicy: aws.iam.assumeRolePolicyForPrincipal(&#123;
    Service: "lambda.amazonaws.com",
  &#125;),
&#125;);

new aws.iam.RolePolicyAttachment("lambda-basic", &#123;
  role: lambdaRole.name,
  policyArn: aws.iam.ManagedPolicy.AWSLambdaBasicExecutionRole,
&#125;);

// Lambda function
const processor = new aws.lambda.Function("processor", &#123;
  runtime: aws.lambda.Runtime.NodeJS20dX,
  handler: "index.handler",
  role: lambdaRole.arn,
  code: new pulumi.asset.AssetArchive(&#123;
    "index.js": new pulumi.asset.StringAsset(
      &#96;exports.handler = async (e) => (&#123; statusCode: 200, body: 'OK' &#125;);&#96;
    ),
  &#125;),
  environment: &#123;
    variables: &#123; BUCKET_NAME: bucket.bucket &#125;,
  &#125;,
&#125;);

// Stack outputs — accessible from other stacks via StackReference
export const bucketName = bucket.bucket;
export const bucketArn = bucket.arn;
export const lambdaArn = processor.arn;</pre>

  <p class="text-text-muted mb-3 leading-relaxed">Manage stacks and deploy:</p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">pulumi stack init dev                    # create dev stack
pulumi config set environment dev       # set config value
pulumi config set --secret dbPass s3cr3t  # encrypted secret
pulumi preview                          # dry-run, see what changes
pulumi up                               # deploy
pulumi stack output bucketName          # read stack output
pulumi destroy                          # tear down resources</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Automation API Example</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">// deploy-programmatically.ts
import &#123; LocalWorkspace &#125; from "@pulumi/pulumi/automation";

async function provisionTenant(tenantId: string) &#123;
  const stack = await LocalWorkspace.createOrSelectStack(&#123;
    stackName: &#96;tenant-&#36;&#123;tenantId&#125;&#96;,
    workDir: "./infrastructure",
  &#125;);

  await stack.setConfig("tenantId", &#123; value: tenantId &#125;);
  await stack.setConfig("dbPassword", &#123; value: "secret", secret: true &#125;);

  const result = await stack.up(&#123; onOutput: console.log &#125;);
  console.log(&#96;Tenant &#36;&#123;tenantId&#125; provisioned:&#96;, result.outputs);
  return result.outputs;
&#125;

// Call from your SaaS app when a customer signs up
provisionTenant("customer-abc-123");</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pulumi vs Alternatives</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse mb-6">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">Pulumi</th>
          <th class="border border-border px-3 py-2 text-left">Terraform</th>
          <th class="border border-border px-3 py-2 text-left">AWS CDK</th>
          <th class="border border-border px-3 py-2 text-left">Crossplane</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-border px-3 py-2">Language</td>
          <td class="border border-border px-3 py-2">TS / Python / Go / C# / Java</td>
          <td class="border border-border px-3 py-2">HCL</td>
          <td class="border border-border px-3 py-2">TS / Python / Java / C# / Go</td>
          <td class="border border-border px-3 py-2">YAML (Kubernetes CRDs)</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Cloud scope</td>
          <td class="border border-border px-3 py-2">Multi-cloud + SaaS (100+)</td>
          <td class="border border-border px-3 py-2">Multi-cloud (1000+ providers)</td>
          <td class="border border-border px-3 py-2">AWS only</td>
          <td class="border border-border px-3 py-2">Multi-cloud via K8s</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">State backend</td>
          <td class="border border-border px-3 py-2">Pulumi Cloud / S3 / GCS / local</td>
          <td class="border border-border px-3 py-2">TF Cloud / S3 / local</td>
          <td class="border border-border px-3 py-2">CloudFormation (managed)</td>
          <td class="border border-border px-3 py-2">etcd (Kubernetes)</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Automation API</td>
          <td class="border border-border px-3 py-2">Yes (first-class)</td>
          <td class="border border-border px-3 py-2">Limited (CLI wrapping)</td>
          <td class="border border-border px-3 py-2">No</td>
          <td class="border border-border px-3 py-2">K8s API</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">Policy as code</td>
          <td class="border border-border px-3 py-2">CrossGuard (TS/Python)</td>
          <td class="border border-border px-3 py-2">Sentinel / OPA</td>
          <td class="border border-border px-3 py-2">CDK Aspects</td>
          <td class="border border-border px-3 py-2">OPA / Kyverno</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Community size</td>
          <td class="border border-border px-3 py-2">Growing</td>
          <td class="border border-border px-3 py-2">Very large</td>
          <td class="border border-border px-3 py-2">Large (AWS ecosystem)</td>
          <td class="border border-border px-3 py-2">Medium (K8s community)</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Use Cases</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li>Multi-cloud infrastructure managed from a single codebase with shared language and tooling</li>
    <li>SaaS platforms that provision cloud resources per customer using the Automation API</li>
    <li>Teams who want to unit-test infrastructure code with Jest, pytest, or Go testing</li>
    <li>Organizations enforcing security and compliance policies automatically via CrossGuard</li>
    <li>Developers migrating from Terraform who prefer TypeScript or Python over HCL</li>
    <li>Kubernetes users who want to manage cloud resources alongside K8s manifests</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pros and Cons</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-green-400 mb-2">Pros</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✓ Real programming languages with full IDE support</li>
        <li>✓ Multi-cloud and SaaS providers in one tool</li>
        <li>✓ Automation API enables infrastructure-as-a-feature</li>
        <li>✓ Unit-testable with standard testing frameworks</li>
        <li>✓ Encrypted secrets built into config system</li>
        <li>✓ StackReference for modular stack composition</li>
      </ul>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-red-400 mb-2">Cons</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✗ Smaller community and provider ecosystem than Terraform</li>
        <li>✗ Pulumi Cloud required for full team features (paid)</li>
        <li>✗ Language flexibility can lead to inconsistent codebases</li>
        <li>✗ State file conflicts can be tricky to resolve</li>
        <li>✗ Longer cold start for complex programs vs HCL plans</li>
        <li>✗ Less mature than Terraform in enterprise tooling</li>
      </ul>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Pulumi IaC Guide" relatedTags={['pulumi', 'iac', 'cloud', 'infrastructure', 'devops']} />
</BaseLayout>
