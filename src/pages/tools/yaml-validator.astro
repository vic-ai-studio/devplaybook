---
import BaseLayout from '../../layouts/BaseLayout.astro';
import YamlValidator from '../../components/YamlValidator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="YAML Validator & Formatter"
  description="Validate and format YAML online. Detect syntax errors by line, format with consistent indentation, and convert to JSON. Free, runs in your browser."
  tool="YAML Validator, YAML Formatter, YAML to JSON, YAML Lint"
>
  <h1 class="text-3xl font-bold mb-2">YAML Validator & Formatter</h1>
  <p class="text-text-muted mb-8">Paste YAML to validate syntax and see errors by line. Format with 2 or 4-space indentation, or convert to JSON. Supports mappings, sequences, nested structures, and scalar types. Runs in your browser.</p>
  <YamlValidator client:load />
  <ToolPageCta currentTool="YAML Validator" relatedTags={['yaml', 'json', 'formatting', 'validation', 'development']} />
</BaseLayout>
