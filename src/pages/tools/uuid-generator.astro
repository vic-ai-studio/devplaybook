---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UuidGenerator from '../../components/UuidGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="UUID Generator"
  description="Generate UUID v4 in bulk. Choose standard, uppercase, no-hyphens, or braces format. Cryptographically secure, runs in your browser. No signup needed."
  tool="UUID Generator, GUID Generator, UUID v4 Bulk Generator"
>
  <h1 class="text-3xl font-bold mb-2">UUID Generator</h1>
  <p class="text-text-muted mb-8">Generate cryptographically secure UUID v4 identifiers — one at a time or in bulk up to 100. Copy individually or all at once in your preferred format.</p>
  <UuidGenerator client:only="preact" />
  <ToolPageCta currentTool="UUID Generator" relatedTags={['uuid', 'guid', 'id-generation', 'database']} />
</BaseLayout>
