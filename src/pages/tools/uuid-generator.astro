---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UuidGenerator from '../../components/UuidGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="UUID Generator — v1, v4, v5 — Free Online Tool"
  description="Generate UUID v1 (time-based), v4 (random), and v5 (name-based) in bulk. Multiple output formats. Cryptographically secure, runs in your browser. No signup needed."
  tool="UUID Generator, GUID Generator, UUID v1 v4 v5 Bulk Generator"
>
  <h1 class="text-3xl font-bold mb-2">UUID Generator</h1>
  <p class="text-text-muted mb-8">Generate UUID v1 (time-based), v4 (cryptographically random), or v5 (SHA-1 name-based) — one at a time or in bulk up to 100. One-click copy in your preferred format.</p>
  <UuidGenerator client:only="preact" />
  <ToolPageCta currentTool="UUID Generator" relatedTags={['uuid', 'guid', 'id-generation', 'database']} />
</BaseLayout>
