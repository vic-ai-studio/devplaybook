---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UuidGenerator from '../../components/UuidGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is a UUID and when should I use one?", answer: "A UUID (Universally Unique Identifier) is a 128-bit identifier that is guaranteed to be unique across space and time. Use UUIDs as primary keys in databases, session tokens, API request IDs, or any time you need a unique identifier without a central authority." },
  { question: "What is the difference between UUID v1, v4, and v5?", answer: "UUID v1 is time-based (includes timestamp and MAC address). UUID v4 is completely random using cryptographic randomness — the most common choice. UUID v5 is deterministic, generated from a namespace and a name using SHA-1, so the same inputs always produce the same UUID." },
  { question: "Is UUID v4 truly unique?", answer: "Practically yes. UUID v4 has 122 random bits, giving 5.3 × 10^36 possible values. The probability of a collision is astronomically low — you'd need to generate 1 billion UUIDs per second for 85 years to have a 50% chance of one duplicate." },
  { question: "What is the difference between UUID and GUID?", answer: "They are the same thing. UUID is the official term from RFC 4122. GUID (Globally Unique Identifier) is Microsoft's name for the same concept. Both use the same 8-4-4-4-12 hex format." },
];
---

<BaseLayout
  title="UUID Generator — v1, v4, v5 — Free Online Tool"
  description="Free UUID generator — create UUID v1 (time-based), v4 (cryptographically random), or v5 (SHA-1 name-based) in bulk. Multiple formats: standard, UPPERCASE, no-hyphens, braces. Generate up to 100 UUIDs at once for database seeding, API testing, and session tokens. No signup, runs 100% in your browser."
  tool="UUID Generator, GUID Generator, UUID v4 Random, UUID v1 Time-based, UUID v5 Name-based, Bulk UUID Generator, UUID Formats"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">UUID Generator</h1>
  <p class="text-text-muted mb-4">Generate UUID v1 (time-based), v4 (cryptographically random), or v5 (SHA-1 name-based) — one at a time or in bulk. Output in standard, UPPERCASE, no-hyphens, or braces format. One-click copy. Pro: generate up to 100 at once.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <UuidGenerator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <!-- Real-World Use Cases -->
  <section class="mt-12 mb-8">
    <h2 class="text-2xl font-bold mb-6">Real-World Use Cases</h2>

    <div class="space-y-6">
      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">1. Database Seed Scripts</h3>
        <p class="text-text-muted mb-3">You're writing a seed script for a PostgreSQL database and need 20 unique primary keys. Generate 20 UUID v4 values in bulk, copy the list, and paste them into your SQL <code class="font-mono text-sm bg-bg-card px-1 rounded">INSERT</code> statements.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Settings</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`Version: v4 (random)\nCount: 20\nFormat: standard (lowercase)`}</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Output (first 3)</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`a3f1d2e8-7b4c-4a1e-9f3d-2c8b5a6e7f01\nb7e2c9d4-3a5f-4e8b-a1c6-8d9f0e7b2a43\nc5d8a1f3-6e9b-4c2d-b7a0-1f4e3d8c5b92`}</pre>
          </div>
        </div>
      </div>

      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">2. Deterministic IDs with UUID v5</h3>
        <p class="text-text-muted mb-3">You need the same ID every time for a given user email — useful for idempotent imports or deduplication. UUID v5 generates a deterministic UUID from a namespace + name, so <code class="font-mono text-sm bg-bg-card px-1 rounded">"alice@example.com"</code> always produces the same UUID.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Input</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`Version: v5 (name-based SHA-1)\nNamespace: URL\nName: alice@example.com`}</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Output (always the same)</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">5c1c48a3-7f3a-5a12-b2e9-4f8d6c0e1b7a</pre>
          </div>
        </div>
      </div>

      <div class="p-4 bg-bg-card rounded-lg border border-border">
        <h3 class="font-semibold text-lg mb-2">3. API Testing with Unique Request IDs</h3>
        <p class="text-text-muted mb-3">When load-testing an API, each request needs a unique <code class="font-mono text-sm bg-bg-card px-1 rounded">X-Request-ID</code> header. Generate 100 UUIDs in no-hyphens format, then feed them into your test script (k6, Artillery, or cURL).</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Settings</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`Version: v4\nCount: 100\nFormat: no-hyphens`}</pre>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-1">Output (first 3)</p>
            <pre class="bg-zinc-900 text-green-400 p-3 rounded text-sm overflow-x-auto">{`a3f1d2e87b4c4a1e9f3d2c8b5a6e7f01\nb7e2c9d43a5f4e8ba1c68d9f0e7b2a43\nc5d8a1f36e9b4c2db7a01f4e3d8c5b92`}</pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Step-by-Step Guide -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold mb-4">How to Use — Step by Step</h2>
    <ol class="list-decimal list-inside space-y-3 text-text-muted">
      <li><strong>Choose a version</strong> — Select v1 for time-ordered IDs, v4 for fully random IDs (most common), or v5 for deterministic name-based IDs.</li>
      <li><strong>Set quantity</strong> — Enter how many UUIDs you need (1–100). Bulk generation is useful for seed scripts and test data.</li>
      <li><strong>Pick a format</strong> — Standard (<code class="font-mono text-sm bg-bg-card px-1 rounded">8-4-4-4-12</code>), UPPERCASE, no-hyphens, or braces (<code class="font-mono text-sm bg-bg-card px-1 rounded">{`{...}`}</code>) for GUID-style systems like .NET.</li>
      <li><strong>Generate</strong> — Click the generate button. All UUIDs are created instantly using your browser's <code class="font-mono text-sm bg-bg-card px-1 rounded">crypto.getRandomValues()</code> for cryptographic randomness.</li>
      <li><strong>Copy</strong> — Click copy to get the full list. Paste into your SQL file, JSON fixture, or test script.</li>
    </ol>
  </section>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="UUID Generator" relatedTags={['uuid', 'guid', 'id-generation', 'database']} />
</BaseLayout>
