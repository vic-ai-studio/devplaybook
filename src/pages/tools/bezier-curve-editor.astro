---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BezierCurveEditor from '../../components/BezierCurveEditor.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is a Bezier curve?", answer: "A Bezier curve is a parametric curve defined by control points. A cubic Bezier has 4 points: P0 (start), P1 and P2 (control handles that shape the curve), and P3 (end). The curve passes through P0 and P3 but is 'attracted' by P1 and P2 without necessarily touching them. They are used everywhere: SVG paths, CSS animations, font outlines, and game pathfinding." },
  { question: "What is the difference between cubic and quadratic Bezier?", answer: "A quadratic Bezier uses 3 points (P0, P1 control, P2 end) and produces a simpler parabola-like curve. A cubic Bezier uses 4 points (two control points) allowing S-curves, loops, and more complex shapes. Most CSS animations, Canvas paths, and SVG <path> elements default to cubic Bezier for their expressiveness." },
  { question: "What does cubic-bezier() mean in CSS?", answer: "CSS cubic-bezier(x1, y1, x2, y2) defines an easing curve for animations. The start point is fixed at (0,0) and end at (1,1). x1/y1 define the first control point; x2/y2 the second. X values must be in [0,1] (time). Y values can exceed [0,1] for overshoot/bounce effects. Built-ins like ease, ease-in, ease-out, ease-in-out are all cubic-bezier() calls." },
  { question: "How is the SVG path notation formed?", answer: "In SVG, M x y moves to a start point. C cx1 cy1, cx2 cy2, x y draws a cubic Bezier to (x,y) with control points (cx1,cy1) and (cx2,cy2). Q cx cy, x y draws a quadratic Bezier. These path commands are used in <path d='...'> attributes and are the building blocks of all SVG icons, logos, and illustrations." },
  { question: "What is the t parameter in Bezier math?", answer: "t is the parameter ranging from 0.0 (start) to 1.0 (end). Plugging t into the Bezier formula gives the exact (x,y) point at that proportion along the curve. t=0.5 is the midpoint of the curve (not the midpoint of the bounding box). This parametric form makes Bezier curves easy to sample, animate along, and split at any position." },
  { question: "How do I animate an object along a Bezier path?", answer: "Increment t from 0 to 1 each frame in requestAnimationFrame. Plug t into the Bezier formula to get the current (x, y) position. For easing, apply a non-linear t: ease-in uses t² or t³, ease-out uses 1-(1-t)², ease-in-out combines them. For CSS, use offset-path with a path() value and animate offset-distance from 0% to 100%." },
];
---

<BaseLayout
  title="Bezier Curve Editor — Visual Cubic & Quadratic Path Builder"
  description="Interactive Bezier curve editor. Drag control points to shape cubic or quadratic paths. Get CSS cubic-bezier easing, SVG path notation, and JavaScript Bezier math code. Animate along the curve."
  tool="Bezier Curve Editor, CSS cubic-bezier Generator, SVG Path Builder, Quadratic Bezier Tool, Canvas Path Editor"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Bezier Curve Editor</h1>
  <p class="text-text-muted mb-4">Drag the control points to sculpt cubic or quadratic Bezier curves. Copy the CSS easing, SVG path, or JavaScript implementation code for any curve you design.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Cubic & quadratic modes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CSS / SVG / JS output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Animate dot along path</span>
  </div>
  <BezierCurveEditor client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Bezier Curve Editor" relatedTags={['css', 'animation', 'svg', 'canvas', 'graphics']} />
</BaseLayout>
