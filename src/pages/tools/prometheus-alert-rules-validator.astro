---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PrometheusAlertRulesValidator from '../../components/PrometheusAlertRulesValidator.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Prometheus alerting?", answer: "Prometheus evaluates alert rules at regular intervals (typically 1m). When a PromQL expression returns results, the alert becomes 'pending'. After the 'for' duration passes, it fires and is sent to Alertmanager, which routes notifications to PagerDuty, Slack, email, etc. Alert rules are defined in YAML files and loaded by Prometheus via the rule_files config." },
  { question: "What is the 'for' clause in alert rules?", answer: "The 'for' clause specifies how long a condition must be true before the alert fires. Without it, alerts fire immediately (and may flap). Example: 'for: 5m' means the CPU must stay above 80% for 5 continuous minutes. Use it to avoid alerting on brief spikes. Set it to 0s or omit it only for critical alerts where you want instant notification." },
  { question: "How do I write PromQL for CPU usage alerts?", answer: "CPU usage: 100 - (avg by (instance) (rate(node_cpu_seconds_total{mode='idle'}[5m])) * 100) > 80. Memory: node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes * 100 < 10. Disk: (node_filesystem_size_bytes - node_filesystem_free_bytes) / node_filesystem_size_bytes * 100 > 85. Use rate() for counters and instant value for gauges." },
  { question: "How do I test alert rules before deploying?", answer: "Use promtool: promtool check rules /path/to/alerts.yaml. For unit testing, write test files with promtool test rules. In Grafana, use the Alerting > Alert rules page to preview firing alerts. You can also query the Prometheus /api/v1/rules endpoint to see current rule status and use /graph to test PromQL expressions interactively." },
  { question: "What labels and annotations should I include?", answer: "Required labels: severity (critical/warning/info) for Alertmanager routing, team or service for ownership. Required annotations: summary (one-line description, use {{ $labels.instance }} for dynamic data), description (detailed context including {{ $value }} for the metric value, runbook_url for links to runbooks). These appear in your notification messages." },
  { question: "How do I avoid alert fatigue?", answer: "Set appropriate 'for' durations (5-15 minutes for non-critical). Use inhibition rules in Alertmanager (e.g. suppress warning when critical fires). Group related alerts. Set proper severity levels and route only critical to PagerDuty. Use dead man's switch alerts for silence detection. Review and tune thresholds regularly — start conservative and tighten based on incident history." },
];
---

<BaseLayout
  title="Prometheus Alert Rules Validator — PromQL YAML Checker — Free Online Tool"
  description="Validate Prometheus alert rules YAML files online. Check PromQL expression syntax, verify required fields (for, labels, annotations), detect duplicate alert names, and get suggestions for better alerting practices."
  tool="prometheus alert rules validator, promql validator, prometheus yaml checker, alert rules syntax, prometheus alertmanager, promql alert expression"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Prometheus Alert Rules Validator</h1>
  <p class="text-text-muted mb-8">Validate your Prometheus alert rules YAML files. Checks PromQL expression syntax, required fields, severity labels, duration formats, and common mistakes. Paste your rules and get instant feedback.</p>
  <PrometheusAlertRulesValidator client:only="preact" />
  <FaqSection faq={faq} />
  <AffiliateSection category={['monitoring', 'devops']} />
  <ToolPageCta currentTool="Prometheus Alert Rules Validator" relatedTags={['prometheus', 'alerting', 'promql', 'monitoring', 'devops']} />
</BaseLayout>
