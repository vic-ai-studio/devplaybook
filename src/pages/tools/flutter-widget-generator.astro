---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a Flutter widget?",
    answer: "A Flutter widget is the basic building block of a Flutter UI. Everything in Flutter is a widget — buttons, text, padding, layout containers, and even the app itself. Widgets describe what their view should look like given their current configuration and state. Flutter has two main widget types: StatelessWidget (no mutable state) and StatefulWidget (maintains state that can change)."
  },
  {
    question: "What is the difference between Container and SizedBox?",
    answer: "Container is a convenience widget that can combine common painting, positioning, and sizing. It can have padding, margin, decoration, color, and child constraints. SizedBox is a simpler box with a fixed size — useful for exact dimensions or as a spacer. When you only need fixed width/height, SizedBox is lighter than Container."
  },
  {
    question: "When should I use Row vs Column?",
    answer: "Use Row to arrange widgets horizontally (side by side) and Column to arrange them vertically (stacked). Both use MainAxisAlignment to control spacing along the main axis and CrossAxisAlignment to control alignment on the cross axis. For dynamic content that might overflow, consider ListView instead of Column."
  },
  {
    question: "What does mainAxisAlignment do?",
    answer: "mainAxisAlignment controls how children are positioned along the main axis — horizontal for Row, vertical for Column. Options include start (pack at beginning), end (pack at end), center (center as a group), spaceBetween (first/last at edges, others evenly spread), spaceAround (equal space around each child), and spaceEvenly (equal space between and around all children)."
  },
  {
    question: "How does padding work in Flutter?",
    answer: "Padding in Flutter uses EdgeInsets. Common constructors: EdgeInsets.all(value) for uniform padding on all sides, EdgeInsets.symmetric(horizontal: h, vertical: v) for paired sides, and EdgeInsets.only(left: l, top: t, right: r, bottom: b) for individual control. The Padding widget wraps a child, while Container accepts padding as a property."
  },
  {
    question: "What is a ListView and when should I use it?",
    answer: "ListView is a scrollable list of widgets laid out linearly. Use it instead of Column when you have many items or content that may overflow the screen. ListView.builder is the most efficient option for long or dynamic lists — it lazily builds items only when they're visible. ListView itself renders all children at once, so it's best for short, fixed lists."
  },
];
---

<BaseLayout
  title="Flutter Widget Generator — Build Flutter/Dart Widget Code"
  description="Generate Flutter widget code instantly. Select widget type, configure padding, margin, alignment, and colors visually. Get ready-to-use Dart code with copy button. Free browser tool, no sign-up."
  tool="Flutter Widget Generator, Flutter Code Generator, Dart Widget Builder, Flutter UI Builder, Flutter Container Generator, Flutter Row Column Generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Flutter Widget Generator",
    "url": "https://devplaybook.cc/tools/flutter-widget-generator",
    "description": "Generate ready-to-use Flutter/Dart widget code. Configure widget type, padding, margin, colors, and alignment visually.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Flutter Widget Generator</h1>
  <p class="text-text-muted mb-4">
    Configure Flutter widgets visually and get ready-to-use Dart code. Choose widget type, set properties like padding, margin, alignment, and color, then copy the generated code directly into your Flutter project.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 8 widget types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Instant Dart code generation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <div id="flutter-app" class="space-y-5">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <!-- Config Panel -->
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-semibold mb-1" for="widget-type">Widget Type</label>
          <select id="widget-type" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent">
            <option value="Container">Container</option>
            <option value="Row">Row</option>
            <option value="Column">Column</option>
            <option value="Stack">Stack</option>
            <option value="ListView">ListView</option>
            <option value="Padding">Padding</option>
            <option value="Center">Center</option>
            <option value="SizedBox">SizedBox</option>
          </select>
        </div>

        <div id="section-size" class="space-y-3">
          <p class="text-xs font-semibold text-text-muted uppercase tracking-wide">Size</p>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs text-text-muted mb-1" for="width">Width</label>
              <input id="width" type="text" placeholder="double.infinity" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1" for="height">Height</label>
              <input id="height" type="text" placeholder="200" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
          </div>
        </div>

        <div id="section-padding" class="space-y-3">
          <p class="text-xs font-semibold text-text-muted uppercase tracking-wide">Padding</p>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs text-text-muted mb-1" for="pad-type">Type</label>
              <select id="pad-type" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent">
                <option value="none">None</option>
                <option value="all">All sides</option>
                <option value="symmetric">Symmetric</option>
                <option value="only">Only</option>
              </select>
            </div>
            <div id="pad-all-group">
              <label class="block text-xs text-text-muted mb-1" for="pad-all">Value</label>
              <input id="pad-all" type="number" value="16" min="0" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
          </div>
          <div id="pad-sym-group" class="hidden grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs text-text-muted mb-1">Horizontal</label>
              <input id="pad-h" type="number" value="16" min="0" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">Vertical</label>
              <input id="pad-v" type="number" value="16" min="0" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
          </div>
          <div id="pad-only-group" class="hidden grid grid-cols-4 gap-2">
            <div>
              <label class="block text-xs text-text-muted mb-1">Top</label>
              <input id="pad-top" type="number" value="8" min="0" class="w-full bg-surface border border-border rounded-lg px-2 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">Right</label>
              <input id="pad-right" type="number" value="8" min="0" class="w-full bg-surface border border-border rounded-lg px-2 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">Bottom</label>
              <input id="pad-bottom" type="number" value="8" min="0" class="w-full bg-surface border border-border rounded-lg px-2 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">Left</label>
              <input id="pad-left" type="number" value="8" min="0" class="w-full bg-surface border border-border rounded-lg px-2 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
          </div>
        </div>

        <div id="section-margin" class="space-y-2">
          <p class="text-xs font-semibold text-text-muted uppercase tracking-wide">Margin</p>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs text-text-muted mb-1" for="margin-type">Type</label>
              <select id="margin-type" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent">
                <option value="none">None</option>
                <option value="all">All sides</option>
                <option value="symmetric">Symmetric</option>
              </select>
            </div>
            <div id="margin-val-group">
              <label class="block text-xs text-text-muted mb-1" for="margin-all">Value</label>
              <input id="margin-all" type="number" value="8" min="0" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
          </div>
          <div id="margin-sym-group" class="hidden grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs text-text-muted mb-1">Horizontal</label>
              <input id="margin-h" type="number" value="16" min="0" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">Vertical</label>
              <input id="margin-v" type="number" value="8" min="0" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
          </div>
        </div>

        <div id="section-color" class="space-y-2">
          <p class="text-xs font-semibold text-text-muted uppercase tracking-wide">Color</p>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs text-text-muted mb-1">Background</label>
              <select id="bg-color" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent">
                <option value="">None</option>
                <option value="Colors.white">Colors.white</option>
                <option value="Colors.black">Colors.black</option>
                <option value="Colors.blue">Colors.blue</option>
                <option value="Colors.red">Colors.red</option>
                <option value="Colors.green">Colors.green</option>
                <option value="Colors.grey[200]">Colors.grey[200]</option>
                <option value="Colors.transparent">Colors.transparent</option>
                <option value="Theme.of(context).primaryColor">primaryColor</option>
              </select>
            </div>
            <div id="section-alignment">
              <label class="block text-xs text-text-muted mb-1">Alignment</label>
              <select id="alignment" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent">
                <option value="">None</option>
                <option value="Alignment.center">center</option>
                <option value="Alignment.topLeft">topLeft</option>
                <option value="Alignment.topCenter">topCenter</option>
                <option value="Alignment.topRight">topRight</option>
                <option value="Alignment.centerLeft">centerLeft</option>
                <option value="Alignment.centerRight">centerRight</option>
                <option value="Alignment.bottomLeft">bottomLeft</option>
                <option value="Alignment.bottomCenter">bottomCenter</option>
                <option value="Alignment.bottomRight">bottomRight</option>
              </select>
            </div>
          </div>
        </div>

        <div id="section-axis" class="hidden space-y-2">
          <p class="text-xs font-semibold text-text-muted uppercase tracking-wide">Axis Alignment</p>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs text-text-muted mb-1">mainAxisAlignment</label>
              <select id="main-axis" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent">
                <option value="MainAxisAlignment.start">start</option>
                <option value="MainAxisAlignment.center">center</option>
                <option value="MainAxisAlignment.end">end</option>
                <option value="MainAxisAlignment.spaceBetween">spaceBetween</option>
                <option value="MainAxisAlignment.spaceAround">spaceAround</option>
                <option value="MainAxisAlignment.spaceEvenly">spaceEvenly</option>
              </select>
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">crossAxisAlignment</label>
              <select id="cross-axis" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent">
                <option value="CrossAxisAlignment.center">center</option>
                <option value="CrossAxisAlignment.start">start</option>
                <option value="CrossAxisAlignment.end">end</option>
                <option value="CrossAxisAlignment.stretch">stretch</option>
                <option value="CrossAxisAlignment.baseline">baseline</option>
              </select>
            </div>
          </div>
        </div>

        <div id="section-children">
          <label class="block text-sm font-semibold mb-1">Child Widget (placeholder)</label>
          <input id="child-widget" type="text" value="Text('Hello Flutter')" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text font-mono focus:outline-none focus:border-accent" placeholder="Text('Hello')" />
        </div>
      </div>

      <!-- Output Panel -->
      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <p class="text-sm font-semibold">Generated Dart Code</p>
          <button id="btn-copy" class="text-xs text-accent hover:underline font-medium">Copy code</button>
        </div>
        <pre id="code-output" class="bg-surface border border-border rounded-lg p-4 text-sm font-mono overflow-auto min-h-64 text-text leading-relaxed whitespace-pre"></pre>
        <div id="copy-toast" class="hidden text-xs text-green-500 font-medium">Copied to clipboard!</div>
      </div>
    </div>

    <!-- Quick Presets -->
    <div>
      <p class="text-xs font-semibold text-text-muted uppercase tracking-wide mb-2">Quick Presets</p>
      <div class="flex flex-wrap gap-2">
        <button class="preset-btn px-3 py-1.5 bg-surface border border-border hover:border-accent/50 text-text text-xs rounded-lg transition-colors" data-preset="card">Card Container</button>
        <button class="preset-btn px-3 py-1.5 bg-surface border border-border hover:border-accent/50 text-text text-xs rounded-lg transition-colors" data-preset="row">Spaced Row</button>
        <button class="preset-btn px-3 py-1.5 bg-surface border border-border hover:border-accent/50 text-text text-xs rounded-lg transition-colors" data-preset="col">Centered Column</button>
        <button class="preset-btn px-3 py-1.5 bg-surface border border-border hover:border-accent/50 text-text text-xs rounded-lg transition-colors" data-preset="listview">ListView</button>
        <button class="preset-btn px-3 py-1.5 bg-surface border border-border hover:border-accent/50 text-text text-xs rounded-lg transition-colors" data-preset="spacer">Spacer SizedBox</button>
      </div>
    </div>
  </div>

  <script>
    (function () {
      function getPadding() {
        const type = document.getElementById('pad-type').value;
        if (type === 'none') return null;
        if (type === 'all') {
          const v = document.getElementById('pad-all').value || '16';
          return `EdgeInsets.all(${v})`;
        }
        if (type === 'symmetric') {
          const h = document.getElementById('pad-h').value || '16';
          const v = document.getElementById('pad-v').value || '16';
          return `EdgeInsets.symmetric(horizontal: ${h}, vertical: ${v})`;
        }
        if (type === 'only') {
          const t = document.getElementById('pad-top').value || '0';
          const r = document.getElementById('pad-right').value || '0';
          const b = document.getElementById('pad-bottom').value || '0';
          const l = document.getElementById('pad-left').value || '0';
          return `EdgeInsets.only(top: ${t}, right: ${r}, bottom: ${b}, left: ${l})`;
        }
        return null;
      }

      function getMargin() {
        const type = document.getElementById('margin-type').value;
        if (type === 'none') return null;
        if (type === 'all') {
          const v = document.getElementById('margin-all').value || '8';
          return `EdgeInsets.all(${v})`;
        }
        if (type === 'symmetric') {
          const h = document.getElementById('margin-h').value || '16';
          const v = document.getElementById('margin-v').value || '8';
          return `EdgeInsets.symmetric(horizontal: ${h}, vertical: ${v})`;
        }
        return null;
      }

      function indent(str, spaces) {
        const pad = ' '.repeat(spaces);
        return str.split('\n').map(l => pad + l).join('\n');
      }

      function generateCode() {
        const wtype = document.getElementById('widget-type').value;
        const width = document.getElementById('width').value.trim();
        const height = document.getElementById('height').value.trim();
        const bgColor = document.getElementById('bg-color').value;
        const alignment = document.getElementById('alignment').value;
        const mainAxis = document.getElementById('main-axis').value;
        const crossAxis = document.getElementById('cross-axis').value;
        const child = document.getElementById('child-widget').value.trim() || "Text('Hello Flutter')";
        const padding = getPadding();
        const margin = getMargin();

        let lines = [];

        if (wtype === 'Container') {
          lines.push('Container(');
          if (width) lines.push(`  width: ${width},`);
          if (height) lines.push(`  height: ${height},`);
          if (padding) lines.push(`  padding: ${padding},`);
          if (margin) lines.push(`  margin: ${margin},`);
          if (bgColor) lines.push(`  color: ${bgColor},`);
          if (alignment) lines.push(`  alignment: ${alignment},`);
          lines.push(`  child: ${child},`);
          lines.push(')');
        } else if (wtype === 'Row') {
          lines.push('Row(');
          lines.push(`  mainAxisAlignment: ${mainAxis},`);
          lines.push(`  crossAxisAlignment: ${crossAxis},`);
          lines.push(`  children: [`);
          lines.push(`    ${child},`);
          lines.push(`  ],`);
          lines.push(')');
        } else if (wtype === 'Column') {
          lines.push('Column(');
          lines.push(`  mainAxisAlignment: ${mainAxis},`);
          lines.push(`  crossAxisAlignment: ${crossAxis},`);
          lines.push(`  children: [`);
          lines.push(`    ${child},`);
          lines.push(`  ],`);
          lines.push(')');
        } else if (wtype === 'Stack') {
          lines.push('Stack(');
          lines.push(`  alignment: ${alignment || 'Alignment.topLeft'},`);
          lines.push(`  children: [`);
          lines.push(`    ${child},`);
          lines.push(`  ],`);
          lines.push(')');
        } else if (wtype === 'ListView') {
          lines.push('ListView(');
          lines.push(`  padding: ${padding || 'EdgeInsets.all(16)'},`);
          lines.push(`  children: [`);
          lines.push(`    ${child},`);
          lines.push(`  ],`);
          lines.push(')');
        } else if (wtype === 'Padding') {
          lines.push('Padding(');
          lines.push(`  padding: ${padding || 'EdgeInsets.all(16)'},`);
          lines.push(`  child: ${child},`);
          lines.push(')');
        } else if (wtype === 'Center') {
          lines.push('Center(');
          lines.push(`  child: ${child},`);
          lines.push(')');
        } else if (wtype === 'SizedBox') {
          lines.push('SizedBox(');
          if (width) lines.push(`  width: ${width},`);
          if (height) lines.push(`  height: ${height},`);
          if (child) lines.push(`  child: ${child},`);
          lines.push(')');
        }

        return lines.join('\n');
      }

      function updateOutput() {
        document.getElementById('code-output').textContent = generateCode();
      }

      function updateVisibility() {
        const wtype = document.getElementById('widget-type').value;
        const isRowCol = wtype === 'Row' || wtype === 'Column';
        const hasColor = wtype === 'Container';
        const hasSize = wtype === 'Container' || wtype === 'SizedBox';
        const hasMargin = wtype === 'Container';
        const hasPad = wtype !== 'Center' && wtype !== 'SizedBox' && wtype !== 'Padding';

        document.getElementById('section-axis').classList.toggle('hidden', !isRowCol);
        document.getElementById('section-color').classList.toggle('hidden', !hasColor);
        document.getElementById('section-size').classList.toggle('hidden', !hasSize);
        document.getElementById('section-margin').classList.toggle('hidden', !hasMargin);

        updateOutput();
      }

      // Padding type toggle
      document.getElementById('pad-type').addEventListener('change', function () {
        const t = this.value;
        document.getElementById('pad-all-group').classList.toggle('hidden', t !== 'all');
        document.getElementById('pad-sym-group').classList.toggle('hidden', t !== 'symmetric');
        document.getElementById('pad-only-group').classList.toggle('hidden', t !== 'only');
        updateOutput();
      });

      // Margin type toggle
      document.getElementById('margin-type').addEventListener('change', function () {
        const t = this.value;
        document.getElementById('margin-val-group').classList.toggle('hidden', t !== 'all');
        document.getElementById('margin-sym-group').classList.toggle('hidden', t !== 'symmetric');
        updateOutput();
      });

      // Widget type change
      document.getElementById('widget-type').addEventListener('change', updateVisibility);

      // All inputs
      document.querySelectorAll('#flutter-app input, #flutter-app select').forEach(el => {
        el.addEventListener('input', updateOutput);
        el.addEventListener('change', updateOutput);
      });

      // Copy button
      document.getElementById('btn-copy').addEventListener('click', function () {
        const code = document.getElementById('code-output').textContent;
        navigator.clipboard.writeText(code).then(() => {
          const toast = document.getElementById('copy-toast');
          toast.classList.remove('hidden');
          setTimeout(() => toast.classList.add('hidden'), 2000);
        });
      });

      // Presets
      const presets = {
        card: { wtype: 'Container', width: 'double.infinity', height: '', pad: 'all', padAll: '16', margin: 'all', marginAll: '8', bg: 'Colors.white', align: '', child: "Text('Card content')" },
        row: { wtype: 'Row', mainAxis: 'MainAxisAlignment.spaceBetween', crossAxis: 'CrossAxisAlignment.center', child: "Text('Item 1'), Text('Item 2')" },
        col: { wtype: 'Column', mainAxis: 'MainAxisAlignment.center', crossAxis: 'CrossAxisAlignment.center', child: "Text('Title'), SizedBox(height: 8), Text('Subtitle')" },
        listview: { wtype: 'ListView', pad: 'all', padAll: '16', child: "ListTile(title: Text('Item 1')), ListTile(title: Text('Item 2'))" },
        spacer: { wtype: 'SizedBox', width: '', height: '16', child: '' },
      };

      document.querySelectorAll('.preset-btn').forEach(btn => {
        btn.addEventListener('click', function () {
          const p = presets[this.dataset.preset];
          if (!p) return;
          document.getElementById('widget-type').value = p.wtype;
          if (p.width !== undefined) document.getElementById('width').value = p.width;
          if (p.height !== undefined) document.getElementById('height').value = p.height;
          if (p.bg) document.getElementById('bg-color').value = p.bg;
          if (p.align !== undefined) document.getElementById('alignment').value = p.align;
          if (p.mainAxis) document.getElementById('main-axis').value = p.mainAxis;
          if (p.crossAxis) document.getElementById('cross-axis').value = p.crossAxis;
          if (p.pad) {
            document.getElementById('pad-type').value = p.pad;
            if (p.padAll) document.getElementById('pad-all').value = p.padAll;
          }
          if (p.margin) {
            document.getElementById('margin-type').value = p.margin;
            if (p.marginAll) document.getElementById('margin-all').value = p.marginAll;
          }
          if (p.child !== undefined) document.getElementById('child-widget').value = p.child;
          updateVisibility();
        });
      });

      // Init
      updateVisibility();
    })();
  </script>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Flutter Widget Generator" relatedTags={['flutter', 'dart', 'mobile', 'ui', 'cross-platform']} />
</BaseLayout>
