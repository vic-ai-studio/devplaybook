---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Jenkins Pipeline Generator — Declarative & Scripted Jenkinsfile Builder"
  description="Generate Jenkins Declarative or Scripted Pipeline Jenkinsfiles. Choose agent, stages (Checkout, Build, Test, Deploy), triggers, post-actions. Runs in your browser."
  tool="Jenkins pipeline generator, Jenkinsfile generator, declarative pipeline, scripted pipeline, Jenkins CI/CD"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Jenkins Pipeline Generator",
    "url": "https://devplaybook.cc/tools/jenkins-pipeline-generator",
    "description": "Generate Jenkins Declarative or Scripted Pipeline Jenkinsfiles online. Configure agent, stages, triggers, and post-actions. Free, runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Jenkins Pipeline Generator</h1>
  <p class="text-text-muted mb-4">Build a production-ready <code class="font-mono text-primary">Jenkinsfile</code> in seconds. Choose Declarative or Scripted syntax, configure your agent, select stages, set triggers, and add post-actions — all without leaving your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Declarative &amp; Scripted pipelines</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Node.js / Python / Maven / Gradle / Docker</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> pollSCM, webhook, cron triggers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs entirely in your browser</span>
  </div>

  <!-- Row 1: Pipeline type + Project type -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
    <div>
      <label class="block text-sm font-medium mb-2">Pipeline Type</label>
      <select id="pipeline-type" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
        <option value="declarative">Declarative</option>
        <option value="scripted">Scripted</option>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium mb-2">Project Type</label>
      <select id="project-type" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
        <option value="nodejs">Node.js</option>
        <option value="python">Python</option>
        <option value="maven">Maven</option>
        <option value="gradle">Gradle</option>
        <option value="docker">Docker</option>
      </select>
    </div>
  </div>

  <!-- Row 2: Agent type -->
  <div class="mb-4">
    <label class="block text-sm font-medium mb-2">Agent</label>
    <div class="flex flex-wrap gap-3">
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <input type="radio" name="agent-type" value="any" checked class="accent-primary" />
        any
      </label>
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <input type="radio" name="agent-type" value="docker" class="accent-primary" />
        docker
      </label>
      <label class="flex items-center gap-2 text-sm cursor-pointer">
        <input type="radio" name="agent-type" value="node" class="accent-primary" />
        node label
      </label>
    </div>
    <div id="docker-image-wrap" class="hidden mt-2">
      <input id="docker-image" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="node:20-alpine" value="node:20-alpine" />
    </div>
    <div id="node-label-wrap" class="hidden mt-2">
      <input id="node-label" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="linux-builder" value="linux-builder" />
    </div>
  </div>

  <!-- Row 3: App name -->
  <div class="mb-4">
    <label class="block text-sm font-medium mb-2">App Name</label>
    <input id="app-name" type="text" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="my-app" value="my-app" />
  </div>

  <!-- Row 4: Stages -->
  <div class="mb-4">
    <label class="block text-sm font-medium mb-3">Stages</label>
    <div class="flex flex-wrap gap-4">
      <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" id="stage-checkout" checked class="rounded accent-primary" /> Checkout</label>
      <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" id="stage-build" checked class="rounded accent-primary" /> Build</label>
      <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" id="stage-test" checked class="rounded accent-primary" /> Test</label>
      <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" id="stage-lint" class="rounded accent-primary" /> Lint</label>
      <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" id="stage-package" class="rounded accent-primary" /> Package</label>
      <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" id="stage-deploy" checked class="rounded accent-primary" /> Deploy</label>
    </div>
  </div>

  <!-- Row 5: Trigger -->
  <div class="mb-4">
    <label class="block text-sm font-medium mb-2">Trigger</label>
    <select id="trigger-type" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary">
      <option value="none">None (manual)</option>
      <option value="pollSCM" selected>pollSCM — every 15 minutes</option>
      <option value="cron">cron — nightly at 02:00</option>
      <option value="webhook">Webhook (GitLab / GitHub)</option>
    </select>
  </div>

  <!-- Row 6: Post actions -->
  <div class="mb-4">
    <label class="block text-sm font-medium mb-3">Post Actions</label>
    <div class="flex flex-wrap gap-4 mb-3">
      <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" id="post-always" checked class="rounded accent-primary" /> always (archive / cleanup)</label>
      <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" id="post-success" checked class="rounded accent-primary" /> success (echo)</label>
      <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" id="post-failure" checked class="rounded accent-primary" /> failure (email)</label>
    </div>
    <div id="email-wrap" class="flex items-center gap-3">
      <label class="text-sm text-text-muted whitespace-nowrap">Email on failure:</label>
      <input id="email-addr" type="text" class="flex-1 bg-bg-card border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="team@example.com" value="team@example.com" />
    </div>
  </div>

  <!-- Buttons -->
  <div class="flex gap-3 mb-6 flex-wrap">
    <button id="btn-generate" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Generate Jenkinsfile</button>
    <button id="btn-example-nodejs" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Node.js Example</button>
    <button id="btn-example-maven" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Maven Example</button>
    <button id="btn-example-docker" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Docker Example</button>
  </div>

  <!-- Output -->
  <div id="output-section" class="hidden">
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <div class="flex justify-between items-center mb-3">
        <span class="text-sm font-medium text-text-muted font-mono">Jenkinsfile</span>
        <button id="copy-btn" class="px-3 py-1.5 bg-bg-card border border-border rounded text-xs hover:border-primary transition-colors">Copy</button>
      </div>
      <pre id="output-code" class="font-mono text-sm whitespace-pre-wrap break-words overflow-x-auto max-h-[500px] overflow-y-auto text-green-300"></pre>
    </div>
  </div>

  <ToolPageCta />
</BaseLayout>

<script is:inline>
function v(id) {
  const el = document.getElementById(id);
  if (!el) return '';
  if (el.type === 'checkbox') return el.checked;
  return (el.value || '').trim();
}
function radio(name) {
  const el = document.querySelector(`input[name="${name}"]:checked`);
  return el ? el.value : '';
}

// Agent visibility
document.querySelectorAll('input[name="agent-type"]').forEach(r => {
  r.addEventListener('change', function () {
    document.getElementById('docker-image-wrap').classList.toggle('hidden', this.value !== 'docker');
    document.getElementById('node-label-wrap').classList.toggle('hidden', this.value !== 'node');
  });
});

// email row visibility
document.getElementById('post-failure').addEventListener('change', function () {
  document.getElementById('email-wrap').style.opacity = this.checked ? '1' : '0.4';
});

// --- command helpers per project type ---
function cmds(projectType, stage) {
  const map = {
    nodejs: {
      build: ["sh 'npm ci'", "sh 'npm run build'"],
      test:  ["sh 'npm test -- --reporter=junit --reporter-option output=test-results/junit.xml'"],
      lint:  ["sh 'npm run lint'"],
      package: ["sh 'npm pack'"],
      deploy: ["sh 'npm run deploy'"],
    },
    python: {
      build: ["sh 'pip install -r requirements.txt'"],
      test:  ["sh 'pytest --junitxml=test-results/junit.xml'"],
      lint:  ["sh 'flake8 . --count --statistics'"],
      package: ["sh 'python setup.py sdist bdist_wheel'"],
      deploy: ["sh 'python deploy.py'"],
    },
    maven: {
      build: ["sh 'mvn clean compile -B'"],
      test:  ["sh 'mvn test -B'"],
      lint:  ["sh 'mvn checkstyle:check -B'"],
      package: ["sh 'mvn package -DskipTests -B'"],
      deploy: ["sh 'mvn deploy -DskipTests -B'"],
    },
    gradle: {
      build: ["sh './gradlew classes'"],
      test:  ["sh './gradlew test'"],
      lint:  ["sh './gradlew checkstyleMain'"],
      package: ["sh './gradlew assemble'"],
      deploy: ["sh './gradlew publish'"],
    },
    docker: {
      build: ["sh 'docker build -t ${DOCKER_IMAGE} .'"],
      test:  ["sh 'docker run --rm ${DOCKER_IMAGE} npm test'"],
      lint:  ["sh 'docker run --rm ${DOCKER_IMAGE} npm run lint'"],
      package: ["sh 'docker save ${DOCKER_IMAGE} | gzip > image.tar.gz'"],
      deploy: ["sh 'docker push ${DOCKER_IMAGE}'"],
    },
  };
  return (map[projectType] && map[projectType][stage]) || [`sh '# ${stage}'`];
}

function junitReport(projectType) {
  if (projectType === 'python') return "junit 'test-results/junit.xml'";
  if (projectType === 'maven') return "junit '**/target/surefire-reports/*.xml'";
  if (projectType === 'gradle') return "junit '**/build/test-results/**/*.xml'";
  return "junit 'test-results/**/*.xml'";
}

function indent(lines, spaces) {
  const pad = ' '.repeat(spaces);
  return lines.map(l => pad + l).join('\n');
}

function generateDeclarative(cfg) {
  const { appName, agentType, dockerImage, nodeLabel, projectType,
          stages, trigger, postAlways, postSuccess, postFailure, email } = cfg;

  const lines = [];
  lines.push('pipeline {');

  // agent
  if (agentType === 'any') {
    lines.push('    agent any');
  } else if (agentType === 'docker') {
    lines.push('    agent {');
    lines.push('        docker {');
    lines.push(`            image '${dockerImage || 'node:20-alpine'}'`);
    lines.push("            args '-u root'");
    lines.push('        }');
    lines.push('    }');
  } else {
    lines.push('    agent {');
    lines.push(`        node { label '${nodeLabel || 'linux-builder'}' }`);
    lines.push('    }');
  }
  lines.push('');

  // triggers
  if (trigger !== 'none') {
    lines.push('    triggers {');
    if (trigger === 'pollSCM') lines.push("        pollSCM('H/15 * * * *')");
    if (trigger === 'cron')    lines.push("        cron('0 2 * * *')");
    if (trigger === 'webhook') lines.push("        GenericTrigger(causeString: 'Triggered by webhook', token: 'MY_WEBHOOK_TOKEN')");
    lines.push('    }');
    lines.push('');
  }

  // environment
  lines.push('    environment {');
  lines.push(`        APP_NAME = '${appName || 'my-app'}'`);
  if (projectType === 'docker') {
    lines.push('        DOCKER_IMAGE = "${env.APP_NAME}:${env.BUILD_NUMBER}"');
  }
  lines.push('    }');
  lines.push('');

  // stages
  lines.push('    stages {');

  if (stages.checkout) {
    lines.push("        stage('Checkout') {");
    lines.push('            steps {');
    lines.push('                checkout scm');
    lines.push('            }');
    lines.push('        }');
  }
  if (stages.build) {
    lines.push("        stage('Build') {");
    lines.push('            steps {');
    cmds(projectType, 'build').forEach(c => lines.push('                ' + c));
    lines.push('            }');
    lines.push('        }');
  }
  if (stages.lint) {
    lines.push("        stage('Lint') {");
    lines.push('            steps {');
    cmds(projectType, 'lint').forEach(c => lines.push('                ' + c));
    lines.push('            }');
    lines.push('        }');
  }
  if (stages.test) {
    lines.push("        stage('Test') {");
    lines.push('            steps {');
    cmds(projectType, 'test').forEach(c => lines.push('                ' + c));
    lines.push('            }');
    lines.push('            post {');
    lines.push('                always {');
    lines.push('                    ' + junitReport(projectType));
    lines.push('                }');
    lines.push('            }');
    lines.push('        }');
  }
  if (stages.package) {
    lines.push("        stage('Package') {");
    lines.push('            steps {');
    cmds(projectType, 'package').forEach(c => lines.push('                ' + c));
    lines.push('            }');
    lines.push('        }');
  }
  if (stages.deploy) {
    lines.push("        stage('Deploy') {");
    lines.push('            when {');
    lines.push("                branch 'main'");
    lines.push('            }');
    lines.push('            steps {');
    cmds(projectType, 'deploy').forEach(c => lines.push('                ' + c));
    lines.push('            }');
    lines.push('        }');
  }

  lines.push('    }');
  lines.push('');

  // post
  const hasPost = postAlways || postSuccess || postFailure;
  if (hasPost) {
    lines.push('    post {');
    if (postAlways) {
      lines.push('        always {');
      lines.push("            cleanWs()");
      lines.push('        }');
    }
    if (postSuccess) {
      lines.push('        success {');
      lines.push("            echo 'Pipeline succeeded!'");
      lines.push('        }');
    }
    if (postFailure) {
      const to = email || 'team@example.com';
      lines.push('        failure {');
      lines.push(`            mail to: '${to}',`);
      lines.push("                 subject: \"Build Failed: ${env.JOB_NAME} #${env.BUILD_NUMBER}\",");
      lines.push("                 body: \"Build ${env.BUILD_NUMBER} failed. Check ${env.BUILD_URL}\"");
      lines.push('        }');
    }
    lines.push('    }');
  }

  lines.push('}');
  return lines.join('\n');
}

function generateScripted(cfg) {
  const { appName, agentType, dockerImage, nodeLabel, projectType,
          stages, trigger, postAlways, postSuccess, postFailure, email } = cfg;

  const agentLabel = agentType === 'node' ? (nodeLabel || 'linux-builder') : 'any';
  const dockerImg  = dockerImage || 'node:20-alpine';

  const lines = [];

  if (trigger === 'pollSCM') {
    lines.push('properties([');
    lines.push("    pipelineTriggers([pollSCM('H/15 * * * *')])");
    lines.push('])');
    lines.push('');
  } else if (trigger === 'cron') {
    lines.push('properties([');
    lines.push("    pipelineTriggers([cron('0 2 * * *')])");
    lines.push('])');
    lines.push('');
  }

  if (agentType === 'docker') {
    lines.push(`node('any') {`);
    lines.push(`    docker.image('${dockerImg}').inside('-u root') {`);
    lines.push(`        def APP_NAME = '${appName || 'my-app'}'`);
    lines.push('');
  } else {
    lines.push(`node('${agentLabel}') {`);
    lines.push(`    def APP_NAME = '${appName || 'my-app'}'`);
    if (projectType === 'docker') {
      lines.push('    def DOCKER_IMAGE = "${APP_NAME}:${BUILD_NUMBER}"');
    }
    lines.push('');
  }

  const baseIndent = agentType === 'docker' ? 8 : 4;
  const pad = ' '.repeat(baseIndent);

  const addStage = (name, cmdsArr) => {
    lines.push(`${pad}stage('${name}') {`);
    cmdsArr.forEach(c => lines.push(`${pad}    ${c}`));
    lines.push(`${pad}}`);
  };

  lines.push(`${pad}try {`);

  if (stages.checkout) {
    lines.push(`${pad}    stage('Checkout') {`);
    lines.push(`${pad}        checkout scm`);
    lines.push(`${pad}    }`);
  }
  if (stages.build) {
    lines.push(`${pad}    stage('Build') {`);
    cmds(projectType, 'build').forEach(c => lines.push(`${pad}        ${c}`));
    lines.push(`${pad}    }`);
  }
  if (stages.lint) {
    lines.push(`${pad}    stage('Lint') {`);
    cmds(projectType, 'lint').forEach(c => lines.push(`${pad}        ${c}`));
    lines.push(`${pad}    }`);
  }
  if (stages.test) {
    lines.push(`${pad}    stage('Test') {`);
    cmds(projectType, 'test').forEach(c => lines.push(`${pad}        ${c}`));
    lines.push(`${pad}        junit '${junitReport(projectType).replace("junit '", "").replace("'", "")}'`);
    lines.push(`${pad}    }`);
  }
  if (stages.package) {
    lines.push(`${pad}    stage('Package') {`);
    cmds(projectType, 'package').forEach(c => lines.push(`${pad}        ${c}`));
    lines.push(`${pad}    }`);
  }
  if (stages.deploy) {
    lines.push(`${pad}    stage('Deploy') {`);
    lines.push(`${pad}        if (env.BRANCH_NAME == 'main') {`);
    cmds(projectType, 'deploy').forEach(c => lines.push(`${pad}            ${c}`));
    lines.push(`${pad}        }`);
    lines.push(`${pad}    }`);
  }

  if (postSuccess) {
    lines.push(`${pad}    echo 'Pipeline succeeded!'`);
  }
  lines.push(`${pad}} catch (err) {`);
  if (postFailure) {
    const to = email || 'team@example.com';
    lines.push(`${pad}    mail to: '${to}',`);
    lines.push(`${pad}         subject: "Build Failed: \${env.JOB_NAME} #\${env.BUILD_NUMBER}",`);
    lines.push(`${pad}         body: "Build \${env.BUILD_NUMBER} failed. Check \${env.BUILD_URL}"`);
  }
  lines.push(`${pad}    throw err`);
  lines.push(`${pad}} finally {`);
  if (postAlways) {
    lines.push(`${pad}    cleanWs()`);
  } else {
    lines.push(`${pad}    // cleanup`);
  }
  lines.push(`${pad}}`);

  if (agentType === 'docker') {
    lines.push('    }'); // docker.image.inside
  }
  lines.push('}'); // node

  return lines.join('\n');
}

function getConfig() {
  return {
    appName: v('app-name'),
    agentType: radio('agent-type'),
    dockerImage: v('docker-image'),
    nodeLabel: v('node-label'),
    projectType: v('project-type'),
    stages: {
      checkout: v('stage-checkout'),
      build:    v('stage-build'),
      test:     v('stage-test'),
      lint:     v('stage-lint'),
      package:  v('stage-package'),
      deploy:   v('stage-deploy'),
    },
    trigger: v('trigger-type'),
    postAlways:  v('post-always'),
    postSuccess: v('post-success'),
    postFailure: v('post-failure'),
    email: v('email-addr'),
  };
}

function generate() {
  const cfg = getConfig();
  const pipelineType = v('pipeline-type');
  const code = pipelineType === 'scripted' ? generateScripted(cfg) : generateDeclarative(cfg);
  document.getElementById('output-code').textContent = code;
  document.getElementById('output-section').classList.remove('hidden');
  setTimeout(() => document.getElementById('output-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
}

function loadExample(preset) {
  const presets = {
    nodejs: {
      type: 'declarative', project: 'nodejs', agent: 'any',
      appName: 'my-node-app', trigger: 'pollSCM',
      stages: [true, true, true, true, false, true],
      post: [true, true, true], email: 'team@example.com',
    },
    maven: {
      type: 'declarative', project: 'maven', agent: 'node',
      nodeLabel: 'java-builder', appName: 'my-java-app', trigger: 'cron',
      stages: [true, true, true, true, true, true],
      post: [true, true, true], email: 'devops@example.com',
    },
    docker: {
      type: 'declarative', project: 'docker', agent: 'docker',
      dockerImage: 'node:20-alpine', appName: 'my-docker-app', trigger: 'webhook',
      stages: [true, true, true, false, true, true],
      post: [true, true, true], email: 'ops@example.com',
    },
  };

  const p = presets[preset];
  if (!p) return;

  document.getElementById('pipeline-type').value = p.type;
  document.getElementById('project-type').value = p.project;
  document.querySelector(`input[name="agent-type"][value="${p.agent}"]`).checked = true;
  document.getElementById('docker-image-wrap').classList.toggle('hidden', p.agent !== 'docker');
  document.getElementById('node-label-wrap').classList.toggle('hidden', p.agent !== 'node');
  if (p.dockerImage) document.getElementById('docker-image').value = p.dockerImage;
  if (p.nodeLabel)   document.getElementById('node-label').value = p.nodeLabel;
  document.getElementById('app-name').value = p.appName;
  document.getElementById('trigger-type').value = p.trigger;

  const stageIds = ['stage-checkout', 'stage-build', 'stage-test', 'stage-lint', 'stage-package', 'stage-deploy'];
  stageIds.forEach((id, i) => { document.getElementById(id).checked = p.stages[i]; });

  document.getElementById('post-always').checked  = p.post[0];
  document.getElementById('post-success').checked = p.post[1];
  document.getElementById('post-failure').checked = p.post[2];
  document.getElementById('email-addr').value = p.email;

  generate();
}

document.getElementById('btn-generate')?.addEventListener('click', generate);
document.getElementById('btn-example-nodejs')?.addEventListener('click', () => loadExample('nodejs'));
document.getElementById('btn-example-maven')?.addEventListener('click', () => loadExample('maven'));
document.getElementById('btn-example-docker')?.addEventListener('click', () => loadExample('docker'));

document.getElementById('copy-btn')?.addEventListener('click', function () {
  const code = document.getElementById('output-code').textContent;
  navigator.clipboard.writeText(code).then(() => {
    this.textContent = 'Copied!';
    setTimeout(() => { this.textContent = 'Copy'; }, 2000);
  });
});

// Auto-generate on load
generate();
</script>
