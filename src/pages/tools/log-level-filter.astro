---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LogLevelFilter from '../../components/LogLevelFilter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Log Level Filter — Parse and Filter Log Output Online"
  description="Paste any log output and filter by level: DEBUG, INFO, WARN, ERROR, FATAL. Color-coded highlights per level with search/grep within logs. Supports Log4j, Winston, Pino, Python logging, and plain text. Free, no install needed."
  tool="Log Level Filter, Parse Log Output Online, Log Grep Tool, Log Viewer"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Log Level Filter",
    "url": "https://devplaybook.cc/tools/log-level-filter",
    "description": "Filter log output by level (DEBUG, INFO, WARN, ERROR, FATAL) with color highlights and search. Free online log viewer.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Log Level Filter</h1>
  <p class="text-text-muted mb-8">
    Paste any log output and instantly filter by level —
    <span class="text-blue-400 font-mono text-sm">DEBUG</span>,
    <span class="text-green-400 font-mono text-sm">INFO</span>,
    <span class="text-yellow-400 font-mono text-sm">WARN</span>,
    <span class="text-red-400 font-mono text-sm">ERROR</span>,
    <span class="text-red-500 font-mono text-sm">FATAL</span>.
    Levels are auto-detected from log content. Search and grep within filtered results.
    Works with Log4j, Winston, Pino, Python <code class="font-mono bg-surface px-1 rounded">logging</code>, and most plain-text formats.
  </p>
  <LogLevelFilter client:load />
  <ToolPageCta currentTool="Log Level Filter" relatedTags={['logging', 'debugging', 'devops', 'monitoring', 'developer-tools']} />
</BaseLayout>
