---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tools = [
  { name: 'HTML Formatter & Minifier', desc: 'Format messy HTML with proper indentation or minify to reduce file size. Handles nested tags, void elements, and pre/script blocks.', href: '/tools/html-formatter', icon: '🌐' },
  { name: 'CSS Formatter & Minifier', desc: 'Beautify CSS with consistent indentation or minify to strip whitespace. Supports @media, @keyframes, and nested rules.', href: '/tools/css-formatter', icon: '🎨' },
  { name: 'JavaScript Formatter & Minifier', desc: 'Format JS for readability or minify for smaller bundles. Preserves strings and template literals. Works with JS, TS, and JSX.', href: '/tools/js-formatter', icon: '💛' },
  { name: 'SQL Formatter & Beautifier', desc: 'Format and indent SQL queries automatically. Uppercase keywords, align clauses, or minify SQL to one line.', href: '/tools/sql-formatter', icon: '🗄️' },
  { name: 'TypeScript to JavaScript', desc: 'Strip TypeScript type annotations, interfaces, generics, enums, and decorators to get clean JavaScript. Runs in your browser.', href: '/tools/typescript-to-js', icon: '🔷' },
  { name: 'JSON Formatter & Validator', desc: 'Format, beautify, and validate JSON instantly. Choose indent size, minify, or copy the result. Syntax errors highlighted live.', href: '/tools/json-formatter', icon: '📋' },
  { name: 'JSON to TypeScript Interface', desc: 'Paste JSON and get TypeScript interfaces instantly. Handles nested objects, arrays, and optional fields.', href: '/tools/json-to-typescript', icon: '🔷' },
  { name: 'Regex Playground', desc: 'Write, test, and debug regular expressions in real-time with match highlighting and flags support.', href: '/tools/regex-playground', icon: '🔍' },
  { name: 'Git Command Builder', desc: 'Build complex Git commands step by step with all common options. Visual builder for git checkout, commit, merge, and more.', href: '/tools/git-command-builder', icon: '🌿' },
  { name: 'Docker Compose Generator', desc: 'Generate docker-compose.yml configurations visually with service templates for common stacks.', href: '/tools/docker-compose-generator', icon: '🐳' },
];
---

<BaseLayout
  title="Free Code Tools for Developers — devplaybook.cc"
  description="10 free code tools: HTML/CSS/JS formatter and minifier, SQL formatter, TypeScript to JavaScript converter, JSON formatter, regex playground, and Git helpers. No signup."
  tool="Code Tools, HTML Formatter, CSS Formatter, JavaScript Formatter, SQL Formatter, TypeScript Converter"
>
  <div class="mb-8">
    <nav class="text-sm text-text-muted mb-4">
      <a href="/tools" class="hover:text-primary transition-colors">All Tools</a>
      <span class="mx-2">→</span>
      <span class="text-text">Code Tools</span>
    </nav>
    <h1 class="text-4xl font-bold mb-3">Code <span class="text-primary">Tools</span></h1>
    <p class="text-text-muted text-lg max-w-2xl">Free code formatting and conversion tools for developers. Format HTML, CSS, JavaScript, SQL. Convert TypeScript to JavaScript. All client-side, no data sent to servers.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mb-12">
    {tools.map(tool => (
      <a href={tool.href} class="block bg-bg-card rounded-xl p-6 border border-border hover:border-primary transition-colors group">
        <div class="text-3xl mb-3">{tool.icon}</div>
        <h2 class="text-lg font-semibold mb-2 group-hover:text-primary transition-colors">{tool.name}</h2>
        <p class="text-text-muted text-sm">{tool.desc}</p>
      </a>
    ))}
  </div>

  <div class="flex flex-wrap gap-3 justify-center">
    <a href="/tools/text" class="bg-bg-card border border-border hover:border-primary px-4 py-2 rounded-lg text-sm transition-colors">📝 Text Tools</a>
    <a href="/tools/utilities" class="bg-bg-card border border-border hover:border-primary px-4 py-2 rounded-lg text-sm transition-colors">⚙️ Developer Utilities</a>
    <a href="/tools" class="bg-bg-card border border-border hover:border-primary px-4 py-2 rounded-lg text-sm transition-colors">🛠️ All Tools</a>
  </div>
</BaseLayout>
