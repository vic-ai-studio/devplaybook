---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is a Web Push notification payload?",
    answer: "A Web Push payload is a JSON object sent from your server to a push service (Google FCM, Apple APNs, Mozilla) which delivers it to the user's browser. The payload defines title, body, icon, badge, actions, and data. It follows the Web Push Protocol (RFC 8030) and is encrypted with VAPID authentication."
  },
  {
    question: "What is VAPID?",
    answer: "VAPID (Voluntary Application Server Identification) is a protocol that lets push services identify your server. You generate a VAPID key pair — the public key is shared with the browser during subscription, and the private key signs your push requests. This prevents other servers from sending push messages to your subscribers."
  },
  {
    question: "What are notification actions?",
    answer: "Actions are buttons shown below the notification body. Each action has an action ID, a title label, and optionally an icon. When a user clicks an action, the service worker receives a notificationclick event with the action ID. Actions only show in browsers that support them (Chrome on Android, desktop Chrome/Edge). Limited to 2-3 actions on most platforms."
  },
  {
    question: "What is the difference between icon, badge, and image?",
    answer: "icon: the small app icon shown next to the notification title (48x48 or larger). badge: a tiny monochrome icon shown in the notification bar on Android to represent your app (96x96 monochrome PNG). image: a large image displayed inside the notification body (landscape ratio, ~360x180px). All three should be absolute HTTPS URLs."
  },
  {
    question: "What is the TTL (time to live) field?",
    answer: "TTL specifies how long (in seconds) the push service should store and retry delivery if the device is offline. TTL: 0 means deliver immediately or drop. TTL: 3600 means retry for up to 1 hour. Max TTL varies by push service — FCM allows up to 2419200 (28 days). Set TTL based on how time-sensitive your notification is."
  }
];
---

<BaseLayout
  title="Push Notification Payload Builder — Web Push JSON Generator"
  description="Build Web Push notification payloads visually. Configure title, body, icon, actions, badge, and TTL. Generate copy-ready JSON for your push notification server. Free tool."
  tool="push notification payload builder, web push payload, FCM notification JSON, push notification builder, notification payload generator, VAPID push"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Push Notification Payload Builder",
    "url": "https://devplaybook.cc/tools/push-notification-payload-builder",
    "description": "Build Web Push notification payloads visually. Configure title, body, icon, actions, and TTL. Generate JSON for your push server.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Push Notification Payload Builder</h1>
  <p class="text-text-muted mb-4">Build Web Push notification payloads visually. Configure all fields and get copy-ready JSON for your notification server.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All notification fields</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live JSON preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> FCM + Web Push format</span>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
    <!-- Left: form -->
    <div class="space-y-3">
      <div class="bg-bg-card border border-border rounded-lg p-4 space-y-3">
        <h2 class="text-sm font-semibold">Basic Info</h2>
        <div>
          <label class="block text-xs text-text-muted mb-1">Title <span class="text-red-400">*</span></label>
          <input id="f-title" type="text" placeholder="New message from Alex" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">Body</label>
          <textarea id="f-body" rows="3" placeholder="Hey! Check out this new feature..." class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm resize-none focus:outline-none focus:border-primary"></textarea>
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">Click URL (data.url)</label>
          <input id="f-url" type="text" placeholder="https://yourapp.com/messages/123" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>
      </div>

      <div class="bg-bg-card border border-border rounded-lg p-4 space-y-3">
        <h2 class="text-sm font-semibold">Media</h2>
        <div>
          <label class="block text-xs text-text-muted mb-1">Icon URL</label>
          <input id="f-icon" type="text" placeholder="https://yourapp.com/icon-192x192.png" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">Badge URL (96x96 monochrome)</label>
          <input id="f-badge" type="text" placeholder="https://yourapp.com/badge.png" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">Image URL (large banner)</label>
          <input id="f-image" type="text" placeholder="https://yourapp.com/promo-banner.jpg" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>
      </div>

      <div class="bg-bg-card border border-border rounded-lg p-4 space-y-3">
        <h2 class="text-sm font-semibold">Options</h2>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs text-text-muted mb-1">Tag (dedup key)</label>
            <input id="f-tag" type="text" placeholder="msg-thread-123" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="block text-xs text-text-muted mb-1">TTL (seconds)</label>
            <input id="f-ttl" type="number" value="3600" min="0" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs text-text-muted mb-1">Priority</label>
            <select id="f-urgency" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
              <option value="high">high</option>
              <option value="normal" selected>normal</option>
              <option value="low">low</option>
              <option value="very-low">very-low</option>
            </select>
          </div>
          <div class="flex items-end pb-1">
            <label class="flex items-center gap-2 text-sm cursor-pointer">
              <input id="f-renotify" type="checkbox" class="rounded" />
              <span class="text-xs">renotify on update</span>
            </label>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <label class="flex items-center gap-2 text-sm cursor-pointer">
            <input id="f-silent" type="checkbox" class="rounded" />
            <span class="text-xs">silent (no sound/vibration)</span>
          </label>
        </div>
      </div>

      <div class="bg-bg-card border border-border rounded-lg p-4">
        <div class="flex items-center justify-between mb-2">
          <h2 class="text-sm font-semibold">Actions (buttons)</h2>
          <button id="btn-add-action" class="text-xs text-primary hover:underline">+ Add action</button>
        </div>
        <div id="actions-list" class="space-y-2"></div>
      </div>
    </div>

    <!-- Right: preview -->
    <div>
      <!-- Visual preview -->
      <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
        <h2 class="text-sm font-semibold mb-3">Visual Preview</h2>
        <div class="bg-gray-800 rounded-xl p-3 max-w-xs mx-auto">
          <div id="preview-image" class="hidden mb-2 rounded-lg overflow-hidden h-24 bg-surface"></div>
          <div class="flex gap-2 items-start">
            <div id="preview-icon" class="w-8 h-8 rounded bg-primary flex-shrink-0 flex items-center justify-center text-white text-xs font-bold">App</div>
            <div class="flex-1 min-w-0">
              <div id="preview-title" class="text-white text-xs font-semibold truncate">Notification Title</div>
              <div id="preview-body" class="text-gray-300 text-xs mt-0.5 line-clamp-2">Notification body text here.</div>
            </div>
          </div>
          <div id="preview-actions" class="flex gap-2 mt-2"></div>
        </div>
      </div>

      <!-- JSON output -->
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <div class="flex items-center justify-between mb-2">
          <div class="flex gap-2">
            <button data-fmt="web" class="fmt-btn px-3 py-1 rounded text-xs font-medium bg-primary text-white">Web Push</button>
            <button data-fmt="fcm" class="fmt-btn px-3 py-1 rounded text-xs font-medium bg-surface border border-border hover:bg-bg-card transition-colors">FCM</button>
          </div>
          <button id="btn-copy-json" class="px-3 py-1.5 bg-primary text-white rounded-lg text-xs font-medium hover:bg-primary/90 transition-colors">Copy JSON</button>
        </div>
        <pre id="output-json" class="bg-surface rounded-lg p-3 text-xs font-mono overflow-auto max-h-80 whitespace-pre text-text-muted"></pre>
        <p id="msg-json" class="text-xs text-green-400 mt-1 hidden">Copied!</p>
      </div>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Push Notification Payload Builder" relatedTags={['pwa', 'mobile', 'web', 'json', 'notifications']} />
</BaseLayout>

<script is:inline>
(function() {
  var actions = [];
  var fmt = 'web';

  function g(id) { return document.getElementById(id); }
  function val(id) { return g(id).value.trim(); }

  function buildPayload() {
    var notification = {};
    if (val('f-title')) notification.title = val('f-title');
    if (val('f-body')) notification.body = val('f-body');
    if (val('f-icon')) notification.icon = val('f-icon');
    if (val('f-badge')) notification.badge = val('f-badge');
    if (val('f-image')) notification.image = val('f-image');
    if (val('f-tag')) notification.tag = val('f-tag');
    if (g('f-renotify').checked) notification.renotify = true;
    if (g('f-silent').checked) notification.silent = true;
    if (actions.length > 0) {
      notification.actions = actions.filter(function(a) { return a.title; }).map(function(a) {
        var obj = { action: a.action || a.title.toLowerCase().replace(/\s+/g, '_'), title: a.title };
        if (a.icon) obj.icon = a.icon;
        return obj;
      });
    }
    if (val('f-url')) notification.data = { url: val('f-url') };
    return notification;
  }

  function render() {
    var notification = buildPayload();

    // Preview
    g('preview-title').textContent = notification.title || 'Notification Title';
    g('preview-body').textContent = notification.body || '';
    if (notification.actions && notification.actions.length > 0) {
      g('preview-actions').innerHTML = notification.actions.slice(0, 2).map(function(a) {
        return '<button class="px-2 py-0.5 bg-gray-700 text-gray-200 rounded text-xs">' + a.title + '</button>';
      }).join('');
    } else {
      g('preview-actions').innerHTML = '';
    }

    // JSON output
    var output;
    if (fmt === 'fcm') {
      output = {
        notification: {
          title: notification.title || '',
          body: notification.body || '',
          icon: notification.icon || undefined,
          image: notification.image || undefined,
          click_action: (notification.data && notification.data.url) ? notification.data.url : undefined
        },
        data: notification.data || undefined,
        webpush: {
          headers: { Urgency: val('f-urgency'), TTL: val('f-ttl') },
          notification: notification
        }
      };
      // clean undefineds
      output = JSON.parse(JSON.stringify(output));
    } else {
      output = {
        notification: notification,
        options: {
          urgency: val('f-urgency'),
          ttl: parseInt(val('f-ttl')) || 3600
        }
      };
    }

    g('output-json').textContent = JSON.stringify(output, null, 2);
  }

  function renderActions() {
    g('actions-list').innerHTML = actions.map(function(a, i) {
      return '<div class="grid grid-cols-2 gap-2 p-2 bg-surface rounded-lg" data-idx="' + i + '">' +
        '<input type="text" placeholder="Action title" value="' + (a.title || '') + '" data-field="title" class="bg-bg-card border border-border rounded px-2 py-1 text-xs font-mono focus:outline-none" />' +
        '<input type="text" placeholder="Icon URL (optional)" value="' + (a.icon || '') + '" data-field="icon" class="bg-bg-card border border-border rounded px-2 py-1 text-xs font-mono focus:outline-none" />' +
        '<button data-remove="' + i + '" class="col-span-2 text-xs text-red-400 hover:text-red-300 text-left">Remove</button>' +
        '</div>';
    }).join('');

    g('actions-list').querySelectorAll('input').forEach(function(inp) {
      inp.addEventListener('input', function() {
        var idx = parseInt(inp.closest('[data-idx]').dataset.idx);
        actions[idx][inp.dataset.field] = inp.value;
        render();
      });
    });

    g('actions-list').querySelectorAll('[data-remove]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        actions.splice(parseInt(btn.dataset.remove), 1);
        renderActions();
        render();
      });
    });
  }

  g('btn-add-action').addEventListener('click', function() {
    if (actions.length >= 3) return;
    actions.push({ title: '', icon: '' });
    renderActions();
  });

  ['f-title','f-body','f-url','f-icon','f-badge','f-image','f-tag','f-ttl'].forEach(function(id) {
    g(id).addEventListener('input', render);
  });
  ['f-urgency','f-renotify','f-silent'].forEach(function(id) {
    g(id).addEventListener('change', render);
  });

  document.querySelectorAll('.fmt-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      fmt = btn.dataset.fmt;
      document.querySelectorAll('.fmt-btn').forEach(function(b) {
        b.classList.remove('bg-primary', 'text-white');
        b.classList.add('bg-surface', 'border', 'border-border');
      });
      btn.classList.add('bg-primary', 'text-white');
      btn.classList.remove('bg-surface', 'border', 'border-border');
      render();
    });
  });

  g('btn-copy-json').addEventListener('click', function() {
    navigator.clipboard.writeText(g('output-json').textContent).then(function() {
      g('msg-json').classList.remove('hidden');
      setTimeout(function() { g('msg-json').classList.add('hidden'); }, 2000);
    });
  });

  render();
})();
</script>
