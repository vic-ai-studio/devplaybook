---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const initExample = `// Sentry SDK initialization (Next.js / React)
import * as Sentry from '@sentry/nextjs';

Sentry.init({
  dsn: 'https://<key>@o<org>.ingest.sentry.io/<project>',
  environment: process.env.NODE_ENV,
  release: process.env.NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA,
  tracesSampleRate: 1.0,      // 100% in dev; use 0.1–0.2 in prod
  profilesSampleRate: 1.0,    // Profiling (requires tracing enabled)
  replaysSessionSampleRate: 0.1,
  replaysOnErrorSampleRate: 1.0, // Always capture replays on error
  integrations: [
    Sentry.replayIntegration(),
    Sentry.browserTracingIntegration(),
  ],
});`;

const captureExample = `// Manual error capture with context
try {
  await processOrder(orderId);
} catch (err) {
  Sentry.withScope((scope) => {
    scope.setTag('flow', 'checkout');
    scope.setUser({ id: user.id, email: user.email });
    scope.setExtra('orderId', orderId);
    scope.setLevel('error');
    Sentry.captureException(err);
  });
  throw err;
}

// Breadcrumbs for context trail
Sentry.addBreadcrumb({
  category: 'ui.click',
  message: 'User clicked checkout',
  level: 'info',
});

// Performance transaction
const transaction = Sentry.startTransaction({ name: 'process-payment' });
const span = transaction.startChild({ op: 'stripe.charge' });
await stripe.charges.create(chargeData);
span.finish();
transaction.finish();`;

const faq = [
  { question: "What is Sentry?", answer: "Sentry is an open-source application monitoring platform that automatically captures errors, crashes, performance bottlenecks, and user context from your applications. It aggregates exceptions across your entire stack — frontend, backend, mobile — correlates them with releases and users, and provides the full stack trace, breadcrumbs, and environment context needed to reproduce and fix bugs." },
  { question: "What is a DSN?", answer: "A DSN (Data Source Name) is a URL that tells the Sentry SDK where to send events. It encodes your organization, project, and authentication key in a single string. Each Sentry project has a unique DSN. Never expose your DSN on a public repo — although DSNs are technically rate-limited per-project, leaking them allows others to fill your quota with junk events." },
  { question: "What is the difference between errors and transactions in Sentry?", answer: "Errors (exceptions) are captured automatically when your code throws — Sentry records the stack trace, breadcrumbs, and environment. Transactions (performance monitoring) are spans of work — a full HTTP request, a database query, a background job. Transactions show you where time is spent, enabling you to find slow endpoints or N+1 database queries. Both are reported through the same SDK but have separate quotas and sampling rates." },
  { question: "How should I set tracesSampleRate in production?", answer: "Start at 0.1–0.2 (10–20% of transactions). At high traffic, 100% sampling is expensive and unnecessary — you only need a statistical sample. For errors, keep errorsSampleRate at 1.0 (capture all errors). Use tracesSampler for dynamic sampling: sample 100% of transactions that include an error, and a lower rate for healthy transactions." },
  { question: "What is Session Replay?", answer: "Session Replay records user interactions as video-like reconstructions (DOM mutations, not actual video) at the time an error occurs. When reviewing an error in Sentry, you can watch exactly what the user did before the crash — every click, scroll, and input. This dramatically reduces the time needed to reproduce frontend bugs. replaysOnErrorSampleRate: 1.0 ensures every error has a replay attached." },
  { question: "Can Sentry be self-hosted?", answer: "Yes. Sentry's source code is on GitHub (getsentry/sentry) and can be deployed via Docker Compose using the official self-hosted repo. Self-hosting gives you full data control, unlimited events, and avoids the SaaS pricing. However, it requires infrastructure management, regular updates, and storage provisioning. Most teams under 10 engineers find the hosted plan simpler to operate." },
];
---

<BaseLayout
  title="Sentry — Error Monitoring and Performance Observability"
  description="Sentry automatically captures exceptions, performance bottlenecks, and user context across your stack. Full stack traces, breadcrumbs, session replay, and release tracking in one platform."
  tool="Sentry, Sentry error monitoring, Sentry SDK, Sentry DSN, Sentry performance, session replay, Sentry tracing, Sentry Next.js, application monitoring"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Sentry — Error Monitoring and Performance Observability",
    "url": "https://devplaybook.cc/tools/sentry",
    "description": "Sentry automatically captures exceptions, performance bottlenecks, and user context across your stack. Full stack traces, breadcrumbs, session replay, and release tracking in one platform.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Sentry</h1>
  <p class="text-text-muted mb-6">
    Application monitoring that automatically captures <strong>errors, performance issues, and user context</strong> from every layer of your stack.
    Sentry gives you full stack traces, breadcrumbs, session replay, and release-level regression tracking — so you spend less time reproducing bugs and more time fixing them.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Automatic exception capture</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Distributed tracing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Session replay on error</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Release tracking</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Sentry?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Sentry is an open-source error monitoring and performance observability platform. Its SDK runs inside your application and automatically intercepts unhandled exceptions, Promise rejections, and crashed processes — capturing the full stack trace, request context, user info, and a trail of breadcrumbs showing what the user did before the error occurred.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    Beyond errors, Sentry's performance module wraps your HTTP handlers, database queries, and async operations as <em>spans</em>, assembling them into distributed traces. You can find which endpoint is slow, which database query runs 500 times per request, and how a deployment correlated with a latency spike.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Error grouping</strong> — intelligent deduplication groups related stack traces, preventing notification floods</li>
    <li><strong>Breadcrumbs</strong> — automatic trail of console logs, network requests, and navigation events leading up to the error</li>
    <li><strong>Session Replay</strong> — DOM-mutation replay of user interactions at the moment an error occurred</li>
    <li><strong>Performance tracing</strong> — distributed traces across frontend, API, and database layers</li>
    <li><strong>Release tracking</strong> — tag errors with deployment releases; see exactly which release introduced a regression</li>
    <li><strong>Source maps</strong> — automatically unminifies JavaScript stack traces for readable line-level context</li>
    <li><strong>Alerts</strong> — configurable alert rules (error rate, new issue, regression) routing to Slack, PagerDuty, or email</li>
    <li><strong>100+ integrations</strong> — GitHub, GitLab, Jira, Slack, PagerDuty, AWS, Vercel, and more</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">SDK Initialization</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={initExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Manual Capture &amp; Context</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={captureExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">SDK Installation (Common Platforms)</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Next.js
npx @sentry/wizard@latest -i nextjs

# Node.js / Express
npm install @sentry/node @sentry/profiling-node

# React
npm install @sentry/react

# Python (Django / FastAPI)
pip install sentry-sdk[fastapi]

# Go
go get github.com/getsentry/sentry-go</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Sampling Strategy</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 font-semibold">Setting</th>
          <th class="text-left py-2 pr-4 font-semibold">Recommended</th>
          <th class="text-left py-2 font-semibold">Notes</th>
        </tr>
      </thead>
      <tbody class="text-text-muted">
        <tr class="border-b border-border/50"><td class="py-2 pr-4 font-mono text-xs">tracesSampleRate</td><td class="py-2 pr-4">0.1 – 0.2 in prod</td><td class="py-2">10–20% of requests; use dynamic sampler for precision</td></tr>
        <tr class="border-b border-border/50"><td class="py-2 pr-4 font-mono text-xs">replaysSessionSampleRate</td><td class="py-2 pr-4">0.05 – 0.1</td><td class="py-2">5–10% of sessions for baseline</td></tr>
        <tr class="border-b border-border/50"><td class="py-2 pr-4 font-mono text-xs">replaysOnErrorSampleRate</td><td class="py-2 pr-4">1.0</td><td class="py-2">Always capture replays on error</td></tr>
        <tr><td class="py-2 pr-4 font-mono text-xs">profilesSampleRate</td><td class="py-2 pr-4">0.1 in prod</td><td class="py-2">CPU profiling; subset of traced transactions</td></tr>
      </tbody>
    </table>
  </div>

  <ToolPageCta />
  <FaqSection faqs={faq} />
</BaseLayout>
