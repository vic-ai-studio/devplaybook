---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Security Headers Checker — Audit HTTP Security Headers Instantly"
  description="Check which HTTP security headers are present or missing in your server response. Enter a URL or paste raw response headers to audit: HSTS, CSP, X-Frame-Options, X-Content-Type-Options, Referrer-Policy, Permissions-Policy. Runs in your browser."
  tool="security headers checker, HSTS checker, CSP validator, X-Frame-Options, X-Content-Type-Options, Referrer-Policy, Permissions-Policy, HTTP security audit, OWASP headers"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Security Headers Checker",
    "url": "https://devplaybook.cc/tools/security-headers-checker",
    "description": "Check which HTTP security headers are present or missing in your server response. Paste raw response headers to audit HSTS, CSP, X-Frame-Options, and more. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Security Headers Checker</h1>
  <p class="text-text-muted mb-4">Paste raw HTTP response headers or add key:value pairs manually to audit your server's security header configuration. Get instant pass/warn/fail results with explanations.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 9 critical security headers checked</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Color-coded pass / warn / fail</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Actionable recommendations</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs entirely in your browser</span>
  </div>

  <!-- Tab navigation -->
  <div class="flex gap-1 mb-6 border-b border-border">
    <button data-tab="paste" class="sec-tab px-4 py-2.5 text-sm font-medium border-b-2 border-primary text-primary transition-colors">Paste Headers</button>
    <button data-tab="manual" class="sec-tab px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-foreground transition-colors">Manual Entry</button>
  </div>

  <!-- Paste Panel -->
  <div id="panel-paste" class="sec-panel">
    <div class="mb-3">
      <label class="block text-sm font-medium mb-2">Paste Raw HTTP Response Headers</label>
      <p class="text-xs text-text-muted mb-2">From curl: <code class="font-mono bg-bg-card border border-border px-1.5 rounded">curl -sI https://your-site.com</code> · From browser DevTools: Network tab → Response Headers → copy all</p>
      <textarea id="headers-paste" class="w-full bg-bg-card border border-border rounded-lg p-3 text-sm font-mono focus:outline-none focus:border-primary resize-none" rows="10" placeholder="HTTP/2 200&#10;content-type: text/html; charset=utf-8&#10;strict-transport-security: max-age=31536000; includeSubDomains&#10;x-content-type-options: nosniff&#10;..."></textarea>
    </div>
    <div class="flex gap-3 mb-6 flex-wrap">
      <button id="btn-check-paste" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Check Headers</button>
      <button id="btn-paste-example-good" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Load Good Example</button>
      <button id="btn-paste-example-bad" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Load Missing Example</button>
      <button id="btn-paste-clear" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Clear</button>
    </div>
  </div>

  <!-- Manual Panel -->
  <div id="panel-manual" class="sec-panel hidden">
    <div class="mb-4">
      <label class="block text-sm font-medium mb-2">Add Headers Manually (key: value)</label>
      <div id="manual-headers-list" class="space-y-2 mb-3"></div>
      <div class="flex gap-3">
        <input id="manual-key" type="text" class="flex-1 bg-bg-card border border-border rounded-lg p-2.5 text-sm font-mono focus:outline-none focus:border-primary" placeholder="Header-Name" />
        <input id="manual-value" type="text" class="flex-1 bg-bg-card border border-border rounded-lg p-2.5 text-sm font-mono focus:outline-none focus:border-primary" placeholder="header-value" />
        <button id="btn-add-header" class="px-4 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Add</button>
      </div>
    </div>
    <div class="flex gap-3 mb-6 flex-wrap">
      <button id="btn-check-manual" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Check Headers</button>
      <button id="btn-manual-clear" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Clear All</button>
    </div>
  </div>

  <!-- Results -->
  <div id="results-section" class="hidden">
    <!-- Score banner -->
    <div id="score-banner" class="p-5 rounded-lg mb-6 flex items-center justify-between flex-wrap gap-4">
      <div>
        <div class="text-2xl font-bold" id="score-label"></div>
        <div class="text-sm mt-1" id="score-sub"></div>
      </div>
      <div class="text-right">
        <div class="text-4xl font-bold font-mono" id="score-num"></div>
        <div class="text-sm text-text-muted">/ 100</div>
      </div>
    </div>

    <!-- Results grid -->
    <div id="results-grid" class="space-y-3 mb-6"></div>

    <!-- Recommendations -->
    <div id="recommendations-section" class="hidden bg-bg-card border border-border rounded-lg p-4">
      <h3 class="text-sm font-semibold mb-3">Recommendations</h3>
      <div id="recommendations-list" class="space-y-3"></div>
    </div>

    <!-- Export -->
    <div class="mt-4 flex gap-3">
      <button id="btn-copy-report" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Copy Report</button>
    </div>
  </div>

  <ToolPageCta />
</BaseLayout>

<script>
// ── Header definitions ─────────────────────────────────────────────────────
const CHECKED_HEADERS = [
  {
    name: 'Strict-Transport-Security',
    key: 'strict-transport-security',
    weight: 15,
    required: true,
    check(val) {
      if (!val) return { status: 'fail', msg: 'Missing — site is vulnerable to SSL stripping and protocol downgrade attacks.' };
      if (!val.includes('max-age')) return { status: 'warn', msg: 'Present but missing max-age directive.' };
      const ma = parseInt(val.match(/max-age=(\d+)/)?.[1] || '0');
      if (ma < 31536000) return { status: 'warn', msg: `max-age=${ma} is less than 1 year (31536000). Increase to at least 31536000.` };
      const hasSubDomains = val.includes('includeSubDomains');
      const hasPreload = val.includes('preload');
      return { status: 'pass', msg: `Correctly configured.${!hasSubDomains ? ' Consider adding includeSubDomains.' : ''}${!hasPreload ? ' Consider adding preload for HSTS preload list.' : ''}` };
    },
    recommend: 'Add: Strict-Transport-Security: max-age=31536000; includeSubDomains; preload',
    learnMore: 'https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Strict-Transport-Security',
  },
  {
    name: 'Content-Security-Policy',
    key: 'content-security-policy',
    weight: 20,
    required: true,
    check(val) {
      if (!val) return { status: 'fail', msg: 'Missing — no XSS protection via CSP. Critical for modern web apps.' };
      const warnings = [];
      if (val.includes("'unsafe-inline'")) warnings.push("'unsafe-inline' weakens XSS protection");
      if (val.includes("'unsafe-eval'")) warnings.push("'unsafe-eval' allows code injection via eval()");
      if (val.includes('*') && !val.includes('data:')) warnings.push('Wildcard * source allows any origin');
      if (warnings.length) return { status: 'warn', msg: `CSP present but has issues: ${warnings.join('; ')}.` };
      return { status: 'pass', msg: 'CSP header present and no obvious weaknesses detected.' };
    },
    recommend: "Add: Content-Security-Policy: default-src 'self'; script-src 'self'; object-src 'none'; base-uri 'self'",
    learnMore: 'https://developer.mozilla.org/en-US/docs/Web/HTTP/CSP',
  },
  {
    name: 'X-Frame-Options',
    key: 'x-frame-options',
    weight: 10,
    required: true,
    check(val) {
      if (!val) {
        return { status: 'fail', msg: "Missing — page can be embedded in iframes on other origins (clickjacking risk). Note: frame-ancestors in CSP is the modern replacement." };
      }
      const v = val.trim().toUpperCase();
      if (v === 'DENY') return { status: 'pass', msg: 'DENY — page cannot be framed by any origin. Best setting.' };
      if (v === 'SAMEORIGIN') return { status: 'pass', msg: 'SAMEORIGIN — page can only be framed by same origin.' };
      if (v.startsWith('ALLOW-FROM')) return { status: 'warn', msg: 'ALLOW-FROM is deprecated and not supported in modern browsers. Use CSP frame-ancestors instead.' };
      return { status: 'warn', msg: `Unexpected value: "${val}". Valid values: DENY, SAMEORIGIN.` };
    },
    recommend: 'Add: X-Frame-Options: DENY (or use CSP frame-ancestors instead)',
    learnMore: 'https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/X-Frame-Options',
  },
  {
    name: 'X-Content-Type-Options',
    key: 'x-content-type-options',
    weight: 10,
    required: true,
    check(val) {
      if (!val) return { status: 'fail', msg: 'Missing — browsers may MIME-sniff responses, enabling content-type confusion attacks.' };
      if (val.trim().toLowerCase() === 'nosniff') return { status: 'pass', msg: "nosniff — browsers won't MIME-sniff responses." };
      return { status: 'warn', msg: `Unexpected value: "${val}". Should be exactly: nosniff` };
    },
    recommend: 'Add: X-Content-Type-Options: nosniff',
    learnMore: 'https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/X-Content-Type-Options',
  },
  {
    name: 'X-XSS-Protection',
    key: 'x-xss-protection',
    weight: 5,
    required: false,
    check(val) {
      if (!val) return { status: 'warn', msg: 'Missing — legacy header for older IE/Chrome. Modern browsers ignore it; CSP is the replacement.' };
      if (val.includes('1; mode=block')) return { status: 'pass', msg: '1; mode=block — enabled for older browsers. CSP provides better modern protection.' };
      if (val.trim() === '0') return { status: 'warn', msg: 'Set to 0 (disabled). Consider enabling for legacy browser support or rely entirely on CSP.' };
      return { status: 'pass', msg: `Present: ${val}` };
    },
    recommend: 'Add: X-XSS-Protection: 1; mode=block (legacy support; prefer CSP)',
    learnMore: 'https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/X-XSS-Protection',
  },
  {
    name: 'Referrer-Policy',
    key: 'referrer-policy',
    weight: 10,
    required: true,
    check(val) {
      if (!val) return { status: 'fail', msg: 'Missing — full URL (including paths/query strings) may leak to third parties in the Referer header.' };
      const safe = ['no-referrer', 'no-referrer-when-downgrade', 'same-origin', 'strict-origin', 'strict-origin-when-cross-origin'];
      const risky = ['unsafe-url', 'origin-when-cross-origin'];
      const v = val.trim().toLowerCase();
      if (safe.includes(v)) return { status: 'pass', msg: `${val} — good referrer policy.` };
      if (risky.includes(v)) return { status: 'warn', msg: `${val} may leak full URLs to cross-origin destinations.` };
      return { status: 'warn', msg: `Unrecognised value: "${val}".` };
    },
    recommend: 'Add: Referrer-Policy: strict-origin-when-cross-origin',
    learnMore: 'https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Referrer-Policy',
  },
  {
    name: 'Permissions-Policy',
    key: 'permissions-policy',
    weight: 10,
    required: false,
    check(val) {
      if (!val) return { status: 'warn', msg: 'Missing — browser features (camera, microphone, geolocation) are unrestricted. Consider setting a restrictive policy.' };
      return { status: 'pass', msg: `Present: ${val.slice(0, 80)}${val.length > 80 ? '...' : ''}` };
    },
    recommend: "Add: Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()",
    learnMore: 'https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Permissions-Policy',
  },
  {
    name: 'Cross-Origin-Opener-Policy',
    key: 'cross-origin-opener-policy',
    weight: 10,
    required: false,
    check(val) {
      if (!val) return { status: 'warn', msg: 'Missing — page shares a browsing context group with cross-origin windows, enabling XS-Leaks attacks.' };
      const v = val.trim().toLowerCase();
      if (v === 'same-origin') return { status: 'pass', msg: 'same-origin — isolates the browsing context. Best for security.' };
      if (v === 'same-origin-allow-popups') return { status: 'pass', msg: 'same-origin-allow-popups — allows popups from same origin.' };
      if (v === 'unsafe-none') return { status: 'warn', msg: 'unsafe-none — no isolation. Consider upgrading to same-origin.' };
      return { status: 'pass', msg: `Present: ${val}` };
    },
    recommend: 'Add: Cross-Origin-Opener-Policy: same-origin',
    learnMore: 'https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Cross-Origin-Opener-Policy',
  },
  {
    name: 'Cross-Origin-Resource-Policy',
    key: 'cross-origin-resource-policy',
    weight: 10,
    required: false,
    check(val) {
      if (!val) return { status: 'warn', msg: 'Missing — cross-origin sites can load this resource via <script>, <img>, etc. (Spectre/XS-Leaks risk for sensitive resources).' };
      const v = val.trim().toLowerCase();
      if (['same-origin', 'same-site', 'cross-origin'].includes(v)) return { status: 'pass', msg: `${val} — cross-origin resource policy set.` };
      return { status: 'warn', msg: `Unexpected value: "${val}". Valid: same-origin, same-site, cross-origin.` };
    },
    recommend: 'Add: Cross-Origin-Resource-Policy: same-origin (or same-site)',
    learnMore: 'https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Cross-Origin-Resource-Policy',
  },
];

const EXAMPLE_GOOD = `HTTP/2 200
date: Sat, 28 Mar 2026 10:00:00 GMT
content-type: text/html; charset=utf-8
strict-transport-security: max-age=31536000; includeSubDomains; preload
content-security-policy: default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'
x-frame-options: DENY
x-content-type-options: nosniff
x-xss-protection: 1; mode=block
referrer-policy: strict-origin-when-cross-origin
permissions-policy: camera=(), microphone=(), geolocation=(), payment=()
cross-origin-opener-policy: same-origin
cross-origin-resource-policy: same-origin`;

const EXAMPLE_BAD = `HTTP/1.1 200 OK
date: Sat, 28 Mar 2026 10:00:00 GMT
content-type: text/html; charset=utf-8
server: Apache/2.4.51
x-powered-by: PHP/8.1.0`;

// ── Tabs ───────────────────────────────────────────────────────────────────
function switchTab(tab) {
  document.querySelectorAll('.sec-tab').forEach(t => {
    const active = t.dataset.tab === tab;
    t.classList.toggle('border-primary', active);
    t.classList.toggle('text-primary', active);
    t.classList.toggle('border-transparent', !active);
    t.classList.toggle('text-text-muted', !active);
  });
  document.querySelectorAll('.sec-panel').forEach(p => p.classList.add('hidden'));
  document.getElementById(`panel-${tab}`)?.classList.remove('hidden');
}
document.querySelectorAll('.sec-tab').forEach(t => t.addEventListener('click', () => switchTab(t.dataset.tab)));

// ── Parse headers ──────────────────────────────────────────────────────────
function parseHeaders(text) {
  const headers = {};
  const lines = text.split(/\r?\n/);
  for (const line of lines) {
    if (!line.trim() || line.match(/^HTTP\//)) continue;
    const idx = line.indexOf(':');
    if (idx < 0) continue;
    const key = line.slice(0, idx).trim().toLowerCase();
    const val = line.slice(idx + 1).trim();
    headers[key] = val;
  }
  return headers;
}

// ── Manual headers state ───────────────────────────────────────────────────
let manualHeaders = {};

function renderManualList() {
  const list = document.getElementById('manual-headers-list');
  if (!list) return;
  list.innerHTML = Object.entries(manualHeaders).map(([k, v]) => `
    <div class="flex items-center gap-2 bg-bg-card border border-border rounded-lg px-3 py-2">
      <span class="font-mono text-xs text-primary flex-shrink-0">${k}:</span>
      <span class="font-mono text-xs text-text-muted flex-1 truncate">${v}</span>
      <button class="btn-remove-manual text-text-muted hover:text-red-400 transition-colors text-lg leading-none flex-shrink-0" data-key="${k}">&#215;</button>
    </div>`).join('') || '<p class="text-xs text-text-muted">No headers added yet.</p>';
  list.querySelectorAll('.btn-remove-manual').forEach(btn => {
    btn.addEventListener('click', () => { delete manualHeaders[btn.dataset.key]; renderManualList(); });
  });
}

document.getElementById('btn-add-header')?.addEventListener('click', () => {
  const keyEl = document.getElementById('manual-key');
  const valEl = document.getElementById('manual-value');
  const key = keyEl?.value.trim().toLowerCase();
  if (!key) { alert('Enter a header name.'); return; }
  manualHeaders[key] = valEl?.value.trim() || '';
  if (keyEl) keyEl.value = '';
  if (valEl) valEl.value = '';
  renderManualList();
});
document.getElementById('btn-manual-clear')?.addEventListener('click', () => { manualHeaders = {}; renderManualList(); });
document.getElementById('btn-check-manual')?.addEventListener('click', () => runCheck(manualHeaders));

// ── Paste panel ────────────────────────────────────────────────────────────
document.getElementById('btn-paste-example-good')?.addEventListener('click', () => { document.getElementById('headers-paste').value = EXAMPLE_GOOD; });
document.getElementById('btn-paste-example-bad')?.addEventListener('click', () => { document.getElementById('headers-paste').value = EXAMPLE_BAD; });
document.getElementById('btn-paste-clear')?.addEventListener('click', () => {
  document.getElementById('headers-paste').value = '';
  document.getElementById('results-section').classList.add('hidden');
});
document.getElementById('btn-check-paste')?.addEventListener('click', () => {
  const raw = document.getElementById('headers-paste').value;
  runCheck(parseHeaders(raw));
});

// ── Check logic ────────────────────────────────────────────────────────────
function runCheck(headers) {
  const results = CHECKED_HEADERS.map(def => {
    const val = headers[def.key];
    const check = def.check(val);
    return { ...def, val, ...check };
  });

  // Score
  let totalWeight = 0, earned = 0;
  results.forEach(r => {
    totalWeight += r.weight;
    if (r.status === 'pass') earned += r.weight;
    else if (r.status === 'warn') earned += r.weight * 0.5;
  });
  const score = Math.round((earned / totalWeight) * 100);

  // Score banner
  const bannerEl = document.getElementById('score-banner');
  const scoreNumEl = document.getElementById('score-num');
  const scoreLabelEl = document.getElementById('score-label');
  const scoreSubEl = document.getElementById('score-sub');
  scoreNumEl.textContent = score;

  if (score >= 80) {
    bannerEl.className = 'p-5 rounded-lg mb-6 flex items-center justify-between flex-wrap gap-4 bg-green-500/10 border border-green-500/30';
    scoreLabelEl.textContent = score >= 95 ? 'Excellent Security' : 'Good Security';
    scoreLabelEl.className = 'text-2xl font-bold text-green-400';
    scoreSubEl.textContent = 'Most security headers are correctly configured.';
    scoreSubEl.className = 'text-sm mt-1 text-green-300';
    scoreNumEl.className = 'text-4xl font-bold font-mono text-green-400';
  } else if (score >= 50) {
    bannerEl.className = 'p-5 rounded-lg mb-6 flex items-center justify-between flex-wrap gap-4 bg-yellow-500/10 border border-yellow-500/30';
    scoreLabelEl.textContent = 'Fair Security';
    scoreLabelEl.className = 'text-2xl font-bold text-yellow-400';
    scoreSubEl.textContent = 'Several security headers are missing or misconfigured.';
    scoreSubEl.className = 'text-sm mt-1 text-yellow-300';
    scoreNumEl.className = 'text-4xl font-bold font-mono text-yellow-400';
  } else {
    bannerEl.className = 'p-5 rounded-lg mb-6 flex items-center justify-between flex-wrap gap-4 bg-red-500/10 border border-red-500/30';
    scoreLabelEl.textContent = 'Poor Security';
    scoreLabelEl.className = 'text-2xl font-bold text-red-400';
    scoreSubEl.textContent = 'Critical security headers are missing. Immediate action recommended.';
    scoreSubEl.className = 'text-sm mt-1 text-red-300';
    scoreNumEl.className = 'text-4xl font-bold font-mono text-red-400';
  }

  // Results grid
  const grid = document.getElementById('results-grid');
  grid.innerHTML = results.map(r => {
    const statusConfig = {
      pass: { bg: 'bg-green-500/10', border: 'border-green-500/30', badge: 'bg-green-500/20 text-green-400', icon: '✓', label: 'PASS' },
      warn: { bg: 'bg-yellow-500/10', border: 'border-yellow-500/30', badge: 'bg-yellow-500/20 text-yellow-400', icon: '⚠', label: 'WARN' },
      fail: { bg: 'bg-red-500/10', border: 'border-red-500/30', badge: 'bg-red-500/20 text-red-400', icon: '✗', label: 'FAIL' },
    };
    const cfg = statusConfig[r.status];
    return `
      <div class="${cfg.bg} border ${cfg.border} rounded-lg p-4">
        <div class="flex items-start justify-between gap-3 mb-2">
          <div class="flex items-center gap-2 flex-wrap min-w-0">
            <span class="font-mono text-sm font-semibold text-foreground">${r.name}</span>
            ${r.required ? '' : '<span class="text-xs text-text-muted">(optional)</span>'}
          </div>
          <span class="flex-shrink-0 text-xs font-bold px-2 py-0.5 rounded ${cfg.badge}">${cfg.icon} ${cfg.label}</span>
        </div>
        <p class="text-xs text-text-muted mb-2">${r.msg}</p>
        ${r.val ? `<code class="text-xs font-mono text-foreground bg-bg-card border border-border px-2 py-1 rounded block break-all">${r.val.length > 120 ? r.val.slice(0, 120) + '...' : r.val}</code>` : ''}
      </div>`;
  }).join('');

  // Recommendations
  const fails = results.filter(r => r.status === 'fail');
  const warns = results.filter(r => r.status === 'warn');
  const recSection = document.getElementById('recommendations-section');
  const recList = document.getElementById('recommendations-list');
  if (fails.length + warns.length > 0) {
    recList.innerHTML = [...fails, ...warns].map(r => `
      <div class="border-b border-border pb-3 last:border-0 last:pb-0">
        <div class="flex items-center gap-2 mb-1">
          <span class="text-xs font-bold px-2 py-0.5 rounded ${r.status === 'fail' ? 'bg-red-500/20 text-red-400' : 'bg-yellow-500/20 text-yellow-400'}">${r.status.toUpperCase()}</span>
          <span class="text-sm font-semibold font-mono">${r.name}</span>
        </div>
        <code class="text-xs font-mono text-primary bg-bg-card border border-border px-2 py-1.5 rounded block break-all mb-1">${r.recommend}</code>
        <a href="${r.learnMore}" target="_blank" rel="noopener noreferrer" class="text-xs text-primary hover:underline">MDN Documentation →</a>
      </div>`).join('');
    recSection.classList.remove('hidden');
  } else {
    recSection.classList.add('hidden');
  }

  document.getElementById('results-section').classList.remove('hidden');
  setTimeout(() => document.getElementById('results-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);

  // Store for report
  window._lastResults = results;
  window._lastScore = score;
}

// Copy report
document.getElementById('btn-copy-report')?.addEventListener('click', () => {
  if (!window._lastResults) return;
  const lines = [`Security Headers Report — Score: ${window._lastScore}/100`, ''];
  window._lastResults.forEach(r => {
    lines.push(`[${r.status.toUpperCase().padEnd(4)}] ${r.name}`);
    lines.push(`       ${r.msg}`);
    if (r.val) lines.push(`       Value: ${r.val}`);
    lines.push('');
  });
  navigator.clipboard.writeText(lines.join('\n')).then(() => {
    const btn = document.getElementById('btn-copy-report');
    if (btn) { btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = 'Copy Report', 2000); }
  });
});

// Init manual list
renderManualList();
</script>
