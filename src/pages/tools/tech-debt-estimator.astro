---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is technical debt?", answer: "Technical debt is the implied cost of future rework caused by choosing a quick, easy solution now instead of a better approach that would take longer. The term was coined by Ward Cunningham. Like financial debt, it accumulates interest — the longer you wait to pay it down, the harder (and slower) feature development becomes. Common sources: rushed features, outdated dependencies, missing tests, poor documentation." },
  { question: "How is technical debt measured in hours?", answer: "One common method (used by SQALE and SonarQube) assigns a remediation time to each type of issue: a code smell might cost 30 minutes to fix, a bug 2 hours, a missing test 1 hour per untested function. Summing these gives an estimated fix effort. This tool uses industry-average remediation constants to estimate total debt from your codebase metrics." },
  { question: "What is the technical debt ratio?", answer: "The technical debt ratio (TDR) = (remediation cost / estimated development cost) × 100%. Development cost is estimated as: lines of code × average cost per line (typically $1–5). A TDR below 5% is considered healthy. 5–10% is moderate — plan sprints to address it. Above 20% is unsustainable and will severely slow new feature development." },
  { question: "What is the difference between planned and unplanned debt?", answer: "Planned (strategic) debt is deliberately taken on to meet a deadline, with a clear plan to pay it back. Unplanned (accidental) debt accumulates through negligence, ignorance, or poor practices — no one decided to create it. Planned debt is manageable; unplanned debt compounds into 'big ball of mud' codebases. Tracking debt explicitly (in backlog, debt register) converts unplanned debt into managed debt." },
  { question: "How much time should we spend paying down tech debt?", answer: "The 'technical debt sprint' approach: dedicate 20% of each sprint to debt reduction — two days per two-week sprint. Google's SRE practice recommends 50% of SRE time on reliability/debt work. Martin Fowler's recommendation: never let debt exceed 5% TDR before dedicated paydown. Many teams use the 'boy scout rule': always leave code cleaner than you found it." },
];
---

<BaseLayout
  title="Tech Debt Estimator — Calculate Technical Debt in Hours & Story Points"
  description="Enter codebase metrics to estimate your total technical debt in hours and story points. Get a debt ratio, severity rating, and recommended paydown strategy. Runs in your browser."
  tool="Tech Debt Estimator, technical debt calculator, debt ratio, code quality metrics, remediation cost, story points, sprint planning, software maintenance"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Tech Debt Estimator",
    "url": "https://devplaybook.cc/tools/tech-debt-estimator",
    "description": "Calculate technical debt in hours and story points from codebase metrics. Get debt ratio and paydown recommendations. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Technical Debt Estimator</h1>
  <p class="text-text-muted mb-4">Enter your codebase metrics to estimate <strong>total technical debt</strong> in hours and story points. Get a debt ratio, severity classification, and a sprint plan recommendation to systematically pay it down.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Hours + story points estimate</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Technical debt ratio (TDR)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Sprint paydown plan</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-6">
    <!-- Inputs -->
    <div class="bg-bg-card border border-border rounded-lg p-5">
      <h2 class="text-sm font-semibold mb-4">Codebase Metrics</h2>
      <div class="space-y-4">

        <div>
          <label class="block text-sm font-medium mb-1">Total Lines of Code (LOC) <span class="text-text-muted text-xs">(run: cloc . --sum-one)</span></label>
          <input id="input-loc" type="number" min="0" class="w-full bg-bg-page border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="e.g. 50000" />
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium mb-1">Test Coverage %</label>
            <input id="input-coverage" type="number" min="0" max="100" class="w-full bg-bg-page border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="e.g. 45" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Avg Cyclomatic Complexity</label>
            <input id="input-complexity" type="number" min="1" class="w-full bg-bg-page border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="e.g. 8" />
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium mb-1">Code Duplication %</label>
            <input id="input-dup" type="number" min="0" max="100" class="w-full bg-bg-page border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="e.g. 12" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Outdated Dependencies</label>
            <input id="input-outdated" type="number" min="0" class="w-full bg-bg-page border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="e.g. 15" />
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium mb-1">TODO/FIXME Count</label>
            <input id="input-todos" type="number" min="0" class="w-full bg-bg-page border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="e.g. 42" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Known Bugs (open)</label>
            <input id="input-bugs" type="number" min="0" class="w-full bg-bg-page border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="e.g. 8" />
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium mb-1">Team Size (developers)</label>
          <input id="input-team" type="number" min="1" class="w-full bg-bg-page border border-border rounded-lg p-3 text-sm focus:outline-none focus:border-primary" placeholder="e.g. 5" value="5" />
        </div>

        <button id="btn-estimate" class="w-full px-4 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Calculate Debt</button>
      </div>
    </div>

    <!-- Results -->
    <div class="space-y-4">
      <!-- Total debt -->
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <h2 class="text-sm font-semibold mb-3">Estimated Technical Debt</h2>
        <div class="grid grid-cols-2 gap-3 mb-4">
          <div class="bg-bg-page rounded-lg p-3 text-center">
            <div class="text-3xl font-bold text-primary" id="result-hours">—</div>
            <div class="text-xs text-text-muted">dev-hours</div>
          </div>
          <div class="bg-bg-page rounded-lg p-3 text-center">
            <div class="text-3xl font-bold text-blue-400" id="result-sp">—</div>
            <div class="text-xs text-text-muted">story points</div>
          </div>
        </div>
        <div class="flex items-center gap-3 mb-2">
          <span class="text-sm text-text-muted">Debt Ratio (TDR):</span>
          <span id="result-tdr" class="text-sm font-bold">—</span>
          <span id="result-severity" class="text-xs px-2 py-0.5 rounded-full bg-bg-page text-text-muted">—</span>
        </div>
        <div class="w-full bg-bg-page rounded-full h-2.5 overflow-hidden">
          <div id="tdr-bar" class="h-2.5 rounded-full bg-text-muted transition-all duration-500" style="width:0%"></div>
        </div>
      </div>

      <!-- Breakdown -->
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <h2 class="text-sm font-semibold mb-3">Debt Breakdown</h2>
        <div id="breakdown-list" class="space-y-2">
          <p class="text-xs text-text-muted italic">Enter metrics to see breakdown.</p>
        </div>
      </div>

      <!-- Sprint plan -->
      <div id="sprint-plan" class="hidden bg-blue-500/10 border border-blue-500/30 rounded-lg p-4">
        <h3 class="text-sm font-semibold text-blue-400 mb-2">Sprint Paydown Plan</h3>
        <div id="sprint-plan-text" class="text-sm text-text-muted space-y-1"></div>
      </div>
    </div>
  </div>

  <ToolPageCta currentTool="Tech Debt Estimator" relatedTags={['code-quality', 'project-management', 'refactoring', 'agile', 'engineering']} />
  <FaqSection faq={faq} />
</BaseLayout>

<script>
// Remediation constants (industry averages)
const REMEDIATION = {
  missingTest: 0.5,          // hours per % of uncovered LOC
  codeSmell: 0.25,           // hours per complexity unit above threshold
  duplication: 0.75,         // hours per % duplication
  outdatedDep: 1.5,          // hours per outdated package
  todo: 0.5,                 // hours per TODO/FIXME
  bug: 3,                    // hours per known bug
};

const SP_PER_HOUR = 0.25; // 1 story point ≈ 4 hours

function estimate() {
  const loc = parseFloat((document.getElementById('input-loc') as HTMLInputElement).value) || 0;
  const coverage = parseFloat((document.getElementById('input-coverage') as HTMLInputElement).value) || 0;
  const complexity = parseFloat((document.getElementById('input-complexity') as HTMLInputElement).value) || 1;
  const dup = parseFloat((document.getElementById('input-dup') as HTMLInputElement).value) || 0;
  const outdated = parseFloat((document.getElementById('input-outdated') as HTMLInputElement).value) || 0;
  const todos = parseFloat((document.getElementById('input-todos') as HTMLInputElement).value) || 0;
  const bugs = parseFloat((document.getElementById('input-bugs') as HTMLInputElement).value) || 0;
  const team = Math.max(1, parseFloat((document.getElementById('input-team') as HTMLInputElement).value) || 5);

  if (!loc && !outdated && !todos && !bugs) return;

  // Calculate component debt hours
  const testDebt = ((100 - Math.min(coverage, 100)) / 100) * (loc / 10) * REMEDIATION.missingTest;
  const complexityDebt = Math.max(0, complexity - 10) * (loc / 100) * REMEDIATION.codeSmell;
  const dupDebt = (dup / 100) * (loc / 50) * REMEDIATION.duplication;
  const depDebt = outdated * REMEDIATION.outdatedDep;
  const todoDebt = todos * REMEDIATION.todo;
  const bugDebt = bugs * REMEDIATION.bug;

  const totalHours = Math.round(testDebt + complexityDebt + dupDebt + depDebt + todoDebt + bugDebt);
  const totalSP = Math.round(totalHours * SP_PER_HOUR);

  // Dev cost: assume $150/hour average fully-loaded cost
  const devCostPerLine = 5; // $5 per line of code (conservative)
  const devCost = loc * devCostPerLine;
  const debtCost = totalHours * 150;
  const tdr = devCost > 0 ? Math.min((debtCost / devCost) * 100, 100) : 0;

  document.getElementById('result-hours')!.textContent = totalHours.toLocaleString();
  document.getElementById('result-sp')!.textContent = totalSP.toLocaleString();
  document.getElementById('result-tdr')!.textContent = `${tdr.toFixed(1)}%`;

  const severity =
    tdr < 5 ? { label: 'Healthy', color: 'bg-green-500/20 text-green-400', bar: 'bg-green-500' } :
    tdr < 10 ? { label: 'Moderate', color: 'bg-yellow-500/20 text-yellow-400', bar: 'bg-yellow-500' } :
    tdr < 20 ? { label: 'High', color: 'bg-orange-500/20 text-orange-400', bar: 'bg-orange-500' } :
    { label: 'Critical', color: 'bg-red-500/20 text-red-400', bar: 'bg-red-500' };

  document.getElementById('result-severity')!.textContent = severity.label;
  document.getElementById('result-severity')!.className = `text-xs px-2 py-0.5 rounded-full font-semibold ${severity.color}`;

  const bar = document.getElementById('tdr-bar')!;
  bar.className = `h-2.5 rounded-full transition-all duration-500 ${severity.bar}`;
  bar.style.width = `${Math.min(tdr, 100)}%`;

  // Breakdown
  const components = [
    { label: 'Missing Test Coverage', hours: testDebt, icon: '🧪' },
    { label: 'High Cyclomatic Complexity', hours: complexityDebt, icon: '🔀' },
    { label: 'Code Duplication', hours: dupDebt, icon: '📋' },
    { label: 'Outdated Dependencies', hours: depDebt, icon: '📦' },
    { label: 'TODO / FIXME Items', hours: todoDebt, icon: '📌' },
    { label: 'Known Bugs', hours: bugDebt, icon: '🐛' },
  ].filter(c => c.hours > 0).sort((a, b) => b.hours - a.hours);

  const maxH = Math.max(...components.map(c => c.hours), 1);
  document.getElementById('breakdown-list')!.innerHTML = components.length ? components.map(c => `
    <div>
      <div class="flex items-center justify-between mb-1">
        <span class="text-xs">${c.icon} ${c.label}</span>
        <span class="text-xs font-semibold">${Math.round(c.hours)}h</span>
      </div>
      <div class="w-full bg-bg-page rounded-full h-1.5 overflow-hidden">
        <div class="h-1.5 rounded-full bg-primary/70" style="width:${(c.hours / maxH * 100).toFixed(1)}%"></div>
      </div>
    </div>
  `).join('') : '<p class="text-xs text-text-muted">No debt items to show.</p>';

  // Sprint plan
  const hoursPerSprintPerDev = 8; // 20% of 40h sprint = 8h per dev for debt
  const totalDebtHoursPerSprint = team * hoursPerSprintPerDev;
  const sprintsNeeded = totalDebtHoursPerSprint > 0 ? Math.ceil(totalHours / totalDebtHoursPerSprint) : 0;

  const plan = document.getElementById('sprint-plan')!;
  const planText = document.getElementById('sprint-plan-text')!;
  if (totalHours > 0) {
    plan.classList.remove('hidden');
    planText.innerHTML = `
      <p>At 20% of sprint capacity for debt work:</p>
      <p>• <strong>${team} devs × 8h/sprint</strong> = ${totalDebtHoursPerSprint}h debt budget per sprint</p>
      <p>• <strong>~${sprintsNeeded} sprints</strong> (${Math.ceil(sprintsNeeded / 2)} months) to pay down ${totalHours}h of debt</p>
      <p class="text-xs mt-2 text-blue-300">Tip: Focus on highest-ROI items first — test coverage and bug fixes typically unlock the most velocity.</p>
    `;
  }
}

document.getElementById('btn-estimate')?.addEventListener('click', estimate);
</script>
