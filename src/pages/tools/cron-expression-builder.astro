---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is a cron expression?",
    answer: "A cron expression is a string of 5 fields (minute, hour, day-of-month, month, day-of-week) that define a schedule for recurring tasks. Format: * * * * * (minute hour day month weekday). For example, '0 9 * * 1-5' means 9:00 AM on weekdays. Most Linux systems, GitHub Actions, AWS EventBridge, and cron-based task runners support this format."
  },
  {
    question: "What is the difference between */5 and 0,5,10,15...?",
    answer: "*/5 means 'every 5 units' — it starts at 0 and increments by 5 (0, 5, 10, 15, 20, 25, 30, 35, 40, 45, 50, 55). 0,5,10,15,20,25,30,35,40,45,50,55 is the explicit equivalent. Both produce the same schedule. The step syntax (*/n) is cleaner for regular intervals; the list syntax is better for irregular intervals like 0,15,45."
  },
  {
    question: "How do I schedule a job for the last day of the month?",
    answer: "Standard cron doesn't support 'last day of month' natively. Common workarounds: use 28 (safe for all months), or use a script that checks if tomorrow is the 1st. Some extended cron systems (like Quartz or node-cron) support L to mean last. AWS EventBridge supports L in day-of-month position."
  },
  {
    question: "What timezone does cron use?",
    answer: "System cron (Linux crontab) uses the server's local timezone, usually UTC in production. GitHub Actions uses UTC. AWS EventBridge uses UTC by default but supports timezone-aware schedules. Always specify timezones explicitly in your CI/CD config to avoid daylight saving time surprises. For Node.js cron jobs, use libraries like node-cron with the timezone option."
  },
  {
    question: "What is the cron expression for 'every 15 minutes, 9am to 5pm, weekdays'?",
    answer: "*/15 9-17 * * 1-5 — this runs every 15 minutes (at :00, :15, :30, :45) from 9:00 to 17:45 on Monday through Friday. Note: it runs at 17:00, 17:15, 17:30, 17:45 — within the 9-17 hour range. To stop at exactly 5pm, you'd need 0,15,30,45 9-16 * * 1-5 (runs from 9:00 to 16:45)."
  }
];
---

<BaseLayout
  title="Cron Expression Builder — Visual Cron Generator with Human-Readable Description"
  description="Build cron expressions visually. Set minute, hour, day, month, and weekday schedules. See human-readable descriptions, next run times, and copy-ready cron syntax. Free browser tool."
  tool="cron expression builder, cron generator, cron schedule builder, cron expression helper, cron job generator, crontab generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Cron Expression Builder",
    "url": "https://devplaybook.cc/tools/cron-expression-builder",
    "description": "Build cron expressions visually. Set minute/hour/day/month/weekday schedules with human-readable descriptions and next run times.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Cron Expression Builder</h1>
  <p class="text-text-muted mb-4">
    Build cron schedule expressions visually. Configure minute, hour, day, month, and weekday fields,
    get a human-readable description, see the next 5 run times, and copy the expression.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Visual field builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Human-readable description</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Next 5 run times</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Common presets</span>
  </div>

  <!-- Manual input -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <label class="block text-sm font-medium mb-2">Cron Expression</label>
    <div class="flex gap-2 items-center">
      <input id="cron-manual" type="text" value="*/15 * * * *" class="flex-1 bg-surface border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" spellcheck="false" />
      <button id="copy-cron" class="px-4 py-2 bg-primary text-white rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors shrink-0">Copy</button>
    </div>
    <div id="cron-description" class="mt-2 text-sm text-accent font-medium"></div>
    <div id="cron-error" class="mt-2 text-sm text-red-400 hidden"></div>
  </div>

  <!-- Field builders -->
  <div class="grid grid-cols-1 sm:grid-cols-5 gap-3 mb-4" id="field-builders">
    <!-- Built by JS -->
  </div>

  <!-- Presets -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-medium mb-3">Common Presets</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2" id="presets-grid"></div>
  </div>

  <!-- Next runs -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-medium mb-3">Next 5 Run Times (UTC)</h2>
    <div id="next-runs" class="space-y-1.5"></div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Cron Expression Builder" relatedTags={['cron', 'scheduling', 'devops', 'automation', 'linux']} />
</BaseLayout>

<script is:inline>
(function() {
  const PRESETS = [
    { label: 'Every minute', expr: '* * * * *' },
    { label: 'Every 5 minutes', expr: '*/5 * * * *' },
    { label: 'Every 15 minutes', expr: '*/15 * * * *' },
    { label: 'Every 30 minutes', expr: '*/30 * * * *' },
    { label: 'Every hour', expr: '0 * * * *' },
    { label: 'Every 6 hours', expr: '0 */6 * * *' },
    { label: 'Every day at midnight', expr: '0 0 * * *' },
    { label: 'Every day at 9am', expr: '0 9 * * *' },
    { label: 'Weekdays at 9am', expr: '0 9 * * 1-5' },
    { label: 'Every Monday at 8am', expr: '0 8 * * 1' },
    { label: 'Every Sunday at midnight', expr: '0 0 * * 0' },
    { label: '1st of month at midnight', expr: '0 0 1 * *' },
    { label: 'Every month at midnight', expr: '0 0 1 * *' },
    { label: 'Twice daily (9am & 5pm)', expr: '0 9,17 * * *' },
    { label: 'Every weekday at 6pm', expr: '0 18 * * 1-5' },
    { label: 'Every 15min, 9-5 weekdays', expr: '*/15 9-17 * * 1-5' },
  ];

  const FIELD_DEFS = [
    { name: 'Minute', id: 'min', min: 0, max: 59, placeholder: '* or 0-59 or */5' },
    { name: 'Hour', id: 'hr', min: 0, max: 23, placeholder: '* or 0-23 or */2' },
    { name: 'Day', id: 'dom', min: 1, max: 31, placeholder: '* or 1-31' },
    { name: 'Month', id: 'mon', min: 1, max: 12, placeholder: '* or 1-12' },
    { name: 'Weekday', id: 'dow', min: 0, max: 6, placeholder: '* or 0-6 (0=Sun)' },
  ];

  const MONTH_NAMES = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const DOW_NAMES = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

  function parseCron(expr) {
    const parts = expr.trim().split(/\s+/);
    if (parts.length !== 5) return null;
    return { min: parts[0], hr: parts[1], dom: parts[2], mon: parts[3], dow: parts[4] };
  }

  function validateField(val, min, max) {
    if (val === '*') return true;
    if (/^\*\/\d+$/.test(val)) {
      const step = parseInt(val.slice(2));
      return step >= 1 && step <= max;
    }
    if (/^\d+$/.test(val)) {
      const n = parseInt(val);
      return n >= min && n <= max;
    }
    if (/^\d+-\d+$/.test(val)) {
      const [a, b] = val.split('-').map(Number);
      return a >= min && b <= max && a <= b;
    }
    if (/^[\d,]+$/.test(val)) {
      return val.split(',').every(v => { const n = parseInt(v); return n >= min && n <= max; });
    }
    if (/^\d+-\d+\/\d+$/.test(val)) return true;
    return false;
  }

  function describeField(val, type) {
    if (val === '*') return type === 'min' ? 'every minute' : type === 'hr' ? 'every hour' : type === 'dom' ? 'every day' : type === 'mon' ? 'every month' : 'every day of week';
    if (/^\*\/(\d+)$/.test(val)) {
      const n = val.match(/\d+/)[0];
      const unit = { min: 'minute', hr: 'hour', dom: 'day', mon: 'month', dow: 'day' }[type];
      return `every ${n} ${unit}s`;
    }
    if (type === 'dow') {
      if (/^\d$/.test(val)) return 'on ' + DOW_NAMES[parseInt(val)];
      if (/^\d-\d$/.test(val)) {
        const [a,b] = val.split('-').map(Number);
        return `${DOW_NAMES[a]}-${DOW_NAMES[b]}`;
      }
    }
    if (type === 'mon') {
      if (/^\d+$/.test(val)) return 'in ' + MONTH_NAMES[parseInt(val)-1];
    }
    return 'at ' + val;
  }

  function describeCron(parsed) {
    if (!parsed) return 'Invalid cron expression';
    const { min, hr, dom, mon, dow } = parsed;
    const parts = [];

    // Minute
    if (min === '*') parts.push('every minute');
    else if (/^\*\/(\d+)$/.test(min)) parts.push(`every ${min.match(/\d+/)[0]} minutes`);
    else if (/^\d+$/.test(min)) parts.push(`at minute :${min.padStart(2,'0')}`);
    else parts.push(`at minutes ${min}`);

    // Hour
    if (hr !== '*') {
      if (/^\*\/(\d+)$/.test(hr)) parts.push(`every ${hr.match(/\d+/)[0]} hours`);
      else if (/^\d+$/.test(hr)) parts.push(`hour ${hr}`);
      else if (/^\d+,\d+/.test(hr)) parts.push(`hours ${hr}`);
      else if (/^\d+-\d+$/.test(hr)) { const [a,b] = hr.split('-'); parts.push(`${a}:00-${b}:59`); }
      else parts.push(`hour ${hr}`);
    }

    // Day of week
    if (dow !== '*') {
      if (/^\d$/.test(dow)) parts.push(`on ${DOW_NAMES[parseInt(dow)]}s`);
      else if (dow === '1-5') parts.push('on weekdays');
      else if (dow === '0,6' || dow === '6,0') parts.push('on weekends');
      else parts.push(`on days ${dow}`);
    }

    // Day of month
    if (dom !== '*') {
      if (/^\d+$/.test(dom)) parts.push(`on day ${dom} of month`);
      else parts.push(`on days ${dom} of month`);
    }

    // Month
    if (mon !== '*') {
      if (/^\d+$/.test(mon)) parts.push(`in ${MONTH_NAMES[parseInt(mon)-1]}`);
      else parts.push(`in months ${mon}`);
    }

    return 'Runs ' + parts.join(', ');
  }

  function matchesField(val, n, min, max) {
    if (val === '*') return true;
    if (/^\*\/(\d+)$/.test(val)) {
      const step = parseInt(val.match(/\d+/)[0]);
      return (n - min) % step === 0;
    }
    if (/^\d+$/.test(val)) return parseInt(val) === n;
    if (/^\d+-\d+$/.test(val)) {
      const [a,b] = val.split('-').map(Number);
      return n >= a && n <= b;
    }
    if (/^[\d,]+$/.test(val)) {
      return val.split(',').map(Number).includes(n);
    }
    if (/^\d+-\d+\/\d+$/.test(val)) {
      const [range, step] = val.split('/');
      const [a,b] = range.split('-').map(Number);
      if (n < a || n > b) return false;
      return (n - a) % parseInt(step) === 0;
    }
    return false;
  }

  function getNextRuns(expr, count = 5) {
    const parsed = parseCron(expr);
    if (!parsed) return [];
    const { min, hr, dom, mon, dow } = parsed;
    const results = [];
    const now = new Date();
    now.setSeconds(0, 0);
    let d = new Date(now.getTime() + 60000); // start from next minute
    let iterations = 0;
    while (results.length < count && iterations < 100000) {
      iterations++;
      const m = d.getUTCMinutes(), h = d.getUTCHours();
      const day = d.getUTCDate(), mo = d.getUTCMonth() + 1, wd = d.getUTCDay();
      if (
        matchesField(min, m, 0, 59) &&
        matchesField(hr, h, 0, 23) &&
        matchesField(dom, day, 1, 31) &&
        matchesField(mon, mo, 1, 12) &&
        matchesField(dow, wd, 0, 6)
      ) {
        results.push(new Date(d));
      }
      d = new Date(d.getTime() + 60000);
    }
    return results;
  }

  function formatDate(d) {
    return d.toISOString().replace('T', ' ').replace('.000Z', ' UTC');
  }

  function getExpr() {
    return document.getElementById('cron-manual').value.trim();
  }

  function updateFromExpr(expr) {
    const parsed = parseCron(expr);
    const errEl = document.getElementById('cron-error');
    const descEl = document.getElementById('cron-description');

    if (!parsed) {
      errEl.textContent = 'Invalid: must have exactly 5 space-separated fields';
      errEl.classList.remove('hidden');
      descEl.textContent = '';
      return;
    }

    const fields = ['min','hr','dom','mon','dow'];
    const ranges = [[0,59],[0,23],[1,31],[1,12],[0,6]];
    let valid = true;
    fields.forEach((f, i) => {
      const v = parsed[f];
      if (!validateField(v, ranges[i][0], ranges[i][1])) valid = false;
    });

    if (!valid) {
      errEl.textContent = 'Expression contains invalid field values';
      errEl.classList.remove('hidden');
      descEl.textContent = '';
    } else {
      errEl.classList.add('hidden');
      descEl.textContent = describeCron(parsed);
    }

    // Update field inputs
    FIELD_DEFS.forEach((f, i) => {
      const el = document.getElementById('field-' + f.id);
      if (el) el.value = parsed[f.id];
    });

    // Next runs
    const runs = getNextRuns(expr);
    const runsEl = document.getElementById('next-runs');
    runsEl.innerHTML = runs.length > 0
      ? runs.map((d, i) => `
          <div class="flex items-center gap-3">
            <span class="text-xs text-text-muted w-4 shrink-0">${i+1}.</span>
            <span class="font-mono text-sm text-foreground/90">${formatDate(d)}</span>
          </div>
        `).join('')
      : '<span class="text-text-muted text-sm">Could not compute next runs</span>';
  }

  function buildFieldUI() {
    const container = document.getElementById('field-builders');
    container.innerHTML = FIELD_DEFS.map(f => `
      <div class="bg-bg-card border border-border rounded-lg p-3">
        <label class="block text-xs font-medium mb-1.5">${f.name}</label>
        <input id="field-${f.id}" type="text" value="*" placeholder="${f.placeholder}"
               class="w-full bg-surface border border-border rounded px-2 py-1.5 text-xs font-mono focus:outline-none focus:border-primary" />
        <div class="flex flex-wrap gap-1 mt-2">
          <button class="field-preset px-1.5 py-0.5 bg-surface border border-border rounded text-xs text-text-muted hover:border-primary transition-colors" data-field="${f.id}" data-val="*">*</button>
          ${f.id === 'min' ? '<button class="field-preset px-1.5 py-0.5 bg-surface border border-border rounded text-xs text-text-muted hover:border-primary transition-colors" data-field="min" data-val="*/5">*/5</button><button class="field-preset px-1.5 py-0.5 bg-surface border border-border rounded text-xs text-text-muted hover:border-primary transition-colors" data-field="min" data-val="0">0</button><button class="field-preset px-1.5 py-0.5 bg-surface border border-border rounded text-xs text-text-muted hover:border-primary transition-colors" data-field="min" data-val="*/15">*/15</button>' : ''}
          ${f.id === 'hr' ? '<button class="field-preset px-1.5 py-0.5 bg-surface border border-border rounded text-xs text-text-muted hover:border-primary transition-colors" data-field="hr" data-val="0">0</button><button class="field-preset px-1.5 py-0.5 bg-surface border border-border rounded text-xs text-text-muted hover:border-primary transition-colors" data-field="hr" data-val="9">9</button><button class="field-preset px-1.5 py-0.5 bg-surface border border-border rounded text-xs text-text-muted hover:border-primary transition-colors" data-field="hr" data-val="*/6">*/6</button>' : ''}
          ${f.id === 'dow' ? '<button class="field-preset px-1.5 py-0.5 bg-surface border border-border rounded text-xs text-text-muted hover:border-primary transition-colors" data-field="dow" data-val="1-5">1-5</button><button class="field-preset px-1.5 py-0.5 bg-surface border border-border rounded text-xs text-text-muted hover:border-primary transition-colors" data-field="dow" data-val="1">Mon</button><button class="field-preset px-1.5 py-0.5 bg-surface border border-border rounded text-xs text-text-muted hover:border-primary transition-colors" data-field="dow" data-val="0">Sun</button>' : ''}
          ${f.id === 'dom' ? '<button class="field-preset px-1.5 py-0.5 bg-surface border border-border rounded text-xs text-text-muted hover:border-primary transition-colors" data-field="dom" data-val="1">1st</button><button class="field-preset px-1.5 py-0.5 bg-surface border border-border rounded text-xs text-text-muted hover:border-primary transition-colors" data-field="dom" data-val="15">15th</button>' : ''}
        </div>
      </div>
    `).join('');

    FIELD_DEFS.forEach(f => {
      document.getElementById('field-' + f.id).addEventListener('input', () => {
        const parts = FIELD_DEFS.map(fd => document.getElementById('field-' + fd.id).value || '*');
        document.getElementById('cron-manual').value = parts.join(' ');
        updateFromExpr(parts.join(' '));
      });
    });

    container.querySelectorAll('.field-preset').forEach(btn => {
      btn.addEventListener('click', () => {
        const el = document.getElementById('field-' + btn.dataset.field);
        el.value = btn.dataset.val;
        el.dispatchEvent(new Event('input'));
      });
    });
  }

  function buildPresets() {
    const grid = document.getElementById('presets-grid');
    grid.innerHTML = PRESETS.map(p => `
      <button class="preset-item flex items-center gap-3 px-3 py-2 bg-surface border border-border rounded-lg hover:border-primary transition-colors text-left" data-expr="${p.expr}">
        <code class="font-mono text-xs text-accent shrink-0 w-32">${p.expr}</code>
        <span class="text-xs text-text-muted">${p.label}</span>
      </button>
    `).join('');

    grid.querySelectorAll('.preset-item').forEach(btn => {
      btn.addEventListener('click', () => {
        document.getElementById('cron-manual').value = btn.dataset.expr;
        updateFromExpr(btn.dataset.expr);
      });
    });
  }

  document.getElementById('cron-manual').addEventListener('input', e => updateFromExpr(e.target.value));

  document.getElementById('copy-cron').addEventListener('click', () => {
    navigator.clipboard.writeText(getExpr()).then(() => {
      const btn = document.getElementById('copy-cron');
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 1500);
    });
  });

  buildFieldUI();
  buildPresets();
  updateFromExpr('*/15 * * * *');
})();
</script>
