---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StringCaseConverter from '../../components/StringCaseConverter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="String Case Converter"
  description="Convert text between camelCase, PascalCase, snake_case, kebab-case, SCREAMING_SNAKE, Title Case, and more. Works with any separator. Instant copy."
  tool="String Case Converter, camelCase, snake_case, kebab-case, PascalCase Converter"
>
  <h1 class="text-3xl font-bold mb-2">String Case Converter</h1>
  <p class="text-text-muted mb-8">Convert any text between 12 common naming conventions: camelCase, PascalCase, snake_case, kebab-case, SCREAMING_SNAKE, Title Case, dot.case, and more. Works with any input separator.</p>
  <StringCaseConverter client:only="preact" />
  <ToolPageCta currentTool="String Case Converter" relatedTags={['text', 'naming', 'code', 'programming', 'developer-tools']} />
</BaseLayout>
