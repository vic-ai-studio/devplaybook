---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StringCaseConverter from '../../components/StringCaseConverter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What naming conventions does this tool support?", answer: "It converts between camelCase, PascalCase (UpperCamelCase), snake_case, kebab-case, SCREAMING_SNAKE_CASE, CONSTANT_CASE, Title Case, Sentence case, dot.case, path/case, and lowercase. All 12 conversions are available from a single input." },
  { question: "When should I use camelCase vs snake_case?", answer: "camelCase is the convention for JavaScript, TypeScript, and Java variables and functions. snake_case is standard for Python, Ruby, and Rust. SQL and database columns typically use snake_case. CSS classes use kebab-case. Follow your language and project conventions." },
  { question: "What is SCREAMING_SNAKE_CASE used for?", answer: "SCREAMING_SNAKE_CASE (all uppercase with underscores) is the standard for constants and environment variables across most languages. Examples: MAX_RETRIES, DATABASE_URL, API_SECRET_KEY. It signals that a value should not be modified." },
  { question: "Can I convert variable names from one codebase style to another?", answer: "Yes. Paste any variable name and the tool detects the input format automatically — whether it uses spaces, hyphens, underscores, or camelCase word boundaries. All other formats are generated instantly for one-click copy." },
  { question: "Does this tool handle multi-word inputs?", answer: "Yes. It splits input on any common separator: spaces, hyphens, underscores, dots, slashes, and camelCase word boundaries. So 'my variable name', 'my-variable-name', and 'myVariableName' all produce the same set of conversions." },
];
---

<BaseLayout
  title="String Case Converter — camelCase, snake_case, kebab-case"
  description="Convert text between camelCase, PascalCase, snake_case, kebab-case, SCREAMING_SNAKE, Title Case, and more. Detects input format automatically. One-click copy. Free, runs in your browser."
  tool="String Case Converter, camelCase, snake_case, kebab-case, PascalCase Converter"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">String Case Converter</h1>
  <p class="text-text-muted mb-4">Convert any text between 12 common naming conventions: camelCase, PascalCase, snake_case, kebab-case, SCREAMING_SNAKE, Title Case, dot.case, and more. Works with any input separator.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <StringCaseConverter client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="String Case Converter" relatedTags={['text', 'naming', 'code', 'programming', 'developer-tools']} />
</BaseLayout>
