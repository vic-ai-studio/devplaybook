---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ApiRateLimitCalculator from '../../components/ApiRateLimitCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="API Rate Limit Calculator — Throttle & Delay Planner"
  description="Calculate API rate limits: convert req/s, req/min, req/hr. Get delay between requests, burst refill time, and code snippets. Presets for OpenAI, GitHub, Stripe."
  tool="API Rate Limit Calculator, API Throttle Calculator, Request Delay Calculator, Rate Limit Converter"
>
  <h1 class="text-3xl font-bold mb-2">API Rate Limit Calculator</h1>
  <p class="text-text-muted mb-8">Convert rate limits across units, calculate delay between requests for your concurrency, and get a ready-to-use Node.js throttle snippet. Presets for popular APIs.</p>
  <ApiRateLimitCalculator client:load />
  <ToolPageCta currentTool="API Rate Limit Calculator" relatedTags={['api', 'rate-limiting', 'throttle', 'http', 'developer-tools']} />
</BaseLayout>
