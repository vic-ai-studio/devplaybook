---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeafletMapConfigBuilder from '../../components/LeafletMapConfigBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Leaflet.js?",
    answer: "Leaflet.js is the leading open-source JavaScript library for interactive maps. It's lightweight (~42KB gzipped), mobile-friendly, and works with any tile provider — OpenStreetMap, Mapbox, CartoDB, and others. Unlike Google Maps or Mapbox GL JS, Leaflet has no mandatory API key for the base library (though some tile providers require one). It's the standard choice for adding interactive maps to web apps without depending on a paid service."
  },
  {
    question: "Which tile provider should I choose?",
    answer: "OpenStreetMap is completely free with no API key — perfect for development and small production sites. CartoDB Light/Dark give a clean, minimal look for data visualization. Esri Satellite is good for geographic applications. Mapbox requires an API key but offers premium styling and vector tiles. For privacy-conscious applications, OpenStreetMap (self-hosted via tile.openstreetmap.org) is the most open choice."
  },
  {
    question: "What are the usage terms for OpenStreetMap tiles?",
    answer: "The tile.openstreetmap.org tiles are free for moderate use but have a Tile Usage Policy: you must display attribution ('© OpenStreetMap contributors'), cache tiles when possible, and not use them for high-traffic commercial apps without self-hosting. For high-traffic production apps, consider running your own tile server, using a commercial provider like Stadia Maps, or switching to Mapbox/Cloudflare."
  },
  {
    question: "How do I use the generated code in a React app?",
    answer: "Import Leaflet and its CSS: import L from 'leaflet'; import 'leaflet/dist/leaflet.css'. Create the map inside a useEffect with an empty dependency array, and return a cleanup function: useEffect(() => { const map = L.map('map').setView([lat, lng], zoom); L.tileLayer(...).addTo(map); return () => map.remove(); }, []). The map.remove() cleanup prevents 'Map container is already initialized' errors in React strict mode."
  },
  {
    question: "What is the difference between Marker, Circle, and Polygon layers?",
    answer: "Markers are pin icons placed at a lat/lng coordinate — great for points of interest with popup labels. Circles are drawn with a center point and radius in meters — useful for showing proximity zones (e.g. delivery radius, sensor range). Polygons define arbitrary shapes with multiple vertices — perfect for regions, districts, or boundaries. All three can have custom colors and click handlers."
  },
  {
    question: "How do I fix the default Leaflet marker icon not showing in webpack/Vite?",
    answer: "This is a known Leaflet + bundler issue caused by how Leaflet resolves image URLs. Fix: import markerIcon2x from 'leaflet/dist/images/marker-icon-2x.png'; import markerIcon from 'leaflet/dist/images/marker-icon.png'; import markerShadow from 'leaflet/dist/images/marker-shadow.png'; delete L.Icon.Default.prototype._getIconUrl; L.Icon.Default.mergeOptions({ iconUrl: markerIcon, iconRetinaUrl: markerIcon2x, shadowUrl: markerShadow }); Add this once at app initialization."
  },
];
---

<BaseLayout
  title="Leaflet Map Config Builder — Generate Leaflet.js Initialization Code"
  description="Generate Leaflet.js map configuration and initialization code. Choose tile provider (OSM, CartoDB, Mapbox), set center coordinates and zoom, add marker/circle/polygon layers. CDN and npm output. Free, runs in your browser."
  tool="leaflet map setup, leaflet js configuration, leaflet map generator, leaflet initialization code"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Leaflet Map Config Builder",
    "url": "https://devplaybook.cc/tools/leaflet-map-config-builder",
    "description": "Generate Leaflet.js map configuration and initialization code for OpenStreetMap, CartoDB, Mapbox, and other tile providers.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Leaflet Map Config Builder</h1>
  <p class="text-text-muted mb-4">
    Generate <strong>Leaflet.js</strong> map initialization code visually. Pick a tile provider (OpenStreetMap, CartoDB, Mapbox),
    set center coordinates and zoom level, add marker, circle, and polygon layers —
    get copy-ready CDN HTML or npm ES module code instantly.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 6 tile providers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Marker / Circle / Polygon</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CDN & npm output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> React cleanup included</span>
  </div>
  <LeafletMapConfigBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Leaflet Map Config Builder" relatedTags={['maps', 'javascript', 'geolocation', 'visualization', 'developer-tools']} />
</BaseLayout>
