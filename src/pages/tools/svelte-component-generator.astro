---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SvelteComponentGenerator from '../../components/SvelteComponentGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the difference between Svelte 5 runes and Svelte 4 reactive syntax?",
    answer: "Svelte 5 introduced runes — a set of compiler hints prefixed with $ that make reactivity explicit. Instead of `let count = 0` (Svelte 4, where any top-level let was reactive), you now write `let count = $state(0)`. Similarly, $props() replaces `export let`, $derived() replaces `$:` reactive declarations, and $effect() replaces `onMount` + reactive blocks. Runes work inside any .svelte.ts file, not just components."
  },
  {
    question: "How do I pass props in Svelte 5?",
    answer: "In Svelte 5, props are declared with `$props()`: `let { title, count = 0 }: { title: string; count?: number } = $props()`. You can destructure with defaults inline. This replaces `export let title: string` from Svelte 4. For spread props, use `let { ...rest } = $props()`. The TypeScript interface provides type safety without a separate `defineProps` call."
  },
  {
    question: "How do events work in Svelte 5 vs Svelte 4?",
    answer: "In Svelte 4, components emitted events via `createEventDispatcher`. Svelte 5 replaces this with callback props — you accept an `onEventName` function prop and call it directly, which is more TypeScript-friendly and avoids event bubbling surprises. Example: `let { onSubmit }: { onSubmit: (data: FormData) => void } = $props()`. In templates, use `onclick` (lowercase) instead of `on:click`."
  },
  {
    question: "What does $effect() do in Svelte 5?",
    answer: "$effect() runs a side effect whenever its reactive dependencies change — similar to React's useEffect but without a dependency array. It tracks dependencies automatically. Return a cleanup function to run before the effect re-runs or the component unmounts. Use $effect.pre() to run before DOM updates. For one-time setup, $effect() with no reactive reads acts like onMount."
  },
  {
    question: "When should I use $derived() vs computed values?",
    answer: "$derived() creates a reactive value that recomputes whenever its dependencies change. Use it for values computed from state: `let total = $derived(items.reduce((s, i) => s + i.price, 0))`. Unlike $effect(), $derived() is pure (no side effects) and lazy (only recomputes when read). For complex multi-statement derivations, use `$derived.by(() => { ... return value; })`."
  },
  {
    question: "What is the Svelte component file structure?",
    answer: "A .svelte file has three optional sections: `<script>` (or `<script lang='ts'>`) for logic, the template (HTML with Svelte directives, no wrapper tag needed), and `<style>` for scoped CSS. In Svelte 5, use `<script lang='ts'>` at the top. Svelte automatically scopes styles to the component, so `.button` in a component won't affect other `.button` elements globally."
  },
];
---

<BaseLayout
  title="Svelte Component Generator — Svelte 5 Runes Boilerplate Builder"
  description="Generate Svelte 5 component boilerplate with runes syntax ($state, $props, $derived, $effect), props, events, and lifecycle. Also supports Svelte 4 legacy syntax. Runs in your browser."
  tool="svelte component generator, svelte 5 runes, svelte boilerplate, svelte template, svelte props generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Svelte Component Generator",
    "url": "https://devplaybook.cc/tools/svelte-component-generator",
    "description": "Generate Svelte 5 component boilerplate with runes syntax, props, events, and lifecycle hooks. Supports Svelte 4 legacy mode. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Svelte Component Generator</h1>
  <p class="text-text-muted mb-4">
    Generate Svelte 5 component boilerplate with the new runes API —
    <code class="font-mono text-sm bg-bg-card px-1 rounded">$state</code>,
    <code class="font-mono text-sm bg-bg-card px-1 rounded">$props</code>,
    <code class="font-mono text-sm bg-bg-card px-1 rounded">$derived</code>, and
    <code class="font-mono text-sm bg-bg-card px-1 rounded">$effect</code>.
    Define your props, events, and lifecycle hooks, then copy the ready-to-paste <code class="font-mono text-sm bg-bg-card px-1 rounded">.svelte</code> file.
    Switch to Svelte 4 legacy mode for older projects.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Svelte 5 runes syntax</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript-first props</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Svelte 4 legacy mode</span>
  </div>
  <SvelteComponentGenerator client:only="preact" />

  <section class="mt-12 space-y-8 text-sm text-text-muted">
    <div>
      <h2 class="text-xl font-semibold text-text mb-3">Svelte 5 Runes vs Svelte 4: A Quick Comparison</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-xs font-mono">
          <thead>
            <tr class="border-b border-border">
              <th class="text-left py-2 pr-4 text-text font-semibold">Concept</th>
              <th class="text-left py-2 pr-4 text-text font-semibold">Svelte 4</th>
              <th class="text-left py-2 text-text font-semibold">Svelte 5 (Runes)</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border/50">
            <tr>
              <td class="py-2 pr-4 text-text">Reactive state</td>
              <td class="py-2 pr-4">let count = 0</td>
              <td class="py-2">let count = $state(0)</td>
            </tr>
            <tr>
              <td class="py-2 pr-4 text-text">Props</td>
              <td class="py-2 pr-4">export let title: string</td>
              <td class="py-2">let &#123; title &#125; = $props()</td>
            </tr>
            <tr>
              <td class="py-2 pr-4 text-text">Derived values</td>
              <td class="py-2 pr-4">$: doubled = count * 2</td>
              <td class="py-2">let doubled = $derived(count * 2)</td>
            </tr>
            <tr>
              <td class="py-2 pr-4 text-text">Side effects</td>
              <td class="py-2 pr-4">$: &#123; sideEffect() &#125;</td>
              <td class="py-2">$effect(() =&gt; &#123; sideEffect() &#125;)</td>
            </tr>
            <tr>
              <td class="py-2 pr-4 text-text">Events</td>
              <td class="py-2 pr-4">createEventDispatcher</td>
              <td class="py-2">Callback props (onEventName)</td>
            </tr>
            <tr>
              <td class="py-2 pr-4 text-text">Lifecycle</td>
              <td class="py-2 pr-4">onMount / onDestroy</td>
              <td class="py-2">$effect + cleanup return</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div>
      <h2 class="text-xl font-semibold text-text mb-3">Svelte 5 Props with TypeScript</h2>
      <p class="mb-3">
        The runes API brings fully typed props without a separate interface declaration step. You define
        the type inline with destructuring:
      </p>
      <pre class="bg-surface border border-border rounded-lg p-4 text-xs font-mono overflow-auto"><code>{`<script lang="ts">
  // Typed props with defaults
  let {
    title,
    count = 0,
    items = [],
    onSelect,
  }: {
    title: string;
    count?: number;
    items?: string[];
    onSelect?: (item: string) => void;
  } = $props();

  // Derived value
  let total = $derived(items.length + count);

  // Effect with cleanup
  $effect(() => {
    const id = setInterval(() => console.log(count), 1000);
    return () => clearInterval(id);
  });
</script>`}</code></pre>
    </div>

    <div>
      <h2 class="text-xl font-semibold text-text mb-3">When to Use Svelte 4 Legacy Mode</h2>
      <p>
        Choose Svelte 4 mode when working on existing projects that haven't migrated to Svelte 5,
        or when using libraries that depend on the legacy compiler behavior (like SvelteKit 1.x projects).
        The <code class="font-mono text-xs bg-surface px-1 rounded">createEventDispatcher</code> pattern and
        <code class="font-mono text-xs bg-surface px-1 rounded">export let</code> syntax remain fully supported
        in Svelte 5 for backwards compatibility, but new projects should prefer runes.
      </p>
    </div>

    <div>
      <h2 class="text-xl font-semibold text-text mb-3">Component File Checklist</h2>
      <ul class="space-y-1 list-disc list-inside">
        <li>Use PascalCase for component filenames (<code class="font-mono text-xs bg-surface px-1 rounded">MyButton.svelte</code>)</li>
        <li>Prefer <code class="font-mono text-xs bg-surface px-1 rounded">lang="ts"</code> for TypeScript benefits even in Svelte 4</li>
        <li>Keep <code class="font-mono text-xs bg-surface px-1 rounded">&lt;style&gt;</code> scoped (the default) — use <code class="font-mono text-xs bg-surface px-1 rounded">:global()</code> sparingly</li>
        <li>For Svelte 5, avoid mixing <code class="font-mono text-xs bg-surface px-1 rounded">$state</code> with non-reactive objects — deep reactivity needs explicit <code class="font-mono text-xs bg-surface px-1 rounded">$state()</code></li>
        <li>Use <code class="font-mono text-xs bg-surface px-1 rounded">$inspect()</code> during development for reactive value debugging</li>
      </ul>
    </div>
  </section>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Svelte Component Generator" relatedTags={['frontend', 'svelte', 'javascript', 'typescript', 'components']} />
</BaseLayout>
