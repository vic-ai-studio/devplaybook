---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TextDiff from '../../components/TextDiff.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---
<BaseLayout
  title="Text Diff Checker"
  description="Compare two blocks of text side-by-side with line-by-line diff highlighting. See added lines in green, removed lines in red, and unchanged lines inline. Copy the diff summary instantly. Runs entirely in your browser."
  tool="Text Diff, Line Diff, File Comparison, Diff Checker"
>
  <h1 class="text-3xl font-bold mb-2">Text Diff Checker</h1>
  <p class="text-text-muted mb-8">Paste two versions of any text and get an instant line-by-line diff. Added lines are highlighted green, removed lines red. Everything runs in your browser — nothing is sent to any server.</p>
  <TextDiff client:only="preact" />
  <ToolPageCta currentTool="Text Diff Checker" relatedTags={['diff', 'text', 'comparison', 'productivity']} />
</BaseLayout>
