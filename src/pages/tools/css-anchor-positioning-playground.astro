---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CssAnchorPositioning from '../../components/CssAnchorPositioning.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is CSS Anchor Positioning?", answer: "CSS Anchor Positioning is a new browser API that lets you position one element relative to another — called an anchor — without JavaScript. You give the anchor element a name with anchor-name: --my-anchor, then point a floating element at it with position-anchor: --my-anchor and place it with inset-area." },
  { question: "What is anchor-name?", answer: "anchor-name is a CSS property that registers an element as an anchor point. You provide a dashed-ident name (like --my-button). Floating elements can then reference this name with position-anchor to attach themselves to the anchor." },
  { question: "What is inset-area?", answer: "inset-area is a CSS property that replaces complex top/left/inset calculations with semantic placement values. Instead of calculating offsets manually, you write inset-area: top to place the floating element above the anchor, inset-area: bottom right to put it to the bottom-right, etc." },
  { question: "What is position-try-fallbacks?", answer: "position-try-fallbacks lets the browser automatically try alternative positions if the element would overflow the viewport. For example, a tooltip anchored to top will flip to bottom if there's no room above. Values include flip-block, flip-inline, and their combination." },
  { question: "How does CSS Anchor Positioning compare to Floating UI or Popper.js?", answer: "Floating UI and Popper.js solve the same problem with JavaScript — computing position, handling scroll, and detecting overflow. CSS Anchor Positioning moves all of this to the browser's CSS engine, eliminating JS overhead, reflow thrashing, and library dependencies. For simple use cases, native anchor positioning is faster and simpler." },
];
---

<BaseLayout
  title="CSS Anchor Positioning Playground — anchor-name & inset-area Generator"
  description="Visual CSS Anchor Positioning API playground. Configure anchor-name, position-anchor, and inset-area to generate tooltip and popover CSS. Live preview with 9 placement positions and browser support check."
  tool="CSS Anchor Positioning, anchor-name CSS, position-anchor, inset-area, CSS Tooltip Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">CSS Anchor Positioning Playground</h1>
  <p class="text-text-muted mb-4">
    Build floating UI elements (tooltips, popovers, dropdowns) without JavaScript using the CSS Anchor Positioning API.
    Configure placement with <code>anchor-name</code>, <code>position-anchor</code>, and <code>inset-area</code> — then copy the generated CSS.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <CssAnchorPositioning client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CSS Anchor Positioning Playground" relatedTags={['css', 'anchor-positioning', 'tooltip', 'popover', 'frontend', 'browser-api']} />
</BaseLayout>
