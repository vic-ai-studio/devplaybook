---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CronGenerator from '../../components/CronGenerator.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is a cron expression?", answer: "A cron expression is a 5-field string (minute, hour, day-of-month, month, day-of-week) that defines a recurring schedule. For example, '0 9 * * 1' runs every Monday at 9:00 AM. Cron is used in Linux, CI/CD pipelines, cloud functions, GitHub Actions, and task schedulers." },
  { question: "How do I schedule a job to run every 5 minutes?", answer: "Use '*/5 * * * *'. The '*/5' in the minute field means 'every 5th minute starting from 0'. Similarly, '*/10' runs every 10 minutes and '*/30' every 30 minutes. You can use the step syntax (*/n) in any field." },
  { question: "How do I run a cron job on weekdays only?", answer: "Use '0 9 * * 1-5' to run at 9 AM Monday through Friday. The day-of-week field '1-5' means Mon(1) through Fri(5). For weekends only, use '0,6' or 'SAT,SUN' in the day-of-week field." },
  { question: "What does * mean in a cron expression?", answer: "An asterisk (*) means 'every possible value' for that field. '* * * * *' runs every minute of every hour of every day. You can also use ranges (1-5), lists (1,3,5), and step values (*/15)." },
  { question: "Is there a difference between cron-builder and cron-generator?", answer: "Both tools help you build cron expressions. The cron builder focuses on interactive construction — choose from presets and see the plain-English description. The cron validator helps you verify an existing expression. Use whichever fits your workflow." },
];
---

<BaseLayout
  title="Cron Expression Builder — Build Cron Schedules Visually"
  description="Build cron expressions visually and see the next run times in plain English. Choose from presets for every minute, hourly, daily, weekly. Free, runs in your browser, no signup."
  tool="Cron Builder, Cron Expression Builder, Cron Schedule Builder, Cron Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Cron Expression Builder</h1>
  <p class="text-text-muted mb-4">Build cron expressions by selecting presets or entering each field manually. See the next run times in plain English, then copy the expression for use in GitHub Actions, Linux crontab, AWS EventBridge, or any task scheduler.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <CronGenerator client:load />
  <!-- Ad slot below tool output — highest CTR position (user pauses after using the tool) -->
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <AffiliateSection category="cicd" />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Need to validate an existing cron expression?</p>
    <a href="/tools/cron-validator" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Cron Expression Validator →</a>
  </div>
  <ToolPageCta currentTool="Cron Expression Builder" relatedTags={['automation', 'devops', 'ci-cd', 'bash', 'linux']} />
</BaseLayout>
