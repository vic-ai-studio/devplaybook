---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RegexVisualizer from '../../components/RegexVisualizer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a regex capture group?", answer: "A capture group is a part of a regex pattern wrapped in parentheses, like (\\d+). It 'captures' the matched text so you can reference it separately from the full match. For example, in (\\d{4})-(\\d{2}), the first group captures the year and the second captures the month. Capture groups are numbered left to right by their opening parenthesis." },
  { question: "What is a named capture group?", answer: "A named capture group uses the syntax (?<name>pattern) to give a group a human-readable name instead of just a number. For example, (?<year>\\d{4})-(?<month>\\d{2}) lets you access the year and month by name in your code. Named groups make complex regexes much more readable and maintainable." },
  { question: "What do the regex flags mean?", answer: "The common flags are: g (global) — find all matches, not just the first; i (case-insensitive) — match uppercase and lowercase the same; m (multiline) — ^ and $ match start/end of each line; s (dotall) — the dot (.) matches newlines too; u (unicode) — enables full Unicode support including \\p{} properties. You can combine flags freely." },
  { question: "What is the difference between regex-visualizer and regex-tester?", answer: "The Regex Visualizer focuses on showing you exactly what each match and capture group contains, with color-coded highlighting for multiple matches. The Regex Tester lets you run assertions (expected match / no-match) to build a test suite for your patterns. Use the visualizer to debug and understand a regex, and the tester to validate it against known cases." },
  { question: "Why does my regex match too much or too little?", answer: "Common causes: missing the g flag (only finds first match), greedy vs lazy quantifiers (use +? or *? for lazy), forgetting to escape special characters like . () [] with a backslash, and anchor misuse (^ and $ match line start/end in multiline mode but string start/end otherwise). Try the presets to see working examples, then modify from there." },
];
---

<BaseLayout
  title="Regex Visualizer — Test Regex with Match Highlighting & Group Capture"
  description="Free regex visualizer. Test regular expressions with color-coded match highlighting, capture group inspection, and named group support. Supports all flags (g, i, m, s, u). Runs entirely in your browser."
  tool="Regex Visualizer, Regex Tester, Regex Match Highlighter, Capture Group Inspector, Named Groups, JavaScript Regex, Regex Flags"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Regex Visualizer</h1>
  <p class="text-text-muted mb-4">Test regular expressions with live match highlighting. See every match color-coded in your test string, inspect capture groups and named groups, toggle flags interactively, and use presets for common patterns like email, IPv4, and dates. Runs in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Match highlighting + group capture</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Named groups + all flags</span>
  </div>
  <RegexVisualizer client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Regex Visualizer" relatedTags={['regex', 'string', 'testing', 'debugging', 'javascript']} />
</BaseLayout>
