---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HtmlEntityEncoder from '../../components/HtmlEntityEncoder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What are HTML entities and when do I need them?", answer: "HTML entities are special character codes like &amp;lt; for < and &amp;amp; for &. You need them when embedding user-generated content in HTML (to prevent XSS), writing HTML inside attributes, or displaying characters that would otherwise be interpreted as markup." },
  { question: "What is the difference between encoding and escaping HTML?", answer: "HTML encoding and HTML escaping mean the same thing: replacing special characters with their entity equivalents so they render as text, not markup. The term 'escaping' comes from programming contexts; 'encoding' is the broader term. Both produce the same &amp;lt; &amp;gt; &amp;amp; output." },
  { question: "Which characters must always be encoded in HTML?", answer: "The five critical characters are: < (&amp;lt;), > (&amp;gt;), & (&amp;amp;), \" (&amp;quot;), and ' (&amp;#39;). These have special meaning in HTML and will break your markup if left unencoded inside content or attributes." },
  { question: "Does encoding HTML prevent XSS attacks?", answer: "Yes — properly encoding user input before inserting it into HTML is the primary defense against reflected and stored XSS. Always encode on output, not input, and make sure to use context-appropriate encoding (HTML body vs. attribute vs. JavaScript context)." },
  { question: "Is my data sent to any server?", answer: "No. All encoding and decoding runs entirely in your browser with JavaScript. Your text never leaves your machine — safe to use with sensitive content, internal code, and production HTML." },
];
---

<BaseLayout
  title="HTML Entity Encoder / Decoder — Free Online Tool"
  description="Encode HTML special characters to entities and decode HTML entities back to text. Convert &lt; &gt; &amp; &quot; and 50+ named entities. Prevent XSS — free, runs 100% in your browser."
  tool="HTML Entity Encoder, HTML Decode, HTML Escape, HTML Entities, XSS prevention, encode HTML"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">HTML Entity Encoder / Decoder</h1>
  <p class="text-text-muted mb-4">Encode text with special characters into safe HTML entities, or decode <code class="bg-bg-secondary px-1 rounded text-sm">&amp;lt;</code> <code class="bg-bg-secondary px-1 rounded text-sm">&amp;gt;</code> <code class="bg-bg-secondary px-1 rounded text-sm">&amp;amp;</code> and other entities back to plain text. Essential for XSS prevention and safe HTML embedding.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 50+ named entities</span>
  </div>
  <HtmlEntityEncoder client:only="preact" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more free developer tools?</p>
    <a href="/tools" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Browse All Free Tools →</a>
  </div>
  <ToolPageCta currentTool="HTML Entity Encoder / Decoder" relatedTags={['html', 'encoding', 'web', 'security', 'xss']} />
</BaseLayout>
