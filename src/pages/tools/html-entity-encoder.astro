---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HtmlEntityEncoder from '../../components/HtmlEntityEncoder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="HTML Entity Encoder / Decoder"
  description="Encode HTML special characters to entities and decode HTML entities back to text. Convert &lt; &gt; &amp; &quot; and 50+ named entities. Free, runs in browser."
  tool="HTML Entity Encoder, HTML Decode, HTML Escape, HTML Entities"
>
  <h1 class="text-3xl font-bold mb-2">HTML Entity Encoder / Decoder</h1>
  <p class="text-text-muted mb-8">Encode text with special characters into safe HTML entities, or decode &amp;lt; &amp;gt; &amp;amp; and other entities back to plain text. Useful for embedding user content in HTML safely.</p>
  <HtmlEntityEncoder client:load />
  <ToolPageCta currentTool="HTML Entity Encoder" relatedTags={['html', 'encoding', 'web', 'security']} />
</BaseLayout>
