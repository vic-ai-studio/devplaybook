---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "Which model has the largest context window?", answer: "As of early 2025, Gemini 1.5 Pro supports 1M tokens (with 2M in preview), making it the largest context window for production use. Claude 3.5 supports 200K and GPT-4o supports 128K. For most tasks, 128K is more than sufficient." },
  { question: "What does 'knowledge cutoff' mean?", answer: "The knowledge cutoff is the date after which the model has no training data. It does not know about events, libraries, or code changes after this date. For real-time tasks, combine models with RAG or web search tools." },
  { question: "OpenAI vs Anthropic vs Google — which should I use?", answer: "GPT-4o excels at code, structured output, and tool use. Claude 3.5 Sonnet excels at long-document analysis, reasoning, and instruction following. Gemini 1.5 Pro excels at very long contexts and multimodal tasks. Run your specific task benchmark before committing." },
  { question: "Are these prices accurate?", answer: "Prices shown are as of Q1 2025. LLM pricing changes frequently. Always verify at the official provider pricing pages: platform.openai.com/pricing, anthropic.com/pricing, and ai.google.dev/pricing." },
];
---

<BaseLayout
  title="AI Model Comparison Table 2025 — GPT-4o vs Claude vs Gemini"
  description="Compare GPT-4o, Claude 3.5, Gemini 1.5, and Llama specs side by side: context window, pricing, knowledge cutoff, multimodal support, and best use cases."
  tool="AI model comparison 2025, GPT-4o vs Claude, LLM comparison table, AI model specs, context window comparison"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">AI Model Comparison Table</h1>
  <p class="text-text-muted mb-6">Compare leading LLMs on context window, pricing, multimodal support, and ideal use cases. Filter by provider or use case.</p>

  <div class="flex flex-wrap gap-2 mb-6">
    <button data-filter="all" class="filter-btn active px-3 py-1.5 rounded-lg text-sm border border-primary bg-primary/10 text-primary transition-colors">All Models</button>
    <button data-filter="OpenAI" class="filter-btn px-3 py-1.5 rounded-lg text-sm border border-border text-text-muted hover:border-primary hover:text-primary transition-colors">OpenAI</button>
    <button data-filter="Anthropic" class="filter-btn px-3 py-1.5 rounded-lg text-sm border border-border text-text-muted hover:border-primary hover:text-primary transition-colors">Anthropic</button>
    <button data-filter="Google" class="filter-btn px-3 py-1.5 rounded-lg text-sm border border-border text-text-muted hover:border-primary hover:text-primary transition-colors">Google</button>
    <button data-filter="Meta" class="filter-btn px-3 py-1.5 rounded-lg text-sm border border-border text-text-muted hover:border-primary hover:text-primary transition-colors">Meta (Open)</button>
  </div>

  <div class="overflow-x-auto mb-8">
    <table class="w-full text-sm min-w-[800px]">
      <thead>
        <tr class="text-text-muted text-xs uppercase border-b border-border">
          <th class="text-left pb-3 pr-3 font-medium">Model</th>
          <th class="text-right pb-3 pr-3 font-medium">Context</th>
          <th class="text-right pb-3 pr-3 font-medium">$/1M In</th>
          <th class="text-right pb-3 pr-3 font-medium">$/1M Out</th>
          <th class="text-center pb-3 pr-3 font-medium">Vision</th>
          <th class="text-center pb-3 pr-3 font-medium">Tool Use</th>
          <th class="text-left pb-3 pr-3 font-medium">Knowledge Cut</th>
          <th class="text-left pb-3 font-medium">Best For</th>
        </tr>
      </thead>
      <tbody id="model-tbody" class="divide-y divide-border"></tbody>
    </table>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <div class="text-xs text-text-muted mb-2 uppercase font-medium">Largest Context</div>
      <div class="font-bold text-lg">Gemini 1.5 Pro</div>
      <div class="text-sm text-text-muted">1M tokens (2M preview)</div>
    </div>
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <div class="text-xs text-text-muted mb-2 uppercase font-medium">Best Value (flagship)</div>
      <div class="font-bold text-lg">Claude 3.5 Sonnet</div>
      <div class="text-sm text-text-muted">$3/1M in · $15/1M out</div>
    </div>
    <div class="bg-bg-card border border-border rounded-lg p-4">
      <div class="text-xs text-text-muted mb-2 uppercase font-medium">Cheapest Capable</div>
      <div class="font-bold text-lg">GPT-4o Mini</div>
      <div class="text-sm text-text-muted">$0.15/1M in · $0.60/1M out</div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="AI Model Comparison Table" relatedTags={['ai', 'openai', 'claude', 'gemini', 'llm', 'comparison']} />
</BaseLayout>

<script>
  interface ModelSpec {
    name: string;
    provider: string;
    contextK: number;
    inputPriceM: number;
    outputPriceM: number;
    vision: boolean;
    toolUse: boolean;
    cutoff: string;
    bestFor: string;
  }

  const MODELS: ModelSpec[] = [
    { name: 'GPT-4o', provider: 'OpenAI', contextK: 128, inputPriceM: 5.00, outputPriceM: 15.00, vision: true, toolUse: true, cutoff: 'Oct 2023', bestFor: 'Code, tool use, structured output' },
    { name: 'GPT-4o Mini', provider: 'OpenAI', contextK: 128, inputPriceM: 0.15, outputPriceM: 0.60, vision: true, toolUse: true, cutoff: 'Oct 2023', bestFor: 'High-volume classification, extraction' },
    { name: 'GPT-4 Turbo', provider: 'OpenAI', contextK: 128, inputPriceM: 10.00, outputPriceM: 30.00, vision: true, toolUse: true, cutoff: 'Apr 2023', bestFor: 'Complex reasoning, legacy compatibility' },
    { name: 'o1', provider: 'OpenAI', contextK: 128, inputPriceM: 15.00, outputPriceM: 60.00, vision: false, toolUse: false, cutoff: 'Oct 2023', bestFor: 'Math, science, multi-step reasoning' },
    { name: 'Claude 3.5 Sonnet', provider: 'Anthropic', contextK: 200, inputPriceM: 3.00, outputPriceM: 15.00, vision: true, toolUse: true, cutoff: 'Apr 2024', bestFor: 'Long docs, instruction following, coding' },
    { name: 'Claude 3.5 Haiku', provider: 'Anthropic', contextK: 200, inputPriceM: 0.80, outputPriceM: 4.00, vision: true, toolUse: true, cutoff: 'Jul 2024', bestFor: 'Fast responses, chat, simple tasks' },
    { name: 'Claude 3 Opus', provider: 'Anthropic', contextK: 200, inputPriceM: 15.00, outputPriceM: 75.00, vision: true, toolUse: true, cutoff: 'Aug 2023', bestFor: 'Deep analysis, research, complex writing' },
    { name: 'Gemini 1.5 Pro', provider: 'Google', contextK: 1000, inputPriceM: 3.50, outputPriceM: 10.50, vision: true, toolUse: true, cutoff: 'Nov 2023', bestFor: 'Very long contexts, multimodal, video' },
    { name: 'Gemini 1.5 Flash', provider: 'Google', contextK: 1000, inputPriceM: 0.075, outputPriceM: 0.30, vision: true, toolUse: true, cutoff: 'Nov 2023', bestFor: 'Long-context at low cost, summarization' },
    { name: 'Llama 3.1 70B', provider: 'Meta', contextK: 128, inputPriceM: 0.90, outputPriceM: 0.90, vision: false, toolUse: true, cutoff: 'Dec 2023', bestFor: 'Open source, self-hosted, privacy' },
    { name: 'Llama 3.1 405B', provider: 'Meta', contextK: 128, inputPriceM: 5.00, outputPriceM: 5.00, vision: false, toolUse: true, cutoff: 'Dec 2023', bestFor: 'Open source flagship, fine-tuning base' },
    { name: 'Mistral Large', provider: 'Mistral', contextK: 128, inputPriceM: 4.00, outputPriceM: 12.00, vision: false, toolUse: true, cutoff: 'Sep 2023', bestFor: 'European compliance, multilingual' },
  ];

  let activeFilter = 'all';

  function fmtCtx(k: number): string {
    return k >= 1000 ? (k / 1000) + 'M' : k + 'K';
  }

  function renderTable(filter: string) {
    const tbody = document.getElementById('model-tbody')!;
    const filtered = filter === 'all' ? MODELS : MODELS.filter(m => m.provider === filter);
    tbody.innerHTML = filtered.map(m => `
      <tr class="hover:bg-bg-card/50 transition-colors">
        <td class="py-3 pr-3">
          <span class="font-semibold">${m.name}</span>
          <span class="text-xs text-text-muted ml-2">${m.provider}</span>
        </td>
        <td class="py-3 pr-3 text-right tabular-nums font-medium">${fmtCtx(m.contextK)}</td>
        <td class="py-3 pr-3 text-right tabular-nums">${m.inputPriceM < 1 ? '$' + m.inputPriceM.toFixed(3) : '$' + m.inputPriceM.toFixed(2)}</td>
        <td class="py-3 pr-3 text-right tabular-nums">${m.outputPriceM < 1 ? '$' + m.outputPriceM.toFixed(3) : '$' + m.outputPriceM.toFixed(2)}</td>
        <td class="py-3 pr-3 text-center">${m.vision ? '<span class="text-green-400">✓</span>' : '<span class="text-text-muted">—</span>'}</td>
        <td class="py-3 pr-3 text-center">${m.toolUse ? '<span class="text-green-400">✓</span>' : '<span class="text-text-muted">—</span>'}</td>
        <td class="py-3 pr-3 text-text-muted text-xs">${m.cutoff}</td>
        <td class="py-3 text-xs text-text-muted">${m.bestFor}</td>
      </tr>`).join('');
  }

  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => {
        b.classList.remove('active', 'border-primary', 'bg-primary/10', 'text-primary');
        b.classList.add('border-border', 'text-text-muted');
      });
      btn.classList.add('active', 'border-primary', 'bg-primary/10', 'text-primary');
      btn.classList.remove('border-border', 'text-text-muted');
      activeFilter = (btn as HTMLElement).dataset.filter || 'all';
      renderTable(activeFilter);
    });
  });

  renderTable('all');
</script>
