---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NeonDbQueryBuilder from '../../components/NeonDbQueryBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Neon and how does it differ from regular PostgreSQL?", answer: "Neon is a serverless PostgreSQL platform that separates storage and compute. It features branching (like Git branches for databases), autoscaling to zero when idle, and a serverless HTTP driver (@neondatabase/serverless) that works in edge runtimes like Cloudflare Workers and Vercel Edge Functions where TCP connections aren't available." },
  { question: "What is the @neondatabase/serverless driver?", answer: "It's Neon's JavaScript/TypeScript driver that uses HTTP or WebSockets instead of TCP, making it compatible with serverless and edge runtimes. Use the neon() tagged template literal for simple queries, or neonConfig + Pool for connection pooling in long-running environments." },
  { question: "How do parameterized queries work with the neon() driver?", answer: "The neon() tagged template literal automatically parameterizes values for safety. Write: sql`SELECT * FROM users WHERE id = ${userId}` and the driver handles escaping. Never use string concatenation for user input — always use template literal interpolation or the $1, $2 positional parameters." },
  { question: "What is the difference between neon() and Pool/Client?", answer: "neon() uses HTTP for each query — best for serverless/edge functions with stateless, short-lived requests. Pool and Client use WebSockets and maintain connections — better for long-running Node.js servers or when you need transactions across multiple queries." },
  { question: "Does Drizzle ORM work with Neon?", answer: "Yes. drizzle-orm/neon-http wraps the @neondatabase/serverless HTTP driver. You get type-safe queries with Drizzle's schema definition and query builder, combined with Neon's serverless/edge compatibility. Use drizzle-orm/neon-serverless for WebSocket-based connections with transaction support." },
  { question: "How do I use database branching in Neon?", answer: "Neon branches are instant copies of your database (like git branches) created from a shared storage layer — no data copying needed. Create a branch for each PR or feature, test schema changes safely, then merge via SQL migrations. Use the Neon CLI: neonctl branches create --name feature/my-feature" },
];
---

<BaseLayout
  title="Neon DB Query Builder — Serverless PostgreSQL Code Generator"
  description="Visual query builder for Neon serverless PostgreSQL. Generate raw SQL, @neondatabase/serverless TypeScript, and Drizzle ORM code. Interactive column editor, WHERE conditions, ORDER BY, LIMIT. Free, runs in browser."
  tool="Neon DB query builder, neon serverless postgresql, @neondatabase/serverless generator, drizzle neon typescript, neon sql generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Neon DB Query Builder",
    "url": "https://devplaybook.cc/tools/neon-db-query-builder",
    "description": "Visual query builder for Neon serverless PostgreSQL. Generates raw SQL, @neondatabase/serverless TypeScript, and Drizzle ORM code.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Neon DB Query Builder</h1>
  <p class="text-text-muted mb-4">
    Visual query builder for <strong>Neon serverless PostgreSQL</strong>. Define your table schema, pick columns, add WHERE conditions, and generate ready-to-paste <strong>SQL</strong>, <strong>@neondatabase/serverless TypeScript</strong>, or <strong>Drizzle ORM</strong> code.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> SELECT / INSERT / UPDATE / DELETE</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> @neondatabase/serverless + Drizzle output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs in browser — no data sent anywhere</span>
  </div>
  <NeonDbQueryBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Neon DB Query Builder" relatedTags={['database', 'postgresql', 'serverless', 'typescript', 'developer-tools']} />
</BaseLayout>
