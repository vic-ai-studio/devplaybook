---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DependencyVersionChecker from '../../components/DependencyVersionChecker.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What version range patterns does this tool analyze?",
    answer: "Six patterns: exact versions (4.17.21 — reproducible but no security patches), caret (^18.2.0 — allows minor/patch updates), tilde (~1.2.3 — patch-only, conservative), wildcard (* or latest — anything goes, high risk), version ranges (>=27 <30), and URL/Git dependencies (github:org/repo — not version-pinned)."
  },
  {
    question: "Why is ^ on version 0.x flagged as high risk?",
    answer: "Semver convention says 0.x versions are pre-stable. The semver spec states that the minor version may include breaking changes when major is 0. So ^0.21.0 allows any 0.x.y update, and those can break your code. Libraries like Axios used 0.x for years during active API churn."
  },
  {
    question: "What is the difference between ^ and ~?",
    answer: "Caret (^) locks the leftmost non-zero digit: ^1.2.3 allows up to <2.0.0, ^0.2.3 allows up to <0.3.0. Tilde (~) locks to the patch range: ~1.2.3 allows >=1.2.3 <1.3.0. Tilde is more conservative and better for production where you want minimal unexpected changes."
  },
  {
    question: "Should I use exact versions or ranges?",
    answer: "Exact versions give fully reproducible installs but require manual updates — you will miss security patches. Ranges (^ or ~) with a lockfile (package-lock.json or yarn.lock) are the most common production approach: ranges allow flexibility, the lockfile pins exact resolved versions. Always commit your lockfile."
  },
  {
    question: "What is a URL or Git dependency risk?",
    answer: "Dependencies like 'github:org/repo#main' resolve to a branch tip at install time. There is no semver contract — a push to that branch can silently break your build. Use Git tags or commit SHAs (github:org/repo#v1.2.3) if you must use a Git source."
  },
  {
    question: "Does this tool check if packages are outdated?",
    answer: "No — this tool analyzes version range patterns and risk level from your package.json without making network calls. It does not query the npm registry. To check for actual outdated packages, run 'npm outdated' or 'npx npm-check-updates' in your terminal."
  },
];
---

<BaseLayout
  title="Dependency Version Checker — Analyze package.json Version Range Risks"
  description="Paste your package.json and analyze all dependency version ranges. Identifies wildcards, caret on 0.x, URL/Git deps, and ambiguous ranges. Risk-scored and filterable. Runs 100% in your browser."
  tool="npm dependency checker, package.json version analyzer, semver risk checker, dependency audit, version range analyzer"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Dependency Version Checker",
    "url": "https://devplaybook.cc/tools/dependency-version-checker",
    "description": "Analyze package.json dependency version ranges for semver risks. Runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Dependency Version Checker</h1>
  <p class="text-text-muted mb-4">
    Paste your <code class="font-mono bg-surface px-1 rounded text-sm">package.json</code> and analyze every
    dependency's version range. Catches wildcards, risky caret ranges on 0.x packages, URL/Git dependencies,
    and ambiguous version patterns — sorted by risk level. No network calls, runs 100% in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> deps + devDeps + peerDeps</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Semver risk scoring</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy report</span>
  </div>
  <DependencyVersionChecker client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Dependency Version Checker" relatedTags={['npm', 'node', 'dependencies', 'security', 'semver', 'package-json', 'developer-tools']} />
</BaseLayout>
