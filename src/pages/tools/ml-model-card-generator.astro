---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MlModelCardGenerator from '../../components/MlModelCardGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a model card and why does HuggingFace require one?",
    answer: "A model card is a standardized documentation file (README.md) that describes a machine learning model — its intended use, training data, performance metrics, limitations, and ethical considerations. HuggingFace uses model cards to populate the model hub page and power search/filtering. The YAML frontmatter (model-index) is machine-readable and used to display metrics on the leaderboard. Well-documented models are more likely to be trusted and adopted by the community."
  },
  {
    question: "What should I put in the 'intended use' section?",
    answer: "Describe the specific tasks your model is designed for, the expected input format, and the target user group. Be concrete: instead of 'NLP tasks', write 'Binary sentiment classification of English product reviews, returning positive/negative with confidence scores'. Also explicitly state out-of-scope uses — this protects users from misapplying the model and reduces liability. Example out-of-scope: 'Not intended for medical diagnosis, legal analysis, or non-English text.'"
  },
  {
    question: "What metrics should I include in the model card?",
    answer: "Include metrics relevant to your task: accuracy and F1 for classification, ROUGE/BLEU for generation, RMSE/MAE for regression. Always specify the dataset the metrics were measured on — separate train/validation/test set metrics. For classification, include per-class metrics if there's class imbalance. The HuggingFace YAML format (model-index) makes these metrics appear in the model hub UI and enables comparison across models."
  },
  {
    question: "What ethical considerations are most important to document?",
    answer: "Document known biases in training data (demographic, geographic, temporal), potential for harmful outputs or misuse, fairness across demographic groups (if applicable), and any privacy considerations. For models trained on web data, note the possibility of reproducing harmful stereotypes. Include a disclaimer if the model should not be used for high-stakes decisions (healthcare, hiring, legal) without human review. Transparency here builds trust and enables safe deployment."
  },
];
---

<BaseLayout
  title="ML Model Card Generator — HuggingFace-Compatible Model Documentation"
  description="Generate HuggingFace-compatible model cards with performance metrics, intended use, limitations, and ethical considerations. Get formatted Markdown with YAML frontmatter. Free, browser-based."
  tool="ml model card generator, huggingface model card, model documentation, model readme, model-index yaml"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "ML Model Card Generator",
    "url": "https://devplaybook.cc/tools/ml-model-card-generator",
    "description": "Generate HuggingFace-compatible model cards with YAML frontmatter, performance metrics, intended use, limitations, and ethical considerations.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">ML Model Card Generator</h1>
  <p class="text-text-muted mb-4">
    Generate <strong>HuggingFace-compatible model cards</strong> with YAML frontmatter, performance metrics, intended use cases, known limitations, and ethical considerations. Get a complete <code>README.md</code> ready to publish.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> YAML frontmatter</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> model-index metrics</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 12 model types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> HuggingFace ready</span>
  </div>
  <MlModelCardGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="ML Model Card Generator" relatedTags={['machine-learning', 'huggingface', 'ml', 'ai', 'developer-tools']} />
</BaseLayout>
