---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FeatureFlagConfigBuilder from '../../components/FeatureFlagConfigBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the difference between feature flags and feature toggles?",
    answer: "Feature flags and feature toggles are the same concept — they are runtime switches that let you enable or disable functionality without deploying new code. 'Feature flag' is the term popularized by tools like LaunchDarkly, while 'feature toggle' was coined by Martin Fowler. Both refer to conditional logic (if flag enabled: show new UI) that decouples deployment from release. This lets teams do trunk-based development, canary releases, A/B testing, and instant rollbacks without touching infrastructure."
  },
  {
    question: "What is the OpenFeature standard and why does it matter?",
    answer: "OpenFeature is a CNCF-incubating open standard for feature flagging. It defines a vendor-neutral SDK API so you can switch between flag providers (LaunchDarkly, GrowthBook, Flagd, Unleash) without changing your application code. You write against the OpenFeature SDK, plug in your provider of choice, and the SDK handles evaluation. The JSON provider format generated by this tool works with @openfeature/flagd-provider, letting you serve flags from a flat JSON file — perfect for local development, CI environments, or self-hosted setups."
  },
  {
    question: "How does percentage rollout work and is it sticky?",
    answer: "Percentage rollout assigns users to the 'on' or 'off' bucket based on a hash of their user ID (or session ID). Because the hash is deterministic, the same user always gets the same bucket — this is called stickiness. A 20% rollout means roughly 20% of unique users consistently see the feature enabled. LaunchDarkly and GrowthBook both use this approach. The OpenFeature JSON provider supports it via the 'fractional' evaluator. Without stickiness (random per request), users would see the feature flicker on and off, which is never desirable."
  },
  {
    question: "When should I clean up feature flags?",
    answer: "Feature flags are technical debt by design — they exist to be temporary. A flag should be removed once the rollout is complete (100% on or fully off). Common practice is to treat flags like TODO comments: file a cleanup ticket the moment you create the flag, set a calendar reminder for 30-90 days, and enforce it with static analysis tools (like eslint-plugin-feature-flags) that fail the build if a flag key is older than N days. LaunchDarkly and GrowthBook both have built-in staleness tracking. Flags left in the codebase for months become invisible dead code that confuses future developers."
  },
];
---

<BaseLayout
  title="Feature Flag Config Builder — OpenFeature, LaunchDarkly, GrowthBook"
  description="Build feature flag configurations for OpenFeature JSON provider, LaunchDarkly, and GrowthBook. Define flags with targeting rules, percentage rollouts, and user targeting. Free, browser-based."
  tool="Feature Flag Config Builder, OpenFeature JSON, LaunchDarkly Flag Config, GrowthBook Features, Feature Toggle Generator, Percentage Rollout"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Feature Flag Config Builder",
    "url": "https://devplaybook.cc/tools/feature-flag-config-builder",
    "description": "Build feature flag configurations for OpenFeature JSON provider, LaunchDarkly, and GrowthBook. Define flags with targeting rules, percentage rollouts, and user targeting.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Feature Flag Config Builder</h1>
  <p class="text-text-muted mb-4">
    Define feature flags with targeting rules — percentage rollouts, user ID lists, or attribute matches —
    and export ready-to-use configs for
    <code class="font-mono bg-surface px-1 rounded text-sm">OpenFeature</code>,
    <code class="font-mono bg-surface px-1 rounded text-sm">LaunchDarkly</code>, and
    <code class="font-mono bg-surface px-1 rounded text-sm">GrowthBook</code>.
    No account required. Runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> OpenFeature / LaunchDarkly / GrowthBook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Percentage rollout, user IDs, attribute match</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multiple flags, multiple rules</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <FeatureFlagConfigBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Feature Flag Config Builder" relatedTags={['developer-tools', 'devops', 'testing', 'frontend', 'backend', 'config']} />
</BaseLayout>
