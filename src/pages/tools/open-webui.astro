---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Open WebUI?", answer: "Open WebUI (formerly Ollama WebUI) is a feature-rich, self-hosted web interface for interacting with Ollama and OpenAI-compatible APIs. It provides a ChatGPT-like experience with advanced features: conversation management, model switching, image generation, document RAG, voice input/output, web search, user management, and an extensible pipe/function plugin system." },
  { question: "Does Open WebUI require Ollama?", answer: "Ollama is the primary local backend, but Open WebUI also works with any OpenAI-compatible API: LM Studio, LocalAI, LiteLLM, Groq, Mistral, or the real OpenAI. You can configure multiple backends and switch between them. Set OPENAI_API_BASE_URL to point at any compatible endpoint." },
  { question: "How do I install Open WebUI with Docker?", answer: "The simplest installation: docker run -d -p 3000:8080 --add-host=host.docker.internal:host-gateway -v open-webui:/app/backend/data --name open-webui --restart always ghcr.io/open-webui/open-webui:main. If Ollama is on the same machine, --add-host handles the network bridge. Open http://localhost:3000 and create your admin account on first launch." },
  { question: "What are Open WebUI pipe plugins?", answer: "Pipes are Python functions that run server-side as middleware in the message processing pipeline. They can transform messages, call external APIs, inject context, filter content, or route requests to different models. Pipes are shared in the Open WebUI community hub and can be installed with one click from the admin panel. This makes Open WebUI highly customizable without forking the codebase." },
  { question: "Can Open WebUI do document RAG?", answer: "Yes. Open WebUI includes a built-in RAG system. Upload documents (PDF, DOCX, TXT, web URLs) to the global knowledge base or attach files to individual conversations. It uses a configurable embedding model (default: local via Ollama) and a vector store (default: Chroma). When you add # before a message, it searches the knowledge base and injects relevant chunks into context." },
  { question: "Open WebUI vs AnythingLLM — key differences?", answer: "Open WebUI excels as a personal or team Ollama frontend with a polished UI, model management, image generation, and an active plugin community. AnythingLLM focuses on workspace-isolated RAG, AI agents, and enterprise-style multi-user access control. Open WebUI is generally better for individuals and developers; AnythingLLM is better for teams needing isolated knowledge bases per project." },
];
---

<BaseLayout
  title="Open WebUI: Feature-Rich Frontend for Ollama &amp; OpenAI (2026)"
  description="Open WebUI is a powerful self-hosted AI interface for Ollama and OpenAI APIs. Chat, RAG, image generation, pipe plugins, and admin panel. Complete Docker installation guide."
  tool="Open WebUI, Ollama WebUI, Ollama frontend, local AI interface, self-hosted AI chat, private LLM UI"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"Open WebUI: Feature-Rich Frontend for Ollama & OpenAI","url":"https://devplaybook.cc/tools/open-webui","description":"Open WebUI is a self-hosted AI chat interface for Ollama and OpenAI-compatible APIs — complete guide for 2026."})} />

  <h1 class="text-3xl font-bold mb-2">Open WebUI: Feature-Rich Frontend for Ollama &amp; OpenAI</h1>
  <p class="text-text-muted mb-6">Open WebUI is the most popular self-hosted frontend for Ollama — a fully-featured, ChatGPT-like interface with model management, document RAG, image generation, voice I/O, pipe plugins, and multi-user support. Run it in Docker in under two minutes.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Works with Ollama, LM Studio, and OpenAI</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Document RAG and web search</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Pipe plugin ecosystem</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Image generation (DALL-E / ComfyUI)</span>
  </div>

  <ToolPageCta />

  <!-- Docker installation -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Docker Installation</h2>
    <p class="text-text-muted text-sm mb-4">Open WebUI is distributed as a Docker image. Choose the right command based on your Ollama setup:</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># Option 1: Ollama running on the same host machine
docker run -d \
  -p 3000:8080 \
  --add-host=host.docker.internal:host-gateway \
  -v open-webui:/app/backend/data \
  --name open-webui \
  --restart always \
  ghcr.io/open-webui/open-webui:main

# Option 2: Ollama also in Docker (use bundled image)
docker run -d \
  -p 3000:8080 \
  --gpus all \
  -v ollama:/root/.ollama \
  -v open-webui:/app/backend/data \
  --name open-webui \
  --restart always \
  ghcr.io/open-webui/open-webui:ollama

# Option 3: OpenAI only (no Ollama)
docker run -d \
  -p 3000:8080 \
  -e OPENAI_API_KEY=sk-your-key \
  -v open-webui:/app/backend/data \
  --name open-webui \
  ghcr.io/open-webui/open-webui:main

# Open http://localhost:3000 — first user becomes admin</code></pre>
  </div>

  <!-- Connecting backends -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Connecting to Ollama &amp; Other Backends</h2>
    <p class="text-text-muted text-sm mb-4">Open WebUI auto-discovers Ollama at <code class="bg-bg-card border border-border rounded px-1.5 py-0.5 text-xs font-mono">http://host.docker.internal:11434</code>. You can add additional OpenAI-compatible connections in Admin Panel &gt; Settings &gt; Connections.</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># Environment variables for Open WebUI
# (pass with -e flags in docker run)

# Ollama connection
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Add OpenAI as additional backend
OPENAI_API_KEY=sk-your-openai-key
OPENAI_API_BASE_URL=https://api.openai.com/v1

# LM Studio as additional backend
OPENAI_API_BASE_URL=http://host.docker.internal:1234/v1
OPENAI_API_KEY=lm-studio

# Groq (fast cloud inference)
OPENAI_API_KEY=gsk_your-groq-key
OPENAI_API_BASE_URL=https://api.groq.com/openai/v1

# After connecting, models appear in the model selector dropdown
# You can assign custom names, icons, and descriptions to each model</code></pre>
  </div>

  <!-- RAG document upload -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">RAG: Document Upload &amp; Knowledge Base</h2>
    <p class="text-text-muted text-sm mb-4">Open WebUI's RAG system lets you upload documents once and reference them in any conversation. It embeds documents using a local model and stores vectors in Chroma.</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># RAG setup workflow:

# 1. Set embedding model (Admin Panel > Documents > Embedding Model)
#    Recommended: nomic-embed-text (via Ollama) or all-minilm (built-in)
#    Pull embedding model: ollama pull nomic-embed-text

# 2. Upload documents:
#    Workspace > Knowledge > Upload (PDF, DOCX, TXT, MD, CSV, web URLs)
#    Or use the paperclip icon in any chat for one-time attachment

# 3. Reference in chat:
#    Type # to search your knowledge base documents
#    Matching documents are injected as context automatically

# 4. Configure chunk settings (Admin Panel > Documents):
#    Chunk Size: 1500 characters (default)
#    Chunk Overlap: 100 characters
#    Top K Results: 5 (docs retrieved per query)

# Supported file types: PDF, DOCX, XLSX, PPTX, TXT, MD, RST, HTML, CSV, JSON, XML</code></pre>
  </div>

  <!-- Pipe plugins -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Pipe Plugins: Extending Open WebUI</h2>
    <p class="text-text-muted text-sm mb-3">Pipes are Python functions injected into the message pipeline. Install community pipes from the Open WebUI hub or write your own:</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-sm mb-4">
      <div class="border border-border rounded-lg p-3">
        <div class="font-medium mb-1">Web Search Pipe</div>
        <p class="text-text-muted text-xs">Auto-trigger web searches for questions needing current info. Uses DuckDuckGo, Brave, or SearXNG as the search backend.</p>
      </div>
      <div class="border border-border rounded-lg p-3">
        <div class="font-medium mb-1">Model Router Pipe</div>
        <p class="text-text-muted text-xs">Route different types of questions to the best model automatically — coding to CodeLlama, general chat to Llama 3, etc.</p>
      </div>
      <div class="border border-border rounded-lg p-3">
        <div class="font-medium mb-1">Filter Pipes</div>
        <p class="text-text-muted text-xs">Intercept messages to add system context, sanitize inputs, log conversations, or enforce content policies before the LLM sees them.</p>
      </div>
      <div class="border border-border rounded-lg p-3">
        <div class="font-medium mb-1">Action Pipes</div>
        <p class="text-text-muted text-xs">Add custom buttons to the chat UI that trigger workflows — send to webhook, save to Notion, create a GitHub issue, etc.</p>
      </div>
    </div>
  </div>

  <!-- Comparison -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-4">Open WebUI vs AnythingLLM</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-text-muted text-xs uppercase border-b border-border">
            <th class="text-left pb-2 pr-4">Feature</th>
            <th class="text-left pb-2 pr-4">Open WebUI</th>
            <th class="text-left pb-2">AnythingLLM</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border text-xs">
          <tr><td class="py-2 pr-4 font-medium">Model management (pull/delete)</td><td class="py-2 pr-4 text-green-500">Yes (Ollama built-in)</td><td class="py-2 text-yellow-500">Via backend only</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Plugin/extension system</td><td class="py-2 pr-4 text-green-500">Pipes + Functions</td><td class="py-2 text-red-400">Limited</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Image generation</td><td class="py-2 pr-4 text-green-500">DALL-E, ComfyUI, A1111</td><td class="py-2 text-red-400">No</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Voice I/O</td><td class="py-2 pr-4 text-green-500">STT + TTS built-in</td><td class="py-2 text-red-400">No</td></tr>
          <tr><td class="py-2 pr-4 font-medium">AI agents</td><td class="py-2 pr-4 text-yellow-500">Via function tools</td><td class="py-2 text-green-500">Native agents</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Workspace isolation</td><td class="py-2 pr-4 text-red-400">No</td><td class="py-2 text-green-500">Yes</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Community plugins</td><td class="py-2 pr-4 text-green-500">Large ecosystem</td><td class="py-2 text-yellow-500">Limited</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Open WebUI" relatedTags={['ai', 'llm', 'local-ai', 'ollama', 'self-hosted', 'rag', 'docker']} />
</BaseLayout>
