---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MarkdownPreview from '../../components/MarkdownPreview.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is a live Markdown preview?", answer: "A live Markdown preview renders your Markdown text into formatted HTML in real time — as you type. You see the final output instantly without switching tabs or running a build command, which makes writing and proofreading much faster." },
  { question: "How do I copy the rendered HTML output?", answer: "Click the 'Copy as HTML' button in the toolbar. The full HTML representation of your Markdown document is copied to your clipboard, ready to paste into an email client, CMS, or any HTML-based system." },
  { question: "Which Markdown syntax is supported?", answer: "This editor supports GitHub Flavored Markdown (GFM): headings (# through ###), bold, italic, strikethrough, inline code, fenced code blocks, blockquotes, unordered/ordered lists, task lists (- [x]), tables, horizontal rules, and links." },
  { question: "Can I switch between split view and preview-only?", answer: "Yes. Use the Split / Preview Only buttons in the toolbar. Split view shows the editor and preview side-by-side (recommended for desktops). Preview-only mode is useful when you've finished editing and just want to review the rendered output." },
  { question: "Does this tool save my Markdown?", answer: "No data is saved to any server — everything runs in your browser. If you want to save your work, click 'Download .md' to save the raw Markdown file locally, or copy the HTML output for immediate use." },
  { question: "What is the difference between this tool and a static Markdown renderer?", answer: "A static renderer requires you to submit or convert your Markdown manually. This live preview updates the output on every keystroke, so there's zero lag between writing and seeing the result. It's the same developer experience you get in editors like VS Code or Notion." },
];
---

<BaseLayout
  title="Markdown Live Preview — Real-Time Editor & HTML Exporter"
  description="Free live Markdown editor with instant side-by-side HTML preview. Type Markdown, see it rendered in real time. Copy rendered HTML or download the .md file. Supports GitHub Flavored Markdown: tables, task lists, code blocks. Runs in your browser."
  tool="Markdown Live Preview, Live Markdown Editor, Real-Time Markdown, Markdown to HTML, GFM Preview, GitHub Flavored Markdown Editor, Copy HTML from Markdown"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Markdown Live Preview</h1>
  <p class="text-text-muted mb-4">Write Markdown in the editor and see the formatted HTML preview update in real time — side-by-side. Supports GitHub Flavored Markdown (GFM): tables, task lists, fenced code blocks, and more. Copy the rendered HTML or download your Markdown file with one click.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Real-time preview as you type</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy rendered HTML</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <MarkdownPreview client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Markdown Live Preview" relatedTags={['markdown', 'html', 'editor', 'documentation', 'content', 'readme']} />
</BaseLayout>
