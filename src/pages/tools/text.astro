---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tools = [
  { name: 'Markdown to HTML Converter', desc: 'Write Markdown and see the live HTML output side-by-side. Copy formatted HTML with one click. Supports GFM tables, task lists, and code blocks.', href: '/tools/markdown-preview', icon: '📝' },
  { name: 'Word Counter & Readability', desc: 'Count words, characters, sentences, and paragraphs. Get reading time and a Flesch readability score with difficulty rating.', href: '/tools/word-counter', icon: '📊' },
  { name: 'Text Diff Checker', desc: 'Compare two text blocks side-by-side with line-level diff highlighting. Instantly see what was added, removed, or unchanged.', href: '/tools/text-diff', icon: '🔀' },
  { name: 'Lorem Ipsum Generator', desc: 'Generate Lorem Ipsum placeholder text by paragraphs, sentences, or words. Start with the classic line. Instant copy for mockups.', href: '/tools/lorem-ipsum', icon: '📄' },
  { name: 'String Case Converter', desc: 'Convert text between camelCase, PascalCase, snake_case, kebab-case, SCREAMING_SNAKE, Title Case, and more.', href: '/tools/string-case-converter', icon: '🔤' },
  { name: 'Line Sorter & Deduplicator', desc: 'Sort lines A–Z, by length, or shuffle. Remove duplicates, trim whitespace, delete empty lines. Perfect for cleaning lists.', href: '/tools/line-sorter', icon: '📑' },
  { name: 'HTML Entity Encoder / Decoder', desc: 'Encode special characters to HTML entities or decode entities back to plain text. Supports 50+ named entities.', href: '/tools/html-entity-encoder', icon: '🏷️' },
  { name: 'URL Encoder / Decoder', desc: 'Encode text to percent-encoded URL format or decode %20 / %3D sequences back to readable text.', href: '/tools/url-encoder', icon: '🔗' },
  { name: 'Base64 Encoder / Decoder', desc: 'Encode and decode Base64 strings. Supports UTF-8, URL-safe encoding, and binary data. Runs in your browser.', href: '/tools/base64', icon: '🔤' },
];
---

<BaseLayout
  title="Free Text Tools for Developers — devplaybook.cc"
  description="9 free text tools: Markdown to HTML converter, word counter with readability, text diff, Lorem ipsum generator, string case converter, line sorter, and more. No signup."
  tool="Text Tools, Markdown Converter, Word Counter, Text Diff, Lorem Ipsum, String Case"
>
  <div class="mb-8">
    <nav class="text-sm text-text-muted mb-4">
      <a href="/tools" class="hover:text-primary transition-colors">All Tools</a>
      <span class="mx-2">→</span>
      <span class="text-text">Text Tools</span>
    </nav>
    <h1 class="text-4xl font-bold mb-3">Text <span class="text-primary">Tools</span></h1>
    <p class="text-text-muted text-lg max-w-2xl">Free text processing tools for developers and writers. Markdown conversion, word counting, readability analysis, diff checking, and more — all client-side.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mb-12">
    {tools.map(tool => (
      <a href={tool.href} class="block bg-bg-card rounded-xl p-6 border border-border hover:border-primary transition-colors group">
        <div class="text-3xl mb-3">{tool.icon}</div>
        <h2 class="text-lg font-semibold mb-2 group-hover:text-primary transition-colors">{tool.name}</h2>
        <p class="text-text-muted text-sm">{tool.desc}</p>
      </a>
    ))}
  </div>

  <div class="flex flex-wrap gap-3 justify-center">
    <a href="/tools/code" class="bg-bg-card border border-border hover:border-primary px-4 py-2 rounded-lg text-sm transition-colors">💻 Code Tools</a>
    <a href="/tools/utilities" class="bg-bg-card border border-border hover:border-primary px-4 py-2 rounded-lg text-sm transition-colors">⚙️ Developer Utilities</a>
    <a href="/tools" class="bg-bg-card border border-border hover:border-primary px-4 py-2 rounded-lg text-sm transition-colors">🛠️ All Tools</a>
  </div>
</BaseLayout>
