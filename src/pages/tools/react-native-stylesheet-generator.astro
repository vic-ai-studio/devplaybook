---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is StyleSheet.create() in React Native?",
    answer: "StyleSheet.create() is a React Native API that creates an optimized style object. It validates your styles at development time and optimizes them for performance by converting the style object to a native representation. Styles defined this way are referenced by ID rather than serialized as objects, reducing bridge communication overhead compared to inline styles."
  },
  {
    question: "How is React Native styling different from CSS?",
    answer: "React Native styles are JavaScript objects, not CSS strings. Property names use camelCase (backgroundColor instead of background-color). Numeric values don't have units — they're device-independent pixels (dp) by default. Not all CSS properties are supported, and some work differently. For example, flexbox works slightly differently: flexDirection defaults to 'column' instead of 'row'."
  },
  {
    question: "What is the difference between flex and flexGrow in React Native?",
    answer: "In React Native, flex behaves like CSS's flex-grow when positive — it makes the component fill available space proportionally. flexGrow explicitly controls how a component grows to fill space. flexShrink controls shrinking. flexBasis sets the initial size before grow/shrink. A flex: 1 on a component inside a flex container will make it take all remaining space."
  },
  {
    question: "How do I add shadows in React Native?",
    answer: "On iOS, use shadowColor, shadowOffset (with width and height), shadowOpacity, and shadowRadius. On Android, use elevation (a single number that controls depth and shadow). For cross-platform shadows, set both: iOS uses the shadow* properties and Android uses elevation. The react-native community library @react-native-community/shadow provides unified shadow support."
  },
  {
    question: "What units does React Native use for dimensions?",
    answer: "React Native uses density-independent pixels (dp/pt) by default — numeric values without unit strings. On iOS, 1 dp = 1 point (which may be 2 or 3 physical pixels on Retina displays). On Android, 1 dp = 1 density-independent pixel. You can use the Dimensions API or useWindowDimensions hook to get the screen size in dp and calculate percentages manually."
  },
  {
    question: "Can I use percentage values for width and height?",
    answer: "Yes, React Native supports percentage strings for width, height, margin, and padding: '50%', '100%', etc. However, they are relative to the parent container (or screen for top-level views), not the viewport. For responsive layouts, consider using the Dimensions API or Flexbox instead of fixed percentages."
  },
];
---

<BaseLayout
  title="React Native StyleSheet Generator — Build RN Style Objects"
  description="Generate React Native StyleSheet.create() code visually. Configure layout, typography, colors, borders, and shadows. Get ready-to-use RN style code with copy button. Free, no sign-up."
  tool="React Native StyleSheet Generator, React Native Style Builder, RN StyleSheet.create, React Native CSS Generator, React Native Layout Tool"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "React Native StyleSheet Generator",
    "url": "https://devplaybook.cc/tools/react-native-stylesheet-generator",
    "description": "Generate React Native StyleSheet.create() objects visually. Configure layout, typography, colors, and borders, then copy the generated code.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">React Native StyleSheet Generator</h1>
  <p class="text-text-muted mb-4">
    Build <code class="font-mono bg-surface px-1 rounded text-sm">StyleSheet.create()</code> objects visually.
    Configure layout (flex, position), typography, colors, spacing, borders, and shadows — then copy the generated code directly into your React Native project.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 6 style categories</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multiple style objects</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <div id="rn-app" class="space-y-5">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <!-- Config -->
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-semibold mb-1" for="style-name">Style name</label>
          <input id="style-name" type="text" value="container" placeholder="container" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text font-mono focus:outline-none focus:border-accent" />
        </div>

        <!-- Layout -->
        <details open>
          <summary class="text-xs font-semibold text-text-muted uppercase tracking-wide cursor-pointer py-1 select-none">Layout &amp; Flex</summary>
          <div class="mt-2 grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs text-text-muted mb-1">flex</label>
              <input id="flex" type="text" placeholder="1" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">flexDirection</label>
              <select id="flex-direction" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent">
                <option value="">–</option>
                <option value="column">column</option>
                <option value="row">row</option>
                <option value="column-reverse">column-reverse</option>
                <option value="row-reverse">row-reverse</option>
              </select>
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">justifyContent</label>
              <select id="justify-content" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent">
                <option value="">–</option>
                <option value="flex-start">flex-start</option>
                <option value="center">center</option>
                <option value="flex-end">flex-end</option>
                <option value="space-between">space-between</option>
                <option value="space-around">space-around</option>
                <option value="space-evenly">space-evenly</option>
              </select>
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">alignItems</label>
              <select id="align-items" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent">
                <option value="">–</option>
                <option value="flex-start">flex-start</option>
                <option value="center">center</option>
                <option value="flex-end">flex-end</option>
                <option value="stretch">stretch</option>
                <option value="baseline">baseline</option>
              </select>
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">width</label>
              <input id="width" type="text" placeholder="'100%' or 200" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">height</label>
              <input id="height" type="text" placeholder="200" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
          </div>
        </details>

        <!-- Spacing -->
        <details>
          <summary class="text-xs font-semibold text-text-muted uppercase tracking-wide cursor-pointer py-1 select-none">Spacing (padding / margin)</summary>
          <div class="mt-2 grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs text-text-muted mb-1">padding</label>
              <input id="padding" type="text" placeholder="16" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">paddingHorizontal</label>
              <input id="padding-h" type="text" placeholder="16" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">paddingVertical</label>
              <input id="padding-v" type="text" placeholder="8" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">margin</label>
              <input id="margin" type="text" placeholder="8" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">marginHorizontal</label>
              <input id="margin-h" type="text" placeholder="16" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">marginVertical</label>
              <input id="margin-v" type="text" placeholder="8" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
          </div>
        </details>

        <!-- Typography -->
        <details>
          <summary class="text-xs font-semibold text-text-muted uppercase tracking-wide cursor-pointer py-1 select-none">Typography</summary>
          <div class="mt-2 grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs text-text-muted mb-1">fontSize</label>
              <input id="font-size" type="number" placeholder="16" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">fontWeight</label>
              <select id="font-weight" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent">
                <option value="">–</option>
                <option value="'normal'">normal</option>
                <option value="'bold'">bold</option>
                <option value="'100'">100</option>
                <option value="'200'">200</option>
                <option value="'300'">300</option>
                <option value="'400'">400</option>
                <option value="'500'">500</option>
                <option value="'600'">600</option>
                <option value="'700'">700</option>
                <option value="'800'">800</option>
                <option value="'900'">900</option>
              </select>
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">color</label>
              <input id="text-color" type="text" placeholder="#333333" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text font-mono focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">textAlign</label>
              <select id="text-align" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent">
                <option value="">–</option>
                <option value="'left'">left</option>
                <option value="'center'">center</option>
                <option value="'right'">right</option>
                <option value="'justify'">justify</option>
              </select>
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">lineHeight</label>
              <input id="line-height" type="number" placeholder="24" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">letterSpacing</label>
              <input id="letter-spacing" type="number" placeholder="0.5" step="0.1" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
          </div>
        </details>

        <!-- Colors & Background -->
        <details>
          <summary class="text-xs font-semibold text-text-muted uppercase tracking-wide cursor-pointer py-1 select-none">Colors &amp; Background</summary>
          <div class="mt-2 grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs text-text-muted mb-1">backgroundColor</label>
              <input id="bg-color" type="text" placeholder="#ffffff" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text font-mono focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">opacity</label>
              <input id="opacity" type="number" placeholder="1" min="0" max="1" step="0.1" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
          </div>
        </details>

        <!-- Borders & Shadow -->
        <details>
          <summary class="text-xs font-semibold text-text-muted uppercase tracking-wide cursor-pointer py-1 select-none">Borders &amp; Shadow</summary>
          <div class="mt-2 grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs text-text-muted mb-1">borderWidth</label>
              <input id="border-width" type="number" placeholder="1" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">borderColor</label>
              <input id="border-color" type="text" placeholder="#cccccc" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text font-mono focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">borderRadius</label>
              <input id="border-radius" type="number" placeholder="8" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">elevation (Android)</label>
              <input id="elevation" type="number" placeholder="4" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">shadowColor (iOS)</label>
              <input id="shadow-color" type="text" placeholder="#000000" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text font-mono focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">shadowOpacity (iOS)</label>
              <input id="shadow-opacity" type="number" placeholder="0.2" min="0" max="1" step="0.05" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm text-text focus:outline-none focus:border-accent" />
            </div>
          </div>
        </details>

        <button id="btn-add-style" class="w-full px-4 py-2 bg-surface border border-dashed border-accent/50 hover:border-accent text-accent text-sm rounded-lg transition-colors">+ Add another style object</button>
      </div>

      <!-- Output -->
      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <p class="text-sm font-semibold">Generated StyleSheet Code</p>
          <button id="btn-copy" class="text-xs text-accent hover:underline font-medium">Copy code</button>
        </div>
        <pre id="code-output" class="bg-surface border border-border rounded-lg p-4 text-sm font-mono overflow-auto min-h-80 text-text leading-relaxed whitespace-pre"></pre>
        <div id="copy-toast" class="hidden text-xs text-green-500 font-medium">Copied to clipboard!</div>
      </div>
    </div>

    <!-- Presets -->
    <div>
      <p class="text-xs font-semibold text-text-muted uppercase tracking-wide mb-2">Quick Presets</p>
      <div class="flex flex-wrap gap-2">
        <button class="preset-btn px-3 py-1.5 bg-surface border border-border hover:border-accent/50 text-text text-xs rounded-lg transition-colors" data-preset="card">Card</button>
        <button class="preset-btn px-3 py-1.5 bg-surface border border-border hover:border-accent/50 text-text text-xs rounded-lg transition-colors" data-preset="screen">Screen Container</button>
        <button class="preset-btn px-3 py-1.5 bg-surface border border-border hover:border-accent/50 text-text text-xs rounded-lg transition-colors" data-preset="button">Primary Button</button>
        <button class="preset-btn px-3 py-1.5 bg-surface border border-border hover:border-accent/50 text-text text-xs rounded-lg transition-colors" data-preset="text">Body Text</button>
        <button class="preset-btn px-3 py-1.5 bg-surface border border-border hover:border-accent/50 text-text text-xs rounded-lg transition-colors" data-preset="header">Heading</button>
      </div>
    </div>
  </div>

  <script>
    (function () {
      let extraStyles = [];

      function getVal(id) {
        const el = document.getElementById(id);
        return el ? el.value.trim() : '';
      }

      function formatVal(val) {
        if (!val) return null;
        // If it's a quoted string already, return as-is
        if (val.startsWith("'") || val.startsWith('"')) return val;
        // If it looks like a color hex
        if (val.startsWith('#')) return `'${val}'`;
        // If it's a percentage
        if (val.endsWith('%')) return `'${val}'`;
        // If it's a pure number
        if (!isNaN(Number(val))) return val;
        // Otherwise wrap in quotes
        return `'${val}'`;
      }

      function buildStyleProps() {
        const props = [];
        const add = (key, val) => { if (val !== null && val !== '') props.push([key, val]); };

        const flex = getVal('flex');
        const fd = getVal('flex-direction');
        const jc = getVal('justify-content');
        const ai = getVal('align-items');
        const w = getVal('width');
        const h = getVal('height');
        const p = getVal('padding');
        const ph = getVal('padding-h');
        const pv = getVal('padding-v');
        const m = getVal('margin');
        const mh = getVal('margin-h');
        const mv = getVal('margin-v');
        const fs = getVal('font-size');
        const fw = getVal('font-weight');
        const tc = getVal('text-color');
        const ta = getVal('text-align');
        const lh = getVal('line-height');
        const ls = getVal('letter-spacing');
        const bg = getVal('bg-color');
        const op = getVal('opacity');
        const bw = getVal('border-width');
        const bc = getVal('border-color');
        const br = getVal('border-radius');
        const elev = getVal('elevation');
        const sc = getVal('shadow-color');
        const sop = getVal('shadow-opacity');

        if (flex) add('flex', flex);
        if (fd) add('flexDirection', `'${fd}'`);
        if (jc) add('justifyContent', `'${jc}'`);
        if (ai) add('alignItems', `'${ai}'`);
        if (w) add('width', formatVal(w));
        if (h) add('height', formatVal(h));
        if (p) add('padding', p);
        if (ph) add('paddingHorizontal', ph);
        if (pv) add('paddingVertical', pv);
        if (m) add('margin', m);
        if (mh) add('marginHorizontal', mh);
        if (mv) add('marginVertical', mv);
        if (fs) add('fontSize', fs);
        if (fw) add('fontWeight', fw);
        if (tc) add('color', formatVal(tc));
        if (ta) add('textAlign', ta);
        if (lh) add('lineHeight', lh);
        if (ls) add('letterSpacing', ls);
        if (bg) add('backgroundColor', formatVal(bg));
        if (op) add('opacity', op);
        if (bw) add('borderWidth', bw);
        if (bc) add('borderColor', formatVal(bc));
        if (br) add('borderRadius', br);
        if (elev) add('elevation', elev);
        if (sc) {
          add('shadowColor', formatVal(sc));
          add('shadowOffset', '{ width: 0, height: 2 }');
          if (sop) add('shadowOpacity', sop);
          add('shadowRadius', '4');
        }

        return props;
      }

      function generateCode() {
        const name = getVal('style-name') || 'container';
        const mainProps = buildStyleProps();

        const formatStyle = (styleName, props) => {
          if (props.length === 0) return `  ${styleName}: {},`;
          const inner = props.map(([k, v]) => `    ${k}: ${v},`).join('\n');
          return `  ${styleName}: {\n${inner}\n  },`;
        };

        let styleBlocks = [formatStyle(name, mainProps)];
        extraStyles.forEach(s => {
          styleBlocks.push(formatStyle(s.name, s.props));
        });

        return `const styles = StyleSheet.create({\n${styleBlocks.join('\n')}\n});`;
      }

      function updateOutput() {
        document.getElementById('code-output').textContent = generateCode();
      }

      document.querySelectorAll('#rn-app input, #rn-app select').forEach(el => {
        el.addEventListener('input', updateOutput);
        el.addEventListener('change', updateOutput);
      });

      document.getElementById('btn-copy').addEventListener('click', function () {
        const code = document.getElementById('code-output').textContent;
        navigator.clipboard.writeText(code).then(() => {
          const toast = document.getElementById('copy-toast');
          toast.classList.remove('hidden');
          setTimeout(() => toast.classList.add('hidden'), 2000);
        });
      });

      document.getElementById('btn-add-style').addEventListener('click', function () {
        const name = prompt('Style object name (e.g. text, button):');
        if (!name || !name.trim()) return;
        extraStyles.push({ name: name.trim(), props: [['flex', '1']] });
        updateOutput();
      });

      const presets = {
        card: { name: 'card', flex: '', fd: '', jc: '', ai: '', w: '', h: '', p: '16', ph: '', pv: '', m: '8', mh: '', mv: '', bg: '#ffffff', op: '', bw: '1', bc: '#e5e7eb', br: '12', elev: '4', sc: '#000000', sop: '0.1' },
        screen: { name: 'container', flex: '1', fd: 'column', jc: '', ai: '', w: '', h: '', p: '16', ph: '', pv: '', m: '', mh: '', mv: '', bg: '#f9fafb', op: '', bw: '', bc: '', br: '', elev: '', sc: '', sop: '' },
        button: { name: 'button', flex: '', fd: 'row', jc: 'center', ai: 'center', w: '', h: '48', p: '', ph: '24', pv: '', m: '', mh: '', mv: '', bg: '#3b82f6', op: '', bw: '', bc: '', br: '8', elev: '2', sc: '', sop: '' },
        text: { name: 'bodyText', flex: '', fd: '', jc: '', ai: '', w: '', h: '', p: '', ph: '', pv: '', m: '', mh: '', mv: '', fs: '16', fw: "'400'", tc: '#374151', ta: "'left'", lh: '24', ls: '', bg: '', op: '', bw: '', bc: '', br: '', elev: '', sc: '', sop: '' },
        header: { name: 'heading', flex: '', fd: '', jc: '', ai: '', w: '', h: '', p: '', ph: '', pv: '', m: '', mh: '', mv: '8', fs: '24', fw: "'700'", tc: '#111827', ta: "'left'", lh: '32', ls: '0.3', bg: '', op: '', bw: '', bc: '', br: '', elev: '', sc: '', sop: '' },
      };

      document.querySelectorAll('.preset-btn').forEach(btn => {
        btn.addEventListener('click', function () {
          const p = presets[this.dataset.preset];
          if (!p) return;
          const setVal = (id, val) => { const el = document.getElementById(id); if (el) el.value = val !== undefined ? val : ''; };
          setVal('style-name', p.name || 'container');
          setVal('flex', p.flex || '');
          setVal('flex-direction', p.fd || '');
          setVal('justify-content', p.jc || '');
          setVal('align-items', p.ai || '');
          setVal('width', p.w || '');
          setVal('height', p.h || '');
          setVal('padding', p.p || '');
          setVal('padding-h', p.ph || '');
          setVal('padding-v', p.pv || '');
          setVal('margin', p.m || '');
          setVal('margin-h', p.mh || '');
          setVal('margin-v', p.mv || '');
          setVal('font-size', p.fs || '');
          setVal('font-weight', p.fw || '');
          setVal('text-color', p.tc || '');
          setVal('text-align', p.ta || '');
          setVal('line-height', p.lh || '');
          setVal('letter-spacing', p.ls || '');
          setVal('bg-color', p.bg || '');
          setVal('opacity', p.op || '');
          setVal('border-width', p.bw || '');
          setVal('border-color', p.bc || '');
          setVal('border-radius', p.br || '');
