---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const dockerComposeExample = `version: "3.8"
services:
  hoppscotch:
    image: hoppscotch/hoppscotch:latest
    ports:
      - "3000:3000"   # App
      - "3100:3100"   # Admin dashboard
      - "3170:3170"   # Backend API
    env_file:
      - .env
    depends_on:
      - db
  db:
    image: postgres:15-alpine
    environment:
      POSTGRES_USER: hoppscotch
      POSTGRES_PASSWORD: secret
      POSTGRES_DB: hoppscotch`;

const cliExample = `# Install Hoppscotch CLI
npm install -g @hoppscotch/cli

# Run a test collection
hopp test my-collection.json --env production.json

# Run with environment variables
hopp test api-tests.json \\
  --env staging.json \\
  --reporter-junit results.xml`;

const faq = [
  { question: "How does Hoppscotch compare to Postman?", answer: "Hoppscotch is a fully open-source, web-based API testing platform whereas Postman is a proprietary desktop and cloud product. Hoppscotch supports REST, GraphQL, WebSocket, SSE, Socket.IO, and MQTT in a single browser tab — no installation required. It offers team workspaces, shared collections, and environment management similar to Postman. The key advantages of Hoppscotch are its open-source nature (MIT licensed), self-hosting capability, and the fact that you can run it entirely within your own infrastructure without sending request data to a third party." },
  { question: "How do I self-host Hoppscotch?", answer: "Hoppscotch provides an official Docker image (hoppscotch/hoppscotch) that bundles the frontend app, backend API, and admin dashboard. You deploy it with Docker Compose, configure a PostgreSQL database, and set environment variables for SMTP email, OAuth providers (GitHub, Google, Microsoft, email), and your domain. The self-hosted version includes all enterprise features at no cost — team workspaces, SAML SSO, audit logs, and custom branding. Detailed documentation is at docs.hoppscotch.io." },
  { question: "Does Hoppscotch have a CLI?", answer: "Yes, Hoppscotch CLI (@hoppscotch/cli, command hopp) lets you run Hoppscotch test collections from the command line. Install with npm install -g @hoppscotch/cli. Run a collection with hopp test collection.json --env env.json. The CLI exits with a non-zero status code on test failures, making it suitable for CI/CD pipelines in GitHub Actions, GitLab CI, Jenkins, and similar systems. Results can be exported in JUnit XML format for test reporting dashboards." },
  { question: "How do team workspaces work in Hoppscotch?", answer: "Team workspaces let multiple developers share collections, environments, and request history. Members can be invited with Admin, Editor, or Viewer roles. Collections and environments sync in real time across all team members. On hoppscotch.io (cloud), team features require a Pro plan. On a self-hosted instance, team workspaces are available to all users at no additional cost. This makes self-hosting particularly attractive for teams that want full collaboration without paying per-seat pricing." },
  { question: "How does Hoppscotch handle GraphQL testing?", answer: "Hoppscotch has a dedicated GraphQL tab with first-class support for queries, mutations, and subscriptions. It can introspect a GraphQL endpoint automatically and display the full schema documentation in the sidebar. The editor provides autocompletion based on the introspected schema. Variables, headers, and authentication are configured the same way as REST requests. WebSocket-based GraphQL subscriptions (via graphql-ws or subscriptions-transport-ws) are also supported, making it easy to test real-time GraphQL APIs." },
  { question: "Can I use Hoppscotch with WebSockets and MQTT?", answer: "Yes. Hoppscotch supports WebSocket connections (including Socket.IO), Server-Sent Events (SSE), and MQTT in addition to REST and GraphQL. For WebSockets you can send and receive messages in real time within the browser. For MQTT, connect to any MQTT broker (with or without TLS) and publish/subscribe to topics. These real-time protocol clients are available alongside REST in the same unified interface, which is a unique capability compared to tools like Postman that have more limited WebSocket/MQTT support." },
];
---

<BaseLayout
  title="Hoppscotch — Open-Source API Testing Platform (Postman Alternative)"
  description="Hoppscotch is a free, open-source API testing platform with REST, GraphQL, WebSocket, SSE, and MQTT support. Use it in the browser at hoppscotch.io or self-host with Docker for full privacy."
  tool="Hoppscotch, open source API client, Hoppscotch vs Postman, self-hosted API testing, GraphQL testing, WebSocket testing, Hoppscotch CLI"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Hoppscotch — Open-Source API Testing Platform",
    "url": "https://devplaybook.cc/tools/hoppscotch",
    "description": "Hoppscotch is a free, open-source API testing platform with REST, GraphQL, WebSocket, SSE, and MQTT support. Use in-browser or self-host with Docker.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Hoppscotch — Open-Source API Testing Platform</h1>
  <p class="text-text-muted mb-6">
    <strong>Hoppscotch</strong> (formerly Postwoman) is a free, open-source API testing platform that runs in your browser. It supports REST, GraphQL, WebSocket, Server-Sent Events, Socket.IO, and MQTT — all in one unified interface. Use it instantly at <code class="font-mono bg-surface px-1 rounded text-sm">hoppscotch.io</code> or self-host it with Docker for full data privacy.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No installation required</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> REST, GraphQL, WebSocket, SSE, MQTT</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Self-hostable with Docker</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Team workspaces</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> MIT licensed, open source</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Hoppscotch?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Hoppscotch is a lightweight, web-based API development ecosystem. Unlike desktop API clients, it runs entirely in your browser — making it instantly accessible from any device with no download or setup. It was originally created by Liyas Thomas as an open-source alternative to Postman and has grown into a full-featured platform with a backend, team collaboration features, and a self-hosting option.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    The cloud version at <code class="font-mono bg-surface px-1 rounded text-sm">hoppscotch.io</code> is free for personal use. Teams can collaborate with shared workspaces on the Pro plan. Organizations that need full control over their data can self-host the complete Hoppscotch stack — frontend, backend API, and admin panel — on their own infrastructure using Docker Compose.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Multi-protocol</strong> — REST, GraphQL (queries/mutations/subscriptions), WebSocket, Socket.IO, SSE, MQTT</li>
    <li><strong>Web-based</strong> — no installation, works in any modern browser, PWA installable</li>
    <li><strong>Team workspaces</strong> — shared collections and environments with role-based access (Admin/Editor/Viewer)</li>
    <li><strong>Self-hostable</strong> — official Docker image with PostgreSQL backend; all team features included at no cost</li>
    <li><strong>Hoppscotch CLI</strong> — headless collection runner for CI/CD with JUnit XML reporting</li>
    <li><strong>GraphQL introspection</strong> — automatic schema discovery and autocomplete in query editor</li>
    <li><strong>Environments</strong> — define variables per environment (development, staging, production)</li>
    <li><strong>Auth support</strong> — Basic, Bearer, API Key, OAuth 2.0 (PKCE + Authorization Code)</li>
    <li><strong>Pre-request scripts</strong> — JavaScript scripting for dynamic request manipulation</li>
    <li><strong>History</strong> — automatic request history with search and replay</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Quick Start</h2>
  <div class="bg-bg-card border border-border rounded-xl p-4 mb-4">
    <p class="text-xs text-text-muted uppercase font-semibold mb-2">Cloud (no install)</p>
    <pre class="text-sm font-mono text-text">Open https://hoppscotch.io in your browser</pre>
  </div>
  <div class="bg-bg-card border border-border rounded-xl p-4 mb-4">
    <p class="text-xs text-text-muted uppercase font-semibold mb-2">Self-host with Docker</p>
    <pre class="text-sm font-mono text-text">docker pull hoppscotch/hoppscotch
docker run -p 3000:3000 hoppscotch/hoppscotch</pre>
  </div>
  <div class="bg-bg-card border border-border rounded-xl p-4 mb-6">
    <p class="text-xs text-text-muted uppercase font-semibold mb-2">CLI for CI/CD</p>
    <pre class="text-sm font-mono text-text" set:html={cliExample}></pre>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Self-Hosting with Docker Compose</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={dockerComposeExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Hoppscotch vs Postman vs Insomnia</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">Hoppscotch</th>
          <th class="border border-border px-3 py-2 text-left">Postman</th>
          <th class="border border-border px-3 py-2 text-left">Insomnia</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-border px-3 py-2">Interface</td>
          <td class="border border-border px-3 py-2">Web browser</td>
          <td class="border border-border px-3 py-2">Desktop app</td>
          <td class="border border-border px-3 py-2">Desktop app</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Self-hostable</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes (Docker)</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">WebSocket support</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes (full)</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Limited</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Limited</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">MQTT support</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">Open source</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes (MIT)</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes (Apache 2)</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Team workspaces</td>
          <td class="border border-border px-3 py-2">Free (self-hosted) / Pro (cloud)</td>
          <td class="border border-border px-3 py-2">Paid</td>
          <td class="border border-border px-3 py-2">Paid</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Use Cases</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li>Quick API exploration without installing desktop software</li>
    <li>Testing GraphQL APIs with schema introspection and subscription support</li>
    <li>Real-time protocol testing: WebSocket, Socket.IO, SSE, MQTT</li>
    <li>Team API collections shared via self-hosted Hoppscotch for full data control</li>
    <li>CI/CD pipeline API regression testing with the Hoppscotch CLI</li>
    <li>On-call debugging from any device with a browser — no installation needed</li>
  </ul>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Hoppscotch API Testing Platform" relatedTags={['api', 'rest', 'graphql', 'websocket', 'http', 'testing', 'open-source']} />
</BaseLayout>
