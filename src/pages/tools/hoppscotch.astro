---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const installExample = `# Install the Hoppscotch CLI globally
npm install -g @hoppscotch/cli

# Verify installation
hopp --version

# Run a collection against a staging environment
hopp test collections/api-tests.json --env environments/staging.json

# Output JUnit XML for CI reporting
hopp test collections/api-tests.json --reporter-junit results/junit.xml`;

const envExample = `// hoppscotch-env.json
{
  "name": "Staging",
  "variables": [
    { "key": "BASE_URL", "value": "https://api.staging.example.com", "secret": false },
    { "key": "API_KEY",  "value": "sk-staging-abc123",               "secret": true  },
    { "key": "USER_ID",  "value": "42",                              "secret": false }
  ]
}

// Reference variables using <<VAR_NAME>> in any request field
// GET <<BASE_URL>>/users/<<USER_ID>>
// Authorization: Bearer <<API_KEY>>`;

const scriptExample = `// Pre-request script — set a dynamic timestamp
pw.env.set("TIMESTAMP", new Date().toISOString());

// Post-response test script
pw.test("Status is 200", () => {
  pw.expect(pw.response.status).toBe(200);
});

pw.test("Response has user id", () => {
  const body = pw.response.body;
  pw.expect(body).toHaveProperty("id");
  pw.expect(body.id).toBeGreaterThan(0);
});

pw.test("Content-Type is JSON", () => {
  pw.expect(pw.response.headers["content-type"]).toContain("application/json");
});`;

const graphqlExample = `# GraphQL query in Hoppscotch GraphQL tab
query GetUser($id: ID!) {
  user(id: $id) {
    id
    name
    email
    createdAt
  }
}

# Variables panel (JSON)
{
  "id": "42"
}

# Subscription example
subscription OnMessageAdded($roomId: ID!) {
  messageAdded(roomId: $roomId) {
    id
    content
    author { name }
  }
}`;

const faq = [
  {
    question: "What is Hoppscotch?",
    answer: "Hoppscotch is a free, open-source API development platform that runs in the browser. It supports REST, GraphQL, WebSocket, Server-Sent Events, Socket.IO, and MQTT from a single web interface. Unlike Postman, it requires no desktop installation and can be self-hosted. The @hoppscotch/cli package enables automated collection runs in CI/CD pipelines."
  },
  {
    question: "How does Hoppscotch differ from Postman?",
    answer: "Hoppscotch is fully open source (MIT) and web-based, while Postman is proprietary and requires a desktop install. Hoppscotch loads instantly in a browser tab with no account requirement for basic use and can be self-hosted for full data control. Postman has a more mature ecosystem and broader marketplace integrations. For teams needing self-hosted solutions or lightweight tooling, Hoppscotch is often preferred."
  },
  {
    question: "Can Hoppscotch be used in CI/CD pipelines?",
    answer: "Yes. Install @hoppscotch/cli globally with npm install -g @hoppscotch/cli and use the hopp command to run collection JSON files from the terminal. Pass environment files with --env and output JUnit XML with --reporter-junit. This integrates with GitHub Actions, GitLab CI, Jenkins, and other pipeline systems."
  },
  {
    question: "How do I set up environment variables in Hoppscotch?",
    answer: "In the web app, open the Environments panel in the left sidebar, create an environment, and add key-value pairs. Reference them in any request field using the <<VARIABLE_NAME>> syntax. Mark variables as secret to mask their values in the UI. For CLI usage, export environments as JSON and pass them with the --env flag."
  },
  {
    question: "Does Hoppscotch support GraphQL subscriptions?",
    answer: "Yes. The dedicated GraphQL tab supports queries, mutations, and subscriptions over WebSocket. Hoppscotch auto-fetches the API schema via introspection. You write queries in the editor, provide variables in a JSON panel, and open live subscription connections — all in the browser."
  },
  {
    question: "How do I self-host Hoppscotch?",
    answer: "Clone the hoppscotch/hoppscotch repository, copy .env.example to .env, and fill in your PostgreSQL database URL, SMTP server, and OAuth credentials. Run docker compose up to start the app, admin dashboard, and backend services. All data is stored in your own PostgreSQL instance."
  },
];
---

<BaseLayout
  title="Hoppscotch — Open-Source API Testing Tool"
  description="Hoppscotch is a lightweight, open-source API testing platform that runs in the browser. Test REST, GraphQL, WebSocket, and more — with a CLI for CI/CD and Docker-based self-hosting."
  tool="hoppscotch, api testing, rest client, graphql client, postman alternative, hopp cli, self-hosted api tool"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Hoppscotch — Open-Source API Testing Tool",
    "url": "https://devplaybook.cc/tools/hoppscotch",
    "description": "Hoppscotch is a lightweight open-source API testing platform running in the browser, supporting REST, GraphQL, WebSocket, and CI/CD via the hopp CLI.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Hoppscotch</h1>
  <p class="text-text-muted mb-6">
    A fast, open-source API development platform that runs entirely in the browser.
    Test REST, GraphQL, WebSocket, SSE, and real-time APIs — no desktop install required.
    Automate collection runs in CI/CD with the <code class="bg-bg-card px-1 rounded text-sm">hopp</code> CLI.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Web-based, no install</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> REST, GraphQL, WebSocket</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Environment variables</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CLI for CI/CD (hopp)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Self-hostable via Docker</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Open source (MIT)</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Hoppscotch?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Hoppscotch (formerly Postwoman) is an open-source API development ecosystem. What started as a browser-based alternative to Postman has grown into a comprehensive platform supporting REST, GraphQL, WebSocket, Server-Sent Events, Socket.IO, and MQTT — all from a single interface at hoppscotch.io.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    Because it runs in the browser, there is nothing to install for basic use. Collections and workspaces are stored locally via IndexedDB or synced to an account. For teams requiring data sovereignty, a Docker Compose deployment puts all data in your own PostgreSQL instance. The <code class="bg-bg-card px-1 rounded text-xs">@hoppscotch/cli</code> package extends the platform into automated pipeline testing.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Multi-protocol support</strong> — REST, GraphQL, WebSocket, SSE, Socket.IO, and MQTT in one unified interface</li>
    <li><strong>Collections and workspaces</strong> — organize requests into nested folders; share with teammates via team workspaces</li>
    <li><strong>Environment variables</strong> — define named environments (dev/staging/prod) and switch with one click; supports secret masking</li>
    <li><strong>Pre-request and test scripts</strong> — JavaScript scripting using the pw API for lifecycle automation and response assertions</li>
    <li><strong>GraphQL schema browser</strong> — introspection-based explorer with autocomplete, variable panels, and subscription support</li>
    <li><strong>Hoppscotch CLI (hopp)</strong> — run collection files from the terminal with environment injection and JUnit XML reporting</li>
    <li><strong>Self-hosting</strong> — Docker Compose setup with PostgreSQL, OAuth SSO, and an admin dashboard</li>
    <li><strong>History and shareable links</strong> — persistent request history and one-click URL sharing for individual requests</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">CLI Installation and Usage</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={installExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Environment Variables</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Define variables in the web app or via a JSON file, then reference them using the <code class="bg-bg-card px-1 rounded text-xs">&lt;&lt;VARIABLE_NAME&gt;&gt;</code> syntax in any request field — URL, headers, body, or authorization.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={envExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Test Scripts</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    The <code class="bg-bg-card px-1 rounded text-xs">pw</code> scripting object is available in pre-request and post-response panels. Use <code class="bg-bg-card px-1 rounded text-xs">pw.test()</code>, <code class="bg-bg-card px-1 rounded text-xs">pw.expect()</code>, and <code class="bg-bg-card px-1 rounded text-xs">pw.env.set()</code> for dynamic behavior and assertions.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={scriptExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">GraphQL Support</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    The GraphQL tab auto-fetches your schema via introspection. Build queries with the schema explorer, provide variables in a JSON panel, and open live subscription connections over WebSocket — all in the browser.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={graphqlExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Hoppscotch vs Postman</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">Hoppscotch</th>
          <th class="border border-border px-3 py-2 text-left">Postman</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2">License</td><td class="border border-border px-3 py-2 text-green-400">Open source (MIT)</td><td class="border border-border px-3 py-2">Proprietary</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Deployment</td><td class="border border-border px-3 py-2">Web app + self-host</td><td class="border border-border px-3 py-2">Desktop app + cloud</td></tr>
        <tr><td class="border border-border px-3 py-2">Desktop install required</td><td class="border border-border px-3 py-2 text-green-400">No</td><td class="border border-border px-3 py-2">Yes</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Self-hosting</td><td class="border border-border px-3 py-2 text-green-400">Yes (Docker)</td><td class="border border-border px-3 py-2">No</td></tr>
        <tr><td class="border border-border px-3 py-2">WebSocket / SSE native</td><td class="border border-border px-3 py-2 text-green-400">Yes</td><td class="border border-border px-3 py-2">Partial</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Ecosystem maturity</td><td class="border border-border px-3 py-2">Growing</td><td class="border border-border px-3 py-2 text-green-400">Mature</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pros and Cons</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-green-400 mb-2">Pros</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✓ Zero install friction — open a browser tab and start testing</li>
        <li>✓ Fully open source with active community development</li>
        <li>✓ Self-hostable for data-sensitive teams</li>
        <li>✓ Native WebSocket, SSE, Socket.IO, and MQTT support</li>
        <li>✓ Free CLI for CI/CD pipeline integration</li>
      </ul>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-red-400 mb-2">Cons</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✗ Smaller integration ecosystem than Postman</li>
        <li>✗ Team collaboration requires self-hosting or a paid cloud plan</li>
        <li>✗ Script API (pw.*) is less documented than Postman's pm.*</li>
        <li>✗ No built-in mock server feature</li>
        <li>✗ Browser extension may be needed for localhost requests in some setups</li>
      </ul>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="hoppscotch" relatedTags={['api', 'testing', 'rest', 'graphql', 'cli', 'open-source']} />
</BaseLayout>
