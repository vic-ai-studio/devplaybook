---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CloudflareWorkersKvSimulator from '../../components/CloudflareWorkersKvSimulator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Cloudflare Workers KV?",
    answer: "Workers KV is a global key-value data store built into Cloudflare's edge network. It is eventually consistent — writes propagate to all edge nodes within ~60 seconds. It is ideal for storing configuration, feature flags, session data, and content that is read frequently and written occasionally."
  },
  {
    question: "How does this simulator differ from the real KV?",
    answer: "This simulator runs in-browser memory — data is lost on page refresh. It mimics the Workers KV JavaScript API surface (get, put, delete, list, getWithMetadata) but does not enforce real KV limits (key size: 512 bytes, value size: 25MB, 1,000 keys per list call) and has no propagation delay."
  },
  {
    question: "What is the difference between get() and getWithMetadata()?",
    answer: "env.MY_KV.get(key) returns the stored string value (or null). env.MY_KV.getWithMetadata(key) returns { value, metadata } where metadata is an optional structured object stored alongside the value. Metadata is useful for storing TTL hints, content types, or any structured data without encoding it in the value string."
  },
  {
    question: "When should I use KV vs Durable Objects vs D1?",
    answer: "KV is best for globally distributed reads with low write frequency. Durable Objects provide strongly consistent, low-latency storage with co-location — good for real-time collaboration, counters, and rate limiting. D1 is a relational SQLite database at the edge — use it when you need SQL queries, joins, and transactions."
  },
  {
    question: "What does expirationTtl do?",
    answer: "expirationTtl sets a TTL in seconds after which the key is automatically deleted. For example, { expirationTtl: 3600 } deletes the key after one hour. Useful for session tokens, rate-limit counters, and temporary data. The minimum TTL is 60 seconds."
  },
  {
    question: "How do I bind a KV namespace to my Worker?",
    answer: "Define the binding in your wrangler.toml: [[kv_namespaces]] binding = 'MY_KV' id = 'your-namespace-id'. Then access it in your Worker via env.MY_KV. Run 'wrangler kv:namespace create MY_KV' to create a namespace and get its ID."
  },
];
---

<BaseLayout
  title="Cloudflare Workers KV Simulator — Test KV Operations in Your Browser"
  description="Simulate Cloudflare Workers KV operations in-browser. Supports get, put, delete, list, and getWithMetadata with metadata and TTL. Generates Worker code snippets. No account needed."
  tool="Cloudflare Workers KV, KV simulator, Workers KV tester, edge key-value store, Cloudflare edge storage"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Cloudflare Workers KV Simulator",
    "url": "https://devplaybook.cc/tools/cloudflare-workers-kv-simulator",
    "description": "Simulate Cloudflare Workers KV API operations in your browser. No Cloudflare account needed.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Cloudflare Workers KV Simulator</h1>
  <p class="text-text-muted mb-4">
    Simulate Cloudflare Workers KV operations right in your browser — no Cloudflare account or
    <code class="font-mono bg-surface px-1 rounded text-sm">wrangler</code> setup needed.
    Practice <code class="font-mono bg-surface px-1 rounded text-sm">get</code>,
    <code class="font-mono bg-surface px-1 rounded text-sm">put</code>,
    <code class="font-mono bg-surface px-1 rounded text-sm">delete</code>,
    <code class="font-mono bg-surface px-1 rounded text-sm">list</code>, and
    <code class="font-mono bg-surface px-1 rounded text-sm">getWithMetadata</code> with
    an interactive operation log and generated Worker code snippets.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 KV operations</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Metadata & TTL support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Code snippet generator</span>
  </div>
  <CloudflareWorkersKvSimulator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Cloudflare Workers KV Simulator" relatedTags={['cloudflare', 'workers', 'edge', 'kv-store', 'serverless', 'developer-tools']} />
</BaseLayout>
