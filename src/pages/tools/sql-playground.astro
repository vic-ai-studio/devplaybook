---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SqlPlayground from '../../components/SqlPlayground.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What SQL dialect does this tool support?", answer: "This tool runs SQLite (via sql.js compiled to WebAssembly). SQLite supports most standard SQL: SELECT, WHERE, GROUP BY, HAVING, ORDER BY, LIMIT, JOIN, subqueries, window functions, CTEs (WITH), and aggregate functions. It does not support stored procedures, user-defined functions, or MySQL/PostgreSQL-specific syntax." },
  { question: "Does my data get sent to a server?", answer: "No. Everything runs in your browser using SQLite compiled to WebAssembly (sql.js). Your CSV data and SQL queries never leave your machine. The WASM binary is loaded from a public CDN (cdnjs.cloudflare.com), but your actual data stays local." },
  { question: "How do I import data?", answer: "Paste CSV data (comma-separated, first row as headers) into the CSV input area, then click 'Import CSV'. The tool creates a table named 'data' with columns matching your CSV headers. You can then run any SELECT query against it. Re-importing will replace the previous table." },
  { question: "Can I run multiple SQL statements?", answer: "Yes. You can run multiple statements separated by semicolons. Each SELECT statement that returns results will show as a separate result tab (Result 1, Result 2, etc.). Non-SELECT statements like CREATE TABLE or INSERT can also be run." },
  { question: "What happens to my data when I close the page?", answer: "The database is in-memory and not persisted. When you close or refresh the page, all imported data and query results are lost. To save your work, export results as CSV using the Export button." },
  { question: "What are common SQL queries I can try?", answer: "SELECT * FROM data; (all rows) — SELECT COUNT(*) FROM data; (count) — SELECT col, AVG(num_col) as avg FROM data GROUP BY col ORDER BY avg DESC; (aggregate) — SELECT * FROM data WHERE col LIKE '%keyword%'; (text search) — SELECT DISTINCT col FROM data; (unique values)" },
];
---

<BaseLayout
  title="SQL Playground — Free In-Browser SQLite Executor"
  description="Import CSV data and run SQL queries in your browser. Uses SQLite WASM (sql.js) — no server, no sign-up. Filter, aggregate, and export results. Supports SELECT, JOIN, GROUP BY, CTEs, and more."
  tool="SQL Playground, SQLite Online, SQL Query Editor, SQL CSV Query, Browser SQL, sql.js"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "SQL Playground",
    "url": "https://devplaybook.cc/tools/sql-playground",
    "description": "Import CSV and run SQL queries in your browser. SQLite WASM engine — no server required. Supports SELECT, JOIN, GROUP BY, CTEs. Export results as CSV.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">SQL Playground</h1>
  <p class="text-text-muted mb-4">Import CSV data and run SQL queries entirely in your browser. Powered by <strong>SQLite WASM</strong> (sql.js) — no server, no sign-up, no data uploaded anywhere. Supports SELECT, JOIN, GROUP BY, CTEs, window functions, and more. Export query results as CSV.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> SQLite in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Import CSV, export results</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No data leaves your device</span>
  </div>
  <SqlPlayground client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SQL Playground" relatedTags={['database', 'sql', 'data', 'csv', 'developer-tools']} />
</BaseLayout>
