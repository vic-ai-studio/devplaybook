---
import BaseLayout from '../../layouts/BaseLayout.astro';
import VueComponentGenerator from '../../components/VueComponentGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Vue 3 Composition API and script setup?",
    answer: "`<script setup>` is the recommended way to write Vue 3 components. It's syntactic sugar over the Composition API that removes boilerplate: no `export default`, no explicit `setup()` function, and all top-level declarations are automatically exposed to the template. Variables defined with `ref()` or `reactive()` are directly usable in templates. It pairs perfectly with TypeScript using `defineProps<Props>()` and `defineEmits<Emits>()`."
  },
  {
    question: "How do I define props with TypeScript in script setup?",
    answer: "Use `defineProps<Props>()` with a TypeScript interface. For default values, wrap with `withDefaults()`: `const props = withDefaults(defineProps<{ title: string; count?: number }>(), { count: 0 })`. The `Props` interface is type-checked at compile time by the Vue compiler. Avoid mixing runtime props declaration (`defineProps({ title: String })`) with the type-based approach in the same component."
  },
  {
    question: "What is the difference between ref() and reactive()?",
    answer: "`ref()` wraps a value in a reactive container — access it via `.value` in script, but the template auto-unwraps it. Use `ref` for primitives (strings, numbers, booleans) and for reactive object references you might reassign. `reactive()` makes an entire object deeply reactive — no `.value` needed. Drawback: you can't destructure a reactive() object without losing reactivity (use `toRefs()` to fix this). Stick with `ref` for most cases."
  },
  {
    question: "When should I use watch() vs watchEffect()?",
    answer: "`watch(source, callback)` runs only when the specific source changes, giving you both old and new values. It's lazy by default (doesn't run on mount). `watchEffect(callback)` tracks all reactive dependencies accessed inside it and runs immediately — similar to Svelte's $effect. Use `watch` when you need old values or want precise control over what triggers the watcher. Use `watchEffect` for effects that should run once immediately and re-run when any dependency changes."
  },
  {
    question: "What is a Vue composable and how should I structure one?",
    answer: "A composable is a function that uses the Composition API to encapsulate and reuse stateful logic. Name it with a `use` prefix (e.g., `useCounter`, `useFetch`). Return reactive state and methods as a plain object. Composables are called at the top level of `<script setup>` (not inside conditions or loops) so Vue can properly track their lifecycle. Libraries like VueUse provide hundreds of production-ready composables."
  },
  {
    question: "How do provide/inject work in Vue 3?",
    answer: "provide/inject is Vue's dependency injection — the ancestor-to-descendant alternative to prop drilling. A parent calls `provide('key', value)` to make a value available to all descendants. A descendant calls `const val = inject('key')` to receive it. For type safety, use InjectionKey: `const countKey: InjectionKey<Ref<number>> = Symbol('count')`. inject() accepts a default value as the second argument."
  },
];
---

<BaseLayout
  title="Vue Component Generator — Vue 3 Composition API script setup Boilerplate"
  description="Generate Vue 3 Composition API components with script setup, TypeScript-typed props, defineEmits, composables, watch, and provide/inject. Copy-paste ready boilerplate. Runs in your browser."
  tool="vue component generator, vue 3 composition api, script setup boilerplate, vue template generator, defineProps defineEmits"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Vue Component Generator",
    "url": "https://devplaybook.cc/tools/vue-component-generator",
    "description": "Generate Vue 3 Composition API component boilerplate with script setup, typed props, emits, composables, and watch. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Vue Component Generator</h1>
  <p class="text-text-muted mb-4">
    Build Vue 3 <code class="font-mono text-sm bg-bg-card px-1 rounded">&lt;script setup&gt;</code> components
    with TypeScript-first props via <code class="font-mono text-sm bg-bg-card px-1 rounded">defineProps&lt;T&gt;</code>,
    typed emits via <code class="font-mono text-sm bg-bg-card px-1 rounded">defineEmits</code>,
    composables, and optional <code class="font-mono text-sm bg-bg-card px-1 rounded">watch</code> / provide-inject setup.
    Copy the generated <code class="font-mono text-sm bg-bg-card px-1 rounded">.vue</code> file and drop it into your project.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> defineProps + withDefaults</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Typed emits</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Composable imports</span>
  </div>
  <VueComponentGenerator client:only="preact" />

  <section class="mt-12 space-y-8 text-sm text-text-muted">
    <div>
      <h2 class="text-xl font-semibold text-text mb-3">script setup vs Options API: Quick Comparison</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-xs font-mono">
          <thead>
            <tr class="border-b border-border">
              <th class="text-left py-2 pr-4 text-text font-semibold">Feature</th>
              <th class="text-left py-2 pr-4 text-text font-semibold">Options API</th>
              <th class="text-left py-2 text-text font-semibold">script setup (Composition API)</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border/50">
            <tr>
              <td class="py-2 pr-4 text-text">Props</td>
              <td class="py-2 pr-4">props: &#123; title: String &#125;</td>
              <td class="py-2">defineProps&lt;&#123; title: string &#125;&gt;()</td>
            </tr>
            <tr>
              <td class="py-2 pr-4 text-text">State</td>
              <td class="py-2 pr-4">data() &#123; return &#123; count: 0 &#125; &#125;</td>
              <td class="py-2">const count = ref(0)</td>
            </tr>
            <tr>
              <td class="py-2 pr-4 text-text">Computed</td>
              <td class="py-2 pr-4">computed: &#123; doubled() &#123; ... &#125; &#125;</td>
              <td class="py-2">const doubled = computed(() =&gt; count.value * 2)</td>
            </tr>
            <tr>
              <td class="py-2 pr-4 text-text">Methods</td>
              <td class="py-2 pr-4">methods: &#123; increment() &#123; &#125; &#125;</td>
              <td class="py-2">function increment() &#123; &#125;</td>
            </tr>
            <tr>
              <td class="py-2 pr-4 text-text">Lifecycle</td>
              <td class="py-2 pr-4">mounted() &#123; &#125;</td>
              <td class="py-2">onMounted(() =&gt; &#123; &#125;)</td>
            </tr>
            <tr>
              <td class="py-2 pr-4 text-text">Logic reuse</td>
              <td class="py-2 pr-4">Mixins (fragile)</td>
              <td class="py-2">Composables (explicit, type-safe)</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div>
      <h2 class="text-xl font-semibold text-text mb-3">Typed Props Pattern (Recommended)</h2>
      <pre class="bg-surface border border-border rounded-lg p-4 text-xs font-mono overflow-auto"><code>{&#96;<script setup lang="ts">
// TypeScript interface approach — preferred
interface Props {
  title: string;
  count?: number;
  items?: string[];
}

const props = withDefaults(defineProps<Props>(), {
  count: 0,
  items: () => [], // Factory function for objects/arrays
});

// Typed emits
const emit = defineEmits<{
  update: [value: number];      // Vue 3.3+ named tuple
  select: [item: string];
}>();

// Usage
emit('update', props.count + 1);
</script>&#96;}</code></pre>
    </div>

    <div>
      <h2 class="text-xl font-semibold text-text mb-3">Building a Composable</h2>
      <p class="mb-3">
        A composable extracts reactive logic into a reusable function. Here's a minimal
        <code class="font-mono text-xs bg-surface px-1 rounded">useCounter</code> pattern:
      </p>
      <pre class="bg-surface border border-border rounded-lg p-4 text-xs font-mono overflow-auto"><code>{&#96;// composables/useCounter.ts
import { ref, computed } from 'vue';

export function useCounter(initial = 0) {
  const count = ref(initial);
  const doubled = computed(() => count.value * 2);

  function increment() { count.value++; }
  function reset() { count.value = initial; }

  return { count, doubled, increment, reset };
}

// In component:
// const { count, increment } = useCounter(10);&#96;}</code></pre>
    </div>

    <div>
      <h2 class="text-xl font-semibold text-text mb-3">Component Best Practices</h2>
      <ul class="space-y-1 list-disc list-inside">
        <li>Always use <code class="font-mono text-xs bg-surface px-1 rounded">lang="ts"</code> — TypeScript catches prop type mismatches at compile time</li>
        <li>Prefer <code class="font-mono text-xs bg-surface px-1 rounded">defineProps&lt;T&gt;()</code> over runtime props for full TypeScript inference</li>
        <li>Default object/array props with factory functions: <code class="font-mono text-xs bg-surface px-1 rounded">items: () =&gt; []</code></li>
        <li>Name emits in kebab-case in templates (<code class="font-mono text-xs bg-surface px-1 rounded">@my-event</code>) but camelCase in defineEmits</li>
        <li>Use <code class="font-mono text-xs bg-surface px-1 rounded">&lt;style scoped&gt;</code> — prevents style leakage between components</li>
        <li>Extract logic over 30 lines into a composable in <code class="font-mono text-xs bg-surface px-1 rounded">composables/</code></li>
      </ul>
    </div>
  </section>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Vue Component Generator" relatedTags={['frontend', 'vue', 'javascript', 'typescript', 'components']} />
</BaseLayout>
