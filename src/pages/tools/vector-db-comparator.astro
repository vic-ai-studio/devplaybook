---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a vector database?", answer: "A vector database stores and indexes high-dimensional numeric vectors (embeddings) produced by machine learning models. Unlike relational databases that filter by exact values, vector databases support similarity search — finding the nearest neighbors to a query vector using metrics like cosine similarity or Euclidean distance. This powers semantic search, RAG (Retrieval-Augmented Generation), recommendation systems, and more." },
  { question: "Pinecone vs Weaviate vs Qdrant vs Chroma — which should I pick?", answer: "Pinecone is fully managed and operationally simple, ideal for teams that want zero infra overhead. Weaviate offers rich GraphQL querying and hybrid search with BM25+vectors. Qdrant excels at advanced filtering with payload indexing and is highly Rust-performant. Chroma is the easiest local/embedded option for prototyping. For production at scale: Pinecone or Qdrant. For local dev/RAG prototypes: Chroma." },
  { question: "What is HNSW and why does it matter?", answer: "HNSW (Hierarchical Navigable Small World) is the dominant approximate nearest-neighbor (ANN) index algorithm. It organizes vectors into a layered graph, enabling sub-linear search time O(log n) vs brute-force O(n). All four databases support HNSW. Higher M (graph degree) and efConstruction improve recall at the cost of memory and indexing time." },
  { question: "What is hybrid search?", answer: "Hybrid search combines dense vector similarity (semantic) with sparse keyword matching (BM25/TF-IDF). This outperforms pure vector search when users use exact keywords or when the corpus has highly domain-specific terminology. Weaviate has the most mature hybrid search. Qdrant supports sparse vectors natively. Pinecone has hybrid via its sparse-dense architecture." },
  { question: "Is Chroma production-ready?", answer: "Chroma is excellent for local development, notebooks, and small-scale deployments. Its hosted/cloud offering is newer. For large-scale production workloads (millions of vectors, SLA requirements), Pinecone, Qdrant Cloud, or self-hosted Weaviate/Qdrant are better choices. Chroma shines as the fastest path from zero to a working RAG prototype." },
];

const dbs = [
  {
    name: 'Pinecone',
    color: '#3b82f6',
    tag: 'Managed SaaS',
    tagColor: 'blue',
    hosting: 'Cloud only (managed)',
    selfHost: false,
    openSource: false,
    license: 'Proprietary',
    index: 'HNSW, IVF',
    hybrid: 'Yes (sparse+dense)',
    filtering: 'Metadata filters',
    languages: 'Python, JS, Go, Java',
    freeTier: '1 index, 100K vectors',
    pricing: 'Pay-per-use (~$0.096/GB/mo)',
    bestFor: 'Fastest path to production; teams wanting zero infra ops',
    score: { setup: 5, scale: 5, filtering: 4, openness: 1, hybrid: 4 },
  },
  {
    name: 'Weaviate',
    color: '#8b5cf6',
    tag: 'Open Source + Cloud',
    tagColor: 'purple',
    hosting: 'Cloud or self-host',
    selfHost: true,
    openSource: true,
    license: 'BSD-3',
    index: 'HNSW, Flat',
    hybrid: 'Yes (BM25 + vector)',
    filtering: 'Rich GraphQL filters',
    languages: 'Python, JS, Go, Java, .NET',
    freeTier: 'Sandbox (14 days)',
    pricing: 'Cloud from $25/mo; self-host free',
    bestFor: 'Rich querying, multi-tenancy, generative search with LLMs',
    score: { setup: 3, scale: 5, filtering: 5, openness: 5, hybrid: 5 },
  },
  {
    name: 'Qdrant',
    color: '#10b981',
    tag: 'Open Source + Cloud',
    tagColor: 'green',
    hosting: 'Cloud or self-host',
    selfHost: true,
    openSource: true,
    license: 'Apache 2.0',
    index: 'HNSW, Scalar, PQ',
    hybrid: 'Yes (sparse vectors)',
    filtering: 'Payload indexing (best-in-class)',
    languages: 'Python, JS, Rust, Go',
    freeTier: '1GB free cluster',
    pricing: 'Cloud from $0/1GB; self-host free',
    bestFor: 'High-performance filtering, Rust core, advanced quantization',
    score: { setup: 4, scale: 5, filtering: 5, openness: 5, hybrid: 4 },
  },
  {
    name: 'Chroma',
    color: '#f59e0b',
    tag: 'Local / Embedded',
    tagColor: 'yellow',
    hosting: 'Local, self-host, cloud (beta)',
    selfHost: true,
    openSource: true,
    license: 'Apache 2.0',
    index: 'HNSW (hnswlib)',
    hybrid: 'Partial (keyword via metadata)',
    filtering: 'Metadata filters',
    languages: 'Python, JS',
    freeTier: 'Fully free (local)',
    pricing: 'Free local; cloud pricing TBD',
    bestFor: 'Rapid prototyping, RAG experiments, local LLM stacks',
    score: { setup: 5, scale: 2, filtering: 3, openness: 5, hybrid: 2 },
  },
];

const dimensions = ['setup', 'scale', 'filtering', 'openness', 'hybrid'] as const;
const dimLabels: Record<string, string> = { setup: 'Ease of Setup', scale: 'Scalability', filtering: 'Filtering', openness: 'Open Source', hybrid: 'Hybrid Search' };
---

<BaseLayout
  title="Vector DB Comparator — Pinecone vs Weaviate vs Qdrant vs Chroma"
  description="Side-by-side comparison of the top vector databases: Pinecone, Weaviate, Qdrant, and Chroma. Compare features, pricing, hosting, hybrid search, and use cases to pick the best vector store for your AI project."
  tool="vector database comparison, Pinecone vs Weaviate, Qdrant vs Chroma, vector store selection, RAG database, embedding database"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Vector DB Comparator</h1>
  <p class="text-text-muted mb-4">Compare Pinecone, Weaviate, Qdrant, and Chroma side-by-side on features, pricing, and use cases. Find the right vector store for your AI and RAG applications.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 4 major vector DBs</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Features, pricing, hosting</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Scoring radar chart</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Use case matcher</span>
  </div>

  <!-- Filter buttons -->
  <div class="flex gap-2 flex-wrap mb-6">
    <button id="filter-all" class="filter-btn text-sm px-4 py-1.5 rounded-full border border-primary text-primary bg-primary/10 font-semibold transition-all" data-filter="all">All</button>
    <button class="filter-btn text-sm px-4 py-1.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-filter="open-source">Open Source Only</button>
    <button class="filter-btn text-sm px-4 py-1.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-filter="self-host">Self-Hostable</button>
    <button class="filter-btn text-sm px-4 py-1.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-filter="hybrid">Hybrid Search</button>
    <button class="filter-btn text-sm px-4 py-1.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-filter="free">Has Free Tier</button>
  </div>

  <!-- Cards grid -->
  <div id="db-cards" class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-8">
    {dbs.map(db => (
      <div
        class="db-card bg-bg-card border border-border rounded-xl p-5 transition-all"
        data-open-source={db.openSource.toString()}
        data-self-host={db.selfHost.toString()}
        data-hybrid={db.hybrid.startsWith('Yes').toString()}
        data-free="true"
      >
        <div class="flex items-start justify-between mb-3">
          <div>
            <h2 class="text-xl font-bold" style={`color: ${db.color}`}>{db.name}</h2>
            <span class={`text-xs px-2 py-0.5 rounded-full mt-1 inline-block ${
              db.tagColor === 'blue' ? 'bg-blue-500/10 text-blue-400 border border-blue-500/20' :
              db.tagColor === 'purple' ? 'bg-purple-500/10 text-purple-400 border border-purple-500/20' :
              db.tagColor === 'green' ? 'bg-green-500/10 text-green-400 border border-green-500/20' :
              'bg-yellow-500/10 text-yellow-400 border border-yellow-500/20'
            }`}>{db.tag}</span>
          </div>
          <div class="text-right text-xs text-text-muted">
            <div>{db.license}</div>
          </div>
        </div>

        <!-- Score bars -->
        <div class="space-y-2 mb-4">
          {dimensions.map(dim => (
            <div class="flex items-center gap-2">
              <span class="text-xs text-text-muted w-24 shrink-0">{dimLabels[dim]}</span>
              <div class="flex-1 bg-bg-surface border border-border rounded-full h-2">
                <div class="h-full rounded-full transition-all" style={`width: ${db.score[dim] * 20}%; background-color: ${db.color}`}></div>
              </div>
              <span class="text-xs font-semibold w-4 text-right">{db.score[dim]}</span>
            </div>
          ))}
        </div>

        <!-- Key info -->
        <div class="space-y-1.5 text-sm">
          <div class="flex justify-between">
            <span class="text-text-muted">Hosting</span>
            <span class="font-medium text-right max-w-[60%]">{db.hosting}</span>
          </div>
          <div class="flex justify-between">
            <span class="text-text-muted">Index types</span>
            <span class="font-medium text-right">{db.index}</span>
          </div>
          <div class="flex justify-between">
            <span class="text-text-muted">Hybrid search</span>
            <span class={`font-medium ${db.hybrid.startsWith('Yes') ? 'text-green-400' : 'text-text-muted'}`}>{db.hybrid}</span>
          </div>
          <div class="flex justify-between">
            <span class="text-text-muted">Free tier</span>
            <span class="font-medium text-right max-w-[60%]">{db.freeTier}</span>
          </div>
          <div class="flex justify-between">
            <span class="text-text-muted">Pricing</span>
            <span class="font-medium text-right max-w-[60%] text-xs">{db.pricing}</span>
          </div>
          <div class="flex justify-between">
            <span class="text-text-muted">Languages</span>
            <span class="font-medium text-right text-xs max-w-[60%]">{db.languages}</span>
          </div>
        </div>

        <div class="mt-4 pt-4 border-t border-border">
          <div class="text-xs text-text-muted mb-1 font-semibold uppercase tracking-wide">Best for</div>
          <div class="text-sm">{db.bestFor}</div>
        </div>
      </div>
    ))}
  </div>

  <!-- Feature matrix -->
  <h2 class="text-base font-semibold mb-4">Feature Matrix</h2>
  <div class="overflow-x-auto mb-8">
    <table class="w-full text-sm min-w-[560px]">
      <thead>
        <tr class="text-text-muted text-xs uppercase border-b border-border">
          <th class="text-left pb-3 pr-4 font-medium">Feature</th>
          {dbs.map(db => (
            <th class="text-center pb-3 pr-4 font-semibold" style={`color: ${db.color}`}>{db.name}</th>
          ))}
        </tr>
      </thead>
      <tbody class="divide-y divide-border text-sm">
        <tr class="hover:bg-bg-card/50">
          <td class="py-3 pr-4 text-text-muted">Open Source</td>
          {dbs.map(db => <td class="py-3 pr-4 text-center">{db.openSource ? '✅' : '❌'}</td>)}
        </tr>
        <tr class="hover:bg-bg-card/50">
          <td class="py-3 pr-4 text-text-muted">Self-Hostable</td>
          {dbs.map(db => <td class="py-3 pr-4 text-center">{db.selfHost ? '✅' : '❌'}</td>)}
        </tr>
        <tr class="hover:bg-bg-card/50">
          <td class="py-3 pr-4 text-text-muted">Hybrid Search</td>
          {dbs.map(db => <td class="py-3 pr-4 text-center">{db.hybrid.startsWith('Yes') ? '✅' : '⚠️'}</td>)}
        </tr>
        <tr class="hover:bg-bg-card/50">
          <td class="py-3 pr-4 text-text-muted">Managed Cloud</td>
          {dbs.map(db => <td class="py-3 pr-4 text-center">{!db.selfHost || db.name === 'Chroma' ? (db.name === 'Pinecone' ? '✅' : '⚠️') : '✅'}</td>)}
        </tr>
        <tr class="hover:bg-bg-card/50">
          <td class="py-3 pr-4 text-text-muted">Multi-tenancy</td>
          {dbs.map(db => <td class="py-3 pr-4 text-center">{db.name === 'Weaviate' ? '✅' : db.name === 'Qdrant' ? '✅' : db.name === 'Pinecone' ? '✅' : '⚠️'}</td>)}
        </tr>
        <tr class="hover:bg-bg-card/50">
          <td class="py-3 pr-4 text-text-muted">Quantization</td>
          {dbs.map(db => <td class="py-3 pr-4 text-center">{db.name === 'Qdrant' ? '✅ (Scalar, PQ, BQ)' : db.name === 'Pinecone' ? '✅' : '⚠️'}</td>)}
        </tr>
        <tr class="hover:bg-bg-card/50">
          <td class="py-3 pr-4 text-text-muted">Free tier</td>
          {dbs.map(db => <td class="py-3 pr-4 text-center text-xs">{db.freeTier}</td>)}
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Use case matcher -->
  <h2 class="text-base font-semibold mb-4">Use Case Matcher</h2>
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block text-xs text-text-muted mb-1">Primary Use Case</label>
        <select id="use-case" class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="rag">RAG / Semantic Search</option>
          <option value="recommendation">Recommendations</option>
          <option value="prototype">Rapid Prototyping</option>
          <option value="production">Large-Scale Production</option>
          <option value="hybrid">Hybrid Search (keyword + semantic)</option>
          <option value="self-host">Self-Hosted / On-Premise</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Team Size</label>
        <select id="team-size" class="w-full bg-bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="solo">Solo / Hackathon</option>
          <option value="small">Small team (2–10)</option>
          <option value="startup">Startup (10–50)</option>
          <option value="enterprise">Enterprise (50+)</option>
        </select>
      </div>
    </div>
    <div id="recommendation" class="rounded-lg p-4 border text-sm bg-primary/5 border-primary/20">
      <div class="font-semibold mb-1" id="rec-title">—</div>
      <div class="text-text-muted" id="rec-reason">—</div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Vector DB Comparator" relatedTags={['ai', 'vector-db', 'embeddings', 'rag', 'llm', 'database']} />
</BaseLayout>

<script>
  const recs: Record<string, Record<string, { title: string; reason: string }>> = {
    rag: {
      solo: { title: 'Chroma', reason: 'pip install chromadb and you\'re running a local RAG pipeline in minutes. No account needed.' },
      small: { title: 'Qdrant', reason: 'Free 1GB cloud cluster, excellent Python SDK, best filtering for metadata-heavy RAG.' },
      startup: { title: 'Pinecone or Qdrant', reason: 'Pinecone for zero-ops simplicity; Qdrant Cloud for cost-efficiency and open-source flexibility.' },
      enterprise: { title: 'Weaviate or Pinecone', reason: 'Weaviate for self-hosted multi-tenancy and compliance; Pinecone for managed SLA at scale.' },
    },
    recommendation: {
      solo: { title: 'Chroma', reason: 'Fastest iteration for exploring recommendation algorithms locally.' },
      small: { title: 'Qdrant', reason: 'Payload filtering makes product attribute filtering trivial. Great Rust performance.' },
      startup: { title: 'Qdrant Cloud', reason: 'Payload indexing + sparse vectors handle collaborative + content-based filtering in one system.' },
      enterprise: { title: 'Pinecone', reason: 'Enterprise SLA, multi-region, and reliability for production recommendation APIs.' },
    },
    prototype: {
      solo: { title: 'Chroma', reason: 'Embedded mode: no server, no config, no account. `client = chromadb.Client()` and you\'re done.' },
      small: { title: 'Chroma or Qdrant', reason: 'Both have excellent local dev experience. Qdrant for when you plan to go to production.' },
      startup: { title: 'Qdrant', reason: 'Easy to run locally via Docker, then promote to Qdrant Cloud without changing your SDK code.' },
      enterprise: { title: 'Weaviate', reason: 'Docker Compose for local dev mirrors your self-hosted production setup.' },
    },
    production: {
      solo: { title: 'Pinecone', reason: 'For solo projects needing reliability without infra work, Pinecone\'s free tier and managed ops are unbeatable.' },
      small: { title: 'Qdrant Cloud', reason: 'Generous free tier, production-grade reliability, competitive pricing.' },
      startup: { title: 'Pinecone or Qdrant', reason: 'Pinecone for simplicity; Qdrant for cost at scale and open-source lock-in avoidance.' },
      enterprise: { title: 'Weaviate (self-hosted) or Pinecone', reason: 'Weaviate for control, compliance, and multi-tenancy. Pinecone for fully managed with enterprise SLA.' },
    },
    hybrid: {
      solo: { title: 'Weaviate', reason: 'The most mature BM25+vector hybrid search, even on local Docker.' },
      small: { title: 'Weaviate', reason: 'GraphQL interface for hybrid search is the most ergonomic. Good sandboxed cloud.' },
      startup: { title: 'Weaviate or Qdrant', reason: 'Weaviate for keyword+semantic; Qdrant for sparse vector hybrid approach (newer but powerful).' },
      enterprise: { title: 'Weaviate', reason: 'Production-grade hybrid search with multi-tenancy and managed cloud option.' },
    },
    'self-host': {
      solo: { title: 'Chroma', reason: 'Simplest to self-host: single Python process, no Docker required.' },
      small: { title: 'Qdrant', reason: 'Single Docker container, minimal config, excellent docs for self-hosting.' },
      startup: { title: 'Qdrant', reason: 'Apache 2.0 license, Helm chart for Kubernetes, strong community for self-hosted ops.' },
      enterprise: { title: 'Weaviate', reason: 'Best enterprise self-hosting story: Helm chart, multi-tenancy, RBAC, compliance features.' },
    },
  };

  function updateRec() {
    var useCase = (document.getElementById('use-case') as HTMLSelectElement).value;
    var teamSize = (document.getElementById('team-size') as HTMLSelectElement).value;
    var rec = recs[useCase]?.[teamSize];
    if (rec) {
      document.getElementById('rec-title')!.textContent = '→ Recommended: ' + rec.title;
      document.getElementById('rec-reason')!.textContent = rec.reason;
    }
  }

  document.getElementById('use-case')!.addEventListener('change', updateRec);
  document.getElementById('team-size')!.addEventListener('change', updateRec);
  updateRec();

  // Filter buttons
  document.querySelectorAll('.filter-btn').forEach(function(btn) {
    btn.addEventListener('click', function(this: HTMLElement) {
      var filter = this.getAttribute('data-filter')!;
      document.querySelectorAll('.filter-btn').forEach(function(b) {
        b.classList.remove('border-primary', 'text-primary', 'bg-primary/10', 'font-semibold');
        b.classList.add('border-border', 'text-text-muted');
      });
      this.classList.add('border-primary', 'text-primary', 'bg-primary/10', 'font-semibold');
      this.classList.remove('border-border', 'text-text-muted');

      document.querySelectorAll('.db-card').forEach(function(card: Element) {
        var el = card as HTMLElement;
        var show = filter === 'all'
          || (filter === 'open-source' && el.dataset.openSource === 'true')
          || (filter === 'self-host' && el.dataset.selfHost === 'true')
          || (filter === 'hybrid' && el.dataset.hybrid === 'true')
          || (filter === 'free' && el.dataset.free === 'true');
        el.style.display = show ? '' : 'none';
      });
    });
  });
</script>
