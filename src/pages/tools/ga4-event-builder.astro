---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Ga4EventBuilder from '../../components/Ga4EventBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is a GA4 event and how is it different from Universal Analytics?", answer: "In GA4, everything is an event — pageviews, button clicks, purchases, scrolls. Unlike Universal Analytics which used categories/actions/labels, GA4 uses a flexible key-value parameter model. Each event has a name and up to 25 custom parameters. This makes GA4 much more flexible but requires more intentional event design." },
  { question: "What is the difference between gtag() and dataLayer.push()?", answer: "gtag() is the direct Google Analytics SDK method — call it directly on pages where you load the GA4 tag. dataLayer.push() is for Google Tag Manager (GTM) — you push events to the dataLayer and GTM picks them up and forwards to GA4. Use dataLayer if you manage tracking via GTM; use gtag() for direct GA4 implementation." },
  { question: "What are recommended events in GA4?", answer: "GA4 has a set of recommended events with predefined schemas — like purchase, add_to_cart, begin_checkout, sign_up, login, search, view_item, generate_lead. Using these enables automatic integration with Google Ads, BigQuery exports, and built-in GA4 reports. Always prefer recommended events over custom events when the semantic fits." },
  { question: "What parameters can I send with a GA4 event?", answer: "Each event can have up to 25 custom parameters. GA4 automatically collects some parameters (page_location, page_title, session_id, etc.). Custom parameters must be registered as 'custom dimensions' or 'custom metrics' in the GA4 property settings before they appear in reports. String values max 100 chars, numeric values as numbers." },
  { question: "How do I validate my GA4 implementation?", answer: "Use Google Analytics Debugview (in GA4 admin → DebugView), the GA4 Tag Assistant Chrome extension, or send events in debug mode by adding &_dbg=1 to your gtag.js URL. Also check the Network tab in DevTools for requests to google-analytics.com/g/collect to verify event payloads are being sent." },
  { question: "What is the currency parameter and how should I format it?", answer: "The currency parameter uses ISO 4217 currency codes (USD, EUR, GBP, JPY, etc.). The value parameter should be a numeric amount — do not include currency symbols. For example: gtag('event', 'purchase', { currency: 'USD', value: 29.99, transaction_id: 'T_12345' }). This is required for revenue tracking in GA4." },
];
---

<BaseLayout
  title="GA4 Event Builder — Google Analytics 4 gtag() & dataLayer Code Generator"
  description="Build Google Analytics 4 event tracking code. Select standard GA4 events or create custom events, add parameters, and get ready-to-use gtag() and dataLayer.push() snippets with parameter validation."
  tool="GA4 Event Builder, Google Analytics 4 Event Generator, gtag Code Generator, dataLayer Event Builder, GA4 Custom Event"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Google Analytics 4 Event Builder</h1>
  <p class="text-text-muted mb-4">Select a GA4 recommended event or build a custom event. Add parameters, validate against GA4 schemas, and copy ready-to-use <code class="font-mono text-sm">gtag()</code> or <code class="font-mono text-sm">dataLayer.push()</code> code.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GA4 recommended & custom events</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> gtag() and dataLayer.push() output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Parameter validation</span>
  </div>
  <Ga4EventBuilder client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Google Analytics 4 Event Builder" relatedTags={['analytics', 'google-analytics', 'tracking', 'javascript', 'marketing']} />
</BaseLayout>
