---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const installExample = `# macOS (Homebrew)
brew install httpie

# Python / pip (cross-platform)
pip install httpie

# Ubuntu / Debian
sudo apt install httpie

# Windows (Scoop)
scoop install httpie

# Verify installation
http --version

# HTTPie Desktop GUI (macOS / Windows / Linux)
# https://httpie.io/desktop`;

const getExample = `# Simple GET request - HTTPie adds headers and pretty-prints JSON automatically
http GET https://api.github.com/users/torvalds

# Shorthand - GET is the default when no body is provided
http https://api.github.com/users/torvalds

# With query parameters (key==value syntax)
http https://api.github.com/search/repositories q==httpie sort==stars

# Response headers only
http --headers https://api.github.com/users/torvalds

# Response body only (pipe-friendly)
http --body https://api.github.com/users/torvalds`;

const postExample = `# POST with JSON body - HTTPie sends JSON by default when key=value pairs are given
http POST https://httpbin.org/post name="Alice" age:=30 active:=true

# Equivalent curl command for comparison:
# curl -X POST https://httpbin.org/post #   -H "Content-Type: application/json" #   -d '{"name":"Alice","age":30,"active":true}'

# POST with explicit raw JSON
echo '{"name":"Alice"}' | http POST https://httpbin.org/post Content-Type:application/json

# POST with a JSON file
http POST https://httpbin.org/post @payload.json

# Form data (not JSON)
http --form POST https://httpbin.org/post username=alice password=secret`;

const authExample = `# Bearer token auth
http GET https://api.example.com/profile Authorization:"Bearer eyJhbGciOiJIUzI1NiJ9..."

# HTTP Basic auth
http -a username:password GET https://api.example.com/protected

# API key in header
http GET https://api.example.com/data X-API-Key:your-key-here

# Session - persist cookies and headers across requests
http --session=./session.json POST https://api.example.com/login email=user@example.com password=secret
http --session=./session.json GET https://api.example.com/me`;

const uploadExample = `# Upload a file (multipart form)
http --form POST https://httpbin.org/post file@/path/to/photo.jpg

# Download a file and save it
http --download https://example.com/file.zip

# Follow redirects
http --follow GET https://httpbin.org/redirect/3

# Set timeout (seconds)
http --timeout=10 GET https://slow-api.example.com/data

# Verbose mode - shows request and response headers
http --verbose POST https://httpbin.org/post name=test`;

const faq = [
  {
    question: "What is HTTPie?",
    answer: "HTTPie is a command-line HTTP client designed to make interacting with APIs and web services as human-friendly as possible. Unlike curl, HTTPie automatically formats and color-codes JSON responses, uses an intuitive key=value syntax for request data, sends JSON by default for POST/PUT/PATCH requests, and displays request and response headers in a readable way. It is available as a CLI tool, a Python library, and a desktop GUI application."
  },
  {
    question: "How does HTTPie compare to curl?",
    answer: "curl is a lower-level, highly portable HTTP client focused on flexibility and scripting. HTTPie is a higher-level tool optimized for human readability and ease of use. With HTTPie you write 'http POST api.example.com/users name=Alice' instead of curl's verbose flags and raw JSON strings. HTTPie color-codes output, auto-formats JSON, and infers Content-Type from the data you provide. curl has broader protocol support (FTP, SFTP, etc.) and is available on virtually every system by default."
  },
  {
    question: "How do I send JSON data with HTTPie?",
    answer: "HTTPie sends JSON automatically when you use the key=value syntax for request data. String values use = (e.g., name=Alice), non-string values (numbers, booleans, arrays, objects) use := (e.g., age:=30, active:=true, tags:=[\"a\",\"b\"]). HTTPie sets Content-Type: application/json and Accept: application/json headers automatically. To send a raw JSON string, pipe it via stdin. To send a JSON file: http POST url @data.json."
  },
  {
    question: "How do HTTPie sessions work?",
    answer: "Sessions let you persist cookies, auth headers, and custom headers across multiple requests without repeating them. Create or reuse a session with --session=./session.json (a file path) or --session=session-name (a named session stored in your config dir). The first request with --session stores any Set-Cookie headers and auth info. Subsequent requests using the same session file automatically include those cookies and headers. This is useful for testing authenticated API flows where you log in once and then make several requests."
  },
  {
    question: "Is HTTPie free?",
    answer: "Yes. The HTTPie CLI is fully free and open source under the BSD license. It is available on PyPI (pip install httpie), Homebrew, APT, and other package managers. The HTTPie Desktop GUI application is also free to download and use. There is no paid tier, no account required for the CLI, and no feature gating - the full tool is available to everyone."
  },
  {
    question: "What is HTTPie Desktop?",
    answer: "HTTPie Desktop is a free GUI application that brings HTTPie's human-friendly interface to a visual, point-and-click environment. It supports the same intuitive syntax as the CLI, adds request collections, environment variables, response history, and a visual request builder. It is available for macOS, Windows, and Linux and is built on the same open-source foundation as the CLI. HTTPie Desktop is a direct alternative to Postman or Insomnia for developers who prefer a GUI over the terminal."
  },
];
---

<BaseLayout
  title="HTTPie - Human-Friendly HTTP Client for the CLI"
  description="HTTPie is a modern command-line HTTP client with color-coded output, intuitive JSON syntax, and built-in sessions. A developer-friendly alternative to curl for testing APIs."
  tool="httpie, http client, cli, curl alternative, api testing, rest client, command line http, json http client"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "HTTPie - Human-Friendly HTTP Client for the CLI",
    "url": "https://devplaybook.cc/tools/httpie",
    "description": "HTTPie is a modern command-line HTTP client with color-coded output, intuitive JSON syntax, and built-in sessions. A developer-friendly alternative to curl for testing APIs.",
  })} />

  <h1 class="text-3xl font-bold mb-2">HTTPie</h1>
  <p class="text-text-muted mb-6">
    Human-friendly HTTP client for the terminal. Color-coded JSON output, intuitive key=value syntax,
    JSON by default - no flags required for common operations. The developer-friendly alternative to curl.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Color-coded JSON output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Intuitive syntax</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> JSON by default</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Sessions support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Desktop GUI available</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Free &amp; open source</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is HTTPie?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    HTTPie is a command-line HTTP client built around one principle: interacting with HTTP APIs should be as readable and intuitive as possible for humans. Where curl requires flags like <code class="bg-bg-card px-1 rounded text-xs">-X POST</code>, <code class="bg-bg-card px-1 rounded text-xs">-H "Content-Type: application/json"</code>, and <code class="bg-bg-card px-1 rounded text-xs">-d '&#123;...&#125;'</code>, HTTPie infers them from simple key=value arguments and handles JSON formatting automatically.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    HTTPie automatically color-codes and pretty-prints JSON responses, sets appropriate headers based on the data you provide, supports persistent sessions for cookie and auth management, and includes a plugin ecosystem for OAuth, JWT, and other extensions. A free desktop GUI (HTTPie Desktop) is also available for macOS, Windows, and Linux.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Human-readable output</strong> - JSON responses are automatically formatted and color-coded in the terminal</li>
    <li><strong>Intuitive syntax</strong> - key=value for strings, key:=value for JSON types; no -X, no --data needed</li>
    <li><strong>JSON by default</strong> - sets Content-Type and Accept headers automatically when sending data</li>
    <li><strong>Sessions</strong> - persist cookies, auth, and custom headers across multiple requests with --session</li>
    <li><strong>File uploads</strong> - multipart form upload with key@/path/to/file syntax</li>
    <li><strong>Downloads</strong> - save responses to disk with --download</li>
    <li><strong>Plugin ecosystem</strong> - extend with OAuth, JWT, HMAC auth, and more via pip-installable plugins</li>
    <li><strong>HTTPie Desktop</strong> - free GUI app with collections, history, and visual request builder</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Installation</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={installExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">GET Requests</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    GET is the default method when no body data is provided. Query parameters use the <code class="bg-bg-card px-1 rounded text-xs">key==value</code> syntax (double equals). HTTPie always pretty-prints and color-codes JSON responses.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={getExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">POST with JSON Body</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Use <code class="bg-bg-card px-1 rounded text-xs">key=value</code> for strings and <code class="bg-bg-card px-1 rounded text-xs">key:=value</code> for non-string JSON types (numbers, booleans, arrays). HTTPie sets <code class="bg-bg-card px-1 rounded text-xs">Content-Type: application/json</code> automatically.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={postExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Authentication &amp; Sessions</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Headers use the <code class="bg-bg-card px-1 rounded text-xs">Name:value</code> syntax (single colon). Sessions persist cookies and auth across requests - log in once, then reuse the session for subsequent calls.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={authExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">File Upload &amp; Advanced Options</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    HTTPie handles multipart uploads, file downloads, redirects, timeouts, and verbose output for debugging - all with readable flags.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={uploadExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">HTTPie vs curl</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">HTTPie</th>
          <th class="border border-border px-3 py-2 text-left">curl</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2">JSON formatting</td><td class="border border-border px-3 py-2 text-green-400">Automatic, color-coded</td><td class="border border-border px-3 py-2">Raw output (pipe to jq)</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Syntax for POST JSON</td><td class="border border-border px-3 py-2 text-green-400">http POST url key=val</td><td class="border border-border px-3 py-2">curl -X POST -H ... -d '...'</td></tr>
        <tr><td class="border border-border px-3 py-2">Default availability</td><td class="border border-border px-3 py-2">Requires install</td><td class="border border-border px-3 py-2 text-green-400">Pre-installed on most systems</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Protocol support</td><td class="border border-border px-3 py-2">HTTP/HTTPS</td><td class="border border-border px-3 py-2 text-green-400">HTTP, FTP, SFTP, SCP, and more</td></tr>
        <tr><td class="border border-border px-3 py-2">Sessions</td><td class="border border-border px-3 py-2 text-green-400">Built-in (--session)</td><td class="border border-border px-3 py-2">Manual cookie jar (-b/-c)</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Learning curve</td><td class="border border-border px-3 py-2 text-green-400">Low - intuitive syntax</td><td class="border border-border px-3 py-2">Medium - many flags to memorize</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pros and Cons</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-green-400 mb-2">Pros</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>&#10003; Automatic JSON pretty-printing and color highlighting</li>
        <li>&#10003; Extremely intuitive syntax - far less typing than curl</li>
        <li>&#10003; Sends JSON by default for common POST/PUT/PATCH operations</li>
        <li>&#10003; Built-in session management for cookie persistence</li>
        <li>&#10003; Free desktop GUI available for non-CLI workflows</li>
        <li>&#10003; Plugin ecosystem for custom auth schemes</li>
      </ul>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-red-400 mb-2">Cons</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>&#10007; Not pre-installed on most systems (requires pip/brew)</li>
        <li>&#10007; Python dependency can complicate some environments</li>
        <li>&#10007; Only supports HTTP/HTTPS (no FTP, SFTP, etc.)</li>
        <li>&#10007; Slower startup than curl for high-frequency scripting</li>
        <li>&#10007; Less commonly found in CI base images than curl</li>
      </ul>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="httpie" relatedTags={['http-client', 'cli', 'api', 'rest', 'curl-alternative']} />
</BaseLayout>
