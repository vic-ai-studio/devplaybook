---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const basicExamples = `# GET request (automatic JSON Accept header)
http GET https://api.example.com/users

# POST with JSON body (key=value pairs auto-encoded as JSON)
http POST https://api.example.com/users name="Jane Doe" email="jane@example.com"

# PUT with nested JSON and auth header
http PUT https://api.example.com/users/1 \\
  Authorization:"Bearer YOUR_TOKEN" \\
  name="Jane Smith"

# DELETE request
http DELETE https://api.example.com/users/1

# Send raw JSON from file
http POST https://api.example.com/users < user.json

# Upload a file (multipart/form-data)
http --multipart POST https://api.example.com/upload file@/path/to/file.txt`;

const sessionExample = `# Create a named session (persists cookies, headers, auth)
http --session=myapi POST https://api.example.com/auth/login \\
  username=admin password=secret

# Subsequent requests reuse session cookies automatically
http --session=myapi GET https://api.example.com/dashboard

# Print request + response headers and body
http --print=HhBb GET https://api.example.com/users`;

const faq = [
  { question: "How does HTTPie syntax differ from curl?", answer: "HTTPie uses a human-readable syntax where JSON fields are written as key=value pairs, headers as Key:Value, and query params as param==value — all space-separated after the URL and method. curl requires you to write raw JSON strings with -d '{\"name\":\"Jane\"}' and explicit content-type headers. HTTPie sets Content-Type: application/json automatically when you provide data items. For most API testing tasks, an HTTPie command is 30-50% shorter and far more readable than the equivalent curl command. curl remains essential for scripting portability since it is universally available." },
  { question: "What do the HTTPie data item operators mean?", answer: "HTTPie uses different operators to distinguish field types. The = operator sends a string value as a JSON field. The := operator sends a raw JSON value (number, boolean, array, object) without string quoting — use this for id:=42 or active:=true. The == operator adds a query string parameter. The : operator sets a request header. The @ operator attaches a file for upload. The =@ and :=@ operators read string or JSON values from a file, respectively. Understanding these six operators covers virtually all HTTPie use cases." },
  { question: "Does HTTPie have a Desktop app?", answer: "Yes. HTTPie for Web and Desktop is a modern GUI application available at httpie.io/app. It works in the browser (no installation) and as a native desktop app for macOS, Windows, and Linux. The Desktop app offers a visual request builder, response syntax highlighting, request history, collections, and environment variables — similar to Postman but with HTTPie's clean design philosophy. It has a free tier and paid plans for teams. The Desktop app is separate from the CLI, which remains fully open-source and free." },
  { question: "How do HTTPie sessions work?", answer: "HTTPie sessions persist cookies, auth credentials, and headers across requests using named session files stored in ~/.config/httpie/sessions/. Use --session=name to create or reuse a session. The first authenticated request stores the session cookie; subsequent requests with the same session name automatically include the cookie. Sessions can also persist custom headers like Authorization if set during a session request. You can inspect session files (they are plain JSON) or delete them to reset state." },
  { question: "Can HTTPie be used in shell scripts?", answer: "Yes, but with caveats. HTTPie outputs formatted, colorized output by default — in scripts you typically want --print=b (response body only) and --quiet to suppress extra output. HTTPie exits with status code 0 on success and non-zero on connection errors. Use http --check-status to also exit non-zero on HTTP 4xx/5xx responses. For pure shell script portability, curl is often preferred since it is pre-installed on most Unix systems, but HTTPie is excellent for interactive use and readable automation scripts on systems where it is installed." },
  { question: "How do I install HTTPie?", answer: "On macOS: brew install httpie. On Ubuntu/Debian: apt install httpie or pip install httpie. On Windows: pip install httpie or use the HTTPie Desktop GUI app from httpie.io/app. Python pip installation works on any platform with Python 3.6+. The package name is httpie and the command is http (not httpie). Some distributions ship an older version; pip install --upgrade httpie ensures you have the latest release." },
];
---

<BaseLayout
  title="HTTPie — Modern Command-Line HTTP Client with Human-Friendly Syntax"
  description="HTTPie is a modern CLI HTTP client with readable syntax, automatic JSON encoding, syntax-highlighted output, sessions, and file uploads. Easier than curl for API development and testing."
  tool="HTTPie, http command line, HTTPie vs curl, HTTPie syntax, API testing CLI, http client terminal, HTTPie Desktop"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "HTTPie — Modern Command-Line HTTP Client",
    "url": "https://devplaybook.cc/tools/httpie",
    "description": "HTTPie is a modern CLI HTTP client with readable syntax, automatic JSON encoding, syntax-highlighted output, and sessions. The developer-friendly curl alternative.",
  })} />

  <h1 class="text-3xl font-bold mb-2">HTTPie — Modern Command-Line HTTP Client</h1>
  <p class="text-text-muted mb-6">
    <strong>HTTPie</strong> (<code class="font-mono bg-surface px-1 rounded text-sm">http</code>) is an open-source command-line HTTP client designed for human-friendly interaction with APIs. It uses intuitive syntax for JSON, headers, and auth — automatically applies sensible defaults, and outputs colorized, formatted responses. A powerful, readable alternative to curl for API development and testing.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Human-friendly syntax</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> JSON by default</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Syntax-highlighted output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Sessions, file uploads, plugins</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Desktop GUI available</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is HTTPie?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    HTTPie was created by Jan-Ivar Bruaroey and maintained by the HTTPie team. It aims to make HTTP interaction as natural as possible for developers. While curl is the universal Swiss Army knife of HTTP, its syntax was designed for scripting and machine use — HTTPie was designed for humans. It automatically sets <code class="font-mono bg-surface px-1 rounded text-sm">Content-Type: application/json</code>, pretty-prints JSON responses with syntax highlighting, and uses a readable key=value syntax for building request bodies.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    HTTPie comes in two forms: the classic open-source CLI tool (installed via pip or brew), and the newer HTTPie for Web and Desktop — a GUI application available at httpie.io with request history, collections, and team workspaces. The CLI is the focus of this guide.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Intuitive syntax</strong> — key=value JSON, Key:Value headers, param==query, all space-separated</li>
    <li><strong>JSON first</strong> — automatic <code class="font-mono bg-surface px-1 rounded text-xs">Content-Type: application/json</code> and <code class="font-mono bg-surface px-1 rounded text-xs">Accept: application/json</code></li>
    <li><strong>Syntax highlighting</strong> — colorized JSON response bodies and headers in the terminal</li>
    <li><strong>Sessions</strong> — persist cookies, auth, and headers across requests with named session files</li>
    <li><strong>Downloads</strong> — download files with progress bars via <code class="font-mono bg-surface px-1 rounded text-xs">--download</code></li>
    <li><strong>File uploads</strong> — multipart form uploads with the <code class="font-mono bg-surface px-1 rounded text-xs">@</code> operator</li>
    <li><strong>Auth</strong> — Basic, Digest, Bearer token, and plugin-based auth (AWS Sig v4 via plugin)</li>
    <li><strong>Plugins</strong> — extend HTTPie with custom auth mechanisms and output formatters</li>
    <li><strong>HTTPS</strong> — TLS verification on by default; <code class="font-mono bg-surface px-1 rounded text-xs">--verify=no</code> to skip for dev</li>
    <li><strong>Offline mode</strong> — <code class="font-mono bg-surface px-1 rounded text-xs">--offline</code> to print the request without sending it</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Installation</h2>
  <div class="bg-bg-card border border-border rounded-xl p-4 mb-4">
    <p class="text-xs text-text-muted uppercase font-semibold mb-2">macOS (Homebrew)</p>
    <pre class="text-sm font-mono text-text">brew install httpie</pre>
  </div>
  <div class="bg-bg-card border border-border rounded-xl p-4 mb-4">
    <p class="text-xs text-text-muted uppercase font-semibold mb-2">Python pip (any platform)</p>
    <pre class="text-sm font-mono text-text">pip install httpie
# Upgrade existing install
pip install --upgrade httpie</pre>
  </div>
  <div class="bg-bg-card border border-border rounded-xl p-4 mb-4">
    <p class="text-xs text-text-muted uppercase font-semibold mb-2">Ubuntu / Debian</p>
    <pre class="text-sm font-mono text-text">sudo apt install httpie</pre>
  </div>
  <div class="bg-bg-card border border-border rounded-xl p-4 mb-6">
    <p class="text-xs text-text-muted uppercase font-semibold mb-2">Windows</p>
    <pre class="text-sm font-mono text-text">pip install httpie
# Or download the Desktop GUI from httpie.io/app</pre>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Basic Usage Examples</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={basicExamples}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Sessions and Output Control</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={sessionExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">HTTPie vs curl vs wget</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">HTTPie</th>
          <th class="border border-border px-3 py-2 text-left">curl</th>
          <th class="border border-border px-3 py-2 text-left">wget</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-border px-3 py-2">JSON syntax</td>
          <td class="border border-border px-3 py-2 text-green-400">key=value (automatic)</td>
          <td class="border border-border px-3 py-2">Raw string with -d</td>
          <td class="border border-border px-3 py-2 text-red-400">Not designed for APIs</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Output highlighting</td>
          <td class="border border-border px-3 py-2 text-green-400">Yes (colorized)</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
          <td class="border border-border px-3 py-2 text-red-400">No</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">Pre-installed</td>
          <td class="border border-border px-3 py-2 text-red-400">No (must install)</td>
          <td class="border border-border px-3 py-2 text-green-400">Most Unix systems</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Some systems</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Sessions</td>
          <td class="border border-border px-3 py-2 text-green-400">Built-in</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Via cookie files</td>
          <td class="border border-border px-3 py-2 text-red-400">Limited</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">Script portability</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Requires install</td>
          <td class="border border-border px-3 py-2 text-green-400">Universal</td>
          <td class="border border-border px-3 py-2 text-yellow-400">Common</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Best for</td>
          <td class="border border-border px-3 py-2">API development</td>
          <td class="border border-border px-3 py-2">Scripting, portability</td>
          <td class="border border-border px-3 py-2">File downloads</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Use Cases</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li>Quickly testing REST API endpoints during development</li>
    <li>Exploring API responses with human-readable, colorized output</li>
    <li>Debugging authentication flows with persistent named sessions</li>
    <li>Sending file uploads for testing multipart API endpoints</li>
    <li>Generating reproducible request examples for documentation</li>
    <li>Checking API health and response structure from the terminal</li>
  </ul>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="HTTPie CLI" relatedTags={['api', 'http', 'rest', 'cli', 'curl', 'testing', 'developer-tools']} />
</BaseLayout>
