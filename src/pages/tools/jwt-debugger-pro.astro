---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JwtDebuggerPro from '../../components/JwtDebuggerPro.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What security issues does JWT Debugger Pro check?",
    answer: "It performs a full security audit: checks for the 'none' algorithm (completely unsigned tokens), expiry validation (past, near-future, or overly long), missing audience (aud) and issuer (iss) claims (which enable token substitution attacks), missing JWT ID (jti) for replay prevention, sensitive data in the payload, and algorithm-specific security notes for HS256 vs RS256 vs ES256."
  },
  {
    question: "Why is alg=none critical?",
    answer: "When algorithm is 'none', the JWT has no signature — it's completely unsigned. A vulnerable server that accepts alg=none will trust any token regardless of its content. An attacker can create a token with any user ID or role by simply setting alg to none and removing the signature. Always validate that the algorithm matches what your server expects, never accept alg=none from clients."
  },
  {
    question: "What is the algorithm confusion attack?",
    answer: "In an algorithm confusion attack, an attacker changes a token's algorithm from RS256 (asymmetric) to HS256 (symmetric) and re-signs the token using the server's public key as the HMAC secret. If the server doesn't enforce the expected algorithm, it verifies the HMAC signature using its public key — which the attacker already has. Prevention: always specify and enforce the expected algorithm when verifying JWTs."
  },
  {
    question: "Why shouldn't I put sensitive data in JWT payloads?",
    answer: "JWT payloads are Base64URL-encoded — this is encoding, not encryption. Anyone who possesses the token can decode and read its contents without any key. This includes passwords, credit card numbers, SSNs, and PII. If sensitive data must travel in a JWT, use JWE (JSON Web Encryption) instead of plain JWT. For standard auth JWTs, include only the minimum necessary claims (sub, roles, exp)."
  },
  {
    question: "What is the difference between RS256 and ES256?",
    answer: "Both are asymmetric algorithms (private key signs, public key verifies), but they use different cryptographic primitives. RS256 uses RSA with 2048+ bit keys. ES256 uses ECDSA with P-256 curve (256-bit keys). ES256 tokens are smaller, ES256 operations are faster, and P-256 keys provide equivalent security to RSA-3072. ES256 is the recommended modern choice for new systems."
  },
  {
    question: "Is it safe to paste my JWT here?",
    answer: "This tool runs 100% in your browser — your token is never sent to any server. However, as a best practice, avoid pasting production tokens that grant admin access to sensitive systems. For security-critical debugging, consider using a local tool or the jwt.io site on a private network. Rotate tokens after sharing them for debugging."
  },
];
---

<BaseLayout
  title="JWT Debugger Pro — Security Audit for JSON Web Tokens"
  description="Advanced JWT security auditor. Decode JWT tokens and check for alg=none vulnerabilities, expiry status, missing iss/aud/jti claims, sensitive payload data, and algorithm security. Runs 100% in your browser."
  tool="jwt debugger, json web token decoder, jwt verify, jwt parser online, jwt security audit, jwt algorithm checker"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "JWT Debugger Pro",
    "url": "https://devplaybook.cc/tools/jwt-debugger-pro",
    "description": "Advanced JWT security auditor. Decode JWT tokens and audit for alg=none, expiry, missing claims, sensitive data, and algorithm vulnerabilities. Runs 100% in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">JWT Debugger Pro</h1>
  <p class="text-text-muted mb-4">
    Advanced JWT security audit tool. Decode any JSON Web Token and get a detailed security report:
    algorithm vulnerabilities, expiry status, missing claims, sensitive payload data, and algorithm-specific
    recommendations. Goes beyond simple decoding to catch real security issues.
    Runs entirely in your browser — your token never leaves your machine.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Algorithm security (alg=none, HS/RS/ES)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Claim validation (exp, iss, aud, jti)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Sensitive data detection</span>
  </div>
  <JwtDebuggerPro client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="JWT Debugger Pro" relatedTags={['security', 'auth', 'api', 'jwt', 'oauth', 'authentication']} />
</BaseLayout>
