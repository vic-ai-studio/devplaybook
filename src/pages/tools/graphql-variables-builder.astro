---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GraphQLVariablesBuilder from '../../components/GraphQLVariablesBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a GraphQL variable?",
    answer: "GraphQL variables are dynamic values passed separately from the query string at runtime. Instead of hardcoding values like query GetUser { user(id: \"abc\") }, you write query GetUser($id: ID!) { user(id: $id) } and pass { \"id\": \"abc\" } as the variables JSON. This prevents injection attacks, enables query reuse, and makes caching more effective."
  },
  {
    question: "What does the '!' mean in a GraphQL type?",
    answer: "The exclamation mark (!) marks a type as non-null — it means the field is required and the server guarantees it will never be null. For example, $id: ID! means the id variable must always be provided. Without !, the variable is optional and can be omitted or set to null."
  },
  {
    question: "How do I pass a list of values as a GraphQL variable?",
    answer: "Use list type syntax like [String!] and check the 'List' option in this tool. In the variables JSON, provide a JSON array: { \"tags\": [\"news\", \"tech\"] }. The type [String!] means a nullable list of non-null strings. [String!]! would mean a required list of non-null strings."
  },
  {
    question: "What is the ID scalar type in GraphQL?",
    answer: "ID is a built-in scalar type used for unique identifiers. It is serialized as a string in JSON but can represent string or integer IDs. Clients should treat it as opaque — don't perform arithmetic on it. Use ID for database primary keys, UUIDs, or any field used to uniquely identify an object."
  },
  {
    question: "How do I use variables in a GraphQL client?",
    answer: "Most GraphQL clients (Apollo, urql, fetch) accept variables separately from the query. With fetch: fetch('/graphql', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ query: '...', variables: { id: '123' } }) }). With Apollo useQuery: useQuery(MY_QUERY, { variables: { id: '123' } })."
  },
  {
    question: "What is the difference between query, mutation, and subscription variables?",
    answer: "The variable syntax is the same for all three operation types. Variables are declared in the operation signature ($name: Type) and used in field arguments. The operation type (query/mutation/subscription) describes what the operation does — read, write, or real-time stream — but the variable mechanism works identically."
  },
];
---

<BaseLayout
  title="GraphQL Variables Builder — Generate Typed Variable Definitions"
  description="Build GraphQL query variables visually. Define variable names, types (String, Int, ID, Boolean, custom), required/optional, and list flags. Generates ready-to-use variables JSON and typed query signature. No setup required."
  tool="GraphQL Variables Builder, GraphQL Query Variables, GraphQL Variable Types, GraphQL Variable Generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "GraphQL Variables Builder",
    "url": "https://devplaybook.cc/tools/graphql-variables-builder",
    "description": "Build GraphQL query variables visually. Define types, required flags, and list wrappers. Generates typed variable JSON and query signature.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">GraphQL Variables Builder</h1>
  <p class="text-text-muted mb-4">
    Build GraphQL query variables visually. Define names, types, and values — get a typed query signature and copy-ready variables JSON instantly. Works for queries, mutations, and subscriptions.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Typed variable definitions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-ready variables JSON</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Required, optional, list support</span>
  </div>
  <GraphQLVariablesBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="GraphQL Variables Builder" relatedTags={['graphql', 'api', 'developer-tools', 'json', 'queries']} />
</BaseLayout>
