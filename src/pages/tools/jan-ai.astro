---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Jan and how is it different from other local AI apps?", answer: "Jan is a fully open-source, privacy-first desktop app for running LLMs locally. Unlike LM Studio (closed source) or Ollama (CLI-focused), Jan is 100% open source (MIT license), stores all data locally on your device, and has a built-in extension system for adding capabilities. It also supports connecting to remote APIs (OpenAI, Anthropic, Groq) alongside local models." },
  { question: "What models does Jan support?", answer: "Jan supports GGUF models from Jan Hub (its curated model registry) and custom model imports. Popular options include Llama 3.2, Mistral 7B, Qwen2.5, Gemma 3, Phi-4, and DeepSeek-R1. Jan Hub provides pre-tested, one-click downloadable versions with recommended settings. You can also import any GGUF file manually from HuggingFace." },
  { question: "Does Jan have a local API server?", answer: "Yes. Jan includes a built-in API server that is compatible with the OpenAI API specification. It runs on http://localhost:1337/v1 by default. Start it from Settings > API Server. You can point any OpenAI SDK or tool (LangChain, LlamaIndex, n8n, etc.) at this endpoint to use local models without code changes." },
  { question: "What are Jan extensions?", answer: "Jan has a built-in extension system similar to VS Code plugins. Extensions can add new model backends (e.g., TensorRT-LLM, remote APIs), UI features, or integrations. The extension manager is available in Settings. This makes Jan highly customizable compared to LM Studio or Ollama, which require third-party frontends for extra functionality." },
  { question: "Can Jan connect to cloud AI APIs?", answer: "Yes — Jan supports both local and remote inference. In the model selector, you can configure connections to OpenAI, Anthropic, Groq, Mistral, and other OpenAI-compatible APIs. This lets you compare local vs cloud responses or use cloud models when local hardware is insufficient, all within the same interface." },
  { question: "What hardware does Jan need?", answer: "Jan uses llama.cpp as its local inference backend, so hardware requirements match GGUF model sizes: 8 GB RAM minimum for 7B models, 16 GB recommended. GPU acceleration is supported via CUDA (NVIDIA), Metal (Apple Silicon), and Vulkan. On Apple Silicon, Jan takes advantage of unified memory — an M2 Pro with 16 GB handles 13B models comfortably." },
];
---

<BaseLayout
  title="Jan: Open-Source ChatGPT Alternative for Local AI (2026)"
  description="Jan is a free, open-source desktop app for running LLMs locally with full privacy. Chat with Llama, Mistral, or Gemma offline, use the built-in API server, and extend with plugins."
  tool="Jan AI, local ChatGPT, open source AI, private AI, offline LLM, Jan Hub, local AI desktop"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"Jan: Open-Source ChatGPT Alternative for Local AI","url":"https://devplaybook.cc/tools/jan-ai","description":"Jan is a free, open-source desktop app for running LLMs locally with full privacy — complete guide for 2026."})} />

  <h1 class="text-3xl font-bold mb-2">Jan: Open-Source ChatGPT Alternative for Local AI</h1>
  <p class="text-text-muted mb-6">Jan is a completely open-source, privacy-first desktop AI app that lets you run powerful language models entirely on your own hardware. It combines a clean chat interface, a curated model hub, a built-in API server, and a plugin ecosystem — all with zero data leaving your device.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100% open source (MIT license)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Local + remote model support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Extension ecosystem</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> OpenAI-compatible API server</span>
  </div>

  <ToolPageCta />

  <!-- Installation -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Installation</h2>
    <p class="text-text-muted text-sm mb-4">Jan is available for macOS, Windows, and Linux. Download from <strong>jan.ai</strong> or use a package manager. The app is ~200 MB; models are stored separately.</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-3"><code># macOS (Homebrew)
brew install --cask jan

# Windows (winget)
winget install Homebrew.jan

# Linux (AppImage — download from jan.ai/download)
chmod +x jan-linux-x86_64-*.AppImage
./jan-linux-x86_64-*.AppImage

# Jan stores data at:
# macOS: ~/Library/Application Support/jan/
# Windows: %APPDATA%\jan\
# Linux: ~/.config/jan/

# Models are in: &lt;data_dir&gt;/models/</code></pre>
  </div>

  <!-- Jan Hub -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Jan Hub: Model Discovery &amp; Download</h2>
    <p class="text-text-muted text-sm mb-4">Jan Hub is the built-in model registry with curated, pre-configured GGUF models. Each model listing shows size, required RAM, speed estimate, and quality notes. One click downloads and pre-configures the model with recommended settings.</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># Jan Hub featured models (2026)
# Model                    Size    RAM     Use Case
# ─────────────────────────────────────────────────
# Llama 3.2 3B (Q4_K_M)   2.0 GB  ~4 GB   Fast chat, mobile-class hardware
# Llama 3.2 7B (Q4_K_M)   4.1 GB  ~6 GB   General purpose (recommended start)
# Mistral 7B v0.3          4.1 GB  ~6 GB   Instruction following, coding
# Qwen2.5 7B Instruct      4.4 GB  ~7 GB   Multilingual, reasoning
# Gemma 3 9B (Q4_K_M)     5.4 GB  ~8 GB   Google's efficient model
# Phi-4 14B (Q4_K_M)      8.4 GB  ~12 GB  Strong reasoning, smaller footprint
# DeepSeek-R1 7B           4.7 GB  ~7 GB   Chain-of-thought reasoning

# To import a custom GGUF from HuggingFace:
# Settings > My Models > Import Model > paste HuggingFace URL</code></pre>
  </div>

  <!-- Local API server -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Using the Jan Local API Server</h2>
    <p class="text-text-muted text-sm mb-4">Jan's API server implements the OpenAI specification on port 1337. Enable it in <strong>Settings &gt; API Server &gt; Start Server</strong>. The server auto-starts with the selected model loaded.</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># List available models
curl http://localhost:1337/v1/models

# Chat completion
curl http://localhost:1337/v1/chat/completions \
  -H "Content-Type: application/json" \
  -d '&#123;
    "model": "llama3.2-7b-instruct",
    "messages": [&#123;"role": "user", "content": "Summarize quantum computing"&#125;],
    "stream": false,
    "max_tokens": 512
  &#125;'

# Using Python openai SDK
from openai import OpenAI
client = OpenAI(base_url="http://localhost:1337/v1", api_key="jan")
completion = client.chat.completions.create(
    model="llama3.2-7b-instruct",
    messages=[&#123;"role": "user", "content": "Write unit tests for this function..."&#125;]
)
print(completion.choices[0].message.content)</code></pre>
  </div>

  <!-- Extensions -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Jan Extensions Ecosystem</h2>
    <p class="text-text-muted text-sm mb-3">Extensions are installed from <strong>Settings &gt; Extensions</strong>. Key extensions available in 2026:</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-sm">
      <div class="border border-border rounded-lg p-3">
        <div class="font-medium mb-1">TensorRT-LLM Engine</div>
        <p class="text-text-muted text-xs">NVIDIA-optimized inference backend. Dramatically faster than llama.cpp on RTX cards. Requires NVIDIA GPU with 8+ GB VRAM.</p>
      </div>
      <div class="border border-border rounded-lg p-3">
        <div class="font-medium mb-1">Remote AI Connectors</div>
        <p class="text-text-muted text-xs">Connect to OpenAI, Anthropic, Groq, Mistral, and other APIs. Compare local vs cloud responses side by side.</p>
      </div>
      <div class="border border-border rounded-lg p-3">
        <div class="font-medium mb-1">Model Management</div>
        <p class="text-text-muted text-xs">Advanced model import tools, HuggingFace integration, and automatic GGUF discovery for local files.</p>
      </div>
      <div class="border border-border rounded-lg p-3">
        <div class="font-medium mb-1">Jan Inference Engine</div>
        <p class="text-text-muted mb-1 text-xs">Default llama.cpp backend. Supports CUDA, Metal, Vulkan, and CPU fallback. Comes pre-installed.</p>
      </div>
    </div>
  </div>

  <!-- Comparison -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-4">Jan vs Ollama vs LM Studio</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-text-muted text-xs uppercase border-b border-border">
            <th class="text-left pb-2 pr-4">Feature</th>
            <th class="text-left pb-2 pr-4">Jan</th>
            <th class="text-left pb-2 pr-4">Ollama</th>
            <th class="text-left pb-2">LM Studio</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border text-xs">
          <tr><td class="py-2 pr-4 font-medium">Open source</td><td class="py-2 pr-4 text-green-500">Yes (MIT)</td><td class="py-2 pr-4 text-green-500">Yes (MIT)</td><td class="py-2 text-red-400">No (proprietary)</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Chat GUI</td><td class="py-2 pr-4 text-green-500">Built-in</td><td class="py-2 pr-4 text-yellow-500">Third party</td><td class="py-2 text-green-500">Built-in</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Extension system</td><td class="py-2 pr-4 text-green-500">Yes</td><td class="py-2 pr-4 text-red-400">No</td><td class="py-2 text-red-400">No</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Remote API support</td><td class="py-2 pr-4 text-green-500">OpenAI, Anthropic, Groq…</td><td class="py-2 pr-4 text-red-400">No</td><td class="py-2 text-yellow-500">Limited</td></tr>
          <tr><td class="py-2 pr-4 font-medium">CLI scripting</td><td class="py-2 pr-4 text-yellow-500">Via API only</td><td class="py-2 pr-4 text-green-500">Excellent</td><td class="py-2 text-yellow-500">Via API only</td></tr>
          <tr><td class="py-2 pr-4 font-medium">API port</td><td class="py-2 pr-4">1337</td><td class="py-2 pr-4">11434</td><td class="py-2">1234</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Jan AI" relatedTags={['ai', 'llm', 'local-ai', 'private-ai', 'open-source', 'offline']} />
</BaseLayout>
