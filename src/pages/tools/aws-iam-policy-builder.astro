---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AwsIamPolicyBuilder from '../../components/AwsIamPolicyBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is an IAM policy and how does it work?",
    answer: "An AWS IAM policy is a JSON document that defines permissions. It contains one or more statements, each specifying an Effect (Allow or Deny), a list of Actions (API calls like s3:GetObject), and Resources (ARNs the actions apply to). Policies are attached to IAM identities (users, groups, roles) or AWS resources. AWS evaluates all applicable policies at request time using a default-deny model."
  },
  {
    question: "What is the difference between Allow and Deny effects?",
    answer: "Allow explicitly grants permission to perform actions on resources. Deny explicitly forbids actions, overriding any Allow statements from other policies. AWS evaluates all policies together: if any Deny matches, access is denied regardless of Allow statements. Use Deny to enforce guardrails that cannot be overridden by other policies, such as preventing deletion of critical resources or restricting to specific regions."
  },
  {
    question: "What are resource ARNs and how do I format them?",
    answer: "ARN (Amazon Resource Name) is a unique identifier for AWS resources. Format: arn:partition:service:region:account-id:resource. Examples: arn:aws:s3:::my-bucket/* (all objects in a bucket), arn:aws:lambda:us-east-1:123456789012:function:my-fn (specific Lambda), arn:aws:dynamodb:us-east-1:123456789012:table/Users (DynamoDB table). Use * as a wildcard for 'all resources', but prefer specific ARNs for least-privilege."
  },
  {
    question: "What is the principle of least privilege in IAM?",
    answer: "Least privilege means granting only the minimum permissions required for a task. Instead of s3:* on all resources, grant s3:GetObject and s3:PutObject on a specific bucket ARN. This limits blast radius if credentials are compromised. Start restrictive and add permissions as needed. Use IAM Access Analyzer to identify and remove unused permissions over time."
  },
  {
    question: "How do IAM Conditions work?",
    answer: "Conditions add context-based restrictions to policy statements. They use condition operators (StringEquals, IpAddress, DateLessThan, etc.) and condition keys (aws:RequestedRegion, aws:SourceIp, s3:prefix). For example, StringEquals with aws:RequestedRegion: us-east-1 restricts actions to that region only. Conditions are ANDed within a block and ORed between blocks of the same operator."
  },
  {
    question: "What is the difference between identity-based and resource-based policies?",
    answer: "Identity-based policies are attached to IAM users, groups, or roles and define what that identity can do. Resource-based policies are attached directly to resources like S3 buckets, Lambda functions, or SQS queues and define who can access that resource. Both are evaluated for cross-account access. Resource-based policies are the only way to grant cross-account access without assuming a role."
  },
];
---

<BaseLayout
  title="AWS IAM Policy Builder — Visual JSON Policy Generator"
  description="Build AWS IAM policies visually. Pick Effect (Allow/Deny), select Actions from S3/EC2/Lambda/DynamoDB service groups, enter Resource ARNs, and get the complete JSON policy document."
  tool="aws iam policy builder, iam policy generator, aws policy json, iam policy document, aws permissions builder"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "AWS IAM Policy Builder",
    "url": "https://devplaybook.cc/tools/aws-iam-policy-builder",
    "description": "Build AWS IAM policies visually. Pick Effect (Allow/Deny), select Actions from S3/EC2/Lambda/DynamoDB service groups, enter Resource ARNs, and get the complete JSON policy document.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">AWS IAM Policy Builder</h1>
  <p class="text-text-muted mb-4">
    Build AWS IAM policies visually without memorizing JSON syntax.
    Pick <code class="font-mono bg-bg-card px-1 rounded text-sm">Effect</code>, select actions from
    S3, EC2, Lambda, DynamoDB, and STS service groups, enter resource ARNs, add optional conditions,
    and copy the complete policy document.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multi-statement support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Service action picker</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Optional conditions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> IAM-ready JSON output</span>
  </div>
  <AwsIamPolicyBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="AWS IAM Policy Builder" relatedTags={['aws', 'iam', 'security', 'cloud', 'devops', 'permissions']} />
</BaseLayout>
