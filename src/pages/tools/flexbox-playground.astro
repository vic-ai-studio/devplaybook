---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CssFlexbox from '../../components/CssFlexbox.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Flexbox Playground — Visualize & Generate CSS Flexbox Layouts"
  description="Interactively configure CSS Flexbox properties — flex-direction, justify-content, align-items, flex-wrap, and gap. See a live visual preview with colored boxes and copy the generated CSS. Free, runs in your browser."
  tool="Flexbox Playground, CSS Flexbox Generator, Flexbox Visualizer, CSS Layout Tool"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Flexbox Playground",
    "description": "Free interactive Flexbox playground. Configure flex-direction, justify-content, align-items, flex-wrap, and gap — see a live preview and copy the CSS.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Web",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "url": "https://devplaybook.cc/tools/flexbox-playground"
  })} />
  <h1 class="text-3xl font-bold mb-2">Flexbox Playground</h1>
  <p class="text-text-muted mb-8">Experiment with CSS Flexbox properties in real time. Adjust flex-direction, justify-content, align-items, flex-wrap, and gap — watch the colored boxes respond instantly, then copy the generated CSS.</p>
  <CssFlexbox client:only="preact" />
  <ToolPageCta currentTool="Flexbox Playground" relatedTags={['css', 'flexbox', 'layout', 'frontend', 'web']} />
</BaseLayout>
