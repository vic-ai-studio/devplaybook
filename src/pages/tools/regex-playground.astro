---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RegexPlayground from '../../components/RegexPlayground.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import UsageLimitGate from '../../components/UsageLimitGate.tsx';
---

<BaseLayout title="Regex Playground" description="Write, test, and debug regular expressions in real-time with match highlighting and replace support." tool="Regex Tester, Regular Expression Debugger">
  <h1 class="text-3xl font-bold mb-2">Regex Playground</h1>
  <p class="text-text-muted mb-8">Test regular expressions with real-time highlighting, match details, and replacement preview. <span class="text-xs text-text-muted">(Free: 10 uses/day)</span></p>
  <RegexPlayground client:load />
  <UsageLimitGate toolName="regex-playground" client:load />
  <ToolPageCta currentTool="Regex Playground" relatedTags={['frontend', 'typescript', 'developer-tools']} />
</BaseLayout>
