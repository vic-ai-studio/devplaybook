---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RegexPlayground from '../../components/RegexPlayground.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import UsageLimitGate from '../../components/UsageLimitGate.tsx';
---

<BaseLayout title="Regex Playground" description="Write, test, and debug regular expressions in real-time with match highlighting and replace support." tool="Regex Tester, Regular Expression Debugger">
  <h1 class="text-3xl font-bold mb-2">Regex Playground</h1>
  <p class="text-text-muted mb-4">Test regular expressions with real-time highlighting, match details, and replacement preview. <span class="text-xs text-text-muted">(Free: 10 uses/day)</span></p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <RegexPlayground client:load />
  <UsageLimitGate toolName="regex-playground" client:load />
  <ToolPageCta currentTool="Regex Playground" relatedTags={['frontend', 'typescript', 'developer-tools']} />
</BaseLayout>
