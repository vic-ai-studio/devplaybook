---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RegexPlayground from '../../components/RegexPlayground.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import UsageLimitGate from '../../components/UsageLimitGate.tsx';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How does the regex playground work?", answer: "Type a regular expression pattern and test text. The tool instantly highlights all matches in real time as you type. You can also enter a replacement string to preview find-and-replace results. All processing runs in your browser." },
  { question: "What regex flavors are supported?", answer: "The tool runs patterns using your browser's JavaScript regex engine (ES2020+), which supports lookahead, lookbehind, named capture groups, and Unicode property escapes. Python and PHP flavor notes are shown for syntax differences." },
  { question: "What do the regex flags (g, i, m, s, u) do?", answer: "g (global) finds all matches. i (ignore case) makes matching case-insensitive. m (multiline) makes ^ and $ match line boundaries. s (dotAll) makes . match newlines. u (unicode) enables full Unicode support for \\p{} and \\u{} patterns." },
  { question: "Can I test replacement patterns?", answer: "Yes. Enter a replacement string and see the result of applying your regex with the replacement in real time. Supports backreferences ($1, $2) and named group references ($<name>) for powerful find-and-replace operations." },
  { question: "Is my data safe when using this tool?", answer: "Yes. All regex matching and replacement runs entirely in your browser. Your patterns and test strings are never sent to any server — safe for testing patterns against sensitive data like logs, API responses, or configuration files." },
];
---

<BaseLayout title="Regex Playground — Test Regular Expressions Online (JS/Python/PHP)" description="Write, test, and debug regular expressions in real-time with instant match highlighting, replacement preview, and pattern library. Supports JavaScript, Python, and PHP regex flavors. Free online tool. No signup required." tool="Regex Tester, Regular Expression Debugger, RegExp Tester, Online Regex, Regex Match Visualizer" faq={faq}>
  <h1 class="text-3xl font-bold mb-2">Regex Playground</h1>
  <p class="text-text-muted mb-4">Test regular expressions with real-time highlighting, match details, and replacement preview. <span class="text-xs text-text-muted">(Free: 10 uses/day)</span></p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <RegexPlayground client:load />
  <UsageLimitGate toolName="regex-playground" client:load />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Regex Playground" relatedTags={['frontend', 'typescript', 'developer-tools']} />
</BaseLayout>
