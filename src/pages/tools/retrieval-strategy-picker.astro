---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the difference between BM25 and dense vector retrieval?", answer: "BM25 is a keyword-based ranking algorithm (like TF-IDF, used in Elasticsearch and Lucene). It matches exact terms and handles rare words well but misses synonyms and semantic meaning. Dense vector retrieval uses neural embeddings to encode meaning — 'automobile' and 'car' have similar vectors. Dense search finds semantically relevant results even with different vocabulary, but can miss exact rare terms." },
  { question: "What is hybrid retrieval and when should I use it?", answer: "Hybrid retrieval combines BM25 keyword scores with dense vector scores (via reciprocal rank fusion or linear interpolation). It gets the best of both worlds: exact keyword precision + semantic understanding. Use hybrid when your queries include both natural language questions AND specific technical terms, IDs, or domain jargon." },
  { question: "What is late interaction (ColBERT) and when is it worth the cost?", answer: "ColBERT (late interaction) encodes each token separately and computes fine-grained token-level similarity at query time. It achieves higher precision than single-vector dense search, especially for long documents. The tradeoff is larger storage (one vector per token vs one per document) and slower retrieval. Worth it for high-stakes domains like legal, medical, or academic research." },
  { question: "Do I need a vector database for semantic search?", answer: "For small corpora (<10K documents), you can store embeddings in memory (numpy arrays, SQLite with sqlite-vec). For production scale, a dedicated vector DB (Qdrant, Weaviate, Pinecone, Milvus) provides ANN (approximate nearest neighbor) indexing, filtering, and scalability. Many support hybrid search natively." },
  { question: "How do I handle multilingual retrieval?", answer: "For multilingual search, use a multilingual embedding model like 'multilingual-e5-large' or 'paraphrase-multilingual-mpnet-base-v2'. These encode text from 50-100+ languages into the same embedding space. BM25 requires language-specific tokenizers and stop-word lists for each language. Dense retrieval is usually simpler to deploy for multilingual use cases." },
];
---

<BaseLayout
  title="Retrieval Strategy Picker — Choose BM25 vs Semantic vs Hybrid Search"
  description="Answer 5 questions to find the right retrieval strategy for your RAG system. Get recommendations for BM25 keyword search, dense vector semantic search, hybrid, or ColBERT late interaction with implementation code."
  tool="Retrieval Strategy Picker, BM25 vs Semantic Search, Hybrid Retrieval, RAG Strategy, Vector Search Selector"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Retrieval Strategy Picker</h1>
  <p class="text-text-muted mb-4">Answer 5 questions about your use case to get the optimal retrieval strategy — keyword, semantic, hybrid, or late interaction — with implementation code.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5-question decision flow</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Recommended tools & libraries</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Setup code snippet</span>
  </div>

  <!-- Questions -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-5">Answer These Questions</h2>
    <div class="space-y-7" id="questions">

      <!-- Q1 -->
      <div>
        <p class="text-sm font-medium mb-3">1. What type of queries will users make?</p>
        <div class="space-y-2">
          <label class="flex items-start gap-3 cursor-pointer p-2.5 rounded-lg hover:bg-black/10 transition-colors">
            <input type="radio" name="q1" value="exact" class="mt-0.5 accent-primary" />
            <div>
              <div class="text-sm font-medium">Exact term matching</div>
              <div class="text-xs text-text-muted">Product codes, error messages, specific names, IDs</div>
            </div>
          </label>
          <label class="flex items-start gap-3 cursor-pointer p-2.5 rounded-lg hover:bg-black/10 transition-colors">
            <input type="radio" name="q1" value="natural" class="mt-0.5 accent-primary" />
            <div>
              <div class="text-sm font-medium">Natural language questions</div>
              <div class="text-xs text-text-muted">"How do I reset my password?", "What causes this error?"</div>
            </div>
          </label>
          <label class="flex items-start gap-3 cursor-pointer p-2.5 rounded-lg hover:bg-black/10 transition-colors">
            <input type="radio" name="q1" value="both" class="mt-0.5 accent-primary" />
            <div>
              <div class="text-sm font-medium">Mix of both</div>
              <div class="text-xs text-text-muted">Keyword searches AND conversational questions</div>
            </div>
          </label>
        </div>
      </div>

      <!-- Q2 -->
      <div>
        <p class="text-sm font-medium mb-3">2. What domain is your content?</p>
        <div class="space-y-2">
          <label class="flex items-start gap-3 cursor-pointer p-2.5 rounded-lg hover:bg-black/10 transition-colors">
            <input type="radio" name="q2" value="general" class="mt-0.5 accent-primary" />
            <div>
              <div class="text-sm font-medium">General / consumer</div>
              <div class="text-xs text-text-muted">Blog posts, FAQs, general knowledge</div>
            </div>
          </label>
          <label class="flex items-start gap-3 cursor-pointer p-2.5 rounded-lg hover:bg-black/10 transition-colors">
            <input type="radio" name="q2" value="technical" class="mt-0.5 accent-primary" />
            <div>
              <div class="text-sm font-medium">Highly technical / specialized</div>
              <div class="text-xs text-text-muted">Developer docs, scientific papers, internal engineering wikis</div>
            </div>
          </label>
          <label class="flex items-start gap-3 cursor-pointer p-2.5 rounded-lg hover:bg-black/10 transition-colors">
            <input type="radio" name="q2" value="precise" class="mt-0.5 accent-primary" />
            <div>
              <div class="text-sm font-medium">Legal / medical / compliance</div>
              <div class="text-xs text-text-muted">Contracts, regulations, clinical records — precision is critical</div>
            </div>
          </label>
        </div>
      </div>

      <!-- Q3 -->
      <div>
        <p class="text-sm font-medium mb-3">3. What are your data freshness requirements?</p>
        <div class="space-y-2">
          <label class="flex items-start gap-3 cursor-pointer p-2.5 rounded-lg hover:bg-black/10 transition-colors">
            <input type="radio" name="q3" value="realtime" class="mt-0.5 accent-primary" />
            <div>
              <div class="text-sm font-medium">Real-time needed</div>
              <div class="text-xs text-text-muted">New documents must be searchable within seconds</div>
            </div>
          </label>
          <label class="flex items-start gap-3 cursor-pointer p-2.5 rounded-lg hover:bg-black/10 transition-colors">
            <input type="radio" name="q3" value="nearrealtime" class="mt-0.5 accent-primary" />
            <div>
              <div class="text-sm font-medium">Near real-time</div>
              <div class="text-xs text-text-muted">Minutes to hours acceptable, e.g. daily ingest pipelines</div>
            </div>
          </label>
          <label class="flex items-start gap-3 cursor-pointer p-2.5 rounded-lg hover:bg-black/10 transition-colors">
            <input type="radio" name="q3" value="batch" class="mt-0.5 accent-primary" />
            <div>
              <div class="text-sm font-medium">Batch OK</div>
              <div class="text-xs text-text-muted">Static corpus, rebuild index periodically</div>
            </div>
          </label>
        </div>
      </div>

      <!-- Q4 -->
      <div>
        <p class="text-sm font-medium mb-3">4. What is your infrastructure budget?</p>
        <div class="space-y-2">
          <label class="flex items-start gap-3 cursor-pointer p-2.5 rounded-lg hover:bg-black/10 transition-colors">
            <input type="radio" name="q4" value="minimal" class="mt-0.5 accent-primary" />
            <div>
              <div class="text-sm font-medium">Minimal — avoid extra services</div>
              <div class="text-xs text-text-muted">No managed vector DB, keep it simple</div>
            </div>
          </label>
          <label class="flex items-start gap-3 cursor-pointer p-2.5 rounded-lg hover:bg-black/10 transition-colors">
            <input type="radio" name="q4" value="moderate" class="mt-0.5 accent-primary" />
            <div>
              <div class="text-sm font-medium">Moderate — self-hosted or small managed tier</div>
              <div class="text-xs text-text-muted">Willing to run Qdrant/Chroma/Weaviate</div>
            </div>
          </label>
          <label class="flex items-start gap-3 cursor-pointer p-2.5 rounded-lg hover:bg-black/10 transition-colors">
            <input type="radio" name="q4" value="flexible" class="mt-0.5 accent-primary" />
            <div>
              <div class="text-sm font-medium">Budget not a constraint</div>
              <div class="text-xs text-text-muted">Use whatever gives best results (Pinecone, Cohere Rerank, etc.)</div>
            </div>
          </label>
        </div>
      </div>

      <!-- Q5 -->
      <div>
        <p class="text-sm font-medium mb-3">5. What is your expected query volume?</p>
        <div class="space-y-2">
          <label class="flex items-start gap-3 cursor-pointer p-2.5 rounded-lg hover:bg-black/10 transition-colors">
            <input type="radio" name="q5" value="low" class="mt-0.5 accent-primary" />
            <div>
              <div class="text-sm font-medium">Low — &lt; 100 queries/day</div>
              <div class="text-xs text-text-muted">Internal tools, prototypes, small team</div>
            </div>
          </label>
          <label class="flex items-start gap-3 cursor-pointer p-2.5 rounded-lg hover:bg-black/10 transition-colors">
            <input type="radio" name="q5" value="medium" class="mt-0.5 accent-primary" />
            <div>
              <div class="text-sm font-medium">Medium — 100 to 10K/day</div>
              <div class="text-xs text-text-muted">SaaS product, department-level tool</div>
            </div>
          </label>
          <label class="flex items-start gap-3 cursor-pointer p-2.5 rounded-lg hover:bg-black/10 transition-colors">
            <input type="radio" name="q5" value="high" class="mt-0.5 accent-primary" />
            <div>
              <div class="text-sm font-medium">High — &gt; 10K queries/day</div>
              <div class="text-xs text-text-muted">Consumer product, search engine, high-traffic API</div>
            </div>
          </label>
        </div>
      </div>
    </div>
  </div>

  <!-- Recommendation -->
  <div id="recommendation" class="hidden bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Recommended Strategy</h2>
    <div id="rec-badge" class="inline-flex items-center gap-2 bg-primary/10 text-primary px-4 py-2 rounded-lg font-semibold text-sm mb-3"></div>
    <p id="rec-why" class="text-sm text-text-muted mb-4"></p>
    <div class="mb-4">
      <h3 class="text-sm font-semibold mb-2">Recommended Tools</h3>
      <div id="rec-tools" class="flex flex-wrap gap-2"></div>
    </div>
    <div class="flex items-center justify-between mb-2">
      <h3 class="text-sm font-semibold">Setup Code</h3>
      <button id="copy-btn" class="text-xs bg-primary text-white px-3 py-1.5 rounded-lg hover:opacity-90 flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
        <span id="copy-label">Copy</span>
      </button>
    </div>
    <pre id="rec-code" class="text-xs font-mono bg-black/20 rounded-lg p-4 overflow-auto whitespace-pre text-green-400 leading-relaxed"></pre>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Retrieval Strategy Picker" relatedTags={['ai', 'rag', 'search', 'bm25', 'semantic', 'hybrid', 'retrieval']} />
</BaseLayout>

<script is:inline>
  const STRATEGIES = {
    bm25: {
      name: 'BM25 Keyword Search',
      why: 'Your queries involve exact terms (product codes, IDs, specific names) or you need a zero-infrastructure solution. BM25 has no embedding costs, works on any text, and handles rare OOV (out-of-vocabulary) terms perfectly. It is the right default when budget is tight or queries are highly lexical.',
      tools: ['Elasticsearch', 'OpenSearch', 'BM25Okapi (rank-bm25)', 'Tantivy (Rust)', 'Whoosh (Python)'],
      code: `from rank_bm25 import BM25Okapi
import re

# Prepare corpus
corpus = [
    "How to reset your password step by step",
    "Error code 404 not found troubleshooting",
    # ... your documents
]

def tokenize(text):
    return re.findall(r'\\w+', text.lower())

tokenized_corpus = [tokenize(doc) for doc in corpus]
bm25 = BM25Okapi(tokenized_corpus)

# Query
query = "password reset steps"
scores = bm25.get_scores(tokenize(query))
top_k_indices = scores.argsort()[-5:][::-1]
results = [corpus[i] for i in top_k_indices]
print(results)

# With Elasticsearch
from elasticsearch import Elasticsearch
es = Elasticsearch()
response = es.search(
    index="documents",
    body={"query": {"match": {"content": query}}},
    size=5
)`,
    },
    dense: {
      name: 'Dense Vector Semantic Search',
      why: 'Your users ask natural language questions and your domain vocabulary is common enough that embeddings capture meaning well. Dense retrieval understands synonyms, paraphrases, and intent — crucial for a good Q&A or chatbot experience.',
      tools: ['sentence-transformers', 'Qdrant', 'Chroma', 'Weaviate', 'OpenAI Embeddings', 'FAISS'],
      code: `from sentence_transformers import SentenceTransformer
import numpy as np

model = SentenceTransformer("all-MiniLM-L6-v2")  # free, fast

corpus = [
    "How to reset your password step by step",
    "Account recovery process for locked users",
    # ... your documents
]

# Encode corpus (do this once, persist to disk)
corpus_embeddings = model.encode(corpus, convert_to_numpy=True)

# Query at runtime
query = "I forgot my password"
query_embedding = model.encode([query], convert_to_numpy=True)

# Cosine similarity
from sklearn.metrics.pairwise import cosine_similarity
scores = cosine_similarity(query_embedding, corpus_embeddings)[0]
top_k = scores.argsort()[-5:][::-1]
results = [(corpus[i], scores[i]) for i in top_k]
for text, score in results:
    print(f"{score:.3f} | {text}")

# For production scale, use Qdrant:
# from qdrant_client import QdrantClient
# client = QdrantClient("localhost", port=6333)
# client.search("my_collection", query_embedding, limit=5)`,
    },
    hybrid: {
      name: 'Hybrid BM25 + Dense Vector Search',
      why: 'Your queries mix natural language AND specific technical terms, IDs, or jargon. Hybrid retrieval fuses keyword precision with semantic understanding using Reciprocal Rank Fusion (RRF). This is the state-of-the-art default for most production RAG systems.',
      tools: ['Qdrant (built-in hybrid)', 'Elasticsearch sparse+dense', 'LangChain EnsembleRetriever', 'Weaviate hybrid', 'OpenSearch Neural Sparse'],
      code: `from langchain.retrievers import BM25Retriever, EnsembleRetriever
from langchain_community.vectorstores import Qdrant
from langchain_openai import OpenAIEmbeddings
from langchain_core.documents import Document

# Sample documents
docs = [
    Document(page_content="Password reset via email link"),
    Document(page_content="Account recovery for locked accounts"),
    Document(page_content="2FA TOTP setup instructions"),
    # ... more documents
]

# BM25 retriever
bm25_retriever = BM25Retriever.from_documents(docs, k=5)

# Dense vector retriever
embeddings = OpenAIEmbeddings(model="text-embedding-3-small")
vectorstore = Qdrant.from_documents(
    docs, embeddings, location=":memory:", collection_name="hybrid"
)
dense_retriever = vectorstore.as_retriever(search_kwargs={"k": 5})

# Hybrid ensemble (equal weights)
ensemble = EnsembleRetriever(
    retrievers=[bm25_retriever, dense_retriever],
    weights=[0.5, 0.5],  # tune based on your data
)

results = ensemble.invoke("TOTP authenticator setup")
for doc in results:
    print(doc.page_content)`,
    },
    colbert: {
      name: 'Sparse + Dense Late Interaction (ColBERT)',
      why: 'You are in a high-stakes domain (legal, medical, compliance) where precision is non-negotiable and budget allows for richer infrastructure. ColBERT\'s token-level late interaction achieves higher recall and precision than single-vector methods, especially for long documents with subtle differences.',
      tools: ['RAGatouille (ColBERT)', 'PLAID index', 'Vespa (WAND + ANN)', 'Cohere Rerank API', 'BGE-M3 (multi-granularity)'],
      code: `# Option 1: ColBERT via RAGatouille (easiest)
from ragatouille import RAGPretrainedModel

RAG = RAGPretrainedModel.from_pretrained("colbert-ir/colbertv2.0")

# Index your corpus
corpus = [
    "Section 4.2: The contractor shall indemnify the client...",
    "Clause 7: Force majeure events including natural disasters...",
    # ... legal documents
]
RAG.index(
    collection=corpus,
    index_name="legal_docs",
    max_document_length=512,
    split_documents=True,
)

# Query
results = RAG.search(query="indemnification obligations contractor", k=5)
for r in results:
    print(f"Score: {r['score']:.3f} | {r['content'][:100]}")

# Option 2: Cohere Rerank (simpler, no self-hosting)
import cohere
co = cohere.Client("your-api-key")
rerank_results = co.rerank(
    query="indemnification contractor",
    documents=corpus,
    model="rerank-english-v3.0",
    top_n=5,
)`,
    },
  };

  function getAnswers() {
    return {
      q1: document.querySelector('input[name="q1"]:checked')?.value,
      q2: document.querySelector('input[name="q2"]:checked')?.value,
      q3: document.querySelector('input[name="q3"]:checked')?.value,
      q4: document.querySelector('input[name="q4"]:checked')?.value,
      q5: document.querySelector('input[name="q5"]:checked')?.value,
    };
  }

  function getStrategyKey(a) {
    if (!a.q1 || !a.q2 || !a.q3 || !a.q4 || !a.q5) return null;
    if (a.q2 === 'precise') return 'colbert';
    if (a.q1 === 'exact' && a.q4 === 'minimal') return 'bm25';
    if (a.q1 === 'natural' && a.q4 !== 'minimal') return 'dense';
    if (a.q1 === 'both') return 'hybrid';
    if (a.q4 === 'minimal') return 'bm25';
    if (a.q5 === 'high' && a.q4 === 'flexible') return 'hybrid';
    return 'dense';
  }

  function recommend() {
    const a = getAnswers();
    const key = getStrategyKey(a);
    if (!key) { document.getElementById('recommendation').classList.add('hidden'); return; }

    const s = STRATEGIES[key];
    document.getElementById('rec-badge').textContent = s.name;
    document.getElementById('rec-why').textContent = s.why;
    document.getElementById('rec-tools').innerHTML = s.tools.map(t =>
      `<span class="bg-primary/10 text-primary text-xs px-2.5 py-1 rounded-full">${t}</span>`
    ).join('');
    document.getElementById('rec-code').textContent = s.code;
    document.getElementById('recommendation').classList.remove('hidden');
  }

  document.querySelectorAll('input[type="radio"]').forEach(r => r.addEventListener('change', recommend));

  document.getElementById('copy-btn').addEventListener('click', () => {
    const code = document.getElementById('rec-code').textContent;
    navigator.clipboard.writeText(code).then(() => {
      const lbl = document.getElementById('copy-label');
      lbl.textContent = 'Copied!';
      setTimeout(() => lbl.textContent = 'Copy', 2000);
    });
  });
</script>
