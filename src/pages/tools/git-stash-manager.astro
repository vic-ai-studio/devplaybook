---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GitStashManager from '../../components/GitStashManager.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is git stash and when should I use it?",
    answer: "git stash temporarily shelves changes you have made to your working copy so you can switch context — for example, pull the latest changes or jump to a different branch — without committing incomplete work. When you are ready, you apply the stash to restore your changes.",
  },
  {
    question: "What is the difference between git stash apply and git stash pop?",
    answer: "Both commands restore stashed changes to your working directory. The difference is that git stash pop also removes the stash entry from the list after applying it, while git stash apply leaves the entry in the list so you can apply it again or to multiple branches.",
  },
  {
    question: "Does git stash save untracked files?",
    answer: "By default, git stash only saves tracked files (modified or staged). To include new untracked files use git stash push --include-untracked. To also include files listed in .gitignore, use git stash push --all.",
  },
  {
    question: "How do I apply a specific stash instead of the most recent one?",
    answer: "Run git stash list to see all stash entries with their index numbers (stash@{0}, stash@{1}, etc.). Then use git stash apply stash@{N} or git stash pop stash@{N} to apply the specific entry you want. Use the stash index input at the top of this tool to update all command examples at once.",
  },
  {
    question: "What does git stash branch do?",
    answer: "git stash branch <branch-name> stash@{N} creates a new branch starting from the commit at which the stash was originally created, checks out that branch, and applies the stash to it. If the apply succeeds, the stash is automatically dropped. This is useful when applying a stash would conflict with your current branch.",
  },
];
---

<BaseLayout
  title="Git Stash Manager — Visual Git Stash Command Reference"
  description="Visual reference for all git stash commands. Copy-ready commands for saving, listing, applying, deleting, and branching from stashes. Adjust the stash index to update all examples instantly."
  tool="Git Stash Manager, git stash commands, git stash cheat sheet, git stash reference"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Git Stash Manager",
    "url": "https://devplaybook.cc/tools/git-stash-manager",
    "description": "Visual reference for all git stash commands. Copy-ready commands for saving, listing, applying, deleting stashes, and creating branches from stashes.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  })} />

  <h1 class="text-3xl font-bold mb-2">Git Stash Manager</h1>
  <p class="text-text-muted mb-4">
    A visual command reference for every git stash operation. Adjust the stash index to instantly update all <code class="font-mono text-primary">stash@&#123;N&#125;</code> examples, then copy the exact command you need. No installation required — runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Dynamic stash index — update all examples at once</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> One-click copy for every command</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Covers save, list, apply, delete &amp; branch</span>
  </div>
  <GitStashManager client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Git Stash Manager" relatedTags={['git', 'version-control', 'cli', 'developer-tools']} />
</BaseLayout>
