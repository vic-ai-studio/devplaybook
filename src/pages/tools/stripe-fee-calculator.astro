---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How does Stripe calculate processing fees?", answer: "Stripe's standard rate is 2.9% + $0.30 per successful card transaction for US businesses. For international cards, an additional 1.5% applies. For manually-entered cards (MOTO), add 0.5% extra. For ACH/bank transfers, the rate is 0.8% capped at $5. Stripe Radar fraud detection can add $0.05 per screened transaction in custom plans." },
  { question: "How do I calculate what to charge to receive a specific amount?", answer: "To receive exactly $X after Stripe fees (2.9% + $0.30), use the formula: charge = (X + 0.30) / (1 - 0.029). For example, to receive $100 net: charge = (100 + 0.30) / 0.971 = $103.40. This ensures the fee is passed through to the customer." },
  { question: "What is Stripe's fee for international cards?", answer: "International cards (cards issued outside your country) have an additional 1.5% on top of the standard rate. So for a US merchant with a European card, the total fee is 2.9% + 1.5% + $0.30 = 4.4% + $0.30. This covers Stripe's currency conversion and cross-border processing costs." },
  { question: "Does Stripe charge differently for different currencies?", answer: "Stripe's percentage fees are similar across currencies, but the fixed per-transaction fee varies by currency. For example, EUR transactions are €0.25 fixed, GBP is £0.20, CAD is C$0.30. The percentages (2.9% + international surcharge) remain roughly consistent. Always check Stripe's pricing page for your exact country rates." },
  { question: "What is Stripe's volume discount?", answer: "Stripe offers custom pricing for high-volume merchants (typically $80K+ monthly processing). Custom rates usually lower the percentage fee — common examples are 2.2-2.5% + $0.20-0.25 per transaction. Contact Stripe's sales team if your monthly volume consistently exceeds $80K." },
  { question: "Are there any hidden fees with Stripe?", answer: "Beyond the standard processing fee, watch for: disputed charges ($15 per dispute, refunded if you win), payouts to non-US banks (0.25% + $0.10 for Instant Payouts), Stripe Tax (0.5% on transactions where it calculates tax), Connect platform fees if using Stripe Connect, and radar for fraud protection in certain plans." },
];
---

<BaseLayout
  title="Stripe Fee Calculator — Calculate Processing Fees & Break-Even Pricing"
  description="Free Stripe fee calculator. Calculate exact processing fees for any transaction amount, compare plans, and find the optimal charge to receive your target amount. Includes international rates and volume discounts."
  tool="Stripe fee calculator, Stripe processing fee, Stripe 2.9 plus 30 cents, Stripe international fee, how much does Stripe charge, Stripe fee estimator, payment processing calculator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Stripe Fee Calculator</h1>
  <p class="text-text-muted mb-4">Calculate exact Stripe processing fees for any transaction. Find out your net payout, estimate monthly costs by volume, and calculate the optimal price to charge customers so you receive your target amount after fees.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Standard + custom rates</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Break-even price calculator</span>
  </div>

  <div class="space-y-5">
    <!-- Tabs -->
    <div class="flex gap-1 bg-surface border border-border rounded-xl p-1">
      <button class="stripe-tab active flex-1 py-2 text-sm font-medium rounded-lg transition-colors" data-tab="single">Single Transaction</button>
      <button class="stripe-tab flex-1 py-2 text-sm font-medium rounded-lg transition-colors" data-tab="volume">Monthly Volume</button>
      <button class="stripe-tab flex-1 py-2 text-sm font-medium rounded-lg transition-colors" data-tab="passthrough">Pass-Through Pricing</button>
    </div>

    <!-- Single Transaction -->
    <div id="tab-single" class="space-y-5">
      <div class="bg-surface border border-border rounded-xl p-5 space-y-5">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="str-amount" class="block text-sm font-medium mb-1.5">Transaction Amount</label>
            <div class="relative">
              <span id="str-currency-symbol" class="absolute left-3 top-1/2 -translate-y-1/2 text-text-muted text-sm">$</span>
              <input id="str-amount" type="number" value="100" min="0" step="0.01"
                class="w-full bg-background border border-border rounded-lg pl-7 pr-3 py-2 text-sm focus:outline-none focus:border-accent" />
            </div>
          </div>
          <div>
            <label for="str-currency" class="block text-sm font-medium mb-1.5">Currency</label>
            <select id="str-currency" class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent">
              <option value="USD" data-pct="0.029" data-fixed="0.30" data-sym="$">USD — US Dollar</option>
              <option value="EUR" data-pct="0.029" data-fixed="0.25" data-sym="€">EUR — Euro</option>
              <option value="GBP" data-pct="0.029" data-fixed="0.20" data-sym="£">GBP — British Pound</option>
              <option value="CAD" data-pct="0.029" data-fixed="0.30" data-sym="C$">CAD — Canadian Dollar</option>
              <option value="AUD" data-pct="0.029" data-fixed="0.30" data-sym="A$">AUD — Australian Dollar</option>
              <option value="JPY" data-pct="0.036" data-fixed="0" data-sym="¥">JPY — Japanese Yen</option>
              <option value="SGD" data-pct="0.034" data-fixed="0.50" data-sym="S$">SGD — Singapore Dollar</option>
              <option value="TWD" data-pct="0.029" data-fixed="10" data-sym="NT$">TWD — New Taiwan Dollar</option>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium mb-2">Card Type</label>
            <div class="flex flex-col gap-2">
              <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="radio" name="str-card" value="0" checked class="accent-accent" /> Domestic card</label>
              <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="radio" name="str-card" value="0.015" class="accent-accent" /> International card (+1.5%)</label>
              <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="radio" name="str-card" value="0.005" class="accent-accent" /> Manually-entered/MOTO (+0.5%)</label>
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium mb-2">Rate Plan</label>
            <div class="flex flex-col gap-2">
              <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="radio" name="str-plan" value="standard" checked class="accent-accent" /> Standard (2.9% + fixed)</label>
              <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="radio" name="str-plan" value="custom" class="accent-accent" /> Custom rate</label>
            </div>
            <div id="str-custom-rate" class="hidden mt-2 grid grid-cols-2 gap-2">
              <div>
                <label class="block text-xs text-text-muted mb-1">% rate</label>
                <input id="str-custom-pct" type="number" value="2.2" step="0.01" min="0" max="10"
                  class="w-full bg-background border border-border rounded-lg px-2 py-1.5 text-sm focus:outline-none focus:border-accent" />
              </div>
              <div>
                <label class="block text-xs text-text-muted mb-1">Fixed fee</label>
                <input id="str-custom-fixed" type="number" value="0.20" step="0.01" min="0"
                  class="w-full bg-background border border-border rounded-lg px-2 py-1.5 text-sm focus:outline-none focus:border-accent" />
              </div>
            </div>
          </div>
        </div>

        <button id="str-calc-single" class="bg-accent hover:bg-accent/80 text-white font-medium px-5 py-2 rounded-lg text-sm transition-colors">
          Calculate Fee
        </button>
      </div>

      <!-- Single result -->
      <div id="str-single-result" class="hidden bg-surface border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold text-text-muted uppercase tracking-wide mb-4">Fee Breakdown</h2>
        <div class="space-y-3">
          <div class="flex justify-between text-sm"><span>Charge Amount</span><span id="res-charge" class="font-mono font-semibold"></span></div>
          <div class="flex justify-between text-sm text-text-muted"><span>Percentage Fee</span><span id="res-pct-fee" class="font-mono"></span></div>
          <div class="flex justify-between text-sm text-text-muted"><span>Fixed Fee</span><span id="res-fixed-fee" class="font-mono"></span></div>
          <div class="border-t border-border pt-3 flex justify-between text-sm font-semibold text-red-400"><span>Total Stripe Fee</span><span id="res-total-fee" class="font-mono"></span></div>
          <div class="flex justify-between text-base font-bold text-green-400"><span>Net Payout</span><span id="res-net" class="font-mono"></span></div>
          <div class="flex justify-between text-xs text-text-muted"><span>Effective Rate</span><span id="res-eff-rate" class="font-mono"></span></div>
        </div>
      </div>
    </div>

    <!-- Volume Calculator -->
    <div id="tab-volume" class="hidden space-y-5">
      <div class="bg-surface border border-border rounded-xl p-5 space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="vol-amount" class="block text-sm font-medium mb-1.5">Avg Transaction Amount</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-text-muted text-sm">$</span>
              <input id="vol-amount" type="number" value="50" min="0" step="0.01"
                class="w-full bg-background border border-border rounded-lg pl-7 pr-3 py-2 text-sm focus:outline-none focus:border-accent" />
            </div>
          </div>
          <div>
            <label for="vol-count" class="block text-sm font-medium mb-1.5">Monthly Transactions</label>
            <input id="vol-count" type="number" value="200" min="0"
              class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent" />
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="vol-intl-pct" class="block text-sm font-medium mb-1.5">International Cards (%)</label>
            <input id="vol-intl-pct" type="number" value="20" min="0" max="100"
              class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent" />
          </div>
          <div>
            <label for="vol-plan" class="block text-sm font-medium mb-1.5">Rate Plan</label>
            <select id="vol-plan" class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent">
              <option value="standard">Standard (2.9% + $0.30)</option>
              <option value="custom-high">High-volume (~2.2% + $0.20)</option>
            </select>
          </div>
        </div>

        <button id="str-calc-volume" class="bg-accent hover:bg-accent/80 text-white font-medium px-5 py-2 rounded-lg text-sm transition-colors">
          Calculate Monthly Cost
        </button>
      </div>

      <div id="str-volume-result" class="hidden bg-surface border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold text-text-muted uppercase tracking-wide mb-4">Monthly Volume Breakdown</h2>
        <div class="space-y-3">
          <div class="flex justify-between text-sm"><span>Gross Volume</span><span id="vol-res-gross" class="font-mono font-semibold"></span></div>
          <div class="flex justify-between text-sm text-text-muted"><span>Domestic Fees</span><span id="vol-res-dom" class="font-mono"></span></div>
          <div class="flex justify-between text-sm text-text-muted"><span>International Surcharge</span><span id="vol-res-intl" class="font-mono"></span></div>
          <div class="border-t border-border pt-3 flex justify-between text-sm font-semibold text-red-400"><span>Total Monthly Fees</span><span id="vol-res-total" class="font-mono"></span></div>
          <div class="flex justify-between text-base font-bold text-green-400"><span>Monthly Net Payout</span><span id="vol-res-net" class="font-mono"></span></div>
          <div class="flex justify-between text-xs text-text-muted"><span>Annual Fee Cost</span><span id="vol-res-annual" class="font-mono"></span></div>
        </div>
      </div>
    </div>

    <!-- Pass-Through -->
    <div id="tab-passthrough" class="hidden space-y-5">
      <div class="bg-surface border border-border rounded-xl p-5 space-y-4">
        <p class="text-sm text-text-muted">Calculate what to charge customers so you receive your desired net amount after fees.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="pt-target" class="block text-sm font-medium mb-1.5">Desired Net Amount (after fees)</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-text-muted text-sm">$</span>
              <input id="pt-target" type="number" value="100" min="0" step="0.01"
                class="w-full bg-background border border-border rounded-lg pl-7 pr-3 py-2 text-sm focus:outline-none focus:border-accent" />
            </div>
          </div>
          <div>
            <label for="pt-plan" class="block text-sm font-medium mb-1.5">Rate Plan</label>
            <select id="pt-plan" class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent">
              <option value="standard">Standard (2.9% + $0.30)</option>
              <option value="intl">International (4.4% + $0.30)</option>
              <option value="custom">Custom</option>
            </select>
          </div>
        </div>
        <div id="pt-custom-row" class="hidden grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs text-text-muted mb-1">% rate</label>
            <input id="pt-custom-pct" type="number" value="2.9" step="0.01" class="w-full bg-background border border-border rounded-lg px-2 py-1.5 text-sm focus:outline-none focus:border-accent" />
          </div>
          <div>
            <label class="block text-xs text-text-muted mb-1">Fixed fee ($)</label>
            <input id="pt-custom-fixed" type="number" value="0.30" step="0.01" class="w-full bg-background border border-border rounded-lg px-2 py-1.5 text-sm focus:outline-none focus:border-accent" />
          </div>
        </div>
        <button id="str-calc-pt" class="bg-accent hover:bg-accent/80 text-white font-medium px-5 py-2 rounded-lg text-sm transition-colors">
          Calculate Charge Price
        </button>
      </div>

      <div id="str-pt-result" class="hidden bg-surface border border-border rounded-xl p-5">
        <h2 class="text-sm font-semibold text-text-muted uppercase tracking-wide mb-4">Pass-Through Result</h2>
        <div class="space-y-3">
          <div class="flex justify-between text-base font-bold text-accent"><span>Charge Customer</span><span id="pt-res-charge" class="font-mono"></span></div>
          <div class="flex justify-between text-sm text-text-muted"><span>Stripe Fee</span><span id="pt-res-fee" class="font-mono"></span></div>
          <div class="flex justify-between text-sm font-semibold text-green-400"><span>You Receive</span><span id="pt-res-net" class="font-mono"></span></div>
        </div>
        <div class="mt-4 p-3 bg-background rounded-lg border border-border">
          <p class="text-xs text-text-muted">Formula: <code class="font-mono">charge = (target + fixed) / (1 - rate)</code></p>
          <p id="pt-formula-detail" class="text-xs font-mono mt-1 text-text-muted"></p>
        </div>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Stripe Fee Calculator" relatedTags={['payments', 'fintech', 'developer-tools', 'saas', 'calculator']} />
</BaseLayout>

<script>
(function () {
  // Tab switching
  const tabs = document.querySelectorAll('.stripe-tab');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => { t.classList.remove('active', 'bg-accent', 'text-white'); t.classList.add('text-text-muted'); });
      tab.classList.add('active', 'bg-accent', 'text-white');
      tab.classList.remove('text-text-muted');
      ['single', 'volume', 'passthrough'].forEach(id => {
        document.getElementById(`tab-${id}`).classList.toggle('hidden', tab.dataset.tab !== id);
      });
    });
  });
  // Set initial active style
  tabs[0].classList.add('bg-accent', 'text-white');
  tabs[0].classList.remove('text-text-muted');

  function fmt(amount, sym) {
    if (!sym) sym = '$';
    return `${sym}${Math.abs(amount).toFixed(2)}`;
  }

  // Currency change → update symbol
  document.getElementById('str-currency').addEventListener('change', function() {
    const sym = this.options[this.selectedIndex].dataset.sym;
    document.getElementById('str-currency-symbol').textContent = sym;
  });

  // Custom rate plan toggle
  document.querySelectorAll('input[name="str-plan"]').forEach(r => {
    r.addEventListener('change', function() {
      document.getElementById('str-custom-rate').classList.toggle('hidden', this.value !== 'custom');
    });
  });

  // Pass-through plan toggle
  document.getElementById('pt-plan').addEventListener('change', function() {
    document.getElementById('pt-custom-row').classList.toggle('hidden', this.value !== 'custom');
  });

  // Single transaction
  document.getElementById('str-calc-single').addEventListener('click', () => {
    const amount = parseFloat(document.getElementById('str-amount').value) || 0;
    const sel = document.getElementById('str-currency');
    const opt = sel.options[sel.selectedIndex];
    const sym = opt.dataset.sym || '$';
    let basePct = parseFloat(opt.dataset.pct) || 0.029;
    let baseFixed = parseFloat(opt.dataset.fixed) || 0.30;

    const plan = document.querySelector('input[name="str-plan"]:checked').value;
    if (plan === 'custom') {
      basePct = (parseFloat(document.getElementById('str-custom-pct').value) || 2.9) / 100;
      baseFixed = parseFloat(document.getElementById('str-custom-fixed').value) || 0.20;
    }

    const intlExtra = parseFloat(document.querySelector('input[name="str-card"]:checked').value) || 0;
    const totalPct = basePct + intlExtra;

    const pctFee = amount * totalPct;
    const totalFee = pctFee + baseFixed;
    const net = amount - totalFee;
    const effRate = amount > 0 ? (totalFee / amount * 100) : 0;

    document.getElementById('res-charge').textContent = fmt(amount, sym);
    document.getElementById('res-pct-fee').textContent = `-${fmt(pctFee, sym)} (${(totalPct * 100).toFixed(2)}%)`;
    document.getElementById('res-fixed-fee').textContent = `-${fmt(baseFixed, sym)}`;
    document.getElementById('res-total-fee').textContent = `-${fmt(totalFee, sym)}`;
    document.getElementById('res-net').textContent = fmt(net, sym);
    document.getElementById('res-eff-rate').textContent = `${effRate.toFixed(2)}%`;
    document.getElementById('str-single-result').classList.remove('hidden');
  });

  // Volume
  document.getElementById('str-calc-volume').addEventListener('click', () => {
    const avgAmt = parseFloat(document.getElementById('vol-amount').value) || 50;
    const count = parseInt(document.getElementById('vol-count').value) || 200;
    const intlPct = (parseFloat(document.getElementById('vol-intl-pct').value) || 0) / 100;
    const plan = document.getElementById('vol-plan').value;

    const basePct = plan === 'standard' ? 0.029 : 0.022;
    const baseFixed = plan === 'standard' ? 0.30 : 0.20;

    const gross = avgAmt * count;
    const domCount = count * (1 - intlPct);
    const intlCount = count * intlPct;

    const domFee = domCount * (avgAmt * basePct + baseFixed);
    const intlFee = intlCount * (avgAmt * (basePct + 0.015) + baseFixed);
    const totalFee = domFee + intlFee;
    const net = gross - totalFee;

    document.getElementById('vol-res-gross').textContent = `$${gross.toFixed(2)}`;
    document.getElementById('vol-res-dom').textContent = `-$${domFee.toFixed(2)}`;
    document.getElementById('vol-res-intl').textContent = `-$${(intlFee - domFee * intlPct / (1 - intlPct || 1)).toFixed(2)}`;
    document.getElementById('vol-res-total').textContent = `-$${totalFee.toFixed(2)}`;
    document.getElementById('vol-res-net').textContent = `$${net.toFixed(2)}`;
    document.getElementById('vol-res-annual').textContent = `$${(totalFee * 12).toFixed(2)}/yr`;
    document.getElementById('str-volume-result').classList.remove('hidden');
  });

  // Pass-through
  document.getElementById('str-calc-pt').addEventListener('click', () => {
    const target = parseFloat(document.getElementById('pt-target').value) || 100;
    const plan = document.getElementById('pt-plan').value;

    let pct, fixed;
    if (plan === 'standard') { pct = 0.029; fixed = 0.30; }
    else if (plan === 'intl') { pct = 0.044; fixed = 0.30; }
    else {
      pct = (parseFloat(document.getElementById('pt-custom-pct').value) || 2.9) / 100;
      fixed = parseFloat(document.getElementById('pt-custom-fixed').value) || 0.30;
    }

    const charge = (target + fixed) / (1 - pct);
    const fee = charge - target;

    document.getElementById('pt-res-charge').textContent = `$${charge.toFixed(2)}`;
    document.getElementById('pt-res-fee').textContent = `-$${fee.toFixed(2)}`;
    document.getElementById('pt-res-net').textContent = `$${target.toFixed(2)}`;
    document.getElementById('pt-formula-detail').textContent = `($${target.toFixed(2)} + $${fixed.toFixed(2)}) / (1 - ${(pct * 100).toFixed(2)}%) = $${charge.toFixed(2)}`;
    document.getElementById('str-pt-result').classList.remove('hidden');
  });
})();
</script>
