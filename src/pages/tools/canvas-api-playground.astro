---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CanvasApiPlayground from '../../components/CanvasApiPlayground.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is the HTML5 Canvas API?", answer: "The HTML5 Canvas API is a JavaScript interface for drawing 2D graphics in a <canvas> element. You use canvas.getContext('2d') to get a 2D rendering context, then call methods like fillRect, arc, beginPath, and drawImage to render shapes, text, and images. It is widely used for games, data visualizations, animations, and image processing." },
  { question: "How does requestAnimationFrame work?", answer: "requestAnimationFrame (rAF) schedules your draw function to run before the browser's next repaint, typically 60 times per second. Unlike setInterval, rAF is synchronized with the display refresh rate, pauses when the tab is hidden (saving CPU), and provides a high-resolution timestamp. Always call rAF at the end of your draw function to create a loop." },
  { question: "What causes canvas animation jank?", answer: "Common causes include: doing too much work per frame (complex calculations, DOM reads), drawing more than needed (redrawing unchanged areas), using save/restore excessively, and creating garbage (new objects every frame). Use an off-screen canvas for complex static backgrounds, minimize state changes, and profile with browser DevTools to find bottlenecks." },
  { question: "How do I control animation speed precisely?", answer: "Track elapsed time using the timestamp provided by requestAnimationFrame. Use the delta (time since last frame) to move objects by distance = speed * delta, not by a fixed amount. This ensures animations look the same regardless of frame rate. For FPS limiting, compare elapsed time to your target interval (e.g., 1000/30 for 30 FPS)." },
  { question: "What is the trail/ghost effect?", answer: "The trail effect draws a semi-transparent black rectangle over the canvas each frame instead of clearing it fully. This leaves 'ghost' copies of previous frames that fade out over time. The transparency value controls fade speed — lower alpha = longer trails. Set fillStyle to rgba(0,0,0,0.1) for slow fades or rgba(0,0,0,0.3) for quick ones." },
  { question: "How do I copy canvas output to an image?", answer: "Call canvas.toDataURL('image/png') to get a base64-encoded PNG, or canvas.toBlob(callback, 'image/png') for a Blob. You can create a temporary <a> element with href set to the data URL and trigger a click to download it: const a = document.createElement('a'); a.href = canvas.toDataURL(); a.download = 'canvas.png'; a.click()." },
];
---

<BaseLayout
  title="HTML5 Canvas API Playground — Live Animation Builder & Code Generator"
  description="Interactive HTML5 Canvas animation playground. Choose from bouncing balls, sine waves, rotating stars, fireworks, and matrix rain. Adjust parameters live and copy the generated JavaScript code."
  tool="HTML5 Canvas Playground, Canvas Animation Generator, JavaScript Canvas Tutorial, requestAnimationFrame Example, Canvas API Demo"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">HTML5 Canvas API Playground</h1>
  <p class="text-text-muted mb-4">Build and explore HTML5 Canvas animations interactively. Adjust parameters in real time and copy the generated code to use in your own projects.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 built-in animation types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live parameter editing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-ready JS code output</span>
  </div>
  <CanvasApiPlayground client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="HTML5 Canvas API Playground" relatedTags={['canvas', 'animation', 'javascript', 'graphics', 'game-dev']} />
</BaseLayout>
