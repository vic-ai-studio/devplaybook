---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="AI SQL Builder — Pro Tool | DevPlaybook"
  description="Convert natural language to SQL queries instantly. Supports PostgreSQL, MySQL, SQLite, and more. DevPlaybook Pro feature."
  tool="AI SQL Builder, Natural Language to SQL, SQL Generator, Text to SQL"
>
  <!-- Pro Gate loading -->
  <div id="pro-loading" class="max-w-2xl mx-auto py-16 text-center text-text-muted">
    Checking your account...
  </div>

  <!-- Not Pro: Upgrade Gate -->
  <div id="pro-gate" class="hidden max-w-2xl mx-auto py-16 px-4 text-center">
    <div class="text-6xl mb-6">🗄️</div>
    <h1 class="text-3xl font-bold mb-3">AI SQL Builder is a <span class="text-primary">Pro</span> feature</h1>
    <p class="text-text-muted text-lg mb-8">
      Type what you want in plain English and get correct SQL instantly. Supports schemas, JOINs, CTEs, and all major dialects.
    </p>
    <div class="bg-bg-card border border-border rounded-2xl p-8 mb-8 text-left">
      <h2 class="font-semibold mb-4">Pro includes:</h2>
      <ul class="space-y-2 text-text-muted text-sm">
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> AI SQL Builder (this tool)</li>
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> AI Code Review</li>
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> AI Doc Generator</li>
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> All premium templates & future tools</li>
        <li class="flex items-start gap-2"><span class="text-primary">✓</span> 7-day free trial, cancel anytime</li>
      </ul>
    </div>
    <a href="/pricing" class="inline-block bg-primary hover:bg-primary-dark text-white font-bold px-10 py-4 rounded-xl transition-colors text-lg">
      Start Free Trial — $9/mo
    </a>
    <p class="text-text-muted text-sm mt-4">
      Already subscribed? <a href="/signin" class="text-primary hover:underline">Sign in</a>
    </p>
  </div>

  <!-- Pro Tool UI -->
  <div id="pro-tool" class="hidden">
    <div class="flex items-center gap-3 mb-2">
      <h1 class="text-3xl font-bold">AI SQL Builder</h1>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-primary/20 text-primary border border-primary/30">PRO</span>
    </div>
    <p class="text-text-muted mb-8">Describe what you want in plain English and get production-ready SQL. Optionally paste your schema for accurate table/column names.</p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Input panel -->
      <div class="flex flex-col gap-4">
        <!-- SQL Dialect -->
        <div>
          <label class="block text-sm font-medium mb-2">SQL Dialect</label>
          <select id="dialect-select" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-primary transition-colors">
            <option value="PostgreSQL">PostgreSQL</option>
            <option value="MySQL">MySQL</option>
            <option value="SQLite">SQLite</option>
            <option value="SQL Server">SQL Server (T-SQL)</option>
            <option value="BigQuery">BigQuery (Standard SQL)</option>
            <option value="Snowflake">Snowflake</option>
          </select>
        </div>

        <!-- Natural language prompt -->
        <div>
          <label class="block text-sm font-medium mb-2" for="nl-prompt">What do you want?</label>
          <textarea
            id="nl-prompt"
            rows="5"
            placeholder="e.g. Get all users who signed up in the last 30 days and have placed at least 2 orders, sorted by total spend descending"
            class="w-full px-4 py-3 rounded-xl bg-bg border border-border text-text placeholder:text-text-muted focus:outline-none focus:border-primary transition-colors text-sm resize-y"
          ></textarea>
        </div>

        <!-- Optional schema -->
        <div>
          <label class="block text-sm font-medium mb-2" for="schema-input">
            Schema (optional)
            <span class="text-text-muted font-normal ml-1">— paste your CREATE TABLE statements</span>
          </label>
          <textarea
            id="schema-input"
            rows="8"
            placeholder="CREATE TABLE users (&#10;  id SERIAL PRIMARY KEY,&#10;  email TEXT NOT NULL,&#10;  created_at TIMESTAMPTZ DEFAULT NOW()&#10;);&#10;&#10;CREATE TABLE orders (&#10;  id SERIAL PRIMARY KEY,&#10;  user_id INT REFERENCES users(id),&#10;  total DECIMAL(10,2)&#10;);"
            class="w-full px-4 py-3 rounded-xl bg-bg border border-border text-text placeholder:text-text-muted focus:outline-none focus:border-primary transition-colors font-mono text-sm resize-y"
          ></textarea>
        </div>

        <button
          id="build-btn"
          class="w-full py-3 px-6 rounded-xl bg-primary hover:bg-primary-dark text-white font-bold transition-colors duration-200 disabled:opacity-50"
        >
          Build SQL
        </button>
        <p id="build-error" class="text-xs text-red-400 hidden"></p>

        <!-- Example prompts -->
        <div class="text-xs text-text-muted">
          <p class="font-medium mb-1">Quick examples:</p>
          <div class="flex flex-wrap gap-1.5">
            {[
              'Get the top 10 customers by revenue this month',
              'Find all orders with no corresponding user',
              'Count active subscriptions by plan type',
              'Users who haven\'t logged in for 90 days',
            ].map(ex => (
              <button
                class="example-prompt px-2 py-1 rounded bg-bg-card border border-border hover:border-primary text-xs transition-colors"
                data-prompt={ex}
              >
                {ex.slice(0, 40)}{ex.length > 40 ? '…' : ''}
              </button>
            ))}
          </div>
        </div>
      </div>

      <!-- Output panel -->
      <div class="flex flex-col gap-4">
        <div class="flex items-center justify-between">
          <label class="block text-sm font-medium">Generated SQL</label>
          <button id="copy-sql-btn" class="text-xs text-text-muted hover:text-primary transition-colors hidden">Copy SQL</button>
        </div>
        <div id="sql-placeholder" class="flex-1 min-h-[200px] rounded-xl bg-bg border border-border flex items-center justify-center text-text-muted text-sm">
          Your SQL will appear here
        </div>
        <div id="sql-loading" class="hidden flex-1 min-h-[200px] rounded-xl bg-bg border border-border flex items-center justify-center text-text-muted text-sm">
          <div class="text-center">
            <div class="animate-pulse text-3xl mb-3">🗄️</div>
            <p>Building your query...</p>
          </div>
        </div>
        <textarea
          id="sql-output"
          class="hidden min-h-[200px] rounded-xl bg-bg border border-border p-4 text-sm font-mono resize-y focus:outline-none focus:border-primary transition-colors"
          readonly
        ></textarea>

        <div id="explanation-wrapper" class="hidden">
          <label class="block text-sm font-medium mb-2">Explanation</label>
          <div id="explanation-output" class="rounded-xl bg-bg-card border border-border p-4 text-sm text-text-muted"></div>
        </div>
      </div>
    </div>

    <div class="mt-8 p-4 bg-bg-card border border-border rounded-xl text-xs text-text-muted">
      <strong>Always review generated SQL</strong> before running against production. The AI understands intent but may make assumptions about your specific data model.
    </div>
  </div>

  <ToolPageCta currentTool="AI SQL Builder" relatedTags={['ai', 'sql', 'database', 'development']} />
</BaseLayout>

<script is:inline>
  async function init() {
    let session;
    try {
      const res = await fetch('/api/auth/session');
      session = await res.json();
    } catch {
      session = { loggedIn: false };
    }

    document.getElementById('pro-loading').classList.add('hidden');

    if (!session.loggedIn || !session.isPro) {
      document.getElementById('pro-gate').classList.remove('hidden');
      return;
    }

    document.getElementById('pro-tool').classList.remove('hidden');

    const btn = document.getElementById('build-btn');
    const nlPrompt = document.getElementById('nl-prompt');
    const schemaInput = document.getElementById('schema-input');
    const dialectSelect = document.getElementById('dialect-select');
    const errorMsg = document.getElementById('build-error');
    const placeholder = document.getElementById('sql-placeholder');
    const loading = document.getElementById('sql-loading');
    const sqlOutput = document.getElementById('sql-output');
    const explanationWrapper = document.getElementById('explanation-wrapper');
    const explanationOutput = document.getElementById('explanation-output');
    const copyBtn = document.getElementById('copy-sql-btn');

    // Example prompt buttons
    document.querySelectorAll('.example-prompt').forEach(exBtn => {
      exBtn.addEventListener('click', () => {
        nlPrompt.value = exBtn.dataset.prompt;
        nlPrompt.focus();
      });
    });

    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(sqlOutput.value).then(() => {
        copyBtn.textContent = 'Copied!';
        setTimeout(() => { copyBtn.textContent = 'Copy SQL'; }, 2000);
      });
    });

    btn.addEventListener('click', async () => {
      const prompt = nlPrompt.value.trim();
      const schema = schemaInput.value.trim();
      const dialect = dialectSelect.value;

      if (!prompt) { errorMsg.textContent = 'Describe what you want first.'; errorMsg.classList.remove('hidden'); return; }
      errorMsg.classList.add('hidden');

      btn.disabled = true;
      btn.textContent = 'Building...';
      placeholder.classList.add('hidden');
      sqlOutput.classList.add('hidden');
      explanationWrapper.classList.add('hidden');
      loading.classList.remove('hidden');

      try {
        const res = await fetch('/api/ai/sql-builder', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ prompt, schema, dialect }),
        });
        const data = await res.json();

        if (!res.ok) {
          if (res.status === 403) {
            errorMsg.textContent = 'Pro subscription required. Refresh to check your status.';
          } else if (res.status === 401) {
            errorMsg.textContent = 'Session expired — please sign in again.';
          } else {
            errorMsg.textContent = data.error || 'Something went wrong.';
          }
          errorMsg.classList.remove('hidden');
          loading.classList.add('hidden');
          placeholder.classList.remove('hidden');
        } else {
          sqlOutput.value = data.sql;
          loading.classList.add('hidden');
          sqlOutput.classList.remove('hidden');
          copyBtn.classList.remove('hidden');

          if (data.explanation) {
            explanationOutput.textContent = data.explanation;
            explanationWrapper.classList.remove('hidden');
          }
        }
      } catch {
        errorMsg.textContent = 'Network error — please try again.';
        errorMsg.classList.remove('hidden');
        loading.classList.add('hidden');
        placeholder.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Build SQL';
      }
    });
  }

  init();
</script>
