---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MongodbAggregationBuilder from '../../components/MongodbAggregationBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a MongoDB aggregation pipeline?",
    answer: "An aggregation pipeline is a sequence of stages that process documents. Each stage transforms the data passing through it. Documents flow through the stages sequentially — the output of one stage becomes the input of the next. Common use cases: filtering, grouping, counting, joining collections, reshaping documents."
  },
  {
    question: "What does the $group stage _id field control?",
    answer: "The _id in $group is the grouping key — it determines which documents are grouped together. Use a field reference like '$category' to group by a field, null to aggregate all documents into one group, or an object like { year: { $year: '$date' }, status: '$status' } to group by multiple fields."
  },
  {
    question: "What is the difference between $match at the start vs end of a pipeline?",
    answer: "Placing $match as the first stage is critical for performance — it filters documents before any other processing, allowing MongoDB to use indexes. A $match at the end filters after all previous stages have processed, which wastes CPU and memory. Always put $match as early as possible."
  },
  {
    question: "How does $lookup work?",
    answer: "$lookup performs a left outer join with another collection. 'from' is the collection to join, 'localField' is the field in the current collection, 'foreignField' is the matching field in the 'from' collection, and 'as' is the array field added to each document with the matching documents."
  },
  {
    question: "When should I use $project?",
    answer: "Use $project to include only the fields you need (set to 1), exclude fields (set to 0), or add computed fields. Projecting early in the pipeline reduces document size, which speeds up subsequent stages and reduces memory usage. Only _id requires explicit exclusion (set to 0) when projecting includes."
  },
  {
    question: "Does this tool send data to a server?",
    answer: "No. All pipeline building and JSON generation happens in your browser. Nothing is sent to any server."
  },
];
---

<BaseLayout
  title="MongoDB Aggregation Builder — Visual Pipeline Generator"
  description="Build MongoDB aggregation pipelines visually. Add and reorder $match, $group, $sort, $project, $limit, and $lookup stages. Outputs a ready-to-use db.collection.aggregate([...]) snippet."
  tool="MongoDB Aggregation Builder, MongoDB Pipeline Generator, MongoDB Aggregation Pipeline Tool"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "MongoDB Aggregation Builder",
    "url": "https://devplaybook.cc/tools/mongodb-aggregation-builder",
    "description": "Build MongoDB aggregation pipelines visually. Supports $match, $group, $sort, $project, $limit, and $lookup stages. Outputs ready-to-use aggregation code.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">MongoDB Aggregation Builder</h1>
  <p class="text-text-muted mb-4">
    Build MongoDB aggregation pipelines visually. Add, reorder, and configure <code class="font-mono bg-surface px-1 rounded text-sm">$match</code>, <code class="font-mono bg-surface px-1 rounded text-sm">$group</code>, <code class="font-mono bg-surface px-1 rounded text-sm">$sort</code>, <code class="font-mono bg-surface px-1 rounded text-sm">$project</code>, <code class="font-mono bg-surface px-1 rounded text-sm">$limit</code>, and <code class="font-mono bg-surface px-1 rounded text-sm">$lookup</code> stages. Outputs a ready-to-use <code class="font-mono bg-surface px-1 rounded text-sm">db.collection.aggregate([...])</code> snippet.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 6 pipeline stages</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Drag to reorder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <MongodbAggregationBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="MongoDB Aggregation Builder" relatedTags={['mongodb', 'database', 'nosql', 'aggregation', 'developer-tools']} />
</BaseLayout>
