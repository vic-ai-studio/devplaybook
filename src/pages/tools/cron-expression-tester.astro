---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CronExpressionParser from '../../components/CronExpressionParser.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How do I test a cron expression?", answer: "Paste your cron expression into the input — e.g. '*/15 9-17 * * 1-5' — and hit Parse. The tester validates each field, explains the expression in plain English, and shows the next 10 scheduled run times with their day-of-week labels." },
  { question: "What do the 5 cron fields mean?", answer: "The 5 fields (left to right) are: Minute (0–59), Hour (0–23), Day of Month (1–31), Month (1–12 or JAN–DEC), and Day of Week (0–6 where 0=Sunday, or SUN–SAT). Use * for 'any', */n for 'every n units', ranges like 1-5, and comma-separated lists like 1,3,5." },
  { question: "What is the difference between cron on Linux and GitHub Actions?", answer: "Linux cron uses 5-field syntax (minute hour day month weekday). GitHub Actions also uses 5-field POSIX cron in UTC. AWS EventBridge uses 6-field syntax with an optional seconds field. This tester uses standard 5-field cron compatible with Linux cron, GitHub Actions, and most schedulers." },
  { question: "Why is my cron expression not running when I expect?", answer: "Common issues: (1) Server timezone — cron runs in local server time, not your local time. Check with 'crontab -l' and 'date'. (2) The expression '0 9 * * 1-5' runs at 9:00 on weekdays, but '0 9 * * 1,2,3,4,5' does the same. (3) Day-of-month and day-of-week fields are ORed in most cron implementations, not ANDed." },
  { question: "How do I run a cron job every 15 minutes during business hours?", answer: "Use '*/15 9-17 * * 1-5'. This runs every 15 minutes (0, 15, 30, 45) during hours 9–17 on weekdays (Monday–Friday). Note: it will fire at 9:00, 9:15, 9:30, ... 17:45 — including the :00 and :45 marks within hour 17." },
  { question: "What is the minimum cron interval?", answer: "Standard cron minimum is 1 minute ('* * * * *' runs every minute). For sub-minute scheduling, use a loop in your script, systemd timers with AccuracySec, or cloud schedulers like AWS EventBridge with rate expressions (rate(30 seconds))." },
];
---

<BaseLayout
  title="Cron Expression Tester — See Next 10 Run Times + Plain-English Explanation"
  description="Test any cron expression instantly. Enter a cron schedule to see the next 10 run times, a plain-English explanation of each field, and validation. Free, runs 100% in your browser."
  tool="cron expression tester, cron tester, cron job tester, cron next run time, cron expression validator, cron expression explained, cron schedule checker"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Cron Expression Tester",
    "url": "https://devplaybook.cc/tools/cron-expression-tester",
    "description": "Test cron expressions and see the next 10 scheduled run times plus plain-English explanation of each field.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Cron Expression Tester</h1>
  <p class="text-text-muted mb-4">
    Enter any cron expression to instantly see the <strong>next 10 scheduled run times</strong>, a plain-English explanation of each field, and validation errors. Works with Linux cron, GitHub Actions, and standard 5-field POSIX cron schedules.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Next 10 run times shown</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Plain-English field explanations</span>
  </div>
  <CronExpressionParser client:only="preact" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more free developer tools?</p>
    <a href="/tools" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Browse All Free Tools →</a>
  </div>
  <ToolPageCta currentTool="Cron Expression Tester" relatedTags={['cron', 'scheduler', 'devops', 'linux', 'automation', 'ci']} />
</BaseLayout>
