---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ColorPaletteExtractor from '../../components/ColorPaletteExtractor.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "How do I extract a color palette from hex codes?", answer: "Paste any hex codes into the input field — comma-separated, space-separated, or raw text. The tool parses all #rrggbb and #rgb values, converts each to RGB and HSL, identifies approximate color names, and builds your palette. Click any swatch to copy its hex code instantly." },
  { question: "What is HSL and how is it different from RGB?", answer: "HSL (Hue, Saturation, Lightness) is a perceptual color model. Hue (0–360°) is the color family (red=0, green=120, blue=240). Saturation (0–100%) controls color intensity — 0% is gray, 100% is vivid. Lightness (0–100%) controls brightness — 0% is black, 50% is pure color, 100% is white. HSL is more intuitive for designers because you can adjust brightness and vibrancy independently." },
  { question: "What are complementary and triadic colors?", answer: "Complementary colors are opposite on the color wheel (hue +180°) — high contrast, vibrant pairings ideal for CTAs and emphasis. Triadic colors are evenly spaced at 120° intervals — a balanced, vibrant trio used for playful, energetic designs. Analogous colors (adjacent, 30° apart) create harmonious, calm palettes common in nature-inspired designs." },
  { question: "How are color shades generated?", answer: "Shades are generated by fixing the hue and saturation from your base color and cycling through lightness values (roughly 10%, 20%, 35%, 50%, 65%, 75%, 85%, 92%). This mirrors how design systems like Tailwind CSS create their color scales. The result gives you a full range from near-black to near-white using your brand's hue." },
  { question: "What is the CSS custom properties output?", answer: "The CSS output generates a :root block with custom properties (CSS variables) for each color: --color-1, --color-2, etc. Copy it into your stylesheet and reference colors anywhere with var(--color-1). This makes it easy to build a consistent design token system from any palette." },
  { question: "How accurate are the color names?", answer: "Color names are approximations based on HSL ranges — useful as labels rather than exact matches. Black/white are detected by lightness, grays by low saturation, and named hue ranges identify reds, oranges, yellows, greens, cyans, blues, purples, and pinks. For precise color naming (e.g., 'Cobalt' vs 'Cerulean'), you would need a full color dictionary lookup." },
];
---

<BaseLayout
  title="Color Palette Extractor — Parse Hex Codes, Generate Shades & Harmony"
  description="Paste hex color codes to extract a complete palette. View swatches, copy hex values, generate shades and tints, see complementary and triadic harmonies, and export CSS custom properties."
  tool="Color Palette Extractor, Hex Color Palette, Color Shades Generator, Complementary Color Finder, CSS Color Variables Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Color Palette Extractor</h1>
  <p class="text-text-muted mb-4">Paste any hex colors to build a visual palette. Explore shades, complementary and triadic harmonies, and export CSS custom properties — all in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Parses any hex list</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Shades, complementary & triadic</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Export CSS custom properties</span>
  </div>
  <ColorPaletteExtractor client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Color Palette Extractor" relatedTags={['color', 'css', 'design', 'palette', 'graphics']} />
</BaseLayout>
