---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CodeComplexityCalculator from '../../components/CodeComplexityCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is cyclomatic complexity?", answer: "Cyclomatic complexity (CC) is a metric introduced by Thomas McCabe in 1976 that measures the number of linearly independent paths through a program. It equals 1 plus the number of decision points (if, else if, for, while, catch, &&, ||). A CC of 1–5 is simple and easy to test; 6–10 is moderate; 11–20 is high and should be refactored; 21+ is very high and difficult to maintain." },
  { question: "Why does cyclomatic complexity matter?", answer: "Higher cyclomatic complexity means more branches to test and more ways the code can fail. Research shows that code with CC above 10 has significantly higher defect rates. It's also harder to understand, maintain, and refactor. Keeping CC low makes unit testing easier, since each independent path ideally needs its own test case." },
  { question: "What is a good cyclomatic complexity score?", answer: "Industry guidelines from McCabe suggest keeping cyclomatic complexity at 10 or below per function. Google's style guides recommend keeping functions under 20. Code with CC above 20 is generally considered too complex for safe modification and should be broken into smaller functions." },
  { question: "What does nesting depth measure?", answer: "Nesting depth counts how many levels deep your code goes with conditionals and loops — for example, an if inside a for loop inside another if is depth 3. Deep nesting (4+ levels) is a code smell that makes logic harder to follow. Use early returns, guard clauses, or extract inner blocks into helper functions to reduce nesting." },
  { question: "What languages does this tool support?", answer: "The tool auto-detects JavaScript, TypeScript, and Python based on syntax patterns. Cyclomatic complexity is calculated from decision keywords (if, for, while, catch, &&, ||, ? etc.) which are similar across these languages. The nesting depth calculation uses curly braces for JS/TS and indentation for Python." },
  { question: "How do I reduce cyclomatic complexity?", answer: "Extract complex conditions into named boolean variables. Use early returns (guard clauses) instead of deeply nested if/else. Split long functions into smaller single-responsibility functions. Replace switch/if chains with lookup maps or polymorphism. Use libraries for common patterns (e.g., Array.filter/map instead of manual loops)." },
];
---

<BaseLayout
  title="Code Complexity Calculator — Free Online Tool | Cyclomatic Complexity"
  description="Paste JS, TypeScript, or Python code to calculate cyclomatic complexity, lines of code, nesting depth, and function count. Color-coded ratings with refactoring suggestions. Runs 100% in your browser."
  tool="Code Complexity Calculator, Cyclomatic Complexity, Code Metrics, Code Quality Analyzer, McCabe Complexity"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Code Complexity Calculator",
    "url": "https://devplaybook.cc/tools/code-complexity-calculator",
    "description": "Calculate cyclomatic complexity, lines of code, nesting depth, and function count for JS/TS/Python code. Color-coded complexity ratings. Runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Code Complexity Calculator</h1>
  <p class="text-text-muted mb-4">Paste JavaScript, TypeScript, or Python code to instantly calculate <strong>cyclomatic complexity</strong>, lines of code, maximum nesting depth, and function count. Get color-coded ratings (Low / Medium / High / Critical) and actionable refactoring suggestions. Runs entirely in your browser — nothing is sent to any server.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> JS, TypeScript & Python</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> McCabe cyclomatic complexity</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No code leaves your browser</span>
  </div>
  <CodeComplexityCalculator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Code Complexity Calculator" relatedTags={['code-quality', 'javascript', 'typescript', 'python', 'refactoring']} />
</BaseLayout>
