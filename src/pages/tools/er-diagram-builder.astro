---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is an ER diagram?",
    answer: "An Entity-Relationship (ER) diagram is a visual model of a database schema. It shows entities (tables), their attributes (columns), and the relationships between them. ER diagrams are used during database design to clarify structure before writing SQL, communicate schema to teammates, and document existing databases."
  },
  {
    question: "What is a primary key vs foreign key?",
    answer: "A primary key (PK) uniquely identifies each row in a table — no two rows can share the same PK value, and it cannot be NULL. Common choices are auto-incrementing integers (id) or UUIDs. A foreign key (FK) is a column in one table that references the primary key of another table, establishing a link between the two. For example, a Post table might have a user_id FK pointing to the User table's id PK."
  },
  {
    question: "What is cardinality in ER diagrams?",
    answer: "Cardinality describes how many instances of one entity relate to instances of another. One-to-one (1:1) means each row in table A corresponds to exactly one row in table B. One-to-many (1:N) means one row in A can relate to many rows in B — the most common type (e.g., one User has many Posts). Many-to-many (M:N) means rows in A can relate to multiple rows in B and vice versa, which requires a junction/pivot table."
  },
  {
    question: "When should I use one-to-many vs many-to-many?",
    answer: "Use one-to-many when ownership is clear and exclusive — one User owns many Posts, one Order contains many OrderItems. Use many-to-many when both sides can have multiple associations — a Student can enroll in many Courses and a Course can have many Students. Many-to-many relationships require a join table (e.g., enrollments) with foreign keys to both sides, and often additional attributes like enrollment date."
  },
  {
    question: "How do I read crow's foot notation?",
    answer: "Crow's foot notation uses symbols at each end of a relationship line. A single vertical line (|) means 'exactly one'. A crow's foot (three lines splaying out) means 'many'. A circle means 'zero'. Combined symbols read as: single line + single line = one and only one; crow's foot + single line = one or many; crow's foot + circle = zero or many. Read the symbol at the far end of the line as the maximum, and the symbol closer to the entity as the minimum."
  }
];
---

<BaseLayout
  title="ER Diagram Builder — Visual Entity-Relationship Diagram Creator"
  description="Build entity-relationship diagrams visually in your browser. Add entities with typed fields, define relationships, and export your schema as PNG or SQL CREATE TABLE statements. No signup required."
  tool="ER diagram, entity relationship diagram, database schema designer, SQL schema generator, ERD tool, database modeling, CREATE TABLE generator, visual database designer"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "ER Diagram Builder",
    "url": "https://devplaybook.cc/tools/er-diagram-builder",
    "description": "Visual entity-relationship diagram creator. Add entities with typed fields, define relationships with cardinality, and export as PNG or SQL.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">ER Diagram Builder</h1>
  <p class="text-text-muted mb-4">Design database schemas visually. Add entities with typed fields, connect them with relationships, then export as PNG or SQL CREATE TABLE statements — all in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Add entities with PK / FK / typed fields</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Define 1:1, 1:N, M:N relationships</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Export PNG + SQL CREATE TABLE</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <!-- Layout: sidebar + canvas -->
  <div class="flex flex-col lg:flex-row gap-4">

    <!-- Left sidebar -->
    <div class="lg:w-72 flex-shrink-0 space-y-4">

      <!-- Add Entity -->
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <h2 class="text-sm font-semibold mb-3">Add Entity</h2>
        <input id="entity-name-input" type="text" placeholder="Entity name (e.g. User)"
          class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary mb-2" />
        <button id="btn-add-entity"
          class="w-full px-3 py-2 bg-primary text-white rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors">
          + Add Entity
        </button>
      </div>

      <!-- Add Relationship -->
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <h2 class="text-sm font-semibold mb-3">Add Relationship</h2>
        <div class="space-y-2">
          <select id="rel-from"
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
            <option value="">From entity…</option>
          </select>
          <select id="rel-to"
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
            <option value="">To entity…</option>
          </select>
          <select id="rel-type"
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
            <option value="1:N">One-to-Many (1:N)</option>
            <option value="1:1">One-to-One (1:1)</option>
            <option value="M:N">Many-to-Many (M:N)</option>
          </select>
          <input id="rel-label" type="text" placeholder="Label (optional)"
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
          <button id="btn-add-rel"
            class="w-full px-3 py-2 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">
            + Add Relationship
          </button>
        </div>
      </div>

      <!-- Entity list -->
      <div class="bg-bg-card border border-border rounded-lg p-4">
        <h2 class="text-sm font-semibold mb-3">Entities</h2>
        <div id="entity-list" class="space-y-2 max-h-64 overflow-y-auto"></div>
      </div>

      <!-- Actions -->
      <div class="bg-bg-card border border-border rounded-lg p-4 space-y-2">
        <h2 class="text-sm font-semibold mb-3">Export</h2>
        <button id="btn-export-png"
          class="w-full px-3 py-2 bg-primary text-white rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors">
          Export PNG
        </button>
        <button id="btn-copy-sql"
          class="w-full px-3 py-2 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">
          Copy SQL
        </button>
        <button id="btn-reset"
          class="w-full px-3 py-2 bg-bg-card border border-border rounded-lg text-sm text-red-400 hover:border-red-400 transition-colors">
          Reset
        </button>
      </div>
    </div>

    <!-- Canvas area -->
    <div class="flex-1 min-h-0">
      <div class="bg-bg-card border border-border rounded-lg overflow-hidden" style="height:560px; position:relative;">
        <canvas id="er-canvas" class="block w-full h-full" style="cursor:grab;"></canvas>
        <div id="canvas-hint" class="absolute bottom-3 right-3 text-xs text-text-muted opacity-60">Drag entities to reposition</div>
      </div>
    </div>
  </div>

  <!-- Field editor modal -->
  <div id="field-modal" class="hidden fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4">
    <div class="bg-bg-card border border-border rounded-xl w-full max-w-lg shadow-xl">
      <div class="flex items-center justify-between px-5 py-4 border-b border-border">
        <h3 id="modal-title" class="text-sm font-semibold">Edit Entity</h3>
        <button id="modal-close" class="text-text-muted hover:text-foreground text-lg leading-none">&times;</button>
      </div>
      <div class="p-5 space-y-4">
        <div>
          <label class="block text-xs font-medium mb-1.5 text-text-muted">Entity Name</label>
          <input id="modal-entity-name" type="text"
            class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <div class="flex items-center justify-between mb-2">
            <label class="text-xs font-medium text-text-muted">Fields</label>
            <button id="modal-add-field"
              class="text-xs px-2 py-1 bg-background border border-border rounded hover:border-primary transition-colors">
              + Add Field
            </button>
          </div>
          <div id="modal-fields" class="space-y-2 max-h-60 overflow-y-auto"></div>
        </div>
        <div class="flex gap-2 pt-2">
          <button id="modal-save"
            class="flex-1 px-4 py-2 bg-primary text-white rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors">
            Save
          </button>
          <button id="modal-delete"
            class="px-4 py-2 bg-red-500/10 border border-red-500/30 text-red-400 rounded-lg text-sm hover:bg-red-500/20 transition-colors">
            Delete
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- SQL output toast -->
  <div id="sql-toast" class="hidden fixed bottom-6 left-1/2 -translate-x-1/2 bg-green-600 text-white text-sm px-5 py-2.5 rounded-full shadow-lg z-50 transition-all">
    SQL copied to clipboard!
  </div>

  <ToolPageCta />
  <FaqSection faq={faq} />

</BaseLayout>

<script>
// =====================================================================
// ER Diagram Builder — vanilla JS, self-contained
// =====================================================================

// ---------- Types / State ----------
const FIELD_TYPES = ['INT','VARCHAR','TEXT','DATE','BOOLEAN','UUID','FLOAT','TIMESTAMP','BIGINT','JSON'];

let entities = [];   // { id, name, x, y, fields: [{id, name, type, pk, fk, required}] }
let relationships = []; // { id, fromId, toId, type, label }
let nextId = 1;

// Canvas drag state
let dragEntity = null;
let dragOffX = 0;
let dragOffY = 0;
let canvas, ctx;

// ---------- Init with example data ----------
function initExample() {
  entities = [
    {
      id: nextId++, name: 'User', x: 60, y: 80,
      fields: [
        { id: nextId++, name: 'id', type: 'UUID', pk: true, fk: false, required: true },
        { id: nextId++, name: 'username', type: 'VARCHAR', pk: false, fk: false, required: true },
        { id: nextId++, name: 'email', type: 'VARCHAR', pk: false, fk: false, required: true },
        { id: nextId++, name: 'created_at', type: 'TIMESTAMP', pk: false, fk: false, required: false }
      ]
    },
    {
      id: nextId++, name: 'Post', x: 320, y: 60,
      fields: [
        { id: nextId++, name: 'id', type: 'UUID', pk: true, fk: false, required: true },
        { id: nextId++, name: 'user_id', type: 'UUID', pk: false, fk: true, required: true },
        { id: nextId++, name: 'title', type: 'VARCHAR', pk: false, fk: false, required: true },
        { id: nextId++, name: 'body', type: 'TEXT', pk: false, fk: false, required: false },
        { id: nextId++, name: 'created_at', type: 'TIMESTAMP', pk: false, fk: false, required: false }
      ]
    },
    {
      id: nextId++, name: 'Comment', x: 580, y: 180,
      fields: [
        { id: nextId++, name: 'id', type: 'UUID', pk: true, fk: false, required: true },
        { id: nextId++, name: 'post_id', type: 'UUID', pk: false, fk: true, required: true },
        { id: nextId++, name: 'user_id', type: 'UUID', pk: false, fk: true, required: true },
        { id: nextId++, name: 'body', type: 'TEXT', pk: false, fk: false, required: true }
      ]
    }
  ];
  relationships = [
    { id: nextId++, fromId: entities[0].id, toId: entities[1].id, type: '1:N', label: 'writes' },
    { id: nextId++, fromId: entities[1].id, toId: entities[2].id, type: '1:N', label: 'has' }
  ];
}

// ---------- Canvas drawing ----------
const ENTITY_W = 190;
const HEADER_H = 34;
const ROW_H = 24;
const PADDING = 12;

function entityHeight(e) {
  return HEADER_H + e.fields.length * ROW_H + PADDING;
}

function isDark() {
  return document.documentElement.classList.contains('dark') ||
    window.matchMedia('(prefers-color-scheme: dark)').matches;
}

function getColors() {
  const dark = isDark();
  return {
    bg: dark ? '#1a1a2e' : '#f8fafc',
    entityBg: dark ? '#16213e' : '#ffffff',
    entityBorder: dark ? '#3b4a6b' : '#e2e8f0',
    headerBg: dark ? '#0f3460' : '#4f46e5',
    headerText: '#ffffff',
    fieldText: dark ? '#cbd5e1' : '#334155',
    pkColor: dark ? '#fbbf24' : '#d97706',
    fkColor: dark ? '#60a5fa' : '#3b82f6',
    mutedText: dark ? '#64748b' : '#94a3b8',
    lineColor: dark ? '#6366f1' : '#4f46e5',
    labelBg: dark ? '#1e293b' : '#f1f5f9',
    labelText: dark ? '#94a3b8' : '#475569',
  };
}

function drawCanvas() {
  if (!canvas) return;
  const dpr = window.devicePixelRatio || 1;
  const w = canvas.clientWidth;
  const h = canvas.clientHeight;
  canvas.width = w * dpr;
  canvas.height = h * dpr;
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

  const c = getColors();
  ctx.fillStyle = c.bg;
  ctx.fillRect(0, 0, w, h);

  // Draw dot grid
  ctx.fillStyle = isDark() ? 'rgba(100,116,139,0.15)' : 'rgba(100,116,139,0.2)';
  for (let gx = 20; gx < w; gx += 20) {
    for (let gy = 20; gy < h; gy += 20) {
      ctx.beginPath();
      ctx.arc(gx, gy, 0.8, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  // Draw relationships
  relationships.forEach(rel => {
    const from = entities.find(e => e.id === rel.fromId);
    const to = entities.find(e => e.id === rel.toId);
    if (!from || !to) return;
    drawRelationship(from, to, rel, c);
  });

  // Draw entities
  entities.forEach(e => drawEntity(e, c));
}

function entityCenterRight(e) {
  return { x: e.x + ENTITY_W, y: e.y + entityHeight(e) / 2 };
}
function entityCenterLeft(e) {
  return { x: e.x, y: e.y + entityHeight(e) / 2 };
}

function drawRelationship(from, to, rel, c) {
  const fromCx = from.x + ENTITY_W / 2;
  const fromCy = from.y + entityHeight(from) / 2;
  const toCx = to.x + ENTITY_W / 2;
  const toCy = to.y + entityHeight(to) / 2;

  // Pick attachment points (left or right edge)
  let startX, startY, endX, endY;
  if (fromCx < toCx) {
    startX = from.x + ENTITY_W; startY = fromCy;
    endX = to.x; endY = toCy;
  } else {
    startX = from.x; startY = fromCy;
    endX = to.x + ENTITY_W; endY = toCy;
  }

  const mx = (startX + endX) / 2;

  ctx.strokeStyle = c.lineColor;
  ctx.lineWidth = 1.5;
  ctx.setLineDash([]);
  ctx.beginPath();
  ctx.moveTo(startX, startY);
  ctx.bezierCurveTo(mx, startY, mx, endY, endX, endY);
  ctx.stroke();

  // "From" end marker — single tick
  drawSingleTick(startX, startY, startX < endX ? -1 : 1, c);

  // "To" end marker — based on type
  if (rel.type === '1:1') {
    drawSingleTick(endX, endY, endX < startX ? -1 : 1, c);
  } else if (rel.type === '1:N') {
    drawCrowFoot(endX, endY, endX < startX ? -1 : 1, c);
  } else {
    // M:N — crow's foot on both ends
    drawCrowFoot(endX, endY, endX < startX ? -1 : 1, c);
    drawCrowFoot(startX, startY, startX < endX ? -1 : 1, c);
  }

  // Label
  const labelX = mx;
  const labelY = (startY + endY) / 2 - 8;
  const labelText = (rel.label ? rel.label + ' ' : '') + rel.type;
  ctx.font = '10px ui-sans-serif, sans-serif';
  const tw = ctx.measureText(labelText).width;
  ctx.fillStyle = c.labelBg;
  ctx.beginPath();
  ctx.roundRect(labelX - tw / 2 - 4, labelY - 10, tw + 8, 16, 4);
  ctx.fill();
  ctx.fillStyle = c.labelText;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(labelText, labelX, labelY - 2);
}

function drawSingleTick(x, y, dir, c) {
  ctx.strokeStyle = c.lineColor;
  ctx.lineWidth = 1.5;
  const o = dir * 8;
  ctx.beginPath();
  ctx.moveTo(x + o, y - 6);
  ctx.lineTo(x + o, y + 6);
  ctx.stroke();
}

function drawCrowFoot(x, y, dir, c) {
  ctx.strokeStyle = c.lineColor;
  ctx.lineWidth = 1.5;
  const o = dir * 10;
  // Three prongs
  ctx.beginPath();
  ctx.moveTo(x, y);
  ctx.lineTo(x + o, y - 7);
  ctx.stroke();
  ctx.beginPath();
  ctx.moveTo(x, y);
  ctx.lineTo(x + o, y);
  ctx.stroke();
  ctx.beginPath();
  ctx.moveTo(x, y);
  ctx.lineTo(x + o, y + 7);
  ctx.stroke();
  // Cross tick
  ctx.beginPath();
  ctx.moveTo(x + o + dir * 4, y - 6);
  ctx.lineTo(x + o + dir * 4, y + 6);
  ctx.stroke();
}

function drawEntity(e, c) {
  const h = entityHeight(e);
  const r = 8;

  // Shadow
  ctx.shadowColor = isDark() ? 'rgba(0,0,0,0.5)' : 'rgba(0,0,0,0.12)';
  ctx.shadowBlur = 12;
  ctx.shadowOffsetY = 4;

  // Body
  ctx.fillStyle = c.entityBg;
  ctx.strokeStyle = c.entityBorder;
  ctx.lineWidth = 1.5;
  roundRect(ctx, e.x, e.y, ENTITY_W, h, r);
  ctx.fill();
  ctx.stroke();

  // Reset shadow
  ctx.shadowColor = 'transparent';
  ctx.shadowBlur = 0;
  ctx.shadowOffsetY = 0;

  // Header
  ctx.fillStyle = c.headerBg;
  roundRectTop(ctx, e.x, e.y, ENTITY_W, HEADER_H, r);
  ctx.fill();

  ctx.fillStyle = c.headerText;
  ctx.font = 'bold 12px ui-sans-serif, sans-serif';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(e.name, e.x + ENTITY_W / 2, e.y + HEADER_H / 2);

  // Divider
  ctx.strokeStyle = c.entityBorder;
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(e.x, e.y + HEADER_H);
  ctx.lineTo(e.x + ENTITY_W, e.y + HEADER_H);
  ctx.stroke();

  // Fields
  e.fields.forEach((f, i) => {
    const fy = e.y + HEADER_H + i * ROW_H + ROW_H / 2;

    // Badge for PK/FK
    if (f.pk) {
      ctx.font = 'bold 9px ui-sans-serif, sans-serif';
      ctx.fillStyle = c.pkColor;
      ctx.textAlign = 'left';
      ctx.fillText('PK', e.x + 7, fy);
    } else if (f.fk) {
      ctx.font = 'bold 9px ui-sans-serif, sans-serif';
      ctx.fillStyle = c.fkColor;
      ctx.textAlign = 'left';
      ctx.fillText('FK', e.x + 7, fy);
    }

    // Field name
    ctx.font = (f.required ? '500' : '400') + ' 11px ui-sans-serif, sans-serif';
    ctx.fillStyle = c.fieldText;
    ctx.textAlign = 'left';
    const nameX = (f.pk || f.fk) ? e.x + 26 : e.x + 8;
    ctx.fillText(f.name, nameX, fy);

    // Type (right aligned)
    ctx.font = '10px ui-mono, monospace';
    ctx.fillStyle = c.mutedText;
    ctx.textAlign = 'right';
    ctx.fillText(f.type, e.x + ENTITY_W - 8, fy);

    // Row divider
    if (i < e.fields.length - 1) {
      ctx.strokeStyle = isDark() ? 'rgba(255,255,255,0.04)' : 'rgba(0,0,0,0.05)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(e.x + 6, e.y + HEADER_H + (i + 1) * ROW_H);
      ctx.lineTo(e.x + ENTITY_W - 6, e.y + HEADER_H + (i + 1) * ROW_H);
      ctx.stroke();
    }
  });
}

function roundRect(c, x, y, w, h, r) {
  c.beginPath();
  c.moveTo(x + r, y);
  c.lineTo(x + w - r, y);
  c.arcTo(x + w, y, x + w, y + r, r);
  c.lineTo(x + w, y + h - r);
  c.arcTo(x + w, y + h, x + w - r, y + h, r);
  c.lineTo(x + r, y + h);
  c.arcTo(x, y + h, x, y + h - r, r);
  c.lineTo(x, y + r);
  c.arcTo(x, y, x + r, y, r);
  c.closePath();
}

function roundRectTop(c, x, y, w, h, r) {
  c.beginPath();
  c.moveTo(x + r, y);
  c.lineTo(x + w - r, y);
  c.arcTo(x + w, y, x + w, y + r, r);
  c.lineTo(x + w, y + h);
  c.lineTo(x, y + h);
  c.lineTo(x, y + r);
  c.arcTo(x, y, x + r, y, r);
  c.closePath();
}

// ---------- Hit testing ----------
function entityAtPoint(px, py) {
  for (let i = entities.length - 1; i >= 0; i--) {
    const e = entities[i];
    const h = entityHeight(e);
    if (px >= e.x && px <= e.x + ENTITY_W && py >= e.y && py <= e.y + h) {
      return e;
    }
  }
  return null;
}

// ---------- Canvas events ----------
function canvasCoords(evt) {
  const rect = canvas.getBoundingClientRect();
  const scaleX = canvas.clientWidth / canvas.clientWidth;
  return {
    x: evt.clientX - rect.left,
    y: evt.clientY - rect.top
  };
}

function onMouseDown(evt) {
  const { x, y } = canvasCoords(evt);
  const e = entityAtPoint(x, y);
  if (e) {
    dragEntity = e;
    dragOffX = x - e.x;
    dragOffY = y - e.y;
    canvas.style.cursor = 'grabbing';
  }
}

function onMouseMove(evt) {
  const { x, y } = canvasCoords(evt);
  if (dragEntity) {
    dragEntity.x = Math.max(0, x - dragOffX);
    dragEntity.y = Math.max(0, y - dragOffY);
    drawCanvas();
  } else {
    canvas.style.cursor = entityAtPoint(x, y) ? 'grab' : 'default';
  }
}

function onMouseUp(evt) {
  if (dragEntity) {
    canvas.style.cursor = 'grab';
    dragEntity = null;
  }
}

function onDblClick(evt) {
  const { x, y } = canvasCoords(evt);
  const e = entityAtPoint(x, y);
  if (e) openFieldModal(e);
}

// ---------- Entity list sidebar ----------
function refreshEntityList() {
  const list = document.getElementById('entity-list');
  if (!list) return;
  list.innerHTML = '';
  if (entities.length === 0) {
    list.innerHTML = '<p class="text-xs text-text-muted">No entities yet.</p>';
    return;
  }
  entities.forEach(e => {
    const div = document.createElement('div');
    div.className = 'flex items-center justify-between bg-background border border-border rounded-lg px-3 py-2 text-sm cursor-pointer hover:border-primary transition-colors';
    div.innerHTML = `<span class="font-medium">${e.name}</span><span class="text-xs text-text-muted">${e.fields.length} fields</span>`;
    div.addEventListener('click', () => openFieldModal(e));
    list.appendChild(div);
  });

  // Refresh relationship dropdowns
  ['rel-from', 'rel-to'].forEach(id => {
    const sel = document.getElementById(id);
    if (!sel) return;
    const current = sel.value;
    sel.innerHTML = `<option value="">${id === 'rel-from' ? 'From' : 'To'} entity…</option>`;
    entities.forEach(e => {
      const opt = document.createElement('option');
      opt.value = e.id;
      opt.textContent = e.name;
      if (String(e.id) === current) opt.selected = true;
      sel.appendChild(opt);
    });
  });
}

// ---------- Field Modal ----------
let modalEntityId = null;

function openFieldModal(entity) {
  modalEntityId = entity.id;
  const title = document.getElementById('modal-title');
  const nameInput = document.getElementById('modal-entity-name');
  const fieldsDiv = document.getElementById('modal-fields');
  if (!title || !nameInput || !fieldsDiv) return;
  title.textContent = 'Edit: ' + entity.name;
  nameInput.value = entity.name;
  renderModalFields(entity.fields);
  document.getElementById('field-modal')?.classList.remove('hidden');
}

function renderModalFields(fields) {
  const fieldsDiv = document.getElementById('modal-fields');
  if (!fieldsDiv) return;
  fieldsDiv.innerHTML = '';
  fields.forEach((f, idx) => {
    const row = document.createElement('div');
    row.className = 'flex items-center gap-2 bg-background border border-border rounded-lg px-2 py-1.5';
    row.dataset.fieldId = f.id;
    row.innerHTML = `
      <input type="text" value="${f.name}" placeholder="field_name" data-prop="name"
        class="flex-1 bg-transparent text-sm focus:outline-none min-w-0" />
      <select data-prop="type"
        class="bg-background border border-border rounded px-1.5 py-1 text-xs focus:outline-none focus:border-primary">
        ${FIELD_TYPES.map(t => `<option value="${t}" ${f.type === t ? 'selected' : ''}>${t}</option>`).join('')}
      </select>
      <label class="flex items-center gap-1 text-xs cursor-pointer" title="Primary Key">
        <input type="checkbox" data-prop="pk" ${f.pk ? 'checked' : ''} class="accent-yellow-400" />PK
      </label>
      <label class="flex items-center gap-1 text-xs cursor-pointer" title="Foreign Key">
        <input type="checkbox" data-prop="fk" ${f.fk ? 'checked' : ''} class="accent-blue-400" />FK
      </label>
      <label class="flex items-center gap-1 text-xs cursor-pointer" title="Required / NOT NULL">
        <input type="checkbox" data-prop="required" ${f.required ? 'checked' : ''} />NN
      </label>
      <button data-remove="${f.id}" class="text-red-400 hover:text-red-300 text-sm leading-none px-1">×</button>
    `;
    fieldsDiv.appendChild(row);
  });

  fieldsDiv.querySelectorAll('[data-remove]').forEach(btn => {
    btn.addEventListener('click', () => {
      const entity = entities.find(e => e.id === modalEntityId);
      if (!entity) return;
      const fid = parseInt(btn.dataset.remove);
      entity.fields = entity.fields.filter(f => f.id !== fid);
      renderModalFields(entity.fields);
    });
  });
}

function collectModalFields() {
  const fieldsDiv = document.getElementById('modal-fields');
  if (!fieldsDiv) return [];
  const rows = fieldsDiv.querySelectorAll('[data-field-id]');
  return Array.from(rows).map(row => {
    const fid = parseInt(row.dataset.fieldId);
    const entity = entities.find(e => e.id === modalEntityId);
    const existing = entity?.fields.find(f => f.id === fid) || {};
    return {
      id: fid,
      name: (row.querySelector('[data-prop="name"]')).value.trim() || 'field',
      type: (row.querySelector('[data-prop="type"]')).value,
      pk: (row.querySelector('[data-prop="pk"]')).checked,
      fk: (row.querySelector('[data-prop="fk"]')).checked,
      required: (row.querySelector('[data-prop="required"]')).checked,
    };
  });
}

// ---------- SQL Generator ----------
function generateSQL() {
  const lines = [];
  entities.forEach(e => {
    lines.push(`CREATE TABLE ${e.name.toLowerCase()} (`);
    const fieldLines = e.fields.map(f => {
      let def = `  ${f.name} ${f.type}`;
      if (f.pk) def += ' PRIMARY KEY';
      if (f.required && !f.pk) def += ' NOT NULL';
      return def;
    });
    // Add FK constraints
    e.fields.filter(f => f.fk).forEach(f => {
      // Guess referenced table from field name (e.g., user_id -> user)
      const refTable = f.name.replace(/_id$/, '');
      fieldLines.push(`  CONSTRAINT fk_${e.name.toLowerCase()}_${f.name} FOREIGN KEY (${f.name}) REFERENCES ${refTable}(id)`);
    });
    lines.push(fieldLines.join(',\n'));
    lines.push(');\n');
  });
  return lines.join('\n');
}

// ---------- Main init ----------
document.addEventListener('DOMContentLoaded', () => {
  canvas = document.getElementById('er-canvas');
  if (!canvas) return;
  ctx = canvas.getContext('2d');

  initExample();
  refreshEntityList();
  drawCanvas();

  // Resize observer
  new ResizeObserver(() => drawCanvas()).observe(canvas.parentElement);

  // Canvas mouse events
  canvas.addEventListener('mousedown', onMouseDown);
  canvas.addEventListener('mousemove', onMouseMove);
  canvas.addEventListener('mouseup', onMouseUp);
  canvas.addEventListener('mouseleave', onMouseUp);
  canvas.addEventListener('dblclick', onDblClick);

  // Touch support
  canvas.addEventListener('touchstart', e => {
    e.preventDefault();
    onMouseDown({ clientX: e.touches[0].clientX, clientY: e.touches[0].clientY });
  }, { passive: false });
  canvas.addEventListener('touchmove', e => {
    e.preventDefault();
    onMouseMove({ clientX: e.touches[0].clientX, clientY: e.touches[0].clientY });
  }, { passive: false });
  canvas.addEventListener('touchend', e => onMouseUp({}));

  // Add Entity
  document.getElementById('btn-add-entity')?.addEventListener('click', () => {
    const input = document.getElementById('entity-name-input');
    const name = input.value.trim();
    if (!name) return;
    const x = 60 + (entities.length % 3) * 220;
    const y = 80 + Math.floor(entities.length / 3) * 220;
    entities.push({
      id: nextId++, name, x, y,
      fields: [
        { id: nextId++, name: 'id', type: 'UUID', pk: true, fk: false, required: true }
      ]
    });
    input.value = '';
    refreshEntityList();
    drawCanvas();
  });

  // Add Relationship
  document.getElementById('btn-add-rel')?.addEventListener('click', () => {
    const fromId = parseInt((document.getElementById('rel-from')).value);
    const toId = parseInt((document.getElementById('rel-to')).value);
    const type = (document.getElementById('rel-type')).value;
    const label = (document.getElementById('rel-label')).value.trim();
    if (!fromId || !toId || fromId === toId) return;
    relationships.push({ id: nextId++, fromId, toId, type, label });
    (document.getElementById('rel-label')).value = '';
    drawCanvas();
  });

  // Export PNG
  document.getElementById('btn-export-png')?.addEventListener('click', () => {
    drawCanvas();
    const link = document.createElement('a');
    link.download = 'er-diagram.png';
    link.href = canvas.toDataURL('image/png');
    link.click();
  });

  // Copy SQL
  document.getElementById('btn-copy-sql')?.addEventListener('click', () => {
    const sql = generateSQL();
    navigator.clipboard.writeText(sql).then(() => {
      const toast = document.getElementById('sql-toast');
      toast?.classList.remove('hidden');
      setTimeout(() => toast?.classList.add('hidden'), 2500);
    });
  });

  // Reset
  document.getElementById('btn-reset')?.addEventListener('click', () => {
    if (!confirm('Reset diagram? All entities and relationships will be cleared.')) return;
    entities = [];
    relationships = [];
    nextId = 1;
    refreshEntityList();
    drawCanvas();
  });

  // Modal: add field
  document.getElementById('modal-add-field')?.addEventListener('click', () => {
    const entity = entities.find(e => e.id === modalEntityId);
    if (!entity) return;
    const currentFields = collectModalFields();
    entity.fields = currentFields;
    entity.fields.push({ id: nextId++, name: 'new_field', type: 'VARCHAR', pk: false, fk: false, required: false });
    renderModalFields(entity.fields);
  });

  // Modal: save
  document.getElementById('modal-save')?.addEventListener('click', () => {
    const entity = entities.find(e => e.id === modalEntityId);
    if (!entity) return;
    entity.name = (document.getElementById('modal-entity-name')).value.trim() || entity.name;
    entity.fields = collectModalFields();
    document.getElementById('field-modal')?.classList.add('hidden');
    refreshEntityList();
    drawCanvas();
  });

  // Modal: delete
  document.getElementById('modal-delete')?.addEventListener('click', () => {
    if (!confirm('Delete this entity?')) return;
    entities = entities.filter(e => e.id !== modalEntityId);
    relationships = relationships.filter(r => r.fromId !== modalEntityId && r.toId !== modalEntityId);
    document.getElementById('field-modal')?.classList.add('hidden');
    refreshEntityList();
    drawCanvas();
  });

  // Modal: close
  document.getElementById('modal-close')?.addEventListener('click', () => {
    document.getElementById('field-modal')?.classList.add('hidden');
  });

  document.getElementById('field-modal')?.addEventListener('click', (e) => {
    if (e.target === document.getElementById('field-modal')) {
      document.getElementById('field-modal')?.classList.add('hidden');
    }
  });

  // Redraw on color scheme change
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => drawCanvas());

  // Watch for dark class toggle
  new MutationObserver(() => drawCanvas()).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
});
</script>
