---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TemporalWorkflowDesigner from '../../components/TemporalWorkflowDesigner.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Temporal and how is a Workflow Designer different from a Scaffolder?",
    answer: "Temporal is a durable execution platform that automatically persists workflow state and retries failed steps. The Workflow Designer focuses on visually composing the step sequence — activities, timers, signals, conditions, parallel fan-outs, and child workflows — and generating the core workflow function code. It shows you the shape of your workflow at a glance before you write any logic."
  },
  {
    question: "What is the difference between Activities, Timers, and Signals?",
    answer: "Activities are the actual work units — calling external APIs, reading from databases, sending emails. They run outside the workflow sandbox and can be retried automatically on failure. Timers (step.sleep / workflow.Sleep) pause execution for a duration without consuming resources. Signals are external messages sent to a running workflow to change its state or unblock a waiting condition — ideal for human-in-the-loop approval flows or order cancellation."
  },
  {
    question: "When should I use parallel steps in Temporal?",
    answer: "Use parallel steps (Promise.all in TypeScript, asyncio.gather in Python) when multiple activities are independent and can run concurrently — for example, simultaneously sending an email, creating a Slack notification, and logging an audit record. Parallel fan-out dramatically reduces overall workflow duration when activities don't depend on each other's output."
  },
  {
    question: "What does retry configuration mean for Activities?",
    answer: "Temporal retries failed Activities automatically with exponential backoff. maximumAttempts sets the ceiling — if all attempts fail, the workflow receives an ApplicationError. The default retry policy retries indefinitely (unlimited attempts) with exponential backoff capped at 100 seconds. Set maximumAttempts to a specific number for non-idempotent operations where retrying would cause duplicate side effects (e.g. charging a credit card)."
  },
  {
    question: "What is a Child Workflow and when should I use one?",
    answer: "A Child Workflow is a full Temporal workflow started by a parent workflow. Use child workflows to decompose large workflows into reusable units, to apply different retry/timeout policies to a section of work, or when a sub-process needs its own observable timeline in the Temporal UI. Child workflows run independently and can outlive the parent if configured to. For simple activity grouping without independent observability, use activity sequences instead."
  },
  {
    question: "Does this tool send my workflow configuration to a server?",
    answer: "No. All code generation runs entirely in your browser using JavaScript. Your workflow names, activity names, and configuration never leave your machine."
  },
];
---

<BaseLayout
  title="Temporal Workflow Designer — Visual State Machine Builder"
  description="Design Temporal workflows visually. Add activities, timers, signals, conditions, and parallel steps. Generate TypeScript, Python, or Go workflow code instantly. Free, runs in your browser."
  tool="Temporal workflow designer, Temporal state machine builder, Temporal workflow generator, Temporal TypeScript Python Go, Temporal activity builder"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Temporal Workflow Designer",
    "url": "https://devplaybook.cc/tools/temporal-workflow-designer",
    "description": "Design Temporal workflows visually. Compose activities, timers, signals, conditions, and parallel fan-outs. Generate TypeScript, Python, or Go workflow code. Runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Temporal Workflow Designer</h1>
  <p class="text-text-muted mb-4">
    Visually compose <a href="https://temporal.io" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">Temporal</a> workflows step-by-step.
    Add activities, timers, signals, conditions, parallel fan-outs, and child workflows — then generate production-ready
    TypeScript, Python, or Go code. Runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript, Python, Go</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 6 step types</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Retry + timeout config</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Signals & queries</span>
  </div>
  <TemporalWorkflowDesigner client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Temporal Workflow Designer" relatedTags={['temporal', 'workflow', 'backend', 'microservices', 'typescript', 'go', 'python', 'distributed-systems']} />
</BaseLayout>
