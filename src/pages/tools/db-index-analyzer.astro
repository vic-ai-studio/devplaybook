---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DbIndexAnalyzer from '../../components/DbIndexAnalyzer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "How does the analyzer detect missing indexes?",
    answer: "The analyzer parses your CREATE TABLE statements to build a schema map (columns + existing indexes), then inspects each SELECT query's WHERE filters, JOIN ON conditions, and ORDER BY columns. Any column referenced in these clauses that has no matching single-column or composite index is flagged as missing."
  },
  {
    question: "What is a redundant index?",
    answer: "A redundant index is one whose columns are a leading prefix of another index. For example, if you have INDEX (status) and INDEX (status, created_at), the first index is redundant — any query that could use INDEX (status) alone can also use the composite index. Redundant indexes waste disk space and slow down INSERT/UPDATE/DELETE without providing any query benefit."
  },
  {
    question: "When should I use a composite index vs multiple single-column indexes?",
    answer: "Use a composite index when your queries consistently filter on multiple columns from the same table together. The database can use a composite index (a, b) for queries filtering on 'a' alone, 'a AND b', or 'a' with ORDER BY b — but not for 'b' alone. Put equality columns first, then range/sort columns. Multiple single-column indexes are better when columns are used independently in different queries."
  },
  {
    question: "Why is indexing foreign keys important?",
    answer: "Without an index on the foreign key column, JOIN operations cause a full table scan of the joined table for each row in the driving table. With an index, each join lookup is O(log n) instead of O(n). For tables with thousands of rows, this is the single most common cause of slow JOIN queries."
  },
  {
    question: "Does this tool send my schema to a server?",
    answer: "No. All analysis runs entirely in your browser using JavaScript. Your schema and query text never leave your machine."
  },
  {
    question: "What SQL dialects are supported?",
    answer: "The analyzer supports standard SQL syntax compatible with MySQL, PostgreSQL, and SQLite. It handles CREATE TABLE with INDEX/KEY definitions inline, PRIMARY KEY constraints, and standard SELECT with WHERE, JOIN ON, and ORDER BY clauses. PostgreSQL-style SERIAL/BIGSERIAL columns and MySQL-style backtick quoting are both handled."
  },
];
---

<BaseLayout
  title="Database Index Analyzer — Find Missing & Redundant Indexes"
  description="Paste SQL CREATE TABLE + SELECT queries to find missing indexes, redundant indexes, and generate CREATE INDEX statements. Analyzes WHERE filters, JOINs, and ORDER BY. Free, runs in your browser."
  tool="Database Index Analyzer, SQL index checker, missing index detector, redundant index finder, CREATE INDEX generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Database Index Analyzer",
    "url": "https://devplaybook.cc/tools/db-index-analyzer",
    "description": "Paste SQL schema and queries to detect missing indexes, redundant indexes, and generate ready-to-run CREATE INDEX statements. Supports MySQL, PostgreSQL, SQLite.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Database Index Analyzer</h1>
  <p class="text-text-muted mb-4">
    Paste your <code class="font-mono bg-surface px-1 rounded text-sm">CREATE TABLE</code> schema and
    <code class="font-mono bg-surface px-1 rounded text-sm">SELECT</code> queries to find missing and redundant indexes.
    Get ready-to-run <code class="font-mono bg-surface px-1 rounded text-sm">CREATE INDEX</code> statements.
    Runs entirely in your browser — nothing is sent to a server.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Detects missing WHERE / JOIN / ORDER BY indexes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Flags redundant indexes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Generates CREATE INDEX SQL</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> MySQL, PostgreSQL, SQLite compatible</span>
  </div>
  <DbIndexAnalyzer client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Database Index Analyzer" relatedTags={['database', 'sql', 'performance', 'postgresql', 'mysql', 'indexing', 'query-optimization']} />
</BaseLayout>
