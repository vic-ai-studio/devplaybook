---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonSchemaGenerator from '../../components/JsonSchemaGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is JSON Schema and why do I need it?", answer: "JSON Schema is a standard for describing the structure and validation rules of JSON data. It defines required fields, data types, string formats, and value constraints. Use it for API request/response validation, form validation, configuration file checks, and code generation." },
  { question: "What is the difference between Draft-07 and 2020-12?", answer: "Draft-07 is the most widely supported version — compatible with most validators and tools. 2020-12 is the latest standard with new features like $dynamicRef, prefixItems for tuples, and improved vocabulary support. Use Draft-07 for maximum compatibility; use 2020-12 for new projects." },
  { question: "What string formats does the tool detect?", answer: "The tool automatically detects date-time (ISO 8601), date, email, uri, uuid, and IPv4/IPv6 formats from your sample data. Format annotations help validators enforce stricter checks beyond just 'string' type." },
  { question: "How does it handle arrays with different element types?", answer: "If all array elements share the same structure, the tool generates a single items schema. If elements are mixed types, it generates a oneOf or anyOf union schema. Empty arrays default to an open items schema." },
  { question: "Can I use the generated schema with AJV or Zod?", answer: "Yes. The generated JSON Schema works with AJV (the fastest JSON Schema validator for JavaScript), Python's jsonschema library, and can be converted to Zod schemas using tools like json-schema-to-zod. It follows the official JSON Schema specification." },
];
---

<BaseLayout
  title="JSON Schema Generator — Auto-generate from JSON"
  description="Generate JSON Schema from sample JSON. Supports Draft-07 and 2020-12, detects email/uri/uuid formats, integer vs number. Free, runs in your browser — no data sent to servers."
  tool="JSON Schema Generator, JSON to Schema, JSON Schema Draft-07, JSON Schema 2020-12"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">JSON Schema Generator</h1>
  <p class="text-text-muted mb-4">
    Paste a JSON sample and get a valid JSON Schema instantly. Supports <strong>Draft-07</strong> and <strong>2020-12</strong>.
    Automatically detects string formats (<code class="text-accent">date-time</code>, <code class="text-accent">email</code>, <code class="text-accent">uri</code>, <code class="text-accent">uuid</code>, <code class="text-accent">date</code>),
    distinguishes <code class="text-accent">integer</code> from <code class="text-accent">number</code>, and handles nested objects and arrays.
    Everything runs in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <JsonSchemaGenerator client:load />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="JSON Schema Generator" relatedTags={['json', 'schema', 'validation', 'api', 'typescript']} />
</BaseLayout>
