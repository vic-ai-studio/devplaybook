---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonSchemaGenerator from '../../components/JsonSchemaGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="JSON Schema Generator — Auto-generate from JSON"
  description="Paste any JSON and instantly generate a JSON Schema. Supports Draft-07 and 2020-12. Auto-detects string formats (date-time, email, uri, uuid), distinguishes integer vs number, and marks all fields as required. Free, runs in your browser."
  tool="JSON Schema Generator, JSON to Schema, JSON Schema Draft-07, JSON Schema 2020-12"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "JSON Schema Generator",
    "url": "https://devplaybook.cc/tools/json-schema-generator",
    "description": "Auto-generate JSON Schema from a JSON sample. Supports Draft-07 and 2020-12. Detects formats like date-time, email, uri, and uuid.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">JSON Schema Generator</h1>
  <p class="text-text-muted mb-8">
    Paste a JSON sample and get a valid JSON Schema instantly. Supports <strong>Draft-07</strong> and <strong>2020-12</strong>.
    Automatically detects string formats (<code class="text-accent">date-time</code>, <code class="text-accent">email</code>, <code class="text-accent">uri</code>, <code class="text-accent">uuid</code>, <code class="text-accent">date</code>),
    distinguishes <code class="text-accent">integer</code> from <code class="text-accent">number</code>, and handles nested objects and arrays.
    Everything runs in your browser.
  </p>
  <JsonSchemaGenerator client:load />
  <ToolPageCta currentTool="JSON Schema Generator" relatedTags={['json', 'schema', 'validation', 'api', 'typescript']} />
</BaseLayout>
