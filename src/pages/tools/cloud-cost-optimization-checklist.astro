---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What are the biggest quick wins for reducing cloud costs?", answer: "The highest-ROI actions in order: (1) Delete idle resources — snapshots, unattached EBS volumes, stopped EC2 instances, unused Elastic IPs cost money with zero value. Run a monthly cleanup script. (2) Right-size compute — most EC2/GCE instances run at 10-30% average CPU. Downsize to the next smaller instance type and save 30-50% immediately. (3) Purchase Savings Plans or Committed Use Discounts — for any workload running more than 60% of the month, 1-year no-upfront saves 30-40%. (4) Move cold data to cheaper storage tiers — S3 Intelligent-Tiering or Glacier for data not accessed in 90+ days. These four alone typically cut bills by 30-50%." },
  { question: "How do I find idle and zombie resources automatically?", answer: "Use cloud-native tools: AWS Trusted Advisor (idle EC2, underutilized RDS, unassociated EIPs), AWS Compute Optimizer (rightsizing recommendations), and AWS Cost Explorer's rightsizing recommendations. For GCP, use the Recommender API (gcloud recommender recommendations list). For Azure, use Advisor. Automate cleanup: use AWS Instance Scheduler to stop dev/test instances on weekends. Use Lambda triggered by CloudWatch to terminate instances with the tag AutoShutdown=true after business hours. A monthly cron job that finds and reports unattached volumes and old snapshots saves significant money passively." },
  { question: "What's the difference between rightsizing and Spot/Preemptible instances?", answer: "Rightsizing means choosing the correct instance size for your workload — matching CPU and memory to actual usage patterns. It applies to all workloads. Spot/Preemptible instances are surplus cloud capacity sold at 60-90% discount, but can be reclaimed with 2-minute notice (AWS) or 30-second notice (GCP). Use rightsizing for all production workloads first. Use Spot for stateless, fault-tolerant, or batch workloads — CI/CD runners, machine learning training, data processing, rendering. Mixing Spot (60%) with On-Demand (40%) in an Auto Scaling Group gives most of the savings with resilience." },
  { question: "How should I structure a monthly cloud cost review?", answer: "A monthly cost review should take 30-60 minutes and follow this structure: (1) Check total spend vs prior month and vs budget — is growth justified? (2) Review top 5 services by cost — any unexpected spikes? (3) Check Cost Anomaly Detection or equivalent alerts. (4) Run rightsizing recommendations and pick 3-5 to action immediately. (5) Review Savings Plan / Reserved Instance utilization — under 80% means you over-committed. (6) Check the waste items checklist: unattached volumes, old snapshots, idle load balancers, underused NAT gateways. (7) Update forecast for next month. Track these metrics in a shared spreadsheet or Grafana dashboard over time." },
];
---

<BaseLayout
  title="Cloud Cost Optimization Checklist — AWS, GCP, Azure Quick Wins"
  description="Multi-cloud cost optimization checklist covering idle resources, rightsizing, reserved instances, Spot, and storage tiers. Monthly review process for AWS, GCP, and Azure."
  tool="cloud cost optimization, AWS cost reduction, GCP cost savings, Azure cost management, rightsizing, Spot instances, FinOps checklist"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Cloud Cost Optimization Checklist",
    "url": "https://devplaybook.cc/tools/cloud-cost-optimization-checklist",
    "description": "Complete multi-cloud cost optimization checklist with quick wins, monthly review process, and automated cleanup scripts.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Cloud Cost Optimization Checklist</h1>
  <p class="text-text-muted mb-6">
    A practical <strong>multi-cloud cost reduction checklist</strong> covering idle resource cleanup, compute rightsizing, commitment discounts, and storage tier optimization for AWS, GCP, and Azure.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> AWS / GCP / Azure</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Idle resource cleanup</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Rightsizing scripts</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Monthly review process</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Quick Wins Checklist</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 font-semibold">Action</th>
          <th class="text-left py-2 pr-4 font-semibold">Typical Savings</th>
          <th class="text-left py-2 pr-4 font-semibold">Effort</th>
          <th class="text-left py-2 font-semibold">AWS / GCP / Azure</th>
        </tr>
      </thead>
      <tbody class="text-text-muted">
        <tr class="border-b border-border"><td class="py-2 pr-4">Delete unattached EBS/PD volumes</td><td class="py-2 pr-4">$5–200/month</td><td class="py-2 pr-4">Low</td><td class="py-2">All</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Remove old snapshots (&gt;90 days)</td><td class="py-2 pr-4">$10–500/month</td><td class="py-2 pr-4">Low</td><td class="py-2">All</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Release unassociated Elastic IPs</td><td class="py-2 pr-4">$3.65/IP/month</td><td class="py-2 pr-4">Low</td><td class="py-2">AWS</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Downsize over-provisioned instances</td><td class="py-2 pr-4">30–50% compute</td><td class="py-2 pr-4">Medium</td><td class="py-2">All</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Stop dev/test on nights &amp; weekends</td><td class="py-2 pr-4">60–70% dev cost</td><td class="py-2 pr-4">Low</td><td class="py-2">All</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Purchase 1-yr Savings Plan / CUD</td><td class="py-2 pr-4">30–40% compute</td><td class="py-2 pr-4">Low</td><td class="py-2">AWS / GCP</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Move cold S3/GCS to archive tier</td><td class="py-2 pr-4">70–90% storage</td><td class="py-2 pr-4">Low</td><td class="py-2">All</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Delete unused load balancers</td><td class="py-2 pr-4">$16–200/month</td><td class="py-2 pr-4">Low</td><td class="py-2">All</td></tr>
        <tr class="border-b border-border"><td class="py-2 pr-4">Use Spot/Preemptible for CI runners</td><td class="py-2 pr-4">60–80% CI cost</td><td class="py-2 pr-4">Medium</td><td class="py-2">All</td></tr>
        <tr><td class="py-2 pr-4">Enable S3 Intelligent-Tiering</td><td class="py-2 pr-4">20–40% S3 cost</td><td class="py-2 pr-4">Low</td><td class="py-2">AWS</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">AWS — Find Idle Resources</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Find unattached EBS volumes
aws ec2 describe-volumes \
  --filters Name=status,Values=available \
  --query 'Volumes[*].&#123;ID:VolumeId,Size:Size,Region:AvailabilityZone&#125;' \
  --output table

# Find snapshots older than 90 days (your account only)
aws ec2 describe-snapshots \
  --owner-ids self \
  --query "Snapshots[?StartTime&lt;='2025-12-01'].&#123;ID:SnapshotId,Size:VolumeSize,Date:StartTime&#125;" \
  --output table

# Find stopped instances
aws ec2 describe-instances \
  --filters Name=instance-state-name,Values=stopped \
  --query 'Reservations[*].Instances[*].&#123;ID:InstanceId,Type:InstanceType,Name:Tags[?Key==`Name`]|[0].Value&#125;' \
  --output table

# Find unassociated Elastic IPs
aws ec2 describe-addresses \
  --query 'Addresses[?AssociationId==null].&#123;IP:PublicIp,AllocationId:AllocationId&#125;' \
  --output table</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">GCP — Find Idle Resources</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># List unattached persistent disks
gcloud compute disks list --filter="NOT users:*" \
  --format="table(name, sizeGb, zone, status)"

# List unused static external IPs
gcloud compute addresses list --filter="status=RESERVED" \
  --format="table(name, address, region, status)"

# Get rightsizing recommendations
gcloud recommender recommendations list \
  --recommender=google.compute.instance.MachineTypeRecommender \
  --location=us-central1 \
  --format="table(name, description, primaryImpact.costProjection.cost)"

# Find stopped instances
gcloud compute instances list --filter="status=TERMINATED" \
  --format="table(name, machineType, zone)"</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Storage Tier Migration</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># AWS S3 — Enable Intelligent-Tiering on a bucket
aws s3api put-bucket-intelligent-tiering-configuration \
  --bucket my-data-bucket \
  --id archive-config \
  --intelligent-tiering-configuration '&#123;
    "Id": "archive-config",
    "Status": "Enabled",
    "Tierings": [
      &#123;"Days": 90, "AccessTier": "ARCHIVE_ACCESS"&#125;,
      &#123;"Days": 180, "AccessTier": "DEEP_ARCHIVE_ACCESS"&#125;
    ]
  &#125;'

# Create S3 lifecycle policy for old objects
aws s3api put-bucket-lifecycle-configuration \
  --bucket my-logs-bucket \
  --lifecycle-configuration '&#123;
    "Rules": [&#123;
      "ID": "move-to-glacier",
      "Status": "Enabled",
      "Filter": &#123;"Prefix": "logs/"&#125;,
      "Transitions": [
        &#123;"Days": 30, "StorageClass": "STANDARD_IA"&#125;,
        &#123;"Days": 90, "StorageClass": "GLACIER"&#125;
      ],
      "Expiration": &#123;"Days": 365&#125;
    &#125;]
  &#125;'</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Monthly Review Process</h2>
  <ul class="list-disc pl-6 text-text-muted space-y-1 mb-6">
    <li><strong>Week 1:</strong> Pull cost report by service — flag &gt;10% MoM increases</li>
    <li><strong>Week 1:</strong> Review anomaly alerts from prior 30 days</li>
    <li><strong>Week 2:</strong> Run rightsizing recommendations — action top 5</li>
    <li><strong>Week 2:</strong> Execute idle resource cleanup script</li>
    <li><strong>Week 3:</strong> Review Savings Plan / CUD utilization rate</li>
    <li><strong>Week 3:</strong> Check storage tier distribution — move cold data</li>
    <li><strong>Week 4:</strong> Update cost forecast for next month</li>
    <li><strong>Week 4:</strong> Review cost by team/project tag — share with leads</li>
  </ul>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="cloud-cost-optimization-checklist" relatedTags={["cloud", "aws", "gcp", "azure", "cost-optimization", "finops", "devops"]} />
</BaseLayout>
