---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SslCertificateDecoder from '../../components/SslCertificateDecoder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a PEM certificate and how do I get one?",
    answer: "PEM (Privacy Enhanced Mail) is a base64-encoded format for X.509 certificates, wrapped between -----BEGIN CERTIFICATE----- and -----END CERTIFICATE----- markers. You can get a certificate's PEM from your server (nginx: ssl_certificate path; Apache: SSLCertificateFile path), from openssl: 'openssl s_client -connect example.com:443 -showcerts </dev/null 2>/dev/null | openssl x509 -outform PEM', from your CA's dashboard, or from certificate files with .pem, .crt, or .cer extensions. If you have a .pfx/.p12 file, convert with: openssl pkcs12 -in cert.pfx -clcerts -nokeys -out cert.pem"
  },
  {
    question: "What are Subject Alternative Names (SANs) and why do they matter?",
    answer: "SANs (Subject Alternative Names) are the authoritative list of hostnames, IP addresses, or email addresses that an SSL/TLS certificate is valid for. Modern browsers and clients use SANs exclusively — the CN (Common Name) in the subject is ignored for host validation. A certificate for example.com with SANs [example.com, www.example.com] is valid for both. Wildcard SANs like *.example.com cover one level of subdomain. If your domain is not listed in the SANs, browsers will show a security warning."
  },
  {
    question: "How does this tool decode certificates without sending them to a server?",
    answer: "The tool implements a pure JavaScript DER (Distinguished Encoding Rules) parser — the binary format that X.509 certificates use internally. After stripping the PEM headers and base64-decoding, it parses the ASN.1 structure to extract fields like subject DN, issuer DN, validity dates, serial number, SANs, and key usage. The SHA-256 fingerprint is computed using the browser's built-in Web Crypto API (crypto.subtle.digest). No network requests are made — everything runs locally in your browser."
  },
  {
    question: "What does it mean when a certificate shows 'Is CA: Yes'?",
    answer: "A CA (Certificate Authority) certificate is used to sign other certificates, not to identify a website or service. CA certificates have the basicConstraints extension with cA=TRUE and typically have the keyCertSign key usage bit set. Root CA certificates are self-signed (subject equals issuer) and stored in browser/OS trust stores. Intermediate CA certificates chain from a Root CA and sign end-entity (leaf) certificates. If your server certificate shows 'Is CA: Yes', something is misconfigured — you should be presenting the leaf certificate, not an intermediate or root CA."
  },
];
---

<BaseLayout
  title="SSL Certificate Decoder — Inspect TLS/SSL Certificate Details from PEM"
  description="Decode and inspect SSL/TLS certificates from PEM format. View subject, issuer, SAN domains, expiry date, key usage, and SHA-256 fingerprint. Runs entirely in your browser, no uploads."
  tool="ssl certificate decoder, tls certificate inspector, pem certificate parser, ssl certificate checker, x509 certificate viewer"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "SSL Certificate Decoder",
    "url": "https://devplaybook.cc/tools/ssl-certificate-decoder",
    "description": "Decode and inspect SSL/TLS certificates from PEM format. View subject, issuer, SAN domains, expiry date, key usage, and SHA-256 fingerprint. Runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">SSL Certificate Decoder</h1>
  <p class="text-text-muted mb-4">
    Paste a <strong>PEM-format SSL/TLS certificate</strong> to decode and inspect all fields — subject, issuer, SANs, validity dates, key usage, and SHA-256 fingerprint. Expiry is color-coded. Runs entirely in your browser — no data is uploaded.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Subject, Issuer, SANs</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Expiry with color coding</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> SHA-256 fingerprint</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100% client-side, no uploads</span>
  </div>
  <SslCertificateDecoder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SSL Certificate Decoder" relatedTags={['ssl', 'tls', 'security', 'certificates', 'developer-tools']} />
</BaseLayout>
