---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CrontabGenerator from '../../components/CrontabGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a cron expression?", answer: "A cron expression is a string of 5 fields (minute, hour, day, month, weekday) that defines a recurring schedule. For example, '0 9 * * 1-5' means 'at 09:00, Monday through Friday'. Cron is used in Unix-like systems, GitHub Actions, AWS Lambda, and many CI/CD pipelines to schedule tasks." },
  { question: "What does * mean in a cron expression?", answer: "An asterisk (*) means 'every valid value'. In the minute field, * means every minute. In the hour field, * means every hour. For example, '* * * * *' runs every minute, and '0 * * * *' runs at minute 0 of every hour (i.e., every hour on the hour)." },
  { question: "How do I run a job every 15 minutes?", answer: "Use the step syntax: '*/15 * * * *'. The */ syntax means 'every N', so */15 in the minute field means every 15 minutes starting from 0 (0, 15, 30, 45). Similarly, */5 means every 5 minutes and */2 means every 2 hours when in the hour field." },
  { question: "What is the difference between day-of-month and day-of-week?", answer: "Day-of-month (field 3) specifies a calendar date (1–31). Day-of-week (field 5) specifies a weekday (0=Sunday through 6=Saturday). When both are set (not *), most cron implementations run the job when EITHER condition is true, not both — this is a common source of confusion." },
  { question: "How do I run a cron job at multiple specific times?", answer: "Use commas to list multiple values. '0 8,12,18 * * *' runs at 08:00, 12:00, and 18:00 every day. You can also combine ranges and lists: '0 9 * * 1,3,5' runs at 09:00 on Monday, Wednesday, and Friday." },
];
---

<BaseLayout
  title="Crontab Generator — Free Cron Expression Builder"
  description="Free visual cron expression builder with human-readable descriptions and next-run preview. Build crontab schedules for Linux, GitHub Actions, AWS EventBridge, and more. No sign-up required — runs 100% in your browser."
  tool="Crontab Generator, Cron Expression Builder, Cron Schedule Builder, Crontab Syntax, Cron Job Scheduler, Linux Cron, GitHub Actions Schedule, AWS EventBridge Cron"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Crontab Generator</h1>
  <p class="text-text-muted mb-4">Build cron expressions visually. Set minute, hour, day, month, and weekday fields or use presets. Get a human-readable description and preview the next 5 scheduled runs — all in your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Human-readable output</span>
  </div>
  <CrontabGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Crontab Generator" relatedTags={['scheduling', 'devops', 'automation', 'linux', 'ci-cd']} />
</BaseLayout>
