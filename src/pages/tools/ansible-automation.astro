---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What makes Ansible 'agentless' and why does it matter?", answer: "Ansible connects to managed nodes over SSH (Linux) or WinRM (Windows) without requiring any software to be pre-installed on those hosts. It copies small Python scripts to the remote node, executes them, then removes them. This agentless architecture dramatically simplifies adoption — you don't need to bootstrap an agent on every server before you can manage it. It also reduces the attack surface and eliminates the need to maintain and update agents across your fleet. The only requirement is Python on the managed node and SSH access from the control node." },
  { question: "What is the difference between a task, role, and playbook in Ansible?", answer: "A task is a single unit of work — one call to an Ansible module (e.g., install a package, copy a file, restart a service). A playbook is a YAML file that defines a sequence of plays; each play targets a group of hosts and runs a list of tasks against them. A role is a reusable, self-contained unit that packages tasks, variables, handlers, templates, and files into a structured directory layout. Roles enable code reuse across playbooks and projects, similar to a library or module in programming." },
  { question: "What are Ansible handlers and when should I use them?", answer: "Handlers are special tasks that run only when notified by another task that reports 'changed'. They execute once at the end of a play, regardless of how many tasks notified them. The canonical use case is restarting a service after its configuration file changes: the task that copies the config file notifies the 'restart nginx' handler. Without handlers you'd either always restart the service (wasteful) or write complex conditional logic. Handlers run in the order they are defined, not the order they are notified." },
  { question: "How do I manage secrets in Ansible?", answer: "Use Ansible Vault to encrypt sensitive data at rest. ansible-vault encrypt_string encrypts an individual string for use inline in a vars file. ansible-vault encrypt secrets.yml encrypts an entire file. Encrypted values are decrypted at runtime using a vault password (provided via --vault-password-file, ANSIBLE_VAULT_PASSWORD_FILE env var, or prompted interactively). For production, integrate Vault passwords with a secrets manager (HashiCorp Vault, AWS Secrets Manager) using a custom vault password script rather than storing the vault password on disk." },
  { question: "What is Ansible Galaxy and how do I use community roles?", answer: "Ansible Galaxy is the official hub for sharing Ansible roles and collections. A collection bundles related roles, modules, plugins, and documentation into a single package. Install a role or collection with ansible-galaxy install geerlingguy.nginx or ansible-galaxy collection install community.docker. Define project dependencies in requirements.yml and install them all with ansible-galaxy install -r requirements.yml. This lets you leverage community-maintained roles for common tasks (LAMP stack, Docker, Kubernetes) rather than writing everything from scratch." },
  { question: "What is the difference between AWX and Ansible Tower?", answer: "AWX is the open-source, community-supported upstream project for Red Hat Ansible Automation Platform (formerly Ansible Tower). AWX provides a web UI, REST API, role-based access control (RBAC), job scheduling, credential management, and inventory management on top of Ansible. Tower is the supported, enterprise-licensed version with SLA and Red Hat integration. For teams without an enterprise license, AWX deployed on Kubernetes via its operator is the recommended path." },
];
---

<BaseLayout
  title="Ansible Automation Guide — Agentless Configuration Management & IT Automation"
  description="Complete Ansible guide: playbooks, roles, inventory, handlers, Vault secrets, Galaxy collections, and AWX. Includes YAML examples and comparison with Chef, Puppet, and SaltStack."
  tool="Ansible, configuration management, Ansible playbook, Ansible roles, Ansible vs Chef, IT automation, agentless"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Ansible Automation Guide — Agentless Configuration Management & IT Automation",
    "url": "https://devplaybook.cc/tools/ansible-automation",
    "description": "Complete Ansible guide: playbooks, roles, inventory, handlers, Vault secrets, Galaxy collections, and AWX. Includes YAML examples and comparison with Chef, Puppet, and SaltStack.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Ansible Automation Guide</h1>
  <p class="text-text-muted mb-6">
    Automate configuration management, application deployment, and IT orchestration with <strong>Ansible</strong> —
    agentless, YAML-based, and works over plain SSH with no agents required.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Agentless (SSH / WinRM)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Idempotent playbooks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Ansible Vault secrets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Galaxy collections</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Ansible?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Ansible is an open-source IT automation tool created in 2012 and maintained by Red Hat. It automates configuration management, application deployment, cloud provisioning, and orchestration across Linux, Windows, network devices, and cloud platforms. Unlike agent-based tools, Ansible requires no software on managed nodes — it connects over SSH, pushes small Python modules, executes them, and cleans up. Everything is described in human-readable YAML files called playbooks.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    Ansible's simplicity is its greatest strength. A sysadmin who knows SSH and YAML can write their first working playbook within minutes. Ansible is idempotent by design — running a playbook multiple times produces the same result, making it safe to apply repeatedly. It is used by organizations from single-server projects to global enterprises managing hundreds of thousands of nodes with Ansible Automation Platform (AWX/Tower).
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Agentless architecture</strong> — SSH and Python only, no agent to install or maintain on managed nodes</li>
    <li><strong>YAML playbooks</strong> — human-readable, version-controlled, self-documenting automation code</li>
    <li><strong>Roles</strong> — reusable, shareable task collections with standard directory layout (tasks/, handlers/, templates/, vars/)</li>
    <li><strong>Dynamic inventory</strong> — pull host lists from AWS EC2, GCP, Azure, or any API at runtime</li>
    <li><strong>Handlers</strong> — event-driven tasks that fire once at end of play when notified by changed tasks</li>
    <li><strong>Ansible Vault</strong> — encrypt secrets at rest, decrypt transparently at runtime</li>
    <li><strong>Jinja2 templates</strong> — dynamically generate config files with variables and filters</li>
    <li><strong>AWX / Automation Platform</strong> — web UI, RBAC, scheduling, and REST API on top of Ansible core</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Inventory File</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># inventory/hosts.ini
[web]
web1.example.com ansible_user=ubuntu
web2.example.com ansible_user=ubuntu

[db]
db1.example.com ansible_user=postgres ansible_port=2222

[production:children]
web
db

[production:vars]
ansible_ssh_private_key_file=~/.ssh/prod_key
env=production</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Example Playbook</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># site.yml
- name: Configure web servers
  hosts: web
  become: true
  vars:
    nginx_port: 80
    app_user: www-data

  pre_tasks:
    - name: Update apt cache
      ansible.builtin.apt:
        update_cache: true
        cache_valid_time: 3600

  tasks:
    - name: Install nginx
      ansible.builtin.apt:
        name: nginx
        state: present

    - name: Deploy nginx configuration
      ansible.builtin.template:
        src: templates/nginx.conf.j2
        dest: /etc/nginx/nginx.conf
        owner: root
        group: root
        mode: '0644'
      notify: Restart nginx

    - name: Ensure nginx is enabled and started
      ansible.builtin.systemd:
        name: nginx
        state: started
        enabled: true

    - name: Deploy application code
      ansible.builtin.git:
        repo: https://github.com/example/app.git
        dest: /var/www/app
        version: "{{ app_version | default('main') }}"
      notify: Restart app service

  handlers:
    - name: Restart nginx
      ansible.builtin.systemd:
        name: nginx
        state: restarted

    - name: Restart app service
      ansible.builtin.systemd:
        name: myapp
        state: restarted</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Jinja2 Template Example</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4">{# templates/nginx.conf.j2 #}
worker_processes {{ ansible_processor_vcpus }};

events {
    worker_connections 1024;
}

http {
    server {
        listen {{ nginx_port }};
        server_name {{ inventory_hostname }};
        root /var/www/{{ app_name | default('app') }};

        {% if ssl_enabled | default(false) %}
        listen 443 ssl;
        ssl_certificate /etc/ssl/certs/{{ inventory_hostname }}.crt;
        ssl_certificate_key /etc/ssl/private/{{ inventory_hostname }}.key;
        {% endif %}

        location / {
            proxy_pass http://127.0.0.1:{{ app_port | default(3000) }};
            proxy_set_header Host $host;
        }
    }
}</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Ansible vs Configuration Management Alternatives</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse mb-6">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">Ansible</th>
          <th class="border border-border px-3 py-2 text-left">Chef</th>
          <th class="border border-border px-3 py-2 text-left">Puppet</th>
          <th class="border border-border px-3 py-2 text-left">SaltStack</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="border border-border px-3 py-2">Architecture</td>
          <td class="border border-border px-3 py-2">Agentless (SSH)</td>
          <td class="border border-border px-3 py-2">Agent (Chef Client)</td>
          <td class="border border-border px-3 py-2">Agent (Puppet Agent)</td>
          <td class="border border-border px-3 py-2">Agent (Minion) or agentless</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Language</td>
          <td class="border border-border px-3 py-2">YAML</td>
          <td class="border border-border px-3 py-2">Ruby (DSL)</td>
          <td class="border border-border px-3 py-2">Puppet DSL / Ruby</td>
          <td class="border border-border px-3 py-2">YAML / Python</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">Learning curve</td>
          <td class="border border-border px-3 py-2">Low</td>
          <td class="border border-border px-3 py-2">High</td>
          <td class="border border-border px-3 py-2">Medium-High</td>
          <td class="border border-border px-3 py-2">Medium</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Push vs Pull</td>
          <td class="border border-border px-3 py-2">Push</td>
          <td class="border border-border px-3 py-2">Pull</td>
          <td class="border border-border px-3 py-2">Pull</td>
          <td class="border border-border px-3 py-2">Push or Pull</td>
        </tr>
        <tr>
          <td class="border border-border px-3 py-2">Windows support</td>
          <td class="border border-border px-3 py-2">Good (WinRM)</td>
          <td class="border border-border px-3 py-2">Good</td>
          <td class="border border-border px-3 py-2">Good</td>
          <td class="border border-border px-3 py-2">Limited</td>
        </tr>
        <tr class="bg-bg-card/30">
          <td class="border border-border px-3 py-2">Community</td>
          <td class="border border-border px-3 py-2">Very large (Galaxy)</td>
          <td class="border border-border px-3 py-2">Medium (Supermarket)</td>
          <td class="border border-border px-3 py-2">Medium (Forge)</td>
          <td class="border border-border px-3 py-2">Medium</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Use Cases</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li>Server provisioning and baseline configuration (packages, users, SSH keys, firewall rules)</li>
    <li>Application deployment pipelines with zero-downtime rolling updates</li>
    <li>Network device automation (Cisco IOS, Juniper, Arista via network modules)</li>
    <li>Cloud provisioning and multi-tier application orchestration across AWS/GCP/Azure</li>
    <li>Security hardening and compliance enforcement via CIS benchmark playbooks</li>
    <li>Disaster recovery automation — fully reproducible environment restoration from playbooks</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pros and Cons</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-green-400 mb-2">Pros</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✓ No agent installation required — works on any SSH-accessible host</li>
        <li>✓ Very low barrier to entry: YAML + SSH knowledge is enough</li>
        <li>✓ Huge community and Galaxy collection ecosystem</li>
        <li>✓ Excellent for ad-hoc commands and one-off tasks</li>
        <li>✓ Idempotent by design — safe to run repeatedly</li>
        <li>✓ Vault provides built-in secret management</li>
      </ul>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-red-400 mb-2">Cons</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✗ Push model requires control node reachability to all hosts</li>
        <li>✗ SSH overhead — slower than agent-based tools at scale (1000+ nodes)</li>
        <li>✗ YAML indentation errors can be frustrating to debug</li>
        <li>✗ No built-in state tracking — re-runs re-execute all tasks</li>
        <li>✗ Complex conditional logic becomes unwieldy in YAML</li>
        <li>✗ AWX/Tower required for enterprise scheduling and RBAC (additional infra)</li>
      </ul>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Ansible Automation Guide" relatedTags={['ansible', 'automation', 'devops', 'configuration-management', 'infrastructure']} />
</BaseLayout>
