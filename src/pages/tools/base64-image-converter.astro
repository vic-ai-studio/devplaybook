---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Base64ImageConverter from '../../components/Base64ImageConverter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Base64 image encoding?",
    answer: "Base64 encoding converts binary image data into a text string using 64 printable ASCII characters. This allows embedding images directly in HTML, CSS, or JSON without a separate HTTP request. A Base64-encoded image data URI looks like: data:image/png;base64,iVBORw0KGgo..."
  },
  {
    question: "When should I use Base64 images?",
    answer: "Use Base64 embedding for small images (under 5–10 KB) like icons, tiny logos, or single-pixel tracking pixels. For email HTML, Base64 avoids blocked external images. For inline SVGs and CSS background patterns, it eliminates an HTTP request. Avoid Base64 for large images — the encoded string is ~33% larger than the original binary."
  },
  {
    question: "What image formats are supported?",
    answer: "All browser-supported formats work: PNG, JPG/JPEG, GIF, WebP, SVG, ICO, AVIF, and BMP. The MIME type is auto-detected from the selected file and included in the data URI output."
  },
  {
    question: "How do I use a Base64 image in HTML?",
    answer: "Use it directly in an <img> src attribute: <img src=\"data:image/png;base64,iVBOR...\">. Or in a CSS background-image: background-image: url('data:image/png;base64,...'). The full data URI includes the MIME type prefix."
  },
  {
    question: "Why is my Base64 string so long?",
    answer: "Base64 encoding adds approximately 33% overhead — every 3 bytes of binary data becomes 4 ASCII characters. A 100 KB image becomes ~133 KB as Base64. For images over 5 KB, serving them as regular files via <img src=\"/image.png\"> is more efficient because browsers can cache them separately."
  },
  {
    question: "Is this tool safe? Does it upload my image?",
    answer: "Yes, completely safe. All processing happens in your browser using the FileReader API and btoa(). No image data is sent to any server. The tool works entirely offline once the page is loaded."
  },
];
---

<BaseLayout
  title="Base64 Image Converter — Encode & Decode Images to Base64 Data URI"
  description="Convert images to Base64 data URI and decode Base64 back to images. Supports PNG, JPG, GIF, WebP, SVG. Get data URI, CSS background, and HTML img tag output. 100% browser-based — no upload."
  tool="Base64 image encoder, image to Base64, data URI generator, Base64 to image, CSS background Base64, HTML img Base64"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Base64 Image Converter",
    "url": "https://devplaybook.cc/tools/base64-image-converter",
    "description": "Convert images to Base64 data URIs and decode Base64 back to images. Supports PNG, JPG, GIF, WebP, SVG. Runs 100% in browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Base64 Image Converter</h1>
  <p class="text-text-muted mb-4">
    Convert images to Base64 data URIs for embedding in HTML, CSS, and JSON — or decode Base64 strings back to viewable images.
    Supports PNG, JPG, GIF, WebP, SVG, and all browser image formats. All processing runs in your browser — no file uploads.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Image → Base64 + Data URI</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Base64 → Preview + Download</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CSS & HTML output formats</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <Base64ImageConverter client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Base64 Image Converter" relatedTags={['images', 'base64', 'css', 'html', 'encoding', 'web', 'developer-tools']} />
</BaseLayout>
