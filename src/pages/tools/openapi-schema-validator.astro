---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OpenApiSchemaValidator from '../../components/OpenApiSchemaValidator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is OpenAPI 3.x and how is it different from Swagger 2.0?",
    answer: "OpenAPI 3.x (formerly known as Swagger 3) is the current standard for describing RESTful APIs. It replaced Swagger 2.0 with a cleaner structure: the top-level field changed from \"swagger: \\\"2.0\\\"\" to \"openapi: \\\"3.0.x\\\"\", request bodies were separated from parameters, and components were unified under a single \"components\" object. This validator only supports OpenAPI 3.x specs."
  },
  {
    question: "What are the required fields in an OpenAPI 3.x specification?",
    answer: "An OpenAPI 3.x document must have three top-level required fields: (1) \"openapi\" — a string like \"3.0.3\" or \"3.1.0\" indicating the specification version; (2) \"info\" — an object containing at minimum \"title\" (string) and \"version\" (string); and (3) \"paths\" — an object mapping URL paths to their operations. All other fields such as \"servers\", \"components\", \"tags\", and \"security\" are optional but recommended."
  },
  {
    question: "Can I validate both YAML and JSON OpenAPI specs?",
    answer: "Yes. This validator accepts both YAML and JSON formats. Use the YAML/JSON toggle to hint which format your spec is in. The validator tries JSON.parse first for JSON-like input (starting with { or [), then falls back to the built-in YAML parser. Both formats are fully supported and produce identical validation results since they represent the same data structure."
  },
  {
    question: "Why does each operation need a \"responses\" field?",
    answer: "The OpenAPI 3.x specification mandates that every operation object must include a \"responses\" field. This is because an API without defined responses provides no contract for clients — they cannot know what to expect. Each response code entry (e.g. \"200\", \"404\", \"default\") should include at minimum a \"description\" string explaining what that response means."
  },
  {
    question: "What is the difference between errors, warnings, and info messages?",
    answer: "Errors (shown in red) indicate violations of the OpenAPI 3.x specification — your spec will not be parseable by conformant tools until these are fixed. Warnings (yellow) indicate practices that are technically allowed but strongly discouraged, such as operations without a summary or response objects without descriptions. Info messages (blue) are suggestions for improving spec quality, such as adding server URLs or schema descriptions, but are entirely optional."
  },
];
---

<BaseLayout
  title="OpenAPI Schema Validator — Validate OpenAPI 3.x YAML & JSON"
  description="Free browser-based OpenAPI 3.x schema validator. Paste your YAML or JSON spec and get instant validation errors and warnings. Check required fields, paths, operations, and schemas without any server upload."
  tool="OpenAPI Schema Validator, OpenAPI 3.x Validator, Swagger Validator, API Spec Checker, OpenAPI YAML Validator, OpenAPI JSON Validator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">OpenAPI 3.x Schema Validator</h1>
  <p class="text-text-muted mb-4">Paste your OpenAPI 3.x specification in YAML or JSON format for instant structural validation. Checks required fields, path definitions, operation objects, response codes, component schemas, and more — all in your browser with no data uploaded.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> OpenAPI 3.0.x and 3.1.x</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> YAML and JSON input</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Paths, operations, schemas, parameters</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100% client-side — spec never leaves your browser</span>
  </div>
  <OpenApiSchemaValidator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="OpenAPI Schema Validator" relatedTags={['api', 'openapi', 'validation', 'swagger', 'yaml']} />
</BaseLayout>
