---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AiTokenCostCalculator from '../../components/AiTokenCostCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "How are tokens counted and why don't character counts match?",
    answer: "Tokens are the atomic units LLMs process — roughly 4 English characters per token, but this varies significantly. Common words like 'the' or 'cat' are 1 token. Rare words, code symbols, or non-English text often tokenize into 2–5 tokens per word. A rough guide: 1 page of English prose ≈ 750 tokens, 1 line of code ≈ 10–20 tokens, 1K characters ≈ 200–300 tokens. For exact counts, use tiktoken (OpenAI) or the provider's tokenizer library."
  },
  {
    question: "What is prompt caching and how much does it save?",
    answer: "Anthropic's prompt caching lets you mark parts of your prompt (e.g. a large system prompt or reference document) to be cached server-side. Subsequent requests that hit the cache pay only ~10% of the normal input token price for those cached tokens. This is a massive saving if you repeat the same large context — e.g. sending a 50,000-token codebase with every request. Cache hits are charged at $0.30/1M for Claude 3.5 Sonnet instead of $3/1M. OpenAI offers automatic prompt caching for prompts over 1,024 tokens on GPT-4o."
  },
  {
    question: "Do longer context windows cost more even if I don't use them?",
    answer: "Yes — you pay per token sent and received, not per context window capacity. A 200K context window doesn't cost more than a 128K window if you only send 1K tokens. However, if you do fill a large context (e.g. feeding a 100K-token document), you pay for every input token on every request. Gemini 1.5 Pro has tiered pricing: inputs under 128K tokens cost $1.25/1M, while inputs over 128K cost $2.50/1M."
  },
  {
    question: "Are there batch discounts for high-volume API usage?",
    answer: "Yes. OpenAI's Batch API offers 50% off for asynchronous requests with up to 24-hour turnaround — ideal for offline processing. Anthropic offers a similar Message Batches API at 50% off. Google has tiered pricing where higher usage can unlock lower rates. For very high volumes, you can also negotiate enterprise contracts directly with providers. This calculator shows standard on-demand pricing; batch pricing would halve the estimates."
  },
  {
    question: "What hidden costs should I account for beyond token pricing?",
    answer: "Several costs are often overlooked: (1) Retry costs — failed requests still charge tokens if the model started generating. (2) System prompt overhead — every request includes your system prompt tokens. (3) Tool call tokens — function definitions and call/response cycles add significant token overhead. (4) Streaming doesn't reduce cost. (5) Rate limit retries waste latency. (6) Egress/compute costs if you're proxying through your own infrastructure. Budget an extra 10–20% for these hidden overheads."
  },
  {
    question: "When should I use a cheaper model instead of GPT-4o or Claude 3.5 Sonnet?",
    answer: "Use cheaper models (GPT-4o mini, Gemini Flash, Claude 3.5 Haiku, Llama 3.1 8B via Groq) for: classification, simple extraction, summarization, chatbot responses, translation, and high-volume pipelines where accuracy isn't critical. Use frontier models for: complex reasoning, code generation, long-context analysis, and tasks where errors are expensive. A hybrid approach — route simple queries to cheap models and complex ones to frontier models — often cuts costs 60–80% with minimal quality loss."
  },
];
---

<BaseLayout
  title="AI Token Cost Calculator — Compare GPT-4, Claude, Gemini API Pricing"
  description="Calculate and compare API costs across OpenAI GPT-4, Claude 3.5, Gemini, and Groq. Input/output token pricing for all major LLM providers. Free, runs in browser."
  tool="AI Token Cost Calculator, LLM API Pricing, GPT-4 Token Cost, Claude API Cost, Gemini Pricing"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "AI Token Cost Calculator",
    "url": "https://devplaybook.cc/tools/ai-token-cost-calculator",
    "description": "Calculate and compare API costs across OpenAI GPT-4o, Claude 3.5 Sonnet, Gemini 1.5 Pro, and Groq Llama. Compare input/output token pricing, prompt caching savings, and monthly cost projections for all major LLM providers.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "featureList": [
      "15 AI models across OpenAI, Anthropic, Google, and Groq",
      "Input and output token cost breakdown",
      "Monthly cost projection by request volume",
      "Anthropic prompt caching savings calculator",
      "CSS bar chart comparison",
      "Estimate tokens from pasted text"
    ]
  })} />

  <h1 class="text-3xl font-bold mb-2">AI Token Cost Calculator</h1>
  <p class="text-text-muted mb-4">
    Compare API costs across OpenAI GPT-4o, Claude 3.5, Gemini, and Groq. Enter your token counts and monthly volume to see real-dollar cost breakdowns and identify the cheapest model for your use case.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 15 models with 2024 pricing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Monthly cost projections</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Prompt caching savings</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in browser</span>
  </div>
  <AiTokenCostCalculator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="AI Token Cost Calculator" relatedTags={['ai', 'llm', 'openai', 'claude', 'gemini', 'cost', 'api', 'tokens']} />
</BaseLayout>
