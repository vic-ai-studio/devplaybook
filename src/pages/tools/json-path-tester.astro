---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonPathTester from '../../components/JsonPathTester.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is JSONPath and when should I use it?",
    answer: "JSONPath is a query language for JSON, similar to XPath for XML. You use it to extract specific values from nested JSON structures — for example, pulling all order IDs from an array of orders, or grabbing every email address nested under customer objects. It is widely used in REST API testing tools like Postman, AWS Step Functions, Kubernetes manifests, and monitoring configurations."
  },
  {
    question: "How does the $ symbol work in JSONPath?",
    answer: "The $ symbol always refers to the root of your JSON document. Every JSONPath expression should start with $. From there you use dot notation ($.store.name) to navigate object keys, bracket notation ($.orders[0]) to access array elements, and wildcards ($.orders[*]) to match all items in an array or all values in an object."
  },
  {
    question: "What is the difference between $.key and $..key?",
    answer: "$.key navigates directly to a property at one specific level of the JSON tree. $..key uses recursive descent, meaning it searches at every depth — it will find 'name' whether it is at the top level, inside an array, or nested five levels deep. Use .. when you want to extract a field without knowing exactly how deeply it is nested."
  },
  {
    question: "How do I select all items in a JSON array?",
    answer: "Use the wildcard operator: $.orders[*] selects every element in the orders array. You can chain this with further selectors — for example $.orders[*].id returns the id property from every order object in the array. To select a specific index use $.orders[0] for the first, $.orders[-1] for the last."
  },
  {
    question: "Is this tool safe to use with sensitive data?",
    answer: "Yes. The JSON Path Tester runs entirely in your browser using JavaScript. No data is transmitted to any server. Your JSON payload — including API responses, config files, and any sensitive values — never leaves your machine. It is safe to paste production API responses for debugging."
  },
  {
    question: "Which tools and frameworks support JSONPath syntax?",
    answer: "JSONPath is supported by Postman (test assertions), AWS Step Functions (input/output filters), Kubernetes (CEL expressions), Grafana (data transformations), n8n and Zapier (expression fields), Java's Jayway JsonPath library, Python's jsonpath-ng, and the jq command-line tool. The core syntax — $, ., .., [], [*] — is consistent across all of them."
  },
];
---

<BaseLayout
  title="JSON Path Tester — Test JSONPath Expressions Online"
  description="Test JSONPath expressions against JSON data in real time. See matched values, paths, and types instantly. Supports $, ., .., [*], [0], and recursive descent. Free, runs in your browser."
  tool="JSON Path Tester, JSONPath Evaluator, JSONPath Query Tool, JSON Expression Tester"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">JSON Path Tester</h1>
  <p class="text-text-muted mb-4">
    Paste any JSON and test JSONPath expressions to see matching values in real time. Supports dot notation, array indexing, wildcards, and recursive descent. Use it to debug API responses, build query expressions, or learn JSONPath syntax.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Real-time expression evaluation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Shows path and type of every match</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100% browser-based, no data sent anywhere</span>
  </div>
  <JsonPathTester client:only="preact" />
  <!-- Ad slot below tool output — highest CTR position (user pauses after using the tool) -->
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="JSON Path Tester" relatedTags={['json', 'api', 'development', 'testing']} />
</BaseLayout>
