---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AspectRatioCalculator from '../../components/AspectRatioCalculator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Aspect Ratio Calculator"
  description="Calculate and convert aspect ratios for any width and height. Simplify ratios, scale dimensions while preserving the ratio, and get the CSS padding-top trick value."
  tool="Aspect Ratio Calculator, Image Ratio Calculator, Screen Resolution Converter, CSS Aspect Ratio"
>
  <h1 class="text-3xl font-bold mb-2">Aspect Ratio Calculator</h1>
  <p class="text-text-muted mb-8">Enter any width and height to calculate the simplified aspect ratio and decimal ratio. Scale dimensions to a new size while preserving the ratio, or look up common sizes for standard ratios like 16:9, 4:3, and 1:1.</p>
  <AspectRatioCalculator client:only="preact" />
  <ToolPageCta currentTool="Aspect Ratio Calculator" relatedTags={['css', 'design', 'image', 'video', 'responsive']} />
</BaseLayout>
