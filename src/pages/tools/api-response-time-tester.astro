---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ApiResponseTimeTester from '../../components/ApiResponseTimeTester.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What does this tool measure?", answer: "This tool measures the round-trip time from your browser to the API endpoint and back, including DNS lookup, TCP connection, TLS handshake, server processing, and data transfer. This gives you a realistic view of what your users experience when calling the API." },
  { question: "Why am I getting CORS errors?", answer: "CORS (Cross-Origin Resource Sharing) errors occur when the API server doesn't allow requests from browser-based clients. This is a security feature, not a bug. APIs that support browser access will have 'Access-Control-Allow-Origin' headers. Use a REST client like Postman or curl for APIs that don't support CORS." },
  { question: "What is a good API response time?", answer: "Under 100ms is excellent (users perceive it as instant). 100-300ms is good. 300-800ms is average and noticeable. Over 800ms users will start to disengage. Over 2 seconds is very slow and should be optimized. For user-facing APIs, aim for under 200ms at the 95th percentile." },
  { question: "Why run multiple test runs?", answer: "The first request may be slower due to DNS resolution and connection establishment. Running 3-10 times gives you a better average and lets you identify variance. High variance (e.g., 50ms vs 800ms) indicates intermittent issues like rate limiting, cold starts, or network congestion." },
];
---

<BaseLayout
  title="API Response Time Tester — Test API Speed From Your Browser"
  description="Test API endpoint response times directly from your browser. Run multiple requests, see average/min/max times, status codes, and response sizes. GET, POST, PUT, DELETE support. Free."
  tool="API Response Time Tester, API Speed Test, API Latency Checker, API Benchmark Tool"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">API Response Time Tester</h1>
  <p class="text-text-muted mb-4">Test API endpoint performance directly from your browser. Send GET, POST, PUT, and other requests, run multiple iterations, and see average response times, status codes, and response sizes — all without leaving the page. <span class="text-xs text-text-muted">Requires CORS-enabled endpoints.</span></p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Custom headers & request body</span>
  </div>
  <ApiResponseTimeTester client:load />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="API Response Time Tester" relatedTags={['api', 'performance', 'debugging', 'backend', 'web']} />
</BaseLayout>
