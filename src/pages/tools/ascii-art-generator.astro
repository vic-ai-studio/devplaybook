---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AsciiArtGenerator from '../../components/AsciiArtGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="ASCII Art Generator — Convert Text to ASCII Art Online"
  description="Turn any text into ASCII art instantly. Choose from Classic, Blocks, Simple, and Bold styles. Copy and share your ASCII art — runs entirely in your browser, no signup needed."
  tool="ASCII Art Generator, Text to ASCII Art, ASCII Text Art"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "ASCII Art Generator",
    "description": "Free browser-based tool that converts text to ASCII art. Supports multiple styles including Classic, Blocks, Simple, and Bold. No server — fully private.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Web",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "url": "https://devplaybook.cc/tools/ascii-art-generator"
  })} />
  <h1 class="text-3xl font-bold mb-2">ASCII Art Generator</h1>
  <p class="text-text-muted mb-8">Convert any text into ASCII art. Pick a style, adjust the size, and copy your result in one click — perfect for README headers, terminal banners, and social posts.</p>
  <AsciiArtGenerator client:only="preact" />
  <ToolPageCta currentTool="ASCII Art Generator" relatedTags={['ascii', 'text', 'design', 'terminal', 'fun']} />
</BaseLayout>
