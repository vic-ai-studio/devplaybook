---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AsciiArtGenerator from '../../components/AsciiArtGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How do I convert text to ASCII art?", answer: "Type or paste your text into the input field, choose a style (Classic, Blocks, Simple, or Bold), and the ASCII art appears instantly. Click Copy to grab it for your README, terminal banner, or social post." },
  { question: "What styles are available?", answer: "The tool includes Classic (traditional banner font), Blocks (chunky block letters), Simple (clean minimal style), and Bold (heavy outlined characters). Each produces a different visual effect suitable for different contexts." },
  { question: "Can I use ASCII art in GitHub README files?", answer: "Yes. Wrap the ASCII art in a code block (triple backticks) in your Markdown file. This preserves the monospace formatting that ASCII art requires. It's a popular way to add visual headers to open-source projects." },
  { question: "Does this work with special characters and emojis?", answer: "ASCII art works best with standard Latin letters, numbers, and common punctuation. Special characters and emojis may not render correctly because the styles are designed around the ASCII character set." },
  { question: "Is there a size or length limit?", answer: "There's no hard limit, but shorter text (1–3 words) produces the most readable results. Longer text may wrap awkwardly depending on the style and your display width." },
];
---

<BaseLayout
  title="ASCII Art Generator — Convert Text to ASCII Art Free Online"
  description="Turn any text into ASCII art instantly. Choose from Classic, Blocks, Simple, and Bold styles. Perfect for README headers, terminal banners, and social posts. Copy and share — runs entirely in your browser, no signup needed."
  tool="ASCII Art Generator, Text to ASCII Art, ASCII Text Art, ASCII Banner, README Header Generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "ASCII Art Generator",
    "description": "Free browser-based tool that converts text to ASCII art. Supports multiple styles including Classic, Blocks, Simple, and Bold. No server — fully private.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Web",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "url": "https://devplaybook.cc/tools/ascii-art-generator"
  })} />
  <h1 class="text-3xl font-bold mb-2">ASCII Art Generator</h1>
  <p class="text-text-muted mb-4">Convert any text into ASCII art — pick a style (Classic, Blocks, Simple, or Bold), adjust the size, and copy your result in one click. Perfect for README headers, terminal banners, and social posts.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <AsciiArtGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="ASCII Art Generator" relatedTags={['ascii', 'text', 'design', 'terminal', 'fun']} />
</BaseLayout>
