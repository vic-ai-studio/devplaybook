---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the most impactful web performance optimization?", answer: "Reducing JavaScript is consistently the highest-impact optimization. JS is the most expensive resource type — it requires downloading, parsing, compiling, and executing, blocking the main thread throughout. Beyond JS: use a CDN to reduce TTFB, properly size and format images (WebP/AVIF), eliminate render-blocking resources, and implement caching. The HTTP Archive shows that JS weight is the strongest predictor of poor Core Web Vitals scores." },
  { question: "How do I optimize images for web performance?", answer: "Use modern formats (WebP saves 25–35% vs JPEG; AVIF saves 50%+ vs JPEG). Set explicit width and height to prevent CLS. Use srcset and sizes for responsive images. Lazy-load below-the-fold images with loading='lazy'. Preload the LCP image. Compress with tools like Squoosh, Sharp, or imagemin. For hero images, consider serving different sizes: 400w mobile, 800w tablet, 1200w desktop." },
  { question: "What is render-blocking and how do I eliminate it?", answer: "Render-blocking resources are CSS and JS files that prevent the browser from painting the page until they finish downloading. CSS in <head> always blocks rendering. Scripts block unless marked async or defer. To eliminate render-blocking: inline critical CSS, load non-critical CSS with media='print' onload trick, add defer or async to scripts, and preload critical fonts. Google's LCP metric is heavily influenced by render-blocking resources." },
  { question: "How do fonts affect web performance?", answer: "Web fonts can cause FOIT (Flash of Invisible Text) or FOUT (Flash of Unstyled Text), contribute to LCP delays, and add layout shift. Best practices: preconnect to font origins, preload critical fonts, use font-display: swap (shows fallback while loading) or font-display: optional (uses fallback if font isn't cached). Subset fonts to only needed characters. Consider variable fonts — one file replaces multiple weight files. Prefer self-hosted fonts over Google Fonts for control." },
  { question: "What is the difference between CDN and edge caching?", answer: "A CDN (Content Delivery Network) stores copies of your static assets (images, JS, CSS) at geographically distributed servers, reducing the physical distance between user and content. Edge caching extends this further — dynamic content and even full page responses are cached at CDN edge nodes. Services like Cloudflare, Vercel, and Fastly offer both. A CDN primarily improves asset delivery; edge caching (like Cloudflare Workers or Vercel Edge) can also accelerate dynamic content by caching HTML at the edge." },
];
---

<BaseLayout
  title="Web Performance Checklist — Interactive Score with Images, JS, CSS, Fonts & Caching"
  description="Interactive web performance checklist covering images, fonts, JavaScript, CSS, caching, and more. Check off items to track your score out of 100 and export as Markdown."
  tool="web performance checklist, website performance audit checklist, performance score tracker, image optimization checklist, JavaScript performance, caching checklist"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Web Performance Checklist",
    "url": "https://devplaybook.cc/tools/web-performance-checklist",
    "description": "Interactive performance checklist with scoring across images, fonts, JavaScript, CSS, caching, and server categories. Export results as Markdown.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Web Performance Checklist</h1>
  <p class="text-text-muted mb-4">Check off each optimization to track your performance score. Items are weighted by impact. Export your results as Markdown to share with your team or track progress over time.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 6 categories, 30+ items</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Weighted score / 100</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Export as Markdown</span>
  </div>

  <div class="space-y-5">
    <!-- Score header -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between flex-wrap gap-4">
        <div>
          <div class="text-sm text-text-muted mb-1">Performance Score</div>
          <div class="flex items-end gap-2">
            <span id="perf-score" class="text-5xl font-bold text-primary">0</span>
            <span class="text-text-muted text-lg mb-1">/100</span>
          </div>
          <div id="perf-label" class="text-sm mt-1 text-text-muted"></div>
        </div>
        <div class="flex gap-3">
          <button id="reset-btn" class="bg-bg border border-border text-text-muted px-4 py-2 rounded-lg text-sm hover:border-primary/40 transition-colors">Reset</button>
          <button id="export-btn" class="bg-primary text-white px-5 py-2 rounded-lg text-sm font-semibold hover:bg-primary/80 transition-colors">Export Markdown</button>
        </div>
      </div>
      <!-- Progress bar -->
      <div class="mt-4 h-3 bg-bg rounded-full overflow-hidden">
        <div id="perf-bar" class="h-full rounded-full transition-all duration-300 bg-primary" style="width:0%"></div>
      </div>
    </div>

    <!-- Checklist categories -->
    <div id="checklist" class="space-y-4"></div>

    <!-- Export output -->
    <div id="export-section" class="hidden bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <h2 class="font-semibold">Markdown Export</h2>
        <button id="copy-md-btn" class="text-xs text-primary border border-primary/30 px-3 py-1 rounded-lg hover:text-primary/80 transition-colors">Copy</button>
      </div>
      <pre id="export-output" class="bg-bg rounded-lg p-4 text-sm font-mono text-text-muted overflow-x-auto whitespace-pre-wrap max-h-96"></pre>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Web Performance Checklist" relatedTags={['performance', 'checklist', 'web-vitals', 'images', 'javascript', 'caching']} />
</BaseLayout>

<script is:inline>
(function () {
  var CATEGORIES = [
    {
      id: 'images',
      label: 'Images',
      icon: '🖼',
      items: [
        { id: 'img-format',   label: 'Use modern image formats (WebP or AVIF)',                       weight: 5 },
        { id: 'img-dims',     label: 'Set explicit width and height on all images',                    weight: 4 },
        { id: 'img-lazy',     label: 'Lazy-load below-the-fold images (loading="lazy")',               weight: 3 },
        { id: 'img-preload',  label: 'Preload the LCP (hero) image',                                   weight: 5 },
        { id: 'img-srcset',   label: 'Use srcset and sizes for responsive images',                     weight: 3 },
        { id: 'img-compress', label: 'Compress images (Squoosh, Sharp, or imagemin in CI)',            weight: 3 },
      ]
    },
    {
      id: 'javascript',
      label: 'JavaScript',
      icon: '⚡',
      items: [
        { id: 'js-defer',    label: 'Add defer or async to non-critical scripts',                       weight: 5 },
        { id: 'js-split',    label: 'Use code splitting and dynamic imports',                           weight: 5 },
        { id: 'js-tree',     label: 'Enable tree shaking (Vite/webpack production build)',              weight: 4 },
        { id: 'js-budget',   label: 'Keep initial JS bundle under 200 KB compressed',                  weight: 5 },
        { id: 'js-thirdpty', label: 'Audit and defer third-party scripts (analytics, chat)',            weight: 4 },
        { id: 'js-polyfill', label: 'Remove unnecessary polyfills for modern targets',                  weight: 2 },
      ]
    },
    {
      id: 'css',
      label: 'CSS',
      icon: '🎨',
      items: [
        { id: 'css-critical', label: 'Inline critical above-the-fold CSS',                             weight: 4 },
        { id: 'css-purge',    label: 'Purge unused CSS (PurgeCSS, Tailwind content config)',            weight: 4 },
        { id: 'css-noblock',  label: 'Load non-critical CSS asynchronously (media=print trick)',        weight: 3 },
        { id: 'css-contain',  label: 'Use CSS contain or content-visibility for off-screen content',   weight: 2 },
        { id: 'css-budget',   label: 'Keep initial CSS under 50 KB compressed',                        weight: 3 },
      ]
    },
    {
      id: 'fonts',
      label: 'Fonts',
      icon: '🔤',
      items: [
        { id: 'font-preconn',  label: 'Preconnect to font origins (fonts.gstatic.com)',                weight: 3 },
        { id: 'font-preload',  label: 'Preload critical font files (woff2)',                            weight: 4 },
        { id: 'font-display',  label: 'Use font-display: swap or optional',                            weight: 4 },
        { id: 'font-subset',   label: 'Subset fonts to only needed characters',                        weight: 3 },
        { id: 'font-selfhost', label: 'Self-host fonts for better cache control',                      weight: 2 },
      ]
    },
    {
      id: 'caching',
      label: 'Caching',
      icon: '💾',
      items: [
        { id: 'cache-immutable', label: 'Set Cache-Control: max-age=31536000, immutable on hashed assets', weight: 5 },
        { id: 'cache-html',      label: 'Use Cache-Control: no-cache for HTML pages',                       weight: 3 },
        { id: 'cache-etag',      label: 'Enable ETags or Last-Modified on the server',                      weight: 2 },
        { id: 'cache-swr',       label: 'Use stale-while-revalidate for API responses',                     weight: 3 },
        { id: 'cache-cdn',       label: 'Serve static assets from a CDN',                                   weight: 5 },
      ]
    },
    {
      id: 'server',
      label: 'Server & Network',
      icon: '🌐',
      items: [
        { id: 'srv-http2',    label: 'Use HTTP/2 or HTTP/3 (h2 multiplexing)',                         weight: 3 },
        { id: 'srv-brotli',   label: 'Enable Brotli compression (better than gzip)',                   weight: 4 },
        { id: 'srv-ttfb',     label: 'Keep TTFB under 800ms (server response time)',                   weight: 5 },
        { id: 'srv-hints',    label: 'Send preconnect/preload via HTTP Link headers',                   weight: 3 },
        { id: 'srv-103',      label: 'Use HTTP 103 Early Hints for critical resources',                 weight: 2 },
      ]
    },
  ];

  var checked = {};
  var totalWeight = 0;
  CATEGORIES.forEach(function (cat) {
    cat.items.forEach(function (item) {
      totalWeight += item.weight;
      checked[item.id] = false;
    });
  });

  function getScore() {
    var earned = 0;
    CATEGORIES.forEach(function (cat) {
      cat.items.forEach(function (item) {
        if (checked[item.id]) earned += item.weight;
      });
    });
    return Math.round((earned / totalWeight) * 100);
  }

  function updateScore() {
    var score = getScore();
    document.getElementById('perf-score').textContent = score;
    document.getElementById('perf-bar').style.width = score + '%';

    var bar = document.getElementById('perf-bar');
    var label = document.getElementById('perf-label');
    if (score >= 90) {
      bar.className = bar.className.replace(/bg-\S+/, 'bg-green-500');
      label.textContent = 'Excellent — keep it up!';
      label.className = 'text-sm mt-1 text-green-400';
    } else if (score >= 70) {
      bar.className = bar.className.replace(/bg-\S+/, 'bg-primary');
      label.textContent = 'Good — a few more items to tackle.';
      label.className = 'text-sm mt-1 text-primary';
    } else if (score >= 40) {
      bar.className = bar.className.replace(/bg-\S+/, 'bg-yellow-500');
      label.textContent = 'Needs improvement — focus on high-weight items first.';
      label.className = 'text-sm mt-1 text-yellow-400';
    } else {
      bar.className = bar.className.replace(/bg-\S+/, 'bg-red-500');
      label.textContent = 'Many optimizations pending.';
      label.className = 'text-sm mt-1 text-red-400';
    }

    // Update category scores
    CATEGORIES.forEach(function (cat) {
      var catEarned = 0, catTotal = 0;
      cat.items.forEach(function (item) {
        catTotal += item.weight;
        if (checked[item.id]) catEarned += item.weight;
      });
      var pct = Math.round((catEarned / catTotal) * 100);
      var el = document.getElementById('cat-score-' + cat.id);
      if (el) el.textContent = pct + '%';
    });
  }

  function renderChecklist() {
    var container = document.getElementById('checklist');
    container.innerHTML = '';

    CATEGORIES.forEach(function (cat) {
      var section = document.createElement('div');
      section.className = 'bg-bg-card border border-border rounded-xl p-5';

      var header = document.createElement('div');
      header.className = 'flex items-center justify-between mb-4';
      header.innerHTML = '<div class="flex items-center gap-2"><span class="text-lg">' + cat.icon + '</span>'
        + '<h2 class="font-semibold">' + cat.label + '</h2></div>'
        + '<span id="cat-score-' + cat.id + '" class="text-sm font-mono text-text-muted">0%</span>';
      section.appendChild(header);

      var itemsEl = document.createElement('div');
      itemsEl.className = 'space-y-2';

      cat.items.forEach(function (item) {
        var row = document.createElement('label');
        row.className = 'flex items-start gap-3 cursor-pointer group';
        var weightDots = '';
        for (var w = 0; w < 5; w++) {
          weightDots += '<span class="w-1.5 h-1.5 rounded-full ' + (w < item.weight ? 'bg-primary' : 'bg-border') + '"></span>';
        }
        row.innerHTML = '<input type="checkbox" data-id="' + item.id + '" '
          + (checked[item.id] ? 'checked' : '')
          + ' class="mt-0.5 rounded shrink-0 accent-primary" />'
          + '<div class="flex-1">'
          + '<span class="text-sm group-hover:text-primary transition-colors ' + (checked[item.id] ? 'line-through text-text-muted' : '') + '">' + item.label + '</span>'
          + '</div>'
          + '<div class="flex gap-0.5 shrink-0 mt-1" title="Impact weight: ' + item.weight + '/5">' + weightDots + '</div>';

        row.querySelector('input').addEventListener('change', function (e) {
          checked[e.target.dataset.id] = e.target.checked;
          var span = row.querySelector('span');
          if (e.target.checked) span.classList.add('line-through', 'text-text-muted');
          else span.classList.remove('line-through', 'text-text-muted');
          updateScore();
        });

        itemsEl.appendChild(row);
      });

      section.appendChild(itemsEl);
      container.appendChild(section);
    });

    updateScore();
  }

  document.getElementById('reset-btn').addEventListener('click', function () {
    Object.keys(checked).forEach(function (k) { checked[k] = false; });
    renderChecklist();
    document.getElementById('export-section').classList.add('hidden');
  });

  document.getElementById('export-btn').addEventListener('click', function () {
    var score = getScore();
    var lines = ['# Web Performance Checklist', '', 'Score: **' + score + '/100**', '', '---', ''];

    CATEGORIES.forEach(function (cat) {
      var catDone = cat.items.filter(function (i) { return checked[i.id]; }).length;
      lines.push('## ' + cat.icon + ' ' + cat.label + ' (' + catDone + '/' + cat.items.length + ')');
      lines.push('');
      cat.items.forEach(function (item) {
        lines.push((checked[item.id] ? '- [x]' : '- [ ]') + ' ' + item.label);
      });
      lines.push('');
    });

    var md = lines.join('\n');
    document.getElementById('export-output').textContent = md;
    document.getElementById('export-section').classList.remove('hidden');
    document.getElementById('export-section').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });

  document.getElementById('copy-md-btn').addEventListener('click', function () {
    var text = document.getElementById('export-output').textContent;
    navigator.clipboard.writeText(text).then(function () {
      var btn = document.getElementById('copy-md-btn');
      btn.textContent = 'Copied!';
      setTimeout(function () { btn.textContent = 'Copy'; }, 2000);
    });
  });

  renderChecklist();
})();
</script>
