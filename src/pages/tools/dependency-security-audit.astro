---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is the difference between npm audit and Snyk?", answer: "npm audit is a free, built-in tool that checks your dependencies against the npm Advisory Database (which sources from NVD and GitHub Advisory Database). It's fast and requires no account. Snyk goes deeper: it has its own vulnerability database (often earlier disclosures), tracks vulnerabilities in container images and IaC configs, provides fix PRs, integrates with Jira, and has a dashboard for teams. npm audit is a good baseline; Snyk is better for teams and enterprise use cases. Both check direct and transitive dependencies." },
  { question: "How do I fix a vulnerability in a transitive dependency?", answer: "Transitive (indirect) dependencies can't be directly pinned in package.json. Options: (1) npm overrides / yarn resolutions — force a specific version of the transitive dep. (2) Update the direct dependency that includes the vulnerable transitive one. (3) If no fix is available, add a note in your audit config to accept the risk temporarily. Use 'npm audit fix --force' carefully — it may introduce breaking changes. Check if the vulnerability is actually reachable in your code path before treating it as critical." },
  { question: "What do CVE severity levels mean?", answer: "CVEs are scored using CVSS (Common Vulnerability Scoring System) 0-10: Critical (9.0-10.0) — exploitable without authentication, often RCE. High (7.0-8.9) — significant impact, usually needs some access. Medium (4.0-6.9) — limited impact or needs specific conditions. Low (0.1-3.9) — minimal impact or hard to exploit. Note that CVSS scores reflect severity in general, not necessarily in your specific context. A critical vulnerability in a dev-only dependency exposed to no external input may carry very low actual risk." },
  { question: "How do I integrate dependency auditing into CI/CD?", answer: "For npm: add 'npm audit --audit-level=high' to your CI pipeline — it exits non-zero if high/critical vulns are found, failing the build. For GitHub Actions, use the actions/dependency-review-action which checks PRs for new vulnerable dependencies. Snyk CI: 'snyk test --severity-threshold=high'. OWASP Dependency-Check can produce SARIF/HTML/XML reports as CI artifacts. Set thresholds appropriate to your risk tolerance — blocking on every medium vuln leads to alert fatigue." },
  { question: "What is a Software Bill of Materials (SBOM) and do I need one?", answer: "An SBOM is a formal, machine-readable inventory of all components in your software — direct deps, transitive deps, version numbers, licenses, and known vulnerabilities. Government contracts (US Executive Order 14028), financial sector, and healthcare increasingly require SBOMs. Generate with: 'npm install -g @cyclonedx/cyclonedx-npm && cyclonedx-npm' or Syft. SBOMs enable rapid vulnerability response — when a new CVE drops (like Log4Shell), you can immediately know which products are affected." },
  { question: "How does GitHub Dependabot work and how is it different from Renovate Bot?", answer: "Dependabot is GitHub's native dependency update bot. It opens PRs to update vulnerable packages (security updates) and can also open PRs for general version updates. It's zero-config for security updates. Renovate Bot (by Mend) is more configurable: it groups updates, allows custom scheduling, supports monorepos better, handles more package managers, and has more merge strategies. Both are free for public repos. Renovate is preferred by teams needing fine-grained control; Dependabot is a solid no-config baseline." },
];
---

<BaseLayout
  title="Dependency Security Audit: npm audit, Snyk & OWASP Dependency-Check"
  description="Complete guide to dependency security auditing using npm audit, yarn audit, Snyk CLI, OWASP Dependency-Check, and GitHub Dependabot. Includes CI/CD integration and severity level guide."
  tool="npm audit, Snyk, OWASP Dependency-Check, Dependabot, Dependency Security, CVE Scanning"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Dependency Security Audit: npm audit, Snyk & OWASP Dependency-Check",
    "url": "https://devplaybook.cc/tools/dependency-security-audit",
    "description": "Complete guide to dependency security auditing with npm audit, Snyk, OWASP Dependency-Check, and Dependabot including CI/CD integration.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Dependency Security Audit Guide</h1>
  <p class="text-text-muted mb-6">Modern applications depend on hundreds of third-party packages. One vulnerable transitive dependency can expose your entire application. This guide covers the tools and workflows to find, track, and fix dependency vulnerabilities at every stage of development.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> npm / yarn / pnpm audit</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Snyk CLI & CI integration</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> OWASP Dependency-Check</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GitHub Dependabot setup</span>
  </div>

  <h2 class="text-xl font-semibold mb-3">Tool Comparison Overview</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm mb-6">
      <thead>
        <tr class="border-b border-border text-left text-text-muted">
          <th class="py-2 pr-4">Tool</th>
          <th class="py-2 pr-4">Ecosystems</th>
          <th class="py-2 pr-4">Free</th>
          <th class="py-2 pr-4">CI/CD</th>
          <th class="py-2">Strength</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <tr><td class="py-2 pr-4 font-medium">npm audit</td><td class="py-2 pr-4">npm only</td><td class="py-2 pr-4 text-green-500">Yes</td><td class="py-2 pr-4 text-green-500">Yes</td><td class="py-2 text-text-muted">Zero-config, built-in</td></tr>
        <tr><td class="py-2 pr-4 font-medium">yarn audit</td><td class="py-2 pr-4">npm only</td><td class="py-2 pr-4 text-green-500">Yes</td><td class="py-2 pr-4 text-green-500">Yes</td><td class="py-2 text-text-muted">Yarn projects</td></tr>
        <tr><td class="py-2 pr-4 font-medium">Snyk</td><td class="py-2 pr-4">npm, pip, Maven, Go, etc.</td><td class="py-2 pr-4 text-yellow-500">Free tier</td><td class="py-2 pr-4 text-green-500">Yes</td><td class="py-2 text-text-muted">Earliest disclosures, fix PRs</td></tr>
        <tr><td class="py-2 pr-4 font-medium">OWASP Dep-Check</td><td class="py-2 pr-4">Java, .NET, Node, Python</td><td class="py-2 pr-4 text-green-500">Open source</td><td class="py-2 pr-4 text-green-500">Yes</td><td class="py-2 text-text-muted">NVD-based, HTML/XML reports</td></tr>
        <tr><td class="py-2 pr-4 font-medium">Dependabot</td><td class="py-2 pr-4">npm, pip, Maven, Go, etc.</td><td class="py-2 pr-4 text-green-500">Free on GitHub</td><td class="py-2 pr-4 text-green-500">Native GitHub</td><td class="py-2 text-text-muted">Auto-PR for updates</td></tr>
        <tr><td class="py-2 pr-4 font-medium">Renovate Bot</td><td class="py-2 pr-4">40+ ecosystems</td><td class="py-2 pr-4 text-green-500">Open source</td><td class="py-2 pr-4 text-green-500">Yes</td><td class="py-2 text-text-muted">Most configurable</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mb-3">npm audit: Basics to Advanced</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Basic audit — shows all vulnerabilities
npm audit

# JSON output for scripting
npm audit --json

# Audit only production dependencies (exclude devDeps)
npm audit --omit=dev

# Auto-fix compatible vulnerabilities
npm audit fix

# Force fix (may upgrade major versions — review changes!)
npm audit fix --force

# Fail CI if high or critical vulns found
npm audit --audit-level=high  # exits 1 if high+ found

# Fix transitive dependency with npm overrides (package.json)
# "overrides": &#123; "vulnerable-package": "^2.1.0" &#125;</pre>

  <h3 class="text-base font-semibold mb-2">Reading npm audit Output</h3>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-6">found 3 vulnerabilities (1 moderate, 1 high, 1 critical)

# critical
lodash  <=4.17.20
Severity: critical
Prototype Pollution — https://npmjs.com/advisories/1523
fix available via `npm audit fix`
node_modules/lodash
  your-package > lodash

# To fix transitive dep when no direct update exists:
# In package.json:
# "overrides": &#123; "lodash": "^4.17.21" &#125;</pre>

  <h2 class="text-xl font-semibold mb-3">Snyk CLI</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Install and authenticate
npm install -g snyk
snyk auth  # opens browser for auth

# Test current project
snyk test

# Test with threshold (fail on high+)
snyk test --severity-threshold=high

# Monitor project (sends snapshot to Snyk dashboard)
snyk monitor

# Fix vulnerabilities (opens PR or patches)
snyk fix

# Test a specific package
snyk test lodash@4.17.20

# Ignore a vuln temporarily (creates .snyk file)
snyk ignore --id=SNYK-JS-LODASH-1234567 --expiry=2026-06-01 --reason="no fix available"

# Python
snyk test --file=requirements.txt

# Docker image scanning
snyk container test node:18-alpine</pre>

  <h2 class="text-xl font-semibold mb-3">OWASP Dependency-Check</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Install (requires Java)
# Download from: https://github.com/jeremylong/DependencyCheck/releases

# Run against Node.js project
./dependency-check.sh \
  --project "MyApp" \
  --scan ./node_modules \
  --format HTML \
  --out ./reports/

# Run against Java project
./dependency-check.sh \
  --project "MyJavaApp" \
  --scan ./build/libs/ \
  --format "HTML,JSON,SARIF" \
  --out ./reports/

# Fail build if CVSS score >= 8
./dependency-check.sh \
  --project "MyApp" \
  --scan . \
  --failOnCVSS 8 \
  --out ./reports/</pre>

  <h2 class="text-xl font-semibold mb-3">GitHub Dependabot Configuration</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-6"># .github/dependabot.yml
version: 2
updates:
  # npm dependencies
  - package-ecosystem: "npm"
    directory: "/"
    schedule:
      interval: "weekly"
      day: "monday"
    open-pull-requests-limit: 10
    groups:
      # Group minor/patch updates into one PR
      production-minor:
        dependency-type: "production"
        update-types: ["minor", "patch"]
    ignore:
      # Ignore major version bumps (review manually)
      - dependency-name: "react"
        update-types: ["version-update:semver-major"]

  # GitHub Actions versions
  - package-ecosystem: "github-actions"
    directory: "/"
    schedule:
      interval: "weekly"

  # Python pip
  - package-ecosystem: "pip"
    directory: "/backend"
    schedule:
      interval: "weekly"</pre>

  <h2 class="text-xl font-semibold mb-3">CI/CD Integration: GitHub Actions</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-6"># .github/workflows/security.yml
name: Security Audit

on:
  push:
    branches: [main, develop]
  pull_request:
    branches: [main]
  schedule:
    - cron: '0 6 * * 1'  # Weekly Monday 6am

jobs:
  audit:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-node@v4
        with:
          node-version: '20'

      - run: npm ci

      # npm audit — fail on high+ severity
      - name: npm audit
        run: npm audit --audit-level=high --omit=dev

      # Snyk (requires SNYK_TOKEN secret)
      - name: Snyk security scan
        uses: snyk/actions/node@master
        env:
          SNYK_TOKEN: $&#123;&#123; secrets.SNYK_TOKEN &#125;&#125;
        with:
          args: --severity-threshold=high

      # Dependency Review (checks PRs for new vulns)
      - name: Dependency review
        uses: actions/dependency-review-action@v4
        with:
          fail-on-severity: high</pre>

  <h2 class="text-xl font-semibold mb-3">CVE Severity Levels Reference</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm mb-6">
      <thead>
        <tr class="border-b border-border text-left text-text-muted">
          <th class="py-2 pr-4">CVSS Score</th>
          <th class="py-2 pr-4">Severity</th>
          <th class="py-2 pr-4">Response Time</th>
          <th class="py-2">Example Impact</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <tr><td class="py-2 pr-4 font-mono">9.0 – 10.0</td><td class="py-2 pr-4 text-red-500 font-bold">Critical</td><td class="py-2 pr-4">Immediate / &lt;24h</td><td class="py-2 text-text-muted">Unauthenticated RCE (Log4Shell)</td></tr>
        <tr><td class="py-2 pr-4 font-mono">7.0 – 8.9</td><td class="py-2 pr-4 text-orange-500 font-bold">High</td><td class="py-2 pr-4">&lt;7 days</td><td class="py-2 text-text-muted">Auth bypass, privilege escalation</td></tr>
        <tr><td class="py-2 pr-4 font-mono">4.0 – 6.9</td><td class="py-2 pr-4 text-yellow-500 font-bold">Medium</td><td class="py-2 pr-4">Next release cycle</td><td class="py-2 text-text-muted">XSS with specific conditions</td></tr>
        <tr><td class="py-2 pr-4 font-mono">0.1 – 3.9</td><td class="py-2 pr-4 text-green-500 font-bold">Low</td><td class="py-2 pr-4">Scheduled maintenance</td><td class="py-2 text-text-muted">Minor info disclosure</td></tr>
      </tbody>
    </table>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Dependency Security Audit" relatedTags={['security', 'devops', 'nodejs', 'ci-cd']} />
</BaseLayout>
