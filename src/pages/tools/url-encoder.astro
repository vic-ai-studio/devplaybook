---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UrlEncoder from '../../components/UrlEncoder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="URL Encoder / Decoder"
  description="Encode and decode URLs online. Convert special characters to percent-encoded format or decode %20, %3D, %2F and other URL escape sequences. Free, runs in your browser."
  tool="URL Encoder, URL Decoder, Percent Encoding, URL Escape"
>
  <h1 class="text-3xl font-bold mb-2">URL Encoder / Decoder</h1>
  <p class="text-text-muted mb-8">Convert text to URL-safe percent-encoded format, or decode encoded URLs back to readable text. Supports both component encoding and full URL encoding modes.</p>
  <UrlEncoder client:load />
  <ToolPageCta currentTool="URL Encoder / Decoder" relatedTags={['encoding', 'api', 'web-development', 'debugging']} />
</BaseLayout>
