---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WebPConverter from '../../components/WebPConverter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is WebP and why should I use it?",
    answer: "WebP is a modern image format developed by Google that provides superior compression for images on the web. It produces files 25–35% smaller than JPEG and 25–50% smaller than PNG at comparable visual quality, which means faster page loads and lower bandwidth costs. All modern browsers — Chrome, Firefox, Safari 14+, and Edge — support WebP natively."
  },
  {
    question: "Is there any quality loss when converting to WebP?",
    answer: "It depends on the quality setting you choose. At quality 80–90, WebP images are visually indistinguishable from the original for most use cases. At lower quality values (50–70) you'll see smaller files but some visible compression artifacts. For pixel-perfect lossless output, set quality to 100 — though file sizes will be closer to the original PNG."
  },
  {
    question: "Can I convert GIF animations to WebP?",
    answer: "This tool converts only the first (static) frame of a GIF. Animated WebP requires a different encoding pipeline not available through the browser Canvas API. If you need animated WebP, use a command-line tool like cwebp or an online service that supports animated WebP output."
  },
  {
    question: "Are my images uploaded to a server?",
    answer: "No. All conversion happens entirely inside your browser using the Canvas API. Your image files never leave your device and are never sent to any server. This makes the tool safe to use with private or sensitive images."
  },
  {
    question: "What is the best quality setting for web images?",
    answer: "Quality 75–85 is the recommended range for most web images. It strikes a good balance between file size savings and visual fidelity. For hero images or photography where quality is critical, use 85–90. For thumbnails or decorative images, 65–75 is often fine and yields the biggest savings."
  },
];
---

<BaseLayout
  title="WebP Converter — Convert PNG/JPG/GIF to WebP Online"
  description="Free client-side WebP converter. Upload PNG, JPG, or GIF images and convert to WebP format instantly. Adjust quality, see file size savings. No files uploaded to any server."
  tool="webp converter, png to webp, jpg to webp, gif to webp, image converter, webp format, image optimization"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">WebP Converter</h1>
  <p class="text-text-muted mb-4">Convert PNG, JPG, or GIF images to WebP in your browser. Adjust quality, compare file sizes, and download optimized WebP files instantly — no upload, no signup.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No files uploaded to server</span>
  </div>
  <WebPConverter client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="WebP Converter" relatedTags={['images', 'optimization', 'webp', 'performance', 'frontend']} />
</BaseLayout>
