---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ParticleSystemConfig from '../../components/ParticleSystemConfig.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is a particle system?", answer: "A particle system is a simulation technique that manages many small sprites (particles) with individual properties: position, velocity, life span, size, color, and opacity. An emitter spawns particles at a rate; each particle's properties evolve over its lifetime according to configured curves. They are used for fire, smoke, rain, snow, explosions, magic effects, and ambient ambience in games and UI." },
  { question: "What does emit rate control?", answer: "Emit rate is the number of new particles spawned per frame. At 60 FPS, an emit rate of 5 creates 300 new particles per second. Combined with lifespan, this determines the average visible count: particles ≈ emitRate × lifespan (in frames). High emit rates with short lifespans create dense, fast-moving effects. Low rates with long lifespans create sparse, lingering ones." },
  { question: "What is additive (lighter) blend mode?", answer: "Additive blending adds particle RGB values to the background instead of covering it. Dark areas stay dark, but overlapping bright particles accumulate into glowing white/yellow centers — the signature look of fire, lasers, magical auras, and energy effects. Use it for emissive/glowing particles. Use 'normal' (source-over) for opaque particles like smoke or bubbles." },
  { question: "How does gravity affect particles?", answer: "Gravity is a constant Y velocity added each frame (positive = downward, negative = upward). It simulates realistic projectile arcs. For fire, set slight negative gravity so particles drift upward. For rain or sparks falling, use positive gravity. Setting gravity to 0 with high turbulence creates floating debris or ambient particles." },
  { question: "What is turbulence in a particle system?", answer: "Turbulence adds random noise to each particle's velocity every frame, simulating wind or chaotic air currents. A small turbulence value (0.1-0.2) gives organic, natural-looking motion. High turbulence (0.5+) creates wild, erratic movement. Fire and smoke benefit from moderate turbulence; sparks and rain typically use little or none." },
  { question: "What is the difference between point, area, and ring emitters?", answer: "A point emitter spawns all particles from one coordinate. An area emitter distributes spawn positions across a rectangular region (good for rain, wide fire). A ring emitter spawns particles on a circle's circumference (good for explosions, magic circles). The emitter type combined with angle/spread controls the initial direction of particles." },
];
---

<BaseLayout
  title="Particle System Config Generator — Fire, Snow, Sparks & Canvas Code"
  description="Interactive particle system configurator. Design fire, smoke, snow, sparks, and magic effects with real-time Canvas preview. Adjust emitter type, gravity, turbulence, blend mode, and export JavaScript config code."
  tool="Particle System Generator, Canvas Particle Effects, Game Dev Particles, Fire Particle Config, JavaScript Particle System"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Particle System Config Generator</h1>
  <p class="text-text-muted mb-4">Design particle effects interactively — fire, snow, sparks, smoke, and magic rings. Tune emitter type, gravity, turbulence, blend mode, colors, and copy the ready-to-use JavaScript config and update code.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 built-in presets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Real-time Canvas preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Export JS config + update code</span>
  </div>
  <ParticleSystemConfig client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Particle System Config Generator" relatedTags={['game-dev', 'canvas', 'animation', 'graphics', 'javascript']} />
</BaseLayout>
