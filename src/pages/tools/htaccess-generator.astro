---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HtaccessGenerator from '../../components/HtaccessGenerator.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is .htaccess and when should I use it?", answer: ".htaccess (hypertext access) is a configuration file for Apache web servers. It controls URL rewriting, redirects, authentication, caching, compression, and security headers on a per-directory basis. Use it when you need server-level config without editing the main httpd.conf — common on shared hosting environments." },
  { question: "How do I force HTTPS with .htaccess?", answer: "Add these two lines: RewriteCond %{HTTPS} off and RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]. The R=301 flag tells browsers and search engines this is a permanent redirect, so they'll update their cache and SEO signals will transfer." },
  { question: "Why does my SPA show a 404 on page reload?", answer: "Single page apps (React, Vue, Angular) handle routing in JavaScript — but when you refresh a URL like /dashboard, the server looks for a real file at that path and returns 404. The fix: add a rewrite rule that sends all requests to index.html, then let your JS router take over. This generator adds that rule automatically for the SPA preset." },
  { question: "What is the difference between 301 and 302 redirects?", answer: "301 is a permanent redirect — search engines transfer link equity to the new URL and browsers cache the redirect. 302 is temporary — search engines keep crawling the original URL, no SEO transfer. Use 301 for production redirects (HTTPS enforcement, domain changes, slug updates). Use 302 only for genuinely temporary situations like maintenance pages." },
  { question: "Does .htaccess slow down my site?", answer: "Slightly. Apache reads .htaccess on every request if AllowOverride is enabled. For high-traffic sites, move rules to the main server config (httpd.conf) for better performance. That said, the overhead is minimal for most sites, and the flexibility of per-directory config is usually worth it." },
  { question: "How do I protect specific files with .htaccess?", answer: "Use a FilesMatch directive: <FilesMatch \"(\\.env|\\.git|config\\.php)$\"> followed by Order Allow,Deny and Deny from all. This prevents direct browser access to sensitive files. Always block .env, .git directories, composer.lock, and similar files that shouldn't be publicly accessible." },
];
---

<BaseLayout
  title=".htaccess Generator — Apache Redirect, SPA, WordPress, Security Rules"
  description="Generate Apache .htaccess files instantly. Supports SPA routing, WordPress rewriting, HTTPS redirects, browser caching, gzip compression, security headers, and hotlink protection. Copy-ready output for Apache servers."
  tool=".htaccess generator, Apache htaccess, Apache redirect, htaccess rewrite, htaccess security, htaccess gzip, SPA routing Apache"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": ".htaccess Generator",
    "url": "https://devplaybook.cc/tools/htaccess-generator",
    "description": "Generate Apache .htaccess config files with rewrite rules, HTTPS redirects, gzip compression, browser caching, and security headers.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">.htaccess Generator</h1>
  <p class="text-text-muted mb-4">
    Generate Apache <code class="font-mono bg-surface px-1 rounded text-sm">.htaccess</code> configuration for your use case — SPA routing, WordPress, HTTPS redirects, caching, gzip, and security headers. No Apache syntax memorization required.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5 presets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> HTTPS + security headers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <HtaccessGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <AffiliateSection category={['hosting', 'deployment']} />
  <ToolPageCta currentTool=".htaccess Generator" relatedTags={['apache', 'server', 'hosting', 'redirect', 'devops']} />
</BaseLayout>
