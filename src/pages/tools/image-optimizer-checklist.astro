---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the best image format for the web in 2024?", answer: "WebP is the modern default — it's ~30% smaller than JPEG at the same quality and is supported by all major browsers. AVIF is even better (~50% smaller than JPEG) but encoding is slower. For photographs, use WebP or AVIF. For icons and logos with transparency, use WebP or SVG. For vector graphics, always use SVG." },
  { question: "What image dimensions should I use for a hero/banner?", answer: "A typical desktop hero is 1200–1920px wide. However, you should serve responsive images with srcset, providing at least three sizes: 400w (mobile), 800w (tablet), 1200w (desktop). Never serve a 1920px image to a 375px mobile device — that wastes bandwidth and hurts LCP." },
  { question: "What is lazy loading and when should I use it?", answer: "Lazy loading defers off-screen images until the user scrolls near them. Use loading='lazy' on all images below the fold. Never lazy-load above-fold images (hero, logo) as it delays LCP. The browser natively supports this attribute in all modern browsers — no JavaScript library needed." },
  { question: "What compression level should I use for JPEG and WebP?", answer: "For JPEG: quality 70–85 is the sweet spot — visually lossless for most photos. Below 60 introduces visible artifacts. For WebP: quality 75–85 gives better results than equivalent JPEG quality. For thumbnails or card images: quality 60–70 is fine. Always check visually after compression." },
  { question: "What are width and height attributes for?", answer: "Setting explicit width and height on <img> elements lets the browser reserve space before the image loads, preventing Cumulative Layout Shift (CLS). It also enables the browser to calculate the aspect ratio before the image downloads. This is required for good CLS scores in Core Web Vitals." },
  { question: "Should I use a CDN for images?", answer: "Yes — a CDN dramatically improves image delivery for global users by serving images from edge nodes close to each visitor. Image CDNs like Cloudinary, Imgix, and Cloudflare Images also offer automatic format conversion (WebP/AVIF), resizing, and compression on the fly, so you don't need to manually convert every image." },
];
---

<BaseLayout
  title="Image Optimizer Checklist — Dimensions, WebP, Lazy Load & Compression Guide"
  description="Enter your image dimensions and file size to get optimization recommendations. Covers WebP conversion, lazy loading, srcset, compression ratios, and CDN tips. Free browser tool."
  tool="image optimizer checklist, image optimization tool, WebP conversion guide, image compression calculator, lazy loading guide, srcset tool"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Image Optimizer Checklist",
    "url": "https://devplaybook.cc/tools/image-optimizer-checklist",
    "description": "Enter image dimensions and file size to get format, compression, lazy loading, and srcset recommendations for web performance optimization.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Image Optimizer Checklist</h1>
  <p class="text-text-muted mb-4">
    Enter your image details to get a personalized optimization checklist. Covers format selection, compression targets,
    lazy loading, srcset breakpoints, and CDN recommendations — all running in your browser.
  </p>
  <div class="flex items-center gap-3 mb-8 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Format recommendations</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Compression targets</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> srcset breakpoints</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>

  <!-- Input Form -->
  <div class="bg-bg-card border border-border rounded-xl p-6 mb-6">
    <h2 class="font-bold text-lg mb-4">Your Image Details</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-5">
      <!-- Width -->
      <div>
        <label class="block text-sm font-medium mb-1.5" for="img-width">Width <span class="text-text-muted font-normal">(px)</span></label>
        <input id="img-width" type="number" min="1" placeholder="e.g. 1920"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
      </div>
      <!-- Height -->
      <div>
        <label class="block text-sm font-medium mb-1.5" for="img-height">Height <span class="text-text-muted font-normal">(px)</span></label>
        <input id="img-height" type="number" min="1" placeholder="e.g. 1080"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
      </div>
      <!-- File size -->
      <div>
        <label class="block text-sm font-medium mb-1.5" for="img-size">File Size <span class="text-text-muted font-normal">(KB)</span></label>
        <input id="img-size" type="number" min="1" placeholder="e.g. 450"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
      </div>
      <!-- Format -->
      <div>
        <label class="block text-sm font-medium mb-1.5" for="img-format">Current Format</label>
        <select id="img-format"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40">
          <option value="">Select format</option>
          <option value="jpeg">JPEG / JPG</option>
          <option value="png">PNG</option>
          <option value="gif">GIF</option>
          <option value="webp">WebP</option>
          <option value="avif">AVIF</option>
          <option value="svg">SVG</option>
        </select>
      </div>
      <!-- Usage -->
      <div>
        <label class="block text-sm font-medium mb-1.5" for="img-usage">Image Usage</label>
        <select id="img-usage"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40">
          <option value="">Select usage</option>
          <option value="hero">Hero / Banner (above fold)</option>
          <option value="content">In-article / Content</option>
          <option value="thumbnail">Thumbnail / Card</option>
          <option value="icon">Icon / Logo</option>
          <option value="background">CSS Background</option>
        </select>
      </div>
      <!-- Has transparency -->
      <div>
        <label class="block text-sm font-medium mb-1.5" for="img-transparency">Has Transparency?</label>
        <select id="img-transparency"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40">
          <option value="no">No</option>
          <option value="yes">Yes</option>
        </select>
      </div>
    </div>

    <div class="flex gap-3">
      <button id="analyze-btn" class="bg-primary text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-primary/80 transition-colors">
        Get Recommendations
      </button>
      <button id="reset-btn" class="text-sm text-text-muted hover:text-red-400 transition-colors">
        Reset
      </button>
    </div>
  </div>

  <!-- Results -->
  <div id="results" class="hidden space-y-5">
    <!-- Score -->
    <div id="score-card" class="rounded-xl p-5 border"></div>

    <!-- Checklist -->
    <div class="bg-bg-card border border-border rounded-xl p-6">
      <h2 class="font-bold mb-4">Optimization Checklist</h2>
      <div id="checklist" class="space-y-3"></div>
    </div>

    <!-- srcset snippet -->
    <div id="srcset-card" class="hidden bg-bg-card border border-border rounded-xl p-6">
      <h2 class="font-bold mb-2">Suggested <code class="font-mono text-sm bg-bg px-1 rounded">srcset</code> Breakpoints</h2>
      <p class="text-sm text-text-muted mb-3">Serve appropriately sized images to each device to avoid sending oversized images to mobile users.</p>
      <div class="relative">
        <pre id="srcset-code" class="bg-bg border border-border rounded-lg p-4 text-xs font-mono overflow-x-auto whitespace-pre-wrap text-text-muted"></pre>
        <button id="copy-srcset" class="absolute top-2 right-2 text-xs px-2 py-1 bg-bg-card border border-border rounded hover:border-primary/50 transition-colors">Copy</button>
      </div>
    </div>

    <!-- Quick reference -->
    <div class="bg-bg-card border border-border rounded-xl p-6">
      <h2 class="font-bold text-sm uppercase tracking-wide text-text-muted mb-4">Format Selection Reference</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-xs uppercase tracking-wide text-text-muted border-b border-border">
              <th class="text-left py-2 pr-4">Format</th>
              <th class="text-left py-2 pr-4">Best For</th>
              <th class="text-left py-2 pr-4">Transparency</th>
              <th class="text-left py-2">Savings vs JPEG</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border text-text-muted">
            <tr><td class="py-2 pr-4 font-medium text-text">AVIF</td><td class="py-2 pr-4">Photos, complex images</td><td class="py-2 pr-4">Yes</td><td class="py-2 text-green-400">~50% smaller</td></tr>
            <tr><td class="py-2 pr-4 font-medium text-text">WebP</td><td class="py-2 pr-4">Photos, UI images</td><td class="py-2 pr-4">Yes</td><td class="py-2 text-green-400">~30% smaller</td></tr>
            <tr><td class="py-2 pr-4 font-medium text-text">SVG</td><td class="py-2 pr-4">Icons, logos, illustrations</td><td class="py-2 pr-4">Yes</td><td class="py-2 text-green-400">Vector (scalable)</td></tr>
            <tr><td class="py-2 pr-4 font-medium text-text">JPEG</td><td class="py-2 pr-4">Photos (legacy fallback)</td><td class="py-2 pr-4">No</td><td class="py-2">Baseline</td></tr>
            <tr><td class="py-2 pr-4 font-medium text-text">PNG</td><td class="py-2 pr-4">Screenshots, transparency (legacy)</td><td class="py-2 pr-4">Yes</td><td class="py-2 text-red-400">Often larger</td></tr>
            <tr><td class="py-2 pr-4 font-medium text-text">GIF</td><td class="py-2 pr-4">Avoid — use video/WebP instead</td><td class="py-2 pr-4">1-bit only</td><td class="py-2 text-red-400">Very large</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Image Optimizer Checklist" relatedTags={['performance', 'images', 'web', 'developer-tools']} />
</BaseLayout>

<script is:inline>
(function () {
  function fmt(kb) {
    return kb >= 1000 ? (kb / 1024).toFixed(1) + ' MB' : kb + ' KB';
  }

  function getFormatRec(format, hasTransparency) {
    if (format === 'svg') return null; // Already optimal
    if (format === 'avif') return null; // Already optimal
    if (hasTransparency === 'yes') return { rec: 'WebP', reason: 'WebP supports transparency and is ~30% smaller than PNG.' };
    if (format === 'gif') return { rec: 'WebP (animated) or MP4/WebM', reason: 'GIFs are huge. WebP animated or looped video is 5–20× smaller.' };
    if (format === 'png') return { rec: 'WebP or AVIF', reason: 'PNG is lossless but heavy for photos/UI. WebP saves ~30–50%.' };
    if (format === 'jpeg') return { rec: 'WebP or AVIF', reason: 'WebP saves ~30%, AVIF saves ~50% over JPEG at equal quality.' };
    return null;
  }

  function getSizeRating(kb, usage, w) {
    var limits = { hero: 200, content: 150, thumbnail: 50, icon: 20, background: 100 };
    var limit = limits[usage] || 200;
    if (kb <= limit) return 'good';
    if (kb <= limit * 2) return 'warn';
    return 'bad';
  }

  document.getElementById('analyze-btn').addEventListener('click', function () {
    var w = parseInt(document.getElementById('img-width').value) || 0;
    var h = parseInt(document.getElementById('img-height').value) || 0;
    var size = parseInt(document.getElementById('img-size').value) || 0;
    var format = document.getElementById('img-format').value;
    var usage = document.getElementById('img-usage').value;
    var transparency = document.getElementById('img-transparency').value;

    if (!w && !h && !size && !format && !usage) {
      alert('Please enter at least one detail about your image.');
      return;
    }

    var items = [];
    var score = 0;
    var maxScore = 0;

    // Format check
    if (format) {
      maxScore += 20;
      var formatRec = getFormatRec(format, transparency);
      if (!formatRec) {
        score += 20;
        items.push({ pass: true, title: 'Format: ' + format.toUpperCase(), detail: 'Your format is already optimal for web delivery.' });
      } else {
        items.push({ pass: false, title: 'Convert to ' + formatRec.rec, detail: formatRec.reason, priority: 'high' });
      }
    }

    // Size check
    if (size && usage) {
      maxScore += 25;
      var limits = { hero: 200, content: 150, thumbnail: 50, icon: 20, background: 100 };
      var limit = limits[usage] || 200;
      var rating = getSizeRating(size, usage, w);
      if (rating === 'good') {
        score += 25;
        items.push({ pass: true, title: 'File size is good (' + fmt(size) + ')', detail: 'Within the recommended ' + fmt(limit) + ' target for ' + usage + ' images.' });
      } else if (rating === 'warn') {
        score += 10;
        items.push({ pass: false, title: 'File size could be smaller (' + fmt(size) + ')', detail: 'Target ≤ ' + fmt(limit) + ' for ' + usage + ' images. Try compression quality 75–80.', priority: 'medium' });
      } else {
        items.push({ pass: false, title: 'File size is too large (' + fmt(size) + ')', detail: 'Target ≤ ' + fmt(limit) + ' for ' + usage + ' images. Current size is ' + Math.round(size / limit) + '× the recommended limit.', priority: 'high' });
      }
    }

    // Dimensions check
    if (w && usage) {
      maxScore += 20;
      var maxWidths = { hero: 1920, content: 1200, thumbnail: 400, icon: 128, background: 1920 };
      var maxW = maxWidths[usage] || 1200;
      if (w <= maxW) {
        score += 20;
        items.push({ pass: true, title: 'Dimensions are appropriate (' + w + '×' + (h || '?') + 'px)', detail: 'Width is within the recommended ' + maxW + 'px maximum for ' + usage + ' images.' });
      } else {
        items.push({ pass: false, title: 'Image is too wide (' + w + 'px)', detail: 'For ' + usage + ' use, resize to maximum ' + maxW + 'px width. You\'re sending ' + Math.round((w / maxW - 1) * 100) + '% extra pixels.', priority: 'high' });
      }
    }

    // Lazy loading
    if (usage) {
      maxScore += 15;
      if (usage === 'hero') {
        score += 15;
        items.push({ pass: true, title: 'Do NOT lazy load (hero/above fold)', detail: 'Hero images should load eagerly. Never add loading="lazy" to above-fold images — it delays LCP.' });
      } else {
        items.push({ pass: false, title: 'Add lazy loading', detail: 'Add loading="lazy" to all below-fold images. Native browser support, no JavaScript needed.', code: 'loading="lazy"', priority: 'medium' });
      }
    }

    // Width/Height attributes
    if (w && h) {
      maxScore += 10;
      items.push({ pass: false, title: 'Set explicit width and height attributes', detail: 'Always set width="' + w + '" height="' + h + '" on <img> elements to prevent CLS (Cumulative Layout Shift).', code: 'width="' + w + '" height="' + h + '"', priority: 'medium' });
      // Adjust — this is a reminder, not a failure
      items[items.length - 1].pass = true;
      score += 10;
    }

    // srcset recommendation
    if (w && w > 600 && usage !== 'icon') {
      maxScore += 10;
      items.push({ pass: false, title: 'Add srcset for responsive images', detail: 'Serve different sizes for mobile, tablet, and desktop. Prevents sending a ' + w + 'px image to a 375px mobile screen.', priority: 'medium' });
    }

    // CDN recommendation
    if (size && size > 100) {
      maxScore += 10;
      items.push({ pass: false, title: 'Serve images from a CDN', detail: 'Use Cloudflare Images, Cloudinary, or Imgix for global edge delivery, automatic format conversion, and on-the-fly resizing.', priority: 'low' });
    }

    // Score card
    var pct = maxScore > 0 ? Math.round((score / maxScore) * 100) : 0;
    var scoreCard = document.getElementById('score-card');
    var scoreColor = pct >= 80 ? 'green' : pct >= 50 ? 'yellow' : 'red';
    scoreCard.className = 'rounded-xl p-5 border bg-' + scoreColor + '-500/10 border-' + scoreColor + '-500/30';
    scoreCard.innerHTML = '<div class="flex items-center gap-4">'
      + '<div class="text-4xl font-bold ' + (pct >= 80 ? 'text-green-400' : pct >= 50 ? 'text-yellow-400' : 'text-red-400') + '">' + pct + '</div>'
      + '<div>'
      + '<div class="font-bold text-lg">' + (pct >= 80 ? 'Well Optimized' : pct >= 50 ? 'Some Issues Found' : 'Needs Optimization') + '</div>'
      + '<div class="text-sm text-text-muted">Based on the details you provided. Address the issues below to improve web performance.</div>'
      + '</div></div>';

    // Checklist
    var checklistEl = document.getElementById('checklist');
    checklistEl.innerHTML = '';
    // Sort: failures first, then passes
    items.sort(function (a, b) {
      if (a.pass === b.pass) return 0;
      return a.pass ? 1 : -1;
    });
    items.forEach(function (item) {
      var div = document.createElement('div');
      var priorityBadge = !item.pass && item.priority ? '<span class="ml-2 text-xs px-2 py-0.5 rounded-full border ' + (item.priority === 'high' ? 'bg-red-500/10 border-red-500/30 text-red-400' : item.priority === 'medium' ? 'bg-yellow-500/10 border-yellow-500/30 text-yellow-400' : 'bg-blue-500/10 border-blue-500/30 text-blue-400') + '">' + item.priority + '</span>' : '';
      div.className = 'flex items-start gap-3 p-4 rounded-xl border ' + (item.pass ? 'bg-green-500/5 border-green-500/20' : 'bg-bg-card border-border');
      div.innerHTML = '<span class="shrink-0 text-lg mt-0.5">' + (item.pass ? '✅' : '⚠️') + '</span>'
        + '<div class="flex-1">'
        + '<div class="font-medium text-sm">' + item.title + priorityBadge + '</div>'
        + '<div class="text-xs text-text-muted mt-1">' + item.detail + '</div>'
        + (item.code ? '<code class="block mt-2 text-xs font-mono bg-bg px-2 py-1 rounded border border-border text-primary">' + item.code + '</code>' : '')
        + '</div>';
      checklistEl.appendChild(div);
    });

    // srcset card
    if (w && w > 600 && usage !== 'icon') {
      var s1 = Math.round(w * 0.25);
      var s2 = Math.round(w * 0.5);
      var s3 = Math.round(w * 0.75);
      var srcsetCode = '<img\n  src="image.webp"\n  srcset="\n    image-' + s1 + 'w.webp ' + s1 + 'w,\n    image-' + s2 + 'w.webp ' + s2 + 'w,\n    image-' + s3 + 'w.webp ' + s3 + 'w,\n    image-' + w + 'w.webp ' + w + 'w\n  "\n  sizes="(max-width: 640px) 100vw, (max-width: 1024px) 75vw, 50vw"' + (w ? '\n  width="' + w + '"' : '') + (h ? ' height="' + h + '"' : '') + '\n  alt="Description of image"' + (usage !== 'hero' ? '\n  loading="lazy"' : '') + '\n/>';
      document.getElementById('srcset-code').textContent = srcsetCode;
      document.getElementById('srcset-card').classList.remove('hidden');
    } else {
      document.getElementById('srcset-card').classList.add('hidden');
    }

    document.getElementById('results').classList.remove('hidden');
    document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });

  document.getElementById('reset-btn').addEventListener('click', function () {
    ['img-width', 'img-height', 'img-size'].forEach(function (id) { document.getElementById(id).value = ''; });
    document.getElementById('img-format').value = '';
    document.getElementById('img-usage').value = '';
    document.getElementById('img-transparency').value = 'no';
    document.getElementById('results').classList.add('hidden');
  });

  document.getElementById('copy-srcset').addEventListener('click', function () {
    var code = document.getElementById('srcset-code').textContent;
    navigator.clipboard.writeText(code).then(function () {
      document.getElementById('copy-srcset').textContent = 'Copied!';
      setTimeout(function () { document.getElementById('copy-srcset').textContent = 'Copy'; }, 2000);
    });
  });
})();
</script>
