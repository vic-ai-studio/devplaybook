---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CorsTester from '../../components/CorsTester.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is CORS and why does it block requests?",
    answer: "CORS (Cross-Origin Resource Sharing) is a browser security mechanism that restricts web pages from making requests to a different origin (domain, protocol, or port) than the one that served the page. Browsers enforce this to prevent malicious scripts from accessing sensitive data on other sites. The server must explicitly permit cross-origin requests by sending the correct Access-Control-Allow-Origin header.",
  },
  {
    question: "What is a preflight request?",
    answer: "A preflight request is an HTTP OPTIONS request that browsers send automatically before certain cross-origin requests — specifically those using methods other than GET/POST, or custom headers. The server must respond with the correct Access-Control headers to signal that the actual request is allowed. If the preflight fails, the browser blocks the real request entirely.",
  },
  {
    question: "Why does Access-Control-Allow-Origin: * not work with credentials?",
    answer: "When you send credentials (cookies, HTTP auth, or client-side certificates), browsers require Access-Control-Allow-Origin to be an explicit origin, not a wildcard (*). Additionally, the server must include Access-Control-Allow-Credentials: true. Using * with credentials is explicitly forbidden by the CORS spec — the browser will reject the response even if the server sends both.",
  },
  {
    question: "How do I fix a CORS error on my API?",
    answer: "Add the correct Access-Control-Allow-Origin header to your API responses. For public APIs, use *. For credentialed requests, reflect the requesting origin dynamically. For preflight support, also handle OPTIONS requests and return Access-Control-Allow-Methods and Access-Control-Allow-Headers. Most frameworks have CORS middleware: Express (cors package), FastAPI (CORSMiddleware), Django (django-cors-headers), etc.",
  },
  {
    question: "What CORS headers should my API return?",
    answer: "The minimum is Access-Control-Allow-Origin. For full functionality: Access-Control-Allow-Methods (e.g. GET, POST, PUT, DELETE, OPTIONS), Access-Control-Allow-Headers (e.g. Content-Type, Authorization), Access-Control-Allow-Credentials: true (if using cookies), Access-Control-Expose-Headers (for custom response headers your client needs to read), and Access-Control-Max-Age (cache duration for preflight results, e.g. 86400 for 24 hours).",
  },
  {
    question: "Why can't I test CORS for localhost URLs in production tools?",
    answer: "Localhost URLs (http://localhost:*) are not reachable from external servers or most proxy-based testing tools. This tester sends requests directly from your browser, so localhost URLs work fine as long as the target server is running on your machine. No proxy is involved — your browser makes the actual cross-origin request.",
  },
];
---

<BaseLayout
  title="CORS Tester — Test Cross-Origin Request Headers Online"
  description="Test CORS for any URL. Send cross-origin requests, inspect Access-Control headers, and diagnose preflight OPTIONS responses. Free, no install needed."
  tool="CORS Tester, CORS Header Checker, Cross-Origin Request Tester, CORS Debugger, Preflight Request Tester"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "CORS Tester",
    "url": "https://devplaybook.cc/tools/cors-tester",
    "description": "Test CORS headers for any URL. Send real cross-origin requests from your browser, inspect Access-Control headers, and diagnose preflight issues.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">CORS Tester</h1>
  <p class="text-text-muted mb-4">
    Send real cross-origin requests from your browser, inspect CORS response headers, and diagnose preflight issues.
    Understand exactly why a request is blocked — no proxy, no server needed.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Real browser requests (no proxy)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Preflight OPTIONS analysis</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Access-Control header breakdown</span>
  </div>
  <CorsTester client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CORS Tester" relatedTags={['cors', 'api', 'http', 'security', 'web']} />
</BaseLayout>
