---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CorsTester from '../../components/CorsTester.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="CORS Tester"
  description="Test CORS headers for any URL. Send real cross-origin requests, analyze preflight OPTIONS responses, and diagnose Access-Control header issues instantly."
  tool="CORS Tester, CORS Header Checker, Cross-Origin Request Tester"
>
  <h1 class="text-3xl font-bold mb-2">CORS Tester</h1>
  <p class="text-text-muted mb-8">Send real cross-origin requests from your browser, inspect CORS response headers, and diagnose preflight issues. Understand exactly why a request is blocked.</p>
  <CorsTester client:only="preact" />
  <ToolPageCta currentTool="CORS Tester" relatedTags={['cors', 'api', 'http', 'security', 'web']} />
</BaseLayout>
