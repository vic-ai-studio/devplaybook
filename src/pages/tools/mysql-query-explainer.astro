---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MysqlQueryExplainer from '../../components/MysqlQueryExplainer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What does the MySQL Query Explainer do?",
    answer: "It parses your MySQL query and produces a plain-English walkthrough of each execution step — FROM, JOIN, WHERE, GROUP BY, HAVING, ORDER BY, LIMIT — plus optimization hints for common performance pitfalls like SELECT *, missing indexes, leading-wildcard LIKE, or UPDATE/DELETE without WHERE."
  },
  {
    question: "Does this tool actually run my query against a database?",
    answer: "No. The analysis runs entirely in your browser using JavaScript pattern matching. Your query is never sent to any server. It provides heuristic explanations — for the true MySQL execution plan, use EXPLAIN or EXPLAIN ANALYZE in your MySQL client."
  },
  {
    question: "What is EXPLAIN and when should I use it?",
    answer: "EXPLAIN SELECT ... shows the query execution plan MySQL chose: which indexes it uses, the join order, estimated row counts, and whether it does a full table scan. In MySQL 8.0+, EXPLAIN ANALYZE actually runs the query and shows real timing data. Always run EXPLAIN on slow queries before optimizing."
  },
  {
    question: "Why is SELECT * bad for performance?",
    answer: "SELECT * fetches every column from every matched row, including large TEXT/BLOB columns you may not need. It prevents 'covering index' optimizations where MySQL can answer the query from the index alone without touching the actual rows. Always select only the columns your application needs."
  },
  {
    question: "What is the difference between WHERE and HAVING?",
    answer: "WHERE filters rows before grouping and aggregation — it is evaluated early and can use indexes. HAVING filters after GROUP BY and aggregation, so it sees aggregate results like COUNT(*) or SUM(amount). If you can express a filter in WHERE instead of HAVING, do so — it is more efficient."
  },
  {
    question: "Why is LIKE '%search%' slow?",
    answer: "A leading wildcard forces MySQL to scan every row because it cannot use a B-tree index to skip rows (there is no known prefix). For full-text search, use MySQL FULLTEXT indexes with MATCH ... AGAINST. For pattern matching on large datasets, consider Elasticsearch or similar search engines."
  },
];
---

<BaseLayout
  title="MySQL Query Explainer — Understand & Optimize SQL Queries"
  description="Paste any MySQL query and get a plain-English explanation of each execution step plus optimization hints. Covers SELECT, JOIN, GROUP BY, HAVING, UPDATE, DELETE, and CREATE TABLE. Free, runs in your browser."
  tool="MySQL query explainer, SQL query analyzer, MySQL optimizer, explain MySQL query, SQL performance tips, MySQL EXPLAIN tool"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "MySQL Query Explainer",
    "url": "https://devplaybook.cc/tools/mysql-query-explainer",
    "description": "Explain MySQL queries in plain English with execution steps and optimization hints. Free, runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">MySQL Query Explainer</h1>
  <p class="text-text-muted mb-4">
    Paste any MySQL query — SELECT, INSERT, UPDATE, DELETE, or CREATE TABLE — and get a plain-English breakdown of how MySQL will execute it, plus optimization hints for common performance issues. Runs 100% in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Step-by-step execution walkthrough</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Optimization hints included</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No data sent to server</span>
  </div>
  <MysqlQueryExplainer client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="MySQL Query Explainer" relatedTags={['mysql', 'sql', 'database', 'performance', 'query', 'backend']} />
</BaseLayout>
