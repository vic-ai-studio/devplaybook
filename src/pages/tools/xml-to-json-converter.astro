---
import BaseLayout from '../../layouts/BaseLayout.astro';
import XmlToJsonConverter from '../../components/XmlToJsonConverter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How are XML attributes converted to JSON?", answer: "XML attributes are prefixed with @ in the JSON output. For example, <book category=\"fiction\"> becomes { \"@category\": \"fiction\" }. This convention is used by many XML-to-JSON libraries including xml2js and fast-xml-parser." },
  { question: "What happens to XML text nodes?", answer: "If an element has only text content and no attributes, its value is the JSON value directly (e.g. <title>Clean Code</title> becomes \"title\": \"Clean Code\"). If the element also has attributes, the text goes into a special #text key alongside the attributes." },
  { question: "How are repeated XML elements handled?", answer: "When multiple sibling elements share the same tag name, they are combined into a JSON array. For example, two <book> elements become \"book\": [{...}, {...}]. A single element remains a plain object, not a one-element array." },
  { question: "Are booleans and numbers preserved?", answer: "Yes. Text values that look like true, false, or numbers are automatically cast to their native JSON types. So <inStock>true</inStock> becomes \"inStock\": true and <price>12.99</price> becomes \"price\": 12.99. This matches common XML parsing behavior." },
  { question: "Does it support XML namespaces?", answer: "Namespace prefixes are preserved as-is in the key names (e.g. <soap:Body> becomes \"soap:Body\"). Namespace declarations (xmlns:*) appear as @xmlns attributes. Full namespace URI resolution is not performed." },
  { question: "Is my XML data sent to any server?", answer: "No. All conversion uses the browser's built-in DOMParser API. Your XML data never leaves your machine — safe for sensitive data, internal API responses, and enterprise XML documents." },
];
---

<BaseLayout
  title="XML to JSON Converter — Free Online Tool | Paste XML Get JSON"
  description="Convert XML to JSON instantly. Attributes become @-prefixed keys, repeated elements become arrays, and text values are type-cast to booleans and numbers. Free, runs 100% in your browser."
  tool="XML to JSON converter, convert XML JSON, XML JSON online, XML to JSON free, parse XML JavaScript, DOMParser JSON, SOAP to JSON"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "XML to JSON Converter",
    "url": "https://devplaybook.cc/tools/xml-to-json-converter",
    "description": "Convert XML to JSON instantly with attribute handling, array detection, and type casting. Free, runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">XML to JSON Converter</h1>
  <p class="text-text-muted mb-4">
    Paste XML and get clean JSON output instantly. Attributes become <code class="bg-bg-secondary px-1 rounded text-sm">@key</code> fields, repeated elements become arrays, and <code class="bg-bg-secondary px-1 rounded text-sm">true</code>/<code class="bg-bg-secondary px-1 rounded text-sm">false</code>/numbers are auto-cast. Useful for REST API migration, config parsing, and SOAP response handling.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Type-aware conversion</span>
  </div>
  <XmlToJsonConverter client:only="preact" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more free developer tools?</p>
    <a href="/tools" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Browse All Free Tools →</a>
  </div>
  <ToolPageCta currentTool="XML to JSON Converter" relatedTags={['xml', 'json', 'converter', 'parser', 'soap', 'api']} />
</BaseLayout>
