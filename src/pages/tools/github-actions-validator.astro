---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GithubActionsValidator from '../../components/GithubActionsValidator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What does this GitHub Actions validator check?",
    answer: "It checks for required fields (on, jobs, runs-on, steps), unpinned action versions, hardcoded secrets, missing checkout step, overly broad push triggers, missing permissions blocks, and YAML syntax issues like tab characters. All validation runs in your browser — nothing is sent to any server."
  },
  {
    question: "Why should I pin action versions?",
    answer: "Using @main or @master means your workflow pulls the latest (possibly broken) version of an action on every run. Pin to a specific version tag (e.g. actions/checkout@v4) or a full commit SHA for reproducible, secure builds. Mutable refs are also a supply chain attack vector — a compromised action could inject malicious code into your pipeline."
  },
  {
    question: "How do I store secrets in GitHub Actions?",
    answer: "Never hardcode secrets in workflow YAML. Add them in your repository or organization settings under Settings → Secrets and variables → Actions. Reference them in workflows with ${{ secrets.SECRET_NAME }}. For environment-specific secrets, use environment protection rules."
  },
  {
    question: "What is the concurrency group and why should I use it?",
    answer: "The concurrency key lets you group related workflow runs and cancel outdated ones. For example: concurrency: { group: 'ci-${{ github.ref }}', cancel-in-progress: true }. This cancels previous CI runs on the same branch when you push again, saving CI minutes and reducing queue buildup."
  },
  {
    question: "What permissions should I set on my workflows?",
    answer: "Add a top-level permissions block with the minimum required. For read-only CI: permissions: { contents: read }. For workflows that publish packages or deploy: grant only the specific write permission needed (e.g. packages: write). Starting from a deny-all base prevents accidental over-permissioning."
  },
  {
    question: "Why does my workflow trigger on every branch push?",
    answer: "If you use 'on: push:' without a branches or paths filter, the workflow runs on every push to any branch. Add branches: [main] or paths: ['src/**'] to scope it. For PRs, pull_request already filters to the target branch by default."
  },
];
---

<BaseLayout
  title="GitHub Actions YAML Validator — Lint Workflow Files Online"
  description="Free online GitHub Actions workflow validator. Checks for missing fields, unpinned action versions, hardcoded secrets, trigger misconfiguration, and security best practices. Runs in your browser."
  tool="GitHub Actions validator, workflow YAML linter, GitHub CI checker, Actions workflow validator, GitHub workflow syntax checker"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "GitHub Actions YAML Validator",
    "url": "https://devplaybook.cc/tools/github-actions-validator",
    "description": "Validate GitHub Actions workflow YAML for required fields, unpinned actions, hardcoded secrets, and CI/CD best practices. Runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">GitHub Actions YAML Validator</h1>
  <p class="text-text-muted mb-4">
    Paste your workflow YAML and instantly catch missing fields, unpinned action versions, hardcoded secrets, and security misconfigurations. No login required — runs 100% in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 8 validation checks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Security best practices</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <GithubActionsValidator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="GitHub Actions YAML Validator" relatedTags={['devops', 'ci-cd', 'github', 'yaml', 'security', 'automation']} />
</BaseLayout>
