---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const migrationExample = `# Rome (the old tool) is no longer maintained.
# If you have @romefrontend/rome or rome installed, uninstall it:
npm remove rome @romefrontend/rome

# Remove Rome config files if present
rm rome.json

# Install Biome — the active successor
npm add -D @biomejs/biome

# Initialize Biome's config
npx @biomejs/biome init

# Run check (lint + format)
npx @biomejs/biome check --write .`;

const biomejsonExample = `// biome.json — Biome's single config file (replaces rome.json)
{
  "$schema": "https://biomejs.dev/schemas/1.6.0/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  }
}`;

const historyTimeline = `# Rome project timeline
# 2020 — Sebastian McKenzie (Babel creator) announces Rome
#         Goal: unify all JS tooling (compiler, bundler, linter, formatter, test runner)
#         Built in TypeScript initially
#
# 2021 — Rome Tools Inc. formed, seed funding raised
#         Rome v1 (TypeScript) released — formatter and linter only
#
# 2022 — Rome rewrites its core in Rust
#         Performance improves dramatically
#         rome.json config file introduced
#
# 2023 Q3 — Rome Tools Inc. goes quiet, maintenance stalls
#            Community forks the Rust codebase
#
# 2023 Aug — Fork renamed "Biome", new GitHub org: biomejs
#            First Biome release (v1.0) ships under new leadership
#
# Today  — Rome is unmaintained; Biome is the active successor
#           All Rome users should migrate to Biome`;

const faq = [
  {
    question: "What happened to Rome tools?",
    answer: "Rome Tools Inc., the company behind the Rome project, went inactive in mid-2023. The team stopped maintaining the repository and responding to issues. The open-source community forked the Rust-based codebase, renamed it Biome, and created a new GitHub organization (biomejs). The first Biome release (v1.0) shipped in August 2023. Rome itself is no longer maintained and should not be used for new projects."
  },
  {
    question: "Why was Rome renamed to Biome?",
    answer: "Rome was not simply renamed — it was forked. After Rome Tools Inc. stopped maintaining the project, community contributors could not get write access to the original Rome repository. They created a hard fork under a new name, Biome, to allow continued development. The name change was a legal and organizational necessity: Biome is an independent project with its own governance, maintainers, and npm packages under the @biomejs scope."
  },
  {
    question: "How do I migrate from Rome to Biome?",
    answer: "Migration is straightforward. Uninstall the rome npm package and delete your rome.json. Install @biomejs/biome and run biome init to generate a biome.json. The configuration structure is nearly identical — most rome.json settings have direct biome.json equivalents. Run biome check --write . to reformat and lint your codebase with Biome's current defaults."
  },
  {
    question: "Who maintains Biome?",
    answer: "Biome is maintained by an independent open-source collective. Key contributors include Emanuele Stoppa and Victorien Elvinger among others, along with a broader community of contributors on GitHub (github.com/biomejs/biome). The project is not backed by a venture-funded company — it is community-maintained and funded through GitHub Sponsors and Open Collective."
  },
  {
    question: "Is Rome still maintained?",
    answer: "No. The original Rome repository (github.com/rome/tools) is no longer actively maintained as of 2023. It receives no bug fixes, security patches, or new features. The npm package 'rome' is outdated and should not be used. All development effort has moved to Biome, which is the only actively supported continuation of Rome's ideas."
  },
  {
    question: "What was Rome originally trying to build?",
    answer: "Rome's original ambition was to unify the entire JavaScript toolchain into a single project: compiler, bundler, linter, formatter, test runner, and type checker — all with zero external dependencies. It was inspired by similar all-in-one toolchains from other language ecosystems (like Go's toolchain or Rust's cargo). The project successfully shipped a linter and formatter but never reached full compiler or bundler functionality before the fork occurred."
  },
];
---

<BaseLayout
  title="Rome Tools — Now Continued as Biome (Migration Guide)"
  description="Rome tools is no longer maintained. The project was forked in 2023 and continues as Biome — a unified Rust-based linter and formatter for JavaScript and TypeScript. Learn the history and how to migrate."
  tool="rome tools, rome javascript, rome formatter, rome linter, biome migration, rome to biome, rome deprecated, biomejs"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Rome Tools — Now Continued as Biome",
    "url": "https://devplaybook.cc/tools/rome",
    "description": "Rome tools is no longer maintained. The project was forked in 2023 and continues as Biome, a unified Rust-based linter and formatter for JavaScript and TypeScript.",
  })} />

  <!-- Notice banner -->
  <div class="bg-yellow-900/30 border border-yellow-600/50 rounded-xl p-4 mb-6">
    <div class="flex items-start gap-3">
      <span class="text-yellow-400 text-lg leading-tight mt-0.5">⚠</span>
      <div>
        <p class="font-semibold text-yellow-300 mb-1">Rome has been forked and is now maintained as Biome</p>
        <p class="text-text-muted text-sm leading-relaxed">
          The Rome project went inactive in 2023. The community forked the codebase and released it as
          <strong class="text-text">Biome</strong> (biomejs.dev). Rome itself is no longer maintained.
          If you are looking for a modern JavaScript/TypeScript linter and formatter, use Biome instead.
        </p>
        <a
          href="/tools/biome"
          class="inline-block mt-3 px-4 py-1.5 bg-yellow-600/20 hover:bg-yellow-600/40 border border-yellow-600/50 rounded-lg text-yellow-300 text-sm font-medium transition-colors"
        >
          Go to the Biome page →
        </a>
      </div>
    </div>
  </div>

  <h1 class="text-3xl font-bold mb-2">Rome Tools</h1>
  <p class="text-text-muted mb-6">
    Rome was an ambitious unified JavaScript toolchain project aiming to replace
    Babel, ESLint, Prettier, and more with a single fast tool.
    The project went inactive in 2023 and was forked by the community as <strong>Biome</strong>.
    This page documents Rome's history and provides a clear migration path.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-red-400">✗</span> No longer maintained</span>
    <span class="flex items-center gap-1.5"><span class="text-red-400">✗</span> npm package outdated</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Fork: Biome is actively maintained</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Migration path is simple</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> rome.json → biome.json</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Rome?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Rome was an open-source JavaScript toolchain project started by <strong>Sebastian McKenzie</strong>, the creator of Babel. Its goal was extraordinarily ambitious: build a single unified tool to replace the entire JavaScript ecosystem's fragmented toolchain — compiler, bundler, linter, formatter, type checker, and test runner — with zero external dependencies.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    Rome successfully shipped a <strong>linter and formatter</strong> — initially written in TypeScript, then rewritten in Rust for dramatic performance gains. The Rust rewrite produced excellent results, but Rome Tools Inc., the company formed to commercialize the project, went quiet in mid-2023. Maintenance stopped, issues went unanswered, and the community had no path to contribute.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">The Fork: How Rome Became Biome</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    In August 2023, a group of Rome contributors — unable to get write access to the dormant Rome repository — forked the Rust codebase and published it under a new name: <strong>Biome</strong>. The new project lives at <a href="https://biomejs.dev/" class="underline hover:text-text" target="_blank" rel="noopener">biomejs.dev</a> and on GitHub at <code class="bg-bg-card px-1 rounded text-xs">github.com/biomejs/biome</code>.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    Biome v1.0 shipped immediately after the fork and has continued to ship frequent releases. The npm package moved from <code class="bg-bg-card px-1 rounded text-xs">rome</code> to <code class="bg-bg-card px-1 rounded text-xs">@biomejs/biome</code>. The config file moved from <code class="bg-bg-card px-1 rounded text-xs">rome.json</code> to <code class="bg-bg-card px-1 rounded text-xs">biome.json</code>.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Project History Timeline</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={historyTimeline}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Migrating from Rome to Biome</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Migration is simple. Uninstall the old <code class="bg-bg-card px-1 rounded text-xs">rome</code> package, install <code class="bg-bg-card px-1 rounded text-xs">@biomejs/biome</code>, and replace <code class="bg-bg-card px-1 rounded text-xs">rome.json</code> with a new <code class="bg-bg-card px-1 rounded text-xs">biome.json</code>. The configuration structure is nearly identical.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={migrationExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Biome Configuration (biome.json)</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    If you had a <code class="bg-bg-card px-1 rounded text-xs">rome.json</code>, here is what the equivalent <code class="bg-bg-card px-1 rounded text-xs">biome.json</code> looks like. The schema is fully typed and documented at <a href="https://biomejs.dev/reference/configuration/" class="underline hover:text-text" target="_blank" rel="noopener">biomejs.dev/reference/configuration</a>.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={biomejsonExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Rome vs Biome at a Glance</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Aspect</th>
          <th class="border border-border px-3 py-2 text-left">Rome (original)</th>
          <th class="border border-border px-3 py-2 text-left">Biome (fork/successor)</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2">Maintenance status</td><td class="border border-border px-3 py-2 text-red-400">Abandoned (2023)</td><td class="border border-border px-3 py-2 text-green-400">Actively maintained</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">npm package</td><td class="border border-border px-3 py-2 text-red-400">rome (outdated)</td><td class="border border-border px-3 py-2 text-green-400">@biomejs/biome</td></tr>
        <tr><td class="border border-border px-3 py-2">Config file</td><td class="border border-border px-3 py-2">rome.json</td><td class="border border-border px-3 py-2 text-green-400">biome.json</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">GitHub repo</td><td class="border border-border px-3 py-2 text-red-400">rome/tools (archived)</td><td class="border border-border px-3 py-2 text-green-400">biomejs/biome (active)</td></tr>
        <tr><td class="border border-border px-3 py-2">Lint rules</td><td class="border border-border px-3 py-2">~100 rules</td><td class="border border-border px-3 py-2 text-green-400">200+ rules (and growing)</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Security patches</td><td class="border border-border px-3 py-2 text-red-400">None</td><td class="border border-border px-3 py-2 text-green-400">Yes</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Should I Use Rome Today?</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-red-400 mb-2">Rome (do not use)</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✗ No longer maintained since 2023</li>
        <li>✗ No security updates or bug fixes</li>
        <li>✗ npm package is outdated</li>
        <li>✗ GitHub issues go unanswered</li>
        <li>✗ Will fall further behind modern JS/TS features</li>
      </ul>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-green-400 mb-2">Biome (use this instead)</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✓ Actively maintained with frequent releases</li>
        <li>✓ 200+ lint rules and Prettier-compatible formatter</li>
        <li>✓ Direct successor with same Rust codebase</li>
        <li>✓ Migration from rome.json is trivial</li>
        <li>✓ Large and growing contributor community</li>
      </ul>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="rome" relatedTags={['linting', 'formatting', 'javascript', 'deprecated', 'biome', 'typescript']} />
</BaseLayout>
