---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AwsIamPolicyGenerator from '../../components/AwsIamPolicyGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is an AWS IAM policy?", answer: "An IAM (Identity and Access Management) policy is a JSON document that defines permissions in AWS. It specifies what actions are allowed or denied, on which resources, and under what conditions. Policies are attached to IAM users, groups, or roles to grant or restrict access." },
  { question: "What is the difference between Allow and Deny?", answer: "By default everything is denied. Allow explicitly permits an action. Deny explicitly blocks it and overrides any Allow. If multiple policies apply, an explicit Deny always wins — even if another policy allows the same action. Use Deny sparingly, usually for security guardrails." },
  { question: "What does '*' mean as a resource?", answer: "The wildcard '*' means all resources of the matched type. For example, Action: s3:ListBucket with Resource: '*' allows listing all S3 buckets. For tighter security, specify exact ARNs like arn:aws:s3:::my-specific-bucket." },
  { question: "What is an ARN?", answer: "An Amazon Resource Name (ARN) uniquely identifies any AWS resource. Format: arn:partition:service:region:account-id:resource. For example, arn:aws:s3:::my-bucket or arn:aws:lambda:us-east-1:123456789012:function:my-function. S3 bucket ARNs omit region and account ID." },
  { question: "What are IAM conditions?", answer: "Conditions add extra constraints to when a policy applies. Common examples: aws:SourceIp to restrict by IP range, aws:SecureTransport to require HTTPS, aws:RequestedRegion to restrict to specific AWS regions, aws:MultiFactorAuthPresent to require MFA." },
  { question: "What is the principle of least privilege?", answer: "Least privilege means granting only the minimum permissions required to perform a task. Instead of s3:* (all S3 actions), grant only the specific actions needed — e.g., s3:GetObject and s3:ListBucket. This limits the blast radius if credentials are compromised." },
];
---

<BaseLayout
  title="AWS IAM Policy Generator — Visual JSON Policy Builder"
  description="Free visual AWS IAM policy generator. Select service, actions, resources, and conditions to build valid IAM policy JSON. No sign-up required — runs in your browser."
  tool="AWS IAM policy generator, IAM policy builder, AWS permissions JSON, IAM policy tool, AWS access control, IAM statement generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">AWS IAM Policy Generator</h1>
  <p class="text-text-muted mb-4">Build AWS IAM policy JSON visually. Select the AWS service, toggle individual actions, set the resource ARN, and optionally add conditions — then copy the valid policy JSON ready to paste into the AWS Console or Terraform.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 10+ AWS services supported</span>
  </div>
  <AwsIamPolicyGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="AWS IAM Policy Generator" relatedTags={['aws', 'cloud', 'devops', 'security', 'infrastructure']} />
</BaseLayout>
