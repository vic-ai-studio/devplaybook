---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is OpenAPI / Swagger?", answer: "OpenAPI (formerly Swagger) is a standard specification for describing RESTful APIs. It allows you to document endpoints, parameters, request bodies, and responses in a machine-readable format (YAML or JSON) that tools can use to generate docs, client SDKs, and server stubs." },
  { question: "What is the difference between OpenAPI 3.0 and Swagger 2.0?", answer: "Swagger 2.0 is the older spec. OpenAPI 3.0 introduced components/schemas (replacing definitions), requestBody (replacing body parameters), and better support for multiple servers. OpenAPI 3.1 aligns fully with JSON Schema." },
  { question: "Can I use this YAML with Swagger UI?", answer: "Yes. The generated YAML is valid OpenAPI 3.0 and works directly with Swagger UI, Redoc, Stoplight, and any OpenAPI-compatible tool. You can paste it into editor.swagger.io to preview it." },
  { question: "What are path parameters vs query parameters?", answer: "Path parameters are part of the URL path (e.g., /users/{id}). Query parameters are appended after ? (e.g., /users?role=admin). Path parameters are typically required; query parameters are often optional filters." },
  { question: "What is a requestBody in OpenAPI?", answer: "A requestBody describes the payload sent in POST/PUT/PATCH requests. It typically contains a JSON schema describing the expected fields. In OpenAPI 3.0, requestBody is defined separately from parameters." },
];
---

<BaseLayout
  title="OpenAPI Code Generator — YAML/JSON Spec Builder — Free Online Tool"
  description="Generate OpenAPI 3.0 YAML from endpoint inputs. Add paths, methods, parameters, and schemas visually — copy-ready for Swagger UI and Redoc. Free."
  tool="OpenAPI generator, Swagger YAML generator, REST API spec builder, OpenAPI 3.0 generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">OpenAPI Code Generator</h1>
  <p class="text-text-muted mb-4">Build an OpenAPI 3.0 specification visually. Define your API info, add endpoints with methods and parameters, then copy the YAML for Swagger UI, Redoc, or code generation tools.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Left: Form -->
    <div class="space-y-4">
      <!-- API Info -->
      <div class="bg-surface border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">API Info</h2>
        <div class="space-y-3">
          <div>
            <label class="block text-xs text-text-muted mb-1">Title</label>
            <input id="oa-title" type="text" value="My API" class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent" />
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs text-text-muted mb-1">Version</label>
              <input id="oa-version" type="text" value="1.0.0" class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">Base URL</label>
              <input id="oa-server" type="text" value="https://api.example.com/v1" class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent" />
            </div>
          </div>
          <div>
            <label class="block text-xs text-text-muted mb-1">Description</label>
            <input id="oa-desc" type="text" placeholder="Optional API description" class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent" />
          </div>
        </div>
      </div>

      <!-- Add Endpoint -->
      <div class="bg-surface border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">Add Endpoint</h2>
        <div class="space-y-3">
          <div class="flex gap-2">
            <select id="oa-method" class="bg-background border border-border rounded-lg px-2 py-2 text-sm font-mono font-bold focus:outline-none focus:border-accent w-28">
              <option value="get">GET</option>
              <option value="post">POST</option>
              <option value="put">PUT</option>
              <option value="patch">PATCH</option>
              <option value="delete">DELETE</option>
            </select>
            <input id="oa-path" type="text" placeholder="/users/{id}" autocomplete="off"
              class="flex-1 bg-background border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-accent" />
          </div>
          <div>
            <label class="block text-xs text-text-muted mb-1">Summary</label>
            <input id="oa-summary" type="text" placeholder="Get user by ID" autocomplete="off"
              class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent" />
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs text-text-muted mb-1">Tag / Group</label>
              <input id="oa-tag" type="text" placeholder="users" autocomplete="off"
                class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent" />
            </div>
            <div>
              <label class="block text-xs text-text-muted mb-1">Response Status</label>
              <select id="oa-status" class="w-full bg-background border border-border rounded-lg px-2 py-2 text-sm focus:outline-none focus:border-accent">
                <option value="200">200 OK</option>
                <option value="201">201 Created</option>
                <option value="204">204 No Content</option>
              </select>
            </div>
          </div>
          <div>
            <label class="flex items-center gap-2 text-xs mb-1 cursor-pointer">
              <input type="checkbox" id="oa-has-body" class="accent-accent" />
              Has request body (POST/PUT/PATCH)
            </label>
            <div id="oa-body-fields" class="hidden space-y-2 mt-2 p-3 bg-background border border-border rounded-lg">
              <p class="text-xs text-text-muted mb-1">Body fields (one per line: fieldName:type e.g. name:string, age:integer)</p>
              <textarea id="oa-body-schema" rows="3" placeholder="name:string&#10;age:integer&#10;email:string"
                class="w-full bg-surface border border-border rounded px-2 py-1.5 text-xs font-mono focus:outline-none focus:border-accent resize-none"></textarea>
            </div>
          </div>
          <button id="oa-add-endpoint" class="bg-accent hover:bg-accent/80 text-white font-medium px-4 py-2 rounded-lg text-sm transition-colors">
            Add Endpoint
          </button>
        </div>

        <!-- Endpoint list -->
        <div id="oa-endpoints-list" class="mt-4 space-y-2"></div>
      </div>
    </div>

    <!-- Right: Output -->
    <div class="bg-surface border border-border rounded-xl p-5 flex flex-col">
      <div class="flex items-center justify-between mb-3">
        <div class="flex gap-2">
          <button id="oa-fmt-yaml" class="text-xs px-3 py-1.5 rounded-lg bg-accent text-white font-medium">YAML</button>
          <button id="oa-fmt-json" class="text-xs px-3 py-1.5 rounded-lg bg-background border border-border hover:bg-accent/20 transition-colors">JSON</button>
        </div>
        <button id="oa-copy" class="text-xs bg-background border border-border hover:bg-accent/20 px-3 py-1.5 rounded-lg transition-colors">Copy</button>
      </div>
      <pre id="oa-output" class="flex-1 bg-background border border-border rounded-lg p-4 text-xs font-mono overflow-auto whitespace-pre min-h-[400px]"></pre>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="OpenAPI Code Generator" relatedTags={['api', 'openapi', 'swagger', 'rest', 'backend']} />
</BaseLayout>

<script>
(function () {
  let endpoints = [
    { method: 'get', path: '/users', summary: 'List all users', tag: 'users', status: '200', hasBody: false, bodyFields: '' },
    { method: 'post', path: '/users', summary: 'Create a new user', tag: 'users', status: '201', hasBody: true, bodyFields: 'name:string\nemail:string\nrole:string' },
    { method: 'get', path: '/users/{id}', summary: 'Get user by ID', tag: 'users', status: '200', hasBody: false, bodyFields: '' },
    { method: 'delete', path: '/users/{id}', summary: 'Delete user', tag: 'users', status: '204', hasBody: false, bodyFields: '' },
  ];
  let outputFormat = 'yaml';

  const METHOD_COLORS = { get: 'text-green-400', post: 'text-blue-400', put: 'text-yellow-400', patch: 'text-orange-400', delete: 'text-red-400' };

  function getInfo() {
    return {
      title: document.getElementById('oa-title').value || 'My API',
      version: document.getElementById('oa-version').value || '1.0.0',
      server: document.getElementById('oa-server').value || 'https://api.example.com/v1',
      description: document.getElementById('oa-desc').value || '',
    };
  }

  function extractPathParams(path) {
    const matches = path.match(/\{([^}]+)\}/g) || [];
    return matches.map(m => m.replace(/[{}]/g, ''));
  }

  function parseBodyFields(raw) {
    if (!raw.trim()) return {};
    const props = {};
    raw.trim().split('\n').forEach(line => {
      const [name, type = 'string'] = line.split(':').map(s => s.trim());
      if (name) props[name] = { type: type.toLowerCase() };
    });
    return props;
  }

  function buildSpec() {
    const info = getInfo();
    const spec = {
      openapi: '3.0.3',
      info: { title: info.title, version: info.version, ...(info.description ? { description: info.description } : {}) },
      servers: [{ url: info.server }],
      paths: {},
    };

    endpoints.forEach(ep => {
      if (!spec.paths[ep.path]) spec.paths[ep.path] = {};
      const pathParams = extractPathParams(ep.path);
      const operation = {
        summary: ep.summary || `${ep.method.toUpperCase()} ${ep.path}`,
        ...(ep.tag ? { tags: [ep.tag] } : {}),
        ...(pathParams.length ? {
          parameters: pathParams.map(p => ({
            name: p, in: 'path', required: true,
            schema: { type: 'string' },
          }))
        } : {}),
        responses: {
          [ep.status]: {
            description: ep.status === '204' ? 'No Content' : ep.status === '201' ? 'Created' : 'Success',
            ...(ep.status !== '204' ? {
              content: {
                'application/json': {
                  schema: { type: 'object', properties: { success: { type: 'boolean' } } }
                }
              }
            } : {})
          }
        }
      };

      if (ep.hasBody && ep.bodyFields) {
        const props = parseBodyFields(ep.bodyFields);
        operation.requestBody = {
          required: true,
          content: {
            'application/json': {
              schema: { type: 'object', properties: props }
            }
          }
        };
      }

      spec.paths[ep.path][ep.method] = operation;
    });

    return spec;
  }

  function objToYaml(obj, indent = 0) {
    const pad = ' '.repeat(indent);
    const lines = [];
    for (const [k, v] of Object.entries(obj)) {
      if (v === null || v === undefined) continue;
      if (typeof v === 'object' && !Array.isArray(v)) {
        if (Object.keys(v).length === 0) { lines.push(`${pad}${k}: {}`); continue; }
        lines.push(`${pad}${k}:`);
        lines.push(objToYaml(v, indent + 2));
      } else if (Array.isArray(v)) {
        if (!v.length) { lines.push(`${pad}${k}: []`); continue; }
        lines.push(`${pad}${k}:`);
        v.forEach(item => {
          if (typeof item === 'object') {
            const subLines = objToYaml(item, indent + 4).split('\n');
            subLines.forEach((sl, si) => {
              if (si === 0) lines.push(`${pad}  - ${sl.trimStart()}`);
              else if (sl.trim()) lines.push(sl);
            });
          } else {
            lines.push(`${pad}  - ${item}`);
          }
        });
      } else if (typeof v === 'string') {
        const needsQuote = v.includes(':') || v.includes('#') || v.startsWith('{') || v === 'true' || v === 'false';
        lines.push(`${pad}${k}: ${needsQuote ? `"${v.replace(/"/g, '\\"')}"` : v}`);
      } else {
        lines.push(`${pad}${k}: ${v}`);
      }
    }
    return lines.join('\n');
  }

  function renderEndpoints() {
    const el = document.getElementById('oa-endpoints-list');
    if (!endpoints.length) { el.innerHTML = ''; return; }
    el.innerHTML = endpoints.map((ep, i) => `
      <div class="flex items-center gap-2 p-2 bg-background border border-border rounded-lg text-xs">
        <span class="font-mono font-bold w-14 shrink-0 ${METHOD_COLORS[ep.method] || 'text-text'}">${ep.method.toUpperCase()}</span>
        <span class="font-mono flex-1 truncate">${ep.path}</span>
        <button onclick="window.__oa_remove(${i})" class="text-red-400 hover:text-red-300 shrink-0">×</button>
      </div>
    `).join('');
  }

  window.__oa_remove = function(i) {
    endpoints.splice(i, 1);
    renderEndpoints(); updateOutput();
  };

  document.getElementById('oa-has-body').addEventListener('change', function() {
    document.getElementById('oa-body-fields').classList.toggle('hidden', !this.checked);
  });

  document.getElementById('oa-add-endpoint').addEventListener('click', () => {
    const method = document.getElementById('oa-method').value;
    const path = document.getElementById('oa-path').value.trim();
    const summary = document.getElementById('oa-summary').value.trim();
    const tag = document.getElementById('oa-tag').value.trim();
    const status = document.getElementById('oa-status').value;
    const hasBody = document.getElementById('oa-has-body').checked;
    const bodyFields = document.getElementById('oa-body-schema').value;

    if (!path) { alert('Path is required (e.g. /users/{id})'); return; }
    if (!path.startsWith('/')) { alert('Path must start with /'); return; }

    endpoints.push({ method, path, summary, tag, status, hasBody, bodyFields });
    document.getElementById('oa-path').value = '';
    document.getElementById('oa-summary').value = '';
    renderEndpoints(); updateOutput();
  });

  // Listen to info changes
  ['oa-title', 'oa-version', 'oa-server', 'oa-desc'].forEach(id => {
    document.getElementById(id).addEventListener('input', updateOutput);
  });

  document.getElementById('oa-fmt-yaml').addEventListener('click', () => {
    outputFormat = 'yaml';
    document.getElementById('oa-fmt-yaml').className = 'text-xs px-3 py-1.5 rounded-lg bg-accent text-white font-medium';
    document.getElementById('oa-fmt-json').className = 'text-xs px-3 py-1.5 rounded-lg bg-background border border-border hover:bg-accent/20 transition-colors';
    updateOutput();
  });
  document.getElementById('oa-fmt-json').addEventListener('click', () => {
    outputFormat = 'json';
    document.getElementById('oa-fmt-json').className = 'text-xs px-3 py-1.5 rounded-lg bg-accent text-white font-medium';
    document.getElementById('oa-fmt-yaml').className = 'text-xs px-3 py-1.5 rounded-lg bg-background border border-border hover:bg-accent/20 transition-colors';
    updateOutput();
  });

  document.getElementById('oa-copy').addEventListener('click', () => {
    navigator.clipboard.writeText(document.getElementById('oa-output').textContent).then(() => {
      const btn = document.getElementById('oa-copy');
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 1500);
    });
  });

  function updateOutput() {
    const spec = buildSpec();
    const out = document.getElementById('oa-output');
    if (outputFormat === 'json') {
      out.textContent = JSON.stringify(spec, null, 2);
    } else {
      out.textContent = objToYaml(spec);
    }
  }

  renderEndpoints();
  updateOutput();
})();
</script>
