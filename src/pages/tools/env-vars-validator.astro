---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EnvVarsValidator from '../../components/EnvVarsValidator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "Is it safe to paste my .env file into this tool?",
    answer: "Yes — this tool runs entirely in your browser using JavaScript. Your environment variables are never sent to any server, stored, or logged. The validation logic executes locally on your machine. You can verify this by opening DevTools → Network tab and confirming no network requests are made when you paste content. That said, always be mindful when copying secrets to any web interface, even offline-capable ones. If you're validating highly sensitive production secrets, consider running the validation logic locally from the source code instead."
  },
  {
    question: "What counts as a 'weak' secret value?",
    answer: "This tool flags common placeholder and weak values for keys that look like secrets (keys containing SECRET, KEY, TOKEN, PASSWORD, PASS, CREDENTIAL, AUTH, PRIVATE, CERT, SALT, or SEED). Flagged weak values include: test, password, password123, 123456, secret, changeme, example, placeholder, xxx, your_key_here, replace_me, todo, fixme, and empty values. These are commonly used as placeholders during development and should always be replaced with strong random values before deploying to production. Use a secrets manager like AWS Secrets Manager, HashiCorp Vault, or Doppler for production credentials."
  },
  {
    question: "What .env format rules does this tool check?",
    answer: "The tool validates several .env format rules: (1) Every non-comment line must have an = sign separating the key from the value. (2) Key names should match [A-Za-z_][A-Za-z0-9_]* — letters, digits, and underscores only, starting with a letter or underscore. (3) No spaces around the = sign. (4) Values containing spaces must be wrapped in double or single quotes (VAR=\"hello world\"). (5) Quotes must be properly closed. (6) Duplicate keys are flagged as errors — the second definition may silently override the first depending on your runtime. (7) Empty values (VAR=) are flagged as warnings."
  },
  {
    question: "How does secret masking work?",
    answer: "Any key whose name contains the words SECRET, KEY, TOKEN, PASSWORD, PASS, CREDENTIAL, PRIVATE, AUTH, CERT, SALT, or SEED is treated as a secret. The tool masks the displayed value, showing only the first 2 and last 2 characters with **** in between (e.g., sk****89). This lets you verify the key is present and non-empty without exposing the full value in the results table. The full value is still processed locally in memory for validation (checking if it's empty or weak), but it is never displayed in full and never leaves your browser."
  },
];
---

<BaseLayout
  title="Environment Variables Validator — Lint .env Files Online"
  description="Validate and lint .env files online. Detect empty values, duplicates, weak secrets, format errors, and unquoted spaces. Masks sensitive values. Free, runs entirely in your browser."
  tool="env validator, dotenv linter, env file checker, environment variables, secret detection, dotenv validator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Environment Variables Validator",
    "url": "https://devplaybook.cc/tools/env-vars-validator",
    "description": "Validate and lint .env files online. Detect empty values, duplicates, weak secrets, format errors, and unquoted spaces. Masks sensitive values. Runs entirely in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Environment Variables Validator</h1>
  <p class="text-text-muted mb-4">
    Paste your <strong>.env file</strong> to validate and lint it instantly. Detects empty values, duplicate keys, unquoted spaces, weak secrets, and format errors. Secret values (API keys, passwords, tokens) are automatically <strong>masked</strong>. Runs 100% in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Weak secret detection</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Duplicate key check</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Format validation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Values never leave browser</span>
  </div>
  <EnvVarsValidator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Environment Variables Validator" relatedTags={['developer-tools', 'environment-variables', 'security', 'devops', 'dotenv']} />
</BaseLayout>
