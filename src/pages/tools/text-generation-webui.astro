---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is text-generation-webui (oobabooga)?", answer: "Text-generation-webui, commonly called 'oobabooga' after its creator, is a feature-rich Gradio-based web interface for running LLMs locally. It supports the widest range of model formats (GGUF, GPTQ, AWQ, EXL2, HQQ) and inference backends of any local AI tool, making it the go-to choice for users who want maximum model compatibility and fine-grained control over generation parameters." },
  { question: "What model formats does text-generation-webui support?", answer: "Text-generation-webui supports GGUF (via llama.cpp), GPTQ (via AutoGPTQ), AWQ (via AutoAWQ), EXL2 (via ExLlamaV2 — fastest quantized format on NVIDIA), HQQ, and full-precision transformers models (FP16/BF16). This breadth of format support is unmatched by Ollama or LM Studio, making it essential for researchers and power users who work with diverse model quantizations." },
  { question: "How do I install text-generation-webui?", answer: "The easiest method is the one-click installer script for your OS (Windows, Linux, macOS). Download the release from GitHub, run the installer, and it sets up a conda environment with all dependencies. For Windows: run start_windows.bat. For Linux/macOS: run start_linux.sh or start_macos.sh. The installer auto-detects your GPU and installs the right CUDA/ROCm/Metal backend." },
  { question: "What is the OpenAI API extension?", answer: "The 'openai' extension (enabled in the --extensions flag) turns text-generation-webui into an OpenAI-compatible API server on port 5000 by default. It implements /v1/chat/completions, /v1/completions, and /v1/models. This lets LangChain, LlamaIndex, and any OpenAI SDK use your local models. Enable it with: python server.py --api --extensions openai." },
  { question: "What are text-generation-webui extensions?", answer: "Extensions are Python modules that add capabilities: 'api' exposes REST endpoints, 'openai' adds OpenAI compatibility, 'superbooga' implements local RAG with ChromaDB, 'sd_api_pictures' generates images via Stable Diffusion, 'gallery' shows model card information, 'long_term_memory' persists context across sessions, and 'silero_tts' adds text-to-speech. Load multiple extensions simultaneously." },
  { question: "text-generation-webui vs Ollama — when to use which?", answer: "Use Ollama when you want a simple, scriptable tool for running standard models in apps or scripts. Use text-generation-webui when you need: advanced quantization formats (GPTQ, AWQ, EXL2), fine-grained sampling controls (mirostat, repetition penalty, typical_p), LoRA adapter loading, grammar-constrained generation, or the superbooga RAG extension. Ollama is simpler; oobabooga is more powerful and configurable." },
];
---

<BaseLayout
  title="Text Generation WebUI (oobabooga): Local LLM Interface Guide (2026)"
  description="Complete guide to text-generation-webui (oobabooga) — installation, model loading (GGUF/GPTQ/AWQ/EXL2), extensions, and OpenAI API setup for local LLM inference."
  tool="text generation webui, oobabooga, local LLM, GGUF loader, TextGen WebUI, GPTQ, AWQ, EXL2"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"Text Generation WebUI (oobabooga): Local LLM Interface Guide","url":"https://devplaybook.cc/tools/text-generation-webui","description":"Complete guide to text-generation-webui — installation, model formats, extensions, and OpenAI API setup for 2026."})} />

  <h1 class="text-3xl font-bold mb-2">Text Generation WebUI (oobabooga): Local LLM Interface Guide</h1>
  <p class="text-text-muted mb-6">Text-generation-webui is the Swiss Army knife of local LLM interfaces. It supports more model formats than any other tool, provides granular control over every generation parameter, and has a powerful extension system for RAG, TTS, and API compatibility — making it the preferred choice for researchers and power users.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Widest model format support (GGUF, GPTQ, AWQ, EXL2)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Advanced sampling parameters</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> OpenAI-compatible API extension</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> LoRA adapter support</span>
  </div>

  <ToolPageCta />

  <!-- Installation -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">One-Click Installation</h2>
    <p class="text-text-muted text-sm mb-4">Text-generation-webui provides platform-specific installer scripts that set up a conda environment with the correct backends for your GPU:</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># Download the latest release from GitHub:
# https://github.com/oobabooga/text-generation-webui/releases

# Windows — double-click or run from PowerShell:
start_windows.bat

# Linux
bash start_linux.sh

# macOS (Apple Silicon + Intel)
bash start_macos.sh

# The installer will ask for your GPU type:
# A) NVIDIA (CUDA)
# B) AMD (ROCm — Linux only)
# C) Apple Silicon (Metal)
# D) CPU only (no GPU)

# After installation, start the server:
python server.py --listen

# With API and OpenAI compatibility enabled:
python server.py --api --extensions openai --listen

# Access the UI at http://localhost:7860</code></pre>
  </div>

  <!-- Model loading -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Loading Models (GGUF, GPTQ, AWQ, EXL2)</h2>
    <p class="text-text-muted text-sm mb-4">Place model files in the <code class="bg-bg-card border border-border rounded px-1.5 py-0.5 text-xs font-mono">models/</code> directory. The UI auto-detects the format and selects the right loader. Here's what each format means and when to use it:</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># Model format guide:

# GGUF — llama.cpp backend
# Best for: CPU inference, Apple Silicon, low VRAM scenarios
# Download from HuggingFace (TheBloke, bartowski repos are reliable)
# Place in: models/llama-3.2-7b-instruct-Q4_K_M.gguf

# GPTQ — AutoGPTQ backend (NVIDIA only)
# Best for: moderate VRAM (4-8 GB), fast NVIDIA inference
# Loader: AutoGPTQ (select in UI or --loader autogptq)
# Place in: models/Llama-3.2-7B-GPTQ/

# AWQ — AutoAWQ backend (NVIDIA only)
# Best for: faster than GPTQ, similar quality, 4-bit precision
# Loader: AutoAWQ
# Place in: models/Llama-3.2-7B-AWQ/

# EXL2 — ExLlamaV2 backend (NVIDIA only, fastest quantized option)
# Best for: maximum NVIDIA speed, various bits-per-weight settings
# Loader: ExLlamaV2 (set bits-per-weight in UI)
# Place in: models/Llama-3.2-7B-EXL2-4.0bpw/

# Load via UI: Models tab > Enter model name > Load
# Or command line: python server.py --model llama-3.2-7b --loader llama.cpp</code></pre>
  </div>

  <!-- Extensions -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Key Extensions</h2>
    <p class="text-text-muted text-sm mb-3">Enable extensions with <code class="bg-bg-card border border-border rounded px-1.5 py-0.5 text-xs font-mono">--extensions ext1 ext2</code> at startup, or toggle them in the Session tab:</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-sm mb-4">
      <div class="border border-border rounded-lg p-3">
        <div class="font-mono text-xs text-primary mb-1">openai</div>
        <p class="text-text-muted text-xs">OpenAI-compatible API on port 5000. Drop-in replacement for OpenAI SDK integrations. Supports chat completions, completions, and embeddings.</p>
      </div>
      <div class="border border-border rounded-lg p-3">
        <div class="font-mono text-xs text-primary mb-1">superbooga</div>
        <p class="text-text-muted text-xs">Local RAG using ChromaDB. Upload documents and the model answers questions grounded in your data. Works entirely offline.</p>
      </div>
      <div class="border border-border rounded-lg p-3">
        <div class="font-mono text-xs text-primary mb-1">sd_api_pictures</div>
        <p class="text-text-muted text-xs">Generate images via Stable Diffusion (requires A1111 running). The LLM can create images on demand during conversations.</p>
      </div>
      <div class="border border-border rounded-lg p-3">
        <div class="font-mono text-xs text-primary mb-1">long_term_memory</div>
        <p class="text-text-muted text-xs">Persist conversation context across sessions using vector search. The model "remembers" past conversations with you automatically.</p>
      </div>
    </div>
  </div>

  <!-- Comparison -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-4">text-generation-webui vs Ollama</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-text-muted text-xs uppercase border-b border-border">
            <th class="text-left pb-2 pr-4">Feature</th>
            <th class="text-left pb-2 pr-4">text-gen-webui</th>
            <th class="text-left pb-2">Ollama</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border text-xs">
          <tr><td class="py-2 pr-4 font-medium">Model formats</td><td class="py-2 pr-4 text-green-500">GGUF, GPTQ, AWQ, EXL2, HQQ, FP16</td><td class="py-2 text-yellow-500">GGUF only</td></tr>
          <tr><td class="py-2 pr-4 font-medium">LoRA adapters</td><td class="py-2 pr-4 text-green-500">Yes</td><td class="py-2 text-red-400">No</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Sampling controls</td><td class="py-2 pr-4 text-green-500">20+ parameters</td><td class="py-2 text-yellow-500">Basic</td></tr>
          <tr><td class="py-2 pr-4 font-medium">OpenAI API</td><td class="py-2 pr-4 text-green-500">Via extension</td><td class="py-2 text-green-500">Native</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Ease of use</td><td class="py-2 pr-4 text-yellow-500">Moderate</td><td class="py-2 text-green-500">Very easy</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Installation</td><td class="py-2 pr-4 text-yellow-500">One-click script</td><td class="py-2 text-green-500">Single binary</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Best for</td><td class="py-2 pr-4">Power users, researchers</td><td class="py-2">Developers, apps</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="text-generation-webui" relatedTags={['ai', 'llm', 'local-ai', 'gguf', 'gptq', 'inference', 'private-ai']} />
</BaseLayout>
