---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is an Internal Developer Portal (IDP)?",
    answer: "An Internal Developer Portal is a centralized platform that gives software engineers a single pane of glass into all services, documentation, tooling, and self-service capabilities within an organization. It acts as the front door to your platform engineering efforts — surfacing the service catalog, enabling self-service scaffolding, integrating observability, and enforcing security & compliance standards. Popular IDP frameworks include Backstage (CNCF), Port, and Cortex."
  },
  {
    question: "What's the difference between Backstage, Port, and Cortex?",
    answer: "Backstage (open source, CNCF) is a plugin-based portal originally built by Spotify — best for large engineering teams with dedicated platform engineers to maintain it. Port is a no-code/low-code hosted SaaS IDP optimized for fast setup and workflow automation — best for teams that want results without heavy infrastructure investment. Cortex focuses on developer scorecards, service quality, and ownership — best for large organizations that need to enforce service standards and track maturity at scale."
  },
  {
    question: "How do I prioritize which IDP capabilities to build first?",
    answer: "Start with Service Catalog (the highest-ROI investment: discoverability and ownership clarity), then Self-Service Templates (reduce ticket-driven ops), then Documentation (cut support load). Observability Integration and CI/CD Integration come next as they amplify catalog data. Security & Compliance often follows as you scale. Developer Experience improvements should be continuous throughout. The maturity model in this checklist reflects that priority order."
  },
  {
    question: "What does the maturity score mean?",
    answer: "The maturity score is calculated from how many checklist items you have completed across all categories. Starter (0–29%): IDP awareness but minimal implementation. Developing (30–59%): core catalog and basic self-service in place. Advanced (60–84%): full lifecycle coverage with observability and CI/CD hooks. Expert (85–100%): world-class developer experience with proactive governance and continuous improvement loops."
  },
  {
    question: "How long does it take to implement a production IDP?",
    answer: "With Backstage: 3–6 months for a basic portal with catalog and TechDocs, 6–18 months to reach full platform maturity. With Port or Cortex: 2–8 weeks for initial rollout due to managed infrastructure. Realistic milestone: aim for Service Catalog + 2 self-service templates in the first quarter. The biggest bottleneck is usually organizational — getting teams to maintain their catalog YAML — not technical setup."
  }
];
---

<BaseLayout
  title="Internal Developer Portal Readiness Checklist — IDP Assessment Tool"
  description="Evaluate your Internal Developer Portal readiness across 7 dimensions: Developer Experience, Service Catalog, Self-Service Templates, Documentation, Observability, Security, and CI/CD. Get a maturity score and platform recommendation."
  tool="internal developer portal, IDP checklist, Backstage, Port, Cortex, platform engineering, developer experience, service catalog"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Internal Developer Portal Readiness Checklist",
    "url": "https://devplaybook.cc/tools/internal-developer-portal-checklist",
    "description": "Evaluate IDP readiness across 7 dimensions and get a maturity score with platform recommendations. Free, runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Internal Developer Portal Readiness Checklist</h1>
  <p class="text-text-muted mb-4">Evaluate your IDP readiness across 7 dimensions. Check off what you have in place to get a maturity score, per-category breakdown, and a platform recommendation (Backstage / Port / Cortex).</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 7 categories, 33 checklist items</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Maturity level: Starter → Expert</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Per-category score bars</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Platform recommendation</span>
  </div>

  <!-- Checklist -->
  <div id="checklist-container" class="space-y-6 mb-8">

    <!-- Category: Developer Experience -->
    <div class="bg-bg-card border border-border rounded-lg p-5" data-category="dx">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-base font-semibold">Developer Experience</h2>
        <span class="cat-score-badge text-xs font-mono bg-primary/10 text-primary px-2 py-0.5 rounded">0 / 5</span>
      </div>
      <div class="cat-bar-wrap mb-4">
        <div class="w-full bg-border rounded-full h-2 overflow-hidden">
          <div class="cat-bar h-full bg-primary rounded-full transition-all duration-300" style="width:0%"></div>
        </div>
      </div>
      <ul class="space-y-2.5">
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Portal is accessible via a single internal URL (no VPN maze)</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Single sign-on (SSO) integration is configured</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Onboarding checklist for new engineers is available in the portal</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Developer satisfaction / NPS is measured regularly</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Portal search covers services, docs, runbooks, and team ownership</span></li>
      </ul>
    </div>

    <!-- Category: Service Catalog -->
    <div class="bg-bg-card border border-border rounded-lg p-5" data-category="catalog">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-base font-semibold">Service Catalog</h2>
        <span class="cat-score-badge text-xs font-mono bg-primary/10 text-primary px-2 py-0.5 rounded">0 / 5</span>
      </div>
      <div class="cat-bar-wrap mb-4">
        <div class="w-full bg-border rounded-full h-2 overflow-hidden">
          <div class="cat-bar h-full bg-primary rounded-full transition-all duration-300" style="width:0%"></div>
        </div>
      </div>
      <ul class="space-y-2.5">
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">All production services are registered in the catalog</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Each service has a designated owner (team or individual)</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Catalog entries include tech stack, SLOs, and lifecycle stage</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Dependencies between services are mapped and visible</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Catalog data is kept up-to-date via automated sync (Git, infra scans)</span></li>
      </ul>
    </div>

    <!-- Category: Self-Service Templates -->
    <div class="bg-bg-card border border-border rounded-lg p-5" data-category="selfservice">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-base font-semibold">Self-Service Templates</h2>
        <span class="cat-score-badge text-xs font-mono bg-primary/10 text-primary px-2 py-0.5 rounded">0 / 5</span>
      </div>
      <div class="cat-bar-wrap mb-4">
        <div class="w-full bg-border rounded-full h-2 overflow-hidden">
          <div class="cat-bar h-full bg-primary rounded-full transition-all duration-300" style="width:0%"></div>
        </div>
      </div>
      <ul class="space-y-2.5">
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Golden path templates exist for at least 2 service types</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">New service scaffolding can be triggered without opening a ticket</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Templates include CI/CD pipeline, Dockerfile, and K8s manifests</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Environment provisioning (dev/staging) is available via self-service</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Template usage is tracked and templates are versioned</span></li>
      </ul>
    </div>

    <!-- Category: Documentation -->
    <div class="bg-bg-card border border-border rounded-lg p-5" data-category="docs">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-base font-semibold">Documentation</h2>
        <span class="cat-score-badge text-xs font-mono bg-primary/10 text-primary px-2 py-0.5 rounded">0 / 4</span>
      </div>
      <div class="cat-bar-wrap mb-4">
        <div class="w-full bg-border rounded-full h-2 overflow-hidden">
          <div class="cat-bar h-full bg-primary rounded-full transition-all duration-300" style="width:0%"></div>
        </div>
      </div>
      <ul class="space-y-2.5">
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Docs live alongside code (docs-as-code, e.g. TechDocs / MkDocs)</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Each service has at least a README, architecture decision record (ADR), and runbook</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Docs staleness is surfaced (last-updated timestamps, dead-link checks)</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">API documentation is auto-generated and linked from the catalog</span></li>
      </ul>
    </div>

    <!-- Category: Observability Integration -->
    <div class="bg-bg-card border border-border rounded-lg p-5" data-category="obs">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-base font-semibold">Observability Integration</h2>
        <span class="cat-score-badge text-xs font-mono bg-primary/10 text-primary px-2 py-0.5 rounded">0 / 5</span>
      </div>
      <div class="cat-bar-wrap mb-4">
        <div class="w-full bg-border rounded-full h-2 overflow-hidden">
          <div class="cat-bar h-full bg-primary rounded-full transition-all duration-300" style="width:0%"></div>
        </div>
      </div>
      <ul class="space-y-2.5">
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Service health / uptime status is visible in the catalog</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Alerts and on-call schedule are linked per service</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">SLO error budget is surfaced per service in the portal</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Logs and traces are reachable with one click from catalog entry</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Incident history is linked to affected services</span></li>
      </ul>
    </div>

    <!-- Category: Security & Compliance -->
    <div class="bg-bg-card border border-border rounded-lg p-5" data-category="sec">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-base font-semibold">Security &amp; Compliance</h2>
        <span class="cat-score-badge text-xs font-mono bg-primary/10 text-primary px-2 py-0.5 rounded">0 / 4</span>
      </div>
      <div class="cat-bar-wrap mb-4">
        <div class="w-full bg-border rounded-full h-2 overflow-hidden">
          <div class="cat-bar h-full bg-primary rounded-full transition-all duration-300" style="width:0%"></div>
        </div>
      </div>
      <ul class="space-y-2.5">
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Dependency vulnerability scan results are visible per service</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Secret management policy is enforced (no secrets in repos)</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Compliance status (SOC 2, PCI, GDPR) is tracked per service</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Role-based access control (RBAC) is applied at the portal level</span></li>
      </ul>
    </div>

    <!-- Category: CI/CD Integration -->
    <div class="bg-bg-card border border-border rounded-lg p-5" data-category="cicd">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-base font-semibold">CI/CD Integration</h2>
        <span class="cat-score-badge text-xs font-mono bg-primary/10 text-primary px-2 py-0.5 rounded">0 / 5</span>
      </div>
      <div class="cat-bar-wrap mb-4">
        <div class="w-full bg-border rounded-full h-2 overflow-hidden">
          <div class="cat-bar h-full bg-primary rounded-full transition-all duration-300" style="width:0%"></div>
        </div>
      </div>
      <ul class="space-y-2.5">
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Latest deployment status is shown per service in the catalog</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Deployment history (who deployed what and when) is queryable</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">One-click deploy or rollback is available for authorized users</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Pipeline quality gates (tests, SAST, coverage) are enforced via golden path</span></li>
        <li class="flex items-start gap-3"><input type="checkbox" class="idp-check mt-0.5 h-4 w-4 rounded border-border bg-bg-card accent-primary cursor-pointer" /><span class="text-sm">Feature flags or canary deployment controls are accessible from portal</span></li>
      </ul>
    </div>

  </div>

  <!-- Action buttons -->
  <div class="flex gap-3 mb-8 flex-wrap">
    <button id="btn-reset-all" class="px-4 py-2.5 bg-bg-card border border-border rounded-lg text-sm hover:border-primary transition-colors">Reset All</button>
  </div>

  <!-- Results -->
  <div id="results-section" class="mb-8">
    <!-- Overall score -->
    <div class="bg-bg-card border border-border rounded-lg p-5 mb-5">
      <div class="flex items-center justify-between mb-3">
        <span class="text-sm font-medium text-text-muted">Overall IDP Readiness</span>
        <span id="overall-score-label" class="text-2xl font-bold font-mono text-primary">0%</span>
      </div>
      <div class="w-full bg-border rounded-full h-3 overflow-hidden mb-3">
        <div id="overall-bar" class="h-full rounded-full transition-all duration-500 bg-primary" style="width:0%"></div>
      </div>
      <div class="flex items-center gap-3">
        <span id="maturity-badge" class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-border text-text-muted">Starter</span>
        <span id="maturity-desc" class="text-sm text-text-muted">Check items above to see your maturity level.</span>
      </div>
    </div>

    <!-- Platform recommendation -->
    <div id="platform-rec" class="bg-bg-card border border-border rounded-lg p-5 mb-5 hidden">
      <h3 class="text-sm font-semibold mb-2">Platform Recommendation</h3>
      <div id="platform-content" class="text-sm text-text-muted"></div>
    </div>
  </div>

  <ToolPageCta />
  <FaqSection faq={faq} />
</BaseLayout>

<script is:inline>
const CATEGORIES = [
  { el: '[data-category="dx"]',         total: 5 },
  { el: '[data-category="catalog"]',    total: 5 },
  { el: '[data-category="selfservice"]',total: 5 },
  { el: '[data-category="docs"]',       total: 4 },
  { el: '[data-category="obs"]',        total: 5 },
  { el: '[data-category="sec"]',        total: 4 },
  { el: '[data-category="cicd"]',       total: 5 },
];

const TOTAL_ITEMS = CATEGORIES.reduce((s, c) => s + c.total, 0);

function updateUI() {
  let totalChecked = 0;
  CATEGORIES.forEach(cat => {
    const container = document.querySelector(cat.el);
    if (!container) return;
    const boxes = container.querySelectorAll('.idp-check');
    const checked = Array.from(boxes).filter(b => b.checked).length;
    totalChecked += checked;

    const pct = cat.total > 0 ? (checked / cat.total) * 100 : 0;
    const badge = container.querySelector('.cat-score-badge');
    const bar = container.querySelector('.cat-bar');
    if (badge) badge.textContent = `${checked} / ${cat.total}`;
    if (bar) bar.style.width = pct.toFixed(1) + '%';
  });

  const overallPct = (totalChecked / TOTAL_ITEMS) * 100;
  document.getElementById('overall-score-label').textContent = overallPct.toFixed(0) + '%';
  document.getElementById('overall-bar').style.width = overallPct.toFixed(1) + '%';

  let maturityLabel, maturityDesc, maturityClass;
  if (overallPct < 30) {
    maturityLabel = 'Starter';
    maturityClass = 'bg-slate-700 text-slate-300';
    maturityDesc = 'IDP awareness is present but implementation is minimal. Focus on Service Catalog and SSO first.';
  } else if (overallPct < 60) {
    maturityLabel = 'Developing';
    maturityClass = 'bg-blue-900/50 text-blue-300';
    maturityDesc = 'Core catalog and basic self-service are taking shape. Expand templates and link observability.';
  } else if (overallPct < 85) {
    maturityLabel = 'Advanced';
    maturityClass = 'bg-violet-900/50 text-violet-300';
    maturityDesc = 'Solid platform coverage. Focus on closing CI/CD, security, and developer experience gaps.';
  } else {
    maturityLabel = 'Expert';
    maturityClass = 'bg-green-900/50 text-green-300';
    maturityDesc = 'World-class developer portal. Maintain via continuous feedback loops and scorecard reviews.';
  }

  const badge = document.getElementById('maturity-badge');
  badge.className = `inline-flex items-center px-3 py-1 rounded-full text-xs font-bold ${maturityClass}`;
  badge.textContent = maturityLabel;
  document.getElementById('maturity-desc').textContent = maturityDesc;

  // Platform recommendation
  const platformRec = document.getElementById('platform-rec');
  const platformContent = document.getElementById('platform-content');
  let recHTML = '';
  if (overallPct < 30) {
    recHTML = '<strong class="text-foreground">Recommended: Port</strong> — With minimal IDP foundation, Port\'s low-code hosted approach gets you a working portal fastest. No Kubernetes required. Start with the free tier.';
  } else if (overallPct < 60) {
    recHTML = '<strong class="text-foreground">Recommended: Port or Backstage</strong> — Port works well if your team wants to grow without heavy maintenance. Choose <strong class="text-foreground">Backstage</strong> if you have a dedicated platform team (&gt;3 engineers) and need deep plugin customization.';
  } else if (overallPct < 85) {
    recHTML = '<strong class="text-foreground">Recommended: Backstage</strong> — Your maturity justifies the investment. Backstage\'s plugin ecosystem (TechDocs, CI/CD integrations, RBAC) matches your Advanced needs. Consider <strong class="text-foreground">Cortex</strong> if scorecards and service standards enforcement are the priority.';
  } else {
    recHTML = '<strong class="text-foreground">Recommended: Backstage or Cortex</strong> — At Expert level, you need the depth of Backstage for full customization, or Cortex if continuous quality scoring and ownership governance are central to your platform strategy. Both integrate well at this maturity.';
  }
  platformContent.innerHTML = recHTML;
  platformRec.classList.remove('hidden');
}

// Attach listeners
document.querySelectorAll('.idp-check').forEach(cb => {
  cb.addEventListener('change', updateUI);
});

document.getElementById('btn-reset-all')?.addEventListener('click', () => {
  document.querySelectorAll('.idp-check').forEach(cb => { cb.checked = false; });
  updateUI();
});

// Initialize
updateUI();
</script>
