---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is the recommended selector strategy for Cypress tests?",
    answer: "Cypress recommends data-cy attributes (e.g., data-cy='submit-button') as the most resilient selector strategy. CSS classes and IDs change during refactoring, breaking tests. data-cy attributes are test-specific and communicate intent clearly. They decouple test selectors from presentation concerns. If you can't add data-cy attributes, prefer role-based selectors (cy.findByRole) or accessible text selectors over CSS classes.",
  },
  {
    question: "What is the difference between cy.get() and cy.find()?",
    answer: "cy.get() queries the entire DOM from the root. cy.find() queries within a previously selected element. Use cy.find() to scope searches: cy.get('[data-cy=form]').find('input') finds all inputs inside the form element. This makes tests more precise and less likely to accidentally target the wrong element when similar elements exist elsewhere on the page.",
  },
  {
    question: "How do I select elements that don't have text content?",
    answer: "For elements without visible text (icons, buttons with only SVGs, inputs), use: data-cy attributes (recommended), aria-label for accessibility-compliant elements ('cy.get([aria-label=Close])'), type attribute for inputs ('cy.get(input[type=email])'), or placeholder text ('cy.get(input[placeholder=Email address])'). Avoid selecting by CSS class alone as it's brittle.",
  },
  {
    question: "How do I handle dynamic content and async loading in Cypress?",
    answer: "Cypress automatically retries commands for up to 4 seconds (configurable via defaultCommandTimeout). For content that loads via API calls, use cy.intercept() to wait for network requests: cy.intercept('GET', '/api/users').as('getUsers'); cy.wait('@getUsers'). This is more reliable than cy.wait(3000) hardcoded delays. For animations, use cy.contains(':visible') to wait for element visibility.",
  },
  {
    question: "What is Testing Library's cy.findBy* and should I use it?",
    answer: "cy.findByRole, cy.findByText, cy.findByLabelText etc. come from the @testing-library/cypress plugin. They encourage accessibility-first selectors — selecting elements the way real users interact with them. cy.findByRole('button', { name: 'Submit' }) is more resilient than cy.get('[data-cy=submit]') and doubles as an accessibility check. Install @testing-library/cypress and add to support/commands.ts for best results.",
  },
];
---

<BaseLayout
  title="Cypress Selector Helper — Build CSS & data-cy Selectors for Cypress Tests"
  description="Build robust Cypress selectors interactively. Generate data-cy attributes, CSS selectors, and cy.get() commands for your E2E tests. Includes selector strategy guide and copy-ready code snippets."
  tool="Cypress Selector Helper, Cypress CSS Selector Builder, data-cy Generator, Cypress E2E Testing, cy.get Selector"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Cypress Selector Helper",
    "url": "https://devplaybook.cc/tools/cypress-selector-helper",
    "description": "Build robust Cypress E2E test selectors. Generate data-cy attributes, CSS selectors, and cy.get() / cy.findBy* commands. Includes best practice guidance.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Cypress Selector Helper</h1>
  <p class="text-text-muted mb-4">
    Build resilient <strong class="text-text">Cypress</strong> selectors and
    <code class="font-mono bg-surface px-1 rounded text-sm">data-cy</code> attributes.
    Paste HTML or describe your element to get ready-to-use cy.get() commands.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> data-cy strategy</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CSS selector builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Selector strength rating</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-ready code</span>
  </div>

  <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
    <!-- Builder panel -->
    <div class="flex flex-col gap-4">
      <!-- HTML input -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted mb-3">Paste HTML Element</h2>
        <textarea
          id="html-input"
          class="w-full h-36 px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm font-mono focus:outline-none focus:border-accent transition-colors resize-none"
          spellcheck="false"
          placeholder="Paste your HTML element here..."
        ><button class="btn btn-primary" id="submit-btn" type="submit" aria-label="Submit form">
  Submit Order
</button></textarea>
        <button id="parse-btn" class="mt-3 w-full py-2 px-4 bg-accent hover:bg-accent/90 text-white rounded-lg text-sm font-medium transition-colors">
          Analyze Element
        </button>
      </div>

      <!-- Manual builder -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted mb-4">Manual Builder</h2>
        <div class="flex flex-col gap-3">
          <div>
            <label class="block text-sm font-medium mb-1">Element Type</label>
            <select id="el-type" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors">
              <option value="button">button</option>
              <option value="input">input</option>
              <option value="a">a (link)</option>
              <option value="form">form</option>
              <option value="div">div</option>
              <option value="span">span</option>
              <option value="select">select</option>
              <option value="textarea">textarea</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">data-cy value</label>
            <input id="data-cy-val" type="text" value="submit-button" placeholder="e.g., submit-button" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm font-mono focus:outline-none focus:border-accent transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Text content</label>
            <input id="text-content" type="text" value="Submit Order" placeholder="Visible text..." class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">aria-label (optional)</label>
            <input id="aria-label-val" type="text" placeholder="e.g., Submit form" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">ID (optional)</label>
            <input id="el-id" type="text" placeholder="e.g., submit-btn" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm font-mono focus:outline-none focus:border-accent transition-colors" />
          </div>
        </div>
      </div>
    </div>

    <!-- Output -->
    <div class="flex flex-col gap-4">
      <!-- Selector ranking -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted mb-3">Selector Options (Best → Worst)</h2>
        <div id="selector-list" class="flex flex-col gap-2"></div>
      </div>

      <!-- Generated code -->
      <div class="bg-bg-card border border-border rounded-xl p-5 flex flex-col flex-1">
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Generated Cypress Code</h2>
          <button id="copy-code-btn" class="px-3 py-1 rounded text-xs bg-bg border border-border text-text-muted hover:text-text transition-colors">Copy</button>
        </div>
        <pre id="cypress-code" class="text-xs font-mono bg-bg rounded-lg p-3 overflow-auto flex-1 text-text whitespace-pre min-h-[200px]"></pre>
      </div>

      <!-- HTML with data-cy added -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Updated HTML</h2>
          <button id="copy-html-btn" class="px-3 py-1 rounded text-xs bg-bg border border-border text-text-muted hover:text-text transition-colors">Copy</button>
        </div>
        <pre id="updated-html" class="text-xs font-mono bg-bg rounded-lg p-3 overflow-auto text-text whitespace-pre max-h-32"></pre>
      </div>
    </div>
  </div>

  <script>
    interface SelectorOption {
      selector: string;
      command: string;
      strength: 'excellent' | 'good' | 'fair' | 'poor';
      label: string;
      reason: string;
    }

    function parseAttributes(html: string): Record<string, string> {
      const attrs: Record<string, string> = {};
      const attrRe = /(\w[\w-]*)(?:=["']([^"']*)["'])?/g;

      // Extract opening tag
      const tagMatch = html.match(/<(\w+)([^>]*)/);
      if (!tagMatch) return attrs;

      attrs['_tag'] = tagMatch[1].toLowerCase();
      const attrStr = tagMatch[2];

      let m: RegExpExecArray | null;
      while ((m = attrRe.exec(attrStr)) !== null) {
        attrs[m[1].toLowerCase()] = m[2] || 'true';
      }

      // Extract inner text
      const textMatch = html.match(/>([^<]+)</);
      if (textMatch) attrs['_text'] = textMatch[1].trim();

      return attrs;
    }

    function buildSelectors(attrs: Record<string, string>): SelectorOption[] {
      const options: SelectorOption[] = [];
      const tag = attrs['_tag'] || 'div';

      // data-cy
      if (attrs['data-cy']) {
        options.push({
          selector: `[data-cy="${attrs['data-cy']}"]`,
          command: `cy.get('[data-cy="${attrs['data-cy']}"]')`,
          strength: 'excellent',
          label: 'data-cy attribute',
          reason: 'Test-specific, decoupled from UI implementation',
        });
      }

      // data-testid (alternative)
      if (attrs['data-testid']) {
        options.push({
          selector: `[data-testid="${attrs['data-testid']}"]`,
          command: `cy.get('[data-testid="${attrs['data-testid']}"]')`,
          strength: 'excellent',
          label: 'data-testid',
          reason: 'Test-specific attribute, React Testing Library compatible',
        });
      }

      // aria-label
      if (attrs['aria-label']) {
        options.push({
          selector: `[aria-label="${attrs['aria-label']}"]`,
          command: `cy.get('[aria-label="${attrs['aria-label']}"]')`,
          strength: 'good',
          label: 'aria-label',
          reason: 'Accessibility-first, pairs well with @testing-library/cypress',
        });
      }

      // Text content
      if (attrs['_text']) {
        options.push({
          selector: attrs['_text'],
          command: `cy.contains('${attrs['_text']}')`,
          strength: 'good',
          label: 'Text content',
          reason: 'Readable but breaks if text changes (i18n issue)',
        });
      }

      // ID
      if (attrs['id'] && attrs['id'] !== 'true') {
        options.push({
          selector: `#${attrs['id']}`,
          command: `cy.get('#${attrs['id']}')`,
          strength: 'fair',
          label: 'ID attribute',
          reason: 'Fast, but IDs often change during refactoring',
        });
      }

      // type for inputs
      if (tag === 'input' && attrs['type'] && attrs['type'] !== 'true') {
        options.push({
          selector: `input[type="${attrs['type']}"]`,
          command: `cy.get('input[type="${attrs['type']}"]')`,
          strength: 'fair',
          label: 'Type attribute',
          reason: 'Useful for form inputs, fragile if multiple same-type inputs exist',
        });
      }

      // name attribute
      if (attrs['name'] && attrs['name'] !== 'true') {
        options.push({
          selector: `[name="${attrs['name']}"]`,
          command: `cy.get('[name="${attrs['name']}"]')`,
          strength: 'fair',
          label: 'Name attribute',
          reason: 'Good for form fields, but name can change',
        });
      }

      // class (worst)
      if (attrs['class'] && attrs['class'] !== 'true') {
        const cls = attrs['class'].trim().split(/\s+/)[0];
        options.push({
          selector: `.${cls}`,
          command: `cy.get('.${cls}')`,
          strength: 'poor',
          label: 'CSS class',
          reason: 'Fragile — CSS classes change with styling refactors',
        });
      }

      return options;
    }

    function buildFromManual(): Record<string, string> {
      const attrs: Record<string, string> = {};
      attrs['_tag'] = (document.getElementById('el-type') as HTMLSelectElement).value;
      const dcVal = (document.getElementById('data-cy-val') as HTMLInputElement).value.trim();
      const text = (document.getElementById('text-content') as HTMLInputElement).value.trim();
      const ariaLabel = (document.getElementById('aria-label-val') as HTMLInputElement).value.trim();
      const elId = (document.getElementById('el-id') as HTMLInputElement).value.trim();

      if (dcVal) attrs['data-cy'] = dcVal;
      if (text) attrs['_text'] = text;
      if (ariaLabel) attrs['aria-label'] = ariaLabel;
      if (elId) attrs['id'] = elId;

      return attrs;
    }

    function generateUpdatedHTML(attrs: Record<string, string>, originalHtml: string): string {
      if (!attrs['data-cy'] || !originalHtml.trim()) {
        const tag = attrs['_tag'] || 'button';
        const dc = attrs['data-cy'] ? ` data-cy="${attrs['data-cy']}"` : '';
        const id = attrs['id'] ? ` id="${attrs['id']}"` : '';
        const aria = attrs['aria-label'] ? ` aria-label="${attrs['aria-label']}"` : '';
        return `<${tag}${dc}${id}${aria}>${attrs['_text'] || ''}</${tag}>`;
      }

      // Add data-cy to existing HTML
      if (originalHtml.includes('data-cy=')) return originalHtml;
      return originalHtml.replace(/<(\w+)/, `<$1 data-cy="${attrs['data-cy']}"`);
    }

    function generateCypressCode(options: SelectorOption[], attrs: Record<string, string>): string {
      if (options.length === 0) return '// No selectors found — add a data-cy attribute to your element.';

      const best = options[0];
      const tag = attrs['_tag'] || 'element';

      let code = `// Best selector (${best.label})\n`;
      code += `${best.command}\n\n`;

      code += `// Common Cypress actions for ${tag}:\n`;
      if (tag === 'button' || tag === 'a') {
        code += `${best.command}.click()\n`;
        code += `${best.command}.should('be.visible')\n`;
        code += `${best.command}.should('not.be.disabled')\n`;
      } else if (tag === 'input' || tag === 'textarea') {
        code += `${best.command}.type('your text here')\n`;
        code += `${best.command}.clear().type('new value')\n`;
        code += `${best.command}.should('have.value', 'expected value')\n`;
      } else if (tag === 'select') {
        code += `${best.command}.select('Option Text')\n`;
        code += `${best.command}.should('have.value', 'option-value')\n`;
      } else {
        code += `${best.command}.should('be.visible')\n`;
        code += `${best.command}.should('contain.text', '${attrs['_text'] || 'expected text'}')\n`;
      }

      code += `\n// Add data-cy to HTML:\n`;
      code += `// data-cy="${attrs['data-cy'] || 'your-element-name'}"\n`;

      return code;
    }

    function render(html?: string) {
      const attrs = html ? parseAttributes(html) : buildFromManual();
      const options = buildSelectors(attrs);

      // Render selector list
      const list = document.getElementById('selector-list')!;
      const colors: Record<string, string> = {
        excellent: 'bg-green-500/10 border-green-500/30 text-green-400',
        good: 'bg-blue-500/10 border-blue-500/30 text-blue-400',
        fair: 'bg-yellow-500/10 border-yellow-500/30 text-yellow-400',
        poor: 'bg-red-500/10 border-red-500/30 text-red-400',
      };

      if (options.length === 0) {
        list.innerHTML = '<p class="text-sm text-text-muted">No attributes found. Add a data-cy attribute or fill in the manual builder.</p>';
      } else {
        list.innerHTML = options.map(opt => `
          <div class="border rounded-lg p-3 ${colors[opt.strength]}">
            <div class="flex items-center justify-between mb-1">
              <span class="text-xs font-medium uppercase">${opt.strength} — ${opt.label}</span>
              <button class="copy-selector px-2 py-0.5 rounded text-xs bg-bg/50 border border-current/20 opacity-60 hover:opacity-100 transition-opacity" data-sel="${opt.command}">copy</button>
            </div>
            <code class="text-xs font-mono block truncate">${opt.command}</code>
            <p class="text-xs opacity-70 mt-1">${opt.reason}</p>
          </div>
        `).join('');

        list.querySelectorAll('.copy-selector').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const sel = (e.currentTarget as HTMLElement).dataset.sel || '';
            navigator.clipboard.writeText(sel);
          });
        });
      }

      // Render cypress code
      const code = generateCypressCode(options, attrs);
      (document.getElementById('cypress-code') as HTMLPreElement).textContent = code;

      // Render updated HTML
      const updatedHtml = generateUpdatedHTML(attrs, html || '');
      (document.getElementById('updated-html') as HTMLPreElement).textContent = updatedHtml;
    }

    document.getElementById('parse-btn')!.addEventListener('click', () => {
      const html = (document.getElementById('html-input') as HTMLTextAreaElement).value.trim();
      render(html || undefined);
    });

    ['el-type', 'data-cy-val', 'text-content', 'aria-label-val', 'el-id'].forEach(id => {
      document.getElementById(id)!.addEventListener('input', () => render());
    });

    document.getElementById('copy-code-btn')!.addEventListener('click', () => {
      const text = (document.getElementById('cypress-code') as HTMLPreElement).textContent || '';
      navigator.clipboard.writeText(text).then(() => {
        const btn = document.getElementById('copy-code-btn') as HTMLButtonElement;
        btn.textContent = 'Copied!';
        setTimeout(() => btn.textContent = 'Copy', 2000);
      });
    });

    document.getElementById('copy-html-btn')!.addEventListener('click', () => {
      const text = (document.getElementById('updated-html') as HTMLPreElement).textContent || '';
      navigator.clipboard.writeText(text).then(() => {
        const btn = document.getElementById('copy-html-btn') as HTMLButtonElement;
        btn.textContent = 'Copied!';
        setTimeout(() => btn.textContent = 'Copy', 2000);
      });
    });

    render();
  </script>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Cypress Selector Helper" relatedTags={['testing', 'cypress', 'e2e-testing', 'selenium', 'developer-tools']} />
</BaseLayout>
