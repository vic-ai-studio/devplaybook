---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "How does the index advisor parse my query?",
    answer: "The advisor uses regex-based pattern matching to extract tables and aliases from the FROM/JOIN clauses, columns from WHERE conditions, JOIN ON predicates, and ORDER BY expressions. It then classifies each column reference and generates CREATE INDEX recommendations. It handles common SQL patterns but is not a full SQL parser — very complex subqueries or CTEs may not be fully analysed."
  },
  {
    question: "When should I use a composite index vs a single-column index?",
    answer: "Use a composite index when your query consistently filters on multiple columns from the same table together (e.g., WHERE status = 'active' AND created_at > ?). Put equality columns first, range columns last. A single-column index is better when a column is frequently queried alone across many different queries."
  },
  {
    question: "What is index selectivity and why does it matter?",
    answer: "Selectivity measures how many distinct values a column has relative to total rows. High selectivity (e.g., user_id, email) means an index narrows down results to very few rows — excellent candidates for indexing. Low selectivity (e.g., status with only 3 values, boolean flags) means an index still returns a large fraction of the table — often not worth the overhead. The advisor flags low-selectivity columns with a warning."
  },
  {
    question: "When should I use a Hash index instead of B-tree?",
    answer: "Hash indexes are only useful for equality lookups (col = ?). They cannot handle range queries (col > ?, col BETWEEN), sorting, or partial matches. In PostgreSQL, Hash indexes are rarely worth it since B-tree handles equality just as fast in practice. MySQL's InnoDB does not support explicit Hash indexes on disk — only in the adaptive hash index buffer. Use Hash only when you have a very specific equality-only access pattern on a memory-based table."
  },
  {
    question: "Will adding more indexes always improve performance?",
    answer: "No. Every index you add slows down INSERT, UPDATE, and DELETE operations because the index must be maintained on every write. Indexes also consume disk space and memory. Only add indexes that serve actual query patterns observed in production. Use EXPLAIN ANALYZE to verify an index is being used before adding it permanently."
  },
  {
    question: "Does this tool send my SQL to a server?",
    answer: "No. All analysis runs entirely in your browser using JavaScript. Your query text is never sent to any server."
  },
];
---

<BaseLayout
  title="SQL Index Advisor — Suggest Indexes for Your SQL Queries"
  description="Paste a SQL SELECT query to get instant index recommendations. Detects WHERE filters, JOIN columns, and ORDER BY expressions. Generates CREATE INDEX statements with type guidance (B-tree, Hash, Composite). Runs 100% in your browser."
  tool="SQL index advisor, CREATE INDEX generator, query optimization, missing index detector, B-tree index, composite index, PostgreSQL index, MySQL index, WHERE clause index"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "SQL Index Advisor",
    "url": "https://devplaybook.cc/tools/index-advisor",
    "description": "Paste a SQL SELECT query to get index recommendations. Detects WHERE, JOIN, and ORDER BY columns, suggests index types, and generates ready-to-run CREATE INDEX statements.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">SQL Index Advisor</h1>
  <p class="text-text-muted mb-4">
    Paste a <code class="font-mono bg-surface px-1 rounded text-sm">SELECT</code> query with <code class="font-mono bg-surface px-1 rounded text-sm">WHERE</code>, <code class="font-mono bg-surface px-1 rounded text-sm">JOIN</code>, or <code class="font-mono bg-surface px-1 rounded text-sm">ORDER BY</code> clauses.
    The advisor detects which columns need indexes, suggests the index type, and generates <code class="font-mono bg-surface px-1 rounded text-sm">CREATE INDEX</code> SQL.
    Runs entirely in your browser — nothing is sent to a server.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> WHERE / JOIN / ORDER BY analysis</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> B-tree, Hash, Composite guidance</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CREATE INDEX SQL ready to run</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Cardinality &amp; selectivity warnings</span>
  </div>

  <div class="mb-4">
    <div class="flex items-center justify-between mb-2">
      <label class="text-sm font-medium" for="query-input">SQL SELECT Query</label>
      <div class="flex gap-2">
        <button id="btn-example" class="px-3 py-1.5 bg-bg-card border border-border rounded-lg text-xs hover:border-primary transition-colors">Load Example</button>
        <button id="btn-clear" class="px-3 py-1.5 bg-bg-card border border-border rounded-lg text-xs hover:border-primary transition-colors">Clear</button>
      </div>
    </div>
    <textarea
      id="query-input"
      class="w-full bg-bg-card border border-border rounded-xl p-4 font-mono text-sm focus:outline-none focus:border-primary resize-none"
      rows="10"
      placeholder="Paste your SELECT query here…"
      spellcheck="false"
    ></textarea>
  </div>

  <div class="flex gap-3 mb-6 flex-wrap">
    <button id="btn-analyze" class="px-5 py-2.5 bg-primary text-white rounded-lg text-sm font-semibold hover:bg-primary/90 transition-colors">Analyze Query</button>
  </div>

  <div id="error-box" class="hidden mb-4 p-4 bg-red-500/10 border border-red-500/30 rounded-lg text-sm text-red-400"></div>

  <!-- Output -->
  <div id="output-section" class="hidden space-y-5">
    <!-- Summary -->
    <div id="summary-bar" class="flex flex-wrap gap-2"></div>

    <!-- Index recommendations -->
    <div id="recommendations-list" class="space-y-3"></div>

    <!-- Generated SQL -->
    <div class="bg-bg-card border border-border rounded-xl overflow-hidden">
      <div class="flex items-center justify-between px-4 py-2 border-b border-border">
        <span class="text-sm font-semibold">Generated CREATE INDEX Statements</span>
        <button id="btn-copy-sql" class="px-3 py-1 text-xs bg-bg-card border border-border rounded hover:border-primary transition-colors">Copy All</button>
      </div>
      <pre id="create-index-sql" class="font-mono text-sm p-4 whitespace-pre overflow-x-auto text-green-300 leading-relaxed max-h-80 overflow-y-auto"></pre>
    </div>

    <!-- Explain hint -->
    <div class="p-4 bg-blue-500/5 border border-blue-500/20 rounded-xl text-sm text-text-muted leading-relaxed">
      <span class="text-blue-400 font-semibold">Pro tip:</span> After adding indexes, run <code class="font-mono text-xs bg-surface px-1 rounded">EXPLAIN ANALYZE</code> (PostgreSQL) or <code class="font-mono text-xs bg-surface px-1 rounded">EXPLAIN FORMAT=JSON</code> (MySQL) on your query to verify the index is being used and check actual vs estimated row counts.
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SQL Index Advisor" relatedTags={['database', 'sql', 'performance', 'postgresql', 'mysql', 'query-optimization', 'indexing']} />
</BaseLayout>

<script>
// ─── Types ────────────────────────────────────────────────────────────────────
interface IndexRec {
  table: string;
  columns: string[];
  reason: string;
  indexType: 'B-tree' | 'Hash' | 'Composite';
  priority: 'high' | 'medium' | 'low';
  source: 'WHERE' | 'JOIN' | 'ORDER BY' | 'Composite';
  warning?: string;
}

// ─── Low-cardinality heuristics ───────────────────────────────────────────────
const LOW_CARD_PATTERNS = /^(status|type|state|flag|is_|active|enabled|deleted|archived|gender|role|tier|level|priority|visibility)/i;
const HIGH_CARD_PATTERNS = /^(id$|_id$|uuid|email|username|token|hash|slug|sku|code|phone|ip_)/i;

function guessCardinality(col: string): 'high' | 'low' | 'unknown' {
  if (HIGH_CARD_PATTERNS.test(col)) return 'high';
  if (LOW_CARD_PATTERNS.test(col)) return 'low';
  return 'unknown';
}

// ─── Parser ───────────────────────────────────────────────────────────────────
function unquote(s: string): string {
  return s.replace(/^[`"'\[]|[`"'\]]$/g, '').trim();
}

interface ParsedQuery {
  tables: Record<string, string>; // alias -> real table name
  whereColumns: Array<{ table: string; col: string; op: string }>;
  joinColumns: Array<{ table: string; col: string }>;
  orderColumns: Array<{ table: string; col: string }>;
}

function parseQuery(sql: string): ParsedQuery {
  const upper = sql.toUpperCase();
  const tables: Record<string, string> = {};
  const whereColumns: Array<{ table: string; col: string; op: string }> = [];
  const joinColumns: Array<{ table: string; col: string }> = [];
  const orderColumns: Array<{ table: string; col: string }> = [];

  // Extract tables from FROM and JOIN clauses
  const fromRe = /(?:FROM|JOIN)\s+([`"\[\w]+)(?:\s+(?:AS\s+)?([`"\[\w]+))?/gi;
  let m: RegExpExecArray | null;
  while ((m = fromRe.exec(sql)) !== null) {
    const tbl = unquote(m[1]);
    const alias = m[2] ? unquote(m[2]) : tbl;
    tables[alias.toLowerCase()] = tbl;
    tables[tbl.toLowerCase()] = tbl;
  }

  function resolveTable(qualifier: string | undefined, col: string): string {
    if (qualifier) {
      return tables[qualifier.toLowerCase()] || qualifier;
    }
    // Try to infer from column name
    const colonMatch = col.match(/^(\w+)\.(\w+)$/);
    if (colonMatch) return tables[colonMatch[1].toLowerCase()] || colonMatch[1];
    // Return first table if only one
    const tblList = Object.values(tables);
    const unique = [...new Set(tblList)];
    return unique[0] || 'unknown_table';
  }

  // WHERE clause columns
  // Find WHERE block (until ORDER BY / GROUP BY / HAVING / LIMIT or end)
  const whereMatch = sql.match(/\bWHERE\b([\s\S]+?)(?:\bORDER\s+BY\b|\bGROUP\s+BY\b|\bHAVING\b|\bLIMIT\b|\bUNION\b|$)/i);
  if (whereMatch) {
    const whereBlock = whereMatch[1];
    // Match: [table.]col [=|>|<|>=|<=|!=|<>|LIKE|IN|IS|BETWEEN]
    const condRe = /(?:(\w+)\.)?(\w+)\s*(=|!=|<>|>=|<=|>|<|\bLIKE\b|\bIN\b|\bIS\b|\bBETWEEN\b)/gi;
    let cond: RegExpExecArray | null;
    while ((cond = condRe.exec(whereBlock)) !== null) {
      const qualifier = cond[1];
      const col = cond[2];
      const op = cond[3].toUpperCase();
      if (/^(AND|OR|NOT|NULL|TRUE|FALSE|IS)$/i.test(col)) continue;
      whereColumns.push({ table: resolveTable(qualifier, col), col: unquote(col), op });
    }
  }

  // JOIN ON columns
  const joinOnRe = /\bON\b\s+(?:(\w+)\.)?(\w+)\s*=\s*(?:(\w+)\.)?(\w+)/gi;
  while ((m = joinOnRe.exec(sql)) !== null) {
    const t1 = resolveTable(m[1], m[2]);
    const t2 = resolveTable(m[3], m[4]);
    joinColumns.push({ table: t1, col: unquote(m[2]) });
    joinColumns.push({ table: t2, col: unquote(m[4]) });
  }

  // ORDER BY columns
  const orderMatch = sql.match(/\bORDER\s+BY\b([\s\S]+?)(?:\bLIMIT\b|\bHAVING\b|$)/i);
  if (orderMatch) {
    const orderBlock = orderMatch[1];
    const orderColRe = /(?:(\w+)\.)?(\w+)(?:\s+(?:ASC|DESC))?/gi;
    let oc: RegExpExecArray | null;
    while ((oc = orderColRe.exec(orderBlock)) !== null) {
      const col = oc[2];
      if (/^(ASC|DESC|NULLS|FIRST|LAST)$/i.test(col)) continue;
      orderColumns.push({ table: resolveTable(oc[1], col), col: unquote(col) });
    }
  }

  return { tables, whereColumns, joinColumns, orderColumns };
}

// ─── Advisor ──────────────────────────────────────────────────────────────────
function advise(parsed: ParsedQuery): IndexRec[] {
  const recs: IndexRec[] = [];
  const seen = new Set<string>();

  function key(table: string, cols: string[]): string {
    return `${table}:${cols.join(',')}`;
  }

  function add(rec: IndexRec): void {
    const k = key(rec.table, rec.columns);
    if (seen.has(k)) return;
    seen.add(k);
    recs.push(rec);
  }

  // JOIN columns (highest priority)
  parsed.joinColumns.forEach(({ table, col }) => {
    if (col.toLowerCase() === 'id') return; // primary keys already indexed
    const card = guessCardinality(col);
    add({
      table, columns: [col],
      reason: `Column \`${col}\` is used in a JOIN ON condition. Without an index, each join requires a full table scan of \`${table}\`.`,
      indexType: 'B-tree',
      priority: 'high',
      source: 'JOIN',
      warning: card === 'low' ? `\`${col}\` appears to have low cardinality. Verify with SELECT COUNT(DISTINCT ${col}) / COUNT(*) — if < 5%, the index may not be used by the query planner.` : undefined,
    });
  });

  // WHERE equality columns
  const eqCols = parsed.whereColumns.filter(c => c.op === '=');
  eqCols.forEach(({ table, col, op: _op }) => {
    if (col.toLowerCase() === 'id') return;
    const card = guessCardinality(col);
    add({
      table, columns: [col],
      reason: `Column \`${col}\` is used in a WHERE equality filter. A B-tree index on \`${col}\` allows the planner to seek directly to matching rows.`,
      indexType: 'B-tree',
      priority: 'high',
      source: 'WHERE',
      warning: card === 'low' ? `\`${col}\` appears to have low cardinality (e.g., status, boolean). The planner may ignore this index if it expects > ~5% of rows to match. Consider a partial index: CREATE INDEX ... WHERE ${col} = 'active'.` : undefined,
    });
  });

  // WHERE range columns
  const rangeCols = parsed.whereColumns.filter(c => ['>', '<', '>=', '<=', 'BETWEEN', 'LIKE'].includes(c.op));
  rangeCols.forEach(({ table, col }) => {
    if (col.toLowerCase() === 'id') return;
    add({
      table, columns: [col],
      reason: `Column \`${col}\` is used in a range filter (${['>', '<', '>=', '<=', 'BETWEEN'].includes(parsed.whereColumns.find(c => c.col === col)?.op || '') ? 'range' : 'LIKE'}). B-tree indexes support range scans efficiently.`,
      indexType: 'B-tree',
      priority: 'medium',
      source: 'WHERE',
      warning: col.toLowerCase().includes('text') || col.toLowerCase().includes('desc')
        ? 'For LIKE patterns, only left-anchored patterns (prefix%) use a B-tree index. Use a full-text index (GIN in PostgreSQL, FULLTEXT in MySQL) for arbitrary substring matching.'
        : undefined,
    });
  });

  // ORDER BY columns
  parsed.orderColumns.forEach(({ table, col }) => {
    if (col.toLowerCase() === 'id') return;
    // Check if already indexed by WHERE
    const alreadyHigh = recs.some(r => r.table === table && r.columns[0] === col && r.priority === 'high');
    if (!alreadyHigh) {
      add({
        table, columns: [col],
        reason: `Column \`${col}\` is in the ORDER BY clause. An index on \`${col}\` allows the database to return pre-sorted rows, eliminating a filesort operation.`,
        indexType: 'B-tree',
        priority: 'medium',
        source: 'ORDER BY',
      });
    }
  });

  // Composite index suggestion: if table has 2+ WHERE equality columns
  const tableEqCols: Record<string, string[]> = {};
  eqCols.forEach(({ table, col }) => {
    if (!tableEqCols[table]) tableEqCols[table] = [];
    if (!tableEqCols[table].includes(col)) tableEqCols[table].push(col);
  });

  Object.entries(tableEqCols).forEach(([table, cols]) => {
    if (cols.length < 2) return;
    const k = key(table, cols);
    if (seen.has(k)) return;
    seen.add(k);

    // Also include ORDER BY column as last in composite
    const orderCol = parsed.orderColumns.find(o => o.table === table)?.col;
    const compositeCols = orderCol && !cols.includes(orderCol) ? [...cols, orderCol] : cols;

    recs.push({
      table,
      columns: compositeCols,
      reason: `Table \`${table}\` is filtered on ${cols.map(c => `\`${c}\``).join(' AND ')}${orderCol ? ` and sorted by \`${orderCol}\`` : ''}. A composite index covering all these columns in one index is more efficient than separate single-column indexes.`,
      indexType: 'Composite',
      priority: 'high',
      source: 'Composite',
    });
  });

  // Sort: high → medium → low
  const order = { high: 0, medium: 1, low: 2 };
  recs.sort((a, b) => order[a.priority] - order[b.priority]);

  return recs;
}

// ─── SQL generator ────────────────────────────────────────────────────────────
function genCreateIndex(recs: IndexRec[]): string {
  return recs.map(rec => {
    const cols = rec.columns.join(', ');
    const idxName = `idx_${rec.table}_${rec.columns.join('_')}`;
    const using = rec.indexType === 'Hash' ? ' USING HASH' : '';
    return `-- ${rec.source} — ${rec.priority.toUpperCase()} priority\nCREATE INDEX ${idxName}\n  ON ${rec.table} (${cols})${using};`;
  }).join('\n\n');
}

// ─── Render ───────────────────────────────────────────────────────────────────
const PRIORITY_STYLES: Record<string, { badge: string; border: string }> = {
  high:   { badge: 'bg-red-500/15 text-red-400 border-red-500/30',    border: 'border-red-500/20' },
  medium: { badge: 'bg-yellow-500/15 text-yellow-400 border-yellow-500/30', border: 'border-yellow-500/20' },
  low:    { badge: 'bg-blue-500/15 text-blue-400 border-blue-500/30', border: 'border-blue-500/20' },
};

const SOURCE_BADGE: Record<string, string> = {
  'WHERE':     'bg-purple-500/15 text-purple-400 border-purple-500/30',
  'JOIN':      'bg-green-500/15 text-green-400 border-green-500/30',
  'ORDER BY':  'bg-blue-500/15 text-blue-400 border-blue-500/30',
  'Composite': 'bg-orange-500/15 text-orange-400 border-orange-500/30',
};

function renderRecs(recs: IndexRec[]): void {
  const list = document.getElementById('recommendations-list')!;
  list.innerHTML = '';

  if (recs.length === 0) {
    list.innerHTML = '<p class="text-sm text-text-muted p-4 bg-bg-card border border-border rounded-xl">No index recommendations found. The query may already be well-indexed, or it may not contain WHERE/JOIN/ORDER BY clauses that benefit from indexing.</p>';
    return;
  }

  recs.forEach(rec => {
    const p = PRIORITY_STYLES[rec.priority];
    const srcBadge = SOURCE_BADGE[rec.source] || '';
    const colsList = rec.columns.map(c => `<code class="font-mono text-xs bg-surface px-1.5 py-0.5 rounded">${c}</code>`).join(' + ');

    const card = document.createElement('div');
    card.className = `bg-bg-card border ${p.border} rounded-xl overflow-hidden`;
    card.innerHTML = `
      <div class="px-4 py-3 border-b border-border flex flex-wrap items-center gap-2">
        <span class="font-mono text-sm font-semibold text-foreground">${rec.table}</span>
        <span class="text-text-muted text-xs">(${colsList})</span>
        <div class="ml-auto flex items-center gap-2 flex-wrap">
          <span class="text-xs px-2 py-0.5 rounded-full border ${srcBadge}">${rec.source}</span>
          <span class="text-xs px-2 py-0.5 rounded-full border ${p.badge}">${rec.priority} priority</span>
          <span class="text-xs px-2 py-0.5 rounded bg-bg-card border border-border text-text-muted">${rec.indexType}</span>
        </div>
      </div>
      <div class="px-4 py-3">
        <p class="text-sm text-foreground leading-relaxed mb-2">${rec.reason}</p>
        ${rec.warning ? `<p class="text-xs text-yellow-300 leading-relaxed mt-2 p-2 rounded bg-yellow-500/10 border border-yellow-500/20">⚠ ${rec.warning}</p>` : ''}
        <code class="block font-mono text-xs text-green-400 mt-3 p-2 rounded bg-surface">CREATE INDEX idx_${rec.table}_${rec.columns.join('_')} ON ${rec.table} (${rec.columns.join(', ')})${rec.indexType === 'Hash' ? ' USING HASH' : ''};</code>
      </div>
    `;
    list.appendChild(card);
  });
}

// ─── Example ──────────────────────────────────────────────────────────────────
const EXAMPLE_QUERY = `SELECT
  o.id,
  o.status,
  o.total_cents,
  u.email,
  u.username,
  p.name AS product_name,
  oi.quantity
FROM orders o
JOIN users u ON u.id = o.user_id
JOIN order_items oi ON oi.order_id = o.id
JOIN products p ON p.id = oi.product_id
WHERE o.status = 'pending'
  AND o.created_at >= '2026-01-01'
  AND u.is_active = TRUE
ORDER BY o.created_at DESC
LIMIT 50;`;

document.getElementById('btn-example')?.addEventListener('click', () => {
  (document.getElementById('query-input') as HTMLTextAreaElement).value = EXAMPLE_QUERY;
});

document.getElementById('btn-clear')?.addEventListener('click', () => {
  (document.getElementById('query-input') as HTMLTextAreaElement).value = '';
  document.getElementById('output-section')!.classList.add('hidden');
  document.getElementById('error-box')!.classList.add('hidden');
});

document.getElementById('btn-analyze')?.addEventListener('click', () => {
  const sql = (document.getElementById('query-input') as HTMLTextAreaElement).value.trim();
  const errorBox = document.getElementById('error-box')!;
  const outputSection = document.getElementById('output-section')!;

  errorBox.classList.add('hidden');
  outputSection.classList.add('hidden');

  if (!sql) {
    errorBox.textContent = 'Please paste a SQL SELECT query.';
    errorBox.classList.remove('hidden');
    return;
  }

  if (!/SELECT/i.test(sql)) {
    errorBox.textContent = 'Only SELECT queries are supported. Paste a SELECT statement with WHERE, JOIN, or ORDER BY clauses.';
    errorBox.classList.remove('hidden');
    return;
  }

  const parsed = parseQuery(sql);
  const recs = advise(parsed);

  // Summary bar
  const tables = [...new Set(Object.values(parsed.tables))];
  const summary = document.getElementById('summary-bar')!;
  summary.innerHTML = `
    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-primary/10 border border-primary/30 text-xs text-primary">${tables.length} Table${tables.length !== 1 ? 's' : ''}</span>
    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-red-500/10 border border-red-500/30 text-xs text-red-400">${recs.filter(r => r.priority === 'high').length} High Priority</span>
    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-yellow-500/10 border border-yellow-500/30 text-xs text-yellow-400">${recs.filter(r => r.priority === 'medium').length} Medium Priority</span>
    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-green-500/10 border border-green-500/30 text-xs text-green-400">${recs.length} Index${recs.length !== 1 ? 'es' : ''} Suggested</span>
  `;

  renderRecs(recs);

  const sql_out = recs.length > 0 ? genCreateIndex(recs) : '-- No indexes to generate.';
  document.getElementById('create-index-sql')!.textContent = sql_out;

  outputSection.classList.remove('hidden');
  setTimeout(() => outputSection.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
});

document.getElementById('btn-copy-sql')?.addEventListener('click', (e) => {
  const text = document.getElementById('create-index-sql')!.textContent || '';
  navigator.clipboard.writeText(text).then(() => {
    const btn = e.currentTarget as HTMLButtonElement;
    btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = 'Copy All', 2000);
  });
});
</script>
