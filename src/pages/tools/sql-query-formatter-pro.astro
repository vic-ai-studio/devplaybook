---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SqlQueryFormatter from '../../components/SqlQueryFormatter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What SQL dialects does this formatter support?",
    answer: "The formatter supports MySQL (backtick identifiers, LIMIT/OFFSET syntax), PostgreSQL (double-quoted identifiers, $1/$2 parameter placeholders), and SQLite (PRAGMA support, no stored procedures). Standard ANSI SQL keywords are handled for all dialects."
  },
  {
    question: "How are CTEs (WITH clauses) formatted?",
    answer: "Common Table Expressions are formatted with each CTE on its own lines, properly indented. Multiple CTEs are separated clearly, and the final SELECT that references them is formatted at the base indentation level, making complex analytical queries much easier to read."
  },
  {
    question: "What is syntax highlighting in a SQL formatter?",
    answer: "Syntax highlighting applies distinct colors to SQL keywords (SELECT, FROM, WHERE), string literals, numeric values, comments, and identifiers. This visual separation makes it far easier to scan a formatted query and spot logical sections, missing clauses, or copy-paste errors."
  },
  {
    question: "Does it handle stored procedures and DDL statements?",
    answer: "Yes. CREATE TABLE, ALTER TABLE, CREATE INDEX, DROP TABLE, and similar DDL statements are formatted with proper indentation for column definitions and constraints. INSERT with multi-row VALUES is also formatted cleanly."
  },
  {
    question: "Is my SQL sent to any server?",
    answer: "No. All formatting runs entirely in your browser using JavaScript. Your SQL queries — including any sensitive schema or data details — never leave your machine."
  },
  {
    question: "What's the difference between 2-space and 4-space indentation for SQL?",
    answer: "Two-space indentation keeps queries compact, which is readable for short to medium queries. Four-space indentation provides stronger visual separation and is preferred for long analytical queries with many nested clauses. Both are widely accepted; teams usually standardize on one in their SQL style guide."
  },
];
---

<BaseLayout
  title="SQL Query Formatter Pro — MySQL, PostgreSQL, SQLite Dialect Support"
  description="Advanced SQL formatter with MySQL, PostgreSQL, and SQLite dialect support. Syntax highlighting, format options (indent size, keyword case), and support for CTEs, JOINs, DDL. Free, runs 100% in your browser."
  tool="SQL Query Formatter Pro, SQL Beautifier MySQL PostgreSQL, Format SQL dialect, SQL Pretty Print, SQL syntax highlight, SQL indenter"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "SQL Query Formatter Pro",
    "url": "https://devplaybook.cc/tools/sql-query-formatter-pro",
    "description": "Advanced SQL formatter with dialect support for MySQL, PostgreSQL, and SQLite. Syntax highlighting, configurable indent size and keyword case. Free, runs in your browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">SQL Query Formatter Pro</h1>
  <p class="text-text-muted mb-4">
    Paste any SQL query and get clean, production-ready output. Supports MySQL, PostgreSQL, and SQLite dialect conventions.
    Formats SELECT, INSERT, UPDATE, DELETE, CREATE TABLE, CTEs, and all JOIN variants. Configure indent size, keyword case, and line wrapping — all in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> MySQL / PostgreSQL / SQLite</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Syntax highlighting</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Uppercase or lowercase keywords</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <SqlQueryFormatter client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="SQL Query Formatter Pro" relatedTags={['sql', 'database', 'formatting', 'postgresql', 'mysql', 'sqlite']} />
</BaseLayout>
