---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LighthouseScoreSimulator from '../../components/LighthouseScoreSimulator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "How accurate are the simulated Lighthouse scores?",
    answer: "This tool provides estimates based on simplified heuristics — not actual browser measurement. Real Lighthouse scores depend on many additional factors including server response headers, JavaScript execution time, third-party scripts, layout shifts, font loading, and network conditions. Use this tool to understand which resource types impact performance most, not as a substitute for running Lighthouse in Chrome DevTools or CI."
  },
  {
    question: "What is LCP and why does it matter?",
    answer: "LCP (Largest Contentful Paint) measures how long it takes for the largest visible content element — usually a hero image or heading — to render. Google's Core Web Vitals threshold is LCP ≤ 2.5s (Good). LCP is the most important single metric for perceived load performance and is a direct Google Search ranking signal since 2021."
  },
  {
    question: "What are render-blocking resources?",
    answer: "Render-blocking resources are scripts and stylesheets that prevent the browser from rendering any content until they are fully loaded and parsed. A <script> tag in <head> without async or defer blocks rendering. A <link rel=stylesheet> blocks rendering until the CSS is parsed. To eliminate render-blocking: add async/defer to scripts, inline critical CSS, and lazy-load non-critical styles."
  },
  {
    question: "What is a good Performance score in Lighthouse?",
    answer: "Lighthouse categories scores as: 90-100 = Good (green), 50-89 = Needs Improvement (orange), 0-49 = Poor (red). For competitive web pages, aim for 90+ on desktop and 70+ on mobile. Mobile scores are typically lower due to CPU throttling (4x) and network throttling (Fast 3G) that Lighthouse applies in mobile mode."
  },
  {
    question: "What is the single most impactful way to improve Lighthouse score?",
    answer: "It depends on your bottleneck. For most sites: (1) Compress and lazy-load images (use WebP/AVIF, add loading=lazy). (2) Code-split your JavaScript — large bundles are the #1 killer of Time to Interactive. (3) Eliminate render-blocking resources with async/defer. (4) Improve TTFB by using a CDN and caching static assets. Run Lighthouse to see your specific Opportunities and Diagnostics."
  },
];
---

<BaseLayout
  title="Lighthouse Score Simulator — Estimate Core Web Vitals & Performance Score"
  description="Simulate Lighthouse performance scores based on your resource sizes. Estimate LCP, FID, CLS, FCP, and overall performance score. Get improvement tips. Free, runs in your browser."
  tool="Lighthouse score simulator, Core Web Vitals estimator, LCP calculator, performance score calculator, web performance tool"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Lighthouse Score Simulator",
    "url": "https://devplaybook.cc/tools/lighthouse-score-simulator",
    "description": "Estimate Lighthouse performance scores based on JS bundle size, CSS, images, TTFB, and render-blocking resources. Get LCP, FID, CLS, FCP estimates.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Lighthouse Score Simulator</h1>
  <p class="text-text-muted mb-4">
    Estimate your Lighthouse Performance score and Core Web Vitals — LCP, FID, CLS, FCP — based on your page's resource profile. Adjust JS bundle size, image weight, TTFB, and render-blocking resources to see how each impacts your score.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> LCP, FID, CLS, FCP estimates</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Improvement tips</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Core Web Vitals thresholds</span>
  </div>
  <LighthouseScoreSimulator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Lighthouse Score Simulator" relatedTags={['performance', 'lighthouse', 'core-web-vitals', 'seo', 'web']} />
</BaseLayout>
