---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CssContainerQueryBuilder from '../../components/CssContainerQueryBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is a CSS container query?",
    answer: "A CSS container query lets you apply styles to an element based on the size of its parent container rather than the viewport. This makes truly reusable, component-level responsive design possible — a card component can adapt its layout whether it's placed in a narrow sidebar or a wide main column, without any extra JavaScript or media query hacks.",
  },
  {
    question: "What is container-type and which value should I use?",
    answer: "The container-type property establishes an element as a query container. 'inline-size' (most common) enables queries on the inline axis (width in horizontal writing modes). 'size' enables queries on both inline and block axes (width and height), but requires the container to have a definite height. 'style' enables style-based queries (CSS custom property values). For most use cases, inline-size is the right choice.",
  },
  {
    question: "When should I use a named container?",
    answer: "Use container-name when you have nested containers and need to target a specific ancestor. Without a name, @container queries match the nearest ancestor that is a query container. Naming lets you write '@container sidebar (min-width: 400px)' to always query the sidebar container specifically, regardless of nesting depth.",
  },
  {
    question: "How is a container query different from a media query?",
    answer: "Media queries respond to the viewport (browser window) size. Container queries respond to the containing element's size. This is a fundamental shift: with media queries, a responsive card must know where it will be placed. With container queries, the card adapts to its own available space automatically, making components truly portable and reusable across any layout.",
  },
  {
    question: "What is browser support for CSS container queries?",
    answer: "Container queries are supported in all modern browsers: Chrome/Edge 105+ (August 2022), Firefox 110+ (February 2023), and Safari 16+ (September 2022). Global browser support is above 93% as of 2024. For progressive enhancement, wrap your container query CSS in '@supports (container-type: inline-size) { ... }' to ensure older browsers simply ignore the block.",
  },
];
---

<BaseLayout
  title="CSS Container Query Builder — Generate @container Rules Visually"
  description="Build CSS container queries visually. Set container-type, add named containers, define min-width and max-width breakpoints, and generate ready-to-copy @container CSS. No viewport dependency — true component-level responsive design."
  tool="CSS Container Query Builder, @container CSS, CSS Container Queries, container-type, responsive components, container-name, inline-size"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">CSS Container Query Builder</h1>
  <p class="text-text-muted mb-4">
    Visually build <code class="bg-bg-card border border-border rounded px-1.5 py-0.5 text-sm font-mono">@container</code> rules without memorizing syntax. Configure your container element, add breakpoints with conditions and CSS properties, and get a ready-to-copy stylesheet snippet instantly.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Named &amp; unnamed containers</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> min/max-width &amp; min/max-height conditions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live CSS preview with one-click copy</span>
  </div>
  <CssContainerQueryBuilder client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="CSS Container Query Builder" relatedTags={['css', 'responsive', 'layout', 'frontend', 'design']} />
</BaseLayout>
