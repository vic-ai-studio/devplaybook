---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const configExample = `# lighthouserc.js
module.exports = {
  ci: {
    collect: {
      url: ['https://example.com/', 'https://example.com/about'],
      numberOfRuns: 3,
    },
    assert: {
      assertions: {
        'categories:performance': ['error', { minScore: 0.9 }],
        'categories:accessibility': ['warn', { minScore: 0.9 }],
        'first-contentful-paint': ['error', { maxNumericValue: 2000 }],
        'largest-contentful-paint': ['error', { maxNumericValue: 2500 }],
        'cumulative-layout-shift': ['error', { maxNumericValue: 0.1 }],
        'total-blocking-time': ['warn', { maxNumericValue: 300 }],
      },
    },
    upload: {
      target: 'temporary-public-storage',
    },
  },
};`;

const githubActionsExample = `# .github/workflows/lighthouse.yml
name: Lighthouse CI
on: [push]

jobs:
  lhci:
    name: Lighthouse
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: 20
      - run: npm ci
      - run: npm run build
      - name: Run Lighthouse CI
        run: |
          npm install -g @lhci/cli@0.14.x
          lhci autorun
        env:
          LHCI_GITHUB_APP_TOKEN: \${{ secrets.LHCI_GITHUB_APP_TOKEN }}`;

const faq = [
  { question: "What is Lighthouse CI?", answer: "Lighthouse CI is an open-source tool that makes it easy to run Google Lighthouse performance audits in continuous integration pipelines. It runs Lighthouse against your URLs on every commit, compares results against defined thresholds, and fails your CI build if performance regressions are detected. It also stores historical results so you can track performance trends over time." },
  { question: "How is Lighthouse CI different from running Lighthouse manually?", answer: "Running Lighthouse manually gives you a one-time snapshot. Lighthouse CI automates the process: it runs on every commit, enforces performance budgets (failing CI if thresholds are breached), stores historical data for trend analysis, integrates with GitHub to post PR status checks, and supports running multiple URLs with multiple test runs for statistical accuracy." },
  { question: "What are Core Web Vitals and why do they matter?", answer: "Core Web Vitals are Google's user experience metrics: LCP (Largest Contentful Paint — loading), INP (Interaction to Next Paint — interactivity), and CLS (Cumulative Layout Shift — visual stability). They directly influence Google Search ranking. Lighthouse CI lets you enforce thresholds on these metrics in CI, catching regressions before they reach production and affect your search rankings." },
  { question: "Can Lighthouse CI test authenticated pages?", answer: "Yes. Use the puppeteerScript option in your lighthouserc config to inject a Puppeteer script that handles login flows before Lighthouse runs. Alternatively, use HTTP headers to pass authentication cookies. The collect block supports puppeteerScript, extraHeaders, and chromePath for advanced browser control." },
  { question: "Where can Lighthouse CI store results?", answer: "Three options: temporary-public-storage (free, hosted by Google, results expire after 7 days), a self-hosted LHCI server (lhci server — Node.js app with SQLite or PostgreSQL), or a custom upload target via a webhook. For production use, the self-hosted server gives you full history retention and a dashboard UI." },
  { question: "How many runs should I configure?", answer: "Set numberOfRuns to at least 3. Lighthouse scores can vary between runs due to network conditions, CPU throttling, and background processes. Taking the median of 3 runs gives more stable, reproducible results. For critical performance budgets, use 5 runs." },
];
---

<BaseLayout
  title="Lighthouse CI — Automated Web Performance Audits in CI/CD"
  description="Lighthouse CI automates Google Lighthouse performance audits in your CI pipeline. Enforce Core Web Vitals budgets, track performance trends, and catch regressions before they hit production."
  tool="Lighthouse CI, lhci, web performance CI, Core Web Vitals CI, performance budget, LCP, CLS, TBT, GitHub Actions Lighthouse, lighthouse autorun"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Lighthouse CI — Automated Web Performance Audits in CI/CD",
    "url": "https://devplaybook.cc/tools/lighthouse-ci",
    "description": "Lighthouse CI automates Google Lighthouse performance audits in your CI pipeline. Enforce Core Web Vitals budgets, track performance trends, and catch regressions before they hit production.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Lighthouse CI</h1>
  <p class="text-text-muted mb-6">
    Run Google Lighthouse on every commit. Lighthouse CI integrates web performance audits into your CI/CD pipeline, enforces
    <strong>Core Web Vitals budgets</strong>, and fails the build when performance regressions are detected — before they reach production.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Performance budgets in CI</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Core Web Vitals enforcement</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GitHub PR status checks</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Historical trend tracking</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Lighthouse CI?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Lighthouse CI (<code class="bg-bg-card px-1 rounded text-xs">@lhci/cli</code>) is the official open-source tooling for running Google Lighthouse in automated environments. While Lighthouse itself is a browser audit tool that measures performance, accessibility, SEO, and best practices, Lighthouse CI wraps it for CI pipelines — handling multi-run averaging, threshold assertions, and result storage.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    By adding Lighthouse CI to your workflow, you get a hard gate on performance: if LCP exceeds 2.5s or CLS exceeds 0.1, the build fails and the PR is blocked. This makes performance a first-class engineering constraint, not an afterthought.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Threshold assertions</strong> — fail CI on any Lighthouse metric exceeding your budget (score, numeric, or both)</li>
    <li><strong>Multi-URL support</strong> — audit multiple pages per build (homepage, product page, checkout flow)</li>
    <li><strong>Statistical accuracy</strong> — run N times, use median to smooth out variance</li>
    <li><strong>GitHub integration</strong> — post pass/fail status checks directly on pull requests</li>
    <li><strong>Result storage</strong> — temporary public storage, self-hosted LHCI server, or custom webhook</li>
    <li><strong>Dashboard</strong> — self-hosted server includes a UI for browsing historical results and diffs</li>
    <li><strong>Puppeteer scripts</strong> — test authenticated pages, SPAs, and custom interactions</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Installation</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Install globally or as dev dependency
npm install -g @lhci/cli
# or
npm install --save-dev @lhci/cli

# Verify
lhci --version</pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Configuration (lighthouserc.js)</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={configExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">GitHub Actions Integration</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={githubActionsExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Core Web Vitals Thresholds</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="border-b border-border">
          <th class="text-left py-2 pr-4 font-semibold">Metric</th>
          <th class="text-left py-2 pr-4 font-semibold text-green-500">Good</th>
          <th class="text-left py-2 pr-4 font-semibold text-yellow-500">Needs Improvement</th>
          <th class="text-left py-2 font-semibold text-red-500">Poor</th>
        </tr>
      </thead>
      <tbody class="text-text-muted">
        <tr class="border-b border-border/50"><td class="py-2 pr-4">LCP (Largest Contentful Paint)</td><td class="py-2 pr-4 text-green-500">&le; 2.5s</td><td class="py-2 pr-4 text-yellow-500">2.5s – 4s</td><td class="py-2 text-red-500">&gt; 4s</td></tr>
        <tr class="border-b border-border/50"><td class="py-2 pr-4">INP (Interaction to Next Paint)</td><td class="py-2 pr-4 text-green-500">&le; 200ms</td><td class="py-2 pr-4 text-yellow-500">200ms – 500ms</td><td class="py-2 text-red-500">&gt; 500ms</td></tr>
        <tr class="border-b border-border/50"><td class="py-2 pr-4">CLS (Cumulative Layout Shift)</td><td class="py-2 pr-4 text-green-500">&le; 0.1</td><td class="py-2 pr-4 text-yellow-500">0.1 – 0.25</td><td class="py-2 text-red-500">&gt; 0.25</td></tr>
        <tr><td class="py-2 pr-4">FCP (First Contentful Paint)</td><td class="py-2 pr-4 text-green-500">&le; 1.8s</td><td class="py-2 pr-4 text-yellow-500">1.8s – 3s</td><td class="py-2 text-red-500">&gt; 3s</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Self-Hosted LHCI Server</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4"># Run via Docker
docker run -p 9001:9001 patrickhulce/lhci-server

# Or install and run with Node.js
npm install -g @lhci/server
lhci server --storage.storageMethod=sql \
  --storage.sqlDialect=sqlite \
  --storage.sqlDatabasePath=./lhci.db</pre>
  <p class="text-text-muted text-sm mb-4">Point your <code class="bg-bg-card px-1 rounded">upload.serverBaseUrl</code> to the server address. The server provides a web UI for browsing historical Lighthouse reports and performance trend charts.</p>

  <ToolPageCta />
  <FaqSection faqs={faq} />
</BaseLayout>
