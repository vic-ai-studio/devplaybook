---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const installExample = `# Install the Bruno CLI globally (for CI/scripting)
npm install -g @usebruno/cli

# Run a collection from the CLI
bru run --env production

# Run a specific folder of requests
bru run requests/users --env staging

# Run with environment variables and output JUnit XML (for CI)
bru run --env ci --reporter junit --output results.xml

# Download the GUI app (macOS / Windows / Linux)
# https://www.usebruno.com/downloads`;

const bruFileExample = `# requests/users/get-user.bru
meta {
  name: Get User by ID
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/users/{{userId}}
  body: none
  auth: bearer
}

headers {
  Accept: application/json
  X-Request-ID: {{$randomUuid}}
}

auth:bearer {
  token: {{authToken}}
}

assert {
  res.status: eq 200
  res.body.id: eq {{userId}}
  res.body.email: isDefined
}`;

const postRequestExample = `# requests/auth/login.bru
meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{userEmail}}",
    "password": "{{userPassword}}"
  }
}

script:post-response {
  // Save the token for subsequent requests
  const token = res.getBody().token;
  bru.setVar("authToken", token);
}

assert {
  res.status: eq 200
  res.body.token: isDefined
}`;

const envExample = `# environments/staging.bru
vars {
  baseUrl: https://staging.api.example.com
  userId: 42
  userEmail: test@example.com
}

vars:secret [
  userPassword,
  authToken
]

# environments/production.bru
vars {
  baseUrl: https://api.example.com
  userId: 42
  userEmail: prod-test@example.com
}

vars:secret [
  userPassword,
  authToken
]`;

const scriptExample = `// script:pre-request - runs before the HTTP request is sent
const timestamp = new Date().toISOString();
bru.setVar("requestTime", timestamp);

// Access environment variables
const baseUrl = bru.getEnvVar("baseUrl");
console.log("Sending request to:", baseUrl);

// script:post-response - runs after the response arrives
if (res.getStatus() === 401) {
  bru.setVar("authToken", "");
  console.warn("Token expired - clear and re-authenticate");
}

// Assertions in scripts (alternative to the assert block)
expect(res.getStatus()).to.equal(200);
expect(res.getBody()).to.have.property("id");`;

const faq = [
  {
    question: "What is Bruno?",
    answer: "Bruno is an open-source, offline-first API client for testing REST, GraphQL, and other HTTP-based APIs. It is designed as a direct alternative to Postman and Insomnia, with one key difference: every collection is stored as plain text files using Bruno's own Bru format on your local filesystem. There is no cloud sync, no account required, and no subscription - your API collections live alongside your source code in Git."
  },
  {
    question: "How does Bruno differ from Postman?",
    answer: "The biggest difference is that Bruno stores collections as plain text .bru files on disk, making them fully version-controllable with Git. Postman stores collections in its cloud by default and requires an account. Bruno has no cloud sync, no telemetry, no pricing tiers that gate features, and is open source under the MIT license. Postman has a more mature GUI, a larger ecosystem of published collections, and built-in cloud collaboration. If Git-native workflows and offline-first operation matter to you, Bruno is the better choice."
  },
  {
    question: "What is the Bru file format?",
    answer: "Bru is a simple, human-readable plain text format developed specifically for Bruno. Each .bru file represents one HTTP request and contains the method, URL, headers, body, authentication, pre/post-request scripts, and assertions - all in a clearly structured, diff-friendly format. Because .bru files are plain text, they can be reviewed in pull requests, searched with grep, and edited in any text editor without needing the Bruno GUI."
  },
  {
    question: "Can Bruno run in CI/CD pipelines?",
    answer: "Yes. Bruno ships a CLI tool (@usebruno/cli, installed via npm) that lets you run collections headlessly in any CI environment - GitHub Actions, GitLab CI, Jenkins, and others. You can target a specific environment file, output results as JUnit XML or JSON, and fail the build on assertion errors. This makes Bruno a complete API testing solution from local development through automated CI."
  },
  {
    question: "Is Bruno open source?",
    answer: "Yes. Bruno is fully open source under the MIT license. The source code is available on GitHub at github.com/usebruno/bruno. The core GUI application, the CLI runner, and the Bru language parser are all open source. There is no paid tier or proprietary cloud component - the entire tool is free to use, self-host, and contribute to."
  },
  {
    question: "Can I import existing Postman or Insomnia collections into Bruno?",
    answer: "Yes. Bruno supports importing collections exported from Postman (v2.1 JSON format) and Insomnia. After importing, Bruno converts each request into the .bru plain text format so you can immediately commit them to Git. Environment variables and authentication configs are also migrated. Some advanced Postman features may require manual adjustment after import."
  },
];
---

<BaseLayout
  title="Bruno - Offline Git-Friendly API Client (Postman Alternative)"
  description="Bruno is an open-source, offline-first API client that stores collections as plain text Bru files. No cloud sync, no account required - commit your API requests directly to Git."
  tool="bruno, api client, postman alternative, insomnia alternative, bru lang, offline api testing, git api collections, http client"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Bruno - Offline Git-Friendly API Client (Postman Alternative)",
    "url": "https://devplaybook.cc/tools/bruno",
    "description": "Bruno is an open-source, offline-first API client that stores collections as plain text Bru files. No cloud sync, no account required - commit your API requests directly to Git.",
  })} />

  <h1 class="text-3xl font-bold mb-2">Bruno</h1>
  <p class="text-text-muted mb-6">
    Open-source, offline-first API client that stores collections as plain text files alongside your source code.
    No cloud sync, no account, no subscription - commit your requests to Git and review them in pull requests like any other code.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Offline-first</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Git-native (plain text Bru files)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> No account required</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> Built-in scripting</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> CLI for CI/CD</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">&#10003;</span> MIT open source</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is Bruno?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    Bruno is an open-source API client built for developers who want their HTTP collections to live where their code lives - in a Git repository. While tools like Postman store collections in the cloud and require an account to collaborate, Bruno takes the opposite approach: every request is a plain text <code class="bg-bg-card px-1 rounded text-xs">.bru</code> file you can read, edit, diff, and commit without ever opening the GUI.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    Bruno supports REST, GraphQL, and other HTTP APIs. It includes environments and variables, pre/post-request JavaScript scripting, assertions, authentication (bearer, basic, API key, OAuth 2.0), and a CLI runner for CI pipelines. The GUI app is available for macOS, Windows, and Linux. The project is fully open source under the MIT license with no paid tier or proprietary cloud component.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Offline-first</strong> - works without an internet connection; no cloud sync, no telemetry, no account required</li>
    <li><strong>Git-native storage</strong> - collections are plain text .bru files; diff them, review them in PRs, search with grep</li>
    <li><strong>Bru language</strong> - human-readable format for requests: method, URL, headers, body, scripts, and assertions in one file</li>
    <li><strong>Environments &amp; variables</strong> - switch between dev/staging/production configs; secrets kept out of version control</li>
    <li><strong>JavaScript scripting</strong> - run pre/post-request scripts to set variables, chain requests, or validate complex responses</li>
    <li><strong>Assertions</strong> - declare expected status codes, body properties, and header values directly in the .bru file</li>
    <li><strong>Import from Postman/Insomnia</strong> - migrate existing collections with a single import action</li>
    <li><strong>CLI runner</strong> - run collections headlessly with <code class="bg-bg-card px-1 rounded text-xs">bru run</code> in any CI environment</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Installation</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={installExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">GET Request with Assertions</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Each request is a standalone <code class="bg-bg-card px-1 rounded text-xs">.bru</code> file. The <code class="bg-bg-card px-1 rounded text-xs">assert</code> block lets you declare expected response values inline - no separate test file needed.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={bruFileExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">POST Request with Post-Response Script</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Scripts run after a response arrives and can read the body, set variables, and chain into subsequent requests. Here a login request saves its returned token for use in later requests.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={postRequestExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Environments</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Environment files define variables per target. Secret variable names are declared but their values are stored outside Git - Bruno keeps sensitive data out of your repository automatically.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={envExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Scripting API</h2>
  <p class="text-text-muted mb-3 leading-relaxed">
    Bruno's scripting layer exposes <code class="bg-bg-card px-1 rounded text-xs">bru</code> helpers for reading and writing variables, environment values, and request/response data. Use the Chai-style <code class="bg-bg-card px-1 rounded text-xs">expect</code> API for programmatic assertions.
  </p>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-4" set:html={scriptExample}></pre>

  <h2 class="text-xl font-semibold mt-8 mb-3">Bruno vs Postman</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Feature</th>
          <th class="border border-border px-3 py-2 text-left">Bruno</th>
          <th class="border border-border px-3 py-2 text-left">Postman</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2">Collection storage</td><td class="border border-border px-3 py-2 text-green-400">Plain text files on disk</td><td class="border border-border px-3 py-2">Cloud (proprietary JSON export)</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Git integration</td><td class="border border-border px-3 py-2 text-green-400">Native - commit .bru files</td><td class="border border-border px-3 py-2">Requires export/import</td></tr>
        <tr><td class="border border-border px-3 py-2">Account required</td><td class="border border-border px-3 py-2 text-green-400">No</td><td class="border border-border px-3 py-2">Yes</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Open source</td><td class="border border-border px-3 py-2 text-green-400">Yes (MIT)</td><td class="border border-border px-3 py-2">No</td></tr>
        <tr><td class="border border-border px-3 py-2">CI/CD runner</td><td class="border border-border px-3 py-2 text-green-400">Yes (bru CLI, free)</td><td class="border border-border px-3 py-2">Paid (Newman / Postman Cloud)</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2">Published collection ecosystem</td><td class="border border-border px-3 py-2">Growing</td><td class="border border-border px-3 py-2 text-green-400">Large (Public API Network)</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pros and Cons</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-green-400 mb-2">Pros</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>&#10003; Collections stored as plain text - fully version-controllable</li>
        <li>&#10003; No cloud account, no telemetry, no subscription</li>
        <li>&#10003; Works offline without any setup</li>
        <li>&#10003; MIT open source - no vendor lock-in</li>
        <li>&#10003; Free CLI runner for CI/CD pipelines</li>
        <li>&#10003; Secrets never written to disk or committed to Git</li>
      </ul>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-red-400 mb-2">Cons</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>&#10007; Smaller ecosystem than Postman (fewer published collections)</li>
        <li>&#10007; GUI is less mature than Postman's (fewer advanced UI features)</li>
        <li>&#10007; No built-in team cloud sharing (Git repo is the collaboration layer)</li>
        <li>&#10007; Mock server support is limited compared to Postman</li>
        <li>&#10007; Fewer integrations with monitoring/alerting platforms</li>
      </ul>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="bruno" relatedTags={['api', 'http-client', 'rest', 'testing', 'git']} />
</BaseLayout>
