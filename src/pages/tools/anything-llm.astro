---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is AnythingLLM?", answer: "AnythingLLM is an all-in-one AI application that combines chat, retrieval-augmented generation (RAG), AI agents, and multi-user support into a single self-hosted platform. You connect it to any LLM backend (Ollama, LM Studio, OpenAI, Anthropic, etc.) and use it to chat with documents, run AI agents that browse the web or execute code, and manage multiple workspaces with different configurations." },
  { question: "How does RAG work in AnythingLLM?", answer: "RAG (Retrieval-Augmented Generation) in AnythingLLM lets the AI answer questions using your own documents. Upload PDFs, Word files, text files, or web URLs to a workspace. AnythingLLM chunks the content, creates vector embeddings, and stores them in a local vector database. When you ask a question, relevant chunks are retrieved and injected into the LLM's context window before generating a response — dramatically improving accuracy on your private knowledge." },
  { question: "What LLM backends does AnythingLLM support?", answer: "AnythingLLM supports a wide range of backends: local inference via Ollama, LM Studio, LocalAI, LiteLLM; cloud APIs including OpenAI, Anthropic Claude, Google Gemini, Azure OpenAI, AWS Bedrock, Cohere, Groq, and HuggingFace. You configure the backend per workspace, so different workspaces can use different models." },
  { question: "What can AnythingLLM agents do?", answer: "AnythingLLM's agent mode gives the LLM access to tools: web browsing (fetch and read URLs), code execution (run Python in a sandboxed environment), document search (query your workspace), and custom tool connectors. Agents can chain multiple tool calls to complete multi-step tasks like 'research this topic and summarize it from three sources'." },
  { question: "How do I install AnythingLLM with Docker?", answer: "The recommended installation method is Docker. Run: docker pull mintplexlabs/anythingllm && docker run -d -p 3001:3001 --cap-add SYS_ADMIN -v $(pwd)/anythingllm_storage:/app/server/storage mintplexlabs/anythingllm. Then open http://localhost:3001 and complete the setup wizard. For persistent storage, the volume mount is essential. A Docker Compose file with all options is available in the official repo." },
  { question: "AnythingLLM vs Open WebUI — which should I use?", answer: "Open WebUI is focused on being a polished frontend for Ollama and OpenAI — excellent for chat and model management. AnythingLLM is more of a full platform with RAG, agents, multi-user access control, and workspace isolation. Choose Open WebUI for a clean chat interface with your local models. Choose AnythingLLM when you need document Q&A, agents, or to deploy a shared AI workspace for a team." },
];
---

<BaseLayout
  title="AnythingLLM: All-in-One Local AI with RAG &amp; Agents (2026)"
  description="AnythingLLM is a self-hosted AI platform combining chat, document RAG, AI agents, and multi-user workspaces. Connect to Ollama, LM Studio, or OpenAI. Complete Docker setup guide."
  tool="AnythingLLM, local AI RAG, private AI chat, Docker AI, Ollama frontend, self-hosted AI, document AI"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"AnythingLLM: All-in-One Local AI with RAG & Agents","url":"https://devplaybook.cc/tools/anything-llm","description":"AnythingLLM is a self-hosted AI platform with chat, RAG, agents, and multi-user workspaces — complete guide for 2026."})} />

  <h1 class="text-3xl font-bold mb-2">AnythingLLM: All-in-One Local AI with RAG &amp; Agents</h1>
  <p class="text-text-muted mb-6">AnythingLLM transforms any LLM backend into a powerful knowledge platform. Chat with your documents, deploy AI agents, manage multiple isolated workspaces, and give your whole team access — all self-hosted with full data privacy.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Document RAG (PDF, DOCX, URLs)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> AI agents with web browsing &amp; code execution</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multi-user with role-based access</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Works with Ollama, OpenAI, Anthropic, and more</span>
  </div>

  <ToolPageCta />

  <!-- Docker setup -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Docker Installation (Recommended)</h2>
    <p class="text-text-muted text-sm mb-4">AnythingLLM is best run via Docker. The container includes the frontend, backend, and a default SQLite + vector store — zero external dependencies required to start.</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># Pull and run AnythingLLM
docker pull mintplexlabs/anythingllm

# Run with persistent storage
docker run -d \
  -p 3001:3001 \
  --cap-add SYS_ADMIN \
  -v $(pwd)/anythingllm_storage:/app/server/storage \
  --name anythingllm \
  mintplexlabs/anythingllm

# Open http://localhost:3001 and complete the setup wizard

# Docker Compose (recommended for teams)
# docker-compose.yml:
# version: '3.8'
# services:
#   anythingllm:
#     image: mintplexlabs/anythingllm
#     ports: ["3001:3001"]
#     cap_add: [SYS_ADMIN]
#     volumes: ["./storage:/app/server/storage"]
#     environment:
#       - SERVER_PORT=3001
#       - LLM_PROVIDER=ollama
#       - OLLAMA_BASE_PATH=http://host.docker.internal:11434</code></pre>
  </div>

  <!-- Connecting to Ollama -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Connecting AnythingLLM to Ollama or LM Studio</h2>
    <p class="text-text-muted text-sm mb-4">In the AnythingLLM admin panel, navigate to <strong>Settings &gt; LLM Preferences</strong> and select your backend. For Ollama running on the same machine as Docker, use the special Docker host URL:</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># Ollama connection settings (in AnythingLLM UI):
# LLM Provider: Ollama
# Ollama Base URL: http://host.docker.internal:11434  (Docker on Mac/Windows)
# Ollama Base URL: http://172.17.0.1:11434            (Docker on Linux)
# Model: llama3.2 (or any model you have pulled)

# LM Studio connection settings:
# LLM Provider: LM Studio
# LM Studio Base URL: http://host.docker.internal:1234

# For embedding (required for RAG):
# Embedding Provider: Ollama
# Embedding Model: nomic-embed-text  ← pull this first
# ollama pull nomic-embed-text

# Verify connection by sending a test message in any workspace</code></pre>
  </div>

  <!-- Workspaces and RAG -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">Workspaces, Documents &amp; RAG</h2>
    <p class="text-text-muted text-sm mb-4">Workspaces are isolated AI environments with their own document collections, model settings, and conversation history. Think of each workspace as a separate AI assistant with specialized knowledge.</p>
    <pre class="bg-bg-card border border-border rounded-lg p-4 text-sm font-mono overflow-x-auto mb-4"><code># Workspace RAG workflow:
# 1. Create a workspace (e.g., "Company Docs", "Research", "Codebase")
# 2. Upload documents — supported formats:
#    PDF, DOCX, TXT, MD, CSV, JSON, XML, HTML, YouTube URLs, web URLs
# 3. AnythingLLM auto-embeds documents into the vector store
# 4. Ask questions — responses cite source documents

# Example questions after uploading a product manual PDF:
# "What are the troubleshooting steps for error code E5?"
# "Summarize the maintenance schedule from chapter 3"
# "Compare the specs of model A vs model B"

# Vector DB options (configure in Settings > Vector DB):
# - LanceDB (default, zero config, embedded)
# - Chroma (for external persistence)
# - Pinecone, Weaviate, Qdrant (cloud/self-hosted)</code></pre>
  </div>

  <!-- Agent tools -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-3">AI Agents: Tools &amp; Capabilities</h2>
    <p class="text-text-muted text-sm mb-3">Enable agent mode in a workspace to give the LLM access to external tools. The agent can reason about which tools to use and chain multiple calls together:</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-sm mb-4">
      <div class="border border-border rounded-lg p-3">
        <div class="font-medium mb-1">Web Browser</div>
        <p class="text-text-muted text-xs">Fetch and read web pages, search Google, scrape content from URLs. Useful for research tasks and real-time information.</p>
      </div>
      <div class="border border-border rounded-lg p-3">
        <div class="font-medium mb-1">Code Execution</div>
        <p class="text-text-muted text-xs">Run Python code in a sandboxed environment. Process data, run calculations, generate charts, and return results.</p>
      </div>
      <div class="border border-border rounded-lg p-3">
        <div class="font-medium mb-1">Document Search</div>
        <p class="text-text-muted text-xs">Query the workspace vector store as a tool call. Agent decides when to search documents vs answer from training.</p>
      </div>
      <div class="border border-border rounded-lg p-3">
        <div class="font-medium mb-1">SQL Connector</div>
        <p class="text-text-muted text-xs">Connect to a database and let the agent write and execute queries. Great for data exploration without SQL knowledge.</p>
      </div>
    </div>
  </div>

  <!-- Comparison -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-xl font-semibold mb-4">AnythingLLM vs Open WebUI</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-text-muted text-xs uppercase border-b border-border">
            <th class="text-left pb-2 pr-4">Feature</th>
            <th class="text-left pb-2 pr-4">AnythingLLM</th>
            <th class="text-left pb-2">Open WebUI</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border text-xs">
          <tr><td class="py-2 pr-4 font-medium">Document RAG</td><td class="py-2 pr-4 text-green-500">Built-in (workspace-level)</td><td class="py-2 text-green-500">Built-in (global)</td></tr>
          <tr><td class="py-2 pr-4 font-medium">AI agents</td><td class="py-2 pr-4 text-green-500">Yes (web, code, SQL)</td><td class="py-2 text-yellow-500">Basic (functions)</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Multi-user + RBAC</td><td class="py-2 pr-4 text-green-500">Yes</td><td class="py-2 text-green-500">Yes</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Workspace isolation</td><td class="py-2 pr-4 text-green-500">Yes</td><td class="py-2 text-red-400">No</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Pipe plugins</td><td class="py-2 pr-4 text-red-400">No</td><td class="py-2 text-green-500">Yes</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Model management</td><td class="py-2 pr-4 text-yellow-500">Via backend</td><td class="py-2 text-green-500">Built-in (Ollama)</td></tr>
          <tr><td class="py-2 pr-4 font-medium">Best for</td><td class="py-2 pr-4">Team knowledge base + agents</td><td class="py-2">Personal Ollama frontend</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="AnythingLLM" relatedTags={['ai', 'llm', 'local-ai', 'rag', 'agents', 'self-hosted', 'docker']} />
</BaseLayout>
