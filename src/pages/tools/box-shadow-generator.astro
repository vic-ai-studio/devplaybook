---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BoxShadowGenerator from '../../components/BoxShadowGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="CSS Box Shadow Generator — Interactive Shadow Builder"
  description="Build and preview CSS box-shadow values visually. Multi-layer shadows, inset, blur, spread, opacity controls. Copy the CSS output with one click. Runs in your browser."
  tool="Box Shadow Generator, CSS Shadow, CSS box-shadow"
>
  <h1 class="text-3xl font-bold mb-2">CSS Box Shadow Generator</h1>
  <p class="text-text-muted mb-8">Design multi-layer CSS box shadows with live preview. Adjust offset, blur, spread, color, and opacity. Add preset styles or build layered shadows from scratch.</p>
  <BoxShadowGenerator client:only="preact" />
  <ToolPageCta currentTool="CSS Box Shadow Generator" relatedTags={['css', 'design', 'shadow', 'generator']} />
</BaseLayout>
