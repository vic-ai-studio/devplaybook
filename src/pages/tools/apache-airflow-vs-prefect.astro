---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Apache Airflow and what is it best for?",
    answer: "Apache Airflow is the original open-source workflow orchestration platform, donated to the Apache Software Foundation by Airbnb in 2016. It uses a DAG (Directed Acyclic Graph) model where tasks are defined in Python and the dependency graph is static — declared at parse time, not at runtime. Airflow excels at batch ETL pipelines, scheduled data processing jobs, and complex multi-system workflows where you need fine-grained control over scheduling, retries, and SLA monitoring. Its rich ecosystem of providers (600+ integrations), massive community, and compatibility with every major cloud make it the dominant choice in enterprise data teams. The tradeoff is operational complexity: you manage the scheduler, workers, metadata database, and webserver yourself (or pay for a managed offering like MWAA or Astronomer)."
  },
  {
    question: "How does Prefect differ from Airflow?",
    answer: "Prefect takes a 'Python-first' approach — any Python function becomes a task with a single @task decorator, and flows are just Python functions. Unlike Airflow's static DAGs, Prefect supports dynamic workflows: you can create tasks in a loop, branch based on runtime data, and change the execution graph on the fly. Prefect Cloud provides a generous free tier with a hosted orchestration backend, so your infra only runs the workers. The result is dramatically lower ops overhead compared to self-hosted Airflow. Prefect is ideal for data science teams, ML pipelines, and small-to-medium engineering teams that want modern Python ergonomics over Airflow's XML/DAG paradigms. Prefect 3.x (2025) introduced serverless execution via Prefect Cloud Work Pools, further reducing self-hosting burden."
  },
  {
    question: "What makes Dagster different from Airflow and Prefect?",
    answer: "Dagster is built around software-defined assets (SDAs) rather than tasks or workflows. Instead of defining how to run a pipeline, you declare what data assets exist, how they are computed, and what their dependencies are. Dagster then figures out what to run and when. This asset-centric model provides automatic data lineage, built-in data quality checks (asset checks), and native integration with dbt, Airbyte, and Fivetran. Dagster Cloud's free tier supports full observability. Dagster is the best choice when your primary concern is data reliability, lineage tracking, and building a self-documenting data platform — rather than raw task orchestration. The learning curve is steeper than Prefect but lower than Airflow for complex data pipelines."
  },
  {
    question: "Is Apache Airflow being replaced by newer tools?",
    answer: "Not in the near term. Airflow 2.x and the upcoming Airflow 3 have addressed many historical pain points — dynamic task mapping, better UI, TaskFlow API for decorator-based task definitions, and the AIP-72 event-driven scheduling proposal. Managed offerings (Astronomer, Google Cloud Composer, Amazon MWAA) have reduced operational burden significantly. Airflow's 600+ provider integrations, decade of production battle-testing, and near-universal cloud support mean it remains the default in large enterprises. However, for greenfield projects under 100 pipelines, Prefect or Dagster often provide faster time-to-value with lower ops overhead. Think of Airflow as the 'enterprise default' and Prefect/Dagster as the 'developer-experience-first' alternatives."
  },
];
---

<BaseLayout
  title="Apache Airflow vs Prefect vs Dagster: Workflow Orchestration 2026"
  description="Compare Apache Airflow, Prefect, and Dagster for workflow orchestration. Interactive 5-question quiz recommends the right tool for your team size, use case, and infrastructure preferences."
  tool="Apache Airflow vs Prefect, Dagster comparison, workflow orchestration tools, data pipeline orchestration, Airflow vs Prefect vs Dagster, ETL orchestration"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Apache Airflow vs Prefect vs Dagster</h1>
  <p class="text-text-muted mb-4">Three workflow orchestration tools with radically different philosophies. Answer 5 questions to get a personalized recommendation for your use case.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 5-question decision quiz</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Feature comparison table</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Self-host vs managed breakdown</span>
  </div>

  <!-- Decision Quiz -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-1">Orchestrator Selector Quiz</h2>
    <p class="text-xs text-text-muted mb-4">Answer all 5 questions to get your recommendation.</p>

    <div class="space-y-5" id="quiz-container">

      <div class="quiz-question" data-q="0">
        <p class="text-sm font-medium mb-2">1. What is your primary use case?</p>
        <div class="flex flex-wrap gap-2">
          <button class="quiz-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="0" data-v="etl" data-label="ETL / batch data pipelines">ETL / batch data pipelines</button>
          <button class="quiz-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="0" data-v="ml" data-label="ML training / model pipelines">ML training / model pipelines</button>
          <button class="quiz-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="0" data-v="dataplatform" data-label="Building a data platform / warehouse">Building a data platform</button>
          <button class="quiz-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="0" data-v="general" data-label="General task automation">General task automation</button>
        </div>
      </div>

      <div class="quiz-question" data-q="1">
        <p class="text-sm font-medium mb-2">2. How many pipelines do you expect to manage?</p>
        <div class="flex flex-wrap gap-2">
          <button class="quiz-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="1" data-v="few">&lt; 20 pipelines</button>
          <button class="quiz-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="1" data-v="medium">20–200 pipelines</button>
          <button class="quiz-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="1" data-v="many">200+ pipelines</button>
        </div>
      </div>

      <div class="quiz-question" data-q="2">
        <p class="text-sm font-medium mb-2">3. Infrastructure preference?</p>
        <div class="flex flex-wrap gap-2">
          <button class="quiz-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="2" data-v="selfhost">Self-host everything (Kubernetes / VMs)</button>
          <button class="quiz-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="2" data-v="hybrid">Hybrid (workers self-hosted, control plane managed)</button>
          <button class="quiz-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="2" data-v="fullmanaged">Fully managed / serverless</button>
        </div>
      </div>

      <div class="quiz-question" data-q="3">
        <p class="text-sm font-medium mb-2">4. How important is data lineage and observability?</p>
        <div class="flex flex-wrap gap-2">
          <button class="quiz-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="3" data-v="low">Nice to have — basic logs are fine</button>
          <button class="quiz-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="3" data-v="medium">Important — want good UI and failure visibility</button>
          <button class="quiz-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="3" data-v="critical">Critical — need column-level lineage and data quality checks</button>
        </div>
      </div>

      <div class="quiz-question" data-q="4">
        <p class="text-sm font-medium mb-2">5. Team Python experience?</p>
        <div class="flex flex-wrap gap-2">
          <button class="quiz-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="4" data-v="beginner">Beginner — want simple decorators</button>
          <button class="quiz-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="4" data-v="intermediate">Intermediate — comfortable with Python</button>
          <button class="quiz-btn px-3 py-1.5 text-xs rounded-lg border border-border hover:border-primary transition-colors" data-q="4" data-v="advanced">Advanced — want full control and flexibility</button>
        </div>
      </div>
    </div>

    <div id="quiz-result" class="hidden mt-5 bg-primary/10 border border-primary/30 rounded-xl p-4">
      <p class="text-sm font-bold text-primary mb-1" id="quiz-tool"></p>
      <p class="text-sm text-text-muted" id="quiz-reason"></p>
    </div>
  </div>

  <!-- Comparison Table -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6 overflow-x-auto">
    <h2 class="text-base font-semibold mb-4">Feature Comparison</h2>
    <table class="w-full text-sm min-w-[600px]">
      <thead>
        <tr class="text-text-muted text-xs border-b border-border">
          <th class="text-left pb-3 font-medium w-48">Feature</th>
          <th class="text-center pb-3 font-medium">Airflow</th>
          <th class="text-center pb-3 font-medium">Prefect</th>
          <th class="text-center pb-3 font-medium">Dagster</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border text-xs">
        <tr><td class="py-2.5 text-text-muted font-medium">Open Source</td><td class="py-2.5 text-center text-green-500">✓</td><td class="py-2.5 text-center text-green-500">✓</td><td class="py-2.5 text-center text-green-500">✓</td></tr>
        <tr><td class="py-2.5 text-text-muted font-medium">Self-host friendly</td><td class="py-2.5 text-center text-green-500">✓</td><td class="py-2.5 text-center text-yellow-500">Workers only</td><td class="py-2.5 text-center text-green-500">✓</td></tr>
        <tr><td class="py-2.5 text-text-muted font-medium">Cloud managed tier</td><td class="py-2.5 text-center">Astronomer / MWAA</td><td class="py-2.5 text-center text-green-500">Prefect Cloud</td><td class="py-2.5 text-center">Dagster Cloud</td></tr>
        <tr><td class="py-2.5 text-text-muted font-medium">Python native (decorators)</td><td class="py-2.5 text-center text-yellow-500">TaskFlow API</td><td class="py-2.5 text-center text-green-500">✓ First-class</td><td class="py-2.5 text-center text-green-500">✓ First-class</td></tr>
        <tr><td class="py-2.5 text-text-muted font-medium">Dynamic workflows</td><td class="py-2.5 text-center text-yellow-500">Limited (2.3+)</td><td class="py-2.5 text-center text-green-500">✓ Full</td><td class="py-2.5 text-center text-green-500">✓ Full</td></tr>
        <tr><td class="py-2.5 text-text-muted font-medium">Asset-centric model</td><td class="py-2.5 text-center text-red-400">✗</td><td class="py-2.5 text-center text-red-400">✗</td><td class="py-2.5 text-center text-green-500">✓ Core feature</td></tr>
        <tr><td class="py-2.5 text-text-muted font-medium">Data lineage UI</td><td class="py-2.5 text-center text-red-400">Plugin only</td><td class="py-2.5 text-center text-yellow-500">Flow only</td><td class="py-2.5 text-center text-green-500">Column-level</td></tr>
        <tr><td class="py-2.5 text-text-muted font-medium">Provider integrations</td><td class="py-2.5 text-center text-green-500">600+</td><td class="py-2.5 text-center">100+</td><td class="py-2.5 text-center">50+ (dbt, Airbyte)</td></tr>
        <tr><td class="py-2.5 text-text-muted font-medium">Observability / UI</td><td class="py-2.5 text-center text-yellow-500">Good</td><td class="py-2.5 text-center text-green-500">Excellent</td><td class="py-2.5 text-center text-green-500">Excellent</td></tr>
        <tr><td class="py-2.5 text-text-muted font-medium">Setup complexity</td><td class="py-2.5 text-center text-red-400">High</td><td class="py-2.5 text-center text-green-500">Low</td><td class="py-2.5 text-center text-yellow-500">Medium</td></tr>
        <tr><td class="py-2.5 text-text-muted font-medium">Free tier (hosted)</td><td class="py-2.5 text-center text-red-400">None</td><td class="py-2.5 text-center text-green-500">500 runs/mo</td><td class="py-2.5 text-center text-green-500">Unlimited (OSS)</td></tr>
      </tbody>
    </table>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Airflow vs Prefect vs Dagster" relatedTags={['airflow', 'prefect', 'dagster', 'workflow-orchestration', 'data-engineering', 'etl', 'pipeline']} />
</BaseLayout>

<script>
  const quizAnswers: Record<string, string> = {};

  function computeQuizResult() {
    const { 0: usecase, 1: scale, 2: infra, 3: lineage, 4: python } = quizAnswers as Record<string, string>;
    if (Object.keys(quizAnswers).length < 5) return null;

    // Dagster path: data platform + critical lineage
    if (lineage === 'critical' || usecase === 'dataplatform') {
      return { tool: 'Dagster', reason: 'Your focus on data quality and lineage aligns perfectly with Dagster\'s software-defined assets model. Dagster gives you automatic data lineage, asset checks, and a self-documenting data platform without extra plugins. Dagster Cloud has a generous free tier for small teams.' };
    }
    // Prefect path: ML, few pipelines, beginner, fully managed
    if (usecase === 'ml' || infra === 'fullmanaged' || (scale === 'few' && python === 'beginner')) {
      return { tool: 'Prefect', reason: 'Prefect\'s decorator-based Python API and managed cloud backend (Prefect Cloud) minimize ops overhead. It\'s the fastest way to get production-grade orchestration running — ideal for ML pipelines and teams that want to focus on code rather than Kubernetes.' };
    }
    // Airflow path: 200+ pipelines, advanced, self-host
    if (scale === 'many' || infra === 'selfhost' || python === 'advanced') {
      return { tool: 'Apache Airflow', reason: 'At your scale and infrastructure preference, Airflow\'s battle-tested scheduler, 600+ provider integrations, and large community are hard to beat. Use the TaskFlow API (Airflow 2.x) for cleaner Python code. Consider Astronomer or MWAA to reduce operational burden.' };
    }
    return { tool: 'Prefect', reason: 'For most greenfield projects, Prefect offers the best balance of developer experience, managed infrastructure, and production reliability. You can self-host workers while letting Prefect Cloud handle the control plane for free.' };
  }

  document.querySelectorAll('.quiz-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const q = (btn as HTMLElement).dataset.q!;
      quizAnswers[q] = (btn as HTMLElement).dataset.v!;

      document.querySelectorAll(`.quiz-btn[data-q="${q}"]`).forEach(b => {
        b.classList.remove('border-primary', 'bg-primary/10', 'text-primary');
        b.classList.add('border-border');
      });
      btn.classList.remove('border-border');
      btn.classList.add('border-primary', 'bg-primary/10', 'text-primary');

      const rec = computeQuizResult();
      const resultEl = document.getElementById('quiz-result')!;
      if (rec) {
        resultEl.classList.remove('hidden');
        document.getElementById('quiz-tool')!.textContent = `Recommended: ${rec.tool}`;
        document.getElementById('quiz-reason')!.textContent = rec.reason;
      }
    });
  });
</script>
