---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GraphqlFragmentGenerator from '../../components/GraphqlFragmentGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is a GraphQL fragment and why should I use one?",
    answer: "A GraphQL fragment is a reusable selection set that you define once and spread across multiple queries or mutations with the `...FragmentName` syntax. Fragments keep your queries DRY: when your User type changes, you update one fragment instead of a dozen query strings. They also make it easier to co-locate data requirements with UI components — a pattern strongly recommended by Apollo, urql, and Relay."
  },
  {
    question: "What is the difference between named fragments and inline fragments?",
    answer: "Named fragments (`fragment UserFields on User { ... }`) are defined separately and can be reused across many operations. Inline fragments (`... on User { ... }`) are written directly inside a query and are not reusable. Inline fragments are mainly used for type-narrowing inside union and interface fields, while named fragments are the go-to choice for code reuse and component-driven data fetching."
  },
  {
    question: "When should I use the 'Expand nested types' option?",
    answer: "Enable it when you want fully self-contained fragments that resolve nested object fields immediately. This generates a separate fragment for each nested type (e.g. `AddressFields`) and spreads it inside the parent fragment. Disable it when you prefer shallow fragments and want to explicitly choose which nested fields to include per query — the generator will leave a comment placeholder instead so you know which fields require expansion."
  },
  {
    question: "Why add __typename to every fragment?",
    answer: "__typename tells Apollo Client (and other normalized caches) exactly which type each object is, which is required for correct cache normalization and for type-safe union/interface handling. It is also required if you use Apollo's `possibleTypes` or Relay's store-based fragments. Enabling this option is a good default for any Apollo or Relay project. For urql with the document cache (non-normalized), __typename is less critical."
  },
  {
    question: "Can I use these fragments with Apollo Client, urql, and Relay?",
    answer: "Yes. The generated fragments are standard GraphQL SDL and work with any GraphQL client. With Apollo Client you import the fragment from a `.gql` / `.graphql` file and spread it inside your query document. With urql you do the same via `gql` tagged templates. Relay requires fragments to be co-located with components and uses its own compiler, but the fragment SDL itself is identical — you just wrap it in Relay's `graphql` tag and call `useFragment`."
  },
];
---

<BaseLayout
  title="GraphQL Fragment Generator — Auto-Generate Reusable Fragments from Schema SDL"
  description="Paste any GraphQL SDL schema and instantly generate named, reusable fragments for all your types, interfaces, and unions. Supports nested type expansion, __typename, and custom prefix. Runs entirely in your browser."
  tool="GraphQL Fragment Generator, GraphQL SDL Parser, GraphQL Fragment Builder, GraphQL Schema Tool, Apollo Fragment Generator, urql Fragment Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">GraphQL Fragment Generator</h1>
  <p class="text-text-muted mb-4">
    Paste your GraphQL SDL schema and instantly generate reusable named fragments for every type, interface, and union.
    Supports nested type expansion, <code class="font-mono text-sm bg-bg-card px-1 py-0.5 rounded border border-border">__typename</code>,
    custom fragment name prefixes, and union inline-fragment spreading.
    Everything runs in your browser — no server, no dependencies.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Pure client-side SDL parsing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Object types, interfaces &amp; unions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Works with Apollo, urql &amp; Relay</span>
  </div>
  <GraphqlFragmentGenerator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="GraphQL Fragment Generator" relatedTags={['graphql', 'api', 'developer-tools', 'codegen', 'schema']} />
</BaseLayout>
