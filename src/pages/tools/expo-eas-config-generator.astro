---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is EAS Build and how is it different from classic Expo build?",
    answer: "EAS Build (Expo Application Services) is Expo's cloud build service that replaced the classic 'expo build' command. Key differences: EAS supports bare workflow (ejected apps) and managed workflow, produces native binaries (.ipa for iOS, .apk/.aab for Android), supports custom native code, and offers configurable build environments. Classic expo build is deprecated; EAS is now the recommended approach for all Expo projects."
  },
  {
    question: "What are the differences between development, preview, and production build profiles?",
    answer: "Development profile: includes dev client (Expo Dev Client), enables debugging, connects to your local dev server. Use for active development. Preview profile: internal distribution build (ad-hoc for iOS, APK for Android), no dev client, used for testing with stakeholders before store submission. Production profile: optimized build for app stores, code signing for release, App Store / Google Play ready. Each profile can have different environment variables, credentials, and build configuration."
  },
  {
    question: "Do I need to commit eas.json to version control?",
    answer: "Yes, eas.json should be committed to your repository. It contains build configuration but not secrets. Sensitive values like API keys should be stored as EAS Secrets (set via 'eas secret:create') and referenced as environment variables in eas.json. The eas.json file defines your build profiles, channel assignments, and distribution settings — all of which should be versioned alongside your code."
  },
  {
    question: "What is the difference between managed and bare workflow in Expo?",
    answer: "Managed workflow: Expo handles all native code. You don't have android/ or ios/ directories. Configuration is done via app.json/app.config.js. Best for simpler apps without heavy native customization. Bare workflow: You have full access to native code (android/ and ios/ directories exist after 'expo eject'). You can add any native module. Requires more native build knowledge. EAS Build supports both, but eas.json configuration differs slightly — bare workflow often needs prebuild steps."
  },
  {
    question: "How do I set up iOS distribution certificates for EAS?",
    answer: "EAS handles certificate management automatically. Run 'eas credentials' to set up. For development: EAS creates a development certificate and provisioning profile automatically. For App Store distribution: EAS can create and manage your distribution certificate and provisioning profile using your Apple Developer account credentials. You can also use existing certificates by running 'eas credentials --platform ios'. EAS stores credentials securely in their servers, avoiding the need to manage .p12 files manually."
  }
];
---

<BaseLayout
  title="Expo EAS Config Generator — eas.json Build Profile Generator"
  description="Generate Expo EAS Build configuration files (eas.json) with development, preview, and production profiles. Configure iOS/Android builds, distribution, and submit settings. Free browser tool."
  tool="eas.json generator, expo eas build config, expo eas configuration, eas build profiles, expo build config generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Expo EAS Config Generator",
    "url": "https://devplaybook.cc/tools/expo-eas-config-generator",
    "description": "Generate Expo EAS Build configuration files with development, preview, and production profiles for iOS and Android.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Expo EAS Config Generator</h1>
  <p class="text-text-muted mb-4">
    Generate a complete <code class="text-accent">eas.json</code> configuration for your Expo app.
    Configure build profiles (development, preview, production) with iOS/Android settings and get a copy-ready output.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Managed &amp; bare workflow</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All 3 build profiles</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> iOS + Android support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Submit config included</span>
  </div>

  <!-- Settings -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-medium mb-4">Project Settings</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-xs text-text-muted mb-1">Workflow Type</label>
        <select id="workflow" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="managed">Managed Workflow</option>
          <option value="bare">Bare Workflow</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Target Platforms</label>
        <select id="platforms" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="both">iOS + Android</option>
          <option value="ios">iOS only</option>
          <option value="android">Android only</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Node.js Version</label>
        <select id="node-ver" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="20.9.0">20.9.0 (LTS recommended)</option>
          <option value="18.18.0">18.18.0 (LTS)</option>
          <option value="22.0.0">22.0.0 (latest)</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Android Build Type (Production)</label>
        <select id="android-build-type" class="w-full bg-surface border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="app-bundle">App Bundle (.aab) — Play Store</option>
          <option value="apk">APK — Direct install</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Profile config -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-medium mb-4">Build Profile Options</h2>
    <div class="space-y-3">
      <label class="flex items-center gap-3 cursor-pointer">
        <input type="checkbox" id="include-dev" checked class="w-4 h-4 accent-primary" />
        <div>
          <div class="text-sm font-medium">Development profile</div>
          <div class="text-xs text-text-muted">Dev client enabled, connects to local dev server</div>
        </div>
      </label>
      <label class="flex items-center gap-3 cursor-pointer">
        <input type="checkbox" id="include-preview" checked class="w-4 h-4 accent-primary" />
        <div>
          <div class="text-sm font-medium">Preview profile</div>
          <div class="text-xs text-text-muted">Internal distribution, no dev client (stakeholder testing)</div>
        </div>
      </label>
      <label class="flex items-center gap-3 cursor-pointer">
        <input type="checkbox" id="include-prod" checked class="w-4 h-4 accent-primary" />
        <div>
          <div class="text-sm font-medium">Production profile</div>
          <div class="text-xs text-text-muted">App store ready, optimized release build</div>
        </div>
      </label>
      <label class="flex items-center gap-3 cursor-pointer">
        <input type="checkbox" id="include-submit" class="w-4 h-4 accent-primary" />
        <div>
          <div class="text-sm font-medium">Include submit section</div>
          <div class="text-xs text-text-muted">Adds eas submit config for App Store / Play Store auto-submit</div>
        </div>
      </label>
      <label class="flex items-center gap-3 cursor-pointer">
        <input type="checkbox" id="include-envvars" class="w-4 h-4 accent-primary" />
        <div>
          <div class="text-sm font-medium">Include environment variables example</div>
          <div class="text-xs text-text-muted">Shows how to set API_URL per profile</div>
        </div>
      </label>
    </div>
  </div>

  <button id="generate-btn" class="mb-4 px-5 py-2 bg-primary text-white rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors">Generate eas.json</button>

  <!-- Output -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-sm font-medium">Generated eas.json</h2>
      <button id="copy-eas" class="px-3 py-1.5 bg-primary text-white rounded text-xs font-medium hover:bg-primary/90 transition-colors">Copy</button>
    </div>
    <pre id="eas-output" class="bg-surface rounded p-3 text-xs font-mono text-foreground/90 overflow-x-auto whitespace-pre"></pre>
  </div>

  <!-- app.json snippet -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-sm font-medium">app.json / app.config.js snippet</h2>
      <button id="copy-app" class="px-3 py-1.5 bg-primary text-white rounded text-xs font-medium hover:bg-primary/90 transition-colors">Copy</button>
    </div>
    <pre id="app-output" class="bg-surface rounded p-3 text-xs font-mono text-foreground/90 overflow-x-auto whitespace-pre"></pre>
  </div>

  <!-- Quick start commands -->
  <div class="bg-bg-card border border-border rounded-lg p-4 mb-4">
    <h2 class="text-sm font-medium mb-3">Quick Start Commands</h2>
    <div id="commands-list" class="space-y-2 font-mono text-xs"></div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Expo EAS Config Generator" relatedTags={['expo', 'react-native', 'eas', 'mobile', 'ios', 'android']} />
</BaseLayout>

<script is:inline>
(function() {
  function generate() {
    const workflow = document.getElementById('workflow').value;
    const platforms = document.getElementById('platforms').value;
    const nodeVer = document.getElementById('node-ver').value;
    const androidBuildType = document.getElementById('android-build-type').value;
    const includeDev = document.getElementById('include-dev').checked;
    const includePreview = document.getElementById('include-preview').checked;
    const includeProd = document.getElementById('include-prod').checked;
    const includeSubmit = document.getElementById('include-submit').checked;
    const includeEnv = document.getElementById('include-envvars').checked;
    const isBare = workflow === 'bare';

    const eas = { cli: { version: ">= 10.0.0" }, build: {} };

    if (includeDev) {
      const dev = {
        developmentClient: true,
        distribution: "internal",
      };
      if (includeEnv) dev.env = { APP_ENV: "development", API_URL: "http://localhost:3000" };
      if (platforms !== 'android') {
        dev.ios = { simulator: true };
      }
      if (platforms !== 'ios') {
        dev.android = { buildType: "apk" };
      }
      if (isBare) dev.prebuildCommand = "npx expo prebuild --clean";
      dev.node = nodeVer;
      eas.build.development = dev;
    }

    if (includePreview) {
      const preview = {
        distribution: "internal",
      };
      if (includeEnv) preview.env = { APP_ENV: "preview", API_URL: "https://staging.example.com" };
      if (platforms !== 'android') {
        preview.ios = { distribution: "internal" };
      }
      if (platforms !== 'ios') {
        preview.android = { buildType: "apk" };
      }
      if (isBare) preview.prebuildCommand = "npx expo prebuild --clean";
      preview.node = nodeVer;
      eas.build.preview = preview;
    }

    if (includeProd) {
      const prod = {
        autoIncrement: true,
      };
      if (includeEnv) prod.env = { APP_ENV: "production", API_URL: "https://api.example.com" };
      if (platforms !== 'android') {
        prod.ios = { distribution: "store" };
      }
      if (platforms !== 'ios') {
        prod.android = { buildType: androidBuildType };
      }
      if (isBare) prod.prebuildCommand = "npx expo prebuild --clean";
      prod.node = nodeVer;
      eas.build.production = prod;
    }

    if (includeSubmit) {
      eas.submit = {};
      if (includeProd) {
        const sub = {};
        if (platforms !== 'android') {
          sub.ios = {
            appleId: "your@email.com",
            ascAppId: "1234567890",
            appleTeamId: "XXXXXXXXXX"
          };
        }
        if (platforms !== 'ios') {
          sub.android = {
            serviceAccountKeyPath: "./path/to/service-account.json",
            track: "internal"
          };
        }
        eas.submit.production = sub;
      }
    }

    document.getElementById('eas-output').textContent = JSON.stringify(eas, null, 2);

    // app.json snippet
    const appSnippet = {
      expo: {
        name: "MyApp",
        slug: "my-app",
        version: "1.0.0",
        extra: { eas: { projectId: "your-project-id-here" } }
      }
    };
    if (!isBare) appSnippet.expo.plugins = ["expo-router"];
    document.getElementById('app-output').textContent = JSON.stringify(appSnippet, null, 2);

    // Commands
    const cmds = [
      { cmd: 'npm install -g eas-cli', desc: 'Install EAS CLI' },
      { cmd: 'eas login', desc: 'Authenticate with Expo account' },
      { cmd: 'eas build:configure', desc: 'Initialize EAS in project' },
    ];
    if (includeDev) cmds.push({ cmd: 'eas build --profile development --platform ' + (platforms === 'both' ? 'all' : platforms), desc: 'Build development client' });
    if (includePreview) cmds.push({ cmd: 'eas build --profile preview --platform ' + (platforms === 'both' ? 'all' : platforms), desc: 'Build preview for internal testing' });
    if (includeProd) cmds.push({ cmd: 'eas build --profile production --platform ' + (platforms === 'both' ? 'all' : platforms), desc: 'Build production release' });
    if (includeSubmit && includeProd) cmds.push({ cmd: 'eas submit --profile production', desc: 'Submit to App Store / Play Store' });

    document.getElementById('commands-list').innerHTML = cmds.map(c => `
      <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-4 p-2 bg-surface rounded border border-border">
        <code class="text-accent">${c.cmd}</code>
        <span class="text-text-muted">${c.desc}</span>
      </div>
    `).join('');
  }

  function copyText(id, srcId) {
    const text = document.getElementById(srcId).textContent;
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById(id);
      const orig = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = orig, 1500);
    });
  }

  document.getElementById('generate-btn').addEventListener('click', generate);
  document.getElementById('copy-eas').addEventListener('click', () => copyText('copy-eas', 'eas-output'));
  document.getElementById('copy-app').addEventListener('click', () => copyText('copy-app', 'app-output'));

  // Auto-generate on load
  generate();

  // Regenerate on any input change
  ['workflow','platforms','node-ver','android-build-type'].forEach(id => {
    document.getElementById(id).addEventListener('change', generate);
  });
  ['include-dev','include-preview','include-prod','include-submit','include-envvars'].forEach(id => {
    document.getElementById(id).addEventListener('change', generate);
  });
})();
</script>
