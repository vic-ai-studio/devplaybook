---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is Wei?", answer: "Wei is the smallest denomination of Ether (ETH). 1 ETH = 10^18 Wei. Named after Wei Dai, the creator of b-money. Most Ethereum smart contracts work in Wei internally to avoid floating-point issues." },
  { question: "What is Gwei?", answer: "Gwei (Gigawei) = 10^9 Wei = 0.000000001 ETH. Gas prices are typically quoted in Gwei. For example, '50 Gwei' means the gas price is 50 × 10^9 = 50,000,000,000 Wei." },
  { question: "What are the full ETH denominations?", answer: "Wei (1), Kwei (10^3), Mwei (10^6), Gwei (10^9), Szabo/Microether (10^12), Finney/Milliether (10^15), Ether (10^18). Gwei is the most commonly used intermediate denomination for gas prices." },
  { question: "Why does Ethereum avoid decimals in code?", answer: "Floating-point arithmetic causes precision errors — 0.1 + 0.2 ≠ 0.3 in most languages. Smart contracts use integers (Wei) to avoid this. ERC-20 tokens use 18 decimals by convention, matching ETH's 18 decimal places." },
];
---

<BaseLayout
  title="ETH Unit Converter — Wei, Gwei, Ether Conversion Calculator"
  description="Convert between Ethereum denominations: Wei, Kwei, Mwei, Gwei, Szabo, Finney, and ETH. Instant conversion with full precision for smart contract development."
  tool="ETH Unit Converter, Wei to ETH Calculator, Gwei Converter, Ethereum Denomination Converter"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">ETH Unit Converter</h1>
  <p class="text-text-muted mb-4">Convert between all Ethereum denominations: Wei, Gwei, Ether, and more. Essential for smart contract development and gas price calculations.</p>

  <div class="bg-bg-card border border-border rounded-xl p-5 max-w-2xl">
    <div class="space-y-3">
      {[
        { id: 'wei', label: 'Wei', factor: '1' },
        { id: 'kwei', label: 'Kwei (10³)', factor: '1000' },
        { id: 'mwei', label: 'Mwei (10⁶)', factor: '1000000' },
        { id: 'gwei', label: 'Gwei (10⁹)', factor: '1000000000' },
        { id: 'szabo', label: 'Szabo / Microether (10¹²)', factor: '1000000000000' },
        { id: 'finney', label: 'Finney / Milliether (10¹⁵)', factor: '1000000000000000' },
        { id: 'ether', label: 'Ether (ETH)', factor: '1000000000000000000' },
      ].map(unit => (
        <div class="flex items-center gap-3">
          <label class="w-48 text-sm text-text-muted flex-shrink-0">{unit.label}</label>
          <input
            id={`unit-${unit.id}`}
            type="text"
            placeholder="0"
            data-factor={unit.factor}
            class="unit-input flex-1 bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary"
          />
        </div>
      ))}
    </div>

    <div class="mt-4 flex gap-2">
      <button id="clear-all" class="text-xs text-text-muted border border-border px-3 py-1.5 rounded-lg hover:bg-bg">Clear</button>
      <button id="set-1eth" class="text-xs text-text-muted border border-border px-3 py-1.5 rounded-lg hover:bg-bg">Set 1 ETH</button>
      <button id="set-50gwei" class="text-xs text-text-muted border border-border px-3 py-1.5 rounded-lg hover:bg-bg">Set 50 Gwei</button>
    </div>
  </div>

  <AdUnit slot="in-content" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="ETH Unit Converter" relatedTags={['blockchain', 'ethereum', 'web3', 'smart-contracts', 'defi']} />
</BaseLayout>

<script>
const WEI_PER_ETH = BigInt('1000000000000000000');

function parseWei(value: string, factor: bigint): bigint | null {
  if (!value || value === '') return null;
  try {
    // Handle decimals
    const [intPart, decPart = ''] = value.split('.');
    const dec = decPart.padEnd(18, '0').slice(0, 18);
    const int = BigInt(intPart || '0') * WEI_PER_ETH;
    const decVal = BigInt(dec) * (WEI_PER_ETH / (BigInt(10) ** BigInt(18)));
    // Actually just work with BigInt math
    const totalWei = (BigInt(intPart || '0') * factor) + (decPart ? BigInt(decPart.padEnd(18, '0').slice(0, 18)) * factor / (BigInt(10) ** BigInt(decPart.padEnd(18,'0').slice(0,18).length)) : 0n);
    return totalWei;
  } catch { return null; }
}

function weiToDisplay(wei: bigint, factor: bigint): string {
  if (factor === 0n) return '0';
  const int = wei / factor;
  const rem = wei % factor;
  if (rem === 0n) return int.toString();
  const dec = rem.toString().padStart(factor.toString().length - 1, '0').replace(/0+$/, '');
  return `${int}.${dec}`;
}

const inputs = Array.from(document.querySelectorAll<HTMLInputElement>('.unit-input'));

inputs.forEach(input => {
  input.addEventListener('input', () => {
    const factorStr = input.dataset.factor || '1';
    const factor = BigInt(factorStr);
    const raw = input.value.trim();

    if (!raw) {
      inputs.forEach(i => { if (i !== input) i.value = ''; });
      return;
    }

    try {
      // Convert to Wei using BigInt
      const [intPart, decPart = ''] = raw.split('.');
      const factorLen = factorStr.length - 1;
      const decPadded = decPart.padEnd(factorLen, '0').slice(0, factorLen);
      const weiFromInt = BigInt(intPart || '0') * factor;
      const weiFromDec = decPadded ? BigInt(decPadded) * (factor / (BigInt(10) ** BigInt(decPadded.length))) : 0n;
      const totalWei = weiFromInt + weiFromDec;

      inputs.forEach(other => {
        if (other === input) return;
        const otherFactor = BigInt(other.dataset.factor || '1');
        other.value = weiToDisplay(totalWei, otherFactor);
      });
    } catch {
      inputs.forEach(other => { if (other !== input) other.value = 'Invalid'; });
    }
  });
});

document.getElementById('clear-all')!.addEventListener('click', () => {
  inputs.forEach(i => i.value = '');
});

document.getElementById('set-1eth')!.addEventListener('click', () => {
  (document.getElementById('unit-ether') as HTMLInputElement).value = '1';
  (document.getElementById('unit-ether') as HTMLInputElement).dispatchEvent(new Event('input'));
});

document.getElementById('set-50gwei')!.addEventListener('click', () => {
  (document.getElementById('unit-gwei') as HTMLInputElement).value = '50';
  (document.getElementById('unit-gwei') as HTMLInputElement).dispatchEvent(new Event('input'));
});
</script>
