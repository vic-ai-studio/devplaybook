---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OpenApi31Validator from '../../components/OpenApi31Validator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is OpenAPI 3.1 and how does it differ from 3.0?",
    answer: "OpenAPI 3.1.0 (released February 2021) aligns fully with JSON Schema 2020-12, whereas 3.0 used a custom subset. Key differences: (1) nullable is replaced by type arrays like type: [string, null], (2) webhooks object added for async event definitions, (3) pathItems can be reused via $ref in paths, (4) schema composition (anyOf, oneOf, allOf) is more powerful, (5) info.license now supports SPDX expression identifiers.",
  },
  {
    question: "What does the 'nullable: true' warning mean?",
    answer: "In OpenAPI 3.0, nullable: true was the way to allow null values for a field. In OpenAPI 3.1, this is removed in favor of the standard JSON Schema approach: use type: ['string', 'null'] (or any base type + 'null'). The validator flags nullable: true as a warning in 3.1 specs and suggests the correct replacement.",
  },
  {
    question: "Why should every operation have an operationId?",
    answer: "operationId is used by SDK generators (openapi-generator, swagger-codegen), documentation tools, and API gateways to name methods and functions. Without it, generators create ugly names like 'getApiV1Users'. A good operationId is camelCase, unique across your spec, and describes the action: listUsers, createUser, getUserById.",
  },
  {
    question: "Does this validator support YAML and JSON?",
    answer: "Yes. Paste your spec in either YAML or JSON format — the validator auto-detects the format. Both OpenAPI 3.1, 3.0, and Swagger 2.0 are supported, with upgrade suggestions when using older versions.",
  },
  {
    question: "How does $ref validation work?",
    answer: "The validator resolves all internal $ref references (those starting with #/) and checks that the target path exists in the spec. External $refs (pointing to other files or URLs) are not resolved since this is a browser-based tool, but they are detected and reported.",
  },
  {
    question: "What are auto-fix suggestions?",
    answer: "For each validation error or warning, the validator provides a concrete fix suggestion. For example: 'Missing info.version → Add version: 1.0.0', or 'nullable:true → Replace with type:[\"string\",\"null\"]'. Toggle 'Show fixes' in the results panel to see or hide them.",
  },
];
---

<BaseLayout
  title="OpenAPI 3.1 Spec Validator — Validate YAML/JSON, Auto-Fix Suggestions"
  description="Free browser-based OpenAPI 3.1 spec validator. Paste YAML or JSON, get instant errors, warnings, and auto-fix suggestions. Checks $refs, operationIds, nullable migration, and JSON Schema 3.1 alignment."
  tool="OpenAPI 3.1 Validator, OpenAPI Spec Validator, Swagger Validator, API Spec Checker, YAML JSON Validator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">OpenAPI 3.1 Spec Validator</h1>
  <p class="text-text-muted mb-4">Paste your OpenAPI YAML or JSON to get instant validation with errors, warnings, and auto-fix suggestions. Supports OpenAPI 3.1, 3.0, and Swagger 2.0. Checks <code>$ref</code> resolution, operationIds, deprecated <code>nullable</code> patterns, and JSON Schema alignment.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> OpenAPI 3.1 / 3.0 / Swagger 2.0</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auto-fix suggestions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> $ref resolution</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Spec stats dashboard</span>
  </div>
  <OpenApi31Validator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="OpenAPI 3.1 Spec Validator" relatedTags={['api', 'openapi', 'swagger', 'yaml', 'json', 'validation', 'rest']} />
</BaseLayout>
