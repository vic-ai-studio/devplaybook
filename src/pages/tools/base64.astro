---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Base64Tool from '../../components/Base64Tool.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Base64 Encoder & Decoder — Free Online Tool"
  description="Encode and decode Base64 strings online. Supports UTF-8 text, URL-safe encoding, and binary data. Runs entirely in your browser — no data sent to servers."
  tool="Base64 Encoder, Base64 Decoder, Base64 Converter"
>
  <h1 class="text-3xl font-bold mb-2">Base64 Encode / Decode</h1>
  <p class="text-text-muted mb-8">Convert plain text to Base64 encoding and back. Useful for embedding data in JSON, headers, or data URIs. Everything runs in your browser — nothing is sent to any server.</p>
  <Base64Tool client:only="preact" />
  <ToolPageCta currentTool="Base64 Encode / Decode" relatedTags={['encoding', 'base64', 'data-uri', 'api']} />
</BaseLayout>
