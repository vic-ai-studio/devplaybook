---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LangChainConfigGenerator from '../../components/LangChainConfigGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is LangChain Expression Language (LCEL)?",
    answer: "LCEL is the modern way to compose LangChain components using the pipe (|) operator. A basic chain looks like: chain = prompt | llm | StrOutputParser(). LCEL chains are composable, support streaming out of the box, and work with .invoke(), .stream(), .batch(), and async variants. LangChain recommends LCEL over legacy LLMChain for all new projects."
  },
  {
    question: "When should I use SequentialChain vs LCEL?",
    answer: "SequentialChain is the legacy approach where each chain's output becomes the next chain's input. LCEL replaces this with cleaner pipe composition: chain = prompt1 | llm | prompt2 | llm. Use LCEL for new projects — it's more explicit, supports parallel execution (RunnableParallel), and has better streaming support. SequentialChain is kept here for compatibility with older codebases."
  },
  {
    question: "How do I use {variable} placeholders in prompt templates?",
    answer: "In LangChain PromptTemplate, any word wrapped in curly braces like {name} or {question} becomes a variable. At runtime, call chain.invoke({'name': 'Alice', 'question': 'What is LangChain?'}) to inject values. ChatPromptTemplate.from_template() works the same way for LCEL chains. Variables are automatically detected and listed in this tool."
  },
  {
    question: "What is the difference between PromptTemplate and ChatPromptTemplate?",
    answer: "PromptTemplate produces a single string for completion-style models. ChatPromptTemplate produces a list of messages with roles (system, human, ai) for chat models. Since all modern models (GPT-4o, Claude, Gemini) are chat models, ChatPromptTemplate is preferred. LCEL chains use ChatPromptTemplate.from_template() by default."
  },
  {
    question: "How do I add memory to a LangChain chain?",
    answer: "For LCEL chains, use RunnableWithMessageHistory to add conversation memory: chain_with_history = RunnableWithMessageHistory(chain, get_session_history, input_messages_key='input', history_messages_key='history'). Pass session_id in config when invoking. For persistent storage, use Redis or SQLite-backed message history classes from langchain_community."
  },
  {
    question: "Which model should I choose for production use?",
    answer: "For general-purpose chat: GPT-4o or Claude 3.5 Sonnet offer the best quality. For cost-efficient high-volume: GPT-4o mini or Gemini 1.5 Flash. For latency-sensitive apps: GPT-3.5 Turbo or GPT-4o mini. Always test your specific task — model rankings vary significantly by use case. Use LangSmith to trace and evaluate chain performance."
  },
];
---

<BaseLayout
  title="LangChain Config Generator — Chain & Prompt Template Builder"
  description="Generate LangChain Python configuration code. Select chain type, model, configure temperature and max tokens, build prompt templates, and get ready-to-run Python code."
  tool="langchain config, langchain chain generator, langchain prompt template, langchain python setup, lcel chain"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "LangChain Config Generator",
    "url": "https://devplaybook.cc/tools/langchain-config-generator",
    "description": "Generate LangChain Python configuration code for LLMChain, SequentialChain, and LCEL pipe chains. Configure model, temperature, max tokens, and prompt templates.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">LangChain Config Generator</h1>
  <p class="text-text-muted mb-4">
    Generate ready-to-run <strong class="text-text">LangChain Python code</strong> for your chain setup.
    Choose between <code class="font-mono bg-bg-card px-1 rounded text-sm">LLMChain</code>,
    <code class="font-mono bg-bg-card px-1 rounded text-sm">SequentialChain</code>, or the modern
    <code class="font-mono bg-bg-card px-1 rounded text-sm">LCEL pipe</code> syntax.
    Configure model, temperature, max tokens, and prompt template with <code class="font-mono bg-bg-card px-1 rounded text-sm">{'{variable}'}</code> placeholders.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> LLMChain / SequentialChain / LCEL</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auto variable detection</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GPT-4o, Claude, Gemini</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy-ready Python code</span>
  </div>
  <LangChainConfigGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="LangChain Config Generator" relatedTags={['ai', 'llm', 'langchain', 'openai', 'python', 'prompts']} />
</BaseLayout>
