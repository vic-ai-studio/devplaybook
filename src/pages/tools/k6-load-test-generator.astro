---
import BaseLayout from '../../layouts/BaseLayout.astro';
import K6LoadTestGenerator from '../../components/K6LoadTestGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is k6 and why should I use it for load testing?",
    answer: "k6 is an open-source load testing tool by Grafana. You write test scripts in JavaScript and run them from the CLI. It supports ramp-up stages, thresholds for pass/fail criteria, and detailed metrics like response time percentiles, RPS, and error rates. Unlike browser-based tools, k6 generates high concurrency from a single machine and integrates well with CI/CD pipelines."
  },
  {
    question: "What are VUs (Virtual Users)?",
    answer: "Virtual Users (VUs) are concurrent simulated users sending requests to your server. 50 VUs means 50 requests are in flight simultaneously. VUs execute your test script in a loop — each iteration makes the HTTP request, sleeps, and repeats. The number of iterations per second depends on response time and the sleep duration."
  },
  {
    question: "What is the stages array used for?",
    answer: "Stages define a ramp-up/ramp-down pattern for VUs over time. A typical pattern: ramp from 0 to 50 VUs over 30s, hold at 50 VUs for 1 minute, then ramp down to 0 over 30s. This simulates gradual user arrival and departure, avoids cold-start spikes, and gives your system time to warm up."
  },
  {
    question: "What are k6 thresholds?",
    answer: "Thresholds are pass/fail criteria for your load test. Common ones: http_req_duration p(95) < 500ms (95th percentile response time under 500ms) and http_req_failed rate < 0.01 (less than 1% error rate). If any threshold is breached, k6 exits with a non-zero status code — perfect for failing CI pipelines."
  },
  {
    question: "How do I authenticate requests in k6?",
    answer: "For Bearer token auth, add 'Authorization': 'Bearer YOUR_TOKEN' to the headers object. For basic auth, use btoa() to encode credentials. For session-based auth, you can do a login request at the start of the test function and reuse the returned cookie. Use __ENV.TOKEN to inject secrets from environment variables without hardcoding them in the script."
  },
  {
    question: "Can I run k6 in CI/CD?",
    answer: "Yes. k6 runs headlessly with no browser required. In GitHub Actions: add a step with 'uses: grafana/setup-k6-action@v1' then 'run: k6 run load-test.js'. k6 exits non-zero when thresholds fail, which fails the CI step. Grafana Cloud k6 can run distributed tests and store historical results."
  },
];
---

<BaseLayout
  title="k6 Load Test Script Generator — Generate k6 JavaScript Tests Online"
  description="Free online k6 load test script generator. Configure VUs, ramp-up stages, HTTP endpoints, thresholds, and auth headers. Generates ready-to-run k6 JavaScript scripts instantly."
  tool="k6 load test generator, k6 script generator, load testing tool, k6 performance test, API load tester, k6 VU ramp generator"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "k6 Load Test Script Generator",
    "url": "https://devplaybook.cc/tools/k6-load-test-generator",
    "description": "Generate ready-to-run k6 load testing scripts. Configure VUs, stages, thresholds, HTTP methods, and auth headers. No signup required.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">k6 Load Test Script Generator</h1>
  <p class="text-text-muted mb-4">
    Generate ready-to-run <a href="https://k6.io" class="text-accent hover:underline" target="_blank" rel="noopener">k6</a> load testing scripts. Configure your endpoint, ramp-up stages, VU count, and pass/fail thresholds — then copy the script and run it instantly.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Ramp-up stages</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Custom thresholds</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auth header support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CI/CD ready output</span>
  </div>
  <K6LoadTestGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="k6 Load Test Script Generator" relatedTags={['performance', 'testing', 'devops', 'api', 'ci-cd', 'monitoring']} />
</BaseLayout>
