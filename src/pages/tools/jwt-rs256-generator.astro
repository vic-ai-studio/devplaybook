---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JwtRs256Generator from '../../components/JwtRs256Generator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the difference between RS256 and HS256?",
    answer: "HS256 (HMAC-SHA256) uses a single shared secret that both the issuer and verifier must know — if the secret leaks, anyone can forge tokens. RS256 (RSA-SHA256) uses an asymmetric key pair: the server signs with a private key, and anyone can verify with the corresponding public key. This means you can publish your public key (e.g., as a JWKS endpoint) so third parties can verify tokens without ever seeing the private key. RS256 is preferred for public APIs and multi-service architectures."
  },
  {
    question: "When should I use asymmetric JWTs like RS256 or ES256?",
    answer: "Use RS256 or ES256 when: (1) multiple services need to verify tokens without sharing a secret, (2) you expose a public JWKS endpoint so external systems can validate tokens, (3) you need stronger non-repudiation guarantees, or (4) your security policy mandates asymmetric cryptography. ES256 (ECDSA P-256) is preferred over RS256 for new systems — it produces shorter signatures and is faster to verify. HS256 is fine for single-service setups where only your own backend verifies tokens."
  },
  {
    question: "What PEM key format does RS256 use?",
    answer: "RS256 uses RSA key pairs in PEM format. The private key starts with '-----BEGIN RSA PRIVATE KEY-----' (PKCS#1) or '-----BEGIN PRIVATE KEY-----' (PKCS#8). The public key starts with '-----BEGIN PUBLIC KEY-----'. Generate a 2048-bit or 4096-bit key pair with: openssl genrsa -out private.pem 2048 and openssl rsa -in private.pem -pubout -out public.pem. Most JWT libraries also accept JWKS (JSON Web Key Sets) format — use a library like node-jose or python-jose to convert. Never embed private keys in client-side code."
  },
  {
    question: "What are JWT claims best practices?",
    answer: "Keep payloads small — JWTs are sent on every request. Use short claim names (sub, iss, aud, exp, iat, jti) for standard data. Always include exp (expiration) — short-lived tokens (15 min to 1 hour) reduce the window for misuse. Include jti (JWT ID) if you need revocation support. Use aud to scope tokens to specific services, preventing token reuse across APIs. Avoid storing sensitive data (passwords, full PII) in claims — the payload is Base64url-encoded but not encrypted. If you need confidentiality, use JWE (JSON Web Encryption) instead of plain JWT."
  },
];
---

<BaseLayout
  title="JWT RS256 Generator — Build & Preview RS256 Tokens"
  description="Build JWT tokens with RS256/ECDSA structure. Set custom claims, preview the Base64url-encoded header and payload, and understand RS256 token anatomy. Free, runs in browser."
  tool="JWT RS256 Generator, JWT Builder, RS256 Token, JWT Claims, JSON Web Token, ES256 JWT, Asymmetric JWT, JWT Debugger"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "JWT RS256 Generator",
    "url": "https://devplaybook.cc/tools/jwt-rs256-generator",
    "description": "Build JWT tokens with RS256/ECDSA structure. Set custom claims, preview the Base64url-encoded header and payload, and understand RS256 token anatomy.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">JWT RS256 Generator</h1>
  <p class="text-text-muted mb-4">
    Build and preview JWT tokens using RS256, RS384, RS512, ES256, and PS256 algorithms.
    Set your <code class="font-mono bg-surface px-1 rounded text-sm">iss</code>,
    <code class="font-mono bg-surface px-1 rounded text-sm">sub</code>,
    <code class="font-mono bg-surface px-1 rounded text-sm">aud</code>, and custom claims,
    then see the real Base64url-encoded header and payload. Understand asymmetric JWT anatomy
    before wiring up server-side signing.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> RS256 / ES256 / PS256 header</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Custom claims builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Real Base64url encoding</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <JwtRs256Generator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="JWT RS256 Generator" relatedTags={['security', 'auth', 'jwt', 'api', 'cryptography', 'developer-tools']} />
</BaseLayout>
