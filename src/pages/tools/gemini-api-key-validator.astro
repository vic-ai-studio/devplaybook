---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How do I get a Google Gemini API key?", answer: "Visit Google AI Studio (aistudio.google.com), sign in with your Google account, and click 'Get API key'. Free tier keys work for Gemini 1.5 Flash and Pro with rate limits. For production use, enable billing in Google Cloud Console and upgrade to a paid tier." },
  { question: "What format is a valid Gemini API key?", answer: "Gemini API keys from Google AI Studio start with 'AIza' followed by alphanumeric characters, typically 39 characters total (e.g., AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX). Keys from Vertex AI may have different formats." },
  { question: "Why does my Gemini API key fail validation?", answer: "Common reasons: (1) Key was deleted or revoked in Google AI Studio, (2) Billing not enabled for paid models, (3) Using a Vertex AI key but calling the Gemini API endpoint, (4) IP restrictions on the key, (5) Quota exhausted for the day/minute." },
  { question: "What models are available with Gemini API?", answer: "Current models: Gemini 2.5 Pro (most capable, reasoning), Gemini 2.0 Flash (fast, multimodal), Gemini 1.5 Pro (1M context), Gemini 1.5 Flash (efficient, free tier). Access depends on your API key tier and region." },
  { question: "Is it safe to test my API key in this tool?", answer: "This tool validates key format locally (client-side) without sending your key anywhere. The 'live test' option sends a minimal request to Google's API directly from your browser — the key never touches our servers. Always rotate keys if you suspect exposure." },
];
---

<BaseLayout
  title="Gemini API Key Validator — Validate Google AI Studio Keys & Test Model Access"
  description="Validate your Google Gemini API key format, check model access, and generate test code snippets. Supports Gemini 2.5 Pro, 2.0 Flash, and 1.5 series keys."
  tool="Gemini API Key Validator, Google AI Studio Key Checker, Gemini API Tester, Google Gemini Key Format Validator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Gemini API Key Validator</h1>
  <p class="text-text-muted mb-4">Validate your Google Gemini API key format and generate test code snippets to verify model access across all Gemini models.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Key format validation</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Model access checker</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Code snippet generator</span>
  </div>

  <!-- Key Input -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">API Key</h2>
    <div class="mb-4">
      <label class="block text-sm font-medium mb-1.5">Google Gemini API Key</label>
      <div class="relative">
        <input id="api-key" type="password" placeholder="AIzaSy..." autocomplete="off"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2.5 text-sm font-mono focus:outline-none focus:border-primary pr-24" />
        <button id="toggle-visibility" class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-text-muted hover:text-text px-2 py-1 rounded">Show</button>
      </div>
      <p class="text-xs text-text-muted mt-1.5">Your key stays in the browser — never sent to our servers.</p>
    </div>
    <div id="validation-result" class="hidden"></div>
  </div>

  <!-- Model Selection -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <h2 class="text-base font-semibold mb-4">Target Model</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium mb-1.5">Model</label>
        <select id="model-select" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <optgroup label="Gemini 2.x">
            <option value="gemini-2.5-pro-preview-05-06">gemini-2.5-pro-preview-05-06 (Latest)</option>
            <option value="gemini-2.0-flash" selected>gemini-2.0-flash (Fast)</option>
            <option value="gemini-2.0-flash-lite">gemini-2.0-flash-lite (Efficient)</option>
          </optgroup>
          <optgroup label="Gemini 1.5">
            <option value="gemini-1.5-pro">gemini-1.5-pro (1M context)</option>
            <option value="gemini-1.5-flash">gemini-1.5-flash (Free tier)</option>
            <option value="gemini-1.5-flash-8b">gemini-1.5-flash-8b (Smallest)</option>
          </optgroup>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5">SDK / Language</label>
        <select id="sdk-select" class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
          <option value="node">Node.js (@google/generative-ai)</option>
          <option value="python">Python (google-generativeai)</option>
          <option value="curl">cURL (REST API)</option>
          <option value="fetch">Fetch API (Browser/Node)</option>
        </select>
      </div>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mt-4">
      <div>
        <label class="block text-xs text-text-muted mb-1">Max Output Tokens</label>
        <input id="max-tokens" type="number" value="1024" min="1" max="8192"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Temperature (0-2)</label>
        <input id="temperature" type="number" value="1.0" step="0.1" min="0" max="2"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Top-P</label>
        <input id="top-p" type="number" value="0.95" step="0.05" min="0" max="1"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
      <div>
        <label class="block text-xs text-text-muted mb-1">Top-K</label>
        <input id="top-k" type="number" value="40" min="1" max="100"
          class="w-full bg-bg-card border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
      </div>
    </div>
  </div>

  <!-- Generated Code -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-5">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-base font-semibold">Generated Test Code</h2>
      <button id="copy-btn" class="text-xs bg-primary/10 hover:bg-primary/20 text-primary px-3 py-1.5 rounded-lg transition-colors">Copy</button>
    </div>
    <pre id="code-output" class="bg-bg-card border border-border rounded-lg p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text leading-relaxed"></pre>
  </div>

  <!-- Key Format Reference -->
  <div class="bg-bg-card border border-border rounded-xl p-5 mb-6">
    <h2 class="text-base font-semibold mb-3">Key Format & Status Reference</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
      <div>
        <h3 class="font-medium mb-2 text-text-muted">Valid Key Patterns</h3>
        <div class="space-y-2">
          <div class="flex items-start gap-2">
            <span class="text-green-500 mt-0.5 shrink-0">✓</span>
            <div><code class="text-xs bg-bg-card border border-border px-1.5 py-0.5 rounded">AIzaSy[A-Za-z0-9_-]{33}</code> — AI Studio key (39 chars)</div>
          </div>
          <div class="flex items-start gap-2">
            <span class="text-yellow-500 mt-0.5 shrink-0">~</span>
            <div>Vertex AI uses OAuth tokens, not API keys — different auth flow</div>
          </div>
        </div>
      </div>
      <div>
        <h3 class="font-medium mb-2 text-text-muted">Common Error Codes</h3>
        <div class="space-y-1 text-xs font-mono">
          <div class="flex gap-2"><span class="text-red-400 w-16 shrink-0">400</span><span class="text-text-muted">Invalid API key format</span></div>
          <div class="flex gap-2"><span class="text-red-400 w-16 shrink-0">403</span><span class="text-text-muted">Key revoked / billing required</span></div>
          <div class="flex gap-2"><span class="text-red-400 w-16 shrink-0">404</span><span class="text-text-muted">Model not found / no access</span></div>
          <div class="flex gap-2"><span class="text-yellow-400 w-16 shrink-0">429</span><span class="text-text-muted">Rate limit / quota exceeded</span></div>
          <div class="flex gap-2"><span class="text-green-400 w-16 shrink-0">200</span><span class="text-text-muted">Key valid, model accessible</span></div>
        </div>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Gemini API Key Validator" relatedTags={['ai', 'gemini', 'google', 'api', 'llm', 'validation']} />
</BaseLayout>

<script>
  function getVal(id: string): string {
    return (document.getElementById(id) as HTMLInputElement).value;
  }

  const KEY_REGEX = /^AIza[A-Za-z0-9_\-]{35}$/;

  function validateKey(key: string): { valid: boolean; message: string; color: string } {
    if (!key) return { valid: false, message: 'Enter your API key to validate', color: 'text-text-muted' };
    if (key.length < 10) return { valid: false, message: 'Key too short — Gemini keys are ~39 characters', color: 'text-red-500' };
    if (!key.startsWith('AIza')) return { valid: false, message: 'Invalid prefix — Gemini AI Studio keys start with "AIza"', color: 'text-red-500' };
    if (!KEY_REGEX.test(key)) return { valid: false, message: `Key length/format mismatch — got ${key.length} chars, expected 39`, color: 'text-yellow-500' };
    return { valid: true, message: '✓ Key format is valid (39 chars, correct prefix)', color: 'text-green-500' };
  }

  function generateCode(): string {
    const key = getVal('api-key') || 'YOUR_API_KEY';
    const model = getVal('model-select');
    const sdk = getVal('sdk-select');
    const maxTokens = getVal('max-tokens');
    const temp = getVal('temperature');
    const topP = getVal('top-p');
    const topK = getVal('top-k');

    if (sdk === 'node') {
      return `import { GoogleGenerativeAI } from '@google/generative-ai';

const genAI = new GoogleGenerativeAI('${key}');

const model = genAI.getGenerativeModel({
  model: '${model}',
  generationConfig: {
    maxOutputTokens: ${maxTokens},
    temperature: ${temp},
    topP: ${topP},
    topK: ${topK},
  },
});

async function test() {
  const result = await model.generateContent('Say "API key is working" in one sentence.');
  console.log(result.response.text());
}

test().catch(console.error);`;
    }

    if (sdk === 'python') {
      return `import google.generativeai as genai

genai.configure(api_key='${key}')

model = genai.GenerativeModel(
    model_name='${model}',
    generation_config=genai.GenerationConfig(
        max_output_tokens=${maxTokens},
        temperature=${temp},
        top_p=${topP},
        top_k=${topK},
    )
)

response = model.generate_content('Say "API key is working" in one sentence.')
print(response.text)`;
    }

    if (sdk === 'curl') {
      return `curl -s \\
  "https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${key}" \\
  -H "Content-Type: application/json" \\
  -d '{
    "contents": [{
      "parts": [{ "text": "Say \\"API key is working\\" in one sentence." }]
    }],
    "generationConfig": {
      "maxOutputTokens": ${maxTokens},
      "temperature": ${temp},
      "topP": ${topP},
      "topK": ${topK}
    }
  }'`;
    }

    // fetch
    return `const response = await fetch(
  \`https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${key}\`,
  {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      contents: [{ parts: [{ text: 'Say "API key is working" in one sentence.' }] }],
      generationConfig: {
        maxOutputTokens: ${maxTokens},
        temperature: ${temp},
        topP: ${topP},
        topK: ${topK},
      },
    }),
  }
);

const data = await response.json();
console.log(data.candidates?.[0]?.content?.parts?.[0]?.text);`;
  }

  function update() {
    const key = getVal('api-key');
    const result = validateKey(key);
    const resultEl = document.getElementById('validation-result')!;
    resultEl.className = `text-sm font-medium mt-2 p-3 rounded-lg border ${result.valid ? 'border-green-500/30 bg-green-500/5' : 'border-border bg-bg-card'} ${result.color}`;
    resultEl.textContent = result.message;
    resultEl.classList.remove('hidden');

    const codeEl = document.getElementById('code-output')!;
    codeEl.textContent = generateCode();
  }

  document.getElementById('toggle-visibility')!.addEventListener('click', () => {
    const input = document.getElementById('api-key') as HTMLInputElement;
    const btn = document.getElementById('toggle-visibility')!;
    if (input.type === 'password') { input.type = 'text'; btn.textContent = 'Hide'; }
    else { input.type = 'password'; btn.textContent = 'Show'; }
  });

  document.getElementById('copy-btn')!.addEventListener('click', () => {
    const code = (document.getElementById('code-output') as HTMLPreElement).textContent || '';
    navigator.clipboard.writeText(code).then(() => {
      const btn = document.getElementById('copy-btn')!;
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 1500);
    });
  });

  document.querySelectorAll('input, select').forEach(el => el.addEventListener('input', update));
  update();
</script>
