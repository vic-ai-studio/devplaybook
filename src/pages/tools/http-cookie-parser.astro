---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HttpCookieParser from '../../components/HttpCookieParser.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is the Set-Cookie header?", answer: "Set-Cookie is an HTTP response header that instructs the browser to store a cookie. Its format is: 'Set-Cookie: name=value; attribute1; attribute2=value'. The server sends it in response headers, and the browser automatically sends the cookie back in subsequent requests via the Cookie request header." },
  { question: "What does HttpOnly mean?", answer: "The HttpOnly flag prevents JavaScript from accessing the cookie via document.cookie. This protects against XSS attacks — even if an attacker injects malicious JS, they cannot steal HttpOnly session cookies. Always set HttpOnly on session tokens, auth cookies, and CSRF tokens." },
  { question: "What is the SameSite attribute?", answer: "SameSite controls when cookies are sent with cross-site requests. Strict: cookie only sent for same-site requests (most restrictive). Lax: sent on top-level navigation (clicking links), but not on embedded resources. None: sent on all requests including cross-site — requires Secure flag. Modern browsers default to Lax if SameSite is omitted." },
  { question: "What is the difference between Expires and Max-Age?", answer: "Expires sets an absolute date/time when the cookie expires (e.g., Thu, 01 Jan 2026 00:00:00 GMT). Max-Age sets a relative duration in seconds from when the cookie was received. If both are present, Max-Age takes precedence in modern browsers. Without either, the cookie is a session cookie — deleted when the browser closes." },
  { question: "What does the Partitioned (CHIPS) attribute do?", answer: "Partitioned (Cookies Having Independent Partitioned State) is a new attribute that scopes cookies to the top-level site they were set on. When a cookie is Partitioned, it's stored in a separate jar per top-level domain — so a cookie set by widget.example.com on site-a.com is only sent to widget.example.com when embedded on site-a.com. This enables necessary third-party cookies while preventing cross-site tracking." },
];
---

<BaseLayout
  title="HTTP Cookie Parser — Parse Set-Cookie Headers Online — Free Tool"
  description="Paste a Set-Cookie header and parse all attributes instantly. Shows Name, Value, Domain, Path, Expires date, Max-Age, HttpOnly, Secure, and SameSite with security analysis. Runs in your browser."
  tool="HTTP cookie parser, Set-Cookie header analyzer, cookie attributes, HTTP cookie decoder, cookie security checker"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">HTTP Cookie Parser</h1>
  <p class="text-text-muted mb-4">
    Paste a <code class="bg-surface px-1 rounded text-sm">Set-Cookie</code> header value and decode all attributes.
    See name, value, domain, path, expiry date (decoded to human-readable format), and security flags — with an instant security analysis.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All cookie attributes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Expires date decoded</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Security flag analysis</span>
  </div>
  <HttpCookieParser client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="HTTP Cookie Parser" relatedTags={['http', 'cookies', 'security', 'web', 'debugging']} />
</BaseLayout>
