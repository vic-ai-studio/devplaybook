---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ApiMockBuilder from '../../components/ApiMockBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is API mocking and when should I use it?",
    answer: "API mocking means simulating API endpoints so your frontend or tests can work without a real backend. Use it when: the backend isn't built yet (frontend-first development), you want tests to run without network calls, you need to test error states (401, 429, 500) that are hard to trigger in development, or you want to prototype UI before the API design is finalized.",
  },
  {
    question: "What is MSW (Mock Service Worker)?",
    answer: "MSW (Mock Service Worker) intercepts real network requests at the service worker level in browsers, and at the Node.js level in tests. Unlike simple fetch mocks, MSW intercepts requests transparently — no changes to application code. The handlers this tool generates are compatible with MSW v2. Install with: npm install msw --save-dev, then run npx msw init public/.",
  },
  {
    question: "How do I mock API calls in Jest / Vitest tests?",
    answer: "Use the MSW handlers from this tool with setupServer() from msw/node: import { setupServer } from 'msw/node'; import { handlers } from './handlers'; const server = setupServer(...handlers); beforeAll(() => server.listen()); afterEach(() => server.resetHandlers()); afterAll(() => server.close());. This gives you real network-level mocking with no axios/fetch monkey-patching.",
  },
  {
    question: "What HTTP status codes should I mock for testing?",
    answer: "Test the happy path (200/201) and all error cases: 400 Bad Request (validation errors), 401 Unauthorized (expired token), 403 Forbidden (wrong role), 404 Not Found (deleted resource), 409 Conflict (duplicate), 422 Unprocessable Entity (semantic validation), 429 Too Many Requests (rate limiting), and 500 Internal Server Error (unexpected failures). Good test coverage mocks each of these.",
  },
  {
    question: "Can I use this to generate curl commands for manual testing?",
    answer: "Yes — switch to the 'cURL' export tab for a curl command for the selected endpoint. You can paste it directly into your terminal to test the response format, or share it with teammates to document your API expectations. Combine with tools like jq for pretty-printing: curl -s ... | jq .",
  },
  {
    question: "What is the difference between API mocking and API testing?",
    answer: "API mocking replaces the real API with a fake that returns predefined responses — used during development and unit/integration testing. API testing sends real requests to a running API and validates the actual responses — used for end-to-end and contract testing. Both are complementary: mock for speed and isolation during dev, test against real endpoints in CI/CD.",
  },
];
---

<BaseLayout
  title="API Mock Builder — Create Mock Endpoints with Custom Responses"
  description="Build mock API endpoints with custom status codes, response bodies, and HTTP methods. Export as fetch(), cURL, or MSW handlers for testing. Free developer tool — no signup required."
  tool="API mock builder, mock API endpoint generator, HTTP mock builder, MSW handler generator, REST API mock, API testing tool, mock server generator, fetch mock"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "API Mock Builder",
    "url": "https://devplaybook.cc/tools/api-mock-builder",
    "description": "Build mock API endpoints with custom responses. Define routes, methods, status codes, and bodies. Export as fetch() calls, cURL commands, or MSW handlers for browser and Node.js testing.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">API Mock Builder</h1>
  <p class="text-text-muted mb-4">
    Define mock API endpoints with custom methods, status codes, and response bodies. Export as <code class="font-mono bg-surface px-1 rounded text-sm">fetch()</code> snippets, cURL commands, or MSW handlers for Jest/Vitest.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multiple endpoints</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Quick body templates</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> MSW v2 handler export</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> cURL & fetch() export</span>
  </div>
  <ApiMockBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="API Mock Builder" relatedTags={['api', 'testing', 'mock', 'http', 'rest', 'json', 'developer-tools']} />
</BaseLayout>
