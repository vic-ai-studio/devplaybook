---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How does cron syntax work in GitHub Actions?", answer: "GitHub Actions uses standard POSIX cron syntax with 5 fields: minute (0–59), hour (0–23), day-of-month (1–31), month (1–12), day-of-week (0–7, where 0 and 7 both mean Sunday). Special characters: * (any), , (list), - (range), / (step). Example: '0 9 * * 1-5' runs at 9:00 AM Monday through Friday. All times are in UTC." },
  { question: "Why does my scheduled workflow not run on time?", answer: "GitHub's scheduler for cron workflows is not precise. High-load periods (top of the hour, on the hour) can delay runs by 15–60+ minutes. GitHub also throttles inactive repos — if you haven't pushed in 60+ days, scheduled workflows are disabled. To avoid top-of-hour contention, offset your schedule (e.g., 17 minutes past the hour instead of exactly on the hour)." },
  { question: "What is the minimum schedule interval?", answer: "GitHub Actions cron schedules have a minimum interval of 5 minutes (the most frequent allowed is '*/5 * * * *'). For sub-5-minute polling, use an external trigger or a self-hosted runner with a loop. Be aware that very frequent schedules still subject to queue delays during peak load." },
  { question: "Can I run a workflow on a schedule AND on push?", answer: "Yes — GitHub Actions supports multiple triggers. Combine schedule with push, pull_request, or workflow_dispatch: 'on: { schedule: [{cron: \"0 2 * * *\"}], push: {branches: [main]}, workflow_dispatch: {} }'. workflow_dispatch adds a manual run button in the Actions tab — highly recommended alongside scheduled jobs." },
  { question: "How do I add conditional logic based on whether it's a scheduled run?", answer: "Check github.event_name in your steps: 'if: github.event_name == schedule' or 'if: github.event_name != schedule'. You can also use the IS_SCHEDULED environment variable pattern or run different jobs depending on trigger type." },
];
---

<BaseLayout
  title="GitHub Actions Cron Builder — Schedule Workflow Generator"
  description="Build GitHub Actions cron schedules visually. Click to set minute/hour/day, get the cron expression, next 5 run times, and a ready-to-paste workflow YAML snippet."
  tool="GitHub Actions cron builder, workflow schedule generator, cron expression GitHub Actions, scheduled workflow YAML, GitHub cron syntax"
  keywords={["github actions cron", "workflow schedule", "cron expression builder", "github actions schedule", "github workflow yaml", "cron generator"]}
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">GitHub Actions Cron Builder</h1>
  <p class="text-text-muted mb-4">Build cron schedules visually, preview next run times, and get a ready-to-paste workflow YAML — all in your browser.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Visual schedule builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Next 5 run times (UTC)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Full workflow YAML snippet</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <!-- Builder -->
    <div class="bg-bg-card border border-border rounded-xl p-5 space-y-5">
      <h2 class="text-base font-semibold">Schedule Builder</h2>

      <!-- Quick presets -->
      <div>
        <label class="block text-sm font-medium mb-2">Quick Presets</label>
        <div class="grid grid-cols-2 gap-2">
          <button class="preset-btn text-xs px-3 py-2 rounded-lg border border-border text-text-muted hover:border-primary hover:text-primary transition-all text-left" data-cron="0 2 * * *">Daily at 2 AM UTC</button>
          <button class="preset-btn text-xs px-3 py-2 rounded-lg border border-border text-text-muted hover:border-primary hover:text-primary transition-all text-left" data-cron="0 9 * * 1-5">Weekdays 9 AM</button>
          <button class="preset-btn text-xs px-3 py-2 rounded-lg border border-border text-text-muted hover:border-primary hover:text-primary transition-all text-left" data-cron="0 0 * * 0">Weekly (Sunday midnight)</button>
          <button class="preset-btn text-xs px-3 py-2 rounded-lg border border-border text-text-muted hover:border-primary hover:text-primary transition-all text-left" data-cron="0 0 1 * *">Monthly (1st of month)</button>
          <button class="preset-btn text-xs px-3 py-2 rounded-lg border border-border text-text-muted hover:border-primary hover:text-primary transition-all text-left" data-cron="*/15 * * * *">Every 15 minutes</button>
          <button class="preset-btn text-xs px-3 py-2 rounded-lg border border-border text-text-muted hover:border-primary hover:text-primary transition-all text-left" data-cron="0 */6 * * *">Every 6 hours</button>
        </div>
      </div>

      <!-- Manual fields -->
      <div class="grid grid-cols-5 gap-2">
        <div>
          <label class="block text-xs text-text-muted mb-1">Minute</label>
          <input id="f-min" type="text" value="0" placeholder="0-59"
            class="w-full bg-bg border border-border rounded-lg px-2 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">Hour</label>
          <input id="f-hour" type="text" value="2" placeholder="0-23"
            class="w-full bg-bg border border-border rounded-lg px-2 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">Day/Mo</label>
          <input id="f-dom" type="text" value="*" placeholder="1-31"
            class="w-full bg-bg border border-border rounded-lg px-2 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">Month</label>
          <input id="f-mon" type="text" value="*" placeholder="1-12"
            class="w-full bg-bg border border-border rounded-lg px-2 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-xs text-text-muted mb-1">Day/Wk</label>
          <input id="f-dow" type="text" value="*" placeholder="0-7"
            class="w-full bg-bg border border-border rounded-lg px-2 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>
      </div>

      <!-- Generated expression -->
      <div class="bg-bg border border-border rounded-xl p-4">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs text-text-muted font-medium">Cron Expression</span>
          <button id="copy-cron" class="text-xs text-primary hover:underline">Copy</button>
        </div>
        <div id="cron-expr" class="text-2xl font-mono font-bold text-primary tracking-widest mb-2">0 2 * * *</div>
        <div id="cron-desc" class="text-sm text-text-muted"></div>
      </div>

      <!-- Workflow settings -->
      <div class="space-y-3">
        <div>
          <label class="block text-sm font-medium mb-1.5">Workflow Name</label>
          <input id="wf-name" type="text" value="Scheduled Task"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1.5">Job / Script to run</label>
          <input id="wf-job" type="text" value="npm run task"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-primary" />
        </div>
        <div class="flex items-center gap-2">
          <input id="add-dispatch" type="checkbox" checked class="w-4 h-4 accent-primary" />
          <label for="add-dispatch" class="text-sm">Add workflow_dispatch (manual trigger button)</label>
        </div>
      </div>
    </div>

    <!-- Output -->
    <div class="space-y-4">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="text-base font-semibold mb-3">Next 5 Run Times (UTC)</h2>
        <ul id="next-runs" class="space-y-1.5 text-sm font-mono text-text-muted"></ul>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-2">
          <h2 class="text-base font-semibold">Workflow YAML</h2>
          <button id="copy-yaml" class="text-xs text-primary hover:underline">Copy</button>
        </div>
        <pre id="yaml-output" class="text-xs font-mono bg-bg border border-border rounded-lg p-3 overflow-x-auto whitespace-pre text-text-muted leading-relaxed max-h-80"></pre>
      </div>
    </div>
  </div>

  <ToolPageCta />
  <FaqSection faq={faq} />
</BaseLayout>

<script>
  function parseCronField(f: string, min: number, max: number): number[] {
    const result: number[] = [];
    if (f === '*') {
      for (let i = min; i <= max; i++) result.push(i);
      return result;
    }
    for (const part of f.split(',')) {
      if (part.startsWith('*/')) {
        const step = parseInt(part.slice(2));
        for (let i = min; i <= max; i += step) result.push(i);
      } else if (part.includes('-')) {
        const [s, e] = part.split('-').map(Number);
        for (let i = s; i <= Math.min(e, max); i++) result.push(i);
      } else if (part.includes('/')) {
        const [base, step] = part.split('/');
        const start = base === '*' ? min : parseInt(base);
        const st = parseInt(step);
        for (let i = start; i <= max; i += st) result.push(i);
      } else {
        const n = parseInt(part);
        if (!isNaN(n) && n >= min && n <= max) result.push(n);
      }
    }
    return [...new Set(result)].sort((a, b) => a - b);
  }

  function getNextRuns(cron: string, count = 5): Date[] {
    const parts = cron.trim().split(/\s+/);
    if (parts.length !== 5) return [];
    const [mf, hf, domf, monf, dowf] = parts;
    const minutes = parseCronField(mf, 0, 59);
    const hours = parseCronField(hf, 0, 23);
    const months = parseCronField(monf, 1, 12);
    const dows = parseCronField(dowf, 0, 7).map(d => d === 7 ? 0 : d);
    const domAny = domf === '*';
    const dowAny = dowf === '*';

    const runs: Date[] = [];
    const now = new Date();
    const dt = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate(), now.getUTCHours(), now.getUTCMinutes() + 1));
    let safety = 0;

    while (runs.length < count && safety < 400000) {
      safety++;
      if (!months.includes(dt.getUTCMonth() + 1)) { dt.setUTCDate(1); dt.setUTCMonth(dt.getUTCMonth() + 1); dt.setUTCHours(0); dt.setUTCMinutes(0); continue; }
      const dom = parseCronField(domf, 1, 31);
      const domMatch = domAny || dom.includes(dt.getUTCDate());
      const dowMatch = dowAny || dows.includes(dt.getUTCDay());
      const dayMatch = (!domAny && !dowAny) ? (domMatch || dowMatch) : (domAny ? dowMatch : domMatch);
      if (!dayMatch) { dt.setUTCDate(dt.getUTCDate() + 1); dt.setUTCHours(0); dt.setUTCMinutes(0); continue; }
      if (!hours.includes(dt.getUTCHours())) { dt.setUTCHours(dt.getUTCHours() + 1); dt.setUTCMinutes(0); continue; }
      if (!minutes.includes(dt.getUTCMinutes())) { dt.setUTCMinutes(dt.getUTCMinutes() + 1); continue; }
      runs.push(new Date(dt));
      dt.setUTCMinutes(dt.getUTCMinutes() + 1);
    }
    return runs;
  }

  function describeCron(expr: string): string {
    const parts = expr.split(/\s+/);
    if (parts.length !== 5) return 'Invalid expression';
    const [min, hour, dom, mon, dow] = parts;
    const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

    if (min.startsWith('*/') && hour === '*' && dom === '*' && mon === '*' && dow === '*') {
      return `Every ${min.slice(2)} minutes`;
    }
    if (min === '0' && hour.startsWith('*/') && dom === '*' && mon === '*' && dow === '*') {
      return `Every ${hour.slice(2)} hours`;
    }
    if (dom === '*' && mon === '*' && dow === '*') {
      return `Daily at ${hour.padStart(2,'0')}:${min.padStart(2,'0')} UTC`;
    }
    if (dom === '*' && mon === '*' && dow !== '*') {
      const dowNames = dow.split(',').map(d => {
        if (d.includes('-')) {
          const [s,e] = d.split('-');
          return `${days[parseInt(s)]}–${days[parseInt(e)]}`;
        }
        return days[parseInt(d)] || d;
      });
      return `${dowNames.join(', ')} at ${hour.padStart(2,'0')}:${min.padStart(2,'0')} UTC`;
    }
    if (dom !== '*' && mon === '*' && dow === '*') {
      return `Monthly on day ${dom} at ${hour.padStart(2,'0')}:${min.padStart(2,'0')} UTC`;
    }
    return expr;
  }

  function buildYaml(cron: string, name: string, job: string, addDispatch: boolean): string {
    const slug = name.toLowerCase().replace(/[^a-z0-9]+/g, '-');
    const dispatch = addDispatch ? '\n  workflow_dispatch:' : '';
    return `name: ${name}

on:
  schedule:
    - cron: '${cron}'${dispatch}

jobs:
  ${slug}:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: Run scheduled task
        run: ${job}`;
  }

  function getCron(): string {
    const min = (document.getElementById('f-min') as HTMLInputElement).value.trim() || '*';
    const hour = (document.getElementById('f-hour') as HTMLInputElement).value.trim() || '*';
    const dom = (document.getElementById('f-dom') as HTMLInputElement).value.trim() || '*';
    const mon = (document.getElementById('f-mon') as HTMLInputElement).value.trim() || '*';
    const dow = (document.getElementById('f-dow') as HTMLInputElement).value.trim() || '*';
    return `${min} ${hour} ${dom} ${mon} ${dow}`;
  }

  function update() {
    const cron = getCron();
    const name = (document.getElementById('wf-name') as HTMLInputElement).value || 'Scheduled Task';
    const job = (document.getElementById('wf-job') as HTMLInputElement).value || 'echo hello';
    const addDispatch = (document.getElementById('add-dispatch') as HTMLInputElement).checked;

    (document.getElementById('cron-expr') as HTMLElement).textContent = cron;
    (document.getElementById('cron-desc') as HTMLElement).textContent = describeCron(cron);

    const runs = getNextRuns(cron);
    const runList = document.getElementById('next-runs') as HTMLElement;
    if (runs.length === 0) {
      runList.innerHTML = '<li class="text-red-400">Could not calculate — check expression syntax.</li>';
    } else {
      runList.innerHTML = runs.map((d, i) => {
        const ds = d.toUTCString().replace(' GMT', ' UTC');
        return `<li class="flex gap-2"><span class="text-text-muted w-4">${i+1}.</span><span>${ds}</span></li>`;
      }).join('');
    }

    (document.getElementById('yaml-output') as HTMLElement).textContent = buildYaml(cron, name, job, addDispatch);
  }

  function setCronFields(cron: string) {
    const parts = cron.split(' ');
    if (parts.length !== 5) return;
    (document.getElementById('f-min') as HTMLInputElement).value = parts[0];
    (document.getElementById('f-hour') as HTMLInputElement).value = parts[1];
    (document.getElementById('f-dom') as HTMLInputElement).value = parts[2];
    (document.getElementById('f-mon') as HTMLInputElement).value = parts[3];
    (document.getElementById('f-dow') as HTMLInputElement).value = parts[4];
  }

  document.querySelectorAll('.preset-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const cron = btn.getAttribute('data-cron') || '';
      setCronFields(cron);
      update();
    });
  });

  ['f-min','f-hour','f-dom','f-mon','f-dow','wf-name','wf-job','add-dispatch'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', update);
  });

  document.getElementById('copy-cron')?.addEventListener('click', () => {
    navigator.clipboard.writeText(getCron()).then(() => {
      const btn = document.getElementById('copy-cron') as HTMLElement;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
    });
  });
  document.getElementById('copy-yaml')?.addEventListener('click', () => {
    const txt = (document.getElementById('yaml-output') as HTMLElement).textContent || '';
    navigator.clipboard.writeText(txt).then(() => {
      const btn = document.getElementById('copy-yaml') as HTMLElement;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
    });
  });

  update();
</script>
