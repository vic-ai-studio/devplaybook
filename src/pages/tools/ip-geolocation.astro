---
import BaseLayout from '../../layouts/BaseLayout.astro';
import IpGeolocation from '../../components/IpGeolocation.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="IP Geolocation Lookup"
  description="Look up the geographic location of any IP address (IPv4 or IPv6). Get city, country, region, timezone, ISP, and coordinates instantly using a public API."
  tool="IP Geolocation, IP Lookup, IP Address Location, Geo IP"
>
  <h1 class="text-3xl font-bold mb-2">IP Geolocation Lookup</h1>
  <p class="text-text-muted mb-8">Enter any IPv4 or IPv6 address to get its approximate geographic location — city, region, country, timezone, ISP, and coordinates. Or look up your own current IP instantly.</p>
  <IpGeolocation client:only="preact" />
  <ToolPageCta currentTool="IP Geolocation Lookup" relatedTags={['networking', 'api', 'ip', 'geolocation']} />
</BaseLayout>
