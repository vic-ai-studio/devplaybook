---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CodeDiff from '../../components/CodeDiff.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Code Diff Viewer — Compare Code Online"
  description="Compare two code snippets side-by-side or unified view. Highlights added lines in green, removed lines in red, and shows a +/- change count. Supports unified and split view. Runs entirely in your browser."
  tool="Code Diff, Code Comparison, Diff Viewer, Compare Code Online, Code Diff Checker"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Code Diff Viewer",
    "url": "https://devplaybook.cc/tools/code-diff",
    "description": "Compare two code snippets online with side-by-side or unified diff view. Added/removed lines highlighted instantly.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Code Diff Viewer</h1>
  <p class="text-text-muted mb-8">
    Paste two versions of any code snippet and instantly see what changed. Choose between unified diff (GitHub-style) or split side-by-side view.
    Added lines are highlighted green, removed lines red. Shows exact +/- line counts. Runs 100% in your browser — nothing is sent to any server.
  </p>
  <CodeDiff client:only="preact" />
  <ToolPageCta currentTool="Code Diff Viewer" relatedTags={['diff', 'code', 'comparison', 'git', 'productivity']} />
</BaseLayout>
