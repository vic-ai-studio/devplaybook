---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CodeDiff from '../../components/CodeDiff.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How do I compare two code files online?", answer: "Paste the original code on the left and the modified version on the right. The tool instantly highlights additions (green), deletions (red), and unchanged lines. Switch between unified (GitHub-style) and split side-by-side views." },
  { question: "What is the difference between unified and split diff?", answer: "Unified diff shows changes in a single column with + and - markers, like GitHub pull requests. Split diff shows the old and new versions side by side in two columns, making it easier to compare line-by-line changes in longer files." },
  { question: "Can I use this to compare JSON, YAML, or SQL?", answer: "Yes. This tool compares any plain text — code in any language, JSON configs, YAML files, SQL queries, Markdown, or even plain prose. It works on a line-by-line basis regardless of the content format." },
  { question: "Is my code safe when pasting it here?", answer: "Yes. The diff comparison runs entirely in your browser. No code is sent to any server. Your source code stays completely private on your machine." },
];
---

<BaseLayout
  title="Code Diff Viewer — Compare Code Online"
  description="Compare two code snippets side-by-side or unified view. Highlights added lines in green, removed lines in red, and shows a +/- change count. Supports unified and split view. Runs entirely in your browser."
  tool="Code Diff, Code Comparison, Diff Viewer, Compare Code Online, Code Diff Checker"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Code Diff Viewer",
    "url": "https://devplaybook.cc/tools/code-diff",
    "description": "Compare two code snippets online with side-by-side or unified diff view. Added/removed lines highlighted instantly.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How do I compare two code files online?", "acceptedAnswer": { "@type": "Answer", "text": "Paste the original code on the left and the modified version on the right. The tool instantly highlights additions (green), deletions (red), and unchanged lines. Switch between unified (GitHub-style) and split side-by-side views." }},
      { "@type": "Question", "name": "What is the difference between unified and split diff?", "acceptedAnswer": { "@type": "Answer", "text": "Unified diff shows changes in a single column with + and - markers, like GitHub pull requests. Split diff shows the old and new versions side by side in two columns, making it easier to compare line-by-line changes in longer files." }},
      { "@type": "Question", "name": "Can I use this to compare JSON, YAML, or SQL?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. This tool compares any plain text — code in any language, JSON configs, YAML files, SQL queries, Markdown, or even plain prose. It works on a line-by-line basis regardless of the content format." }},
      { "@type": "Question", "name": "Is my code safe when pasting it here?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. The diff comparison runs entirely in your browser. No code is sent to any server. Your source code stays completely private on your machine." }}
    ]
  })} />

  <h1 class="text-3xl font-bold mb-2">Code Diff Viewer</h1>
  <p class="text-text-muted mb-8">
    Paste two versions of any code snippet and instantly see what changed. Choose between unified diff (GitHub-style) or split side-by-side view.
    Added lines are highlighted green, removed lines red. Shows exact +/- line counts. Runs 100% in your browser — nothing is sent to any server.
  </p>
  <CodeDiff client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Code Diff Viewer" relatedTags={['diff', 'code', 'comparison', 'git', 'productivity']} />
</BaseLayout>
