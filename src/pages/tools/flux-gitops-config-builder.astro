---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FluxGitopsConfigBuilder from '../../components/FluxGitopsConfigBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is the difference between Flux and ArgoCD?",
    answer: "Both are CNCF GitOps tools for Kubernetes, but they take different approaches. Flux is pull-based and controller-driven — each resource type (GitRepository, HelmRelease, Kustomization) has a dedicated controller that watches and reconciles independently. ArgoCD is application-centric with a central server, a rich UI, and an opinionated Application CRD. Flux is generally more composable and CLI/YAML-first, while ArgoCD offers a better out-of-the-box UI. Flux v2 (the Flux this builder targets) is built on the GitOps Toolkit and supports multi-tenancy natively."
  },
  {
    question: "What is the difference between GitRepository and OCIRepository in Flux?",
    answer: "GitRepository sources manifests directly from a Git repository — Flux polls the repo on a defined interval and applies changes. OCIRepository sources OCI-compliant artifacts from a container registry (like GitHub Container Registry or Docker Hub). Use OCIRepository when your manifests or Helm charts are packaged as OCI artifacts and pushed to a registry as part of your CI pipeline. GitRepository is the standard choice for most GitOps setups where your YAML manifests live in Git."
  },
  {
    question: "How does HelmRelease reconciliation work in Flux?",
    answer: "A HelmRelease CRD tells the Helm controller to install or upgrade a Helm chart on a defined interval. The chart is sourced from either a HelmRepository or a GitRepository. On each reconciliation, Flux checks whether the installed release matches the desired state (chart version, values). If drift is detected or a new chart version matches the version constraint, Flux performs a Helm upgrade. Install and upgrade remediation settings control what happens on failure — the controller can automatically roll back or retry a configurable number of times."
  },
  {
    question: "What does the path field mean in a Kustomization?",
    answer: "The path field in a Flux Kustomization specifies the directory within the referenced GitRepository that contains your Kubernetes manifests or a kustomization.yaml file. It's relative to the repository root. For example, ./k8s/overlays/production points to a Kustomize overlay. If you don't use Kustomize overlays, you can point path to any directory containing plain YAML manifests — Flux will apply them all. Use path: ./ to apply everything in the root. The targetNamespace field lets you override the namespace for all resources in that path."
  },
  {
    question: "How does Flux image automation work?",
    answer: "Flux image automation has three components: ImageRepository (scans a container registry for available tags), ImagePolicy (selects which tag to use based on a policy like semver range or alphabetical order), and ImageUpdateAutomation (writes the selected tag back to Git by updating image references in your YAML files). Flux detects the new commit in Git and reconciles your cluster to the updated image. This creates a fully automated image update pipeline: push a new image → Flux detects it → updates Git → Flux applies the updated manifests."
  },
  {
    question: "How do you bootstrap Flux into a cluster?",
    answer: "Run 'flux bootstrap github --owner=my-org --repository=my-fleet --branch=main --path=clusters/production' (or the equivalent for GitLab, Bitbucket, or generic Git). Bootstrap installs the Flux controllers into your cluster and creates the initial GitRepository and Kustomization pointing to your fleet repository. All future Flux configuration is managed via Git commits — you never need to run flux bootstrap again unless you're setting up a new cluster. Use 'flux check' to verify all controllers are healthy."
  },
];
---

<BaseLayout
  title="Flux GitOps Config Builder — Generate GitRepository, HelmRelease, Kustomization YAML"
  description="Build Flux v2 GitOps configuration manifests visually. Generate GitRepository, HelmRepository, HelmRelease, Kustomization, ImagePolicy, and ImageUpdateAutomation YAML. Free, runs in your browser."
  tool="flux gitops config builder, flux v2 yaml generator, fluxcd kustomization builder, helmrelease flux, gitrepository flux yaml"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Flux GitOps Config Builder",
    "description": "Build Flux v2 GitOps configuration manifests visually. Generate GitRepository, HelmRepository, HelmRelease, Kustomization, ImagePolicy, and ImageUpdateAutomation YAML.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "url": "https://devplaybook.cc/tools/flux-gitops-config-builder"
  })} />

  <h1 class="text-3xl font-bold mb-2">Flux GitOps Config Builder</h1>
  <p class="text-text-muted mb-6">
    Generate <strong>Flux v2</strong> GitOps configuration manifests without memorizing the spec.
    Build GitRepository, HelmRepository, HelmRelease, Kustomization, ImagePolicy, and ImageUpdateAutomation resources — then copy the combined multi-document YAML ready for <code class="bg-surface px-1 rounded text-sm">kubectl apply</code>.
  </p>

  <div class="flex flex-wrap gap-2 mb-8">
    <span class="text-xs bg-surface border border-border rounded-full px-3 py-1 text-text-muted">6 resource types</span>
    <span class="text-xs bg-surface border border-border rounded-full px-3 py-1 text-text-muted">Multi-document YAML</span>
    <span class="text-xs bg-surface border border-border rounded-full px-3 py-1 text-text-muted">HelmRelease values editor</span>
    <span class="text-xs bg-surface border border-border rounded-full px-3 py-1 text-text-muted">Flux v2 / GitOps Toolkit</span>
  </div>

  <FluxGitopsConfigBuilder client:only="preact" />

  <FaqSection faq={faq} />

  <ToolPageCta
    currentTool="Flux GitOps Config Builder"
    relatedTags={['flux', 'gitops', 'kubernetes', 'k8s', 'devops', 'helm']}
  />
</BaseLayout>
