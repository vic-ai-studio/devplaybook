---
import BaseLayout from '../../layouts/BaseLayout.astro';
import K8sIngressBuilder from '../../components/K8sIngressBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a Kubernetes Ingress?",
    answer: "A Kubernetes Ingress is an API object that manages external HTTP and HTTPS access to services inside a cluster. It acts as a reverse proxy — routing traffic based on hostnames and URL paths to the appropriate backend Services. Ingress consolidates routing rules in one place instead of exposing each Service with a LoadBalancer or NodePort. An Ingress Controller (like NGINX, Traefik, or Istio) must be running in the cluster for Ingress resources to take effect."
  },
  {
    question: "What is the difference between Prefix and Exact path types?",
    answer: "Prefix matches any URL path that begins with the specified string (e.g., /api matches /api, /api/users, /api/v2). Exact only matches the path exactly as written (e.g., /api only matches /api, not /api/users). ImplementationSpecific leaves the matching behavior up to the Ingress controller — useful for controllers with custom regex support. Use Prefix for routing to microservices and Exact for specific endpoints."
  },
  {
    question: "How do I set up TLS termination with Ingress?",
    answer: "Create a Kubernetes Secret of type kubernetes.io/tls containing your certificate and private key: kubectl create secret tls my-tls --cert=cert.pem --key=key.pem. Then reference the secret name in the Ingress spec.tls block alongside the hostnames it covers. The Ingress controller handles TLS termination — the backend services receive plain HTTP traffic. Use cert-manager to automate certificate provisioning from Let's Encrypt."
  },
  {
    question: "What are the differences between NGINX, Traefik, and Istio ingress controllers?",
    answer: "NGINX Ingress is the most widely used, battle-tested, and has extensive annotation support for rate limiting, rewrites, auth, and more. Traefik is cloud-native, auto-discovers routes via annotations and CRDs, and has a built-in dashboard — great for dynamic environments. Istio Ingress provides basic Ingress support but its real power is in Gateway + VirtualService CRDs for advanced traffic management, canary deployments, mutual TLS, and observability. For most use cases, start with NGINX."
  },
  {
    question: "What is ingressClassName and when should I use it?",
    answer: "ingressClassName replaces the deprecated kubernetes.io/ingress.class annotation in Kubernetes 1.18+. It specifies which Ingress controller should handle the Ingress resource — important when multiple controllers are running in the same cluster. Create an IngressClass resource first (or check what classes exist with kubectl get ingressclass), then set spec.ingressClassName to match. Both annotation and ingressClassName work in most controllers today, but ingressClassName is the modern approach."
  },
  {
    question: "How do I route to multiple services with one Ingress?",
    answer: "Define multiple path rules under the same host, or multiple host rules in one Ingress spec. For example, /api can route to api-service:8080 and /web to frontend-service:3000. Each path entry targets a different backend Service. You can also define separate host blocks in the same Ingress — example.com routes to one service while api.example.com routes to another. All services must be in the same namespace as the Ingress."
  },
];
---

<BaseLayout
  title="Kubernetes Ingress Builder — Visual K8s Ingress YAML Generator"
  description="Build Kubernetes Ingress YAML visually. Configure host rules, path routing, TLS, and annotations for NGINX, Traefik, or Istio ingress controllers. Free, no signup, runs in your browser."
  tool="Kubernetes Ingress Builder, K8s Ingress Generator, Ingress YAML, Kubernetes Ingress Controller, NGINX Ingress, Traefik Ingress, K8s TLS"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Kubernetes Ingress Builder",
    "url": "https://devplaybook.cc/tools/k8s-ingress-builder",
    "description": "Visual builder for Kubernetes Ingress YAML with TLS, path rules, and annotations for NGINX, Traefik, and Istio controllers.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Kubernetes Ingress Builder</h1>
  <p class="text-text-muted mb-4">
    Visually configure Kubernetes Ingress resources — host rules, URL path routing, TLS termination,
    and controller-specific annotations — and get production-ready YAML instantly.
    Supports NGINX, Traefik, and Istio ingress controllers.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> NGINX / Traefik / Istio</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TLS + multi-host + path routing</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <K8sIngressBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Kubernetes Ingress Builder" relatedTags={['kubernetes', 'devops', 'cloud', 'infrastructure', 'nginx', 'traefik']} />
</BaseLayout>
