---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "When should I increment MAJOR vs MINOR vs PATCH?",
    answer: "Increment PATCH (1.0.0 → 1.0.1) for backward-compatible bug fixes only — no new features, no API changes. Increment MINOR (1.0.0 → 1.1.0) when you add new functionality in a backward-compatible way — new functions, new optional parameters, new endpoints. Increment MAJOR (1.0.0 → 2.0.0) for any breaking change — removing a function, changing a function signature, changing the API response format, or dropping support for a language version."
  },
  {
    question: "What does 0.x.y versioning mean?",
    answer: "Versions below 1.0.0 are considered initial development. The API is considered unstable — anything may change at any time. In 0.x.y, the MINOR version behaves like MAJOR: breaking changes can happen on MINOR bumps. Once your public API is stable and ready for production use, release 1.0.0. Many libraries stay at 0.x for years; do not assume 0.x means abandoned or immature."
  },
  {
    question: "How do pre-release versions work in SemVer?",
    answer: "Append a hyphen and identifier: 1.0.0-alpha, 1.0.0-alpha.1, 1.0.0-beta.2, 1.0.0-rc.1. Pre-release versions have lower precedence than the release: 1.0.0-alpha < 1.0.0-alpha.1 < 1.0.0-beta < 1.0.0-rc.1 < 1.0.0. Use alpha for early internal testing, beta for external testing with known issues, and rc (release candidate) for the version that will become the final release unless critical bugs appear."
  },
  {
    question: "What is build metadata and when is it used?",
    answer: "Build metadata is appended with a plus sign: 1.0.0+20241201, 1.0.0+sha.abc1234. It carries information about the specific build — date, git SHA, build number — but has NO effect on version precedence. Two versions with different build metadata are considered equal for dependency resolution purposes (1.0.0+build1 == 1.0.0+build2). It is primarily used for traceability in enterprise environments."
  },
  {
    question: "How does SemVer map to Conventional Commits?",
    answer: "Conventional Commits provides a machine-readable commit format that maps directly to SemVer increments. Commits with 'BREAKING CHANGE:' in the footer or '!' after the type (feat!:, fix!:) trigger a MAJOR bump. Commits starting with 'feat:' trigger a MINOR bump. Commits starting with 'fix:', 'perf:', 'refactor:', etc. trigger a PATCH bump. Tools like semantic-release and release-please read your git history and automatically determine and apply the correct version bump."
  },
  {
    question: "SemVer vs CalVer — which should I use?",
    answer: "SemVer (MAJOR.MINOR.PATCH) is best for libraries and APIs where communicating breaking changes to consumers is essential — it tells users exactly what kind of change to expect. CalVer (calendar versioning, e.g. 2024.1, 2024.03.15) is better for applications, OS distros, and tools where the release date is more meaningful than API stability (Ubuntu uses YY.MM). Use SemVer for any package published to npm, PyPI, or similar registries. Use CalVer for end-user software with predictable release schedules."
  }
];
---

<BaseLayout
  title="Semantic Versioning (SemVer) Guide: MAJOR.MINOR.PATCH Explained"
  description="Complete SemVer reference: MAJOR.MINOR.PATCH rules, pre-release versions, build metadata, Conventional Commits mapping, changelog generation tools, and SemVer vs CalVer comparison."
  tool="semantic versioning, semver, MAJOR MINOR PATCH, versioning strategy, changelog, Conventional Commits, pre-release"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"WebPage","name":"Semantic Versioning (SemVer) Guide: MAJOR.MINOR.PATCH Explained","url":"https://devplaybook.cc/tools/semantic-versioning-calculator","description":"Complete SemVer reference covering MAJOR.MINOR.PATCH rules, pre-release versions, Conventional Commits mapping, changelog tools, and CalVer comparison."})} />

  <h1 class="text-3xl font-bold mb-2">Semantic Versioning (SemVer): MAJOR.MINOR.PATCH Explained</h1>
  <p class="text-text-muted mb-6">Semantic Versioning is the contract between library authors and consumers. Version numbers communicate intent: does upgrading break my code? This guide explains exactly when to increment each segment, how pre-release identifiers work, and how to automate versioning with Conventional Commits — so your changelogs write themselves.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> MAJOR.MINOR.PATCH decision rules</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Pre-release &amp; build metadata</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Conventional Commits → version mapping</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Changelog automation tools</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> SemVer vs CalVer comparison</span>
  </div>

  <ToolPageCta />

  <div class="mt-8 space-y-8">

    <section>
      <h2 class="text-2xl font-bold mb-3">SemVer Format &amp; Decision Rules</h2>
      <p class="text-text-muted mb-4">Given a version number <code class="font-mono text-sm bg-bg-card px-1 rounded">MAJOR.MINOR.PATCH</code>, increment each part based on the nature of the change. Reset lower segments to zero when incrementing a higher one.</p>
      <pre class="bg-bg-card border border-gray-700 rounded-lg p-4 overflow-x-auto text-sm font-mono text-gray-300"><code># PATCH: backward-compatible bug fix
# Before: 1.4.2  →  After: 1.4.3
function getUserById(id: string): User | null &#123;
  // Fixed: was throwing instead of returning null for missing users
  return db.users.find(u => u.id === id) ?? null;
&#125;

# MINOR: new backward-compatible feature
# Before: 1.4.3  →  After: 1.5.0
function getUserById(id: string, options?: &#123; includeDeleted?: boolean &#125;): User | null &#123;
  // New: optional includeDeleted parameter added
  const query = options?.includeDeleted ? db.users : db.users.where(&#123; deleted: false &#125;);
  return query.find(u => u.id === id) ?? null;
&#125;

# MAJOR: breaking change (changed return type)
# Before: 1.5.0  →  After: 2.0.0
async function getUserById(id: string): Promise&lt;User&gt; &#123;
  // Breaking: now async, throws UserNotFoundError instead of returning null
  const user = await db.users.findById(id);
  if (!user) throw new UserNotFoundError(id);
  return user;
&#125;</code></pre>
    </section>

    <section>
      <h2 class="text-2xl font-bold mb-3">Pre-Release Versions &amp; Build Metadata</h2>
      <p class="text-text-muted mb-4">Use pre-release identifiers for software that is not yet stable. Precedence order: <code class="font-mono text-sm bg-bg-card px-1 rounded">alpha &lt; beta &lt; rc &lt; release</code>. Build metadata is ignored during version comparison.</p>
      <pre class="bg-bg-card border border-gray-700 rounded-lg p-4 overflow-x-auto text-sm font-mono text-gray-300"><code># Pre-release version progression
1.0.0-alpha        # early internal testing
1.0.0-alpha.1      # second alpha build
1.0.0-beta.1       # external testing begins
1.0.0-rc.1         # release candidate — feature freeze
1.0.0              # final release

# Precedence (lower to higher):
# 1.0.0-alpha < 1.0.0-alpha.1 < 1.0.0-alpha.beta < 1.0.0-beta
# < 1.0.0-beta.2 < 1.0.0-beta.11 < 1.0.0-rc.1 < 1.0.0

# Build metadata (IGNORED during comparison)
1.0.0+20241201.sha.abc1234    # date + git SHA
1.0.0+build.42                # CI build number
# 1.0.0+build.42  ==  1.0.0+build.99  (same version, different builds)</code></pre>
    </section>

    <section>
      <h2 class="text-2xl font-bold mb-3">Conventional Commits → Version Bump Mapping</h2>
      <p class="text-text-muted mb-4">Conventional Commits encode the version bump type directly in the commit message. Tools like <code class="font-mono text-sm bg-bg-card px-1 rounded">semantic-release</code> and <code class="font-mono text-sm bg-bg-card px-1 rounded">release-please</code> read these to automate releases entirely.</p>
      <pre class="bg-bg-card border border-gray-700 rounded-lg p-4 overflow-x-auto text-sm font-mono text-gray-300"><code># MAJOR bump — breaking change (two ways to signal)
feat!: change getUserById to async with error throwing
# OR footer notation:
fix: correct edge case in user lookup

BREAKING CHANGE: getUserById now throws UserNotFoundError instead of returning null

# MINOR bump — new feature
feat: add includeDeleted option to getUserById
feat(api): add batch user lookup endpoint

# PATCH bump — bug fix, performance, refactor
fix: prevent null pointer when user id is empty
perf: cache user lookup results for 5 minutes
refactor: extract user mapper to separate module

# No version bump (ignored by release tools)
docs: update getUserById JSDoc examples
test: add edge case tests for getUserById
chore: upgrade dev dependencies
ci: add caching to GitHub Actions workflow</code></pre>
    </section>

    <section>
      <h2 class="text-2xl font-bold mb-4">SemVer vs CalVer Comparison</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="border-b border-gray-700">
              <th class="text-left py-3 px-4 text-gray-300 font-semibold">Dimension</th>
              <th class="text-left py-3 px-4 text-gray-300 font-semibold">SemVer (1.2.3)</th>
              <th class="text-left py-3 px-4 text-gray-300 font-semibold">CalVer (2024.03.15)</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-700/50 hover:bg-gray-800/30">
              <td class="py-3 px-4 text-gray-300">Signals</td>
              <td class="py-3 px-4 text-gray-400">Breaking changes &amp; new features</td>
              <td class="py-3 px-4 text-gray-400">Release date &amp; cadence</td>
            </tr>
            <tr class="border-b border-gray-700/50 hover:bg-gray-800/30">
              <td class="py-3 px-4 text-gray-300">Best for</td>
              <td class="py-3 px-4 text-gray-400">Libraries, APIs, packages</td>
              <td class="py-3 px-4 text-gray-400">OSes, apps, tools with fixed schedules</td>
            </tr>
            <tr class="border-b border-gray-700/50 hover:bg-gray-800/30">
              <td class="py-3 px-4 text-gray-300">Examples</td>
              <td class="py-3 px-4 text-gray-400">React 18.2.0, Django 4.2.1</td>
              <td class="py-3 px-4 text-gray-400">Ubuntu 24.04, pip 24.0</td>
            </tr>
            <tr class="border-b border-gray-700/50 hover:bg-gray-800/30">
              <td class="py-3 px-4 text-gray-300">Automation</td>
              <td class="py-3 px-4 text-gray-400">semantic-release, release-please</td>
              <td class="py-3 px-4 text-gray-400">Date-based scripts</td>
            </tr>
            <tr class="hover:bg-gray-800/30">
              <td class="py-3 px-4 text-gray-300">Ecosystem support</td>
              <td class="py-3 px-4 text-gray-400">npm, PyPI, Cargo, RubyGems</td>
              <td class="py-3 px-4 text-gray-400">Project-specific (no standard tooling)</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-bold mb-3">Changelog Generation Tools</h2>
      <ul class="space-y-2 text-text-muted">
        <li class="flex items-start gap-2"><span class="text-green-500 mt-0.5">✓</span><span><strong class="text-white">semantic-release</strong> — Fully automated: reads commits, determines version, publishes to npm/GitHub, updates CHANGELOG.md. Zero configuration for projects following Conventional Commits. Best for libraries.</span></li>
        <li class="flex items-start gap-2"><span class="text-green-500 mt-0.5">✓</span><span><strong class="text-white">release-please (Google)</strong> — Creates a Release PR that accumulates all changes since the last release. You control when to merge. Supports multi-package monorepos. Best for apps and teams wanting a manual merge gate.</span></li>
        <li class="flex items-start gap-2"><span class="text-green-500 mt-0.5">✓</span><span><strong class="text-white">standard-version</strong> — Local CLI that bumps version, updates CHANGELOG.md, and creates a git tag. No CI integration required. Good for teams starting out.</span></li>
        <li class="flex items-start gap-2"><span class="text-green-500 mt-0.5">✓</span><span><strong class="text-white">git-cliff</strong> — Rust-based, highly customizable changelog generator. Supports custom templates (Tera syntax) and any commit format. Fast and configurable for non-standard commit styles.</span></li>
      </ul>
    </section>

  </div>

  <FaqSection faq={faq} />
</BaseLayout>
