---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GcpServiceAccountKeyChecker from '../../components/GcpServiceAccountKeyChecker.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is a GCP service account key?",
    answer: "A service account key is a JSON file containing credentials that allow applications to authenticate to Google Cloud APIs as a service account. The key file contains a private RSA key, the service account email, project ID, and OAuth endpoints. Applications use the key with client libraries or gcloud CLI to obtain access tokens. Keys are powerful — they grant the permissions of the service account and don't expire by default."
  },
  {
    question: "Why should I avoid using service account key files?",
    answer: "Service account key files are long-lived credentials that are easy to leak (committed to Git, stored in environment variables, included in container images). Google recommends avoiding key files when running on GCP infrastructure. Alternatives: Workload Identity Federation for GKE workloads (Pod uses its Kubernetes service account to authenticate without a key), Application Default Credentials on Compute Engine/Cloud Run (no key needed — ADC uses the VM's attached service account), and Workload Identity Federation for external workloads (GitHub Actions, AWS, Azure)."
  },
  {
    question: "How should I rotate service account keys?",
    answer: "Create a new key before disabling the old one to avoid downtime. Steps: 1) Create a new key (gcloud iam service-accounts keys create), 2) Update all systems using the old key to use the new one, 3) Verify the new key works, 4) Delete the old key (gcloud iam service-accounts keys delete). GCP recommends rotating keys every 90 days. You can list all keys with 'gcloud iam service-accounts keys list --iam-account=SA_EMAIL'."
  },
  {
    question: "What is the difference between service_account and authorized_user key types?",
    answer: "service_account keys represent non-human identities designed for application authentication. They have long-lived RSA private keys and grant the permissions of the service account's IAM bindings. authorized_user keys represent OAuth2 credentials for a human Google account (generated by gcloud auth application-default login). These are user-context credentials with user-level permissions. Never use authorized_user credentials in production — use service accounts with minimal permissions instead."
  },
  {
    question: "What is Workload Identity Federation?",
    answer: "Workload Identity Federation lets external workloads (GitHub Actions, AWS EC2, Azure VMs, Kubernetes outside GCP) authenticate to GCP without service account key files. Instead of a long-lived key, the workload exchanges a short-lived credential from its native platform for a GCP access token. This eliminates the key rotation problem and reduces the risk of credential leaks. For GKE specifically, Workload Identity maps Kubernetes service accounts to GCP service accounts."
  },
  {
    question: "How do I check what permissions a service account has?",
    answer: "Use 'gcloud projects get-iam-policy PROJECT_ID --flatten=bindings[].members --filter=bindings.members:serviceAccount:SA_EMAIL --format=table(bindings.role)' to list all roles bound to a service account at the project level. Also check at the folder and organization level. Use IAM Recommender to identify unused permissions for least-privilege cleanup. The Google Cloud Console IAM page also shows effective permissions with inherited roles."
  },
];
---

<BaseLayout
  title="GCP Service Account Key Checker — Validate JSON Key Files Online"
  description="Free online GCP service account key checker. Validates JSON structure, required fields, client_email format, private_key format, and security best practices. Runs 100% in your browser."
  tool="GCP service account key checker, Google Cloud key validator, GCP JSON key validator, service account key format checker, GCP credentials validator, Google Cloud security checker"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">GCP Service Account Key Checker</h1>
  <p class="text-text-muted mb-4">Validate a GCP service account key JSON file for structural correctness, required fields, and security best practices. All checking runs locally in your browser — your key file is never transmitted anywhere.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100% local — key never leaves your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 9 validation checks</span>
  </div>
  <GcpServiceAccountKeyChecker client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="GCP Service Account Key Checker" relatedTags={['gcp', 'cloud', 'devops', 'security', 'infrastructure']} />
</BaseLayout>
