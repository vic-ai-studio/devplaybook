---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HttpStatusReference from '../../components/HttpStatusReference.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What are HTTP status codes and why do they matter?",
    answer: "HTTP status codes are 3-digit numbers a server returns with every response to indicate the outcome of a request. They're grouped into 5 classes: 1xx (informational), 2xx (success), 3xx (redirection), 4xx (client error), and 5xx (server error). Understanding them is essential for debugging APIs, building error handling, and interpreting server logs."
  },
  {
    question: "What's the difference between 401 Unauthorized and 403 Forbidden?",
    answer: "401 Unauthorized means the server doesn't know who you are — authentication is missing or invalid. 403 Forbidden means the server knows who you are but you don't have permission. Use 401 when credentials are absent or wrong; use 403 when the user is authenticated but lacks access rights."
  },
  {
    question: "When should I use 301 vs 302 redirects?",
    answer: "301 Moved Permanently tells browsers and search engines to permanently update their records — SEO equity passes and the redirect is cached. 302 Found is temporary, so the original URL is preserved and not cached. Use 301 for permanent URL changes and domain migrations; use 302 for login flows, A/B testing, and temporary redirects."
  },
  {
    question: "What does 429 Too Many Requests mean?",
    answer: "429 indicates rate limiting — the client has exceeded the allowed request rate. Servers should include a Retry-After header showing when to retry. Clients should implement exponential backoff with jitter. This is the standard way to protect APIs from abuse without returning a 503."
  },
  {
    question: "When should a REST API return 422 vs 400?",
    answer: "400 Bad Request is for syntactically malformed requests (invalid JSON, missing Content-Type header). 422 Unprocessable Entity is for syntactically valid but semantically invalid input (correct JSON structure, but a field fails validation like 'age' being -5). Use 422 for form/field validation errors in modern APIs."
  },
  {
    question: "What is the difference between 404 and 410?",
    answer: "404 Not Found means the resource doesn't exist or you're not revealing its existence. 410 Gone means the resource previously existed but has been permanently deleted — this signals crawlers to deindex the URL and removes it from search results faster. Use 410 when you deliberately retire URLs; 404 is fine when you don't track deletions."
  },
];
---

<BaseLayout
  title="HTTP Status Code Reference — All 1xx–5xx Codes Explained"
  description="Complete HTTP status code reference. Search all 1xx, 2xx, 3xx, 4xx, and 5xx codes with plain-English descriptions, real-world use cases, and when to use each in REST APIs. Free, runs in your browser."
  tool="HTTP Status Code Reference, HTTP Response Codes, REST API Status Codes, HTTP Error Codes List"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "HTTP Status Code Reference",
    "url": "https://devplaybook.cc/tools/http-status-code-reference",
    "description": "Interactive reference for all HTTP status codes 1xx–5xx. Search and filter codes with descriptions, use cases, and best practices for REST APIs.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">HTTP Status Code Reference</h1>
  <p class="text-text-muted mb-4">
    Every HTTP status code explained — with real-world use cases, when to use them, and what they mean in REST APIs.
    Filter by category (1xx–5xx) or search by code number, name, or keyword.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> All 60+ standard codes</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Grouped by category (1xx–5xx)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Search by code or keyword</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <HttpStatusReference client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="HTTP Status Code Reference" relatedTags={['http', 'api', 'rest', 'web', 'debugging', 'networking']} />
</BaseLayout>
