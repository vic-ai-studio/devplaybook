---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NumberFormatter from '../../components/NumberFormatter.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What number formats does this tool support?", answer: "The formatter shows: US and EU locale formats (with thousand separators), scientific notation, percentage, currencies (USD, EUR, GBP, JPY), binary, octal, hexadecimal, number-in-words, file size (bytes/KB/MB/GB), and fixed decimal formats." },
  { question: "How does number-to-words work?", answer: "The tool converts integers up to billions into English words. For example, 1,234,567 becomes 'one million, two hundred thirty-four thousand, five hundred sixty-seven'. Decimals are truncated for the words format." },
  { question: "Can I convert a number to hexadecimal?", answer: "Yes — integer numbers show binary (base 2), octal (base 8), and hexadecimal (base 16) representations. Negative or non-integer numbers show 'N/A' for these formats since they only apply to non-negative integers." },
  { question: "What is scientific notation?", answer: "Scientific notation expresses numbers as a coefficient times a power of 10. For example, 1234567.89 becomes 1.23456789e+6. It's useful for very large or very small numbers in scientific and engineering contexts." },
];
---

<BaseLayout
  title="Number Formatter — Format Numbers in Multiple Ways"
  description="Format any number in multiple ways: locale formats, currencies, scientific notation, binary, hex, octal, words, and file sizes. Free online number formatter."
  tool="number formatter, number to words, number to binary, number to hex, format number online, locale number format"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Number Formatter</h1>
  <p class="text-text-muted mb-4">Enter any number and instantly see it formatted in multiple ways: locale formats (US, EU), currencies, scientific notation, binary, hexadecimal, words, file size, and more. Copy any format with one click.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 15+ output formats</span>
  </div>
  <NumberFormatter client:only="preact" />
  <FaqSection faq={faq} />
  <div class="mt-8 p-4 bg-accent/10 border border-accent/20 rounded-lg text-center">
    <p class="text-sm text-text-muted mb-2">Looking for more free developer tools?</p>
    <a href="/tools" class="inline-flex items-center gap-2 text-accent font-medium hover:underline">Browse All Free Tools →</a>
  </div>
  <ToolPageCta currentTool="Number Formatter" relatedTags={['numbers', 'formatting', 'converter', 'math']} />
</BaseLayout>
