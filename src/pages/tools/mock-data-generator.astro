---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What field types can I generate mock data for?",
    answer: "This generator supports the most common schema field types: name (first, last, full), email, phone, date (ISO format), number (integer ranges), boolean, uuid (v4 format), url, address, company, and custom string arrays. Each type generates realistic-looking data — not just random strings — making it useful for UI development and API testing.",
  },
  {
    question: "How do I use the generated mock data in my tests?",
    answer: "Copy the JSON output and use it as fixture data in your test files. For Jest/Vitest, save it to a __fixtures__/users.json file and import it. For API mocking with MSW (Mock Service Worker), use it directly in your route handlers. For Playwright, use it with page.route() to intercept and return mock responses.",
  },
  {
    question: "Can I generate nested objects or arrays of objects?",
    answer: "This tool generates flat objects and arrays of objects. For deeply nested structures, generate the individual objects separately and compose them in your code. For complex schemas, consider using libraries like Faker.js (faker-js) for programmatic generation, or Zod + zod-mock for TypeScript schema-driven generation.",
  },
  {
    question: "What is a UUID and when should I use it for IDs?",
    answer: "UUID (Universally Unique Identifier) v4 is a randomly generated 128-bit number formatted as xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx. Use UUIDs as IDs when you need globally unique identifiers across distributed systems, when you want to avoid sequential ID exposure (which reveals record count), or when you're pre-generating IDs client-side before inserting into a database.",
  },
  {
    question: "How realistic is the generated data?",
    answer: "The generator uses curated lists of real first names, last names, company names, domains, and street names. Email addresses use realistic patterns (firstname.lastname@domain.com). Phone numbers follow US format. Dates are random within the last 5 years. While not as comprehensive as Faker.js, the output looks realistic enough for UI development and testing.",
  },
  {
    question: "Can I use this for generating test fixtures for Prisma or TypeORM?",
    answer: "Yes — generate the JSON array, then map it to your Prisma createMany() or TypeORM insert() calls. For Prisma: prisma.user.createMany({ data: generatedArray }). For TypeORM: repository.save(generatedArray). The field names in the schema builder should match your model field names exactly.",
  },
];
---

<BaseLayout
  title="Mock Data Generator — Generate Realistic JSON Test Data from Schema"
  description="Generate realistic mock JSON data from a schema definition. Add fields (name, email, date, UUID, number, boolean), set record count, and copy JSON arrays for testing, Prisma seeds, and API mocking. Free, runs in your browser."
  tool="Mock Data Generator, JSON Test Data Generator, Fake Data Generator, Prisma Seed Data, Faker Alternative Online"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Mock Data Generator",
    "url": "https://devplaybook.cc/tools/mock-data-generator",
    "description": "Generate realistic mock JSON data from a schema definition. Supports name, email, date, UUID, number, boolean, and more. Copy JSON arrays for test fixtures and API mocking.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Mock Data Generator</h1>
  <p class="text-text-muted mb-4">
    Define a schema with field names and types — generate a realistic JSON array instantly.
    Perfect for test fixtures, Prisma seeds, Storybook stories, and API mock responses.
    Runs entirely in your browser.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> name, email, phone, date, uuid, url</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> number, boolean, address, company</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Up to 100 records</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Copy as JSON array</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Schema Builder -->
    <div class="flex flex-col gap-4">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted">Schema Fields</h2>
          <button id="add-field" class="px-3 py-1.5 rounded-lg text-xs font-medium bg-accent text-white hover:opacity-90 transition-opacity">+ Add Field</button>
        </div>
        <div id="fields-container" class="flex flex-col gap-2"></div>
      </div>

      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted mb-3">Options</h2>
        <div class="flex items-center gap-4">
          <div class="flex-1">
            <label class="block text-sm font-medium mb-1" for="record-count">Records to Generate</label>
            <input id="record-count" type="number" value="5" min="1" max="100" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" />
          </div>
          <div class="flex-1">
            <label class="block text-sm font-medium mb-1" for="output-format">Output Format</label>
            <select id="output-format" class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors">
              <option value="array">JSON Array</option>
              <option value="object">Single Object</option>
              <option value="ts">TypeScript Interface + Data</option>
            </select>
          </div>
        </div>
        <button id="generate-btn" class="mt-4 w-full px-4 py-2.5 rounded-lg bg-accent text-white font-medium text-sm hover:opacity-90 transition-opacity">Generate Mock Data</button>
      </div>
    </div>

    <!-- Output -->
    <div class="flex flex-col gap-2">
      <div class="flex items-center justify-between">
        <label class="text-sm font-medium text-text-muted uppercase tracking-wide">Generated Output</label>
        <div class="flex gap-2">
          <span id="record-info" class="text-xs text-text-muted"></span>
          <button id="copy-output" class="px-3 py-1 rounded text-xs bg-bg-card border border-border text-text-muted hover:text-text transition-colors">Copy</button>
        </div>
      </div>
      <textarea id="output" rows="28" readonly class="w-full px-3 py-2 rounded-lg bg-bg border border-border text-text text-xs font-mono focus:outline-none resize-none opacity-80"></textarea>
    </div>
  </div>

  <script>
    const FIRST_NAMES = ['Alice','Bob','Carol','David','Emma','Frank','Grace','Henry','Isabella','James','Kate','Liam','Mia','Noah','Olivia','Peter','Quinn','Rachel','Sam','Tina','Uma','Victor','Wendy','Xavier','Yara','Zoe'];
    const LAST_NAMES = ['Smith','Johnson','Williams','Brown','Jones','Garcia','Miller','Davis','Martinez','Wilson','Anderson','Taylor','Thomas','Jackson','White','Harris','Martin','Thompson','Young','Hall'];
    const DOMAINS = ['gmail.com','yahoo.com','outlook.com','company.io','dev.co','techcorp.com','example.com','mail.net'];
    const COMPANIES = ['Acme Corp','TechFlow','DataSphere','CloudNine','DevStack','Nexus Systems','Sigma Labs','ByteForge','Pixel Works','CodeBridge'];
    const STREETS = ['Main St','Oak Ave','Maple Dr','Cedar Ln','Elm St','Park Blvd','Lake Rd','Hill Way','River Rd','Forest Ave'];
    const CITIES = ['New York','Los Angeles','Chicago','Houston','Phoenix','Philadelphia','San Antonio','San Diego','Dallas','Austin'];
    const TLD_LIST = ['com','io','dev','net','org','co'];
    const WORDS = ['alpha','beta','gamma','delta','epsilon','zeta','eta','theta','iota','kappa'];

    function rand<T>(arr: T[]): T { return arr[Math.floor(Math.random() * arr.length)]; }
    function randInt(min: number, max: number): number { return Math.floor(Math.random() * (max - min + 1)) + min; }
    function randFloat(min: number, max: number, dec = 2): number { return parseFloat((Math.random() * (max - min) + min).toFixed(dec)); }

    function uuid(): string {
      return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {
        const r = Math.random() * 16 | 0;
        return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);
      });
    }

    function isoDate(): string {
      const d = new Date(Date.now() - Math.random() * 5 * 365 * 24 * 3600 * 1000);
      return d.toISOString().split('T')[0];
    }

    function generateValue(type: string, fieldName: string): unknown {
      const name = fieldName.toLowerCase();
      switch(type) {
        case 'name': {
          const first = rand(FIRST_NAMES), last = rand(LAST_NAMES);
          if (name.includes('first')) return first;
          if (name.includes('last')) return last;
          return `${first} ${last}`;
        }
        case 'email': {
          const first = rand(FIRST_NAMES).toLowerCase();
          const last = rand(LAST_NAMES).toLowerCase();
          return `${first}.${last}@${rand(DOMAINS)}`;
        }
        case 'phone': return `+1-${randInt(200,999)}-${randInt(100,999)}-${randInt(1000,9999)}`;
        case 'date': return isoDate();
        case 'datetime': return new Date(Date.now() - Math.random() * 5 * 365 * 24 * 3600 * 1000).toISOString();
        case 'number': return randInt(1, 10000);
        case 'float': return randFloat(0, 1000);
        case 'boolean': return Math.random() > 0.5;
        case 'uuid': return uuid();
        case 'url': return `https://${rand(WORDS)}.${rand(TLD_LIST)}/${rand(WORDS)}`;
        case 'address': return `${randInt(1,9999)} ${rand(STREETS)}, ${rand(CITIES)}`;
        case 'company': return rand(COMPANIES);
        case 'id': return uuid();
        default: return `${rand(WORDS)}-${randInt(100,999)}`;
      }
    }

    interface Field { name: string; type: string; }
    let fields: Field[] = [
      { name: 'id', type: 'uuid' },
      { name: 'name', type: 'name' },
      { name: 'email', type: 'email' },
      { name: 'createdAt', type: 'datetime' },
      { name: 'isActive', type: 'boolean' },
    ];

    const TYPE_OPTIONS = ['uuid','name','email','phone','date','datetime','number','float','boolean','url','address','company','id'];

    function renderFields() {
      const container = document.getElementById('fields-container') as HTMLElement;
      container.innerHTML = fields.map((f, i) => `
        <div class="flex gap-2 items-center" data-index="${i}">
          <input type="text" class="field-name flex-1 px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors" value="${f.name}" placeholder="fieldName" />
          <select class="field-type px-3 py-2 rounded-lg bg-bg border border-border text-text text-sm focus:outline-none focus:border-accent transition-colors">
            ${TYPE_OPTIONS.map(t => `<option value="${t}" ${t === f.type ? 'selected' : ''}>${t}</option>`).join('')}
          </select>
          <button class="remove-field px-2 py-2 rounded-lg bg-bg border border-border text-text-muted hover:text-red-400 transition-colors text-sm" title="Remove">✕</button>
        </div>
      `).join('');

      container.querySelectorAll('.field-name').forEach((el, i) => {
        el.addEventListener('input', (e) => { fields[i].name = (e.target as HTMLInputElement).value; });
      });
      container.querySelectorAll('.field-type').forEach((el, i) => {
        el.addEventListener('change', (e) => { fields[i].type = (e.target as HTMLSelectElement).value; });
      });
      container.querySelectorAll('.remove-field').forEach((el, i) => {
        el.addEventListener('click', () => { fields.splice(i, 1); renderFields(); });
      });
    }

    function generate() {
      const count = Math.min(100, parseInt((document.getElementById('record-count') as HTMLInputElement).value) || 5);
      const format = (document.getElementById('output-format') as HTMLSelectElement).value;
      const validFields = fields.filter(f => f.name.trim());

      if (validFields.length === 0) {
        (document.getElementById('output') as HTMLTextAreaElement).value = '// Add at least one field to generate data';
        return;
      }

      if (format === 'object') {
        const obj: Record<string, unknown> = {};
        validFields.forEach(f => { obj[f.name] = generateValue(f.type, f.name); });
        (document.getElementById('output') as HTMLTextAreaElement).value = JSON.stringify(obj, null, 2);
        (document.getElementById('record-info') as HTMLElement).textContent = '1 record';
      } else if (format === 'ts') {
        const typeMap: Record<string, string> = { uuid:'string', name:'string', email:'string', phone:'string', date:'string', datetime:'string', number:'number', float:'number', boolean:'boolean', url:'string', address:'string', company:'string', id:'string' };
        const iface = `interface GeneratedItem {\n${validFields.map(f => `  ${f.name}: ${typeMap[f.type] || 'string'};`).join('\n')}\n}\n\n`;
        const data: Record<string, unknown>[] = Array.from({ length: count }, () => {
          const obj: Record<string, unknown> = {};
          validFields.forEach(f => { obj[f.name] = generateValue(f.type, f.name); });
          return obj;
        });
        (document.getElementById('output') as HTMLTextAreaElement).value = iface + `const mockData: GeneratedItem[] = ${JSON.stringify(data, null, 2)};`;
        (document.getElementById('record-info') as HTMLElement).textContent = `${count} records`;
      } else {
        const data: Record<string, unknown>[] = Array.from({ length: count }, () => {
          const obj: Record<string, unknown> = {};
          validFields.forEach(f => { obj[f.name] = generateValue(f.type, f.name); });
          return obj;
        });
        (document.getElementById('output') as HTMLTextAreaElement).value = JSON.stringify(data, null, 2);
        (document.getElementById('record-info') as HTMLElement).textContent = `${count} records`;
      }
    }

    document.getElementById('add-field')!.addEventListener('click', () => {
      fields.push({ name: `field${fields.length + 1}`, type: 'name' });
      renderFields();
    });

    document.getElementById('generate-btn')!.addEventListener('click', generate);
    document.getElementById('record-count')!.addEventListener('input', generate);
    document.getElementById('output-format')!.addEventListener('change', generate);

    document.getElementById('copy-output')!.addEventListener('click', () => {
      const val = (document.getElementById('output') as HTMLTextAreaElement).value;
      if (val) {
        navigator.clipboard.writeText(val).then(() => {
          const btn = document.getElementById('copy-output') as HTMLButtonElement;
          btn.textContent = 'Copied!';
          setTimeout(() => btn.textContent = 'Copy', 2000);
        });
      }
    });

    renderFields();
    generate();
  </script>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Mock Data Generator" relatedTags={['testing', 'json', 'mock', 'fixtures', 'developer-tools']} />
</BaseLayout>
