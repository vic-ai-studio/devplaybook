---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OxcLintConfigGenerator from '../../components/OxcLintConfigGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is OXC and oxlint?", answer: "OXC (Oxidation Compiler) is a Rust-powered JavaScript/TypeScript toolchain. oxlint is its linter — written in Rust, it runs 50-100x faster than ESLint. oxlint focuses on correctness and best practice rules with minimal configuration. It's designed to be a drop-in partial replacement for ESLint, handling the most impactful rules while being easy to adopt incrementally." },
  { question: "How do I install and run oxlint?", answer: "Install: npm install --save-dev oxlint (or use npx oxlint directly). Run: npx oxlint src/. By default, oxlint runs all correctness rules — no config required. For customization, create an oxlint.json in your project root. Add a script to package.json: \"lint:ox\": \"oxlint src/\". oxlint also integrates with VS Code via the OXC extension." },
  { question: "What is the difference between oxlint and ESLint?", answer: "oxlint is a fast Rust linter focused on correctness rules — no formatting, no import sorting. ESLint is a JavaScript linter with a massive plugin ecosystem but is significantly slower. The recommended approach: use oxlint for fast correctness/best-practice checks (catches most real bugs), and ESLint only for rules oxlint doesn't support yet. oxlint includes an ESLint compatibility layer for gradual migration." },
  { question: "What rule categories does oxlint support?", answer: "oxlint groups rules into: correctness (code that is definitely wrong or likely buggy), suspicious (patterns that might be bugs), pedantic (strict best practices), style (code style preferences), restriction (rules that prohibit certain patterns), and nursery (new rules in development). correctness rules are enabled by default. Run oxlint --list-rules to see all available rules." },
  { question: "How do I configure plugins in oxlint?", answer: "oxlint supports plugins for ecosystem-specific rules. Enable plugins in oxlint.json: { \"plugins\": [\"import\", \"react\", \"unicorn\", \"typescript\"] }. Each plugin adds relevant rules — the react plugin checks React hooks and JSX patterns, typescript plugin checks TypeScript-specific issues, unicorn adds opinionated modern JavaScript rules. Plugin rules follow the same off/warn/error severity system." },
  { question: "Can I use oxlint with ESLint together?", answer: "Yes. eslint-plugin-oxlint provides an ESLint config that disables all ESLint rules already covered by oxlint, preventing duplicate reports. Install: npm install --save-dev eslint-plugin-oxlint. Add to eslint.config.js: import oxlint from 'eslint-plugin-oxlint'; and spread oxlint.configs['flat/all'] in your config array. This setup runs oxlint first (fast pass) then ESLint for remaining rules." },
];
---

<BaseLayout
  title="OXC Lint Config Generator — oxlint.json Builder"
  description="Generate oxlint.json configuration for the OXC Rust linter. Toggle rules by category, configure environments and plugins, set ignore patterns. 50-100x faster than ESLint. Free tool."
  tool="OXC linter, oxlint config, oxlint.json, Rust linter, JavaScript linting, ESLint alternative, OXC toolchain"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "OXC Lint Config Generator",
    "url": "https://devplaybook.cc/tools/oxc-lint-config-generator",
    "description": "Build oxlint.json configurations visually. Toggle linting rules by category, enable environments and plugins, add ignore patterns. Get a copy-ready config for the OXC Rust linter.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">OXC Lint Config Generator</h1>
  <p class="text-text-muted mb-4">Build <strong>oxlint.json</strong> configs for the OXC Rust linter — 50-100x faster than ESLint. Toggle rules by category, enable plugins, and configure environments. Copy the result directly into your project.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 4 rule categories</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> React/TS/Unicorn plugins</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Environment toggles</span>
  </div>
  <OxcLintConfigGenerator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="OXC Lint Config Generator" relatedTags={['javascript', 'typescript', 'linting', 'tooling', 'rust', 'oxc']} />
</BaseLayout>
