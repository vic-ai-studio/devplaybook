---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is MMLU and why does it matter?",
    answer: "MMLU (Massive Multitask Language Understanding) tests knowledge across 57 academic subjects including math, science, law, and humanities. It measures breadth of world knowledge and reasoning. A score of 90%+ indicates near-expert level. GPT-4 scores ~86%, Claude 3 Opus ~86%, and Gemini Ultra ~83% on MMLU."
  },
  {
    question: "What is HumanEval and how is it measured?",
    answer: "HumanEval is a coding benchmark from OpenAI testing 164 Python programming problems. Models are measured on pass@1 (percentage of problems solved correctly on the first try). GPT-4 achieves ~90% pass@1, Claude 3.5 Sonnet ~92%. It's the industry standard for measuring code generation capability."
  },
  {
    question: "What is HellaSwag?",
    answer: "HellaSwag tests commonsense reasoning by asking models to complete sentences in a way that makes physical and social sense. It's designed to be easy for humans (>95%) but hard for AI. Models scoring above 90% demonstrate strong commonsense understanding. GPT-4 achieves ~95.3%, close to human level."
  },
  {
    question: "What does GSM8K measure?",
    answer: "GSM8K (Grade School Math 8K) tests multi-step arithmetic reasoning using 8,500 grade-school math word problems. It requires breaking down problems into steps and performing accurate calculations. GPT-4 achieves ~97% on GSM8K. This benchmark correlates strongly with general reasoning ability."
  },
  {
    question: "How do I choose the right LLM for my use case?",
    answer: "Match benchmarks to your needs: (1) General knowledge tasks → prioritize MMLU. (2) Code generation → prioritize HumanEval. (3) Reasoning/math → prioritize GSM8K and MATH. (4) Long documents → prioritize context window and SCROLLS. (5) Fast responses → prioritize tokens/second. (6) Budget-conscious → balance cost-per-token against performance scores."
  }
];
---

<BaseLayout
  title="LLM Benchmark Calculator — Compare AI Models on MMLU, HumanEval, GSM8K"
  description="Compare large language models across standard benchmarks: MMLU, HumanEval, HellaSwag, GSM8K, MATH, and more. Filter by task type to find the best LLM for your use case."
  tool="llm benchmark calculator, ai model benchmark comparison, mmlu scores, humaneval leaderboard, llm performance comparison"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "LLM Benchmark Calculator",
    "url": "https://devplaybook.cc/tools/llm-benchmark-calculator",
    "description": "Compare LLMs across standard benchmarks including MMLU, HumanEval, HellaSwag, GSM8K, and MATH. Find the best model for your specific use case.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">LLM Benchmark Calculator</h1>
  <p class="text-text-muted mb-4">
    Compare top language models across industry-standard benchmarks. Filter by use case to find the best model for your project.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 10+ frontier models</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 6 benchmark categories</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Composite score ranking</span>
  </div>

  <!-- Filter by task -->
  <div class="mb-6">
    <label class="block text-sm font-medium mb-2">Filter by Use Case</label>
    <div class="flex flex-wrap gap-2">
      <button class="filter-btn active text-xs px-3 py-1.5 rounded-full border border-primary text-primary bg-primary/10 transition-all" data-filter="all">All</button>
      <button class="filter-btn text-xs px-3 py-1.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-filter="knowledge">Knowledge</button>
      <button class="filter-btn text-xs px-3 py-1.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-filter="code">Code</button>
      <button class="filter-btn text-xs px-3 py-1.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-filter="math">Math/Reasoning</button>
      <button class="filter-btn text-xs px-3 py-1.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-filter="budget">Budget Models</button>
    </div>
  </div>

  <!-- Benchmark table -->
  <div class="overflow-x-auto mb-8">
    <table id="benchmark-table" class="w-full text-sm min-w-[800px]">
      <thead>
        <tr class="text-text-muted text-xs uppercase border-b border-border">
          <th class="text-left pb-3 pr-4 font-medium cursor-pointer hover:text-primary" data-sort="name">Model <span class="sort-icon">↕</span></th>
          <th class="text-right pb-3 pr-4 font-medium cursor-pointer hover:text-primary" data-sort="mmlu">MMLU <span class="sort-icon">↕</span></th>
          <th class="text-right pb-3 pr-4 font-medium cursor-pointer hover:text-primary" data-sort="humaneval">HumanEval <span class="sort-icon">↕</span></th>
          <th class="text-right pb-3 pr-4 font-medium cursor-pointer hover:text-primary" data-sort="hellaswag">HellaSwag <span class="sort-icon">↕</span></th>
          <th class="text-right pb-3 pr-4 font-medium cursor-pointer hover:text-primary" data-sort="gsm8k">GSM8K <span class="sort-icon">↕</span></th>
          <th class="text-right pb-3 pr-4 font-medium cursor-pointer hover:text-primary" data-sort="math">MATH <span class="sort-icon">↕</span></th>
          <th class="text-right pb-3 pr-4 font-medium cursor-pointer hover:text-primary" data-sort="composite">Score <span class="sort-icon">↓</span></th>
          <th class="text-right pb-3 font-medium">$/1M tok</th>
        </tr>
      </thead>
      <tbody id="model-rows" class="divide-y divide-border">
      </tbody>
    </table>
  </div>

  <!-- Benchmark descriptions -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-8">
    <div class="border border-border rounded-lg p-4">
      <div class="text-sm font-semibold mb-1">MMLU</div>
      <p class="text-xs text-text-muted">57-subject knowledge test. Best proxy for general world knowledge and academic reasoning.</p>
    </div>
    <div class="border border-border rounded-lg p-4">
      <div class="text-sm font-semibold mb-1">HumanEval</div>
      <p class="text-xs text-text-muted">Python coding problems. Industry standard for code generation capability (pass@1).</p>
    </div>
    <div class="border border-border rounded-lg p-4">
      <div class="text-sm font-semibold mb-1">HellaSwag</div>
      <p class="text-xs text-text-muted">Commonsense NLI completion. Tests physical/social reasoning close to human-level tasks.</p>
    </div>
    <div class="border border-border rounded-lg p-4">
      <div class="text-sm font-semibold mb-1">GSM8K</div>
      <p class="text-xs text-text-muted">Grade-school math word problems. Strong proxy for multi-step reasoning ability.</p>
    </div>
    <div class="border border-border rounded-lg p-4">
      <div class="text-sm font-semibold mb-1">MATH</div>
      <p class="text-xs text-text-muted">Competition-level mathematics. Measures advanced mathematical problem-solving.</p>
    </div>
    <div class="border border-border rounded-lg p-4">
      <div class="text-sm font-semibold mb-1">Composite Score</div>
      <p class="text-xs text-text-muted">Weighted average: MMLU 30% + HumanEval 20% + HellaSwag 15% + GSM8K 20% + MATH 15%.</p>
    </div>
  </div>

  <AdUnit />
  <ToolPageCta />

<script>
(() => {
  const MODELS = [
    { name: 'GPT-4o', provider: 'OpenAI', mmlu: 88.7, humaneval: 90.2, hellaswag: 95.3, gsm8k: 97.0, math: 76.6, inputPrice: 5.00, outputPrice: 15.00, tier: 'frontier', tags: ['knowledge', 'code', 'math'] },
    { name: 'o1', provider: 'OpenAI', mmlu: 92.3, humaneval: 92.4, hellaswag: 96.1, gsm8k: 99.0, math: 90.8, inputPrice: 15.00, outputPrice: 60.00, tier: 'reasoning', tags: ['knowledge', 'code', 'math'] },
    { name: 'o1-mini', provider: 'OpenAI', mmlu: 85.2, humaneval: 97.9, hellaswag: 91.0, gsm8k: 98.0, math: 90.0, inputPrice: 3.00, outputPrice: 12.00, tier: 'reasoning', tags: ['code', 'math'] },
    { name: 'GPT-4o Mini', provider: 'OpenAI', mmlu: 82.0, humaneval: 87.2, hellaswag: 90.0, gsm8k: 91.0, math: 70.2, inputPrice: 0.15, outputPrice: 0.60, tier: 'budget', tags: ['budget', 'knowledge', 'code'] },
    { name: 'Claude 3.5 Sonnet', provider: 'Anthropic', mmlu: 88.3, humaneval: 92.0, hellaswag: 89.0, gsm8k: 96.4, math: 71.1, inputPrice: 3.00, outputPrice: 15.00, tier: 'frontier', tags: ['knowledge', 'code', 'math'] },
    { name: 'Claude 3 Opus', provider: 'Anthropic', mmlu: 86.8, humaneval: 84.9, hellaswag: 89.1, gsm8k: 95.0, math: 60.1, inputPrice: 15.00, outputPrice: 75.00, tier: 'frontier', tags: ['knowledge', 'code'] },
    { name: 'Claude 3.5 Haiku', provider: 'Anthropic', mmlu: 77.6, humaneval: 88.1, hellaswag: 85.9, gsm8k: 88.9, math: 54.9, inputPrice: 0.80, outputPrice: 4.00, tier: 'budget', tags: ['budget', 'code'] },
    { name: 'Gemini 1.5 Pro', provider: 'Google', mmlu: 85.9, humaneval: 84.1, hellaswag: 92.0, gsm8k: 91.7, math: 58.5, inputPrice: 3.50, outputPrice: 10.50, tier: 'frontier', tags: ['knowledge', 'code'] },
    { name: 'Gemini 2.0 Flash', provider: 'Google', mmlu: 76.0, humaneval: 71.5, hellaswag: 89.2, gsm8k: 87.3, math: 59.4, inputPrice: 0.10, outputPrice: 0.40, tier: 'budget', tags: ['budget'] },
    { name: 'Llama 3.3 70B', provider: 'Meta', mmlu: 86.0, humaneval: 88.4, hellaswag: 93.1, gsm8k: 93.0, math: 68.0, inputPrice: 0.59, outputPrice: 0.79, tier: 'open-source', tags: ['knowledge', 'code', 'budget'] },
    { name: 'Llama 3.1 8B', provider: 'Meta', mmlu: 73.0, humaneval: 72.6, hellaswag: 82.1, gsm8k: 78.5, math: 32.0, inputPrice: 0.10, outputPrice: 0.10, tier: 'open-source', tags: ['budget'] },
    { name: 'Mistral Large 2', provider: 'Mistral', mmlu: 84.0, humaneval: 92.1, hellaswag: 88.7, gsm8k: 93.0, math: 66.1, inputPrice: 3.00, outputPrice: 9.00, tier: 'frontier', tags: ['knowledge', 'code', 'math'] },
  ];

  // Compute composite: MMLU 30% + HumanEval 20% + HellaSwag 15% + GSM8K 20% + MATH 15%
  MODELS.forEach(m => {
    m.composite = Math.round((m.mmlu * 0.30 + m.humaneval * 0.20 + m.hellaswag * 0.15 + m.gsm8k * 0.20 + m.math * 0.15) * 10) / 10;
    m.avgPrice = ((m.inputPrice + m.outputPrice) / 2).toFixed(2);
  });

  let currentSort = 'composite';
  let sortDir = -1; // -1 = desc
  let currentFilter = 'all';

  function bar(val, max = 100, color = 'bg-primary') {
    const pct = Math.round((val / max) * 100);
    return `<div class="flex items-center gap-2 justify-end">
      <span class="font-mono text-xs">${val.toFixed(1)}%</span>
      <div class="w-16 h-1.5 bg-surface rounded-full overflow-hidden border border-border">
        <div class="${color} h-full rounded-full" style="width:${pct}%"></div>
      </div>
    </div>`;
  }

  function render() {
    const filtered = currentFilter === 'all'
      ? MODELS
      : MODELS.filter(m => m.tags.includes(currentFilter));

    const sorted = [...filtered].sort((a, b) => {
      const av = a[currentSort], bv = b[currentSort];
      if (typeof av === 'string') return av.localeCompare(bv) * sortDir;
      return (av - bv) * sortDir;
    });

    const tbody = document.getElementById('model-rows');
    tbody.innerHTML = sorted.map((m, i) => {
      const provColor = m.provider === 'OpenAI' ? 'text-green-400'
        : m.provider === 'Anthropic' ? 'text-orange-400'
        : m.provider === 'Google' ? 'text-blue-400'
        : m.provider === 'Meta' ? 'text-purple-400'
        : 'text-text-muted';
      const badge = m.tier === 'open-source' ? '<span class="text-xs px-1.5 py-0.5 rounded bg-purple-500/20 text-purple-400 ml-1">OSS</span>'
        : m.tier === 'reasoning' ? '<span class="text-xs px-1.5 py-0.5 rounded bg-blue-500/20 text-blue-400 ml-1">Reasoning</span>'
        : '';
      return `<tr class="model-row hover:bg-surface/50 transition-colors" data-tags="${m.tags.join(',')}">
        <td class="py-3 pr-4">
          <div class="font-medium text-sm">${m.name}${badge}</div>
          <div class="text-xs ${provColor}">${m.provider}</div>
        </td>
        <td class="py-3 pr-4">${bar(m.mmlu, 100, 'bg-primary')}</td>
        <td class="py-3 pr-4">${bar(m.humaneval, 100, 'bg-accent')}</td>
        <td class="py-3 pr-4">${bar(m.hellaswag, 100, 'bg-green-500')}</td>
        <td class="py-3 pr-4">${bar(m.gsm8k, 100, 'bg-yellow-500')}</td>
        <td class="py-3 pr-4">${bar(m.math, 100, 'bg-orange-500')}</td>
        <td class="py-3 pr-4 text-right">
          <span class="font-bold font-mono text-sm ${m.composite >= 85 ? 'text-green-400' : m.composite >= 75 ? 'text-yellow-400' : 'text-text-muted'}">${m.composite}</span>
        </td>
        <td class="py-3 text-right font-mono text-xs text-text-muted">$${m.inputPrice.toFixed(2)}</td>
      </tr>`;
    }).join('');
  }

  // Sort headers
  document.querySelectorAll('[data-sort]').forEach(th => {
    th.addEventListener('click', () => {
      const col = th.dataset.sort;
      if (currentSort === col) sortDir *= -1;
      else { currentSort = col; sortDir = -1; }
      render();
    });
  });

  // Filter buttons
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active', 'border-primary', 'text-primary', 'bg-primary/10'));
      btn.classList.add('active', 'border-primary', 'text-primary', 'bg-primary/10');
      currentFilter = btn.dataset.filter;
      render();
    });
  });

  render();
})();
</script>

  <FaqSection faq={faq} />
</BaseLayout>
