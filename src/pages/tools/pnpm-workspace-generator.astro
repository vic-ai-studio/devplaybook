---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PnpmWorkspaceGenerator from '../../components/PnpmWorkspaceGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is pnpm-workspace.yaml and why do I need it?",
    answer: "pnpm-workspace.yaml is the configuration file that tells pnpm which directories in your repository contain workspace packages. By listing glob patterns such as 'packages/*' or 'apps/*', pnpm treats those directories as local packages and links them together automatically. Without this file, pnpm treats your repository as a single package and does not enable monorepo features like shared dependencies or cross-package linking.",
  },
  {
    question: "What is the pnpm catalog feature?",
    answer: "Introduced in pnpm v9, the catalog feature lets you define a set of canonical dependency versions in pnpm-workspace.yaml under the 'catalog:' key. Individual packages in the workspace can then reference these versions using 'catalog:' as a version specifier in their package.json instead of hard-coding a version string. This keeps all packages in sync and makes version bumps a single-file change.",
  },
  {
    question: "When should I use package overrides?",
    answer: "Use overrides when you need to force every package in the workspace to use a specific version of a transitive dependency — for example, to patch a security vulnerability in a deeply nested package, or to resolve conflicting peer dependency requirements between packages. Overrides are a last resort; prefer updating the direct dependency first.",
  },
  {
    question: "Should I enable shamefullyHoist?",
    answer: "Only enable shamefullyHoist if you have a tool or framework that relies on Node.js resolution finding packages directly in the root node_modules directory rather than through pnpm's isolated symlink layout. Examples include some older Webpack plugins or tools that use require.resolve without traversing symlinks. Enabling it trades strictness for compatibility and can hide missing dependency declarations.",
  },
  {
    question: "What is the difference between pnpm overrides and resolutions (npm/yarn)?",
    answer: "All three fields serve the same purpose — forcing a specific version of a transitive dependency — but have different syntax and scope. npm uses 'overrides' in package.json, Yarn uses 'resolutions', and pnpm uses 'overrides' in either package.json or pnpm-workspace.yaml. Placing overrides in pnpm-workspace.yaml applies them workspace-wide across all packages, which is usually what you want in a monorepo.",
  },
];
---

<BaseLayout
  title="pnpm Workspace Generator — Generate pnpm-workspace.yaml"
  description="Free online pnpm workspace generator. Configure package globs, catalog entries, overrides, and options to instantly generate a pnpm-workspace.yaml for your monorepo. Runs in your browser."
  tool="pnpm Workspace Generator, pnpm monorepo, pnpm-workspace.yaml, pnpm catalog, pnpm overrides, monorepo setup"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">pnpm Workspace Generator</h1>
  <p class="text-text-muted mb-4">Configure your pnpm monorepo workspace visually and get a ready-to-use <code class="font-mono text-sm bg-bg-card border border-border px-1.5 py-0.5 rounded">pnpm-workspace.yaml</code> instantly. Add package globs, set up a catalog for shared versions, pin overrides, and toggle workspace-wide flags.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Package glob patterns</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Catalog (pnpm v9+)</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Dependency overrides</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs entirely in your browser</span>
  </div>
  <PnpmWorkspaceGenerator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="pnpm Workspace Generator" relatedTags={['pnpm', 'monorepo', 'nodejs', 'package-manager', 'yaml']} />
</BaseLayout>
