---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is OpenAI function calling?", answer: "Function calling (also called tool use) lets GPT-4o and other models call structured functions instead of generating free text. You define a function schema (name, description, parameters as JSON Schema), and the model decides when to call it based on the conversation. This enables reliable structured output, API integrations, and agentic workflows." },
  { question: "What is the difference between 'functions' and 'tools' in the API?", answer: "The 'functions' API was the original interface; 'tools' is the modern replacement (introduced mid-2023). Both work the same way, but 'tools' supports multiple tool types (function, code_interpreter, retrieval) and is the recommended interface for all new development. This generator uses the 'tools' format." },
  { question: "How do I make function parameters required vs optional?", answer: "In the JSON Schema, list required parameters in the 'required' array. Parameters not listed in 'required' are optional — the model may omit them. For reliable results, make all parameters required and use descriptive enum values or patterns to constrain inputs. Avoid too many optional parameters as the model may hallucinate values." },
  { question: "What JSON Schema types can I use?", answer: "Supported types: string, number, integer, boolean, array, object, null. Use 'enum' to restrict to specific values. Use 'description' on every parameter — this is critical for model accuracy. Use 'items' for array element type, and 'properties' for nested objects. Avoid deeply nested schemas as they increase token cost and reduce reliability." },
  { question: "How do I handle the model's function call in Python?", answer: "After calling chat.completions.create(), check if response.choices[0].message.tool_calls is not None. Extract the function name and parse the JSON arguments string. Execute your function, then append the result as a 'tool' role message. Finally, call the API again with the tool result — the model will incorporate it into its final response." },
];
---

<BaseLayout
  title="OpenAI Function Calling Generator — JSON Schema from TypeScript Interface"
  description="Generate OpenAI function calling JSON schema from a TypeScript interface or visual form. Copy-ready Python and JavaScript code for GPT-4o tool use."
  tool="OpenAI function calling generator, tool use schema, JSON Schema generator, GPT-4o function calling, TypeScript to JSON Schema, OpenAI tools"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">OpenAI Function Calling Generator</h1>
  <p class="text-text-muted mb-4">Define your function visually or paste a TypeScript interface to generate OpenAI-compatible tool schemas with copy-ready Python and JS code.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Visual parameter builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> JSON Schema output</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Python + JS code</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GPT-4o / Claude compatible</span>
  </div>

  <div class="space-y-5">
    <!-- Function definition -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="font-semibold mb-4">Function Definition</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-sm font-medium text-text-muted mb-1" for="fn-name">Function Name</label>
          <input id="fn-name" type="text" value="get_weather"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40"
            placeholder="my_function_name" />
          <div class="text-xs text-text-muted mt-1">snake_case recommended</div>
        </div>
        <div>
          <label class="block text-sm font-medium text-text-muted mb-1" for="fn-desc">Description</label>
          <input id="fn-desc" type="text" value="Get the current weather for a location"
            class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40"
            placeholder="What does this function do?" />
          <div class="text-xs text-text-muted mt-1">Be specific — the model uses this to decide when to call</div>
        </div>
      </div>
    </div>

    <!-- Parameters -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-semibold">Parameters</h2>
        <button id="add-param-btn" class="text-xs bg-primary/10 text-primary border border-primary/30 px-3 py-1.5 rounded-lg hover:bg-primary/20 transition-colors">+ Add Parameter</button>
      </div>
      <div id="params-list" class="space-y-3"></div>
    </div>

    <!-- Presets -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="font-semibold mb-3">Load Example</h2>
      <div class="flex flex-wrap gap-2">
        <button class="example-btn px-3 py-1.5 text-xs rounded-lg bg-bg border border-border hover:border-primary hover:text-primary transition-colors" data-example="weather">get_weather</button>
        <button class="example-btn px-3 py-1.5 text-xs rounded-lg bg-bg border border-border hover:border-primary hover:text-primary transition-colors" data-example="search">search_documents</button>
        <button class="example-btn px-3 py-1.5 text-xs rounded-lg bg-bg border border-border hover:border-primary hover:text-primary transition-colors" data-example="email">send_email</button>
        <button class="example-btn px-3 py-1.5 text-xs rounded-lg bg-bg border border-border hover:border-primary hover:text-primary transition-colors" data-example="db">query_database</button>
      </div>
    </div>

    <!-- Output tabs -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex gap-2 mb-4">
        <button class="tab-btn active px-4 py-2 text-sm rounded-lg bg-primary text-white font-medium" data-tab="schema">JSON Schema</button>
        <button class="tab-btn px-4 py-2 text-sm rounded-lg bg-bg border border-border hover:border-primary hover:text-primary transition-colors" data-tab="python">Python</button>
        <button class="tab-btn px-4 py-2 text-sm rounded-lg bg-bg border border-border hover:border-primary hover:text-primary transition-colors" data-tab="js">JavaScript</button>
      </div>
      <div class="relative">
        <button id="copy-output-btn" class="absolute top-2 right-2 text-xs bg-bg-card border border-border px-2 py-1 rounded hover:border-primary hover:text-primary transition-colors z-10">Copy</button>
        <pre id="output-code" class="bg-bg rounded-lg p-4 text-xs font-mono overflow-x-auto text-green-400 whitespace-pre-wrap min-h-[200px] pt-8"></pre>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="OpenAI Function Calling Generator" relatedTags={['openai', 'ai', 'api', 'json-schema', 'gpt', 'tool-use']} />
</BaseLayout>

<script is:inline>
(function () {
  var fnName = document.getElementById('fn-name');
  var fnDesc = document.getElementById('fn-desc');
  var paramsList = document.getElementById('params-list');
  var addParamBtn = document.getElementById('add-param-btn');
  var outputCode = document.getElementById('output-code');
  var copyOutputBtn = document.getElementById('copy-output-btn');
  var currentTab = 'schema';

  var params = [
    { name: 'location', type: 'string', description: 'The city and state, e.g. "San Francisco, CA"', required: true, enum: '' },
    { name: 'unit', type: 'string', description: 'Temperature unit', required: false, enum: 'celsius,fahrenheit' },
  ];

  var EXAMPLES = {
    weather: {
      name: 'get_weather', desc: 'Get the current weather for a location',
      params: [
        { name: 'location', type: 'string', description: 'City and state, e.g. "San Francisco, CA"', required: true, enum: '' },
        { name: 'unit', type: 'string', description: 'Temperature unit', required: false, enum: 'celsius,fahrenheit' },
      ]
    },
    search: {
      name: 'search_documents', desc: 'Search through documents in the knowledge base',
      params: [
        { name: 'query', type: 'string', description: 'The search query string', required: true, enum: '' },
        { name: 'limit', type: 'integer', description: 'Maximum number of results to return (1-50)', required: false, enum: '' },
        { name: 'category', type: 'string', description: 'Filter by document category', required: false, enum: 'technical,marketing,legal,finance' },
      ]
    },
    email: {
      name: 'send_email', desc: 'Send an email to a recipient',
      params: [
        { name: 'to', type: 'string', description: 'Recipient email address', required: true, enum: '' },
        { name: 'subject', type: 'string', description: 'Email subject line', required: true, enum: '' },
        { name: 'body', type: 'string', description: 'Email body text (plain text or markdown)', required: true, enum: '' },
        { name: 'priority', type: 'string', description: 'Email priority level', required: false, enum: 'low,normal,high' },
      ]
    },
    db: {
      name: 'query_database', desc: 'Execute a read-only SQL query on the database',
      params: [
        { name: 'sql', type: 'string', description: 'The SQL SELECT query to execute', required: true, enum: '' },
        { name: 'database', type: 'string', description: 'Target database name', required: true, enum: '' },
        { name: 'timeout_seconds', type: 'integer', description: 'Query timeout in seconds (max 30)', required: false, enum: '' },
      ]
    }
  };

  function renderParams() {
    paramsList.innerHTML = params.map(function (p, i) {
      return '<div class="grid grid-cols-1 sm:grid-cols-12 gap-3 items-start p-3 border border-border rounded-lg bg-bg">' +
        '<div class="sm:col-span-2">' +
        '<label class="block text-xs text-text-muted mb-1">Name</label>' +
        '<input class="param-name w-full bg-bg-card border border-border rounded px-2 py-1.5 text-xs font-mono focus:outline-none focus:ring-1 focus:ring-primary/40" data-idx="' + i + '" value="' + p.name + '" />' +
        '</div>' +
        '<div class="sm:col-span-2">' +
        '<label class="block text-xs text-text-muted mb-1">Type</label>' +
        '<select class="param-type w-full bg-bg-card border border-border rounded px-2 py-1.5 text-xs focus:outline-none focus:ring-1 focus:ring-primary/40" data-idx="' + i + '">' +
        ['string', 'number', 'integer', 'boolean', 'array', 'object'].map(function (t) { return '<option value="' + t + '"' + (p.type === t ? ' selected' : '') + '>' + t + '</option>'; }).join('') +
        '</select>' +
        '</div>' +
        '<div class="sm:col-span-4">' +
        '<label class="block text-xs text-text-muted mb-1">Description</label>' +
        '<input class="param-desc w-full bg-bg-card border border-border rounded px-2 py-1.5 text-xs font-mono focus:outline-none focus:ring-1 focus:ring-primary/40" data-idx="' + i + '" value="' + p.description.replace(/"/g, '&quot;') + '" />' +
        '</div>' +
        '<div class="sm:col-span-2">' +
        '<label class="block text-xs text-text-muted mb-1">Enum values</label>' +
        '<input class="param-enum w-full bg-bg-card border border-border rounded px-2 py-1.5 text-xs font-mono focus:outline-none focus:ring-1 focus:ring-primary/40" data-idx="' + i + '" value="' + p.enum + '" placeholder="val1,val2" />' +
        '</div>' +
        '<div class="sm:col-span-1 flex flex-col items-center gap-2 pt-4">' +
        '<label class="flex items-center gap-1 cursor-pointer text-xs">' +
        '<input type="checkbox" class="param-required accent-primary" data-idx="' + i + '"' + (p.required ? ' checked' : '') + ' />' +
        'Req' +
        '</label>' +
        '<button class="remove-param text-xs text-text-muted hover:text-red-400 transition-colors" data-idx="' + i + '">✕</button>' +
        '</div>' +
        '</div>';
    }).join('');

    paramsList.querySelectorAll('.param-name').forEach(function (el) { el.addEventListener('input', function () { params[+el.dataset.idx].name = el.value; updateOutput(); }); });
    paramsList.querySelectorAll('.param-type').forEach(function (el) { el.addEventListener('change', function () { params[+el.dataset.idx].type = el.value; updateOutput(); }); });
    paramsList.querySelectorAll('.param-desc').forEach(function (el) { el.addEventListener('input', function () { params[+el.dataset.idx].description = el.value; updateOutput(); }); });
    paramsList.querySelectorAll('.param-enum').forEach(function (el) { el.addEventListener('input', function () { params[+el.dataset.idx].enum = el.value; updateOutput(); }); });
    paramsList.querySelectorAll('.param-required').forEach(function (el) { el.addEventListener('change', function () { params[+el.dataset.idx].required = el.checked; updateOutput(); }); });
    paramsList.querySelectorAll('.remove-param').forEach(function (btn) { btn.addEventListener('click', function () { params.splice(+btn.dataset.idx, 1); renderParams(); updateOutput(); }); });
  }

  function buildSchema() {
    var properties = {};
    var required = [];
    params.forEach(function (p) {
      var prop = { type: p.type, description: p.description };
      if (p.enum) {
        prop.enum = p.enum.split(',').map(function (v) { return v.trim(); }).filter(Boolean);
      }
      properties[p.name] = prop;
      if (p.required) required.push(p.name);
    });
    return {
      type: 'function',
      function: {
        name: fnName.value || 'my_function',
        description: fnDesc.value || '',
        parameters: {
          type: 'object',
          properties: properties,
          required: required
        }
      }
    };
  }

  function buildPython() {
    var schema = buildSchema();
    var schemaStr = JSON.stringify(schema, null, 4).split('\n').join('\n');
    return 'from openai import OpenAI\nimport json\n\nclient = OpenAI()\n\n' +
      '# Define the tool\ntool = ' + schemaStr + '\n\n' +
      '# Call the model with tool\nresponse = client.chat.completions.create(\n' +
      '    model="gpt-4o",\n' +
      '    messages=[{"role": "user", "content": "What\'s the weather in San Francisco?"}],\n' +
      '    tools=[tool],\n' +
      '    tool_choice="auto"\n' +
      ')\n\n' +
      '# Handle tool call\nmsg = response.choices[0].message\nif msg.tool_calls:\n' +
      '    call = msg.tool_calls[0]\n' +
      '    args = json.loads(call.function.arguments)\n' +
      '    # Execute: result = ' + (fnName.value || 'my_function') + '(**args)\n' +
      '    print(f"Called: {call.function.name} with {args}")';
  }

  function buildJS() {
    var schema = buildSchema();
    var schemaStr = JSON.stringify(schema, null, 2);
    return 'import OpenAI from "openai";\n\nconst client = new OpenAI();\n\n' +
      'const tool = ' + schemaStr + ';\n\n' +
      'const response = await client.chat.completions.create({\n' +
      '  model: "gpt-4o",\n' +
      '  messages: [{ role: "user", content: "What\'s the weather in San Francisco?" }],\n' +
      '  tools: [tool],\n' +
      '  tool_choice: "auto",\n' +
      '});\n\n' +
      'const msg = response.choices[0].message;\nif (msg.tool_calls?.length) {\n' +
      '  const call = msg.tool_calls[0];\n' +
      '  const args = JSON.parse(call.function.arguments);\n' +
      '  console.log("Called:", call.function.name, "with", args);\n' +
      '  // const result = await ' + (fnName.value || 'myFunction') + '(args);\n' +
      '}';
  }

  function updateOutput() {
    if (currentTab === 'schema') {
      outputCode.textContent = JSON.stringify(buildSchema(), null, 2);
    } else if (currentTab === 'python') {
      outputCode.textContent = buildPython();
    } else {
      outputCode.textContent = buildJS();
    }
  }

  document.querySelectorAll('.tab-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      currentTab = btn.dataset.tab;
      document.querySelectorAll('.tab-btn').forEach(function (b) {
        b.classList.toggle('active', false);
        b.className = b.className.replace('bg-primary text-white font-medium', '').trim() + ' bg-bg border border-border hover:border-primary hover:text-primary transition-colors';
      });
      btn.className = 'tab-btn active px-4 py-2 text-sm rounded-lg bg-primary text-white font-medium';
      updateOutput();
    });
  });

  document.querySelectorAll('.example-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var ex = EXAMPLES[btn.dataset.example];
      fnName.value = ex.name;
      fnDesc.value = ex.desc;
      params = ex.params.map(function (p) { return Object.assign({}, p); });
      renderParams();
      updateOutput();
    });
  });

  addParamBtn.addEventListener('click', function () {
    params.push({ name: 'param_' + (params.length + 1), type: 'string', description: '', required: false, enum: '' });
    renderParams();
    updateOutput();
  });

  [fnName, fnDesc].forEach(function (el) { el.addEventListener('input', updateOutput); });

  copyOutputBtn.addEventListener('click', function () {
    navigator.clipboard.writeText(outputCode.textContent).then(function () {
      copyOutputBtn.textContent = 'Copied!';
      setTimeout(function () { copyOutputBtn.textContent = 'Copy'; }, 2000);
    });
  });

  renderParams();
  updateOutput();
})();
</script>
