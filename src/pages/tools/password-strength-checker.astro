---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PasswordStrengthChecker from '../../components/PasswordStrengthChecker.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "How is password strength measured?", answer: "This tool checks six criteria: length (8+ and 12+), presence of uppercase letters, lowercase letters, numbers, and special characters. Each criterion adds to the overall score, which maps to Very Weak / Weak / Fair / Good / Strong / Very Strong. It also estimates entropy — the mathematical unpredictability in bits." },
  { question: "What is password entropy?", answer: "Entropy measures how hard a password is to brute-force. It's calculated from the character set size and length: entropy = length × log₂(charset size). A 16-character password using all character types has roughly 95–104 bits of entropy — considered very strong against modern attacks." },
  { question: "Does this tool send my password anywhere?", answer: "No. Everything runs entirely in your browser. Your password never leaves your device and is never sent to any server. You can disconnect from the internet and the tool will still work." },
  { question: "What makes a password strong?", answer: "Length is the most important factor — each additional character multiplies the search space exponentially. Combine length (12+ characters) with character variety (uppercase, lowercase, numbers, symbols) and avoid dictionary words, names, or common patterns. A passphrase (four random words) can be both strong and memorable." },
  { question: "What is the difference between a password strength checker and a password generator?", answer: "A strength checker evaluates a password you already have — or one you're considering — and tells you how secure it is. A password generator creates new random passwords for you. For best security, use the DevPlaybook Password Generator to create a strong password, then check it here to confirm it meets your standards." },
];
---

<BaseLayout
  title="Password Strength Checker — Test Your Password Security Online"
  description="Free password strength checker. Enter any password to get an instant strength rating, entropy estimate, criteria checklist, and tips to improve it. Runs 100% in your browser — nothing is stored."
  tool="Password Strength Checker, Password Strength Tester, Password Security Checker, Check Password Strength"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Password Strength Checker</h1>
  <p class="text-text-muted mb-4">Type any password to instantly see its strength score, entropy, criteria checklist, and actionable improvement tips. Everything runs in your browser — your password is never transmitted anywhere.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Your password is never stored or sent</span>
  </div>
  <PasswordStrengthChecker client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Password Strength Checker" relatedTags={['security', 'password', 'encryption', 'hashing', 'auth']} />
</BaseLayout>
