---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReactUseOptimistic from '../../components/ReactUseOptimistic.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is useOptimistic in React 19?", answer: "useOptimistic is a React 19 hook that lets you show an optimistic (predicted) UI state immediately while a background async operation runs. You provide the real state and a reducer function. React derives the optimistic state from your real state plus any pending optimistic updates, automatically reverting when the operation completes." },
  { question: "How does automatic rollback work?", answer: "When you call addOptimistic(data), React temporarily overlays the optimistic change on top of your real state. If the async action succeeds and you call setRealState(), React merges the real result. If the action throws an error and you don't catch it, React automatically drops the optimistic overlay and reverts to the last real state — no manual cleanup needed." },
  { question: "What is the difference between useOptimistic and useState?", answer: "useState holds authoritative data — it only changes when you explicitly call setState. useOptimistic holds temporary predicted state that auto-reverts. Think of useOptimistic as a 'ghost layer' on top of your real state: it shows what you expect to happen, while the real state catches up asynchronously." },
  { question: "Can I use useOptimistic with React 18?", answer: "No — useOptimistic is a React 19 API. For React 18, you can implement the same pattern manually: optimistically update a useState variable, run the async call, and revert with the original value in the catch block. It's more boilerplate but the same concept." },
  { question: "What happens if multiple optimistic updates are in flight?", answer: "React queues and merges multiple optimistic updates. Each addOptimistic call adds to the optimistic layer. As each corresponding async operation completes (or fails), its contribution is committed (or dropped) independently. This lets you handle multiple simultaneous mutations safely." },
  { question: "Is useOptimistic only for lists?", answer: "No — useOptimistic works for any state shape. It's common with todo lists and forms, but you can use it for counters (optimistic like count), field updates, status toggles, or any UI that should feel instant. The reducer can transform state in any way." },
];
---

<BaseLayout
  title="React useOptimistic Playground — React 19 Optimistic UI Demo"
  description="Interactive React 19 useOptimistic hook playground. Add and toggle todos with optimistic updates, simulate server delays and failures, watch automatic rollback in action. Includes code snippets for add, toggle, and rollback patterns."
  tool="React useOptimistic, optimistic UI React 19, React 19 hooks, useOptimistic tutorial"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">React useOptimistic Playground</h1>
  <p class="text-text-muted mb-4">
    Explore React 19's <code>useOptimistic</code> hook with a live todo list demo. Add items, toggle completion, and watch optimistic state vs. actual server state — with configurable delay and failure rates to trigger rollbacks.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <ReactUseOptimistic client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="React useOptimistic Playground" relatedTags={['react', 'react19', 'hooks', 'optimistic-ui', 'typescript', 'frontend']} />
</BaseLayout>
