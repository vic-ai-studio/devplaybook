---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FakeDataGenerator from '../../components/FakeDataGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a fake data generator used for?", answer: "Fake data generators create realistic but fictional user records — names, emails, addresses, phone numbers — for use in testing, development, and demos. They let you populate databases, seed test fixtures, and mock API responses without using real personal data, keeping your dev environment privacy-safe." },
  { question: "Why use locale-specific fake data?", answer: "Locale-specific data ensures your app handles real-world edge cases: Japanese names don't use spaces, Taiwanese addresses follow a different format, phone number formats differ by country. Testing with locale-appropriate data catches encoding bugs, layout overflow, and internationalization issues before production." },
  { question: "What is the difference between JSON, CSV, and SQL INSERT output?", answer: "JSON is ideal for seeding JavaScript/TypeScript apps or mocking REST API responses. CSV works great for importing into spreadsheets, databases, or data analysis tools. SQL INSERT generates ready-to-run INSERT statements for populating a database table directly — just specify your table name and paste into your SQL client." },
  { question: "Is the generated data truly random?", answer: "The data is pseudo-random, generated entirely in your browser using Math.random(). Each time you click Generate, a new set of random combinations is produced from curated word lists. The data looks realistic because it uses locale-appropriate names, domains, and address formats — but it is entirely fictional." },
  { question: "Can I use this data in production?", answer: "No — fake data is for development, testing, and demos only. Never use generated fake data for production systems, especially not for user-facing profiles or identity verification. For production, use real data with proper privacy controls and consent." },
];
---

<BaseLayout
  title="Fake Data Generator — Realistic Test Data in JSON, CSV, SQL"
  description="Generate realistic fake user data instantly — names, emails, phones, addresses, companies, and more. Choose locale (en/zh-TW/ja), output count (1–100), and format (JSON/CSV/SQL INSERT). 100% browser-based, no signup."
  tool="Fake Data Generator, Test Data Generator, Mock Data Generator, JSON Test Data, CSV Sample Data, SQL Seed Data, Dummy Data Generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Fake Data Generator</h1>
  <p class="text-text-muted mb-4">Generate realistic fake user records for testing and development. Choose locale (English, 繁體中文, 日本語), select which fields to include, and export as JSON, CSV, or SQL INSERT. No data leaves your browser.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 3 locales, 9 field types</span>
  </div>
  <FakeDataGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Fake Data Generator" relatedTags={['testing', 'json', 'csv', 'database', 'mock']} />
</BaseLayout>
