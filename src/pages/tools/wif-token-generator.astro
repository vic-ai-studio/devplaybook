---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WifTokenGenerator from '../../components/WifTokenGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is Workload Identity Federation (WIF)?",
    answer: "Workload Identity Federation lets external workloads (running on AWS, Azure, GitHub Actions, Kubernetes, etc.) authenticate to Google Cloud APIs without needing a downloaded service account key file. Instead, your workload presents its native identity token (an AWS SigV4 request, an Azure managed identity JWT, a GitHub OIDC token, etc.) to GCP's Security Token Service, which exchanges it for a short-lived Google access token. This eliminates long-lived credential files that can be leaked or stolen."
  },
  {
    question: "Why is WIF better than downloading a service account key?",
    answer: "Service account key files (JSON key files) are long-lived credentials that never expire unless you manually rotate them. If they are committed to git, logged, or copied to an insecure location they remain valid until deleted — a major security risk. WIF credentials are short-lived (1-hour tokens by default), tied to the specific identity of your workload, auditable in Cloud Audit Logs, and require zero file distribution. GCP, AWS, and GitHub all recommend WIF over static key files for CI/CD and cross-cloud access."
  },
  {
    question: "How do I set up a WIF pool and provider on GCP?",
    answer: "1. Enable the IAM and STS APIs in your GCP project. 2. Create a Workload Identity Pool: gcloud iam workload-identity-pools create POOL_ID --location=global --display-name='My Pool'. 3. Create a provider inside the pool, specifying the issuer URI and attribute mappings (e.g. for AWS: --provider-type=aws --account-id=AWS_ACCOUNT_ID). 4. Grant the external identity permission to impersonate a service account: gcloud iam service-accounts add-iam-policy-binding SA_EMAIL --role=roles/iam.workloadIdentityUser --member='principalSet://iam.googleapis.com/projects/PROJECT_NUMBER/locations/global/workloadIdentityPools/POOL_ID/attribute.aws_role/arn:aws:sts::ACCOUNT:assumed-role/ROLE'. 5. Generate the credential configuration file using this tool and set GOOGLE_APPLICATION_CREDENTIALS to its path."
  },
  {
    question: "Can I use WIF for cross-cloud federation between AWS and GCP?",
    answer: "Yes. AWS-to-GCP is one of the most common WIF patterns. Your AWS workload (EC2, Lambda, EKS pod) fetches its IAM role credentials from IMDSv2, signs a GetCallerIdentity request using SigV4, and sends it to GCP STS. GCP verifies the AWS identity, checks your attribute mappings and IAM bindings, then returns a short-lived Google access token. The generated credential_configuration.json handles this entire flow automatically when loaded by any Google client library or the gcloud CLI."
  }
];
---

<BaseLayout
  title="Workload Identity Federation Config Generator — GCP, AWS, Azure"
  description="Generate Workload Identity Federation configuration files for GCP, AWS, and Azure. Build credential_configuration.json for keyless authentication between cloud providers. Free, browser-based."
  tool="Workload Identity Federation Generator, WIF Config Generator, GCP WIF, AWS to GCP Authentication, Azure to GCP WIF, credential_configuration.json Generator, Keyless Authentication"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Workload Identity Federation Config Generator",
    "url": "https://devplaybook.cc/tools/wif-token-generator",
    "description": "Generate Workload Identity Federation configuration files for GCP, AWS, and Azure. Build credential_configuration.json for keyless authentication between cloud providers.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Workload Identity Federation Config Generator</h1>
  <p class="text-text-muted mb-4">
    Generate <code class="font-mono bg-surface px-1 rounded text-sm">credential_configuration.json</code> for GCP Workload Identity Federation.
    Supports GCP OIDC / JWT providers, AWS SigV4 exchange, and Azure Managed Identity — no service account key files needed.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> GCP, AWS &amp; Azure</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No service account keys</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Short-lived tokens only</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
  </div>
  <WifTokenGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Workload Identity Federation Config Generator" relatedTags={['security', 'devops', 'cloud', 'gcp', 'aws', 'azure', 'infrastructure', 'iam']} />
</BaseLayout>
