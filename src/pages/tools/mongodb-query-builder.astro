---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MongodbQueryBuilder from '../../components/MongodbQueryBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is the difference between find, findOne, and aggregate in MongoDB?",
    answer: "find() returns a cursor of all matching documents — use it to fetch multiple records with optional sort, limit, and skip. findOne() is equivalent to find().limit(1) and returns a single document object (or null) instead of a cursor — ideal when you know only one record matches. aggregate() uses a pipeline of stages ($match, $group, $project, $sort, $lookup, etc.) to transform documents; it's more powerful than find() for computations, joins, grouping, and reshaping data. For simple CRUD reads, prefer find/findOne; use aggregate when you need computed fields, joined data, or grouped results."
  },
  {
    question: "How does projection work in MongoDB?",
    answer: "Projection controls which fields are returned in each document. Pass an object where 1 includes a field and 0 excludes it: { name: 1, email: 1 } returns only name and email (plus _id by default). You cannot mix inclusions and exclusions in the same projection — except for _id, which you can explicitly exclude alongside inclusions: { name: 1, _id: 0 }. Projections reduce network transfer and memory usage when documents are large but you only need a subset of fields."
  },
  {
    question: "What are the most commonly used MongoDB query operators?",
    answer: "$eq is the implicit default — db.users.find({ age: 25 }) is shorthand for { age: { $eq: 25 } }. Comparison operators ($gt, $gte, $lt, $lte, $ne) work on numbers, dates, and strings. $in and $nin match against an array of possible values: { status: { $in: ['active', 'pending'] } }. $regex matches string fields against a regular expression. $exists checks whether a field is present: { phone: { $exists: true } }. Combine multiple operators with $and (implicit when using multiple fields) or $or for alternative conditions."
  },
  {
    question: "How is Mongoose different from the native MongoDB Node.js driver?",
    answer: "The native MongoDB driver (@mongodb/mongodb) gives you direct access to all MongoDB operations with minimal abstraction — you work with plain JavaScript objects and the full query API. Mongoose adds a schema layer on top: you define models with types, validation rules, and default values, and it enforces those at the application level. Mongoose also provides middleware (pre/post hooks), virtual fields, and helper methods. For simple apps or microservices where flexibility matters more than schema enforcement, the native driver is lighter. For full-stack apps that benefit from data validation and model organization, Mongoose is the popular choice."
  },
  {
    question: "When should I use aggregate instead of find with sort/limit?",
    answer: "Use aggregate when you need any of the following: $group to count or sum values (e.g., total orders per user), $lookup to join with another collection (like SQL JOIN), $unwind to flatten arrays into individual documents, $addFields or $project to compute new fields (e.g., concatenate name parts, calculate age from birthdate), or multi-stage data transformation pipelines. For simple filtering, sorting, and pagination without computed fields or joins, find() with sort/limit is faster and simpler. MongoDB also optimizes find() with index usage more aggressively than complex aggregate pipelines."
  },
];
---

<BaseLayout
  title="MongoDB Query Builder — Build MongoDB Queries Visually"
  description="Build MongoDB queries visually without memorizing syntax. Add filter conditions with operators ($eq, $gt, $in, $regex), configure projections, sort, limit, and skip. Outputs ready-to-copy MongoDB Shell, Mongoose, and Node.js driver code."
  tool="MongoDB Query Builder, MongoDB, Mongoose, NoSQL, Database, Query Builder, find, aggregate, MongoDB Shell"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "MongoDB Query Builder",
    "url": "https://devplaybook.cc/tools/mongodb-query-builder",
    "description": "Build MongoDB queries visually. Add filter conditions with operators, configure projections, sort, and pagination. Outputs MongoDB Shell, Mongoose, and Node.js driver code.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">MongoDB Query Builder</h1>
  <p class="text-text-muted mb-4">
    Build MongoDB queries visually — no syntax memorization required.
    Add filter conditions using operators like <code class="text-accent font-mono">$eq</code>,
    <code class="text-accent font-mono">$gt</code>, <code class="text-accent font-mono">$in</code>,
    and <code class="text-accent font-mono">$regex</code>. Configure projections, sort, limit, and skip.
    Instantly generates <strong>MongoDB Shell</strong>, <strong>Mongoose</strong>, and
    <strong>Node.js driver</strong> code.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> find / findOne / aggregate</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 10 filter operators</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Projection, sort, limit, skip</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Shell / Mongoose / Node.js driver output</span>
  </div>
  <MongodbQueryBuilder client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="MongoDB Query Builder" relatedTags={['mongodb', 'database', 'nosql', 'developer-tools']} />
</BaseLayout>
