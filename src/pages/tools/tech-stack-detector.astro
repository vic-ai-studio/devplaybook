---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TechStackDetector from '../../components/TechStackDetector.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Tech Stack Detector — Detect Any GitHub Repo's Tech Stack"
  description="Paste a GitHub repository URL to instantly detect its tech stack — languages, frameworks, databases, testing tools, and DevOps setup. Creates a shareable stack report."
  tool="Tech Stack Detector, GitHub Tech Stack, Repo Stack Analyzer, Technology Detector"
>
  <h1 class="text-3xl font-bold mb-2">Tech Stack Detector</h1>
  <p class="text-text-muted mb-8">Paste a GitHub repository URL (or <code class="font-mono text-sm bg-bg-card px-1 rounded">owner/repo</code>) to instantly analyze the tech stack — programming languages, frameworks, databases, testing tools, and more. All analysis runs client-side via the public GitHub API.</p>
  <TechStackDetector client:load />
  <ToolPageCta currentTool="Tech Stack Detector" relatedTags={['github', 'tech-stack', 'analysis', 'developer-tools']} />
</BaseLayout>
