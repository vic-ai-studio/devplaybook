---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const installExample = `# macOS (Homebrew)
brew install lazygit

# Windows (winget)
winget install JesseDuffield.lazygit

# Windows (Scoop)
scoop install lazygit

# Linux (apt — Ubuntu/Debian)
LAZYGIT_VERSION=$(curl -s "https://api.github.com/repos/jesseduffield/lazygit/releases/latest" | grep -Po '"tag_name": "v\\K[^"]*')
curl -Lo lazygit.tar.gz "https://github.com/jesseduffield/lazygit/releases/latest/download/lazygit_\${LAZYGIT_VERSION}_Linux_x86_64.tar.gz"
tar xf lazygit.tar.gz lazygit
sudo install lazygit /usr/local/bin

# Go (any platform)
go install github.com/jesseduffield/lazygit@latest`;

const faq = [
  { question: "What is lazygit?", answer: "lazygit is a terminal UI (TUI) for Git built in Go by Jesse Duffield. It gives you a keyboard-driven visual interface for common Git operations directly in your terminal — branches, commits, diffs, stashes, interactive rebase — without memorizing complex CLI flags. It runs in any terminal emulator and integrates naturally into a terminal-centric workflow." },
  { question: "How do I do interactive rebase with lazygit?", answer: "Open lazygit, switch to the Commits panel (press 4 or navigate there), scroll to the commit you want to rebase from, and press 'e' to start interactive rebase. You'll see a list of commits with options to pick, squash, fixup, reword, drop, or move them. Use arrow keys to navigate, and press the corresponding key for each action. Press Enter to execute the rebase. lazygit handles the autosquash step automatically when you mark commits as fixup." },
  { question: "How does lazygit compare to tig?", answer: "tig is a read-heavy TUI focused on browsing Git history, blame, and diffs — it is excellent as a viewer but more limited as an action tool. lazygit is action-first: it is designed for the full Git workflow (staging, committing, branching, rebasing, pushing, pulling) with rich keyboard shortcuts for every operation. Most developers use lazygit as their primary Git interface and may reach for tig when they need deep history browsing. Both are terminal-native and complement each other well." },
  { question: "What are the most useful lazygit keybindings?", answer: "Key keybindings: 'space' to stage/unstage a file or hunk, 'c' to commit, 'P' to push, 'p' to pull, 'b' to create a new branch, 'f' to fetch, 'z' to undo, 'e' to open your editor on the file, 'd' to delete a branch (with confirmation), 'r' to rebase, 'i' for interactive rebase, 's' to stash, 'g' to view stash list. The '?' key shows a full keybinding reference from within lazygit." },
  { question: "How do I configure lazygit to use a custom git editor or pager?", answer: "lazygit uses a YAML config file at ~/.config/lazygit/config.yml (Linux/macOS) or %APPDATA%/lazygit/config.yml (Windows). Set 'os.editCommand' to override the editor (e.g., 'os: {editCommand: nvim}'). You can also set custom keybindings, theme colors, and git log format. Run 'lazygit --config' to see the full default config. Most users don't need to configure anything — the defaults work well out of the box." },
  { question: "Can I use lazygit inside Neovim or tmux?", answer: "Yes. lazygit is a popular pairing with Neovim via plugins like lazyvim (LazyVim config), toggleterm.nvim (floating terminal), and dedicated plugins like kdheepak/lazygit.nvim that provide a floating lazygit window mapped to a keybinding. In tmux, you can open lazygit in a new window or pane and switch back as needed. The combination of Neovim + lazygit in tmux is a common high-productivity terminal workflow." },
];
---

<BaseLayout
  title="lazygit — Terminal UI for Git Commands"
  description="lazygit is a fast, keyboard-driven terminal UI for Git. Stage hunks, commit, branch, rebase interactively, manage stashes — all without memorizing git CLI flags. Free and open source."
  tool="lazygit, git TUI, terminal git UI, lazygit keybindings, interactive rebase TUI, git branch management terminal"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "lazygit — Terminal UI for Git Commands",
    "url": "https://devplaybook.cc/tools/lazygit",
    "description": "lazygit is a fast, keyboard-driven terminal UI for Git. Stage hunks, commit, branch, rebase interactively, manage stashes — all without memorizing git CLI flags.",
  })} />

  <h1 class="text-3xl font-bold mb-2">lazygit</h1>
  <p class="text-text-muted mb-6">
    A fast, keyboard-driven <strong>terminal UI for Git</strong> built in Go.
    lazygit brings visual branch management, hunk-level staging, interactive rebase,
    and stash management to your terminal — no memorizing flags required.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Terminal-native TUI</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Keyboard-driven interface</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Interactive rebase built-in</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Open source (MIT)</span>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">What is lazygit?</h2>
  <p class="text-text-muted mb-4 leading-relaxed">
    lazygit is an open-source terminal UI for Git written in Go by Jesse Duffield. It wraps Git operations in a split-pane keyboard-driven interface you can use without leaving your terminal. The five main panels — Status, Files, Branches, Commits, and Stash — let you navigate and execute Git operations with single-key commands.
  </p>
  <p class="text-text-muted mb-4 leading-relaxed">
    Unlike GUI applications, lazygit stays in the terminal, making it ideal for SSH sessions, remote servers, or developers who prefer a keyboard-centric workflow. It executes real Git commands under the hood (you can see them in a log panel), so it is fully compatible with any Git repository and workflow.
  </p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Key Features</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li><strong>Keyboard-driven TUI</strong> — every operation has a single-key shortcut, no mouse required</li>
    <li><strong>Visual diff viewer</strong> — syntax-highlighted diffs with side-by-side option</li>
    <li><strong>Hunk-level staging</strong> — stage or unstage individual diff hunks with 'space', not just whole files</li>
    <li><strong>Interactive rebase</strong> — squash, fixup, reword, drop, and reorder commits visually</li>
    <li><strong>Branch management</strong> — create, checkout, merge, delete, and track remote branches</li>
    <li><strong>Stash management</strong> — stash, pop, apply, and drop stashes from the stash panel</li>
    <li><strong>Undo/redo</strong> — lazygit tracks its own action history so you can undo operations with 'z'</li>
    <li><strong>Custom keybindings</strong> — configure shortcuts and run custom shell commands from within lazygit</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Installation</h2>
  <pre class="bg-bg-card border border-border rounded-xl p-4 text-xs font-mono overflow-x-auto whitespace-pre text-text mb-2" set:html={installExample}></pre>
  <p class="text-text-muted text-sm mb-4">Run <code class="bg-bg-card px-1 rounded">lazygit</code> in any Git repository to launch the UI.</p>

  <h2 class="text-xl font-semibold mt-8 mb-3">Essential Keybindings</h2>
  <div class="overflow-x-auto mb-6">
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-bg-card">
          <th class="border border-border px-3 py-2 text-left">Key</th>
          <th class="border border-border px-3 py-2 text-left">Action</th>
          <th class="border border-border px-3 py-2 text-left">Panel</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="border border-border px-3 py-2 font-mono">space</td><td class="border border-border px-3 py-2">Stage / unstage file or hunk</td><td class="border border-border px-3 py-2">Files</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2 font-mono">c</td><td class="border border-border px-3 py-2">Commit staged changes</td><td class="border border-border px-3 py-2">Files</td></tr>
        <tr><td class="border border-border px-3 py-2 font-mono">P</td><td class="border border-border px-3 py-2">Push to remote</td><td class="border border-border px-3 py-2">Any</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2 font-mono">p</td><td class="border border-border px-3 py-2">Pull from remote</td><td class="border border-border px-3 py-2">Any</td></tr>
        <tr><td class="border border-border px-3 py-2 font-mono">b</td><td class="border border-border px-3 py-2">Create new branch</td><td class="border border-border px-3 py-2">Branches</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2 font-mono">r</td><td class="border border-border px-3 py-2">Rebase current branch</td><td class="border border-border px-3 py-2">Branches</td></tr>
        <tr><td class="border border-border px-3 py-2 font-mono">i</td><td class="border border-border px-3 py-2">Interactive rebase</td><td class="border border-border px-3 py-2">Commits</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2 font-mono">z</td><td class="border border-border px-3 py-2">Undo last action</td><td class="border border-border px-3 py-2">Any</td></tr>
        <tr><td class="border border-border px-3 py-2 font-mono">s</td><td class="border border-border px-3 py-2">Stash changes</td><td class="border border-border px-3 py-2">Files</td></tr>
        <tr class="bg-bg-card/30"><td class="border border-border px-3 py-2 font-mono">e</td><td class="border border-border px-3 py-2">Open file in editor</td><td class="border border-border px-3 py-2">Files</td></tr>
        <tr><td class="border border-border px-3 py-2 font-mono">?</td><td class="border border-border px-3 py-2">Show keybinding help</td><td class="border border-border px-3 py-2">Any</td></tr>
      </tbody>
    </table>
  </div>

  <h2 class="text-xl font-semibold mt-8 mb-3">Use Cases</h2>
  <ul class="list-disc list-inside text-text-muted space-y-1 mb-4 ml-2">
    <li>Staging individual hunks for granular, atomic commits without leaving the terminal</li>
    <li>Interactive rebase to clean up a messy local branch before pushing</li>
    <li>Fast branch switching, merging, and remote tracking in a split-pane view</li>
    <li>Managing stashes when context-switching between tasks</li>
    <li>Reviewing commit history and diffs on remote servers over SSH</li>
    <li>Pairing with Neovim via lazygit.nvim for an all-terminal development environment</li>
  </ul>

  <h2 class="text-xl font-semibold mt-8 mb-3">Pros and Cons</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-green-400 mb-2">Pros</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✓ Works over SSH — no GUI required</li>
        <li>✓ Extremely fast for common Git operations</li>
        <li>✓ Hunk-level staging without complex git add -p</li>
        <li>✓ Undo stack for safety</li>
        <li>✓ Excellent Neovim and tmux integration</li>
        <li>✓ Free and open source</li>
      </ul>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <h3 class="font-semibold text-red-400 mb-2">Cons</h3>
      <ul class="text-text-muted text-sm space-y-1">
        <li>✗ Learning curve for the keybinding system</li>
        <li>✗ Terminal dependency — not ideal for non-terminal users</li>
        <li>✗ Weaker conflict resolution UI compared to GUI tools</li>
        <li>✗ Less polished history graph than GitKraken or Tower</li>
        <li>✗ Some advanced Git operations still require the CLI</li>
      </ul>
    </div>
  </div>

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="lazygit" relatedTags={['git', 'cli', 'devops', 'terminal', 'version-control']} />
</BaseLayout>
