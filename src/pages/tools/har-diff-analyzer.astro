---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HarDiffAnalyzer from '../../components/HarDiffAnalyzer.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is a HAR file and how do I export one?",
    answer: "HAR (HTTP Archive) is a JSON-format file that records every HTTP request and response made during a browser session, including headers, timing breakdowns, status codes, and body sizes. To export one from Chrome or Edge: open DevTools (F12), go to the Network tab, reproduce the flow you want to capture, then right-click any request and choose 'Save all as HAR with content'. In Firefox, click the gear icon in the Network panel and select 'Save All as HAR'.",
  },
  {
    question: "How does the diff work — what counts as the same request?",
    answer: "Requests are matched by HTTP method + URL path + query string, ignoring the host and protocol. This means a GET /api/users?page=2 in File A will be matched to the same path in File B even if the domain changed. If a URL appears multiple times in one file (e.g. polling), the first occurrence is used for comparison.",
  },
  {
    question: "What do the performance regression colors mean?",
    answer: "Red delta values mean the request got slower in File B compared to File A. Green delta values mean it got faster. Rows with a yellow background indicate a status code change (e.g. 200 → 404). The regression table is sorted by absolute timing delta, so the most impactful changes appear at the top.",
  },
  {
    question: "Is my HAR data uploaded to any server?",
    answer: "No — all parsing and diffing runs entirely in your browser using JavaScript. Your HAR files never leave your machine. This is important because HAR files often contain sensitive data such as authentication tokens, cookies, and API keys.",
  },
  {
    question: "What is a good delta threshold to consider a performance regression?",
    answer: "The 'Changed' tab filters to requests with a timing delta of ≥ 50 ms or a status code change, which is a practical starting point. For user-facing page loads, regressions above 100 ms are typically noticeable. For API calls on a critical path, even 20–30 ms differences can compound significantly under load. Use the 'Performance Regression' tab to see the full sorted list and decide your own threshold.",
  },
];
---

<BaseLayout
  title="HAR Diff Analyzer — Compare HTTP Archive Files Online"
  description="Upload two HAR files to diff HTTP requests side-by-side. Find new, removed, and changed requests. Spot performance regressions and status code changes (200→404) instantly. 100% browser-side, no data uploaded."
  tool="HAR Diff, HAR Compare, HTTP Archive Diff, Performance Regression Finder, HAR File Comparison"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "HAR Diff Analyzer",
    "description": "Compare two HAR files to find new, removed, and changed HTTP requests. Detect performance regressions and status code changes. Runs entirely in the browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  })} />

  <h1 class="text-3xl font-bold mb-2">HAR Diff Analyzer</h1>
  <p class="text-text-muted mb-4">Upload two <strong>.har files</strong> — a baseline (File A) and a comparison (File B) — to instantly diff every HTTP request. Find <strong>new and removed requests</strong>, detect <strong>performance regressions</strong>, and surface <strong>status code changes</strong> like 200&nbsp;→&nbsp;404. Everything runs in your browser — no data is ever uploaded.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Drag & drop two .har files</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Performance regression table with delta sorting</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Status code change highlighting</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> New / removed request detection</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 100% client-side, no data uploaded</span>
  </div>

  <HarDiffAnalyzer client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="HAR Diff Analyzer" relatedTags={['performance', 'network', 'debugging', 'api', 'http']} />
</BaseLayout>
