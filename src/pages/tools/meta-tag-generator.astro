---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MetaTagGenerator from '../../components/MetaTagGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What are Open Graph meta tags?",
    answer: "Open Graph (OG) tags are HTML meta tags that control how your page appears when shared on social media platforms like Facebook, LinkedIn, and Slack. They define the title, description, image, and URL shown in link previews."
  },
  {
    question: "What size should my OG image be?",
    answer: "The recommended OG image size is 1200×630 pixels (1.91:1 aspect ratio). This works across Facebook, LinkedIn, Twitter, and most messaging apps. Keep it under 1MB for fast loading."
  },
  {
    question: "What is the ideal meta description length?",
    answer: "Google typically displays 155–160 characters of a meta description. Aim for 70–160 characters — long enough to be descriptive but short enough to display in full. Descriptions over 160 characters get truncated."
  },
  {
    question: "What is Twitter Card and how does it differ from OG?",
    answer: "Twitter Card tags control how your content appears when shared on Twitter/X. While Twitter can read OG tags as fallback, Twitter-specific tags give you more control over the card type (summary vs large image) and Twitter-specific fields like site handle."
  },
  {
    question: "Do I need both OG and Twitter Card tags?",
    answer: "Best practice is to include both. Twitter reads OG tags as fallback, but explicit Twitter Card tags ensure correct rendering. Other platforms (LinkedIn, Slack, Discord) primarily read OG tags."
  },
];
---

<BaseLayout
  title="Meta Tag Generator — Free OG, Twitter Card & SEO Tag Generator"
  description="Generate complete meta tags for SEO, Open Graph, and Twitter Card with a live social preview. Copy all tags in one click. Free developer SEO tool, no signup."
  tool="Meta Tag Generator, Open Graph Generator, OG Tag Generator, Twitter Card Generator, SEO Meta Tags, Social Media Tags"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Meta Tag Generator</h1>
  <p class="text-text-muted mb-4">
    Generate SEO, Open Graph, and Twitter Card meta tags for your web pages. See a live social preview and copy all tags with one click.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> SEO + OG + Twitter Card</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Live preview</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> No sign-up required</span>
  </div>
  <MetaTagGenerator client:load />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Meta Tag Generator" relatedTags={['seo', 'html', 'frontend', 'developer-tools', 'social-media']} />
</BaseLayout>
