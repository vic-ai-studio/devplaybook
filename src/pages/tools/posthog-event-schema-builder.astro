---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostHogEventSchemaBuilder from '../../components/PostHogEventSchemaBuilder.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is PostHog and what is event tracking?",
    answer: "PostHog is an open-source product analytics platform. Event tracking means recording user actions — like button clicks, form submissions, or page views — as discrete named events with properties describing the context. These events let you understand how users interact with your product, funnel through flows, and what drives retention or churn."
  },
  {
    question: "What is the difference between event properties and person properties?",
    answer: "Event properties describe the specific action that happened — like which button was clicked, the plan selected, or the page visited. They're passed in the properties object of posthog.capture(). Person properties describe the user themselves — like their email, subscription plan, or signup date — and are set via posthog.identify(). Person properties persist across events and let you segment users."
  },
  {
    question: "What naming convention should I use for events?",
    answer: "PostHog recommends snake_case for event names (e.g. user_signed_up, checkout_started, feature_used). Use consistent noun-verb or verb-noun patterns across your codebase. Avoid spaces and special characters. Prefix events by area if you have many (e.g. auth_login_clicked, billing_plan_upgraded). Good naming makes autocomplete and search much faster as your event library grows."
  },
  {
    question: "How do I use this in a Next.js or React app?",
    answer: "Install posthog-js: npm install posthog-js. In your _app.tsx or layout.tsx, call posthog.init('YOUR_API_KEY', { api_host: 'https://app.posthog.com' }). Then anywhere in your components, import posthog and call posthog.capture('event_name', { ...properties }). Use the generated code from this tool directly — just replace the example values with real variables."
  },
  {
    question: "What is the distinctId in posthog.capture()?",
    answer: "The distinctId uniquely identifies the user or session. For logged-in users, use your internal user ID (e.g. user.id from your database). For anonymous users, PostHog auto-generates a UUID on init and stores it in localStorage. After a user logs in, call posthog.identify(userId) to link the anonymous events to the identified user — this is called alias merging."
  },
  {
    question: "Should I track events server-side or client-side?",
    answer: "Client-side tracking (browser JS) is easiest and captures the most detail, but ad blockers can interfere. Server-side tracking (Node.js or Python SDK) is more reliable and can't be blocked — it's better for critical events like purchases or sign-ups. Many teams use both: client-side for UI interactions, server-side for transactional events. The generated code covers both approaches."
  },
];
---

<BaseLayout
  title="PostHog Event Schema Builder — Generate Analytics Tracking Code"
  description="Build PostHog analytics event schema and generate tracking code. Define event names, properties with types, person properties, and get posthog.capture() code for JavaScript, Node.js, and Python. Free, runs in your browser."
  tool="posthog event tracking, posthog analytics setup, posthog capture generator, event schema builder"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "PostHog Event Schema Builder",
    "url": "https://devplaybook.cc/tools/posthog-event-schema-builder",
    "description": "Build PostHog analytics event tracking schema and generate posthog.capture() code for JavaScript, Node.js, and Python.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">PostHog Event Schema Builder</h1>
  <p class="text-text-muted mb-4">
    Design your <strong>PostHog analytics event schema</strong> visually. Define events with typed properties,
    add person properties for user segmentation, and generate ready-to-use
    <code class="font-mono bg-surface px-1 rounded text-sm">posthog.capture()</code> code for
    Browser JavaScript, Node.js, and Python — plus TypeScript interfaces.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Multi-event schema</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> JS / Node.js / Python</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript interfaces</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Person properties</span>
  </div>
  <PostHogEventSchemaBuilder client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="PostHog Event Schema Builder" relatedTags={['analytics', 'tracking', 'javascript', 'typescript', 'developer-tools']} />
</BaseLayout>
