---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LoadBalancerConfigGenerator from '../../components/LoadBalancerConfigGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  { question: "What is a load balancer?", answer: "A load balancer distributes incoming network traffic across multiple backend servers to improve availability, scalability, and fault tolerance. When one server fails or becomes overloaded, the load balancer routes traffic to healthy servers. Common examples include nginx, HAProxy, AWS ALB, and Cloudflare Load Balancing." },
  { question: "What is the difference between round-robin, least-conn, and ip-hash?", answer: "Round-robin distributes requests evenly in sequence across all backends — simple and predictable. Least-connections routes each new request to the backend with the fewest active connections — better for requests with variable processing time. IP-hash consistently routes the same client IP to the same backend, maintaining session affinity without shared session storage." },
  { question: "When should I use nginx vs HAProxy?", answer: "nginx is a full web server and reverse proxy with excellent static file serving, SSL termination, and HTTP/2 support. Use nginx when you also serve web content or need tight HTTP feature integration. HAProxy is a dedicated high-performance proxy with richer load balancing algorithms, better Layer 4 (TCP) support, and more detailed stats. Use HAProxy for pure load balancing in high-throughput TCP/HTTP scenarios." },
  { question: "What are health checks and why do they matter?", answer: "Health checks periodically probe each backend to verify it can handle requests. A backend that fails health checks is temporarily removed from the pool, preventing the load balancer from sending traffic to a broken server. Without health checks, the load balancer will send requests to down servers, resulting in errors for users. Always configure meaningful health check paths (e.g. /health or /ping) that verify the application layer, not just TCP connectivity." },
  { question: "How does SSL termination work at the load balancer?", answer: "With SSL termination, the load balancer decrypts HTTPS traffic and forwards plain HTTP to backends. This reduces CPU overhead on each backend, centralizes certificate management, and simplifies backend configuration. Traffic between the load balancer and backends travels on your private network unencrypted. If you need end-to-end encryption (for compliance), use SSL passthrough instead, where the load balancer forwards raw TLS to backends." },
  { question: "What timeout values should I use?", answer: "connect timeout (1-5s): how long to wait for a TCP connection to a backend. send timeout (30-60s): how long to wait to send a request. read timeout (30-60s): how long to wait for a response. For long-running operations (file uploads, AI requests), increase read timeout significantly (120-600s). For fast API responses, keep all timeouts tight (10-30s) to fail fast and free connections." },
];
---

<BaseLayout
  title="Load Balancer Config Generator — nginx & HAProxy"
  description="Generate nginx and HAProxy load balancer configurations visually. Add backend servers, choose LB algorithm (round-robin, least-conn, ip-hash), configure health checks, timeouts, and SSL termination. Copy-ready config. Free, runs in your browser."
  tool="Load Balancer Config Generator, nginx load balancer, HAProxy config, round-robin, least-connections, ip-hash, SSL termination, health checks"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Load Balancer Config Generator</h1>
  <p class="text-text-muted mb-4">Generate production-ready <strong>nginx</strong> or <strong>HAProxy</strong> load balancer configurations. Add backend servers, choose your LB algorithm, configure health checks and timeouts, and optionally enable SSL termination. Copy-ready output.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> nginx + HAProxy</span>
  </div>
  <LoadBalancerConfigGenerator client:only="preact" />
  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Load Balancer Config Generator" relatedTags={['nginx', 'haproxy', 'devops', 'infrastructure', 'networking', 'deployment']} />
</BaseLayout>
