---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ResumeBulletGenerator from '../../components/ResumeBulletGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Resume Bullet Generator — STAR Format for Software Engineers"
  description="Generate strong, quantified resume bullet points in STAR format for software engineering roles. Choose from 6 achievement templates — built, optimized, led, automated, and more. Free."
  tool="Resume Bullet Generator, Software Engineer Resume, STAR Format Resume, Tech Resume Bullet Points, Developer Resume Generator"
>
  <h1 class="text-3xl font-bold mb-2">Resume Bullet Generator</h1>
  <p class="text-text-muted mb-8">Generate strong, quantified resume bullet points for software engineering roles using the STAR format (Situation, Task, Action, Result). Pick a template, fill in your details, and copy the result.</p>
  <ResumeBulletGenerator client:only="preact" />
  <ToolPageCta currentTool="Resume Bullet Generator" relatedTags={['career', 'resume', 'job', 'interview']} />
</BaseLayout>
