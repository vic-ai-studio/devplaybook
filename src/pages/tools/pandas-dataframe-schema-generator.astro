---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PandasDataframeSchemaGenerator from '../../components/PandasDataframeSchemaGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What dtypes should I use in a pandas DataFrame?",
    answer: "Use int64 for whole numbers (IDs, counts, ages), float64 for decimals (prices, rates, probabilities), object for strings and mixed data, bool for True/False flags, datetime64[ns] for timestamps and dates, and category for low-cardinality string columns (status, country, gender). Using category instead of object for repeated strings can reduce memory usage by 50–90%."
  },
  {
    question: "Why does df.astype() matter for performance?",
    answer: "Pandas reads CSV files as the most permissive dtype by default — most columns become object (string). Explicitly casting to int64, float64, bool, or category reduces memory footprint, speeds up operations (especially groupby and merge), and prevents subtle bugs from mixed-type comparisons. A 1 million row DataFrame can shrink from 500MB to under 50MB with correct dtypes."
  },
  {
    question: "How do I parse datetime columns when loading CSV data?",
    answer: "Use pd.read_csv('file.csv', parse_dates=['created_at', 'updated_at']) to parse during load. Alternatively, use pd.to_datetime(df['created_at']) after loading. The datetime64[ns] dtype enables .dt accessor methods like .dt.year, .dt.month, .dt.dayofweek, and time-based filtering like df[df['date'] > '2024-01-01']."
  },
  {
    question: "What is a pandas schema validation and why use it?",
    answer: "Schema validation ensures your DataFrame has the expected shape and dtypes before processing. This catches data pipeline errors early — for example, a CSV with a changed column name or an unexpected None in an integer column. The assert statements generated by this tool act as lightweight runtime checks. For production pipelines, consider libraries like pandera or great_expectations for richer validation rules."
  },
];
---

<BaseLayout
  title="Pandas DataFrame Schema Generator — Generate dtype Code from CSV/JSON"
  description="Generate pandas DataFrame schema code from CSV headers or JSON samples. Set dtypes, get astype() calls, validation assertions, and schema definitions. Free, runs in browser."
  tool="pandas dataframe schema generator, pandas dtype, astype, pandas schema, csv to dataframe, json to dataframe"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Pandas DataFrame Schema Generator",
    "url": "https://devplaybook.cc/tools/pandas-dataframe-schema-generator",
    "description": "Generate pandas DataFrame schema code from CSV headers or JSON samples. Set dtypes, get astype() calls, validation assertions, and schema definitions.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">Pandas DataFrame Schema Generator</h1>
  <p class="text-text-muted mb-4">
    Paste <strong>CSV headers</strong> or a <strong>JSON sample</strong> to instantly generate pandas DataFrame schema code with proper dtypes, <code>astype()</code> calls, and validation assertions.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> CSV &amp; JSON input</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Auto dtype detection</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> astype() + assertions</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Schema dict output</span>
  </div>
  <PandasDataframeSchemaGenerator client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Pandas DataFrame Schema Generator" relatedTags={['python', 'pandas', 'data-science', 'ml', 'developer-tools']} />
</BaseLayout>
