---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "Which LLM is the best overall?", answer: "It depends on your use case. GPT-4o and Claude 3.5 Sonnet excel at reasoning and code. Gemini 1.5 Pro has the largest context window. For budget, Gemini Flash and Claude Haiku offer the best value. Llama 3 is ideal for self-hosted / private deployments." },
  { question: "What does context window mean?", answer: "The context window is the maximum amount of text (in tokens) an LLM can read at once — including your prompt, conversation history, and its response. 1,000 tokens ≈ 750 words. Larger windows allow processing full documents or long conversations." },
  { question: "Why are prices listed per million tokens?", answer: "LLM APIs charge per 1 million tokens processed. Input (what you send) and output (what the model generates) have separate rates. Output tokens are typically 3–5x more expensive than input tokens." },
  { question: "Are these prices up to date?", answer: "Prices shown are approximate as of Q1 2025 and change frequently. Always verify on the provider's official pricing page before budgeting: platform.openai.com/pricing, anthropic.com/pricing, ai.google.dev/pricing." },
  { question: "What is multimodal support?", answer: "Multimodal models can process images, audio, or video in addition to text. GPT-4o, Claude 3.5, and Gemini 1.5 Pro all support image inputs. Some models also support audio and video." },
];

const models = [
  {
    name: 'GPT-4o',
    provider: 'OpenAI',
    contextK: 128,
    inputPriceM: 5.00,
    outputPriceM: 15.00,
    strengths: ['Reasoning', 'Code', 'Multimodal'],
    multimodal: true,
    openSource: false,
    tier: 'frontier',
  },
  {
    name: 'GPT-4o Mini',
    provider: 'OpenAI',
    contextK: 128,
    inputPriceM: 0.15,
    outputPriceM: 0.60,
    strengths: ['Speed', 'Budget', 'Code'],
    multimodal: true,
    openSource: false,
    tier: 'budget',
  },
  {
    name: 'o1',
    provider: 'OpenAI',
    contextK: 200,
    inputPriceM: 15.00,
    outputPriceM: 60.00,
    strengths: ['Deep Reasoning', 'Math', 'Science'],
    multimodal: false,
    openSource: false,
    tier: 'reasoning',
  },
  {
    name: 'Claude 3.5 Sonnet',
    provider: 'Anthropic',
    contextK: 200,
    inputPriceM: 3.00,
    outputPriceM: 15.00,
    strengths: ['Code', 'Writing', 'Agents'],
    multimodal: true,
    openSource: false,
    tier: 'frontier',
  },
  {
    name: 'Claude 3.5 Haiku',
    provider: 'Anthropic',
    contextK: 200,
    inputPriceM: 0.80,
    outputPriceM: 4.00,
    strengths: ['Speed', 'Budget', 'Summarization'],
    multimodal: true,
    openSource: false,
    tier: 'budget',
  },
  {
    name: 'Claude 3 Opus',
    provider: 'Anthropic',
    contextK: 200,
    inputPriceM: 15.00,
    outputPriceM: 75.00,
    strengths: ['Complex Tasks', 'Writing', 'Analysis'],
    multimodal: true,
    openSource: false,
    tier: 'frontier',
  },
  {
    name: 'Gemini 1.5 Pro',
    provider: 'Google',
    contextK: 1000,
    inputPriceM: 3.50,
    outputPriceM: 10.50,
    strengths: ['Long Context', 'Multimodal', 'Documents'],
    multimodal: true,
    openSource: false,
    tier: 'frontier',
  },
  {
    name: 'Gemini 1.5 Flash',
    provider: 'Google',
    contextK: 1000,
    inputPriceM: 0.075,
    outputPriceM: 0.30,
    strengths: ['Speed', 'Budget', 'Long Context'],
    multimodal: true,
    openSource: false,
    tier: 'budget',
  },
  {
    name: 'Llama 3.3 70B',
    provider: 'Meta',
    contextK: 128,
    inputPriceM: 0.59,
    outputPriceM: 0.79,
    strengths: ['Open Source', 'Privacy', 'Code'],
    multimodal: false,
    openSource: true,
    tier: 'open-source',
  },
  {
    name: 'Llama 3.1 8B',
    provider: 'Meta',
    contextK: 128,
    inputPriceM: 0.10,
    outputPriceM: 0.10,
    strengths: ['Self-hosted', 'Budget', 'Fast'],
    multimodal: false,
    openSource: true,
    tier: 'open-source',
  },
];
---

<BaseLayout
  title="AI Model Comparator — GPT-4o vs Claude vs Gemini vs Llama"
  description="Compare top LLMs side by side: GPT-4o, Claude 3.5, Gemini 1.5, Llama 3, and more. Compare context window, pricing, strengths, and multimodal support. Free, no signup required."
  tool="AI Model Comparator, LLM Comparison Table, GPT-4o vs Claude, Gemini vs ChatGPT, LLM Pricing Chart"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">AI Model Comparator</h1>
  <p class="text-text-muted mb-6">Compare top LLMs by context window, pricing, and strengths. Filter by use case to find the right model for your project.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 10 models</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Filter by tier</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Prices as of Q1 2025</span>
  </div>

  <!-- Filter controls -->
  <div class="flex flex-wrap gap-2 mb-6">
    <button class="filter-btn active text-xs px-3 py-1.5 rounded-full border border-primary text-primary bg-primary/10 transition-all" data-filter="all">All Models</button>
    <button class="filter-btn text-xs px-3 py-1.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-filter="frontier">Frontier</button>
    <button class="filter-btn text-xs px-3 py-1.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-filter="budget">Budget</button>
    <button class="filter-btn text-xs px-3 py-1.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-filter="reasoning">Reasoning</button>
    <button class="filter-btn text-xs px-3 py-1.5 rounded-full border border-border text-text-muted hover:border-primary hover:text-primary transition-all" data-filter="open-source">Open Source</button>
  </div>

  <!-- Comparison table -->
  <div class="overflow-x-auto mb-8">
    <table class="w-full text-sm min-w-[640px]">
      <thead>
        <tr class="text-text-muted text-xs uppercase border-b border-border">
          <th class="text-left pb-3 pr-4 font-medium">Model</th>
          <th class="text-left pb-3 pr-4 font-medium">Provider</th>
          <th class="text-right pb-3 pr-4 font-medium">Context</th>
          <th class="text-right pb-3 pr-4 font-medium">Input /1M</th>
          <th class="text-right pb-3 pr-4 font-medium">Output /1M</th>
          <th class="text-left pb-3 pr-4 font-medium">Strengths</th>
          <th class="text-center pb-3 font-medium">Vision</th>
        </tr>
      </thead>
      <tbody id="model-table" class="divide-y divide-border">
        {models.map(m => (
          <tr class="model-row hover:bg-bg-card/50 transition-colors" data-tier={m.tier}>
            <td class="py-3 pr-4">
              <span class="font-semibold">{m.name}</span>
              {m.openSource && <span class="ml-2 text-xs px-1.5 py-0.5 bg-green-500/10 text-green-500 rounded">OSS</span>}
            </td>
            <td class="py-3 pr-4 text-text-muted">{m.provider}</td>
            <td class="py-3 pr-4 text-right tabular-nums font-medium">{m.contextK}K</td>
            <td class="py-3 pr-4 text-right tabular-nums">${m.inputPriceM.toFixed(m.inputPriceM < 1 ? 3 : 2)}</td>
            <td class="py-3 pr-4 text-right tabular-nums">${m.outputPriceM.toFixed(m.outputPriceM < 1 ? 3 : 2)}</td>
            <td class="py-3 pr-4">
              <div class="flex flex-wrap gap-1">
                {m.strengths.map(s => (
                  <span class="text-xs px-2 py-0.5 bg-bg-card border border-border rounded-full">{s}</span>
                ))}
              </div>
            </td>
            <td class="py-3 text-center">{m.multimodal ? <span class="text-green-500 font-bold">✓</span> : <span class="text-text-muted">—</span>}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Quick picks -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <p class="text-xs text-text-muted uppercase tracking-wide mb-2">Best Overall</p>
      <p class="font-bold text-primary mb-1">Claude 3.5 Sonnet</p>
      <p class="text-xs text-text-muted">Best coding, writing, and agent tasks at a reasonable price. Used by most production AI apps.</p>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <p class="text-xs text-text-muted uppercase tracking-wide mb-2">Best Budget</p>
      <p class="font-bold text-primary mb-1">Gemini 1.5 Flash</p>
      <p class="text-xs text-text-muted">$0.075/1M input tokens. Largest context window (1M). Ideal for high-volume, long-document tasks.</p>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <p class="text-xs text-text-muted uppercase tracking-wide mb-2">Best Reasoning</p>
      <p class="font-bold text-primary mb-1">o1</p>
      <p class="text-xs text-text-muted">Spends extra time reasoning before responding. Best for math, science, and multi-step logic problems.</p>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <p class="text-xs text-text-muted uppercase tracking-wide mb-2">Best Long Context</p>
      <p class="font-bold text-primary mb-1">Gemini 1.5 Pro</p>
      <p class="text-xs text-text-muted">1M token context window. Process entire codebases, books, or long videos in a single call.</p>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <p class="text-xs text-text-muted uppercase tracking-wide mb-2">Best Open Source</p>
      <p class="font-bold text-primary mb-1">Llama 3.3 70B</p>
      <p class="text-xs text-text-muted">Fully open, self-hostable. Competitive with GPT-4 class models. Available on Groq, Together AI, and locally.</p>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-4">
      <p class="text-xs text-text-muted uppercase tracking-wide mb-2">Best Speed</p>
      <p class="font-bold text-primary mb-1">GPT-4o Mini</p>
      <p class="text-xs text-text-muted">Ultra-fast with multimodal support at $0.15/1M. Great for real-time apps, chat, and classification tasks.</p>
    </div>
  </div>

  <p class="text-xs text-text-muted mb-8">Prices are approximate as of Q1 2025 and change frequently. Verify at each provider's official pricing page. Llama prices are indicative of cloud inference APIs (Together AI, Groq).</p>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="AI Model Comparator" relatedTags={['ai', 'llm', 'openai', 'claude', 'gemini', 'llama', 'comparison']} />
</BaseLayout>

<script>
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');
      document.querySelectorAll('.filter-btn').forEach(b => {
        b.classList.remove('active', 'border-primary', 'text-primary', 'bg-primary/10');
        b.classList.add('border-border', 'text-text-muted');
      });
      btn.classList.add('active', 'border-primary', 'text-primary', 'bg-primary/10');
      btn.classList.remove('border-border', 'text-text-muted');

      document.querySelectorAll('.model-row').forEach(row => {
        const tier = row.getAttribute('data-tier');
        if (filter === 'all' || tier === filter) {
          (row as HTMLElement).style.display = '';
        } else {
          (row as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
