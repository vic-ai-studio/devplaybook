---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is a discriminated union in TypeScript?", answer: "A discriminated union (also called a tagged union or algebraic data type) is a union type where each member has a common literal property called the discriminant. TypeScript uses this discriminant field to narrow the type in switch/if statements, giving you exhaustive type checking. They model finite sets of states cleanly — like UI states (loading/success/error) or action types in reducers." },
  { question: "When should I use discriminated unions vs optional properties?", answer: "Use discriminated unions when your data has mutually exclusive states — never allow a combination that makes no sense in your domain. For example, don't use { data?: T, error?: Error, loading?: boolean } — use a union with discriminant 'status': 'loading' | 'success' | 'error'. This prevents impossible states at the type level and forces exhaustive handling." },
  { question: "What is exhaustive checking with never?", answer: "By adding a default case that assigns the discriminant to 'never', TypeScript will emit a compile error if you forget to handle a union member. Pattern: default: const _exhaustive: never = state; throw new Error('Unhandled state'). When you add a new state to the union, TypeScript will tell you exactly which switch statements need updating." },
  { question: "How do discriminated unions work with switch statements?", answer: "TypeScript narrows the type inside each case block based on the discriminant value. If the discriminant is 'status' and the case is 'success', TypeScript knows the full shape including success-only fields. This means you get autocomplete, null-checking, and type errors when accessing fields that don't exist in that state — without any runtime overhead." },
  { question: "What is the difference between discriminated unions and class inheritance?", answer: "Discriminated unions are pure data structures — plain objects with a type discriminant. They're serializable, immutable-friendly, and work great with JSON. Class inheritance requires instantiation and is harder to serialize. In functional TypeScript (Redux, Zustand, React reducers), discriminated unions are preferred. For OOP patterns with methods and polymorphism, classes are more appropriate." },
];
---

<BaseLayout
  title="TypeScript Discriminated Union Builder — Visual Builder for Tagged Unions"
  description="Build TypeScript discriminated unions visually. Add variants with fields and get type-safe switch statements, type guards, and exhaustive checking code."
  tool="TypeScript discriminated union builder, tagged union, algebraic data type, TypeScript union types, switch exhaustive, type guard generator"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">TypeScript Discriminated Union Builder</h1>
  <p class="text-text-muted mb-4">Define union variants visually. Get type-safe TypeScript with switch statements, type guards, and exhaustive checking.</p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Visual variant builder</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Type guards</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Exhaustive switch</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Redux action patterns</span>
  </div>

  <div class="space-y-5">
    <!-- Union config -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <h2 class="font-semibold mb-4">Union Configuration</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label class="block text-sm text-text-muted mb-1" for="union-name">Union Type Name</label>
          <input id="union-name" type="text" value="ApiState" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
        </div>
        <div>
          <label class="block text-sm text-text-muted mb-1" for="discriminant-key">Discriminant Key</label>
          <input id="discriminant-key" type="text" value="status" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
        </div>
        <div>
          <label class="block text-sm text-text-muted mb-1" for="code-style">Code Style</label>
          <select id="code-style" class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/40">
            <option value="types" selected>Type aliases</option>
            <option value="interfaces">Interfaces</option>
          </select>
        </div>
      </div>

      <!-- Presets -->
      <div class="mt-4">
        <div class="text-xs text-text-muted mb-2 font-medium uppercase tracking-wide">Presets</div>
        <div class="flex flex-wrap gap-2">
          <button class="preset-btn px-3 py-1.5 text-xs rounded-lg bg-bg border border-border hover:border-primary hover:text-primary transition-colors" data-preset="async">Async State (loading/success/error)</button>
          <button class="preset-btn px-3 py-1.5 text-xs rounded-lg bg-bg border border-border hover:border-primary hover:text-primary transition-colors" data-preset="form">Form State (idle/submitting/submitted/error)</button>
          <button class="preset-btn px-3 py-1.5 text-xs rounded-lg bg-bg border border-border hover:border-primary hover:text-primary transition-colors" data-preset="redux">Redux Actions (fetch/update/delete)</button>
          <button class="preset-btn px-3 py-1.5 text-xs rounded-lg bg-bg border border-border hover:border-primary hover:text-primary transition-colors" data-preset="shape">Shape (circle/rectangle/triangle)</button>
        </div>
      </div>
    </div>

    <!-- Variants -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-semibold">Variants</h2>
        <button id="add-variant-btn" class="text-xs bg-primary/10 text-primary border border-primary/30 px-3 py-1.5 rounded-lg hover:bg-primary/20 transition-colors">+ Add Variant</button>
      </div>
      <div id="variants-list" class="space-y-4"></div>
    </div>

    <!-- Output tabs -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex flex-wrap gap-2 mb-4">
        <button class="tab-btn active px-4 py-2 text-sm rounded-lg bg-primary text-white font-medium" data-tab="types">Type Definitions</button>
        <button class="tab-btn px-4 py-2 text-sm rounded-lg bg-bg border border-border hover:border-primary hover:text-primary transition-colors" data-tab="guards">Type Guards</button>
        <button class="tab-btn px-4 py-2 text-sm rounded-lg bg-bg border border-border hover:border-primary hover:text-primary transition-colors" data-tab="switch">Switch Statement</button>
        <button class="tab-btn px-4 py-2 text-sm rounded-lg bg-bg border border-border hover:border-primary hover:text-primary transition-colors" data-tab="reducer">Reducer Pattern</button>
      </div>
      <div class="relative">
        <button id="copy-output-btn" class="absolute top-2 right-2 text-xs bg-bg-card border border-border px-2 py-1 rounded hover:border-primary hover:text-primary transition-colors z-10">Copy</button>
        <pre id="code-output" class="bg-bg rounded-lg p-4 text-xs font-mono overflow-x-auto text-green-400 whitespace-pre pt-8 max-h-[500px] overflow-y-auto"></pre>
      </div>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="TypeScript Discriminated Union Builder" relatedTags={['typescript', 'javascript', 'react', 'redux', 'types', 'patterns']} />
</BaseLayout>

<script is:inline>
(function () {
  var PRESETS = {
    async: {
      name: 'ApiState', disc: 'status',
      variants: [
        { label: 'idle', fields: [] },
        { label: 'loading', fields: [] },
        { label: 'success', fields: [{ name: 'data', type: 'T' }] },
        { label: 'error', fields: [{ name: 'message', type: 'string' }, { name: 'code', type: 'number' }] },
      ]
    },
    form: {
      name: 'FormState', disc: 'status',
      variants: [
        { label: 'idle', fields: [] },
        { label: 'submitting', fields: [] },
        { label: 'submitted', fields: [{ name: 'result', type: 'string' }] },
        { label: 'error', fields: [{ name: 'errors', type: 'Record<string, string>' }] },
      ]
    },
    redux: {
      name: 'UserAction', disc: 'type',
      variants: [
        { label: 'FETCH_USER', fields: [{ name: 'userId', type: 'string' }] },
        { label: 'UPDATE_USER', fields: [{ name: 'userId', type: 'string' }, { name: 'payload', type: 'Partial<User>' }] },
        { label: 'DELETE_USER', fields: [{ name: 'userId', type: 'string' }] },
        { label: 'FETCH_USER_SUCCESS', fields: [{ name: 'user', type: 'User' }] },
        { label: 'FETCH_USER_FAILURE', fields: [{ name: 'error', type: 'string' }] },
      ]
    },
    shape: {
      name: 'Shape', disc: 'kind',
      variants: [
        { label: 'circle', fields: [{ name: 'radius', type: 'number' }] },
        { label: 'rectangle', fields: [{ name: 'width', type: 'number' }, { name: 'height', type: 'number' }] },
        { label: 'triangle', fields: [{ name: 'base', type: 'number' }, { name: 'height', type: 'number' }] },
      ]
    }
  };

  var variants = [
    { label: 'loading', fields: [] },
    { label: 'success', fields: [{ name: 'data', type: 'unknown' }] },
    { label: 'error', fields: [{ name: 'message', type: 'string' }] },
  ];

  var currentTab = 'types';
  var variantsList = document.getElementById('variants-list');
  var codeOutput = document.getElementById('code-output');
  var copyOutputBtn = document.getElementById('copy-output-btn');

  function renderVariants() {
    variantsList.innerHTML = variants.map(function (v, i) {
      return '<div class="border border-border rounded-lg p-4 bg-bg">' +
        '<div class="flex items-center gap-3 mb-3">' +
        '<input class="variant-label bg-bg-card border border-border rounded px-2 py-1.5 text-sm font-mono font-bold focus:outline-none focus:ring-1 focus:ring-primary/40 w-40" data-idx="' + i + '" value="' + v.label + '" placeholder="variantName" />' +
        '<span class="text-text-muted text-xs">' + v.fields.length + ' field' + (v.fields.length !== 1 ? 's' : '') + '</span>' +
        '<button class="remove-variant ml-auto text-xs text-text-muted hover:text-red-400 transition-colors" data-idx="' + i + '">✕ Remove</button>' +
        '</div>' +
        '<div class="space-y-2" id="fields-' + i + '">' +
        v.fields.map(function (f, j) {
          return '<div class="flex items-center gap-2">' +
            '<input class="field-name w-32 bg-bg-card border border-border rounded px-2 py-1 text-xs font-mono focus:outline-none focus:ring-1 focus:ring-primary/40" data-vi="' + i + '" data-fi="' + j + '" value="' + f.name + '" placeholder="fieldName" />' +
            '<span class="text-text-muted text-xs">:</span>' +
            '<input class="field-type flex-1 bg-bg-card border border-border rounded px-2 py-1 text-xs font-mono focus:outline-none focus:ring-1 focus:ring-primary/40" data-vi="' + i + '" data-fi="' + j + '" value="' + f.type + '" placeholder="type" />' +
            '<button class="remove-field text-xs text-text-muted hover:text-red-400 ml-1" data-vi="' + i + '" data-fi="' + j + '">✕</button>' +
            '</div>';
        }).join('') +
        '</div>' +
        '<button class="add-field-btn mt-2 text-xs text-primary hover:underline" data-idx="' + i + '">+ Add field</button>' +
        '</div>';
    }).join('');

    variantsList.querySelectorAll('.variant-label').forEach(function (el) {
      el.addEventListener('input', function () { variants[+el.dataset.idx].label = el.value; updateOutput(); });
    });
    variantsList.querySelectorAll('.remove-variant').forEach(function (btn) {
      btn.addEventListener('click', function () { variants.splice(+btn.dataset.idx, 1); renderVariants(); updateOutput(); });
    });
    variantsList.querySelectorAll('.field-name').forEach(function (el) {
      el.addEventListener('input', function () { variants[+el.dataset.vi].fields[+el.dataset.fi].name = el.value; updateOutput(); });
    });
    variantsList.querySelectorAll('.field-type').forEach(function (el) {
      el.addEventListener('input', function () { variants[+el.dataset.vi].fields[+el.dataset.fi].type = el.value; updateOutput(); });
    });
    variantsList.querySelectorAll('.remove-field').forEach(function (btn) {
      btn.addEventListener('click', function () { variants[+btn.dataset.vi].fields.splice(+btn.dataset.fi, 1); renderVariants(); updateOutput(); });
    });
    variantsList.querySelectorAll('.add-field-btn').forEach(function (btn) {
      btn.addEventListener('click', function () { variants[+btn.dataset.idx].fields.push({ name: 'field', type: 'string' }); renderVariants(); updateOutput(); });
    });
  }

  function getConfig() {
    return {
      name: document.getElementById('union-name').value || 'MyUnion',
      disc: document.getElementById('discriminant-key').value || 'type',
      style: document.getElementById('code-style').value,
    };
  }

  function buildVariantName(cfg, label) {
    return cfg.name + '_' + label.charAt(0).toUpperCase() + label.slice(1).replace(/_([a-z])/g, function (_, c) { return c.toUpperCase(); });
  }

  function buildTypes() {
    var cfg = getConfig();
    var lines = [];
    var isInterface = cfg.style === 'interfaces';
    variants.forEach(function (v) {
      var vName = buildVariantName(cfg, v.label);
      if (isInterface) {
        lines.push('interface ' + vName + ' {');
        lines.push("  " + cfg.disc + ": '" + v.label + "';");
        v.fields.forEach(function (f) { lines.push('  ' + f.name + ': ' + f.type + ';'); });
        lines.push('}');
      } else {
        var parts = [cfg.disc + ": '" + v.label + "'"].concat(v.fields.map(function (f) { return f.name + ': ' + f.type; }));
        lines.push('type ' + vName + ' = { ' + parts.join('; ') + ' };');
      }
    });
    lines.push('');
    lines.push('type ' + cfg.name + ' =');
    variants.forEach(function (v, i) {
      lines.push('  | ' + buildVariantName(cfg, v.label) + (i < variants.length - 1 ? '' : ';'));
    });
    return lines.join('\n');
  }

  function buildGuards() {
    var cfg = getConfig();
    var lines = [buildTypes(), ''];
    variants.forEach(function (v) {
      var vName = buildVariantName(cfg, v.label);
      lines.push('function is' + vName + '(s: ' + cfg.name + '): s is ' + vName + ' {');
      lines.push("  return s." + cfg.disc + " === '" + v.label + "';");
      lines.push('}');
    });
    return lines.join('\n');
  }

  function buildSwitch() {
    var cfg = getConfig();
    var paramName = cfg.name.charAt(0).toLowerCase() + cfg.name.slice(1);
    var lines = [buildTypes(), '', 'function handle' + cfg.name + '(' + paramName + ': ' + cfg.name + '): void {', '  switch (' + paramName + '.' + cfg.disc + ') {'];
    variants.forEach(function (v) {
      lines.push("    case '" + v.label + "':");
      if (v.fields.length) {
        lines.push('      // Access: ' + v.fields.map(function (f) { return paramName + '.' + f.name; }).join(', '));
      }
      lines.push('      break;');
    });
    lines.push('    default:');
    lines.push('      const _exhaustive: never = ' + paramName + ';');
    lines.push("      throw new Error(`Unhandled state: ${(_exhaustive as any)." + cfg.disc + '}`);');
    lines.push('  }');
    lines.push('}');
    return lines.join('\n');
  }

  function buildReducer() {
    var cfg = getConfig();
    var stateName = cfg.name + 'State';
    var initialLabel = variants[0] ? variants[0].label : 'idle';
    var lines = [buildTypes(), '', 'type ' + stateName + ' = ' + cfg.name + ';', '',
      'const initial' + stateName + ': ' + stateName + ' = {', '  ' + cfg.disc + ": '" + initialLabel + "',", '};', '',
      'function ' + cfg.name.charAt(0).toLowerCase() + cfg.name.slice(1) + 'Reducer(', '  state: ' + stateName + ' = initial' + stateName + ',', '  action: Action', '): ' + stateName + ' {', '  switch (state.' + cfg.disc + ') {'];
    variants.forEach(function (v) {
      lines.push("    case '" + v.label + "':");
      lines.push('      return state; // handle actions for this state');
    });
    lines.push('    default:');
    lines.push('      const _exhaustive: never = state;');
    lines.push('      return _exhaustive;');
    lines.push('  }');
    lines.push('}');
    return lines.join('\n');
  }

  function updateOutput() {
    var generators = { types: buildTypes, guards: buildGuards, switch: buildSwitch, reducer: buildReducer };
    codeOutput.textContent = (generators[currentTab] || buildTypes)();
  }

  document.querySelectorAll('.tab-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      currentTab = btn.dataset.tab;
      document.querySelectorAll('.tab-btn').forEach(function (b) {
        b.className = 'tab-btn px-4 py-2 text-sm rounded-lg bg-bg border border-border hover:border-primary hover:text-primary transition-colors';
      });
      btn.className = 'tab-btn active px-4 py-2 text-sm rounded-lg bg-primary text-white font-medium';
      updateOutput();
    });
  });

  document.querySelectorAll('.preset-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var p = PRESETS[btn.dataset.preset];
      document.getElementById('union-name').value = p.name;
      document.getElementById('discriminant-key').value = p.disc;
      variants = p.variants.map(function (v) { return { label: v.label, fields: v.fields.map(function (f) { return Object.assign({}, f); }) }; });
      renderVariants();
      updateOutput();
    });
  });

  document.getElementById('add-variant-btn').addEventListener('click', function () {
    variants.push({ label: 'variant' + (variants.length + 1), fields: [] });
    renderVariants(); updateOutput();
  });

  ['union-name', 'discriminant-key', 'code-style'].forEach(function (id) {
    document.getElementById(id).addEventListener('input', updateOutput);
    document.getElementById(id).addEventListener('change', updateOutput);
  });

  copyOutputBtn.addEventListener('click', function () {
    navigator.clipboard.writeText(codeOutput.textContent).then(function () {
      copyOutputBtn.textContent = 'Copied!'; setTimeout(function () { copyOutputBtn.textContent = 'Copy'; }, 2000);
    });
  });

  renderVariants();
  updateOutput();
})();
</script>
