---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PasswordGenerator from '../../components/PasswordGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Password Generator — Secure Random Passwords Online"
  description="Generate strong, secure random passwords instantly. Control length, character sets, and symbols. Runs entirely in your browser — no passwords sent to any server."
  tool="Password Generator, Random Password, Secure Password"
>
  <h1 class="text-3xl font-bold mb-2">Password Generator</h1>
  <p class="text-text-muted mb-8">Generate cryptographically secure random passwords with custom length and character sets. Everything runs in your browser — nothing is ever sent to a server.</p>
  <PasswordGenerator client:only="preact" />
  <ToolPageCta currentTool="Password Generator" relatedTags={['security', 'password', 'random', 'generator']} />
</BaseLayout>
