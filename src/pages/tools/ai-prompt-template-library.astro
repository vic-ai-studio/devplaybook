---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AiPromptTemplateLibrary from '../../components/AiPromptTemplateLibrary.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  {
    question: "What is prompt engineering and why does it matter?",
    answer: "Prompt engineering is the practice of crafting inputs to AI language models to get consistently useful, accurate, and well-formatted outputs. A well-engineered prompt specifies the AI's role, the task, the expected output format, constraints, and examples. Without good prompts, AI responses are often generic, incomplete, or incorrectly formatted. With a good prompt, the same model can produce results that are dramatically more useful — studies show prompt quality accounts for 40-80% of output quality variance."
  },
  {
    question: "What are prompt variables and how do I use them?",
    answer: "Prompt variables (shown as {{variable_name}} in these templates) are placeholders you replace with specific values before sending the prompt. For example, {{language}} might be replaced with 'TypeScript', or {{code}} with the actual code you want reviewed. This template approach lets you reuse well-crafted prompts across different inputs without writing from scratch each time. Fill in the variable inputs above the preview panel and the final prompt updates in real time."
  },
  {
    question: "What is few-shot prompting?",
    answer: "Few-shot prompting means including 2-5 examples of the desired input-output pattern in your prompt before presenting the actual task. For example, showing the AI two examples of a bug report being converted to a GitHub issue format before asking it to convert a third. This technique dramatically improves output consistency and format adherence compared to zero-shot prompting (no examples). Many templates in this library include implicit few-shot structure in their format sections."
  },
  {
    question: "What is a system prompt and how is it different from a user prompt?",
    answer: "A system prompt is an instruction set given to an AI at the start of a conversation that defines its persona, capabilities, and behavioral constraints. It persists across the entire conversation. A user prompt is the individual message you send for each request. System prompts are ideal for: setting a consistent expert persona, enforcing output format, defining hard constraints (what the AI should never do), and establishing domain context. This library's 'AI System Prompt Builder' template helps you craft effective system prompts."
  },
  {
    question: "Does it matter which AI model I use these prompts with?",
    answer: "Yes, meaningfully so. Claude 3.5 Sonnet excels at nuanced reasoning, long-context tasks, code analysis, and following complex multi-step instructions — ideal for code review, architectural decisions, and system prompts. GPT-4o is strong for structured data extraction, JSON output, and tasks requiring strict format adherence. Gemini 1.5 Pro handles very long documents well. Each template in this library includes a model suggestion, but the prompts work across all major models — the suggestions are based on where each model tends to shine."
  },
  {
    question: "How do I adapt these templates for my specific use case?",
    answer: "Start by filling in the variables to match your context. Then customize the structure: add domain-specific requirements in the numbered list, change the output format to match your tools (e.g. change 'markdown' to 'JSON' if you need structured data), and add examples of good and bad outputs to guide the AI. For critical workflows, test your customized prompt with 5-10 diverse inputs to validate consistency before using it in production. The most effective prompts are iteratively refined based on actual outputs."
  },
];
---

<BaseLayout
  title="AI Prompt Template Library — Browse & Customize AI Prompts"
  description="Browse 30+ curated AI prompt templates for coding, writing, analysis, and more. Customize variables and copy ready-to-use prompts for ChatGPT, Claude, and Gemini. Free."
  tool="AI Prompt Templates, Prompt Engineering, ChatGPT Prompts, Claude Prompts, LLM Prompts, Developer Prompts, Code Review Prompt, Debugging Prompt"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">AI Prompt Template Library</h1>
  <p class="text-text-muted mb-4">
    Browse 30+ production-tested prompt templates for coding, writing, analysis, debugging, and more. Select a template, fill in the <code class="font-mono text-sm bg-surface px-1 rounded">{"{{variables}}"}</code>, and copy a ready-to-use prompt for ChatGPT, Claude, Gemini, or any LLM. No account required — runs entirely in your browser.
  </p>

  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 30+ curated templates</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Variable substitution</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 6 categories: Code, Writing, Analysis, Data, Debug, System</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Model suggestions included</span>
  </div>

  <AiPromptTemplateLibrary client:only="preact" />

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="AI Prompt Template Library" relatedTags={['ai', 'prompts', 'chatgpt', 'claude', 'llm', 'developer-tools']} />
</BaseLayout>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "AI Prompt Template Library",
  "description": "Browse 30+ curated AI prompt templates for coding, writing, analysis, and more. Customize variables and copy ready-to-use prompts for ChatGPT, Claude, and Gemini.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "url": "https://devplaybook.cc/tools/ai-prompt-template-library"
}
</script>
