---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OpenGraphPreview from '../../components/OpenGraphPreview.tsx';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout title="Open Graph Preview — Social Media Card Tester" description="Preview how your URLs appear when shared on social media. Edit og:title, og:image, og:description and see live previews for Twitter/X, Facebook, and Slack. Copy meta tags instantly." tool="Open Graph Preview, Social Media Preview, OG Tag Generator, Meta Tag Preview, Twitter Card Preview">
  <h1 class="text-3xl font-bold mb-2">Open Graph Preview</h1>
  <p class="text-text-muted mb-8">Preview how your page looks when shared on X/Twitter, Facebook, and Slack. Edit OG tags and copy them instantly.</p>
  <OpenGraphPreview client:load />
  <AffiliateSection category={['seo', 'marketing']} />
  <ToolPageCta currentTool="Open Graph Preview" relatedTags={['seo', 'frontend', 'meta', 'social']} />
</BaseLayout>
