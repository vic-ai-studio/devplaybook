---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is an S3 bucket policy?", answer: "An S3 bucket policy is a resource-based IAM policy attached directly to an S3 bucket. It controls who can access the bucket and what actions they can perform — without needing to configure per-user IAM roles. Use it for public read access, cross-account sharing, CloudFront OAI, and IP-based restrictions." },
  { question: "What is the difference between s3:GetObject and s3:ListBucket?", answer: "s3:GetObject allows downloading individual objects. s3:ListBucket allows listing the contents of the bucket. For a public static website you typically need both. They apply to different resources: ListBucket applies to the bucket ARN, GetObject applies to the bucket's objects (arn:aws:s3:::my-bucket/*)." },
  { question: "How do I restrict access to a specific IP range?", answer: "Add a condition with key aws:SourceIp and a list of CIDR blocks as the value. For example: {\"aws:SourceIp\": [\"203.0.113.0/24\", \"198.51.100.5/32\"]}. Use IpAddress to allow those IPs, or NotIpAddress with Effect: Deny to block everything else." },
  { question: "What is a CloudFront Origin Access Identity (OAI)?", answer: "An OAI is a special CloudFront identity that lets you restrict S3 bucket access so objects can only be served through CloudFront, not accessed directly. The policy allows s3:GetObject for the principal arn:aws:iam::cloudfront:user/CloudFront Origin Access Identity <OAI-ID>." },
  { question: "What is the Principal field?", answer: "Principal defines who the policy applies to. Use \"*\" for everyone (public). Use an AWS account ID for cross-account access. Use a specific IAM user, role, or service ARN for scoped access. The format is {\"AWS\": \"arn:aws:iam::account-id:role/role-name\"} or {\"Service\": \"cloudfront.amazonaws.com\"} for services." },
  { question: "Should I use Allow or Deny?", answer: "In most S3 bucket policies you use Effect: Allow with your intended principals and actions. Only add explicit Deny statements when you need to override an Allow — for example, to block HTTP (require HTTPS) or deny access from outside a VPC. An explicit Deny always wins over any Allow." },
];
---

<BaseLayout
  title="AWS S3 Bucket Policy Generator — Visual JSON Policy Builder"
  description="Free visual AWS S3 bucket policy generator. Select principal, actions, conditions (IP, MFA, SSL) and copy valid policy JSON. No sign-up required — runs in your browser."
  tool="AWS S3 bucket policy generator, S3 policy builder, S3 bucket permissions JSON, AWS S3 access control, S3 public read policy, cross-account S3 policy, CloudFront OAI policy"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">AWS S3 Bucket Policy Generator</h1>
  <p class="text-text-muted mb-4">Build AWS S3 bucket policy JSON visually. Choose a template or configure principal, actions, resource, and conditions manually — then copy the ready-to-use JSON for the AWS Console or Terraform.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 60K+ developers trust DevPlaybook</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Runs 100% in your browser</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Common templates included</span>
  </div>

  <div class="space-y-6">
    <!-- Templates -->
    <div class="bg-surface border border-border rounded-xl p-5">
      <h2 class="text-sm font-semibold mb-3 text-text-muted uppercase tracking-wide">Quick Templates</h2>
      <div class="flex flex-wrap gap-2">
        <button class="s3-tpl px-3 py-1.5 rounded-lg text-sm border border-border bg-background hover:border-accent transition-colors" data-tpl="public-read">Public Read</button>
        <button class="s3-tpl px-3 py-1.5 rounded-lg text-sm border border-border bg-background hover:border-accent transition-colors" data-tpl="cross-account">Cross-Account Access</button>
        <button class="s3-tpl px-3 py-1.5 rounded-lg text-sm border border-border bg-background hover:border-accent transition-colors" data-tpl="cloudfront-oai">CloudFront OAI</button>
        <button class="s3-tpl px-3 py-1.5 rounded-lg text-sm border border-border bg-background hover:border-accent transition-colors" data-tpl="deny-http">Deny HTTP (force HTTPS)</button>
        <button class="s3-tpl px-3 py-1.5 rounded-lg text-sm border border-border bg-background hover:border-accent transition-colors" data-tpl="ip-restrict">IP Restriction</button>
      </div>
    </div>

    <!-- Builder -->
    <div class="bg-surface border border-border rounded-xl p-5 space-y-5">
      <h2 class="text-sm font-semibold mb-1 text-text-muted uppercase tracking-wide">Policy Builder</h2>

      <!-- Bucket Name -->
      <div>
        <label for="s3-bucket" class="block text-sm font-medium mb-1.5">Bucket Name</label>
        <input id="s3-bucket" type="text" placeholder="my-bucket-name" value="my-bucket-name"
          class="w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent" />
      </div>

      <!-- Effect -->
      <div>
        <label class="block text-sm font-medium mb-2">Effect</label>
        <div class="flex gap-4">
          <label class="flex items-center gap-2 cursor-pointer text-sm">
            <input type="radio" name="s3-effect" value="Allow" checked class="accent-accent" /> Allow
          </label>
          <label class="flex items-center gap-2 cursor-pointer text-sm">
            <input type="radio" name="s3-effect" value="Deny" class="accent-accent" /> Deny
          </label>
        </div>
      </div>

      <!-- Principal -->
      <div>
        <label class="block text-sm font-medium mb-2">Principal</label>
        <select id="s3-principal-type" class="w-full mb-2 bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent">
          <option value="everyone">Everyone (*)</option>
          <option value="aws-account">AWS Account</option>
          <option value="iam-role">IAM Role ARN</option>
          <option value="iam-user">IAM User ARN</option>
          <option value="cloudfront">CloudFront Service</option>
          <option value="custom">Custom ARN</option>
        </select>
        <input id="s3-principal-value" type="text" placeholder="123456789012"
          class="hidden w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent" />
      </div>

      <!-- Actions -->
      <div>
        <label class="block text-sm font-medium mb-2">Actions</label>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-2" id="s3-actions">
          <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" value="s3:GetObject" checked class="accent-accent" /> s3:GetObject</label>
          <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" value="s3:PutObject" class="accent-accent" /> s3:PutObject</label>
          <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" value="s3:DeleteObject" class="accent-accent" /> s3:DeleteObject</label>
          <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" value="s3:ListBucket" class="accent-accent" /> s3:ListBucket</label>
          <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" value="s3:GetBucketLocation" class="accent-accent" /> s3:GetBucketLocation</label>
          <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" value="s3:*" class="accent-accent" /> s3:* (all)</label>
        </div>
      </div>

      <!-- Resource Scope -->
      <div>
        <label class="block text-sm font-medium mb-2">Resource Scope</label>
        <div class="flex flex-col gap-2">
          <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" id="s3-res-bucket" checked class="accent-accent" /> Bucket (<code class="text-xs bg-background px-1 rounded">arn:aws:s3:::bucket-name</code>)</label>
          <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" id="s3-res-objects" checked class="accent-accent" /> Objects (<code class="text-xs bg-background px-1 rounded">arn:aws:s3:::bucket-name/*</code>)</label>
          <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" id="s3-res-prefix" class="accent-accent" /> Prefix filter</label>
          <input id="s3-prefix-val" type="text" placeholder="uploads/*" class="hidden w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent" />
        </div>
      </div>

      <!-- Conditions -->
      <div>
        <label class="block text-sm font-medium mb-2">Conditions (optional)</label>
        <div class="space-y-2">
          <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" id="cond-ssl" class="accent-accent" /> Require SSL (deny HTTP)</label>
          <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" id="cond-mfa" class="accent-accent" /> Require MFA</label>
          <label class="flex items-center gap-2 text-sm cursor-pointer"><input type="checkbox" id="cond-ip" class="accent-accent" /> IP Range restriction</label>
          <input id="cond-ip-val" type="text" placeholder="203.0.113.0/24, 198.51.100.5/32" class="hidden w-full bg-background border border-border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-accent" />
        </div>
      </div>

      <button id="s3-generate" class="bg-accent hover:bg-accent/80 text-white font-medium px-5 py-2 rounded-lg text-sm transition-colors">
        Generate Policy JSON
      </button>
    </div>

    <!-- Output -->
    <div id="s3-output-area" class="bg-surface border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <label class="text-sm font-medium">Policy JSON</label>
        <button id="s3-copy" class="text-xs bg-background border border-border hover:bg-accent/20 px-3 py-1 rounded-lg transition-colors">Copy</button>
      </div>
      <pre id="s3-output" class="bg-background border border-border rounded-lg px-4 py-3 text-xs font-mono overflow-x-auto whitespace-pre leading-relaxed"></pre>
      <p class="text-xs text-text-muted mt-2">Paste this into the S3 bucket policy editor in the AWS Console, or use <code class="bg-background px-1 rounded">aws s3api put-bucket-policy</code>.</p>
    </div>
  </div>

  <FaqSection faq={faq} />
  <ToolPageCta currentTool="AWS S3 Bucket Policy Generator" relatedTags={['aws', 'cloud', 'devops', 'security', 'infrastructure', 's3']} />
</BaseLayout>

<script>
(function () {
  const TEMPLATES = {
    'public-read': {
      effect: 'Allow', principalType: 'everyone', principalValue: '',
      actions: ['s3:GetObject'], resBucket: false, resObjects: true, resPrefix: false, prefixVal: '',
      ssl: false, mfa: false, ip: false, ipVal: ''
    },
    'cross-account': {
      effect: 'Allow', principalType: 'aws-account', principalValue: '123456789012',
      actions: ['s3:GetObject', 's3:ListBucket'], resBucket: true, resObjects: true, resPrefix: false, prefixVal: '',
      ssl: false, mfa: false, ip: false, ipVal: ''
    },
    'cloudfront-oai': {
      effect: 'Allow', principalType: 'cloudfront', principalValue: 'E1234567890123',
      actions: ['s3:GetObject'], resBucket: false, resObjects: true, resPrefix: false, prefixVal: '',
      ssl: false, mfa: false, ip: false, ipVal: ''
    },
    'deny-http': {
      effect: 'Deny', principalType: 'everyone', principalValue: '',
      actions: ['s3:*'], resBucket: true, resObjects: true, resPrefix: false, prefixVal: '',
      ssl: true, mfa: false, ip: false, ipVal: ''
    },
    'ip-restrict': {
      effect: 'Deny', principalType: 'everyone', principalValue: '',
      actions: ['s3:*'], resBucket: true, resObjects: true, resPrefix: false, prefixVal: '',
      ssl: false, mfa: false, ip: true, ipVal: '203.0.113.0/24'
    }
  };

  function applyTemplate(name) {
    const t = TEMPLATES[name];
    document.querySelector(`input[name="s3-effect"][value="${t.effect}"]`).checked = true;
    const ptSel = document.getElementById('s3-principal-type');
    ptSel.value = t.principalType;
    handlePrincipalType();
    const pvInput = document.getElementById('s3-principal-value');
    if (t.principalValue) pvInput.value = t.principalValue;

    document.querySelectorAll('#s3-actions input[type=checkbox]').forEach(cb => {
      cb.checked = t.actions.includes(cb.value);
    });

    document.getElementById('s3-res-bucket').checked = t.resBucket;
    document.getElementById('s3-res-objects').checked = t.resObjects;
    document.getElementById('s3-res-prefix').checked = t.resPrefix;
    document.getElementById('s3-prefix-val').classList.toggle('hidden', !t.resPrefix);
    if (t.prefixVal) document.getElementById('s3-prefix-val').value = t.prefixVal;

    document.getElementById('cond-ssl').checked = t.ssl;
    document.getElementById('cond-mfa').checked = t.mfa;
    const ipCb = document.getElementById('cond-ip');
    ipCb.checked = t.ip;
    document.getElementById('cond-ip-val').classList.toggle('hidden', !t.ip);
    if (t.ipVal) document.getElementById('cond-ip-val').value = t.ipVal;

    buildPolicy();
  }

  function handlePrincipalType() {
    const type = document.getElementById('s3-principal-type').value;
    const inp = document.getElementById('s3-principal-value');
    const hidden = ['everyone'].includes(type);
    inp.classList.toggle('hidden', hidden);
    if (type === 'aws-account') inp.placeholder = '123456789012';
    else if (type === 'iam-role') inp.placeholder = 'arn:aws:iam::123456789012:role/MyRole';
    else if (type === 'iam-user') inp.placeholder = 'arn:aws:iam::123456789012:user/john';
    else if (type === 'cloudfront') inp.placeholder = 'E1234567890123 (OAI ID)';
    else inp.placeholder = 'arn:aws:iam::...';
  }

  function buildPolicy() {
    const bucket = document.getElementById('s3-bucket').value.trim() || 'my-bucket-name';
    const effect = document.querySelector('input[name="s3-effect"]:checked').value;
    const pType = document.getElementById('s3-principal-type').value;
    const pVal = document.getElementById('s3-principal-value').value.trim();

    let principal;
    if (pType === 'everyone') {
      principal = '*';
    } else if (pType === 'aws-account') {
      principal = { AWS: `arn:aws:iam::${pVal || '123456789012'}:root` };
    } else if (pType === 'cloudfront') {
      principal = { Service: 'cloudfront.amazonaws.com' };
    } else {
      principal = { AWS: pVal || 'arn:aws:iam::ACCOUNT_ID:role/ROLE_NAME' };
    }

    const actions = Array.from(document.querySelectorAll('#s3-actions input[type=checkbox]:checked')).map(cb => cb.value);
    if (actions.length === 0) actions.push('s3:GetObject');

    const resources = [];
    if (document.getElementById('s3-res-bucket').checked) resources.push(`arn:aws:s3:::${bucket}`);
    if (document.getElementById('s3-res-objects').checked) resources.push(`arn:aws:s3:::${bucket}/*`);
    if (document.getElementById('s3-res-prefix').checked) {
      const prefix = document.getElementById('s3-prefix-val').value.trim() || 'prefix/*';
      resources.push(`arn:aws:s3:::${bucket}/${prefix}`);
    }
    if (resources.length === 0) resources.push(`arn:aws:s3:::${bucket}/*`);

    const statement = {
      Sid: 'GeneratedByDevPlaybook',
      Effect: effect,
      Principal: principal,
      Action: actions.length === 1 ? actions[0] : actions,
      Resource: resources.length === 1 ? resources[0] : resources
    };

    const conditions = {};
    if (document.getElementById('cond-ssl').checked) {
      conditions['Bool'] = { 'aws:SecureTransport': 'false' };
    }
    if (document.getElementById('cond-mfa').checked) {
      conditions['Bool'] = Object.assign(conditions['Bool'] || {}, { 'aws:MultiFactorAuthPresent': 'true' });
    }
    if (document.getElementById('cond-ip').checked) {
      const ipRaw = document.getElementById('cond-ip-val').value;
      const ips = ipRaw.split(',').map(s => s.trim()).filter(Boolean);
      if (ips.length > 0) {
        conditions['NotIpAddress'] = { 'aws:SourceIp': ips };
      }
    }
    if (Object.keys(conditions).length > 0) statement.Condition = conditions;

    const policy = {
      Version: '2012-10-17',
      Statement: [statement]
    };

    document.getElementById('s3-output').textContent = JSON.stringify(policy, null, 2);
  }

  // Wire events
  document.querySelectorAll('.s3-tpl').forEach(btn => {
    btn.addEventListener('click', () => applyTemplate(btn.dataset.tpl));
  });
  document.getElementById('s3-principal-type').addEventListener('change', () => { handlePrincipalType(); buildPolicy(); });
  document.getElementById('s3-generate').addEventListener('click', buildPolicy);

  // Prefix toggle
  document.getElementById('s3-res-prefix').addEventListener('change', function() {
    document.getElementById('s3-prefix-val').classList.toggle('hidden', !this.checked);
    buildPolicy();
  });

  // IP condition toggle
  document.getElementById('cond-ip').addEventListener('change', function() {
    document.getElementById('cond-ip-val').classList.toggle('hidden', !this.checked);
    buildPolicy();
  });

  // Copy
  document.getElementById('s3-copy').addEventListener('click', () => {
    const text = document.getElementById('s3-output').textContent;
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById('s3-copy');
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 1500);
    });
  });

  // Initial build
  buildPolicy();
})();
</script>
