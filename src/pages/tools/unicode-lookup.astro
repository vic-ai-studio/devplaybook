---
import BaseLayout from '../../layouts/BaseLayout.astro';
import UnicodeLookup from '../../components/UnicodeLookup.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="Unicode Character Lookup"
  description="Look up Unicode characters by code point, name, or search. Get UTF-8 bytes, UTF-16, HTML entity, CSS escape, and JS escape for any character. Free, runs in browser."
  tool="Unicode Lookup, Unicode Character, UTF-8, HTML Entity, Code Point"
>
  <h1 class="text-3xl font-bold mb-2">Unicode Character Lookup</h1>
  <p class="text-text-muted mb-8">Look up any Unicode character by typing it, entering a code point (U+2665), decimal, or HTML entity. Get UTF-8 bytes, UTF-16 encoding, HTML entities, CSS and JS escape sequences.</p>
  <UnicodeLookup client:load />
  <ToolPageCta currentTool="Unicode Character Lookup" relatedTags={['text', 'encoding', 'web', 'unicode']} />
</BaseLayout>
