---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
---

<BaseLayout
  title="jq Playground — Test & Build jq Expressions Online"
  description="Interactive jq playground. Write jq expressions, test them against JSON, and see results instantly. Includes common jq snippets and syntax reference. Free browser-based jq tester."
  tool="jq Playground, jq Online, jq Tester, jq Expression Builder, JSON Filter, jq Cheatsheet, jq Formatter"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "jq Playground",
    "url": "https://devplaybook.cc/tools/jq-playground",
    "description": "Test jq expressions against JSON data interactively in the browser.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">jq Playground</h1>
  <p class="text-text-muted mb-2">
    Test <code class="font-mono bg-surface px-1 rounded">jq</code> expressions against JSON data in real time.
    Explore common snippets, build filters, and copy the ready-to-use command for your terminal.
  </p>
  <p class="text-xs text-text-muted mb-8 flex items-center gap-2">
    <span class="text-yellow-500">⚠</span>
    This playground simulates common jq operations in JavaScript. For full jq spec, run
    <code class="font-mono bg-surface px-1 rounded">jq</code> locally.
    <a href="https://jqlang.github.io/jq/download/" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">Install jq →</a>
  </p>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
    <!-- Left panel -->
    <div class="space-y-4">
      <!-- Filter -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <label class="block font-semibold text-sm uppercase tracking-wide text-text-muted mb-2" for="jq-filter">jq Filter</label>
        <div class="flex gap-2">
          <input id="jq-filter" type="text" value="." placeholder=".users[] | .name"
            class="flex-1 bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40" />
          <button id="run-btn" class="bg-primary text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-primary/80 transition-colors">Run</button>
        </div>
        <p class="text-xs text-text-muted mt-2">Press <kbd class="bg-bg border border-border px-1.5 py-0.5 rounded text-xs">Ctrl+Enter</kbd> to run</p>
      </div>

      <!-- JSON Input -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-2">
          <label class="font-semibold text-sm uppercase tracking-wide text-text-muted" for="json-input">JSON Input</label>
          <div class="flex gap-2">
            <button id="fmt-btn" class="text-xs text-primary hover:underline">Format</button>
            <button id="clear-btn" class="text-xs text-text-muted hover:text-red-400">Clear</button>
          </div>
        </div>
        <textarea id="json-input" rows="14" spellcheck="false"
          class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40 resize-none"
        >{
  "users": [
    { "id": 1, "name": "Alice", "role": "admin", "active": true },
    { "id": 2, "name": "Bob", "role": "user", "active": false },
    { "id": 3, "name": "Carol", "role": "user", "active": true }
  ],
  "meta": { "total": 3, "page": 1 }
}</textarea>
        <div id="json-error" class="text-xs text-red-400 mt-1 hidden"></div>
      </div>
    </div>

    <!-- Right panel -->
    <div class="space-y-4">
      <!-- Output -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-2">
          <label class="font-semibold text-sm uppercase tracking-wide text-text-muted">Output</label>
          <button id="copy-output" class="text-xs bg-primary text-white px-3 py-1.5 rounded-lg hover:bg-primary/80 transition-colors">Copy</button>
        </div>
        <pre id="jq-output" class="bg-bg border border-border rounded-lg p-4 text-sm font-mono whitespace-pre-wrap min-h-[200px] text-green-400 overflow-auto max-h-[320px]">Run a filter to see output</pre>
        <div class="mt-3 p-3 bg-bg border border-border rounded-lg">
          <p class="text-xs text-text-muted mb-1">Terminal command:</p>
          <pre id="terminal-cmd" class="text-xs font-mono text-blue-400 whitespace-pre-wrap break-all">echo '...' | jq '.'</pre>
          <button id="copy-cmd" class="text-xs text-primary hover:underline mt-1">Copy command</button>
        </div>
      </div>

      <!-- Snippets -->
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted mb-3">Common Snippets</h2>
        <div class="grid grid-cols-1 gap-1.5" id="snippets-list"></div>
      </div>
    </div>
  </div>

  <!-- Reference -->
  <div class="mt-5 bg-bg-card border border-border rounded-xl p-5">
    <h2 class="font-semibold text-sm uppercase tracking-wide text-text-muted mb-3">Quick Reference</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {[
        { expr: '.', desc: 'Identity — pretty-print whole input' },
        { expr: '.key', desc: 'Get object field' },
        { expr: '.key.nested', desc: 'Get nested field' },
        { expr: '.key?', desc: 'Optional field (no error if missing)' },
        { expr: '.[]', desc: 'Iterate array or object values' },
        { expr: '.[0]', desc: 'First array element' },
        { expr: '.[-1]', desc: 'Last array element' },
        { expr: '.[2:5]', desc: 'Array slice (index 2–4)' },
        { expr: 'keys', desc: 'Get object keys as array' },
        { expr: 'values', desc: 'Get object values as array' },
        { expr: 'length', desc: 'Length of array/string/object' },
        { expr: 'type', desc: 'Type of value' },
        { expr: 'has("key")', desc: 'Check if key exists' },
        { expr: 'select(cond)', desc: 'Filter items by condition' },
        { expr: 'map(.field)', desc: 'Map: transform each element' },
        { expr: 'map(select(.active))', desc: 'Filter array by field' },
        { expr: '[.[] | .name]', desc: 'Collect results into array' },
        { expr: 'add', desc: 'Sum numbers or concat arrays/strings' },
        { expr: 'unique', desc: 'Remove duplicate values' },
        { expr: 'group_by(.field)', desc: 'Group array by field value' },
        { expr: 'sort_by(.field)', desc: 'Sort array by field' },
        { expr: 'to_entries', desc: 'Object → [{key,value}] array' },
        { expr: 'from_entries', desc: '[{key,value}] → object' },
        { expr: 'with_entries(.value += 1)', desc: 'Transform object entries' },
        { expr: '. + { "k": "v" }', desc: 'Merge/add field to object' },
        { expr: 'del(.key)', desc: 'Delete a key from object' },
        { expr: 'empty', desc: 'Produce no output (filter all)' },
        { expr: 'env', desc: 'All environment variables' },
        { expr: 'ascii_downcase', desc: 'Lowercase string' },
        { expr: 'split(",")', desc: 'Split string into array' },
      ].map(r => (
        <div class="flex items-start gap-2 text-xs">
          <code class="font-mono text-primary bg-bg px-1.5 py-0.5 rounded shrink-0">{r.expr}</code>
          <span class="text-text-muted">{r.desc}</span>
        </div>
      ))}
    </div>
  </div>

  <ToolPageCta currentTool="jq Playground" relatedTags={['json', 'cli', 'data', 'devops', 'terminal']} />
</BaseLayout>

<script is:inline>
(function () {
  const SNIPPETS = [
    { label: 'Pretty print', filter: '.' },
    { label: 'Get all users', filter: '.users[]' },
    { label: 'Extract names', filter: '[.users[] | .name]' },
    { label: 'Filter active users', filter: '[.users[] | select(.active)]' },
    { label: 'Get active user names', filter: '[.users[] | select(.active) | .name]' },
    { label: 'Count users', filter: '.users | length' },
    { label: 'Get admin users', filter: '[.users[] | select(.role == "admin")]' },
    { label: 'First user', filter: '.users[0]' },
    { label: 'Keys of root object', filter: 'keys' },
    { label: 'Meta total', filter: '.meta.total' },
    { label: 'Sort by name', filter: '[.users[] | .] | sort_by(.name)' },
    { label: 'User IDs as array', filter: '[.users[] | .id]' },
  ];

  function el(id) { return document.getElementById(id); }

  // Render snippets
  const snippetsList = el('snippets-list');
  SNIPPETS.forEach(s => {
    const btn = document.createElement('button');
    btn.className = 'text-left flex items-center gap-2 p-2 rounded-lg hover:bg-bg transition-colors group';
    btn.innerHTML = `
      <code class="font-mono text-xs text-primary bg-bg group-hover:bg-bg-card px-1.5 py-0.5 rounded transition-colors shrink-0">${s.filter}</code>
      <span class="text-xs text-text-muted truncate">${s.label}</span>`;
    btn.addEventListener('click', () => {
      el('jq-filter').value = s.filter;
      runFilter();
    });
    snippetsList.appendChild(btn);
  });

  // Minimal jq simulator (common operations in JS)
  function applyJq(data, filter) {
    filter = filter.trim();

    // Identity
    if (filter === '.') return [data];

    // Keys / values / type / length / add / unique / empty
    if (filter === 'keys') return [Object.keys(data).sort()];
    if (filter === 'values') return [Object.values(data)];
    if (filter === 'type') {
      const t = Array.isArray(data) ? 'array' : typeof data;
      return [t === 'object' && data === null ? 'null' : t];
    }
    if (filter === 'length') {
      if (Array.isArray(data)) return [data.length];
      if (typeof data === 'string') return [data.length];
      if (data && typeof data === 'object') return [Object.keys(data).length];
      return [0];
    }
    if (filter === 'add') {
      if (Array.isArray(data)) {
        if (data.length === 0) return [null];
        return [data.reduce((a, b) => {
          if (Array.isArray(a) && Array.isArray(b)) return [...a, ...b];
          return a + b;
        })];
      }
    }
    if (filter === 'unique') return [[...new Set(Array.isArray(data) ? data : [])]];
    if (filter === 'empty') return [];
    if (filter === 'to_entries') {
      if (data && typeof data === 'object' && !Array.isArray(data))
        return [Object.entries(data).map(([k, v]) => ({ key: k, value: v }))];
    }
    if (filter === 'from_entries') {
      if (Array.isArray(data)) {
        const obj = {};
        data.forEach(e => { if (e.key !== undefined) obj[e.key] = e.value; });
        return [obj];
      }
    }
    if (filter === 'env') return [{}]; // not supported in browser

    // ascii_downcase / ascii_upcase
    if (filter === 'ascii_downcase' && typeof data === 'string') return [data.toLowerCase()];
    if (filter === 'ascii_upcase' && typeof data === 'string') return [data.toUpperCase()];

    // Iterate: .[]
    if (filter === '.[]') {
      if (Array.isArray(data)) return data;
      if (data && typeof data === 'object') return Object.values(data);
      return [data];
    }

    // Field access: .key or .key.nested or .key?
    const fieldMatch = filter.match(/^\.([a-zA-Z_][a-zA-Z0-9_]*)(\??)((?:\.[a-zA-Z_][a-zA-Z0-9_]*\??)*)$/);
    if (fieldMatch) {
      let val = data;
      const parts = [fieldMatch[1], ...fieldMatch[3].split('.').filter(Boolean)];
      for (const p of parts) {
        const key = p.replace(/\?$/, '');
        if (val && typeof val === 'object') val = val[key];
        else { val = null; break; }
      }
      return val === undefined ? [null] : [val];
    }

    // Array index: .[N] or .[-N]
    const idxMatch = filter.match(/^\.\[(-?\d+)\]$/);
    if (idxMatch) {
      const n = parseInt(idxMatch[1]);
      if (Array.isArray(data)) {
        const i = n < 0 ? data.length + n : n;
        return i >= 0 && i < data.length ? [data[i]] : [null];
      }
    }

    // Array slice: .[N:M]
    const sliceMatch = filter.match(/^\.\[(-?\d*):(-?\d*)\]$/);
    if (sliceMatch) {
      const s = sliceMatch[1] ? parseInt(sliceMatch[1]) : 0;
      const e = sliceMatch[2] ? parseInt(sliceMatch[2]) : undefined;
      if (Array.isArray(data)) return [data.slice(s, e)];
    }

    // Field + iterate: .field[]
    const fieldIterMatch = filter.match(/^\.([a-zA-Z_][a-zA-Z0-9_]*)\[\]$/);
    if (fieldIterMatch) {
      const arr = data[fieldIterMatch[1]];
      if (Array.isArray(arr)) return arr;
    }

    // split
    const splitMatch = filter.match(/^split\("(.+)"\)$/);
    if (splitMatch && typeof data === 'string') return [data.split(splitMatch[1])];

    // has
    const hasMatch = filter.match(/^has\("(.+)"\)$/);
    if (hasMatch && data && typeof data === 'object') return [hasMatch[1] in data];

    // del
    const delMatch = filter.match(/^del\(\.([a-zA-Z_][a-zA-Z0-9_]*)\)$/);
    if (delMatch && data && typeof data === 'object') {
      const copy = { ...data };
      delete copy[delMatch[1]];
      return [copy];
    }

    // length on field
    const lenFieldMatch = filter.match(/^\.([a-zA-Z_][a-zA-Z0-9_]*)\s*\|\s*length$/);
    if (lenFieldMatch) {
      const v = data[lenFieldMatch[1]];
      if (Array.isArray(v)) return [v.length];
      if (typeof v === 'string') return [v.length];
      if (v && typeof v === 'object') return [Object.keys(v).length];
      return [0];
    }

    // map(.field)
    const mapFieldMatch = filter.match(/^map\(\.([a-zA-Z_][a-zA-Z0-9_]*)\)$/);
    if (mapFieldMatch && Array.isArray(data)) return [data.map(i => i[mapFieldMatch[1]])];

    // [.field[] | .subfield]
    const collectMatch = filter.match(/^\[\.([a-zA-Z_][a-zA-Z0-9_]*)\[\]\s*\|\s*\.([a-zA-Z_][a-zA-Z0-9_]*)\]$/);
    if (collectMatch) {
      const arr = data[collectMatch[1]];
      if (Array.isArray(arr)) return [arr.map(i => i[collectMatch[2]])];
    }

    // [.field[] | select(.key)] or [.field[] | select(.active)]
    const selectBoolMatch = filter.match(/^\[\.([a-zA-Z_][a-zA-Z0-9_]*)\[\]\s*\|\s*select\(\.([a-zA-Z_][a-zA-Z0-9_]*)\)\]$/);
    if (selectBoolMatch) {
      const arr = data[selectBoolMatch[1]];
      if (Array.isArray(arr)) return [arr.filter(i => !!i[selectBoolMatch[2]])];
    }

    // [.field[] | select(.key == "val") | .subfield]
    const selectEqSubMatch = filter.match(/^\[\.([a-zA-Z_][a-zA-Z0-9_.]*)\[\]\s*\|\s*select\(\.([a-zA-Z_][a-zA-Z0-9_.]*)\s*==\s*"([^"]*)"\)\s*\|\s*\.([a-zA-Z_][a-zA-Z0-9_.]*)\]$/);
    if (selectEqSubMatch) {
      const arr = data[selectEqSubMatch[1]];
      if (Array.isArray(arr)) return [arr.filter(i => i[selectEqSubMatch[2]] === selectEqSubMatch[3]).map(i => i[selectEqSubMatch[4]])];
    }

    // [.field[] | select(.key == "val")]
    const selectEqMatch = filter.match(/^\[\.([a-zA-Z_][a-zA-Z0-9_.]*)\[\]\s*\|\s*select\(\.([a-zA-Z_][a-zA-Z0-9_.]*)\s*==\s*"([^"]*)"\)\]$/);
    if (selectEqMatch) {
      const arr = data[selectEqMatch[1]];
      if (Array.isArray(arr)) return [arr.filter(i => i[selectEqMatch[2]] === selectEqMatch[3])];
    }

    // [.field[] | select(.active) | .subfield]
    const selectBoolSubMatch = filter.match(/^\[\.([a-zA-Z_][a-zA-Z0-9_]*)\[\]\s*\|\s*select\(\.([a-zA-Z_][a-zA-Z0-9_]*)\)\s*\|\s*\.([a-zA-Z_][a-zA-Z0-9_]*)\]$/);
    if (selectBoolSubMatch) {
      const arr = data[selectBoolSubMatch[1]];
      if (Array.isArray(arr)) return [arr.filter(i => !!i[selectBoolSubMatch[2]]).map(i => i[selectBoolSubMatch[3]])];
    }

    // sort_by
    const sortMatch = filter.match(/^\[\.([a-zA-Z_][a-zA-Z0-9_]*)\[\]\s*\|\s*\.\]\s*\|\s*sort_by\(\.([a-zA-Z_][a-zA-Z0-9_]*)\)$/) ||
                      filter.match(/^sort_by\(\.([a-zA-Z_][a-zA-Z0-9_]*)\)$/);
    if (sortMatch) {
      const field = sortMatch[2] || sortMatch[1];
      const arr = sortMatch[2] ? (data[sortMatch[1]] || []) : (Array.isArray(data) ? data : []);
      return [[...arr].sort((a, b) => (a[field] > b[field] ? 1 : a[field] < b[field] ? -1 : 0))];
    }

    // [.field[] | .id]
    const collectIdxMatch = filter.match(/^\[\.([a-zA-Z_][a-zA-Z0-9_]*)\[\]\s*\|\s*\.([a-zA-Z_][a-zA-Z0-9_]*)\]$/);
    if (collectIdxMatch) {
      const arr = data[collectIdxMatch[1]];
      if (Array.isArray(arr)) return [arr.map(i => i[collectIdxMatch[2]])];
    }

    return null; // unsupported
  }

  function runFilter() {
    const filterStr = el('jq-filter').value.trim();
    const jsonStr = el('json-input').value.trim();
    const errEl = el('json-error');
    errEl.classList.add('hidden');

    let data;
    try {
      data = JSON.parse(jsonStr);
    } catch (e) {
      errEl.textContent = 'Invalid JSON: ' + e.message;
      errEl.classList.remove('hidden');
      el('jq-output').textContent = 'Fix JSON input first';
      el('jq-output').className = 'bg-bg border border-border rounded-lg p-4 text-sm font-mono whitespace-pre-wrap min-h-[200px] text-red-400 overflow-auto max-h-[320px]';
      return;
    }

    const results = applyJq(data, filterStr);

    if (results === null) {
      el('jq-output').textContent = `⚠ Filter not yet supported in browser simulation.\nRun locally:\n  echo '...' | jq '${filterStr}'`;
      el('jq-output').className = 'bg-bg border border-border rounded-lg p-4 text-sm font-mono whitespace-pre-wrap min-h-[200px] text-yellow-400 overflow-auto max-h-[320px]';
    } else if (results.length === 0) {
      el('jq-output').textContent = '(empty — no results)';
      el('jq-output').className = 'bg-bg border border-border rounded-lg p-4 text-sm font-mono whitespace-pre-wrap min-h-[200px] text-text-muted overflow-auto max-h-[320px]';
    } else {
      el('jq-output').textContent = results.map(r => JSON.stringify(r, null, 2)).join('\n');
      el('jq-output').className = 'bg-bg border border-border rounded-lg p-4 text-sm font-mono whitespace-pre-wrap min-h-[200px] text-green-400 overflow-auto max-h-[320px]';
    }

    // Update terminal command
    const jsonOneLine = JSON.stringify(data);
    const safe = jsonOneLine.length > 120 ? "$(cat input.json)" : `'${jsonOneLine.replace(/'/g, "'\\''")}'`;
    el('terminal-cmd').textContent = `echo ${safe} | jq '${filterStr}'`;
  }

  el('run-btn').addEventListener('click', runFilter);
  el('jq-filter').addEventListener('keydown', e => { if (e.ctrlKey && e.key === 'Enter') runFilter(); });
  el('json-input').addEventListener('keydown', e => { if (e.ctrlKey && e.key === 'Enter') runFilter(); });

  el('fmt-btn').addEventListener('click', () => {
    try {
      const data = JSON.parse(el('json-input').value);
      el('json-input').value = JSON.stringify(data, null, 2);
      el('json-error').classList.add('hidden');
    } catch (e) {
      const errEl = el('json-error');
      errEl.textContent = 'Invalid JSON: ' + e.message;
      errEl.classList.remove('hidden');
    }
  });

  el('clear-btn').addEventListener('click', () => {
    el('json-input').value = '';
    el('jq-output').textContent = 'Run a filter to see output';
  });

  el('copy-output').addEventListener('click', () => {
    navigator.clipboard.writeText(el('jq-output').textContent).then(() => {
      const btn = el('copy-output');
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
    });
  });

  el('copy-cmd').addEventListener('click', () => {
    navigator.clipboard.writeText(el('terminal-cmd').textContent).then(() => {
      const btn = el('copy-cmd');
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy command'; }, 2000);
    });
  });

  // Run on load with defaults
  runFilter();
})();
</script>
