---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateSection from '../../components/AffiliateSection.astro';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What is Zod and why convert from JSON Schema?", answer: "Zod is a TypeScript-first schema validation library that provides full static type inference. JSON Schema is a widely used standard for describing data shapes (used by OpenAPI, JSON:API, many databases). Converting JSON Schema to Zod allows you to use existing API contracts as runtime validators in TypeScript projects — giving you both compile-time types and runtime validation from a single schema definition." },
  { question: "What JSON Schema features does this converter support?", answer: "This converter handles: primitive types (string, number, integer, boolean), object types with required/optional fields, array types with item definitions, enum values, string formats (email, uri, date-time), string constraints (minLength, maxLength), number constraints (minimum, maximum), nullable fields, description annotations (.describe()), and simple $ref resolution when the definition is inline." },
  { question: "What JSON Schema features are NOT supported?", answer: "Advanced features like oneOf, anyOf, allOf, if/then/else, pattern (regex), remote $ref URLs, $defs with cross-file references, and complex composition are not supported in this client-side tool. For production use with complex schemas, consider the json-schema-to-zod npm package which handles more edge cases." },
  { question: "How do I use the generated Zod schema in my project?", answer: "Install Zod with 'npm install zod', then copy the generated code into your TypeScript file. The generated schemas use z.object(), z.string(), z.number(), z.array(), z.enum(), and other Zod primitives. You can export the schema and infer its type with 'export type MyType = z.infer<typeof mySchema>'. This gives you both runtime validation and TypeScript static types from one definition." },
];
---

<BaseLayout
  title="JSON Schema to Zod Converter — Convert JSON Schema to TypeScript Zod"
  description="Convert JSON Schema definitions to Zod TypeScript schemas instantly. Supports objects, arrays, enums, formats, constraints, nullable, and descriptions. Free, runs in browser."
  tool="JSON Schema to Zod, convert JSON Schema TypeScript, Zod schema generator, json-schema-to-zod online, Zod converter"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "JSON Schema to Zod Converter",
    "url": "https://devplaybook.cc/tools/json-schema-to-zod-converter",
    "description": "Convert JSON Schema definitions to Zod TypeScript schemas. Supports objects, arrays, enums, formats, constraints, nullable, and description annotations.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">JSON Schema to Zod Converter</h1>
  <p class="text-text-muted mb-4">
    Convert JSON Schema definitions to Zod TypeScript schemas.
    Supports objects, arrays, enums, string formats, number constraints, nullable fields, and description annotations.
    Runs entirely in your browser — no server, no data upload.
  </p>
  <div class="flex items-center gap-3 mb-8 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Objects &amp; required fields</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Arrays, enums, formats</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Constraints &amp; nullable</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> .describe() annotations</span>
  </div>

  <!-- Converter -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
    <!-- Input -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <label class="font-semibold text-sm" for="jschema-input">JSON Schema Input</label>
        <button id="jschema-example" class="text-xs text-primary hover:underline">Load example</button>
      </div>
      <textarea id="jschema-input" rows="22"
        placeholder='{\n  "type": "object",\n  "properties": {\n    "name": { "type": "string" }\n  }\n}'
        class="w-full bg-bg border border-border rounded-lg px-3 py-3 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-primary/40 resize-y"></textarea>
    </div>
    <!-- Output -->
    <div class="bg-bg-card border border-border rounded-xl p-5">
      <div class="flex items-center justify-between mb-3">
        <span class="font-semibold text-sm">Zod Schema Output</span>
        <button id="jschema-copy" class="text-xs text-primary hover:underline hidden">Copy</button>
      </div>
      <div id="jschema-error" class="hidden mb-3 p-3 bg-red-500/10 border border-red-500/20 rounded-lg text-sm text-red-400"></div>
      <textarea id="zod-output" rows="22" readonly
        placeholder="Zod schema will appear here..."
        class="w-full bg-bg border border-border rounded-lg px-3 py-3 text-sm font-mono resize-y text-text-muted focus:outline-none"></textarea>
    </div>
  </div>

  <div class="flex gap-3 mb-8">
    <button id="jschema-convert" class="bg-primary text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-primary/80 transition-colors">
      Convert to Zod
    </button>
    <button id="jschema-clear" class="text-sm text-text-muted hover:text-red-400 transition-colors">Clear</button>
  </div>

  <!-- Quick reference -->
  <div class="bg-bg-card border border-border rounded-xl p-6 mb-8">
    <h2 class="font-bold text-sm uppercase tracking-wide text-text-muted mb-4">JSON Schema → Zod Quick Reference</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border">
            <th class="text-left py-2 pr-4 text-text-muted font-medium">JSON Schema</th>
            <th class="text-left py-2 text-text-muted font-medium">Zod</th>
          </tr>
        </thead>
        <tbody class="font-mono text-xs text-text-muted">
          <tr class="border-b border-border/50"><td class="py-2 pr-4">"type": "string"</td><td>z.string()</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4">"type": "number"</td><td>z.number()</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4">"type": "integer"</td><td>z.number().int()</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4">"type": "boolean"</td><td>z.boolean()</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4">"enum": ["a", "b"]</td><td>z.enum(["a", "b"])</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4">"format": "email"</td><td>z.string().email()</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4">"minLength": 3</td><td>z.string().min(3)</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4">"minimum": 0</td><td>z.number().min(0)</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4">"nullable": true</td><td>.nullable()</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4">"type": "array"</td><td>z.array(...)</td></tr>
          <tr class="border-b border-border/50"><td class="py-2 pr-4">not in required</td><td>.optional()</td></tr>
          <tr><td class="py-2 pr-4">"description": "..."</td><td>.describe("...")</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <AffiliateSection />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="JSON Schema to Zod Converter" relatedTags={['json', 'zod', 'typescript', 'validation', 'schema', 'converter']} />
</BaseLayout>

<script is:inline>
(function () {

  // ── JSON Schema → Zod converter ───────────────────────────────────────────────

  function indent(n) {
    return '  '.repeat(n);
  }

  function convertSchema(schema, requiredFields, depth) {
    if (!schema || typeof schema !== 'object') return 'z.unknown()';
    depth = depth || 0;

    // Handle $ref (simple inline defs only)
    if (schema['$ref']) {
      var refName = schema['$ref'].replace('#/definitions/', '').replace('#/$defs/', '');
      return refName + 'Schema';
    }

    var parts = [];
    var type = schema.type;
    var nullable = schema.nullable === true;

    // enum (can appear without type)
    if (schema.enum) {
      var vals = schema.enum.map(function (v) { return JSON.stringify(v); });
      var base = 'z.enum([' + vals.join(', ') + '])';
      if (schema.description) base += '.describe(' + JSON.stringify(schema.description) + ')';
      if (nullable) base += '.nullable()';
      return base;
    }

    // object
    if (type === 'object' || (schema.properties && !type)) {
      var props = schema.properties || {};
      var required = schema.required || requiredFields || [];
      var lines = [];
      Object.keys(props).forEach(function (key) {
        var propSchema = props[key];
        var isRequired = required.indexOf(key) !== -1;
        var zodProp = convertSchema(propSchema, [], depth + 1);
        if (!isRequired) zodProp += '.optional()';
        lines.push(indent(depth + 1) + JSON.stringify(key) + ': ' + zodProp);
      });
      var objStr = 'z.object({\n' + lines.join(',\n') + '\n' + indent(depth) + '})';
      if (schema.description) objStr += '.describe(' + JSON.stringify(schema.description) + ')';
      if (nullable) objStr += '.nullable()';
      return objStr;
    }

    // array
    if (type === 'array') {
      var itemsZod = schema.items ? convertSchema(schema.items, [], depth) : 'z.unknown()';
      var arrStr = 'z.array(' + itemsZod + ')';
      if (schema.minItems !== undefined) arrStr += '.min(' + schema.minItems + ')';
      if (schema.maxItems !== undefined) arrStr += '.max(' + schema.maxItems + ')';
      if (schema.description) arrStr += '.describe(' + JSON.stringify(schema.description) + ')';
      if (nullable) arrStr += '.nullable()';
      return arrStr;
    }

    // string
    if (type === 'string') {
      var s = 'z.string()';
      if (schema.format === 'email') s += '.email()';
      else if (schema.format === 'uri' || schema.format === 'url') s += '.url()';
      else if (schema.format === 'date-time') s += '.datetime()';
      else if (schema.format === 'uuid') s += '.uuid()';
      if (schema.minLength !== undefined) s += '.min(' + schema.minLength + ')';
      if (schema.maxLength !== undefined) s += '.max(' + schema.maxLength + ')';
      if (schema.pattern) s += '.regex(/' + schema.pattern + '/)';
      if (schema.description) s += '.describe(' + JSON.stringify(schema.description) + ')';
      if (nullable) s += '.nullable()';
      return s;
    }

    // number / integer
    if (type === 'number' || type === 'integer') {
      var n = 'z.number()';
      if (type === 'integer') n += '.int()';
      if (schema.minimum !== undefined) n += '.min(' + schema.minimum + ')';
      if (schema.maximum !== undefined) n += '.max(' + schema.maximum + ')';
      if (schema.exclusiveMinimum !== undefined) n += '.gt(' + schema.exclusiveMinimum + ')';
      if (schema.exclusiveMaximum !== undefined) n += '.lt(' + schema.exclusiveMaximum + ')';
      if (schema.multipleOf !== undefined) n += '.multipleOf(' + schema.multipleOf + ')';
      if (schema.description) n += '.describe(' + JSON.stringify(schema.description) + ')';
      if (nullable) n += '.nullable()';
      return n;
    }

    // boolean
    if (type === 'boolean') {
      var b = 'z.boolean()';
      if (schema.description) b += '.describe(' + JSON.stringify(schema.description) + ')';
      if (nullable) b += '.nullable()';
      return b;
    }

    // null
    if (type === 'null') return 'z.null()';

    // fallback
    return 'z.unknown()';
  }

  function generateZod(jsonSchema) {
    var lines = ["import { z } from 'zod';", ''];

    // Handle $defs / definitions
    var defs = jsonSchema['$defs'] || jsonSchema['definitions'] || {};
    Object.keys(defs).forEach(function (defName) {
      lines.push('const ' + defName + 'Schema = ' + convertSchema(defs[defName], [], 0) + ';');
      lines.push('');
    });

    var schemaName = jsonSchema.title
      ? jsonSchema.title.replace(/\s+(.)/g, function (_, c) { return c.toUpperCase(); }).replace(/^./, function (c) { return c.toLowerCase(); }) + 'Schema'
      : 'schema';

    lines.push('export const ' + schemaName + ' = ' + convertSchema(jsonSchema, jsonSchema.required || [], 0) + ';');
    lines.push('');
    lines.push('export type ' + (jsonSchema.title || 'Schema') + ' = z.infer<typeof ' + schemaName + '>;');

    return lines.join('\n');
  }

  // ── Example ───────────────────────────────────────────────────────────────────
  var EXAMPLE = JSON.stringify({
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "User",
    "type": "object",
    "required": ["id", "email", "role"],
    "properties": {
      "id": { "type": "integer", "minimum": 1, "description": "Unique user ID" },
      "email": { "type": "string", "format": "email", "description": "User email address" },
      "username": { "type": "string", "minLength": 3, "maxLength": 30 },
      "role": { "type": "string", "enum": ["admin", "editor", "viewer"] },
      "age": { "type": "integer", "minimum": 0, "maximum": 120, "nullable": true },
      "website": { "type": "string", "format": "uri" },
      "tags": {
        "type": "array",
        "items": { "type": "string" },
        "description": "User tags"
      },
      "address": {
        "type": "object",
        "required": ["street", "city"],
        "properties": {
          "street": { "type": "string" },
          "city": { "type": "string" },
          "zip": { "type": "string", "pattern": "^[0-9]{5}$" }
        }
      }
    }
  }, null, 2);

  document.getElementById('jschema-example').addEventListener('click', function () {
    document.getElementById('jschema-input').value = EXAMPLE;
  });

  document.getElementById('jschema-clear').addEventListener('click', function () {
    document.getElementById('jschema-input').value = '';
    document.getElementById('zod-output').value = '';
    document.getElementById('jschema-error').classList.add('hidden');
    document.getElementById('jschema-copy').classList.add('hidden');
  });

  document.getElementById('jschema-convert').addEventListener('click', function () {
    var raw = document.getElementById('jschema-input').value.trim();
    var errEl = document.getElementById('jschema-error');
    var outEl = document.getElementById('zod-output');
    var copyBtn = document.getElementById('jschema-copy');

    errEl.classList.add('hidden');
    outEl.value = '';
    copyBtn.classList.add('hidden');

    if (!raw) {
      errEl.textContent = 'Please paste a JSON Schema first.';
      errEl.classList.remove('hidden');
      return;
    }

    try {
      var parsed = JSON.parse(raw);
      var result = generateZod(parsed);
      outEl.value = result;
      copyBtn.classList.remove('hidden');
    } catch (e) {
      errEl.textContent = 'JSON parse error: ' + (e.message || String(e));
      errEl.classList.remove('hidden');
    }
  });

  document.getElementById('jschema-copy').addEventListener('click', function () {
    var val = document.getElementById('zod-output').value;
    if (val) navigator.clipboard && navigator.clipboard.writeText(val);
    this.textContent = 'Copied!';
    var btn = this;
    setTimeout(function () { btn.textContent = 'Copy'; }, 2000);
  });

})();
</script>
