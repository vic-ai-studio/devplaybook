---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BunWorkspaceGenerator from '../../components/BunWorkspaceGenerator.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';
import AdUnit from '../../components/AdUnit.astro';

const faq = [
  {
    question: "What is a Bun workspace (monorepo)?",
    answer: "A Bun workspace is a monorepo where multiple packages share a single root node_modules and package.json. Define it with the 'workspaces' field in root package.json: { \"workspaces\": [\"packages/*\"] }. Bun automatically links local packages — if packages/web depends on @myorg/shared, Bun symlinks it from the workspace without publishing to npm. Run scripts across all packages: 'bun run --filter \"*\" build'. This is faster than npm/yarn workspaces due to Bun's native package manager."
  },
  {
    question: "What is bunfig.toml?",
    answer: "bunfig.toml is Bun's configuration file for install behavior, test runner settings, and runtime options. The [install] section configures registry, scoped registries, and install flags. The [test] section sets test timeout, preload files, and coverage settings. The [run] section controls script execution. Unlike package.json engines or .npmrc, bunfig.toml is Bun-specific and lives at the root of your project or in ~/.bunfig.toml for global config."
  },
  {
    question: "What is the difference between bun.lock and package-lock.json?",
    answer: "bun.lock is Bun's binary lockfile format — significantly smaller and faster to read/write than JSON-based lockfiles. It records exact resolved package versions and integrity hashes. Use 'bun install --frozen-lockfile' in CI to fail if the lockfile would change. If you need npm/yarn compatibility (e.g., for Vercel or other platforms that call npm install), set 'bun install --save-text-lockfile' to generate a text-format lockfile, or commit package-lock.json alongside bun.lock."
  },
  {
    question: "How does 'bun run --filter' work?",
    answer: "The --filter flag selects which workspace packages to run a script in. 'bun run --filter \"*\" build' runs the 'build' script in all packages that have it. 'bun run --filter \"frontend\" dev' runs only in the 'frontend' package (matched by name field). You can also use glob patterns: 'bun run --filter \"@myorg/*\" test'. Bun runs these in parallel by default and respects workspace dependency order for build scripts."
  },
  {
    question: "Should I use bun build, vite, or tsup for bundling?",
    answer: "bun build is the fastest option and works well for server-side bundles (Bun runtime target) and simple browser bundles. vite is the best choice for frontend apps with hot module replacement, CSS handling, and the rich plugin ecosystem. tsup (powered by esbuild) is ideal for library packages that need dual CJS+ESM output, TypeScript declarations, and tree-shakeable builds. For a monorepo: use bun build or tsup for shared/library packages and vite for frontend apps."
  },
];
---

<BaseLayout
  title="Bun Workspace Generator — Monorepo package.json & bunfig.toml Builder"
  description="Generate a complete Bun monorepo workspace configuration. Creates root package.json with workspaces, bunfig.toml, TypeScript project references, and per-package configs for frontend, backend, shared, CLI, and docs packages."
  tool="Bun workspace generator, Bun monorepo, bunfig.toml, bun workspaces, TypeScript monorepo, bun package.json"
  faq={faq}
>
  <h1 class="text-3xl font-bold mb-2">Bun Workspace Generator</h1>
  <p class="text-text-muted mb-4">Generate a complete Bun monorepo setup. Choose packages (frontend, backend, shared, types, CLI), configure TypeScript, test runner, and build tool — get root package.json, bunfig.toml, and per-package configs.</p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Root package.json + workspaces</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> bunfig.toml config</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> TypeScript project refs</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Per-package stubs</span>
  </div>

  <BunWorkspaceGenerator client:only="preact" />

  <AdUnit slot="auto" format="auto" label="Advertisement" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="Bun Workspace Generator" relatedTags={['bun', 'monorepo', 'workspace', 'typescript', 'package-manager', 'build-tools']} />
</BaseLayout>
