---
import BaseLayout from '../../layouts/BaseLayout.astro';
import IpGeolocation from '../../components/IpGeolocation.tsx';
import ToolPageCta from '../../components/ToolPageCta.astro';
import FaqSection from '../../components/FaqSection.astro';

const faq = [
  { question: "What information does an IP lookup return?", answer: "An IP address lookup returns geographic information including city, region, country, timezone, ISP (Internet Service Provider), organization, and approximate latitude/longitude coordinates. Note that geolocation is approximate — accuracy varies by IP type and ISP routing." },
  { question: "Can I look up my own IP address?", answer: "Yes. Click 'Detect My IP' to automatically retrieve your current public IP address and its associated location data. This shows the IP your device uses when connecting to the internet, which may be your ISP's IP or a VPN/proxy IP if you're using one." },
  { question: "Why is my IP geolocation inaccurate?", answer: "IP geolocation is an estimation based on registration data, not GPS. ISPs often register IP blocks at their headquarters rather than where individual customers are. VPNs and proxies also cause the detected location to differ from your physical location. Accuracy is typically within 25–100 miles for most residential IPs." },
  { question: "What is the difference between IPv4 and IPv6?", answer: "IPv4 uses 32-bit addresses (e.g., 192.168.1.1) providing ~4.3 billion unique addresses. IPv6 uses 128-bit addresses (e.g., 2001:db8::1) providing a virtually unlimited address space. IPv6 was introduced to solve IPv4 exhaustion. Both are supported by this lookup tool." },
  { question: "Can I look up a private IP address?", answer: "Private IP ranges (10.x.x.x, 172.16–31.x.x, 192.168.x.x) are reserved for local networks and cannot be geolocated — they're not routable on the public internet. The tool works with public (routable) IP addresses only." },
  { question: "Is this tool free and private?", answer: "Yes. The lookup uses a public API (ipapi.co) and your query is sent to their servers to resolve geolocation data. Your lookup history is not stored by DevPlaybook. The API may have rate limits for high-volume usage." },
];
---

<BaseLayout
  title="IP Address Lookup — Find Location, ISP & Geolocation"
  description="Look up any IP address to find its location, ISP, timezone, and coordinates. Or detect your own current IP instantly. Free online IPv4 and IPv6 lookup tool."
  tool="IP Address Lookup, IP Lookup, Find IP Location, IP Geolocation, IP Address Checker"
  faq={faq}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "IP Address Lookup",
    "url": "https://devplaybook.cc/tools/ip-address-lookup",
    "description": "Look up any IP address to find its geographic location, ISP, timezone, and coordinates. Supports IPv4 and IPv6. Detect your own IP instantly.",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  })} />

  <h1 class="text-3xl font-bold mb-2">IP Address Lookup</h1>
  <p class="text-text-muted mb-4">
    Enter any IPv4 or IPv6 address to get its approximate geographic location — city, region, country, ISP, timezone, and coordinates. Click <strong>Detect My IP</strong> to look up your own current public IP address instantly.
  </p>
  <div class="flex items-center gap-3 mb-6 text-sm text-text-muted flex-wrap">
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> IPv4 &amp; IPv6 support</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> Detect your current IP</span>
    <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> City, ISP, timezone, coordinates</span>
  </div>
  <IpGeolocation client:only="preact" />
  <FaqSection faq={faq} />
  <ToolPageCta currentTool="IP Address Lookup" relatedTags={['networking', 'api', 'ip', 'geolocation']} />
</BaseLayout>
