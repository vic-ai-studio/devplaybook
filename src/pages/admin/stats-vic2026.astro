---
// No auth — URL-based security (/admin/stats-vic2026)
// All data read client-side from localStorage (pc_events, pc_pages_visited)
---
<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>DevPlaybook Stats (VIC)</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      body { background: #0f0f13; color: #e4e4e7; font-family: system-ui, sans-serif; margin: 0; padding: 24px; }
      h1 { font-size: 1.5rem; font-weight: 700; color: #a78bfa; margin-bottom: 4px; }
      .sub { color: #71717a; font-size: 0.85rem; margin-bottom: 24px; }
      .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 32px; }
      .card { background: #18181b; border: 1px solid #27272a; border-radius: 12px; padding: 20px; }
      .card-title { color: #71717a; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
      .card-val { font-size: 2rem; font-weight: 700; color: #a78bfa; }
      .card-sub { font-size: 0.8rem; color: #52525b; margin-top: 4px; }
      table { width: 100%; border-collapse: collapse; }
      th { text-align: left; color: #71717a; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; padding: 8px 12px; border-bottom: 1px solid #27272a; }
      td { padding: 8px 12px; border-bottom: 1px solid #18181b; font-size: 0.9rem; }
      tr:hover td { background: #1c1c22; }
      .section { background: #18181b; border: 1px solid #27272a; border-radius: 12px; padding: 20px; margin-bottom: 24px; }
      .section-title { font-weight: 600; margin-bottom: 16px; color: #d4d4d8; }
      .badge { display: inline-block; padding: 2px 8px; border-radius: 999px; font-size: 0.75rem; font-weight: 600; }
      .badge-green { background: #14532d; color: #4ade80; }
      .badge-blue { background: #1e3a5f; color: #60a5fa; }
      .badge-purple { background: #3b1f6e; color: #c084fc; }
      .empty { color: #52525b; font-style: italic; text-align: center; padding: 32px; }
      #clear-btn { background: #7f1d1d; color: #fca5a5; border: 1px solid #991b1b; border-radius: 8px; padding: 6px 14px; font-size: 0.8rem; cursor: pointer; float: right; }
      #clear-btn:hover { background: #991b1b; }
    </style>
  </head>
  <body>
    <h1>📊 DevPlaybook Analytics</h1>
    <div class="sub">Privacy-first · localStorage only · Last 7 days · <span id="last-updated"></span></div>

    <button id="clear-btn" onclick="clearData()">Clear Data</button>
    <br style="clear:both" /><br />

    <!-- Summary cards -->
    <div class="grid" id="summary-cards">
      <div class="card"><div class="card-title">Gumroad Clicks</div><div class="card-val" id="stat-gumroad">—</div><div class="card-sub">last 7 days</div></div>
      <div class="card"><div class="card-title">Pro CTA Clicks</div><div class="card-val" id="stat-pro">—</div><div class="card-sub">last 7 days</div></div>
      <div class="card"><div class="card-title">Newsletter Signups</div><div class="card-val" id="stat-newsletter">—</div><div class="card-sub">last 7 days</div></div>
      <div class="card"><div class="card-title">Total Page Views</div><div class="card-val" id="stat-views">—</div><div class="card-sub">last 7 days</div></div>
      <div class="card"><div class="card-title">Device Split</div><div class="card-val" id="stat-device">—</div><div class="card-sub" id="stat-device-sub">desktop / mobile</div></div>
    </div>

    <!-- Events by type -->
    <div class="section">
      <div class="section-title">Events — Last 7 Days</div>
      <table id="events-table">
        <thead><tr><th>Event</th><th>Count</th><th>Details</th></tr></thead>
        <tbody id="events-body"><tr><td colspan="3" class="empty">Loading…</td></tr></tbody>
      </table>
    </div>

    <!-- Most visited pages -->
    <div class="section">
      <div class="section-title">Most Visited Pages — Last 7 Days</div>
      <table id="pages-table">
        <thead><tr><th>Page</th><th>Views</th><th>Desktop</th><th>Mobile</th></tr></thead>
        <tbody id="pages-body"><tr><td colspan="4" class="empty">Loading…</td></tr></tbody>
      </table>
    </div>

    <!-- Raw recent events -->
    <div class="section">
      <div class="section-title">Recent Events (last 20)</div>
      <table>
        <thead><tr><th>Time</th><th>Event</th><th>Props</th></tr></thead>
        <tbody id="recent-body"><tr><td colspan="3" class="empty">Loading…</td></tr></tbody>
      </table>
    </div>

    <script is:inline>
      var SEVEN_DAYS = 7 * 24 * 60 * 60 * 1000;
      var now = Date.now();

      function fmtTime(ts) {
        var d = new Date(ts);
        return d.toLocaleDateString() + ' ' + d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      }

      function clearData() {
        if (!confirm('Clear all tracking data from localStorage?')) return;
        localStorage.removeItem('pc_events');
        localStorage.removeItem('pc_pages_visited');
        location.reload();
      }

      function eventBadge(name) {
        if (name === 'gumroad_click') return '<span class="badge badge-green">gumroad</span>';
        if (name === 'pro_cta_click') return '<span class="badge badge-purple">pro cta</span>';
        if (name === 'newsletter_submit') return '<span class="badge badge-blue">newsletter</span>';
        return '<span class="badge" style="background:#27272a;color:#a1a1aa">' + name + '</span>';
      }

      function render() {
        document.getElementById('last-updated').textContent = 'updated ' + fmtTime(now);

        // Load data
        var allEvents = [];
        var allViews = [];
        try { allEvents = JSON.parse(localStorage.getItem('pc_events') || '[]'); } catch(e) {}
        try { allViews = JSON.parse(localStorage.getItem('pc_pages_visited') || '[]'); } catch(e) {}

        // Filter to last 7 days
        var events = allEvents.filter(function(e) { return now - e.ts < SEVEN_DAYS; });
        var views = allViews.filter(function(v) { return now - v.ts < SEVEN_DAYS; });

        // Summary stats
        var gCount = events.filter(function(e) { return e.event === 'gumroad_click'; }).length;
        var pCount = events.filter(function(e) { return e.event === 'pro_cta_click'; }).length;
        var nCount = events.filter(function(e) { return e.event === 'newsletter_submit'; }).length;
        var vCount = views.length;
        var mViews = views.filter(function(v) { return v.mobile; }).length;
        var dViews = vCount - mViews;

        document.getElementById('stat-gumroad').textContent = gCount;
        document.getElementById('stat-pro').textContent = pCount;
        document.getElementById('stat-newsletter').textContent = nCount;
        document.getElementById('stat-views').textContent = vCount;
        document.getElementById('stat-device').textContent = dViews + ' / ' + mViews;
        document.getElementById('stat-device-sub').textContent = 'desktop / mobile';

        // Events by type table
        var eventMap = {};
        events.forEach(function(e) {
          if (!eventMap[e.event]) eventMap[e.event] = { count: 0, sources: {} };
          eventMap[e.event].count++;
          var src = (e.props && (e.props.source || e.props.product_name)) || '';
          if (src) eventMap[e.event].sources[src] = (eventMap[e.event].sources[src] || 0) + 1;
        });
        var evtRows = Object.keys(eventMap).sort(function(a, b) { return eventMap[b].count - eventMap[a].count; });
        var evtBody = document.getElementById('events-body');
        if (evtRows.length === 0) {
          evtBody.innerHTML = '<tr><td colspan="3" class="empty">No events in last 7 days</td></tr>';
        } else {
          evtBody.innerHTML = evtRows.map(function(name) {
            var info = eventMap[name];
            var srcs = Object.keys(info.sources).map(function(s) { return s + ' (' + info.sources[s] + ')'; }).join(', ');
            return '<tr><td>' + eventBadge(name) + '</td><td><strong>' + info.count + '</strong></td><td style="color:#71717a;font-size:0.8rem">' + (srcs || '—') + '</td></tr>';
          }).join('');
        }

        // Most visited pages
        var pageMap = {};
        views.forEach(function(v) {
          var p = v.path || '/';
          if (!pageMap[p]) pageMap[p] = { total: 0, desktop: 0, mobile: 0 };
          pageMap[p].total++;
          if (v.mobile) pageMap[p].mobile++;
          else pageMap[p].desktop++;
        });
        var pageKeys = Object.keys(pageMap).sort(function(a, b) { return pageMap[b].total - pageMap[a].total; }).slice(0, 20);
        var pBody = document.getElementById('pages-body');
        if (pageKeys.length === 0) {
          pBody.innerHTML = '<tr><td colspan="4" class="empty">No page views in last 7 days</td></tr>';
        } else {
          pBody.innerHTML = pageKeys.map(function(p) {
            var info = pageMap[p];
            return '<tr><td style="font-family:monospace;font-size:0.85rem">' + p + '</td><td><strong>' + info.total + '</strong></td><td>' + info.desktop + '</td><td>' + info.mobile + '</td></tr>';
          }).join('');
        }

        // Recent events (last 20, newest first)
        var recent = allEvents.slice(-20).reverse();
        var rBody = document.getElementById('recent-body');
        if (recent.length === 0) {
          rBody.innerHTML = '<tr><td colspan="3" class="empty">No events recorded yet</td></tr>';
        } else {
          rBody.innerHTML = recent.map(function(e) {
            var props = JSON.stringify(e.props || {});
            return '<tr><td style="font-size:0.8rem;color:#71717a;white-space:nowrap">' + fmtTime(e.ts) + '</td><td>' + eventBadge(e.event) + '</td><td style="font-family:monospace;font-size:0.75rem;color:#71717a">' + props + '</td></tr>';
          }).join('');
        }
      }

      render();
    </script>
  </body>
</html>
