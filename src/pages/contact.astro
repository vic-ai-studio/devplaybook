---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us"
  description="Get in touch with the DevPlaybook team — feedback, bug reports, partnership inquiries, and support."
>
  <div class="max-w-2xl mx-auto">
    <div class="text-center mb-12">
      <h1 class="text-3xl font-bold mb-3">Contact Us</h1>
      <p class="text-text-muted text-lg">
        Have feedback, found a bug, or want to collaborate? We'd love to hear from you.
      </p>
    </div>

    <div class="grid gap-6 mb-12">
      <div class="bg-bg-card border border-border rounded-2xl p-6">
        <h2 class="text-lg font-semibold mb-4">Get in Touch</h2>
        <div class="space-y-4 text-text-muted">
          <div class="flex items-start gap-3">
            <span class="text-xl mt-0.5">📧</span>
            <div>
              <p class="font-medium text-text">Email</p>
              <a href="mailto:hello@devplaybook.cc" class="text-primary hover:underline">hello@devplaybook.cc</a>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-xl mt-0.5">🐛</span>
            <div>
              <p class="font-medium text-text">Bug Reports</p>
              <p>Found an issue with one of our tools? Email us with the tool name and a description of the problem.</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-xl mt-0.5">💡</span>
            <div>
              <p class="font-medium text-text">Feature Requests</p>
              <p>Have an idea for a new tool or improvement? We prioritize suggestions from the community.</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-xl mt-0.5">🤝</span>
            <div>
              <p class="font-medium text-text">Partnerships & Advertising</p>
              <p>Interested in sponsoring or advertising on DevPlaybook? See our <a href="/advertise" class="text-primary hover:underline">advertising page</a> or email us directly.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-bg-card border border-border rounded-2xl p-6">
        <h2 class="text-lg font-semibold mb-4">Response Time</h2>
        <p class="text-text-muted leading-relaxed">
          We typically respond within 1–2 business days. For urgent tool issues (broken functionality, security concerns), please include "URGENT" in your subject line.
        </p>
      </div>

      <div class="bg-bg-card border border-border rounded-2xl p-6">
        <h2 class="text-lg font-semibold mb-4">Follow Us</h2>
        <div class="flex gap-4">
          <a href="https://twitter.com/devplaybook" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            @devplaybook
          </a>
          <a href="https://github.com/nicholasgriffintn/devplaybook" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
