---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Welcome to Pro" description="You're now a DevPlaybook Pro member. Thank you for subscribing!">
  <div class="max-w-2xl mx-auto text-center py-16">
    <div class="text-6xl mb-6">🎉</div>
    <h1 class="text-4xl font-bold mb-4">Welcome to <span class="text-primary">DevPlaybook Pro</span>!</h1>
    <p class="text-text-muted text-lg mb-8">
      Your subscription is active. You now have access to all Pro features including exclusive tools, templates, and member-only discounts.
    </p>

    <div class="bg-bg-card border border-border rounded-xl p-6 mb-8 text-left">
      <h2 class="text-xl font-semibold mb-4">What's included in your Pro plan:</h2>
      <ul class="space-y-3 text-text-muted">
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold shrink-0">✓</span>
          <span>All premium tools &amp; templates — including future releases</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold shrink-0">✓</span>
          <span>Early access to new content before the general public</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold shrink-0">✓</span>
          <span>Member-only discounts on all Gumroad products</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold shrink-0">✓</span>
          <span>Priority support — your questions answered first</span>
        </li>
      </ul>
    </div>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/"
        class="bg-primary hover:bg-primary-dark text-white font-semibold px-8 py-3 rounded-lg transition-colors"
      >
        Explore Tools
      </a>
      <a
        href="/products"
        class="bg-bg-card border border-border hover:border-primary text-text font-semibold px-8 py-3 rounded-lg transition-colors"
      >
        Browse Products
      </a>
    </div>

    <p class="text-text-muted text-sm mt-8">
      A confirmation email has been sent via Stripe. To manage your subscription, visit the
      <a href="https://billing.stripe.com" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">Stripe billing portal</a>.
    </p>
  </div>
</BaseLayout>
