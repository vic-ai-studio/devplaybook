---
import BaseLayout from '../layouts/BaseLayout.astro';
import { products } from '../data/products';

const BUNDLE_URL = 'https://vicnail.gumroad.com/l/devplaybook-pro-bundle?utm_source=devplaybook&utm_medium=deals_page&utm_campaign=deals';
const BUNDLE_PRICE = 79;
const BUNDLE_ORIGINAL = products.reduce((sum, p) => sum + p.price, 0);
const savings = BUNDLE_ORIGINAL - BUNDLE_PRICE;
const savingsPct = Math.round((savings / BUNDLE_ORIGINAL) * 100);

// Sort by price ascending
const sortedProducts = [...products].sort((a, b) => a.price - b.price);

// Group products by price tier
const tiers = [
  { label: 'Under $15', items: sortedProducts.filter(p => p.price < 15) },
  { label: '$15–$20', items: sortedProducts.filter(p => p.price >= 15 && p.price <= 20) },
  { label: '$25+', items: sortedProducts.filter(p => p.price > 20) },
];
---

<BaseLayout
  title="DevPlaybook Deals — All Products & Pricing"
  description={`All ${products.length} DevPlaybook products on Gumroad with current pricing. Boilerplates, automation scripts, AI toolkits, MCP templates, and more. Or grab the full bundle and save ${savingsPct}%.`}
  noDefaultJsonLd
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "DevPlaybook Deals",
    "url": "https://devplaybook.cc/deals",
    "description": `All ${products.length} DevPlaybook products with pricing. Save ${savingsPct}% with the bundle.`,
    "itemListElement": products.map((product, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": product.name,
      "url": `https://devplaybook.cc/products/${product.slug}`,
      "item": {
        "@type": "Product",
        "name": product.name,
        "description": product.description,
        "url": `https://devplaybook.cc/products/${product.slug}`,
        "image": "https://devplaybook.cc/og-default.svg",
        "offers": {
          "@type": "Offer",
          "price": product.price,
          "priceCurrency": "USD",
          "priceValidUntil": "2027-12-31",
          "availability": "https://schema.org/InStock",
          "hasMerchantReturnPolicy": {
            "@type": "MerchantReturnPolicy",
            "applicableCountry": "US",
            "returnPolicyCategory": "https://schema.org/MerchantReturnNotPermitted",
            "merchantReturnDays": 0
          },
          "shippingDetails": {
            "@type": "OfferShippingDetails",
            "shippingRate": { "@type": "MonetaryAmount", "value": "0", "currency": "USD" },
            "shippingDestination": { "@type": "DefinedRegion", "addressCountry": "US" },
            "deliveryTime": { "@type": "ShippingDeliveryTime", "handlingTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 0, "unitCode": "DAY" }, "transitTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 0, "unitCode": "DAY" } }
          }
        }
      }
    }))
  })} />

  <!-- Hero -->
  <div class="text-center mb-12">
    <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-3">All Products</p>
    <h1 class="text-4xl font-bold mb-3">DevPlaybook <span class="text-primary">Deals</span></h1>
    <p class="text-text-muted text-lg max-w-2xl mx-auto">
      {products.length} premium developer products on Gumroad. Buy individually or grab the full bundle and save {savingsPct}%.
    </p>
  </div>

  <!-- Bundle Hero CTA -->
  <div class="mb-12 rounded-2xl border border-primary/40 bg-gradient-to-br from-primary/5 to-bg-card p-8 text-center">
    <span class="inline-block text-xs font-bold uppercase tracking-widest text-primary mb-3 bg-primary/10 px-3 py-1 rounded-full">Best Value</span>
    <h2 class="text-3xl font-bold mb-2">DevPlaybook Pro Bundle</h2>
    <p class="text-text-muted mb-5 max-w-xl mx-auto">
      Every product in one download. {products.length} premium items — boilerplates, scripts, AI toolkits, MCP templates, and guides.
    </p>
    <div class="flex items-center justify-center gap-4 mb-6">
      <span class="text-5xl font-bold text-primary">${BUNDLE_PRICE}</span>
      <div class="text-left">
        <span class="block text-text-muted line-through text-base">${BUNDLE_ORIGINAL} separately</span>
        <span class="block text-green-400 font-semibold">Save ${savings} ({savingsPct}% off)</span>
      </div>
    </div>
    <a
      href={BUNDLE_URL}
      target="_blank"
      rel="noopener noreferrer"
      data-track="bundle_cta_click"
      data-cta-location="deals_page_hero"
      class="inline-block bg-primary hover:bg-primary-dark text-white font-bold px-10 py-4 rounded-xl text-lg transition-colors"
    >
      Get Full Bundle — ${BUNDLE_PRICE} →
    </a>
    <p class="text-text-muted text-xs mt-3">One-time payment · MIT licensed · Instant download on Gumroad</p>
  </div>

  <!-- Divider -->
  <div class="flex items-center gap-4 mb-10">
    <div class="flex-1 border-t border-border"></div>
    <span class="text-text-muted text-sm font-medium">Or buy individually</span>
    <div class="flex-1 border-t border-border"></div>
  </div>

  <!-- All Products by Tier -->
  {tiers.map(tier => tier.items.length > 0 && (
    <div class="mb-12">
      <div class="flex items-center gap-3 mb-5">
        <h2 class="text-xl font-bold">{tier.label}</h2>
        <span class="text-xs text-text-muted bg-bg-card border border-border px-2 py-0.5 rounded-full">{tier.items.length} product{tier.items.length !== 1 ? 's' : ''}</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {tier.items.map(product => (
          <div class="bg-bg-card rounded-xl border border-border hover:border-primary transition-colors group flex flex-col overflow-hidden">
            <div class="p-5 flex-1">
              <div class="flex items-start justify-between mb-3">
                <span class="text-3xl">{product.icon}</span>
                <span class="text-2xl font-bold text-primary">${product.price}</span>
              </div>
              <h3 class="font-semibold text-base mb-2 group-hover:text-primary transition-colors">{product.name}</h3>
              <p class="text-text-muted text-sm line-clamp-3 mb-3">{product.description}</p>
              <div class="flex flex-wrap gap-1.5 mb-3">
                {product.tags.slice(0, 3).map(tag => (
                  <span class="text-xs bg-bg border border-border text-text-muted px-2 py-0.5 rounded">{tag}</span>
                ))}
              </div>
            </div>
            <div class="px-5 pb-5 flex gap-2">
              <a
                href={product.gumroadUrl}
                target="_blank"
                rel="noopener noreferrer"
                data-track="gumroad_buy_click"
                data-product-name={product.name}
                data-product-price={String(product.price)}
                data-cta-location="deals_page"
                class="flex-1 bg-primary hover:bg-primary-dark text-white text-sm font-semibold px-4 py-2.5 rounded-lg transition-colors text-center"
              >
                Buy — ${product.price}
              </a>
              <a
                href={`/products/${product.slug}`}
                data-track="product_details_click"
                class="px-4 py-2.5 bg-bg border border-border hover:border-primary text-sm rounded-lg transition-colors text-center"
              >
                Details
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  ))}

  <!-- Bottom bundle repeat -->
  <div class="mt-8 rounded-2xl border border-primary/30 bg-gradient-to-r from-bg-card to-bg p-6 flex flex-col sm:flex-row items-center gap-5">
    <div class="flex-1">
      <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-1">Bundle & Save</p>
      <h3 class="text-xl font-bold mb-1">Get all {products.length} products for ${BUNDLE_PRICE}</h3>
      <p class="text-text-muted text-sm">Save ${savings} ({savingsPct}% off) vs buying individually. One-time payment, MIT licensed.</p>
    </div>
    <a
      href={BUNDLE_URL}
      target="_blank"
      rel="noopener noreferrer"
      data-track="bundle_cta_click"
      data-cta-location="deals_page_footer"
      class="shrink-0 bg-primary hover:bg-primary-dark text-white font-bold px-7 py-3 rounded-xl transition-colors whitespace-nowrap"
    >
      Get Bundle — ${BUNDLE_PRICE} →
    </a>
  </div>

  <!-- Email capture -->
  <div class="mt-8 bg-bg-card border border-border rounded-xl p-6 text-center">
    <h3 class="font-semibold text-base mb-1">Get notified when new products drop</h3>
    <p class="text-text-muted text-sm mb-4">Weekly tips + early access to new tools and products. No spam.</p>
    <form
      action="https://buttondown.com/api/emails/embed-subscribe/devplaybook"
      method="post"
      target="_blank"
      class="flex gap-2 justify-center flex-wrap sm:flex-nowrap max-w-sm mx-auto"
      data-track-submit="newsletter_signup_deals"
    >
      <input
        type="email"
        name="email"
        placeholder="you@example.com"
        required
        class="flex-1 px-3 py-2 text-sm bg-bg border border-border rounded-lg focus:outline-none focus:border-primary min-w-0"
      />
      <button
        type="submit"
        class="px-4 py-2 bg-primary hover:bg-primary-dark text-white text-sm font-semibold rounded-lg transition-colors whitespace-nowrap"
        data-track="newsletter_signup"
        data-form-name="deals_page"
      >
        Subscribe →
      </button>
    </form>
  </div>
</BaseLayout>
