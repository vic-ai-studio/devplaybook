---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Payment Result" description="Payment result page">
  <div class="max-w-2xl mx-auto text-center py-16">
    <div id="result-loading">
      <p class="text-lg text-text-muted">Processing payment result...</p>
    </div>
    <div id="result-success" class="hidden">
      <span class="text-6xl block mb-6">&#10003;</span>
      <h1 class="text-3xl font-bold mb-4 text-secondary">Payment Successful!</h1>
      <p class="text-text-muted mb-8">Thank you for your purchase. Your download link has been sent to your email.</p>
      <a href="/products" class="inline-block bg-primary hover:bg-primary-dark text-white font-semibold px-8 py-3 rounded-lg transition-colors">
        Back to Products
      </a>
    </div>
    <div id="result-failed" class="hidden">
      <span class="text-6xl block mb-6">&#10007;</span>
      <h1 class="text-3xl font-bold mb-4 text-red-500">Payment Failed</h1>
      <p class="text-text-muted mb-4" id="error-message">The payment was not completed.</p>
      <a href="/products" class="inline-block bg-primary hover:bg-primary-dark text-white font-semibold px-8 py-3 rounded-lg transition-colors">
        Try Again
      </a>
    </div>
  </div>

  <script>
    const params = new URLSearchParams(window.location.search);
    const rtnCode = params.get('RtnCode');

    document.getElementById('result-loading').classList.add('hidden');

    if (rtnCode === '1') {
      document.getElementById('result-success').classList.remove('hidden');
    } else {
      document.getElementById('result-failed').classList.remove('hidden');
      const msg = params.get('RtnMsg');
      if (msg) {
        document.getElementById('error-message').textContent = msg;
      }
    }
  </script>
</BaseLayout>
