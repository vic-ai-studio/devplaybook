---
import BaseLayout from '../layouts/BaseLayout.astro';
import { products } from '../data/products';

const BUNDLE_URL = 'https://vicnail.gumroad.com/l/devplaybook-pro-bundle?utm_source=devplaybook&utm_medium=bundles_page&utm_campaign=pro-bundle';
const BUNDLE_PRICE = 79;
const BUNDLE_ORIGINAL = products.reduce((sum, p) => sum + p.price, 0);
const savings = BUNDLE_ORIGINAL - BUNDLE_PRICE;
const savingsPct = Math.round((savings / BUNDLE_ORIGINAL) * 100);
---

<BaseLayout
  title="DevPlaybook Pro Bundle — All 13 Products"
  description={`Get all 13 DevPlaybook products in one bundle for $${BUNDLE_PRICE}. Boilerplates, automation scripts, AI toolkits, MCP templates, and more. Save $${BUNDLE_ORIGINAL - BUNDLE_PRICE} vs buying separately.`}
  noDefaultJsonLd
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "DevPlaybook Pro Bundle",
    "description": `All 13 DevPlaybook products in one bundle. Save ${savingsPct}% vs buying separately.`,
    "url": "https://devplaybook.cc/bundles",
    "offers": {
      "@type": "Offer",
      "price": BUNDLE_PRICE,
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock",
      "url": BUNDLE_URL
    }
  })} />

  <!-- Hero -->
  <div class="text-center mb-16">
    <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-4">Complete Bundle</p>
    <h1 class="text-5xl font-bold mb-4">DevPlaybook <span class="text-primary">Pro</span></h1>
    <p class="text-text-muted text-xl max-w-2xl mx-auto mb-8">
      Every premium product in one bundle. Boilerplates, automation scripts,
      AI toolkits, MCP templates, guides — everything you need to ship faster.
    </p>

    <div class="flex items-center justify-center gap-4 mb-8">
      <div class="text-center">
        <span class="block text-6xl font-bold text-primary">${BUNDLE_PRICE}</span>
        <span class="block text-text-muted text-sm mt-1">one-time payment</span>
      </div>
      <div class="text-left">
        <span class="block text-text-muted line-through text-lg">${BUNDLE_ORIGINAL} if bought separately</span>
        <span class="block text-green-400 font-semibold text-lg">You save ${savings} ({savingsPct}% off)</span>
        <span class="block text-text-muted text-sm mt-1">13 products · MIT licensed · Instant download</span>
      </div>
    </div>

    <a
      href={BUNDLE_URL}
      target="_blank"
      rel="noopener noreferrer"
      data-track="bundle_hero_cta"
      data-product-name="DevPlaybook Pro Bundle"
      data-product-price={String(BUNDLE_PRICE)}
      class="inline-block bg-primary hover:bg-primary-dark text-white font-bold px-10 py-5 rounded-2xl text-xl transition-colors shadow-lg"
    >
      Get DevPlaybook Pro — ${BUNDLE_PRICE} →
    </a>
    <p class="text-text-muted text-sm mt-4">No subscription · No DRM · Instant Gumroad download</p>
  </div>

  <!-- What's included -->
  <div class="mb-16">
    <h2 class="text-3xl font-bold text-center mb-10">What's <span class="text-primary">Included</span></h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {products.map(product => (
        <div class="bg-bg-card rounded-xl p-5 border border-border">
          <div class="flex items-start justify-between mb-3">
            <span class="text-3xl">{product.icon}</span>
            <div class="text-right">
              <span class="block text-text-muted line-through text-xs">${product.price}</span>
              <span class="block text-green-400 text-xs font-semibold">included</span>
            </div>
          </div>
          <h3 class="font-semibold mb-2 text-sm leading-snug">{product.name}</h3>
          <p class="text-text-muted text-xs line-clamp-2 mb-3">{product.description}</p>
          <div class="flex flex-wrap gap-1">
            {product.tags.slice(0, 3).map(tag => (
              <span class="text-xs bg-bg-input text-text-muted px-2 py-0.5 rounded">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Value breakdown -->
  <div class="bg-bg-card rounded-2xl border border-border p-8 mb-16">
    <h2 class="text-2xl font-bold mb-6 text-center">Price Breakdown</h2>
    <div class="max-w-md mx-auto">
      {products.map(product => (
        <div class="flex justify-between py-2 border-b border-border text-sm">
          <span class="text-text-muted">{product.icon} {product.name}</span>
          <span class="font-semibold">${product.price}</span>
        </div>
      ))}
      <div class="flex justify-between py-3 text-text-muted text-sm mt-1">
        <span>Total if bought separately</span>
        <span class="line-through">${BUNDLE_ORIGINAL}</span>
      </div>
      <div class="flex justify-between py-3 border-t border-primary/30 text-lg font-bold">
        <span>DevPlaybook Pro Bundle</span>
        <span class="text-primary">${BUNDLE_PRICE}</span>
      </div>
      <div class="flex justify-between py-2 text-green-400 font-semibold text-sm">
        <span>You save</span>
        <span>${savings} ({savingsPct}% off)</span>
      </div>
    </div>
  </div>

  <!-- Bottom CTA -->
  <div class="text-center py-12 border-t border-border">
    <h2 class="text-3xl font-bold mb-4">Ready to ship faster?</h2>
    <p class="text-text-muted mb-8 max-w-lg mx-auto">
      Stop reinventing the wheel. Get every boilerplate, script, template, and guide
      in one place — and get back to building what matters.
    </p>
    <a
      href={BUNDLE_URL}
      target="_blank"
      rel="noopener noreferrer"
      data-track="bundle_bottom_cta"
      data-product-name="DevPlaybook Pro Bundle"
      data-product-price={String(BUNDLE_PRICE)}
      class="inline-block bg-primary hover:bg-primary-dark text-white font-bold px-10 py-5 rounded-2xl text-xl transition-colors"
    >
      Get DevPlaybook Pro — ${BUNDLE_PRICE} →
    </a>
    <p class="text-text-muted text-sm mt-4">Or <a href="/products" class="text-primary hover:underline">browse individual products</a> from $9</p>
  </div>
</BaseLayout>
