---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="You're on the DevPlaybook Pro Waitlist!"
  description="You've joined the DevPlaybook Pro early bird waitlist. We'll email you when your spot opens — first 100 members get 50% off forever."
>
  <div class="max-w-lg mx-auto text-center py-20">
    <div class="text-6xl mb-6">🎉</div>
    <h1 class="text-3xl md:text-4xl font-bold mb-4">You're on the list!</h1>
    <p class="text-text-muted text-lg mb-8 max-w-md mx-auto">
      Your early bird spot is reserved. We'll email you when DevPlaybook Pro launches — first 100 members get <strong class="text-primary">50% off forever</strong>.
    </p>

    <div class="bg-bg-card border border-border rounded-2xl p-6 mb-8 text-left max-w-sm mx-auto">
      <h2 class="font-semibold mb-3 text-sm uppercase tracking-wide text-text-muted">What you'll get at launch</h2>
      <ul class="space-y-2 text-sm">
        <li class="flex items-center gap-2"><span class="text-primary">⚡</span> AI Code Review</li>
        <li class="flex items-center gap-2"><span class="text-primary">⚡</span> AI Doc Generator</li>
        <li class="flex items-center gap-2"><span class="text-primary">⚡</span> AI SQL Builder</li>
        <li class="flex items-center gap-2"><span class="text-primary">⚡</span> Unlimited API access</li>
        <li class="flex items-center gap-2"><span class="text-primary">⚡</span> Premium templates</li>
        <li class="flex items-center gap-2"><span class="text-primary">⚡</span> Member discounts</li>
      </ul>
    </div>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a
        href="/tools"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-primary hover:bg-primary/90 text-white font-semibold transition-colors text-sm no-underline"
      >
        Explore Free Tools While You Wait →
      </a>
      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-border hover:border-primary text-sm font-medium transition-colors no-underline"
      >
        Back to Home
      </a>
    </div>
  </div>
</BaseLayout>
