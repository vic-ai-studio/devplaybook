---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProWaitlist from '../components/ProWaitlist.tsx';

const faqs = [
  { q: 'What do I get with Pro?', a: 'All premium templates, early access to new AI tools (Code Review, Doc Generator, SQL Builder), member-only product discounts, and priority support. Every future release is included automatically.' },
  { q: 'Can I cancel anytime?', a: 'Yes, cancel anytime with no questions. Your access continues until the end of the billing period. You can manage your subscription at app.gumroad.com/library.' },
  { q: 'What payment methods are accepted?', a: 'All major credit cards (Visa, Mastercard, Amex) via Gumroad. All payments are secure and PCI-compliant.' },
  { q: 'Is there a free trial?', a: 'Yes — 7 days free. No charge until the trial ends. Cancel before then and you owe nothing.' },
  { q: 'What AI tools are included in Pro?', a: 'AI Code Review (instant code feedback), AI Doc Generator (auto-generate README + API docs), and AI SQL Builder (natural language to SQL). More AI tools are added regularly.' },
];

const siteUrl = 'https://devplaybook.cc';
---

<BaseLayout
  title="DevPlaybook Pro — $9/month | Pricing"
  description="Upgrade to DevPlaybook Pro for $9/month. Unlock all premium AI tools, templates, early access content, and member-only discounts. 7 days free, cancel anytime."
  noDefaultJsonLd
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "FAQPage",
        "mainEntity": faqs.map(f => ({
          "@type": "Question",
          "name": f.q,
          "acceptedAnswer": { "@type": "Answer", "text": f.a }
        }))
      },
      {
        "@type": "Product",
        "name": "DevPlaybook Pro",
        "description": "Premium developer tools, AI-powered features, templates, and guides.",
        "url": `${siteUrl}/pricing`,
        "image": `${siteUrl}/og-default.svg`,
        "offers": {
          "@type": "Offer",
          "price": "9.00",
          "priceCurrency": "USD",
          "priceValidUntil": "2027-12-31",
          "availability": "https://schema.org/InStock",
          "url": `${siteUrl}/pricing`,
          "hasMerchantReturnPolicy": {
            "@type": "MerchantReturnPolicy",
            "applicableCountry": "US",
            "returnPolicyCategory": "https://schema.org/MerchantReturnNotPermitted",
            "merchantReturnDays": 0
          },
          "shippingDetails": {
            "@type": "OfferShippingDetails",
            "shippingRate": { "@type": "MonetaryAmount", "value": "0", "currency": "USD" },
            "shippingDestination": { "@type": "DefinedRegion", "addressCountry": "US" },
            "deliveryTime": { "@type": "ShippingDeliveryTime", "handlingTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 0, "unitCode": "DAY" }, "transitTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 0, "unitCode": "DAY" } }
          }
        }
      }
    ]
  })} />
  <div class="max-w-4xl mx-auto py-12">
    <!-- Hero -->
    <div class="text-center mb-12">
      <h1 class="text-4xl sm:text-5xl font-bold mb-4">
        Simple, <span class="text-primary">Honest</span> Pricing
      </h1>
      <p class="text-lg text-text-muted max-w-xl mx-auto">
        Everything you need to level up your dev workflow — tools, templates, and guides. One low monthly price.
      </p>
    </div>

    <!-- Pricing Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-3xl mx-auto mb-16">

      <!-- Free Plan -->
      <div class="bg-bg-card border border-border rounded-2xl p-8">
        <h2 class="text-2xl font-bold mb-2">Free</h2>
        <p class="text-text-muted mb-6">Core developer tools, forever free.</p>
        <div class="mb-8">
          <span class="text-4xl font-bold">$0</span>
          <span class="text-text-muted">/month</span>
        </div>
        <ul class="space-y-3 mb-8 text-sm">
          <li class="flex items-start gap-3"><span class="text-green-500 font-bold shrink-0">✓</span> All free developer tools</li>
          <li class="flex items-start gap-3"><span class="text-green-500 font-bold shrink-0">✓</span> Runs in your browser (private)</li>
          <li class="flex items-start gap-3"><span class="text-green-500 font-bold shrink-0">✓</span> Regex, Cron, Git, Docker &amp; more</li>
          <li class="flex items-start gap-3"><span class="text-green-500 font-bold shrink-0">✓</span> Blog &amp; guides</li>
          <li class="flex items-start gap-3"><span class="text-text-muted shrink-0">✗</span> <span class="text-text-muted">Premium templates</span></li>
          <li class="flex items-start gap-3"><span class="text-text-muted shrink-0">✗</span> <span class="text-text-muted">Early access content</span></li>
          <li class="flex items-start gap-3"><span class="text-text-muted shrink-0">✗</span> <span class="text-text-muted">Member discounts</span></li>
        </ul>
        <a href="/tools" class="block w-full text-center py-3 px-6 rounded-xl border border-border text-text font-medium hover:border-primary transition-colors duration-200">
          Browse Free Tools
        </a>
      </div>

      <!-- Pro Plan -->
      <div class="bg-bg-card border-2 border-primary rounded-2xl p-8 relative shadow-lg">
        <div class="absolute -top-4 left-1/2 -translate-x-1/2">
          <span class="inline-flex items-center px-4 py-1 rounded-full bg-primary text-white text-sm font-medium">
            Most Popular
          </span>
        </div>
        <h2 class="text-2xl font-bold mb-2">Pro</h2>
        <p class="text-text-muted mb-6">Everything, unlocked. For serious builders.</p>
        <div class="mb-8">
          <span class="text-4xl font-bold">$9</span>
          <span class="text-text-muted">/month</span>
        </div>
        <ul class="space-y-3 mb-8 text-sm">
          <li class="flex items-start gap-3"><span class="text-green-500 font-bold shrink-0">✓</span> Everything in Free</li>
          <li class="flex items-start gap-3"><span class="text-primary font-bold shrink-0">⚡</span> <strong>All premium templates &amp; tools</strong></li>
          <li class="flex items-start gap-3"><span class="text-primary font-bold shrink-0">⚡</span> Early access to new content</li>
          <li class="flex items-start gap-3"><span class="text-primary font-bold shrink-0">⚡</span> Member-only discounts on products</li>
          <li class="flex items-start gap-3"><span class="text-primary font-bold shrink-0">⚡</span> Priority support</li>
          <li class="flex items-start gap-3"><span class="text-primary font-bold shrink-0">⚡</span> Future releases included</li>
        </ul>
        <div class="flex flex-col gap-3">
          <input
            id="pricing-email"
            type="email"
            placeholder="your@email.com"
            class="w-full px-4 py-3 rounded-xl bg-bg border border-border text-text placeholder:text-text-muted focus:outline-none focus:border-primary transition-colors"
          />
          <button
            id="pricing-checkout-btn"
            class="w-full py-3 px-6 rounded-xl bg-primary hover:bg-primary-dark text-white font-bold transition-colors duration-200 shadow-lg"
          >
            Upgrade to Pro — $9/mo
          </button>
          <p id="pricing-checkout-error" class="text-xs text-red-400 hidden"></p>
        </div>
        <p class="text-center text-xs text-text-muted mt-3">7 days free · Secure payment via Gumroad · Cancel anytime</p>
      </div>
    </div>

    <!-- Pro Waitlist (shown while Gumroad is configuring / as secondary CTA) -->
    <div class="max-w-2xl mx-auto mb-12">
      <ProWaitlist variant="banner" client:load />
    </div>

    <!-- FAQ -->
    <div class="max-w-2xl mx-auto mb-16">
      <h2 class="text-2xl font-bold text-center mb-8">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqs.map(faq => (
          <details class="group bg-bg-card border border-border rounded-xl">
            <summary class="flex items-center justify-between cursor-pointer p-5 font-medium">
              {faq.q}
              <svg class="w-5 h-5 text-text-muted group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-5 text-text-muted text-sm">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </div>

  <!-- Checkout script -->
  <script is:inline>
    const btn = document.getElementById('pricing-checkout-btn');
    const emailInput = document.getElementById('pricing-email');

    if (btn) {
      btn.addEventListener('click', () => {
        const email = emailInput ? emailInput.value.trim() : '';
        let url = 'https://vicnail.gumroad.com/l/yvbwzb?recurrence=monthly';
        if (email) url += '&email=' + encodeURIComponent(email);
        window.location.href = url;
      });
    }
  </script>
</BaseLayout>
