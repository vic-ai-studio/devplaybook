---
import BaseLayout from '../../layouts/BaseLayout.astro';

const PRODUCT_NAME = 'Premium Workflow Pack';
const PRODUCT_PRICE = 19;
const PRODUCT_PRICE_NTD = Math.round(PRODUCT_PRICE * 32);
const GUMROAD_URL = 'https://vicnail.gumroad.com/l/premium-workflow-pack?utm_source=devplaybook&utm_medium=product_page&utm_campaign=workflow-pack';

const highlights = [
  {
    icon: '🔵',
    title: 'Blue-Green Deploy',
    desc: 'Zero-downtime deployments with automated traffic switching and health-check verification.',
  },
  {
    icon: '🐦',
    title: 'Canary Release',
    desc: 'Gradual rollout to 5% → 25% → 100% of traffic with automatic rollback on errors.',
  },
  {
    icon: '🎭',
    title: 'E2E with Playwright',
    desc: 'Sharded parallel Playwright tests across 4 workers with full artifact upload.',
  },
  {
    icon: '🛡️',
    title: 'Security Scanning',
    desc: 'Trivy + Grype container scanning + gitleaks secret detection on every PR.',
  },
  {
    icon: '🗄️',
    title: 'DB Migration CI',
    desc: 'Automated backup, dry-run mode, and rollback on migration failure.',
  },
  {
    icon: '↩️',
    title: 'Automated Rollback',
    desc: 'Health-check triggered rollback with Slack notifications. Set and forget.',
  },
];

const included = [
  '10 advanced GitHub Actions workflows',
  'Blue-green deployment with traffic switching',
  'Canary release with percentage-based rollout',
  'E2E testing with Playwright sharding',
  'Container security scanning (Trivy + Grype + gitleaks)',
  'Database migration CI with backup + dry-run',
  'Automated rollback with health-check verification',
  '5 architecture guides (microservices, monorepo, serverless, event-driven, API gateway)',
  'Code review checklist (security, performance, design, testing)',
  'PR workflow guide with conventional commits + PR template',
  '5 deployment Bash scripts (deploy, rollback, db-migrate, health-check, setup-env)',
  'Every script has # CUSTOMIZE: comments — no guessing what to change',
  'MIT licensed — commercial use OK',
  'Cloud-agnostic — AWS examples with swap-in guides for GCP, Azure, Kubernetes',
];

const testimonials = [
  {
    quote: "The blue-green workflow took me 20 minutes to set up. We've been running zero-downtime deploys for 3 months without a single incident.",
    author: "Senior DevOps Engineer",
    role: "Series B SaaS startup",
  },
  {
    quote: "The architecture guides are actually useful — not fluff. The event-driven one helped us redesign our notification pipeline in a weekend.",
    author: "Staff Engineer",
    role: "Remote contractor, 8 years exp",
  },
  {
    quote: "Canary releases were something we always wanted but never had time to set up. Copy-pasted the workflow, changed 3 env vars, shipped it.",
    author: "Engineering Lead",
    role: "10-person startup",
  },
];

const faqs = [
  {
    q: 'How is this different from a basic CI/CD template pack?',
    a: 'Standard CI packs cover build + test + deploy. This focuses on production deployment strategies (blue-green, canary, rollback), security scanning, and E2E testing — plus architecture guides and Bash scripts not found in template packs.',
  },
  {
    q: 'Do I need all 10 workflows?',
    a: 'No — pick what you need. Each workflow is self-contained. Use just the canary release, or just the security scanner. Nothing is interdependent.',
  },
  {
    q: 'Which cloud providers are supported?',
    a: 'Cloud-agnostic. AWS examples are shown in comments, but every workflow includes swap-in instructions for GCP, Azure, Kubernetes, and Cloudflare.',
  },
  {
    q: 'Are the Bash scripts production-safe?',
    a: 'Yes — they use set -euo pipefail, include dry-run modes, validate inputs, and back up databases before migrations. Designed for cautious production use.',
  },
  {
    q: 'What GitHub Actions runner do I need?',
    a: 'Standard ubuntu-latest runners. No self-hosted runner required. All workflows use first-party GitHub Actions where possible.',
  },
  {
    q: 'Is there a refund policy?',
    a: "Digital products are non-refundable. The page shows exactly what you're getting — if it's not the right fit, hold off until you're sure.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": PRODUCT_NAME,
  "description": "10 advanced GitHub Actions workflows for blue-green deploys, canary releases, E2E testing, and security scanning — plus architecture guides and production Bash scripts.",
  "url": "https://devplaybook.cc/products/workflow-pack",
  "image": "https://devplaybook.cc/og-default.svg",
  "brand": { "@type": "Brand", "name": "DevPlaybook" },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "11",
    "bestRating": "5",
    "worstRating": "1"
  },
  "review": {
    "@type": "Review",
    "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
    "author": { "@type": "Person", "name": "DevPlaybook User" },
    "reviewBody": "The blue-green workflow took me 20 minutes to set up. Zero-downtime deploys for 3 months without a single incident."
  },
  "offers": {
    "@type": "Offer",
    "price": PRODUCT_PRICE,
    "priceCurrency": "USD",
    "priceValidUntil": "2027-12-31",
    "availability": "https://schema.org/InStock",
    "url": GUMROAD_URL,
    "hasMerchantReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "applicableCountry": "US",
      "returnPolicyCategory": "https://schema.org/MerchantReturnNotPermitted",
      "merchantReturnDays": 0
    },
    "shippingDetails": {
      "@type": "OfferShippingDetails",
      "shippingRate": { "@type": "MonetaryAmount", "value": "0", "currency": "USD" },
      "shippingDestination": { "@type": "DefinedRegion", "addressCountry": "US" },
      "deliveryTime": {
        "@type": "ShippingDeliveryTime",
        "handlingTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 0, "unitCode": "DAY" },
        "transitTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 0, "unitCode": "DAY" }
      }
    }
  },
  "keywords": "github actions, ci-cd, devops, blue-green deployment, canary release, security scanning, bash scripts, architecture guide"
};
---

<BaseLayout
  title="Premium Workflow Pack — 10 Advanced GitHub Actions Workflows + Architecture Guides"
  description="Production deployment strategies developers actually need: blue-green deploys, canary releases, E2E with Playwright, security scanning, and 5 architecture guides. $19."
  noDefaultJsonLd
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Breadcrumb -->
  <nav class="mb-8 text-sm text-text-muted">
    <a href="/" class="hover:text-primary">Home</a>
    <span class="mx-2">/</span>
    <a href="/products" class="hover:text-primary">Products</a>
    <span class="mx-2">/</span>
    <span class="text-text">Premium Workflow Pack</span>
  </nav>

  <div class="max-w-4xl mx-auto">
    <!-- Hero -->
    <div class="text-center mb-14">
      <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-4">10 Workflows · 5 Architecture Guides · 5 Bash Scripts</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-5 leading-tight">
        Production Workflows<br />
        <span class="text-primary">That Actually Ship</span>
      </h1>
      <p class="text-text-muted text-xl max-w-2xl mx-auto mb-3">
        Blue-green deploys, canary releases, E2E testing, and security scanning.
        The advanced CI/CD patterns your team keeps putting off.
      </p>
      <p class="text-text-muted text-base max-w-xl mx-auto mb-10">
        Copy the workflow. Change 3 env vars. Ship to production tonight.
      </p>

      <!-- Price + CTA -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-4">
        <div class="text-center sm:text-left">
          <span class="block text-5xl font-bold text-primary">${PRODUCT_PRICE}</span>
          <span class="block text-text-muted text-sm mt-1">one-time · instant download</span>
        </div>
        <div class="flex flex-col gap-3">
          <a
            href={GUMROAD_URL}
            target="_blank"
            rel="noopener noreferrer"
            data-track="gumroad_hero_cta"
            class="inline-block bg-primary hover:bg-primary-dark text-white font-bold px-10 py-4 rounded-xl text-lg transition-colors shadow-lg"
          >
            Get the Pack — ${PRODUCT_PRICE} →
          </a>
          <button
            class="ecpay-buy-btn inline-block border border-green-500 text-green-500 hover:bg-green-500 hover:text-white font-semibold px-8 py-3 rounded-xl transition-colors cursor-pointer"
            data-product-slug="premium-workflow-pack"
            data-product-name={PRODUCT_NAME}
            data-product-price={String(PRODUCT_PRICE_NTD)}
            data-track="ecpay_hero_cta"
          >
            NT${PRODUCT_PRICE_NTD} — Taiwan Payment
          </button>
        </div>
      </div>
      <p class="text-text-muted text-xs">No subscription · No DRM · MIT licensed · Cloud-agnostic</p>
    </div>

    <!-- Social proof bar -->
    <div class="flex flex-wrap items-center justify-center gap-6 mb-14 py-5 border-y border-border text-sm text-text-muted">
      <span>🔵 Blue-green + Canary deploys</span>
      <span>🛡️ Security scanning built-in</span>
      <span>🏗️ 5 Architecture deep-dives</span>
      <span>🔑 MIT licensed — commercial use OK</span>
    </div>

    <!-- Problem / Solution -->
    <div class="mb-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-red-950/20 border border-red-800/30 rounded-xl p-6">
          <h2 class="font-bold text-lg mb-4 text-red-400">Without this pack</h2>
          <ul class="space-y-3 text-sm text-text-muted">
            <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5 shrink-0">✕</span> Downtime every deploy because you're doing hot-swap</li>
            <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5 shrink-0">✕</span> Security issues caught by users, not your pipeline</li>
            <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5 shrink-0">✕</span> No automated rollback — manual panic at 2am</li>
            <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5 shrink-0">✕</span> E2E tests exist locally but never run in CI</li>
            <li class="flex items-start gap-2"><span class="text-red-400 mt-0.5 shrink-0">✕</span> Architecture decisions made by whoever talks loudest</li>
          </ul>
        </div>
        <div class="bg-green-950/20 border border-green-700/30 rounded-xl p-6">
          <h2 class="font-bold text-lg mb-4 text-green-400">With Premium Workflow Pack</h2>
          <ul class="space-y-3 text-sm text-text-muted">
            <li class="flex items-start gap-2"><span class="text-green-400 mt-0.5 shrink-0">✓</span> Zero-downtime blue-green deploys from day one</li>
            <li class="flex items-start gap-2"><span class="text-green-400 mt-0.5 shrink-0">✓</span> Trivy + Grype + gitleaks scan every PR automatically</li>
            <li class="flex items-start gap-2"><span class="text-green-400 mt-0.5 shrink-0">✓</span> Health-check triggered rollback — no more 2am panics</li>
            <li class="flex items-start gap-2"><span class="text-green-400 mt-0.5 shrink-0">✓</span> Sharded Playwright tests running in CI in parallel</li>
            <li class="flex items-start gap-2"><span class="text-green-400 mt-0.5 shrink-0">✓</span> Architecture guides to back up your design decisions</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Workflow Highlights -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold text-center mb-3">Workflow <span class="text-primary">Highlights</span></h2>
      <p class="text-text-muted text-center mb-10">10 production-grade workflows. Pick what you need — nothing is interdependent.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {highlights.map(h => (
          <div class="bg-bg-card rounded-xl p-5 border border-border">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-2xl">{h.icon}</span>
              <h3 class="font-semibold">{h.title}</h3>
            </div>
            <p class="text-xs text-text-muted leading-relaxed">{h.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Code preview -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-center mb-10">See What You're Getting</h2>
      <div class="bg-bg-card border border-border rounded-xl p-5 max-w-3xl mx-auto overflow-x-auto">
        <p class="text-xs text-text-muted mb-3 font-mono">canary-release.yml — excerpt</p>
        <pre class="text-sm font-mono text-text whitespace-pre-wrap"><code>jobs:
  deploy-canary:
    runs-on: ubuntu-latest
    steps:
      - name: Deploy to 5% traffic
        run: |
          # CUSTOMIZE: swap in your cloud provider here
          aws ecs update-service \
            --cluster $CLUSTER \
            --service $SERVICE_CANARY \
            --desired-count 1

      - name: Monitor error rate (5 min)
        run: ./scripts/health-check.sh --threshold 1%

      - name: Promote to 100% on success
        if: success()
        run: ./scripts/deploy.sh --promote-canary</code></pre>
      </div>
    </section>

    <!-- Everything included -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">Everything Included</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {included.map(item => (
          <div class="flex items-start gap-3 bg-bg-card rounded-lg p-4 border border-border">
            <span class="text-primary mt-0.5 shrink-0">✓</span>
            <span class="text-sm">{item}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Testimonials -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-center mb-10">What Engineers Say</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {testimonials.map(t => (
          <div class="bg-bg-card border border-border rounded-xl p-5">
            <p class="text-sm text-text-muted mb-4 italic">"{t.quote}"</p>
            <div>
              <p class="font-semibold text-sm">{t.author}</p>
              <p class="text-xs text-text-muted">{t.role}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Mid-page CTA -->
    <section class="mb-16 text-center bg-bg-card border border-primary/20 rounded-2xl p-10">
      <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-3">One-time purchase</p>
      <h2 class="text-3xl font-bold mb-3">10 workflows. 5 guides. ${PRODUCT_PRICE}.</h2>
      <p class="text-text-muted mb-8 max-w-lg mx-auto">
        Everything you need to run production deployments like a senior team.
        MIT licensed. Use in commercial projects. No recurring fees.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={GUMROAD_URL}
          target="_blank"
          rel="noopener noreferrer"
          data-track="gumroad_mid_cta"
          class="inline-block bg-primary hover:bg-primary-dark text-white font-bold px-10 py-4 rounded-xl text-lg transition-colors"
        >
          Get the Pack — ${PRODUCT_PRICE} →
        </a>
        <button
          class="ecpay-buy-btn inline-block border border-green-500 text-green-500 hover:bg-green-500 hover:text-white font-semibold px-8 py-3 rounded-xl transition-colors cursor-pointer"
          data-product-slug="premium-workflow-pack"
          data-product-name={PRODUCT_NAME}
          data-product-price={String(PRODUCT_PRICE_NTD)}
          data-track="ecpay_mid_cta"
        >
          NT${PRODUCT_PRICE_NTD} — Taiwan Payment
        </button>
      </div>
      <p class="text-text-muted text-xs mt-4">No subscription · No DRM · Instant download</p>
    </section>

    <!-- FAQ -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">FAQ</h2>
      <div class="space-y-4">
        {faqs.map(item => (
          <div class="bg-bg-card border border-border rounded-lg p-5">
            <h3 class="font-semibold mb-2">{item.q}</h3>
            <p class="text-text-muted text-sm">{item.a}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Tags -->
    <section class="mb-12">
      <div class="flex flex-wrap gap-2">
        {['github-actions', 'ci-cd', 'devops', 'blue-green', 'canary', 'security-scanning', 'bash', 'deployment', 'architecture', 'production'].map(tag => (
          <span class="text-xs bg-bg-input text-text-muted px-3 py-1 rounded-full">{tag}</span>
        ))}
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="text-center mb-8 py-10 border-t border-border">
      <h2 class="text-3xl font-bold mb-4">Ship to production with confidence.</h2>
      <p class="text-text-muted mb-8 max-w-lg mx-auto">
        10 advanced GitHub Actions workflows + 5 architecture guides + 5 deployment scripts.
        MIT licensed. One-time payment.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={GUMROAD_URL}
          target="_blank"
          rel="noopener noreferrer"
          data-track="gumroad_bottom_cta"
          class="inline-block bg-primary hover:bg-primary-dark text-white font-bold px-10 py-5 rounded-xl text-xl transition-colors shadow-lg"
        >
          Get the Pack — ${PRODUCT_PRICE} →
        </a>
        <button
          class="ecpay-buy-btn inline-block border border-green-500 text-green-500 hover:bg-green-500 hover:text-white font-semibold px-8 py-4 rounded-xl transition-colors cursor-pointer"
          data-product-slug="premium-workflow-pack"
          data-product-name={PRODUCT_NAME}
          data-product-price={String(PRODUCT_PRICE_NTD)}
          data-track="ecpay_bottom_cta"
        >
          NT${PRODUCT_PRICE_NTD} Taiwan
        </button>
      </div>
      <p class="text-text-muted text-sm mt-4">
        <a href="/products" class="hover:text-primary">&larr; Browse all products</a>
      </p>
    </section>

    <!-- ECPay Checkout Script -->
    <script>
      document.querySelectorAll('.ecpay-buy-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const slug = (btn as HTMLElement).dataset.productSlug;
          const name = (btn as HTMLElement).dataset.productName;
          const price = parseInt((btn as HTMLElement).dataset.productPrice ?? '0', 10);

          (btn as HTMLButtonElement).disabled = true;
          btn.textContent = 'Processing...';

          try {
            const res = await fetch('/api/ecpay-checkout', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ productSlug: slug, productName: name, price }),
            });

            if (!res.ok) {
              const err = await res.json();
              throw new Error(err.error || 'Checkout failed');
            }

            const html = await res.text();
            document.open();
            document.write(html);
            document.close();
          } catch (err) {
            alert('Payment error: ' + (err as Error).message);
            (btn as HTMLButtonElement).disabled = false;
            btn.textContent = `NT$${price} Taiwan Payment`;
          }
        });
      });
    </script>
  </div>
</BaseLayout>
