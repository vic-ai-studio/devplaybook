          'Works with Claude, GPT-4o, Gemini, Cursor, Copilot Chat',
          'MIT licensed — use across your whole team',
          'Organized into 55 individual Markdown files',
        ].map(item => (
          <div class="flex items-start gap-3 bg-bg-card rounded-lg p-4 border border-border">
            <span class="text-primary mt-0.5 shrink-0">✓</span>
            <span class="text-sm">{item}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">FAQ</h2>
      <div class="space-y-4">
        {faqs.map(item => (
          <div class="bg-bg-card border border-border rounded-lg p-5">
            <h3 class="font-semibold mb-2">{item.q}</h3>
            <p class="text-text-muted text-sm">{item.a}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Tags -->
    <section class="mb-12">
      <div class="flex flex-wrap gap-2">
        {['ai', 'prompts', 'claude', 'chatgpt', 'code-review', 'debugging', 'architecture', 'documentation', 'testing', 'productivity', 'llm', 'vscode'].map(tag => (
          <span class="text-xs bg-bg-input text-text-muted px-3 py-1 rounded-full">{tag}</span>
        ))}
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="text-center mb-8 py-10 border-t border-border">
      <h2 class="text-3xl font-bold mb-4">Stop writing prompts from scratch.</h2>
      <p class="text-text-muted mb-8 max-w-lg mx-auto">
        Get 55 production-ready developer prompt templates. Use them solo or standardize your whole team's AI workflow.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={GUMROAD_URL}
          target="_blank"
          rel="noopener noreferrer"
          data-track="gumroad_bottom_cta"
          class="inline-block bg-primary hover:bg-primary-dark text-white font-bold px-10 py-5 rounded-xl text-xl transition-colors shadow-lg"
        >
          Get the Pack — ${PRODUCT_PRICE} →
        </a>
        <button
          class="ecpay-buy-btn inline-block border border-green-500 text-green-500 hover:bg-green-500 hover:text-white font-semibold px-8 py-4 rounded-xl transition-colors cursor-pointer"
