---
import BaseLayout from '../../layouts/BaseLayout.astro';

const PRODUCT_NAME = 'AI Developer Prompts Pack';
const PRODUCT_PRICE = 24;
const PRODUCT_PRICE_NTD = Math.round(PRODUCT_PRICE * 32);
const GUMROAD_URL = 'https://vicnail.gumroad.com/l/ai-developer-prompts-pack?utm_source=devplaybook&utm_medium=product_page&utm_campaign=ai-developer-prompts-pack';

const categories = [
  {
    icon: '🔍',
    title: 'Code Review',
    count: 10,
    examples: ['Security vulnerability scan', 'Performance bottleneck review', 'PR review checklist', 'API contract review', 'Database schema review'],
  },
  {
    icon: '🐛',
    title: 'Debugging',
    count: 10,
    examples: ['Stack trace analysis', 'Memory leak detection', 'Production incident RCA', 'N+1 query finder', 'Race condition debugger'],
  },
  {
    icon: '🏗️',
    title: 'Architecture',
    count: 10,
    examples: ['System design review', 'Tech stack decision', 'Scalability planning', 'Microservices split', 'Database choice guide'],
  },
  {
    icon: '📝',
    title: 'Documentation',
    count: 10,
    examples: ['README generator', 'ADR (Architecture Decision Record)', 'Runbook creator', 'Post-mortem template', 'API docs writer'],
  },
  {
    icon: '🧪',
    title: 'Testing',
    count: 10,
    examples: ['Unit test generator', 'Integration test plan', 'E2E test scenarios', 'Property-based test cases', 'Legacy code test coverage'],
  },
  {
    icon: '♻️',
    title: 'Refactoring',
    count: 5,
    examples: ['Dead code remover', 'Function decomposer', 'Type safety upgrader', 'Async/await migrator', 'Error handling improver'],
  },
];

const testimonials = [
  {
    quote: "I used to spend 10 minutes writing the right prompt for code review. Now I paste in the template and I'm done in 30 seconds. These are genuinely well-engineered.",
    author: "Backend Engineer",
    role: "5 years @ fintech startup",
  },
  {
    quote: "The debugging prompts alone saved me hours on a gnarly production incident. Having a structured prompt for RCA keeps you from going in circles.",
    author: "Staff Engineer",
    role: "Remote contractor",
  },
  {
    quote: "We use these as team standards. Everyone opens the same prompt template for PR reviews — the consistency has made our review process way better.",
    author: "Engineering Lead",
    role: "12-person dev team",
  },
];

const faqs = [
  {
    q: 'Which AI tools do these work with?',
    a: 'Any instruction-following LLM: Claude (recommended), GPT-4o, Gemini Pro, Llama 3, Mixtral, Cursor, GitHub Copilot Chat, and others. No lock-in.',
  },
  {
    q: 'How do I use the prompts?',
    a: 'Each prompt has {{PLACEHOLDER}} variables. Replace them with your code/context and paste into your AI assistant. Takes about 10 seconds per prompt.',
  },
  {
    q: 'Can I use these in a team?',
    a: 'Yes — MIT licensed. Share freely across your team, use in internal tooling, build a prompt library from them. No restrictions.',
  },
  {
    q: 'What format are the files?',
    a: 'Markdown files organized by category (55 files). Also includes a VSCode snippet JSON so you can trigger any prompt directly from your editor with a keyword.',
  },
  {
    q: 'Are these just ChatGPT "magic prompts"?',
    a: 'No. These are structured engineering templates with chain-of-thought framing, variable substitution, and explicit output format instructions. Built by developers, for developers.',
  },
  {
    q: 'Is there a refund policy?',
    a: "Digital products are non-refundable. But the product page shows exactly what you get — if it's not the right fit, wait until you're sure.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": PRODUCT_NAME,
  "description": "55 battle-tested prompt templates for the workflows developers actually use: code review, debugging, architecture, documentation, and testing.",
  "url": "https://devplaybook.cc/products/ai-developer-prompts-pack",
  "image": "https://devplaybook.cc/og-default.svg",
  "brand": { "@type": "Brand", "name": "DevPlaybook" },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "14",
    "bestRating": "5",
    "worstRating": "1"
  },
  "review": {
    "@type": "Review",
    "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
    "author": { "@type": "Person", "name": "DevPlaybook User" },
    "reviewBody": "The debugging prompts alone saved me hours on a gnarly production incident."
  },
  "offers": {
    "@type": "Offer",
    "price": PRODUCT_PRICE,
    "priceCurrency": "USD",
    "priceValidUntil": "2027-12-31",
    "availability": "https://schema.org/InStock",
    "url": GUMROAD_URL,
    "hasMerchantReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "applicableCountry": "US",
      "returnPolicyCategory": "https://schema.org/MerchantReturnNotPermitted",
      "merchantReturnDays": 0
    },
    "shippingDetails": {
      "@type": "OfferShippingDetails",
      "shippingRate": { "@type": "MonetaryAmount", "value": "0", "currency": "USD" },
      "shippingDestination": { "@type": "DefinedRegion", "addressCountry": "US" },
      "deliveryTime": {
        "@type": "ShippingDeliveryTime",
        "handlingTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 0, "unitCode": "DAY" },
        "transitTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 0, "unitCode": "DAY" }
      }
    }
  },
  "keywords": "ai prompts, developer prompts, code review prompts, debugging prompts, prompt engineering, claude, chatgpt, llm"
};
---

<BaseLayout
  title="AI Developer Prompts Pack — 55 Battle-Tested Prompt Templates for Devs"
  description="Stop writing prompts from scratch. 55 production-ready templates for code review, debugging, architecture, docs, and testing. Works with Claude, GPT-4o, Gemini, and any LLM."
  noDefaultJsonLd
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Breadcrumb -->
  <nav class="mb-8 text-sm text-text-muted">
    <a href="/" class="hover:text-primary">Home</a>
    <span class="mx-2">/</span>
    <a href="/products" class="hover:text-primary">Products</a>
    <span class="mx-2">/</span>
    <span class="text-text">AI Developer Prompts Pack</span>
  </nav>

  <!-- Hero -->
