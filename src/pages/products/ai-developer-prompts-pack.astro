            NT${PRODUCT_PRICE_NTD} — Taiwan Payment
          </button>
        </div>
      </div>
      <p class="text-text-muted text-xs">No subscription · No DRM · MIT licensed · 55 files</p>
    </div>

    <!-- Social proof bar -->
    <div class="flex flex-wrap items-center justify-center gap-6 mb-14 py-5 border-y border-border text-sm text-text-muted">
      <span>💬 Works with Claude, GPT-4o, Gemini</span>
      <span>📁 55 templates across 6 categories</span>
      <span>⚡ VSCode snippet format included</span>
      <span>🔑 MIT licensed — use in teams</span>
    </div>

    <!-- Problem / Solution -->
    <div class="mb-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-red-950/20 border border-red-800/30 rounded-xl p-6">
          <h2 class="font-bold text-lg mb-4 text-red-400">Without this pack</h2>
          <ul class="space-y-3 text-sm text-text-muted">
