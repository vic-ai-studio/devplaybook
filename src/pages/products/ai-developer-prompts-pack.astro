          data-product-name={PRODUCT_NAME}
          data-product-price={String(PRODUCT_PRICE_NTD)}
          data-track="ecpay_mid_cta"
        >
          NT${PRODUCT_PRICE_NTD} — Taiwan Payment
        </button>
      </div>
      <p class="text-text-muted text-xs mt-4">No subscription · No DRM · Instant download</p>
    </section>

    <!-- What you get summary -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">Everything in the Pack</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {[
          '10 code review prompts (security, performance, PR, API, DB)',
          '10 debugging prompts (stack traces, memory leaks, incidents)',
          '10 architecture prompts (system design, tech choice, scaling)',
          '10 documentation prompts (README, ADR, runbooks, post-mortems)',
