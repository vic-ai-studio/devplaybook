            <li class="flex items-start gap-2"><span class="text-green-400 mt-0.5 shrink-0">✓</span> Checklists baked in — nothing falls through the cracks</li>
            <li class="flex items-start gap-2"><span class="text-green-400 mt-0.5 shrink-0">✓</span> VSCode snippets so prompts trigger from the editor</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- What's included — by category -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold text-center mb-3">What's <span class="text-primary">Inside</span></h2>
      <p class="text-text-muted text-center mb-10">55 templates across 6 developer workflow categories</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {categories.map(cat => (
