          <span class="block text-5xl font-bold text-primary">${PRODUCT_PRICE}</span>
          <span class="block text-text-muted text-sm mt-1">one-time · instant download</span>
        </div>
        <div class="flex flex-col gap-3">
          <a
            href={GUMROAD_URL}
            target="_blank"
            rel="noopener noreferrer"
            data-track="gumroad_hero_cta"
            class="inline-block bg-primary hover:bg-primary-dark text-white font-bold px-10 py-4 rounded-xl text-lg transition-colors shadow-lg"
