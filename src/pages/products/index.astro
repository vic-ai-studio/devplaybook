---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { products } from '../../data/products';
---

<BaseLayout title="Developer Products" description="Premium developer tools, templates, and resources. Boilerplates, automation scripts, AI toolkits, and productivity packs for modern developers." noDefaultJsonLd>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Developer Products",
    "url": "https://devplaybook.cc/products",
    "description": "Premium developer tools, templates, and resources.",
    "itemListElement": products.map((product, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": product.name,
      "url": `https://devplaybook.cc/products/${product.slug}`,
      "item": {
        "@type": "Product",
        "name": product.name,
        "description": product.description,
        "url": `https://devplaybook.cc/products/${product.slug}`,
        "offers": {
          "@type": "Offer",
          "price": product.price,
          "priceCurrency": "USD",
          "availability": "https://schema.org/InStock"
        }
      }
    }))
  })} />
  <div class="text-center mb-12">
    <h1 class="text-4xl font-bold mb-4">Developer <span class="text-primary">Products</span></h1>
    <p class="text-text-muted text-lg max-w-2xl mx-auto">Premium tools, templates, and resources to ship faster. All MIT licensed.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {products.map(product => (
      <a href={`/products/${product.slug}`} class="block bg-bg-card rounded-xl p-6 border border-border hover:border-primary transition-colors group">
        <div class="flex items-start justify-between mb-3">
          <span class="text-3xl">{product.icon}</span>
          <span class="text-primary font-bold text-lg">${product.price}</span>
        </div>
        <h2 class="text-lg font-semibold mb-2 group-hover:text-primary transition-colors">{product.name}</h2>
        <p class="text-text-muted text-sm mb-4 line-clamp-2">{product.description}</p>
        <div class="flex flex-wrap gap-1.5">
          {product.tags.slice(0, 3).map(tag => (
            <span class="text-xs bg-bg-input text-text-muted px-2 py-0.5 rounded">{tag}</span>
          ))}
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
