---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { products } from '../../data/products';

const BUNDLE_URL = 'https://vicnail.gumroad.com/l/devplaybook-pro-bundle?utm_source=devplaybook&utm_medium=products_page&utm_campaign=pro-bundle';
const BUNDLE_PRICE = 79;
const BUNDLE_ORIGINAL = products.reduce((sum, p) => sum + p.price, 0);
const savingsPct = Math.round(((BUNDLE_ORIGINAL - BUNDLE_PRICE) / BUNDLE_ORIGINAL) * 100);
---

<BaseLayout title="Developer Products" description="Premium developer tools, templates, and resources. Boilerplates, automation scripts, AI toolkits, and productivity packs for modern developers." noDefaultJsonLd>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Developer Products",
    "url": "https://devplaybook.cc/products",
    "description": "Premium developer tools, templates, and resources.",
    "itemListElement": products.map((product, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": product.name,
      "url": `https://devplaybook.cc/products/${product.slug}`,
      "item": {
        "@type": "Product",
        "name": product.name,
        "description": product.description,
        "url": `https://devplaybook.cc/products/${product.slug}`,
        "image": "https://devplaybook.cc/og-default.svg",
        "offers": {
          "@type": "Offer",
          "price": product.price,
          "priceCurrency": "USD",
          "priceValidUntil": "2027-12-31",
          "availability": "https://schema.org/InStock",
          "hasMerchantReturnPolicy": {
            "@type": "MerchantReturnPolicy",
            "applicableCountry": "US",
            "returnPolicyCategory": "https://schema.org/MerchantReturnNotPermitted",
            "merchantReturnDays": 0
          },
          "shippingDetails": {
            "@type": "OfferShippingDetails",
            "shippingRate": { "@type": "MonetaryAmount", "value": "0", "currency": "USD" },
            "shippingDestination": { "@type": "DefinedRegion", "addressCountry": "US" },
            "deliveryTime": { "@type": "ShippingDeliveryTime", "handlingTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 0, "unitCode": "DAY" }, "transitTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 0, "unitCode": "DAY" } }
          }
        }
      }
    }))
  })} />
  <div class="text-center mb-8">
    <h1 class="text-4xl font-bold mb-4">Developer <span class="text-primary">Products</span></h1>
    <p class="text-text-muted text-lg max-w-2xl mx-auto">Premium tools, templates, and resources to ship faster. All MIT licensed.</p>
  </div>

  <!-- Bundle Hero CTA -->
  <div class="mb-10 rounded-2xl border border-primary/40 bg-gradient-to-br from-primary/5 to-bg-card p-6 flex flex-col sm:flex-row items-center gap-5">
    <div class="flex-1 text-center sm:text-left">
      <span class="inline-block text-xs font-bold uppercase tracking-widest text-primary mb-2 bg-primary/10 px-3 py-1 rounded-full">Best Value</span>
      <h2 class="text-2xl font-bold mb-1">Get all {products.length} products — ${BUNDLE_PRICE}</h2>
      <p class="text-text-muted text-sm">Save {savingsPct}% vs buying individually. One-time payment · MIT licensed · Instant download.</p>
    </div>
    <div class="shrink-0 flex flex-col items-center gap-2">
      <a
        href={BUNDLE_URL}
        target="_blank"
        rel="noopener noreferrer"
        data-track="bundle_cta_click"
        data-cta-location="products_index_hero"
        class="inline-block bg-primary hover:bg-primary-dark text-white font-bold px-7 py-3 rounded-xl transition-colors whitespace-nowrap"
      >
        Get Full Bundle — ${BUNDLE_PRICE} →
      </a>
      <a href="/deals" class="text-xs text-primary hover:underline">Browse all deals →</a>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {products.map(product => (
      <div class="bg-bg-card rounded-xl border border-border hover:border-primary transition-colors group flex flex-col">
        <a href={`/products/${product.slug}`} class="block p-6 flex-1">
          <div class="flex items-start justify-between mb-3">
            <span class="text-3xl">{product.icon}</span>
            <span class="text-primary font-bold text-lg">${product.price}</span>
          </div>
          <h2 class="text-lg font-semibold mb-2 group-hover:text-primary transition-colors">{product.name}</h2>
          <p class="text-text-muted text-sm mb-4 line-clamp-2">{product.description}</p>
          <div class="flex flex-wrap gap-1.5">
            {product.tags.slice(0, 3).map(tag => (
              <span class="text-xs bg-bg-input text-text-muted px-2 py-0.5 rounded">{tag}</span>
            ))}
          </div>
        </a>
        <div class="px-6 pb-5 flex gap-2">
          <a
            href={product.gumroadUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-track="gumroad_buy_click"
            data-product-name={product.name}
            data-product-price={String(product.price)}
            data-cta-location="products_index"
            class="flex-1 bg-primary hover:bg-primary-dark text-white text-sm font-semibold px-4 py-2.5 rounded-lg transition-colors text-center"
          >
            Buy — ${product.price}
          </a>
          <a
            href={`/products/${product.slug}`}
            class="px-4 py-2.5 bg-bg border border-border hover:border-primary text-sm rounded-lg transition-colors text-center"
          >
            Details
          </a>
        </div>
      </div>
    ))}
  </div>
</BaseLayout>
