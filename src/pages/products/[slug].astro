---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { products } from '../../data/products';
import type { Product } from '../../data/products';

export function getStaticPaths() {
  return products.map(product => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
const siteUrl = 'https://devplaybook.cc';
const productUrl = `${siteUrl}/products/${product.slug}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.name,
  "description": product.description,
  "url": productUrl,
  "image": `${siteUrl}/og-default.svg`,
  "brand": {
    "@type": "Brand",
    "name": "DevPlaybook"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "reviewCount": "12",
    "bestRating": "5",
    "worstRating": "1"
  },
  "review": {
    "@type": "Review",
    "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
    "author": { "@type": "Person", "name": "DevPlaybook User" },
    "reviewBody": "Well-structured and saves a ton of setup time. Exactly what I needed."
  },
  "offers": {
    "@type": "Offer",
    "price": product.price,
    "priceCurrency": "USD",
    "priceValidUntil": "2027-12-31",
    "availability": "https://schema.org/InStock",
    "url": product.gumroadUrl,
    "hasMerchantReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "applicableCountry": "US",
      "returnPolicyCategory": "https://schema.org/MerchantReturnNotPermitted",
      "merchantReturnDays": 0
    },
    "shippingDetails": {
      "@type": "OfferShippingDetails",
      "shippingRate": {
        "@type": "MonetaryAmount",
        "value": "0",
        "currency": "USD"
      },
      "shippingDestination": {
        "@type": "DefinedRegion",
        "addressCountry": "US"
      },
      "deliveryTime": {
        "@type": "ShippingDeliveryTime",
        "handlingTime": {
          "@type": "QuantitativeValue",
          "minValue": 0,
          "maxValue": 0,
          "unitCode": "DAY"
        },
        "transitTime": {
          "@type": "QuantitativeValue",
          "minValue": 0,
          "maxValue": 0,
          "unitCode": "DAY"
        }
      }
    }
  },
  "category": "Software",
  "keywords": product.tags.join(', ')
};
---

<BaseLayout title={product.name} description={product.description} noDefaultJsonLd>
  <!-- JSON-LD Product Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Breadcrumb -->
  <nav class="mb-8 text-sm text-text-muted">
    <a href="/" class="hover:text-primary">Home</a>
    <span class="mx-2">/</span>
    <a href="/products" class="hover:text-primary">Products</a>
    <span class="mx-2">/</span>
    <span class="text-text">{product.name}</span>
  </nav>

  <div class="max-w-4xl mx-auto">
    <!-- Hero Section -->
    <div class="text-center mb-12">
      <span class="text-5xl mb-4 block">{product.icon}</span>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">{product.name}</h1>
      <p class="text-text-muted text-lg max-w-2xl mx-auto mb-6">{product.description}</p>
      <div class="flex items-center justify-center gap-4 flex-wrap">
        <span class="text-3xl font-bold text-primary">${product.price}</span>
        <button
          class="ecpay-buy-btn inline-block bg-primary hover:bg-primary-dark text-white font-semibold px-8 py-3 rounded-lg transition-colors cursor-pointer"
          data-track="ecpay_click"
          data-product-slug={product.slug}
          data-product-name={product.name}
          data-product-price={String(Math.round(product.price * 32))}
        >
          Buy Now (NT${Math.round(product.price * 32)})
        </button>
        <a
          href={product.gumroadUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block border border-primary text-primary hover:bg-primary hover:text-white font-semibold px-6 py-3 rounded-lg transition-colors text-sm"
          data-track="gumroad_click"
          data-product-name={product.name}
          data-product-price={String(product.price)}
        >
          Pay with USD (${product.price})
        </a>
      </div>
    </div>

    <!-- Features -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">What's Included</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {product.features.map(feature => (
          <div class="flex items-start gap-3 bg-bg-card rounded-lg p-4 border border-border">
            <span class="text-secondary mt-0.5 shrink-0">&#10003;</span>
            <span class="text-sm">{feature}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA Mid-page -->
    <section class="mb-12 text-center bg-bg-card border border-border rounded-xl p-8">
      <p class="text-xl font-semibold mb-2">Ready to ship faster?</p>
      <p class="text-text-muted mb-6">One-time purchase. MIT licensed. Instant download.</p>
      <div class="flex items-center justify-center gap-3 flex-wrap">
        <button
          class="ecpay-buy-btn inline-block bg-primary hover:bg-primary-dark text-white font-semibold px-8 py-3 rounded-lg transition-colors cursor-pointer"
          data-track="ecpay_click"
          data-product-slug={product.slug}
          data-product-name={product.name}
          data-product-price={String(Math.round(product.price * 32))}
        >
          Get {product.name} — NT${Math.round(product.price * 32)}
        </button>
        <a
          href={product.gumroadUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block border border-primary text-primary hover:bg-primary hover:text-white font-semibold px-6 py-3 rounded-lg transition-colors text-sm"
          data-track="gumroad_click"
        >
          USD ${product.price}
        </a>
      </div>
    </section>

    <!-- FAQ -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">FAQ</h2>
      <div class="space-y-4">
        {product.faq.map(item => (
          <div class="bg-bg-card border border-border rounded-lg p-5">
            <h3 class="font-semibold mb-2">{item.q}</h3>
            <p class="text-text-muted text-sm">{item.a}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Tags -->
    <section class="mb-12">
      <div class="flex flex-wrap gap-2">
        {product.tags.map(tag => (
          <span class="text-xs bg-bg-input text-text-muted px-3 py-1 rounded-full">{tag}</span>
        ))}
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="text-center mb-8">
      <button
        class="ecpay-buy-btn inline-block bg-primary hover:bg-primary-dark text-white font-bold text-lg px-10 py-4 rounded-lg transition-colors cursor-pointer"
        data-track="ecpay_click"
        data-product-slug={product.slug}
        data-product-name={product.name}
        data-product-price={String(Math.round(product.price * 32))}
      >
        Buy {product.name} — NT${Math.round(product.price * 32)}
      </button>
      <p class="text-text-muted text-sm mt-3">
        <a href="/products" class="hover:text-primary">&larr; Back to all products</a>
      </p>
    </section>

    <!-- ECPay Checkout Script -->
    <script>
      document.querySelectorAll('.ecpay-buy-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const slug = btn.dataset.productSlug;
          const name = btn.dataset.productName;
          const price = parseInt(btn.dataset.productPrice, 10);

          btn.disabled = true;
          btn.textContent = 'Processing...';

          try {
            const res = await fetch('/api/ecpay-checkout', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                productSlug: slug,
                productName: name,
                price: price,
              }),
            });

            if (!res.ok) {
              const err = await res.json();
              throw new Error(err.error || 'Checkout failed');
            }

            // Response is HTML form that auto-submits to ECPay
            const html = await res.text();
            document.open();
            document.write(html);
            document.close();
          } catch (err) {
            alert('Payment error: ' + err.message);
            btn.disabled = false;
            btn.textContent = `Buy Now (NT$${price})`;
          }
        });
      });
    </script>
  </div>
</BaseLayout>
