---
import BaseLayout from '../../layouts/BaseLayout.astro';

const PRODUCT_NAME = 'TypeScript Quick Reference Toolkit';
const PRODUCT_PRICE = 14;
const PRODUCT_PRICE_NTD = Math.round(PRODUCT_PRICE * 32);
const GUMROAD_URL = 'https://vicnail.gumroad.com/l/typescript-quick-reference-toolkit?utm_source=devplaybook&utm_medium=product_page&utm_campaign=typescript-quick-reference-toolkit';

const files = [
  {
    icon: '📄',
    name: 'TypeScript Cheatsheet',
    detail: 'A4 · 2 pages',
    desc: 'Basic types, interfaces, generics, functions, union/intersection, type narrowing, enums, classes, async — all the syntax you reach for daily.',
  },
  {
    icon: '📊',
    name: 'TypeScript vs JavaScript Comparison',
    detail: '1 page',
    desc: 'Side-by-side syntax, key differences, 5 real bugs TS would have caught, JS→TS migration checklist, and a decision guide.',
  },
  {
    icon: '💡',
    name: '20 Utility Types with Real Examples',
    detail: '2 pages',
    desc: 'Every built-in utility type (Partial, Pick, Omit, Record, ReturnType...) with real-world code patterns. Plus 4 custom utilities and template literal types.',
  },
  {
    icon: '⚙️',
    name: 'tsconfig.json Best Practices Template',
    detail: 'JSON file',
    desc: 'Production-ready config with every setting commented. Preset notes for Node.js, React/Vite, Next.js, and library authors.',
  },
  {
    icon: '🐛',
    name: '15 Common TypeScript Mistakes & Fixes',
    detail: '3 pages',
    desc: 'Before/after code for the bugs that trip up every TS developer: any abuse, null checks, enum pitfalls, async types, non-null assertions, and more.',
  },
];

const faqs = [
  {
    q: 'Is this for beginners or experienced developers?',
    a: 'Both. Beginners get the full syntax overview and mistake guide to avoid common pitfalls. Experienced devs get the utility types deep-dive and tsconfig best practices they always look up.',
  },
  {
    q: 'What format are the files?',
    a: 'Markdown files — open in VS Code, Obsidian, Notion, or any text editor. Convert to PDF with Pandoc or your browser print function (Ctrl+P → Save as PDF).',
  },
  {
    q: 'Does the tsconfig work with Next.js / Vite / Node.js?',
    a: 'Yes — the template includes preset notes for each environment with the specific settings to change (module, moduleResolution, jsx, lib). Copy the base and adjust for your stack.',
  },
  {
    q: 'Is JavaScript knowledge required?',
    a: 'Yes — TypeScript builds on JavaScript. Some JS familiarity is assumed (variables, functions, classes). If you know JS basics, this will level up your TS immediately.',
  },
  {
    q: 'Will this stay up to date?',
    a: 'The content covers stable TypeScript patterns that have been consistent for several major versions. Nothing in here is TypeScript 5.x-specific — it all applies to TS 4.x and newer.',
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": PRODUCT_NAME,
  "description": "5 practical TypeScript reference files: cheatsheet, TS vs JS comparison, 20 utility types examples, tsconfig template, and 15 common mistakes guide.",
  "url": "https://devplaybook.cc/products/typescript-quick-reference-toolkit",
  "image": "https://devplaybook.cc/og-default.svg",
  "brand": { "@type": "Brand", "name": "DevPlaybook" },
  "offers": {
    "@type": "Offer",
    "price": PRODUCT_PRICE,
    "priceCurrency": "USD",
    "priceValidUntil": "2027-12-31",
    "availability": "https://schema.org/InStock",
    "url": GUMROAD_URL,
    "hasMerchantReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "applicableCountry": "US",
      "returnPolicyCategory": "https://schema.org/MerchantReturnNotPermitted",
      "merchantReturnDays": 0
    },
    "shippingDetails": {
      "@type": "OfferShippingDetails",
      "shippingRate": { "@type": "MonetaryAmount", "value": "0", "currency": "USD" },
      "shippingDestination": { "@type": "DefinedRegion", "addressCountry": "US" },
      "deliveryTime": {
        "@type": "ShippingDeliveryTime",
        "handlingTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 0, "unitCode": "DAY" },
        "transitTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 0, "unitCode": "DAY" }
      }
    }
  },
  "keywords": "typescript cheatsheet, typescript utility types, tsconfig, typescript vs javascript, typescript mistakes, developer reference"
};
---

<BaseLayout
  title="TypeScript Quick Reference Toolkit — Cheatsheet, Utility Types & tsconfig | DevPlaybook"
  description="Stop Googling the same TypeScript patterns. 5 practical reference files: cheatsheet, TS vs JS comparison, 20 utility types, tsconfig template, 15 mistakes guide. $14."
  noDefaultJsonLd
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Breadcrumb -->
  <nav class="mb-8 text-sm text-text-muted">
    <a href="/" class="hover:text-primary">Home</a>
    <span class="mx-2">/</span>
    <a href="/products" class="hover:text-primary">Products</a>
    <span class="mx-2">/</span>
    <span class="text-text">TypeScript Quick Reference Toolkit</span>
  </nav>

  <div class="max-w-4xl mx-auto">
    <!-- Hero -->
    <div class="text-center mb-14">
      <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-4">5 Reference Files · TypeScript Developers</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-5 leading-tight">
        Stop Googling the Same<br /><span class="text-primary">TypeScript Patterns</span>
      </h1>
      <p class="text-text-muted text-xl max-w-2xl mx-auto mb-3">
        Cheatsheet, utility types, tsconfig template, and mistake guide —
        everything you reach for daily, in 5 printable files.
      </p>
      <p class="text-text-muted text-base max-w-xl mx-auto mb-10">
        Print the cheatsheet. Keep it on your desk. Stop context-switching out of your editor.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-4">
        <div class="text-center sm:text-left">
          <span class="block text-5xl font-bold text-primary">${PRODUCT_PRICE}</span>
          <span class="block text-text-muted text-sm mt-1">one-time · instant download</span>
        </div>
        <div class="flex flex-col gap-3">
          <a
            href={GUMROAD_URL}
            target="_blank"
            rel="noopener noreferrer"
            data-track="gumroad_hero_cta"
            class="inline-block bg-primary hover:bg-primary-dark text-white font-bold px-10 py-4 rounded-xl text-lg transition-colors shadow-lg"
          >
            Get the Toolkit — ${PRODUCT_PRICE} →
          </a>
          <button
            class="ecpay-buy-btn inline-block border border-green-500 text-green-500 hover:bg-green-500 hover:text-white font-semibold px-8 py-3 rounded-xl transition-colors cursor-pointer"
            data-product-slug="typescript-quick-reference-toolkit"
            data-product-name={PRODUCT_NAME}
            data-product-price={String(PRODUCT_PRICE_NTD)}
            data-track="ecpay_hero_cta"
          >
            NT${PRODUCT_PRICE_NTD} — Taiwan Payment
          </button>
        </div>
      </div>
      <p class="text-text-muted text-xs">No subscription · Markdown files · Print-ready</p>
    </div>

    <!-- Social proof bar -->
    <div class="flex flex-wrap items-center justify-center gap-6 mb-14 py-5 border-y border-border text-sm text-text-muted">
      <span>📘 5 reference files (ZIP)</span>
      <span>🖨️ Print-ready A4 format</span>
      <span>⚙️ tsconfig for every stack</span>
      <span>🐛 15 real mistake patterns</span>
    </div>

    <!-- What's included -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold text-center mb-3">What's <span class="text-primary">Inside</span></h2>
      <p class="text-text-muted text-center mb-10">5 focused files — no filler, no fluff</p>
      <div class="space-y-4">
        {files.map(f => (
          <div class="bg-bg-card border border-border rounded-xl p-5 flex items-start gap-4">
            <span class="text-3xl shrink-0">{f.icon}</span>
            <div>
              <div class="flex items-center gap-2 mb-1">
                <h3 class="font-semibold">{f.name}</h3>
                <span class="text-xs text-primary bg-primary/10 px-2 py-0.5 rounded-full">{f.detail}</span>
              </div>
              <p class="text-text-muted text-sm">{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Sample content -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">Sample: Utility Types in Action</h2>
      <div class="bg-bg-card border border-border rounded-xl p-5 overflow-x-auto">
        <pre class="text-sm font-mono text-text whitespace-pre"><code>{`interface User {
  id: number; name: string; email: string;
  role: "admin" | "user" | "guest";
}

// Partial — update payloads (only send what changed)
async function updateUser(id: number, data: Partial<User>) {
  await db.users.update({ where: { id }, data });
}
updateUser(1, { name: "Alice" }); // ✅ only changed fields

// Pick — return only safe fields
type UserPreview = Pick<User, "id" | "name" | "role">;

// Omit — strip sensitive fields from API response
type PublicUser = Omit<User, "email">;

// Record — config maps with exhaustive keys
const rolePerms: Record<User["role"], string[]> = {
  admin: ["read", "write", "delete"],
  user:  ["read", "write"],
  guest: ["read"],
};

// ReturnType — reuse function return shape
function createUser(name: string) {
  return { id: Date.now(), name, createdAt: new Date() };
}
type CreatedUser = ReturnType<typeof createUser>;`}</code></pre>
      </div>
    </section>

    <!-- Who it's for -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">Who This Is For</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {[
          { icon: '🟡', label: 'JS devs learning TypeScript', desc: 'Get the syntax overview and mistake guide to avoid the most common pitfalls from day one.' },
          { icon: '🔵', label: 'TypeScript devs who want a reference', desc: 'Keep the cheatsheet on your desk. Stop alt-tabbing to the docs for the same patterns.' },
          { icon: '🟢', label: 'Teams onboarding to TypeScript', desc: 'Share the toolkit as a team resource. Everyone starts from the same foundation.' },
          { icon: '🟣', label: 'Anyone who Googles "tsconfig options"', desc: "The tsconfig template covers every setting with explanations — you won't need to guess again." },
        ].map(item => (
          <div class="bg-bg-card border border-border rounded-xl p-5 flex items-start gap-3">
            <span class="text-2xl shrink-0">{item.icon}</span>
            <div>
              <h3 class="font-semibold mb-1">{item.label}</h3>
              <p class="text-text-muted text-sm">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Mid CTA -->
    <section class="mb-16 text-center bg-bg-card border border-primary/20 rounded-2xl p-10">
      <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-3">One-time purchase</p>
      <h2 class="text-3xl font-bold mb-3">5 TypeScript references. ${PRODUCT_PRICE}.</h2>
      <p class="text-text-muted mb-8 max-w-lg mx-auto">
        Cheatsheet, utility types, tsconfig, and mistake guide. Print them. Keep them close.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={GUMROAD_URL}
          target="_blank"
          rel="noopener noreferrer"
          data-track="gumroad_mid_cta"
          class="inline-block bg-primary hover:bg-primary-dark text-white font-bold px-10 py-4 rounded-xl text-lg transition-colors"
        >
          Get the Toolkit — ${PRODUCT_PRICE} →
        </a>
        <button
          class="ecpay-buy-btn inline-block border border-green-500 text-green-500 hover:bg-green-500 hover:text-white font-semibold px-8 py-3 rounded-xl transition-colors cursor-pointer"
          data-product-slug="typescript-quick-reference-toolkit"
          data-product-name={PRODUCT_NAME}
          data-product-price={String(PRODUCT_PRICE_NTD)}
          data-track="ecpay_mid_cta"
        >
          NT${PRODUCT_PRICE_NTD} — Taiwan Payment
        </button>
      </div>
      <p class="text-text-muted text-xs mt-4">No subscription · Markdown + JSON · Instant download</p>
    </section>

    <!-- FAQ -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-6">FAQ</h2>
      <div class="space-y-4">
        {faqs.map(item => (
          <div class="bg-bg-card border border-border rounded-lg p-5">
            <h3 class="font-semibold mb-2">{item.q}</h3>
            <p class="text-text-muted text-sm">{item.a}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Tags -->
    <section class="mb-12">
      <div class="flex flex-wrap gap-2">
        {['typescript', 'javascript', 'cheatsheet', 'reference', 'utility-types', 'tsconfig', 'frontend', 'backend', 'developer-tools', 'type-system'].map(tag => (
          <span class="text-xs bg-bg-input text-text-muted px-3 py-1 rounded-full">{tag}</span>
        ))}
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="text-center mb-8 py-10 border-t border-border">
      <h2 class="text-3xl font-bold mb-4">Your TypeScript desk reference.</h2>
      <p class="text-text-muted mb-8 max-w-lg mx-auto">
        5 focused files covering the patterns you look up most. Print the cheatsheet. Keep the tsconfig template. Reference the utility types. Done.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={GUMROAD_URL}
          target="_blank"
          rel="noopener noreferrer"
          data-track="gumroad_bottom_cta"
          class="inline-block bg-primary hover:bg-primary-dark text-white font-bold px-10 py-5 rounded-xl text-xl transition-colors shadow-lg"
        >
          Get the Toolkit — ${PRODUCT_PRICE} →
        </a>
        <button
          class="ecpay-buy-btn inline-block border border-green-500 text-green-500 hover:bg-green-500 hover:text-white font-semibold px-8 py-4 rounded-xl transition-colors cursor-pointer"
          data-product-slug="typescript-quick-reference-toolkit"
          data-product-name={PRODUCT_NAME}
          data-product-price={String(PRODUCT_PRICE_NTD)}
          data-track="ecpay_bottom_cta"
        >
          NT${PRODUCT_PRICE_NTD} Taiwan
        </button>
      </div>
      <p class="text-text-muted text-sm mt-4">
        <a href="/products" class="hover:text-primary">&larr; Browse all products</a>
      </p>
    </section>

    <!-- ECPay Checkout Script -->
    <script>
      document.querySelectorAll('.ecpay-buy-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const slug = (btn as HTMLElement).dataset.productSlug;
          const name = (btn as HTMLElement).dataset.productName;
          const price = parseInt((btn as HTMLElement).dataset.productPrice ?? '0', 10);

          (btn as HTMLButtonElement).disabled = true;
          btn.textContent = 'Processing...';

          try {
            const res = await fetch('/api/ecpay-checkout', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ productSlug: slug, productName: name, price }),
            });

            if (!res.ok) {
              const err = await res.json();
              throw new Error(err.error || 'Checkout failed');
            }

            const html = await res.text();
            document.open();
            document.write(html);
            document.close();
          } catch (err) {
            alert('Payment error: ' + (err as Error).message);
            (btn as HTMLButtonElement).disabled = false;
            btn.textContent = `NT$${price} Taiwan Payment`;
          }
        });
      });
    </script>
  </div>
</BaseLayout>
