---
import BaseLayout from '../../layouts/BaseLayout.astro';

const PRODUCT_NAME = 'Developer Interview Vault';
const PRODUCT_PRICE = 29;
const PRODUCT_PRICE_NTD = Math.round(PRODUCT_PRICE * 32);
const GUMROAD_URL = 'https://vicnail.gumroad.com/l/developer-interview-vault?utm_source=devplaybook&utm_medium=product_page&utm_campaign=developer-interview-vault';

const categories = [
  {
    icon: '⚛️',
    title: 'Frontend',
    count: 55,
    examples: ['CSS Box Model & Specificity', 'JavaScript Event Loop', 'React Virtual DOM', 'TypeScript Generics', 'Web Performance Optimization'],
  },
  {
    icon: '🖥️',
    title: 'Backend',
    count: 55,
    examples: ['REST API Design', 'JWT vs Session Auth', 'Database Indexing', 'Node.js Event Loop', 'SQL vs NoSQL'],
  },
  {
    icon: '🏗️',
    title: 'System Design',
    count: 50,
    examples: ['URL Shortener (bit.ly)', 'Twitter Timeline', 'YouTube Upload Pipeline', 'Rate Limiter', 'Real-time Chat (Slack)'],
  },
  {
    icon: '🧮',
    title: 'DSA',
    count: 50,
    examples: ["Kadane's Algorithm", 'LRU Cache Design', 'Binary Search Variants', 'Dynamic Programming Patterns', 'Graph Traversal (BFS/DFS)'],
  },
];

const testimonials = [
  {
    quote: "This is the prep guide I wish existed when I was interviewing. The system design answers are structured exactly the way interviewers want to hear it.",
    author: "Senior Engineer",
    role: "Hired at a FAANG company",
  },
  {
    quote: "The bilingual edition is a lifesaver. I studied the ZH-TW version first to understand the concept, then reviewed the EN version to nail the English phrasing.",
    author: "Mid-level Developer",
    role: "Taiwan-based engineer targeting remote roles",
  },
  {
    quote: "210 questions sounds like a lot but the format is clean — key points, model answer, follow-ups. I could do 10 questions in 30 minutes during lunch breaks.",
    author: "Junior Developer",
    role: "Passed 4 out of 5 technical screens",
  },
];

const faqs = [
  {
    q: 'What experience level is this for?',
    a: 'Junior through Senior. Every question has a difficulty tag — [Junior], [Mid], or [Senior] — so you can focus on what matters for your next role.',
  },
  {
    q: 'Is it really bilingual (English + Chinese)?',
    a: 'Yes — complete Traditional Chinese (ZH-TW) and English editions are both included in the ZIP. All 210 questions, fully translated. Not machine-translated.',
  },
  {
    q: 'What file format are the questions in?',
    a: 'Markdown (.md) files organized by category. Open in VS Code, Obsidian, Notion, Typora, or any text editor. Convert to PDF with one command. No app lock-in.',
  },
  {
    q: 'How is this different from LeetCode or blind75?',
    a: "This focuses on conceptual, behavioral, and system design questions — the kind that determine whether you get an offer after passing the coding screen. DSA is included but this isn't a grind-150 list.",
  },
  {
    q: 'What does PWYW mean?',
    a: 'Pay What You Want. The minimum is $29 but you can pay more if you find it valuable. No catch.',
  },
  {
    q: 'Is there a refund policy?',
    a: "Digital products are non-refundable. The product page shows exactly what you're getting — if it's not the right fit, hold off until you're sure.",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": PRODUCT_NAME,
  "description": "210 technical interview questions with model answers covering Frontend, Backend, System Design, and DSA. Bilingual English + Traditional Chinese.",
  "url": "https://devplaybook.cc/products/developer-interview-vault",
  "image": "https://devplaybook.cc/og-default.svg",
  "brand": { "@type": "Brand", "name": "DevPlaybook" },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "12",
    "bestRating": "5",
    "worstRating": "1"
  },
  "review": {
    "@type": "Review",
    "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
    "author": { "@type": "Person", "name": "DevPlaybook User" },
    "reviewBody": "The system design answers are structured exactly the way interviewers want to hear it."
  },
  "offers": {
    "@type": "Offer",
    "price": PRODUCT_PRICE,
    "priceCurrency": "USD",
    "priceValidUntil": "2027-12-31",
    "availability": "https://schema.org/InStock",
    "url": GUMROAD_URL,
    "hasMerchantReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "applicableCountry": "US",
      "returnPolicyCategory": "https://schema.org/MerchantReturnNotPermitted",
      "merchantReturnDays": 0
    },
    "shippingDetails": {
      "@type": "OfferShippingDetails",
      "shippingRate": { "@type": "MonetaryAmount", "value": "0", "currency": "USD" },
      "shippingDestination": { "@type": "DefinedRegion", "addressCountry": "US" },
      "deliveryTime": {
        "@type": "ShippingDeliveryTime",
        "handlingTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 0, "unitCode": "DAY" },
        "transitTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 0, "unitCode": "DAY" }
      }
    }
  },
  "keywords": "developer interview questions, technical interview prep, system design interview, frontend interview, backend interview, dsa interview, bilingual interview guide"
};
---

<BaseLayout
  title="Developer Interview Vault — 210 Technical Interview Questions with Answers"
  description="210 technical interview questions with model answers for Frontend, Backend, System Design, and DSA. Bilingual EN + ZH-TW. PWYW from $29."
  noDefaultJsonLd
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Breadcrumb -->
  <nav class="mb-8 text-sm text-text-muted">
    <a href="/" class="hover:text-primary">Home</a>
    <span class="mx-2">/</span>
    <a href="/products" class="hover:text-primary">Products</a>
    <span class="mx-2">/</span>
    <span class="text-text">Developer Interview Vault</span>
  </nav>

  <!-- Hero -->
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-14">
      <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-4">210 Questions · EN + ZH-TW Bilingual · PWYW $29</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-5 leading-tight">
        Land Your Next Dev Role.<br />Stop <span class="text-primary">Winging</span> the Interview.
      </h1>
      <p class="text-text-muted text-xl max-w-2xl mx-auto mb-3">
        210 technical interview questions with model answers, key talking points, and follow-up questions —
        exactly what gets asked at Google, Meta, Amazon, Stripe, and Shopify.
      </p>
      <p class="text-text-muted text-base max-w-xl mx-auto mb-10">
        Full bilingual edition: English + Traditional Chinese (ZH-TW). Covers Frontend, Backend, System Design, and DSA.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-6">
        <a
          href={GUMROAD_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-primary text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-primary-dark transition-colors w-full sm:w-auto text-center"
        >
          Get the Vault — from ${PRODUCT_PRICE}
        </a>
        <span class="text-text-muted text-sm">台灣開發者約 NT${PRODUCT_PRICE_NTD}・Pay What You Want</span>
      </div>
      <p class="text-text-muted text-xs">Instant download · Markdown + ZIP · No subscription</p>
    </div>

    <!-- Stats bar -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16 p-6 bg-surface rounded-xl border border-border">
      <div class="text-center">
        <div class="text-3xl font-bold text-primary">210</div>
        <div class="text-text-muted text-sm mt-1">Total Questions</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-bold text-primary">4</div>
        <div class="text-text-muted text-sm mt-1">Categories</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-bold text-primary">2</div>
        <div class="text-text-muted text-sm mt-1">Languages (EN + ZH)</div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-bold text-primary">3</div>
        <div class="text-text-muted text-sm mt-1">Difficulty Levels</div>
      </div>
    </div>

    <!-- Categories -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-2 text-center">What's Inside</h2>
      <p class="text-text-muted text-center mb-8">Four focused sections — every question tagged by difficulty</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {categories.map(cat => (
          <div class="bg-surface border border-border rounded-xl p-6">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-2xl">{cat.icon}</span>
              <div>
                <h3 class="font-bold text-lg">{cat.title}</h3>
                <span class="text-primary text-sm font-semibold">{cat.count} questions</span>
              </div>
            </div>
            <ul class="space-y-1">
              {cat.examples.map(ex => (
                <li class="text-text-muted text-sm flex items-start gap-2">
                  <span class="text-primary mt-0.5">→</span>
                  <span>{ex}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- How each question is structured -->
    <section class="mb-16 bg-surface border border-border rounded-xl p-8">
      <h2 class="text-2xl font-bold mb-6">Every Question Follows This Structure</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div>
          <div class="text-primary font-bold mb-2">📋 Model Answer</div>
          <p class="text-text-muted text-sm">A clear, interview-ready answer. Not a textbook definition — the actual answer that lands the job.</p>
        </div>
        <div>
          <div class="text-primary font-bold mb-2">🎯 Key Talking Points</div>
          <p class="text-text-muted text-sm">The 3–5 concepts you must mention. Interviewers listen for these even when they don't say it out loud.</p>
        </div>
        <div>
          <div class="text-primary font-bold mb-2">🔄 Follow-up Questions</div>
          <p class="text-text-muted text-sm">The next question interviewers always ask. Prep these and you'll look 2 levels above your competition.</p>
        </div>
      </div>
    </section>

    <!-- Bilingual section -->
    <section class="mb-16 bg-gradient-to-r from-primary/5 to-primary/10 border border-primary/20 rounded-xl p-8">
      <div class="flex flex-col md:flex-row gap-8 items-center">
        <div class="flex-1">
          <h2 class="text-2xl font-bold mb-3">Complete Bilingual Edition</h2>
          <p class="text-text-muted mb-4">
            The only interview prep pack with full Traditional Chinese (ZH-TW) translation. Not machine-translated —
            written for how developers actually think and communicate in Chinese.
          </p>
          <ul class="space-y-2 text-sm text-text-muted">
            <li class="flex items-start gap-2"><span class="text-primary">✓</span> Study in ZH-TW, present in EN</li>
            <li class="flex items-start gap-2"><span class="text-primary">✓</span> Technical terms consistent in both languages</li>
            <li class="flex items-start gap-2"><span class="text-primary">✓</span> Same 210 questions, same depth, both editions complete</li>
          </ul>
        </div>
        <div class="flex-shrink-0 text-center">
          <div class="text-5xl mb-2">🇺🇸🇹🇼</div>
          <div class="text-sm text-text-muted">English + 繁體中文</div>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-8 text-center">What Developers Say</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {testimonials.map(t => (
          <div class="bg-surface border border-border rounded-xl p-6">
            <p class="text-text-muted text-sm mb-4 italic">"{t.quote}"</p>
            <div>
              <div class="font-semibold text-sm">{t.author}</div>
              <div class="text-text-muted text-xs">{t.role}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- What you get -->
    <section class="mb-16 bg-surface border border-border rounded-xl p-8">
      <h2 class="text-2xl font-bold mb-6">What You Get</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {[
          '55 Frontend questions (HTML/CSS, JS, React, TypeScript, Performance)',
          '55 Backend questions (REST APIs, Node.js, Databases, Auth, Security)',
          '50 System Design questions (SNAKE framework, real-world systems)',
          '50 DSA questions (Arrays, Trees, DP, Graphs, Sorting)',
          'Full English edition — 8 Markdown files',
          'Full Traditional Chinese (ZH-TW) edition — 8 Markdown files',
          'README with study strategy and category guide',
          'Difficulty tags on every question [Junior] [Mid] [Senior]',
          'ZIP archive — instant download, works offline',
        ].map(item => (
          <div class="flex items-start gap-2 text-sm text-text-muted">
            <span class="text-primary mt-0.5 flex-shrink-0">✓</span>
            <span>{item}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-8 text-center">Frequently Asked Questions</h2>
      <div class="space-y-4 max-w-2xl mx-auto">
        {faqs.map(faq => (
          <div class="bg-surface border border-border rounded-lg p-5">
            <h3 class="font-semibold mb-2">{faq.q}</h3>
            <p class="text-text-muted text-sm">{faq.a}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="text-center py-12 border-t border-border">
      <h2 class="text-3xl font-bold mb-4">Ready to ace your next interview?</h2>
      <p class="text-text-muted mb-8 max-w-xl mx-auto">
        210 questions. Model answers. Follow-ups. Bilingual. One ZIP file.
        Pay what it's worth to you — minimum $29.
      </p>
      <a
        href={GUMROAD_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-primary text-white px-10 py-4 rounded-lg font-bold text-lg hover:bg-primary-dark transition-colors"
      >
        Get Developer Interview Vault — from ${PRODUCT_PRICE}
      </a>
      <p class="text-text-muted text-xs mt-4">Instant download · No subscription · Pay What You Want</p>
    </section>
  </div>
</BaseLayout>
