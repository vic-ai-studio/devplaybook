---
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = 'https://devplaybook.cc';

const features = [
  { name: 'All free developer tools (90+)',       free: true,  pro: true  },
  { name: 'Runs in browser — fully private',       free: true,  pro: true  },
  { name: 'Blog & dev guides',                     free: true,  pro: true  },
  { name: 'Weekly newsletter',                     free: true,  pro: true  },
  { name: 'CSS Grid, JWT, Color Contrast & more',  free: true,  pro: true  },
  { name: 'ASCII Art Generator',                   free: true,  pro: true  },
  { name: 'AI Code Review',                        free: false, pro: true  },
  { name: 'AI Doc Generator',                      free: false, pro: true  },
  { name: 'AI SQL Builder',                        free: false, pro: true  },
  { name: 'Premium boilerplate templates',         free: false, pro: true  },
  { name: 'Full-Stack Boilerplate Collection',     free: false, pro: true  },
  { name: 'Developer Productivity Bundle',         free: false, pro: true  },
  { name: 'Member-only discounts on products',     free: false, pro: true  },
  { name: 'Early access to new tools & content',   free: false, pro: true  },
  { name: 'Priority support',                      free: false, pro: true  },
  { name: 'All future releases — included',        free: false, pro: true  },
];

const faqs = [
  {
    q: 'What do I get with Pro?',
    a: 'All premium AI tools (Code Review, Doc Generator, SQL Builder), every template and boilerplate, early access to new releases, member-only discounts, and priority support. Everything added in the future is included automatically.'
  },
  {
    q: 'What is the yearly plan?',
    a: 'The yearly plan is $49/year — that\'s less than $4.10/month, saving you over 54% vs monthly. You get the same full Pro access for 12 months upfront.'
  },
  {
    q: 'Is there a free trial?',
    a: 'Yes — 7 days free on the monthly plan. No charge until the trial ends. Cancel before then and you owe nothing.'
  },
  {
    q: 'Can I cancel anytime?',
    a: 'Yes. Cancel anytime with no questions asked. Your access continues until the end of your billing period. Manage your subscription through Gumroad.'
  },
  {
    q: 'What is the Pro waitlist?',
    a: 'We\'re rolling out Pro subscriptions in batches to give every member a smooth onboarding experience. Join the waitlist to lock in early adopter pricing ($9/mo) and get notified the moment your spot opens.'
  },
  {
    q: 'What payment methods are accepted?',
    a: 'All major credit cards (Visa, Mastercard, Amex) and PayPal via Gumroad. Secure, PCI-compliant checkout.'
  },
];
---

<BaseLayout
  title="DevPlaybook Pro — Unlock Every Tool, Template & AI Feature"
  description="Upgrade to DevPlaybook Pro. Get all AI tools, premium templates, early access, and member discounts for $9/month or $49/year. 7 days free. Cancel anytime."
  noDefaultJsonLd
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Product",
        "name": "DevPlaybook Pro",
        "description": "Premium developer tools subscription. Includes all AI tools, templates, early access, and member-only discounts.",
        "url": `${siteUrl}/pro`,
        "image": `${siteUrl}/og-default.svg`,
        "offers": [
          {
            "@type": "Offer",
            "name": "Monthly",
            "price": "9.00",
            "priceCurrency": "USD",
            "priceValidUntil": "2027-12-31",
            "availability": "https://schema.org/InStock",
            "url": `${siteUrl}/pro`,
            "hasMerchantReturnPolicy": {
              "@type": "MerchantReturnPolicy",
              "applicableCountry": "US",
              "returnPolicyCategory": "https://schema.org/MerchantReturnNotPermitted",
              "merchantReturnDays": 0
            },
            "shippingDetails": {
              "@type": "OfferShippingDetails",
              "shippingRate": { "@type": "MonetaryAmount", "value": "0", "currency": "USD" },
              "shippingDestination": { "@type": "DefinedRegion", "addressCountry": "US" },
              "deliveryTime": { "@type": "ShippingDeliveryTime", "handlingTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 0, "unitCode": "DAY" }, "transitTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 0, "unitCode": "DAY" } }
            }
          },
          {
            "@type": "Offer",
            "name": "Yearly",
            "price": "49.00",
            "priceCurrency": "USD",
            "priceValidUntil": "2027-12-31",
            "availability": "https://schema.org/InStock",
            "url": `${siteUrl}/pro`,
            "hasMerchantReturnPolicy": {
              "@type": "MerchantReturnPolicy",
              "applicableCountry": "US",
              "returnPolicyCategory": "https://schema.org/MerchantReturnNotPermitted",
              "merchantReturnDays": 0
            },
            "shippingDetails": {
              "@type": "OfferShippingDetails",
              "shippingRate": { "@type": "MonetaryAmount", "value": "0", "currency": "USD" },
              "shippingDestination": { "@type": "DefinedRegion", "addressCountry": "US" },
              "deliveryTime": { "@type": "ShippingDeliveryTime", "handlingTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 0, "unitCode": "DAY" }, "transitTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 0, "unitCode": "DAY" } }
            }
          }
        ]
      },
      {
        "@type": "FAQPage",
        "mainEntity": faqs.map(f => ({
          "@type": "Question",
          "name": f.q,
          "acceptedAnswer": { "@type": "Answer", "text": f.a }
        }))
      }
    ]
  })} />

  <div class="max-w-4xl mx-auto py-12">

    <!-- Hero -->
    <div class="text-center mb-14">
      <span class="inline-flex items-center gap-1.5 bg-primary/10 text-primary text-xs font-semibold px-3 py-1 rounded-full border border-primary/20 mb-4">
        🔥 Early Adopter Pricing — Lock it in before it changes
      </span>
      <h1 class="text-4xl sm:text-5xl font-bold mb-4 leading-tight">
        Everything unlocked.<br />
        <span class="text-primary">One low price.</span>
      </h1>
      <p class="text-lg text-text-muted max-w-xl mx-auto mb-6">
        DevPlaybook Pro gives you every AI tool, premium template, and future release — plus early access and member-only discounts. Built for serious developers.
      </p>
      <!-- Social proof -->
      <div class="flex flex-wrap items-center justify-center gap-4 text-sm text-text-muted">
        <span class="flex items-center gap-1.5"><span class="text-green-500 font-bold">60,000+</span> developers trust DevPlaybook</span>
        <span class="text-border">·</span>
        <span class="flex items-center gap-1.5"><span class="text-yellow-400">★★★★★</span> 4.9/5</span>
        <span class="text-border">·</span>
        <span class="flex items-center gap-1.5"><span class="text-green-500">✓</span> 7-day free trial</span>
      </div>
    </div>

    <!-- Pricing Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-14">

      <!-- Free -->
      <div class="bg-bg-card border border-border rounded-2xl p-7 flex flex-col">
        <h2 class="text-xl font-bold mb-1">Free</h2>
        <p class="text-text-muted text-sm mb-5">Core tools, forever free.</p>
        <div class="mb-6">
          <span class="text-4xl font-bold">$0</span>
          <span class="text-text-muted text-sm">/month</span>
        </div>
        <ul class="space-y-2 mb-8 text-sm flex-1">
          <li class="flex items-start gap-2"><span class="text-green-500 shrink-0 mt-0.5">✓</span> 90+ free developer tools</li>
          <li class="flex items-start gap-2"><span class="text-green-500 shrink-0 mt-0.5">✓</span> Runs in browser (private)</li>
          <li class="flex items-start gap-2"><span class="text-green-500 shrink-0 mt-0.5">✓</span> Blog & guides</li>
          <li class="flex items-start gap-2"><span class="text-text-muted shrink-0 mt-0.5">✗</span><span class="text-text-muted"> AI tools</span></li>
          <li class="flex items-start gap-2"><span class="text-text-muted shrink-0 mt-0.5">✗</span><span class="text-text-muted"> Premium templates</span></li>
        </ul>
        <a href="/tools" class="block w-full text-center py-3 px-6 rounded-xl border border-border font-medium hover:border-primary transition-colors text-sm">
          Browse Free Tools
        </a>
      </div>

      <!-- Pro Monthly -->
      <div class="bg-bg-card border-2 border-primary rounded-2xl p-7 relative shadow-xl flex flex-col">
        <div class="absolute -top-4 left-1/2 -translate-x-1/2">
          <span class="inline-flex items-center px-4 py-1 rounded-full bg-primary text-white text-xs font-bold">
            Most Popular
          </span>
        </div>
        <h2 class="text-xl font-bold mb-1">Pro Monthly</h2>
        <p class="text-text-muted text-sm mb-5">Everything. Cancel anytime.</p>
        <div class="mb-6">
          <span class="text-4xl font-bold text-primary">$9</span>
          <span class="text-text-muted text-sm">/month</span>
        </div>
        <ul class="space-y-2 mb-8 text-sm flex-1">
          <li class="flex items-start gap-2"><span class="text-green-500 shrink-0 mt-0.5">✓</span> Everything in Free</li>
          <li class="flex items-start gap-2"><span class="text-primary shrink-0 mt-0.5">⚡</span> <strong>All AI tools</strong></li>
          <li class="flex items-start gap-2"><span class="text-primary shrink-0 mt-0.5">⚡</span> Premium templates</li>
          <li class="flex items-start gap-2"><span class="text-primary shrink-0 mt-0.5">⚡</span> Early access</li>
          <li class="flex items-start gap-2"><span class="text-primary shrink-0 mt-0.5">⚡</span> Member discounts</li>
          <li class="flex items-start gap-2"><span class="text-primary shrink-0 mt-0.5">⚡</span> Priority support</li>
          <li class="flex items-start gap-2"><span class="text-primary shrink-0 mt-0.5">⚡</span> Future releases included</li>
        </ul>
        <div class="space-y-2">
          <a
            id="pro-monthly-btn"
            href="https://vicnail.gumroad.com/l/yvbwzb?recurrence=monthly&utm_source=devplaybook&utm_medium=pro_page&utm_campaign=monthly"
            class="block w-full py-3.5 px-6 rounded-xl bg-primary hover:bg-primary/90 text-white font-bold transition-colors text-base shadow-lg shadow-primary/25 text-center no-underline"
            rel="noopener"
          >
            Start Free Trial → $9/mo after
          </a>
          <p class="text-center text-xs text-text-muted">✓ 7 days free · No charge until trial ends · Cancel anytime</p>
          <p class="text-center text-xs text-text-muted">🔒 Secure checkout via Gumroad</p>
        </div>
      </div>

      <!-- Pro Yearly -->
      <div class="bg-bg-card border border-border rounded-2xl p-7 relative flex flex-col">
        <div class="absolute -top-4 left-1/2 -translate-x-1/2">
          <span class="inline-flex items-center px-4 py-1 rounded-full bg-green-600 text-white text-xs font-bold">
            Save 54%
          </span>
        </div>
        <h2 class="text-xl font-bold mb-1">Pro Yearly</h2>
        <p class="text-text-muted text-sm mb-5">Best value for committed builders.</p>
        <div class="mb-1">
          <span class="text-4xl font-bold">$49</span>
          <span class="text-text-muted text-sm">/year</span>
        </div>
        <p class="text-green-400 text-xs font-semibold mb-5">≈ $4.08/month · Save $59 vs monthly</p>
        <ul class="space-y-2 mb-8 text-sm flex-1">
          <li class="flex items-start gap-2"><span class="text-green-500 shrink-0 mt-0.5">✓</span> Everything in Pro Monthly</li>
          <li class="flex items-start gap-2"><span class="text-green-500 shrink-0 mt-0.5">✓</span> 12 months full access</li>
          <li class="flex items-start gap-2"><span class="text-green-500 shrink-0 mt-0.5">✓</span> Locked-in early adopter rate</li>
        </ul>
        <div class="space-y-2">
          <a
            id="pro-yearly-btn"
            href="https://vicnail.gumroad.com/l/yvbwzb?recurrence=yearly&utm_source=devplaybook&utm_medium=pro_page&utm_campaign=yearly"
            class="block w-full py-3.5 px-6 rounded-xl bg-green-600 hover:bg-green-700 text-white font-bold transition-colors text-base text-center no-underline"
            rel="noopener"
          >
            Get Yearly — $49 · Save 54%
          </a>
          <p class="text-center text-xs text-text-muted">✓ 12 months full access · Early adopter rate locked in</p>
          <p class="text-center text-xs text-text-muted">🔒 Secure checkout via Gumroad</p>
        </div>
      </div>
    </div>

    <!-- Feature Comparison Table -->
    <div class="mb-14">
      <h2 class="text-2xl font-bold text-center mb-8">Free vs Pro — Full Comparison</h2>
      <div class="bg-bg-card border border-border rounded-2xl overflow-hidden">
        <div class="grid grid-cols-3 bg-bg border-b border-border text-sm font-semibold">
          <div class="col-span-1 p-4 text-text-muted">Feature</div>
          <div class="p-4 text-center text-text-muted">Free</div>
          <div class="p-4 text-center text-primary font-bold">Pro</div>
        </div>
        {features.map((f, i) => (
          <div class={`grid grid-cols-3 text-sm border-b border-border last:border-0 ${i % 2 === 0 ? '' : 'bg-bg/50'}`}>
            <div class="col-span-1 p-4 text-text">{f.name}</div>
            <div class="p-4 text-center">
              {f.free
                ? <span class="text-green-500 font-bold">✓</span>
                : <span class="text-text-muted">—</span>
              }
            </div>
            <div class="p-4 text-center">
              {f.pro
                ? <span class="text-primary font-bold">✓</span>
                : <span class="text-text-muted">—</span>
              }
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Still thinking section -->
    <div class="mb-14">
      <div class="bg-gradient-to-br from-primary/10 to-bg-card border border-primary/30 rounded-2xl p-8 text-center">
        <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-2">Still on the Fence?</p>
        <h2 class="text-2xl font-bold mb-3">Try Pro Free for 7 Days</h2>
        <p class="text-text-muted mb-6 max-w-md mx-auto text-sm">
          No credit card stress. Start your 7-day free trial and use every Pro feature. If it doesn't save you time, cancel before the trial ends — you won't be charged.
        </p>
        <a
          id="pro-cta-secondary-btn"
          href="https://vicnail.gumroad.com/l/yvbwzb?recurrence=monthly&utm_source=devplaybook&utm_medium=pro_page&utm_campaign=secondary_cta"
          class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-primary hover:bg-primary/90 text-white font-bold transition-colors text-base shadow-lg shadow-primary/25 no-underline"
          rel="noopener"
        >
          Start Free Trial → $9/mo after
        </a>
        <p class="mt-3 text-xs text-text-muted">🔒 Secure checkout · Cancel anytime · 7 days free</p>
      </div>
    </div>

    <!-- FAQ -->
    <div class="max-w-2xl mx-auto mb-12">
      <h2 class="text-2xl font-bold text-center mb-8">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqs.map(faq => (
          <details class="group bg-bg-card border border-border rounded-xl">
            <summary class="flex items-center justify-between cursor-pointer p-5 font-medium text-sm">
              {faq.q}
              <svg class="w-4 h-4 text-text-muted group-open:rotate-180 transition-transform shrink-0 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-5 pb-5 text-text-muted text-sm">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>

    <!-- Bottom CTA -->
    <div class="text-center">
      <p class="text-text-muted text-sm mb-2">Not ready to subscribe? <a href="/pro-waitlist" class="text-primary hover:underline font-medium">Join the early bird waitlist — lock in 50% off →</a></p>
      <p class="text-text-muted text-sm mb-4">Not ready for Pro? <a href="/tools" class="text-primary hover:underline">Browse all free tools →</a></p>
      <p class="text-xs text-text-muted">Questions? <a href="/blog" class="hover:text-primary">Check the blog</a> or reach out via the newsletter.</p>
    </div>
  </div>

  <!-- GA4 Pro page tracking -->
  <script is:inline>
    // pro_upgrade_click: fired once per session when user views /pro page
    (function() {
      try {
        if (sessionStorage.getItem('pro_upgrade_click_fired')) return;
        sessionStorage.setItem('pro_upgrade_click_fired', '1');
        if (typeof gtag === 'function') {
          gtag('event', 'pro_upgrade_click', { page: '/pro' });
        }
      } catch(e) {}
    })();
  </script>

  <!-- GA4 checkout tracking (navigation handled by <a> href) -->
  <script is:inline>
    function trackCheckout(btnId, plan) {
      var btn = document.getElementById(btnId);
      if (!btn) return;
      btn.addEventListener('click', function() {
        try {
          if (typeof gtag === 'function') {
            gtag('event', 'pro_checkout_start', {
              plan: plan,
              currency: 'USD',
              value: plan === 'yearly' ? 49 : 9
            });
          }
        } catch(e) {}
      });
    }
    trackCheckout('pro-monthly-btn', 'monthly');
    trackCheckout('pro-yearly-btn', 'yearly');
    trackCheckout('pro-cta-secondary-btn', 'monthly');
  </script>
</BaseLayout>
