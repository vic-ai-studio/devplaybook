---
import BaseLayout from '../layouts/BaseLayout.astro';
import { products } from '../data/products';
import { getCollection } from 'astro:content';
import NewsletterForm from '../components/NewsletterForm.astro';
import LeadMagnetBox from '../components/LeadMagnetBox.astro';

const featuredProducts = products.slice(0, 3);
const recentPosts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const tools = [
  { name: 'JWT Decoder', desc: 'Decode and inspect JSON Web Tokens. View header, payload, claims, and expiry instantly.', href: '/tools/jwt-decoder', icon: '🔐', isNew: false },
  { name: 'API Request Builder', desc: 'Build and test HTTP requests visually. Generate cURL commands.', href: '/tools/api-request-builder', icon: '🔗', isNew: false },
  { name: 'Regex Playground', desc: 'Write, test, and debug regular expressions in real-time', href: '/tools/regex-playground', icon: '🔍', isNew: false },
  { name: 'Cron Expression Generator', desc: 'Generate cron expressions with a visual interface', href: '/tools/cron-generator', icon: '⏰', isNew: false },
  { name: 'Git Command Builder', desc: 'Build complex Git commands step by step', href: '/tools/git-command-builder', icon: '🌿', isNew: false },
  { name: 'Docker Compose Generator', desc: 'Generate docker-compose.yml configurations visually', href: '/tools/docker-compose-generator', icon: '🐳', isNew: false },
];

const newTools = [
  { name: 'Color Format Converter', desc: 'Convert between HEX, RGB, and HSL. Visual picker and live preview.', href: '/tools/color-converter', icon: '🔄' },
  { name: 'UUID Generator', desc: 'Generate v1, v4, and v5 UUIDs. Bulk mode — up to 100 at once. Client-side.', href: '/tools/uuid-generator', icon: '🆔' },
  { name: 'CSS Clip Path Generator', desc: 'Build CSS clip-path shapes visually. Polygon, circle, ellipse, inset. Live preview.', href: '/tools/css-clip-path-generator', icon: '✂️' },
  { name: 'JSON Formatter Pro', desc: 'Advanced JSON formatter with JSONPath querying, schema validation, and diff.', href: '/tools/json-formatter-pro', icon: '🔍' },
  { name: 'Regex Tester Pro', desc: 'Test regex against multiple strings. Batch pass/fail assertions with match highlights.', href: '/tools/regex-tester-pro', icon: '✅' },
];
---

<BaseLayout title="Free Online Developer Tools — JSON, Regex, UUID, Base64 & More" description="200+ free online developer tools: JSON formatter, Base64 encoder, regex tester, UUID generator, CORS tester, cron generator, git commands, and more. Fast, private — runs in your browser, no signup required." noDefaultJsonLd>
  <!-- Announcement Bar -->
  <div class="bg-gradient-to-r from-primary to-primary-dark text-white text-center text-sm py-2.5 px-4 -mt-4 mb-8 rounded-xl flex items-center justify-center gap-2 flex-wrap">
    <span>🎉 Early Bird — First 100 members get <strong>50% off Pro forever</strong></span>
    <a href="/pro" class="underline font-bold hover:no-underline whitespace-nowrap">Lock in $4.50/mo →</a>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://devplaybook.cc/#organization",
        "name": "DevPlaybook",
        "url": "https://devplaybook.cc",
        "logo": { "@type": "ImageObject", "url": "https://devplaybook.cc/favicon.svg" },
        "description": "Free interactive developer tools, boilerplates, and guides for developers.",
        "sameAs": []
      },
      {
        "@type": "WebSite",
        "@id": "https://devplaybook.cc/#website",
        "url": "https://devplaybook.cc",
        "name": "DevPlaybook",
        "publisher": { "@id": "https://devplaybook.cc/#organization" },
        "potentialAction": {
          "@type": "SearchAction",
          "target": "https://devplaybook.cc/tools?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      },
      {
        "@type": "WebApplication",
        "@id": "https://devplaybook.cc/#webapp",
        "name": "DevPlaybook",
        "url": "https://devplaybook.cc",
        "description": "200+ free, privacy-first developer tools — JWT decoder, JSON formatter, regex tester, cron builder, and more. No signup, no ads, all client-side.",
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "Any",
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
        "publisher": { "@id": "https://devplaybook.cc/#organization" }
      }
    ]
  })} />
  <div class="text-center mb-12">
    <!-- Social proof badge -->
    <div class="flex flex-wrap items-center justify-center gap-3 mb-4">
      <div class="inline-flex items-center gap-2 bg-primary/10 text-primary text-xs font-semibold px-3 py-1.5 rounded-full">
        <span aria-hidden="true">⚡</span> 200+ Free Tools · No Signup · Works in Your Browser
      </div>
      <div class="inline-flex items-center gap-1.5 bg-green-500/10 text-green-600 dark:text-green-400 text-xs font-semibold px-3 py-1.5 rounded-full border border-green-500/20">
        <span aria-hidden="true">👥</span> 60,000+ developers trust DevPlaybook
      </div>
    </div>
    <h1 class="text-4xl sm:text-5xl font-bold mb-4">Stop Tab-Switching.<br><span class="text-primary">Every Dev Tool in One Place.</span></h1>
    <p class="text-text-muted text-lg max-w-2xl mx-auto mb-4">JWT decoder, JSON formatter, regex tester, cron builder, UUID generator — all free, all client-side. <strong class="text-text">Your data never leaves your browser.</strong></p>
    <div class="flex flex-wrap justify-center gap-2 text-xs text-text-muted mb-6">
      <span class="bg-bg-card border border-border rounded px-2 py-1">JWT Decoder</span>
      <span class="bg-bg-card border border-border rounded px-2 py-1">JSON Formatter</span>
      <span class="bg-bg-card border border-border rounded px-2 py-1">Regex Tester</span>
      <span class="bg-bg-card border border-border rounded px-2 py-1">Cron Builder</span>
      <span class="bg-bg-card border border-border rounded px-2 py-1">UUID Generator</span>
      <span class="bg-bg-card border border-border rounded px-2 py-1">Base64</span>
      <span class="bg-bg-card border border-border rounded px-2 py-1">+190 more →</span>
    </div>
    <!-- Search bar -->
    <form action="/tools" method="get" role="search" class="flex gap-2 max-w-md mx-auto mb-6">
      <input
        type="search"
        name="q"
        placeholder="Search 200+ free tools..."
        aria-label="Search developer tools"
        class="flex-1 px-4 py-3 rounded-xl border border-border bg-bg-card text-text placeholder-text-muted focus:outline-none focus:border-primary text-sm"
        autocomplete="off"
      />
      <button type="submit" class="px-5 py-3 bg-primary hover:bg-primary-dark text-white font-semibold rounded-xl transition-colors text-sm whitespace-nowrap">
        Search
      </button>
    </form>
    <div class="flex flex-col sm:flex-row gap-3 justify-center items-center">
      <a href="/tools" class="px-8 py-3.5 bg-primary hover:bg-primary-dark text-white font-bold rounded-xl transition-colors text-base shadow-lg shadow-primary/20">
        Access 200+ Free Dev Tools →
      </a>
      <a href="/pro" class="px-7 py-3.5 border border-primary/50 text-primary hover:bg-primary/10 font-semibold rounded-xl transition-colors text-base flex items-center gap-2">
        ⚡ Try Pro — 7 Days Free
      </a>
    </div>
    <p class="text-text-muted text-xs mt-4">
      No credit card · No account · No ads on free tools
    </p>
    <!-- Value Proposition Strip -->
    <div class="flex flex-wrap justify-center gap-x-8 gap-y-2 text-sm text-text-muted mt-4 mb-2">
      <span class="flex items-center gap-1.5">
        <span class="text-green-500 font-bold">✓</span>
        200+ free tools — no login ever
      </span>
      <span class="flex items-center gap-1.5">
        <span class="text-green-500 font-bold">✓</span>
        Privacy-first — data never leaves your browser
      </span>
      <span class="flex items-center gap-1.5">
        <span class="text-green-500 font-bold">✓</span>
        Zero ads on free tools
      </span>
      <span class="flex items-center gap-1.5">
        <span class="text-green-500 font-bold">✓</span>
        Open source · MIT licensed
      </span>
    </div>
    <div class="mt-6 max-w-sm mx-auto">
      <p class="text-text-muted text-xs mb-2">Get weekly dev tools & tips in your inbox:</p>
      <NewsletterForm source="hero" compact={true} />
    </div>
  </div>

  <!-- Featured tools -->
  <div class="mb-3">
    <h2 class="text-xl font-semibold text-center mb-5">Most Popular Tools</h2>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {tools.map(tool => (
      <a href={tool.href} class="block bg-bg-card rounded-xl p-6 border border-border hover:border-primary transition-colors group">
        <div class="text-3xl mb-3">{tool.icon}</div>
        <h2 class="text-xl font-semibold mb-2 group-hover:text-primary transition-colors">{tool.name}</h2>
        <p class="text-text-muted text-sm">{tool.desc}</p>
      </a>
    ))}
  </div>
  <div class="text-center mt-4 mb-2">
    <a href="/tools" class="text-primary hover:text-primary-dark text-sm font-medium">Browse all 200+ free tools &rarr;</a>
  </div>

  <!-- Recently added tools -->
  <div class="mt-10 mb-2">
    <h2 class="text-xl font-semibold text-center mb-5">Recently Added</h2>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
    {newTools.map(tool => (
      <a href={tool.href} class="block bg-bg-card rounded-xl p-5 border border-border hover:border-primary transition-colors group relative">
        <span class="absolute top-3 right-3 text-xs font-bold bg-green-500/15 text-green-500 border border-green-500/30 px-2 py-0.5 rounded-full">New</span>
        <div class="text-2xl mb-2">{tool.icon}</div>
        <h2 class="text-base font-semibold mb-1 group-hover:text-primary transition-colors">{tool.name}</h2>
        <p class="text-text-muted text-sm">{tool.desc}</p>
      </a>
    ))}
  </div>

  <!-- Gumroad Product Spotlight -->
  <div class="mt-14 mb-2">
    <div class="flex items-center justify-between mb-5">
      <h2 class="text-xl font-semibold">Grab a Toolkit — Ship Faster</h2>
      <a href="/products" class="text-primary text-sm font-medium hover:text-primary-dark">View all →</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {featuredProducts.map(product => (
        <a href={product.gumroadUrl} target="_blank" rel="noopener" class="block bg-bg-card rounded-xl p-5 border border-border hover:border-primary transition-colors group">
          <div class="flex items-start justify-between mb-2">
            <span class="text-3xl">{product.icon}</span>
            <span class="text-primary font-bold text-lg">${product.price}</span>
          </div>
          <h3 class="text-base font-semibold mb-1 group-hover:text-primary transition-colors">{product.name}</h3>
          <p class="text-text-muted text-xs line-clamp-2 mb-3">{product.description}</p>
          <span class="text-xs font-semibold text-primary bg-primary/10 px-2 py-0.5 rounded-full">Buy on Gumroad →</span>
        </a>
      ))}
    </div>
  </div>

  <!-- Testimonials -->
  <div class="mt-14 mb-2">
    <h2 class="text-xl font-semibold text-center mb-6">What Developers Say</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      <div class="bg-bg-card rounded-xl p-5 border border-border">
        <div class="flex items-center gap-1 mb-3 text-yellow-400 text-sm">★★★★★</div>
        <p class="text-text-muted text-sm mb-3">"DevPlaybook's JWT decoder and JSON formatter are open in my browser every single day. Saves me from context-switching constantly."</p>
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center text-xs font-bold text-primary">MK</div>
          <div>
            <div class="text-text text-xs font-semibold">Marcus K.</div>
            <div class="text-text-muted text-xs">Senior Backend Engineer</div>
          </div>
        </div>
      </div>
      <div class="bg-bg-card rounded-xl p-5 border border-border">
        <div class="flex items-center gap-1 mb-3 text-yellow-400 text-sm">★★★★★</div>
        <p class="text-text-muted text-sm mb-3">"The AI Prompt Engineering Toolkit paid for itself in the first code review session. 10x better outputs with the structured templates."</p>
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center text-xs font-bold text-primary">SL</div>
          <div>
            <div class="text-text text-xs font-semibold">Sophie L.</div>
            <div class="text-text-muted text-xs">Full-Stack Developer</div>
          </div>
        </div>
      </div>
      <div class="bg-bg-card rounded-xl p-5 border border-border">
        <div class="flex items-center gap-1 mb-3 text-yellow-400 text-sm">★★★★★</div>
        <p class="text-text-muted text-sm mb-3">"Bookmarked the regex playground and cron builder. No more Googling cron syntax at 11pm. Everything I need in one clean UI."</p>
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center text-xs font-bold text-primary">AJ</div>
          <div>
            <div class="text-text text-xs font-semibold">Alex J.</div>
            <div class="text-text-muted text-xs">DevOps Engineer</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Newsletter Banner -->
  <div class="mt-16 mb-8">
    <div class="bg-gradient-to-r from-primary/10 via-primary/5 to-transparent border border-primary/20 rounded-2xl p-8 md:p-10 text-center">
      <div class="max-w-xl mx-auto">
        <p class="text-xs font-semibold text-primary uppercase tracking-wider mb-2">Free Weekly Newsletter</p>
        <h2 class="text-2xl md:text-3xl font-bold mb-3">Get weekly dev tips + free tools</h2>
        <p class="text-text-muted mb-6">Join 2,000+ developers getting curated tool guides, productivity playbooks, and free resources every week. No spam, unsubscribe anytime.</p>
        <form id="homepage-newsletter-form" class="flex flex-col sm:flex-row gap-3 justify-center max-w-md mx-auto">
          <input
            type="text"
            name="name"
            placeholder="Your name"
            class="flex-1 px-4 py-3 rounded-xl border border-border bg-bg-alt text-text placeholder-text-muted focus:outline-none focus:border-primary text-sm"
          />
          <input
            type="email"
            name="email"
            placeholder="your@email.com"
            required
            class="flex-1 px-4 py-3 rounded-xl border border-border bg-bg-alt text-text placeholder-text-muted focus:outline-none focus:border-primary text-sm"
          />
          <button type="submit" class="px-6 py-3 bg-primary hover:bg-primary-dark text-white font-semibold rounded-xl transition-colors whitespace-nowrap text-sm">
            Subscribe Free →
          </button>
        </form>
        <p id="homepage-newsletter-msg" class="text-sm mt-3 hidden"></p>
        <p class="text-text-muted text-xs mt-3">✓ Free dev tools &nbsp;·&nbsp; ✓ No spam &nbsp;·&nbsp; ✓ Unsubscribe anytime</p>
      </div>
    </div>
  </div>

  <script>
    (function() {
      var form = document.getElementById('homepage-newsletter-form');
      if (!form) return;
      var msg = document.getElementById('homepage-newsletter-msg');
      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        var emailInput = form.querySelector('input[name="email"]');
        var nameInput = form.querySelector('input[name="name"]');
        var btn = form.querySelector('button[type="submit"]');
        var email = emailInput ? emailInput.value.trim() : '';
        var name = nameInput ? nameInput.value.trim() : '';
        btn.disabled = true;
        btn.textContent = 'Subscribing...';
        try {
          var res = await fetch('/api/newsletter/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: email, name: name, source: 'homepage_banner' }),
          });
          var data = await res.json();
          if (data.success) {
            form.innerHTML = '<p class="text-green-400 font-semibold text-lg">You\'re in! Check your inbox soon.</p>';
            if (msg) msg.classList.add('hidden');
          } else {
            btn.disabled = false;
            btn.textContent = 'Subscribe Free \u2192';
            if (msg) { msg.textContent = data.error || 'Something went wrong.'; msg.classList.remove('hidden'); msg.style.color = '#f87171'; }
          }
        } catch (err) {
          btn.disabled = false;
          btn.textContent = 'Subscribe Free \u2192';
          if (msg) { msg.textContent = 'Network error. Please try again.'; msg.classList.remove('hidden'); msg.style.color = '#f87171'; }
        }
      });
    })();
  </script>

  <!-- New Product Promo Banner -->
  <div class="mt-16 mb-8">
    <a href="/products/ai-developer-prompts-pack" class="block bg-gradient-to-r from-primary/10 to-primary/5 border border-primary/30 rounded-2xl p-6 md:p-8 hover:border-primary/60 transition-colors group">
      <div class="flex flex-col md:flex-row md:items-center gap-4">
        <div class="text-5xl">💬</div>
        <div class="flex-1">
          <div class="flex items-center gap-2 mb-1">
            <span class="text-xs font-semibold uppercase tracking-wider text-primary bg-primary/10 px-2 py-0.5 rounded">New</span>
            <span class="text-xs text-text-muted">AI Developer Prompts Pack</span>
          </div>
          <h2 class="text-xl md:text-2xl font-bold mb-2 group-hover:text-primary transition-colors">55 Battle-Tested AI Prompt Templates for Developers</h2>
          <p class="text-text-muted text-sm md:text-base">Code review · Debugging · Architecture · Docs · Testing. Stop writing prompts from scratch.</p>
        </div>
        <div class="flex-shrink-0 text-right">
          <div class="text-3xl font-bold text-primary">$24</div>
          <div class="text-sm text-text-muted mt-1">55 prompts</div>
        </div>
      </div>
    </a>
  </div>


  <!-- Latest Articles -->
  {recentPosts.length > 0 && (
    <div class="mt-16 mb-8">
      <div class="text-center mb-8">
        <h2 class="text-3xl font-bold mb-3">Latest <span class="text-primary">Guides</span></h2>
        <p class="text-text-muted">In-depth articles to level up your development workflow.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {recentPosts.map(post => (
          <a href={`/blog/${post.id}`} class="block bg-bg-card rounded-xl p-6 border border-border hover:border-primary transition-colors group">
            <div class="text-sm text-text-muted mb-3">
              {new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })} · {post.data.readingTime}
            </div>
            <h3 class="text-lg font-semibold mb-2 group-hover:text-primary transition-colors">{post.data.title}</h3>
            <p class="text-text-muted text-sm line-clamp-2">{post.data.description}</p>
          </a>
        ))}
      </div>
      <div class="text-center mt-6">
        <a href="/blog" class="text-primary hover:text-primary-dark font-medium">Read all articles &rarr;</a>
      </div>
    </div>
  )}

  <!-- AdSense display ad (entry point 3/3: homepage between sections)
       Activates automatically when PUBLIC_ADSENSE_PUBLISHER_ID is set -->
  {import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID && (
    <div class="mt-12 flex justify-center" aria-label="Advertisement">
      <ins class="adsbygoogle"
        style="display:block;width:100%;max-width:728px;height:90px;"
        data-ad-client={import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID}
        data-ad-slot="auto"
        data-ad-format="horizontal">
      </ins>
      <script>try{(adsbygoogle = window.adsbygoogle || []).push({});}catch(e){}</script>
    </div>
  )}

  <!-- Lead Magnet + Newsletter Signup -->
  <div id="newsletter" class="mt-16">
    <LeadMagnetBox source="homepage" />
  </div>

  <!-- Free vs Pro Comparison -->
  <div class="mt-16 mb-8">
    <h2 class="text-2xl font-bold text-center mb-6">Free vs <span class="text-primary">Pro</span></h2>
    <div class="overflow-x-auto">
      <table class="w-full max-w-2xl mx-auto text-sm border-collapse">
        <thead>
          <tr>
            <th class="text-left py-3 px-4 text-text-muted font-medium">Feature</th>
            <th class="text-center py-3 px-4 font-semibold">Free</th>
            <th class="text-center py-3 px-4 font-semibold text-primary">Pro <span class="text-xs font-normal text-text-muted">$9/mo</span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          <tr class="hover:bg-bg-card/50 transition-colors">
            <td class="py-3 px-4 text-text-muted">90+ developer tools</td>
            <td class="py-3 px-4 text-center text-green-500">✓</td>
            <td class="py-3 px-4 text-center text-green-500">✓</td>
          </tr>
          <tr class="hover:bg-bg-card/50 transition-colors">
            <td class="py-3 px-4 text-text-muted">Runs in browser (private)</td>
            <td class="py-3 px-4 text-center text-green-500">✓</td>
            <td class="py-3 px-4 text-center text-green-500">✓</td>
          </tr>
          <tr class="hover:bg-bg-card/50 transition-colors">
            <td class="py-3 px-4 text-text-muted">Daily tool usage limit</td>
            <td class="py-3 px-4 text-center text-text-muted">10/day</td>
            <td class="py-3 px-4 text-center text-primary font-semibold">Unlimited</td>
          </tr>
          <tr class="hover:bg-bg-card/50 transition-colors">
            <td class="py-3 px-4 text-text-muted">AI Code Review</td>
            <td class="py-3 px-4 text-center text-text-muted">✗</td>
            <td class="py-3 px-4 text-center text-primary">⚡</td>
          </tr>
          <tr class="hover:bg-bg-card/50 transition-colors">
            <td class="py-3 px-4 text-text-muted">AI Doc Generator</td>
            <td class="py-3 px-4 text-center text-text-muted">✗</td>
            <td class="py-3 px-4 text-center text-primary">⚡</td>
          </tr>
          <tr class="hover:bg-bg-card/50 transition-colors">
            <td class="py-3 px-4 text-text-muted">Premium templates</td>
            <td class="py-3 px-4 text-center text-text-muted">✗</td>
            <td class="py-3 px-4 text-center text-primary">⚡</td>
          </tr>
          <tr class="hover:bg-bg-card/50 transition-colors">
            <td class="py-3 px-4 text-text-muted">Member-only discounts</td>
            <td class="py-3 px-4 text-center text-text-muted">✗</td>
            <td class="py-3 px-4 text-center text-primary">⚡</td>
          </tr>
          <tr class="hover:bg-bg-card/50 transition-colors">
            <td class="py-3 px-4 text-text-muted">Priority support</td>
            <td class="py-3 px-4 text-center text-text-muted">✗</td>
            <td class="py-3 px-4 text-center text-primary">⚡</td>
          </tr>
        </tbody>
      </table>
    </div>
    <div class="text-center mt-6">
      <a href="/pricing" class="inline-block px-6 py-3 bg-primary hover:bg-primary-dark text-white font-semibold rounded-xl transition-colors shadow-lg">
        Start 7-day Free Trial →
      </a>
      <p class="text-xs text-text-muted mt-2">7 days free · Cancel anytime</p>
