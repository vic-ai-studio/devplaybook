---
import BaseLayout from '../layouts/BaseLayout.astro';
import { products } from '../data/products';
import { getCollection } from 'astro:content';
import NewsletterForm from '../components/NewsletterForm.astro';

const featuredProducts = products.slice(0, 3);
const recentPosts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const tools = [
  { name: 'API Request Builder', desc: 'Build and test HTTP requests visually', href: '/tools/api-request-builder', icon: '🔗' },
  { name: 'Regex Playground', desc: 'Write, test, and debug regular expressions in real-time', href: '/tools/regex-playground', icon: '🔍' },
  { name: 'Cron Expression Generator', desc: 'Generate cron expressions with a visual interface', href: '/tools/cron-generator', icon: '⏰' },
  { name: 'Git Command Builder', desc: 'Build complex Git commands step by step', href: '/tools/git-command-builder', icon: '🌿' },
  { name: 'Docker Compose Generator', desc: 'Generate docker-compose.yml configurations visually', href: '/tools/docker-compose-generator', icon: '🐳' },
];
---

<BaseLayout title="Free Developer Tools" description="Free interactive developer tools: API builder, regex playground, cron generator, git commands, and Docker Compose generator." noDefaultJsonLd>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://devplaybook.cc/#organization",
        "name": "DevPlaybook",
        "url": "https://devplaybook.cc",
        "logo": { "@type": "ImageObject", "url": "https://devplaybook.cc/favicon.svg" },
        "description": "Free interactive developer tools, boilerplates, and guides for developers.",
        "sameAs": []
      },
      {
        "@type": "WebSite",
        "@id": "https://devplaybook.cc/#website",
        "url": "https://devplaybook.cc",
        "name": "DevPlaybook",
        "publisher": { "@id": "https://devplaybook.cc/#organization" },
        "potentialAction": {
          "@type": "SearchAction",
          "target": "https://devplaybook.cc/tools?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      },
      {
        "@type": "WebApplication",
        "@id": "https://devplaybook.cc/#webapp",
        "name": "DevPlaybook",
        "url": "https://devplaybook.cc",
        "description": "100+ free, privacy-first developer tools — JWT decoder, JSON formatter, regex tester, cron builder, and more. No signup, no ads, all client-side.",
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "Any",
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
        "publisher": { "@id": "https://devplaybook.cc/#organization" }
      }
    ]
  })} />
  <div class="text-center mb-12">
    <div class="inline-flex items-center gap-2 bg-primary/10 text-primary text-xs font-semibold px-3 py-1.5 rounded-full mb-5">
      <span>⚡</span> 100+ tools · Zero signup · Works in your browser
    </div>
    <h1 class="text-4xl sm:text-5xl font-bold mb-4">Stop Tab-Switching.<br><span class="text-primary">Every Dev Tool in One Place.</span></h1>
    <p class="text-text-muted text-lg max-w-2xl mx-auto mb-4">JWT decoder, JSON formatter, regex tester, cron builder, UUID generator — all free, all client-side. Your data never leaves your browser.</p>
    <div class="flex flex-wrap justify-center gap-2 text-xs text-text-muted mb-6">
      <span class="bg-bg-card border border-border rounded px-2 py-1">JWT Decoder</span>
      <span class="bg-bg-card border border-border rounded px-2 py-1">JSON Formatter</span>
      <span class="bg-bg-card border border-border rounded px-2 py-1">Regex Tester</span>
      <span class="bg-bg-card border border-border rounded px-2 py-1">Cron Builder</span>
      <span class="bg-bg-card border border-border rounded px-2 py-1">UUID Generator</span>
      <span class="bg-bg-card border border-border rounded px-2 py-1">Base64</span>
      <span class="bg-bg-card border border-border rounded px-2 py-1">+94 more →</span>
    </div>
    <div class="flex flex-col sm:flex-row gap-3 justify-center items-center">
      <a href="/tools" class="px-7 py-3 bg-primary hover:bg-primary-dark text-white font-semibold rounded-xl transition-colors text-base">
        Open Free Tools →
      </a>
      <a href="/pricing" class="px-7 py-3 bg-bg-card border border-primary/40 text-primary hover:border-primary font-semibold rounded-xl transition-colors text-base">
        Try Pro — 7 Days Free
      </a>
    </div>
    <p class="text-text-muted text-xs mt-4">
      No credit card · No account · No ads on free tools
    </p>
    <div class="mt-6 max-w-sm mx-auto">
      <p class="text-text-muted text-xs mb-2">Get weekly dev tools & tips in your inbox:</p>
      <NewsletterForm source="hero" compact={true} />
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {tools.map(tool => (
      <a href={tool.href} class="block bg-bg-card rounded-xl p-6 border border-border hover:border-primary transition-colors group">
        <div class="text-3xl mb-3">{tool.icon}</div>
        <h2 class="text-xl font-semibold mb-2 group-hover:text-primary transition-colors">{tool.name}</h2>
        <p class="text-text-muted text-sm">{tool.desc}</p>
      </a>
    ))}
  </div>

  <!-- New Product Promo Banner -->
  <div class="mt-16 mb-8">
    <a href="/products/ai-developer-prompts-pack" class="block bg-gradient-to-r from-primary/10 to-primary/5 border border-primary/30 rounded-2xl p-6 md:p-8 hover:border-primary/60 transition-colors group">
      <div class="flex flex-col md:flex-row md:items-center gap-4">
        <div class="text-5xl">💬</div>
        <div class="flex-1">
          <div class="flex items-center gap-2 mb-1">
            <span class="text-xs font-semibold uppercase tracking-wider text-primary bg-primary/10 px-2 py-0.5 rounded">New</span>
            <span class="text-xs text-text-muted">AI Developer Prompts Pack</span>
          </div>
          <h2 class="text-xl md:text-2xl font-bold mb-2 group-hover:text-primary transition-colors">55 Battle-Tested AI Prompt Templates for Developers</h2>
          <p class="text-text-muted text-sm md:text-base">Code review · Debugging · Architecture · Docs · Testing. Stop writing prompts from scratch.</p>
        </div>
        <div class="flex-shrink-0 text-right">
          <div class="text-3xl font-bold text-primary">$24</div>
          <div class="text-sm text-text-muted mt-1">55 prompts</div>
        </div>
      </div>
    </a>
  </div>

  <!-- Featured Products -->
  <div class="mt-8 mb-8">
    <div class="text-center mb-8">
      <h2 class="text-3xl font-bold mb-3">Premium <span class="text-primary">Products</span></h2>
      <p class="text-text-muted">Boilerplates, toolkits, and templates to ship faster.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {featuredProducts.map(product => (
        <a href={`/products/${product.slug}`} class="block bg-bg-card rounded-xl p-6 border border-border hover:border-primary transition-colors group">
          <div class="flex items-start justify-between mb-3">
            <span class="text-3xl">{product.icon}</span>
            <span class="text-primary font-bold">${product.price}</span>
          </div>
          <h3 class="text-lg font-semibold mb-2 group-hover:text-primary transition-colors">{product.name}</h3>
          <p class="text-text-muted text-sm line-clamp-2">{product.description}</p>
        </a>
      ))}
    </div>
    <div class="text-center mt-6">
      <a href="/products" class="text-primary hover:text-primary-dark font-medium">View all {products.length} products &rarr;</a>
    </div>
  </div>

  <!-- Latest Articles -->
  {recentPosts.length > 0 && (
    <div class="mt-16 mb-8">
      <div class="text-center mb-8">
        <h2 class="text-3xl font-bold mb-3">Latest <span class="text-primary">Guides</span></h2>
        <p class="text-text-muted">In-depth articles to level up your development workflow.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {recentPosts.map(post => (
          <a href={`/blog/${post.id}`} class="block bg-bg-card rounded-xl p-6 border border-border hover:border-primary transition-colors group">
            <div class="text-sm text-text-muted mb-3">
              {new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })} · {post.data.readingTime}
            </div>
            <h3 class="text-lg font-semibold mb-2 group-hover:text-primary transition-colors">{post.data.title}</h3>
            <p class="text-text-muted text-sm line-clamp-2">{post.data.description}</p>
          </a>
        ))}
      </div>
      <div class="text-center mt-6">
        <a href="/blog" class="text-primary hover:text-primary-dark font-medium">Read all articles &rarr;</a>
      </div>
    </div>
  )}

  <!-- AdSense display ad (entry point 3/3: homepage between sections)
       Activates automatically when PUBLIC_ADSENSE_PUBLISHER_ID is set -->
  {import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID && (
    <div class="mt-12 flex justify-center" aria-label="Advertisement">
      <ins class="adsbygoogle"
        style="display:block;width:100%;max-width:728px;height:90px;"
        data-ad-client={import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID}
        data-ad-slot="auto"
        data-ad-format="horizontal">
      </ins>
      <script>try{(adsbygoogle = window.adsbygoogle || []).push({});}catch(e){}</script>
    </div>
  )}

  <!-- Newsletter Signup -->
  <div id="newsletter" class="mt-16 bg-bg-card border border-border rounded-xl p-8 text-center">
    <h2 class="text-2xl font-bold mb-2">Stay in the Loop</h2>
    <p class="text-text-muted mb-2">Get new tools, guides, and products delivered to your inbox. No spam, unsubscribe anytime.</p>
    <p class="text-text-muted text-sm mb-6"><a href="/newsletter" class="text-primary hover:text-primary-dark underline">See what's inside →</a></p>
    <NewsletterForm source="homepage" />
  </div>

  <!-- Free vs Pro Comparison -->
  <div class="mt-16 mb-8">
    <h2 class="text-2xl font-bold text-center mb-6">Free vs <span class="text-primary">Pro</span></h2>
    <div class="overflow-x-auto">
      <table class="w-full max-w-2xl mx-auto text-sm border-collapse">
        <thead>
          <tr>
            <th class="text-left py-3 px-4 text-text-muted font-medium">Feature</th>
            <th class="text-center py-3 px-4 font-semibold">Free</th>
            <th class="text-center py-3 px-4 font-semibold text-primary">Pro <span class="text-xs font-normal text-text-muted">$9/mo</span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          <tr class="hover:bg-bg-card/50 transition-colors">
            <td class="py-3 px-4 text-text-muted">90+ developer tools</td>
            <td class="py-3 px-4 text-center text-green-500">✓</td>
            <td class="py-3 px-4 text-center text-green-500">✓</td>
          </tr>
          <tr class="hover:bg-bg-card/50 transition-colors">
            <td class="py-3 px-4 text-text-muted">Runs in browser (private)</td>
            <td class="py-3 px-4 text-center text-green-500">✓</td>
            <td class="py-3 px-4 text-center text-green-500">✓</td>
          </tr>
          <tr class="hover:bg-bg-card/50 transition-colors">
            <td class="py-3 px-4 text-text-muted">Daily tool usage limit</td>
            <td class="py-3 px-4 text-center text-text-muted">10/day</td>
            <td class="py-3 px-4 text-center text-primary font-semibold">Unlimited</td>
          </tr>
          <tr class="hover:bg-bg-card/50 transition-colors">
            <td class="py-3 px-4 text-text-muted">AI Code Review</td>
            <td class="py-3 px-4 text-center text-text-muted">✗</td>
            <td class="py-3 px-4 text-center text-primary">⚡</td>
          </tr>
          <tr class="hover:bg-bg-card/50 transition-colors">
            <td class="py-3 px-4 text-text-muted">AI Doc Generator</td>
            <td class="py-3 px-4 text-center text-text-muted">✗</td>
            <td class="py-3 px-4 text-center text-primary">⚡</td>
          </tr>
          <tr class="hover:bg-bg-card/50 transition-colors">
            <td class="py-3 px-4 text-text-muted">Premium templates</td>
            <td class="py-3 px-4 text-center text-text-muted">✗</td>
            <td class="py-3 px-4 text-center text-primary">⚡</td>
          </tr>
          <tr class="hover:bg-bg-card/50 transition-colors">
            <td class="py-3 px-4 text-text-muted">Member-only discounts</td>
            <td class="py-3 px-4 text-center text-text-muted">✗</td>
            <td class="py-3 px-4 text-center text-primary">⚡</td>
          </tr>
          <tr class="hover:bg-bg-card/50 transition-colors">
            <td class="py-3 px-4 text-text-muted">Priority support</td>
            <td class="py-3 px-4 text-center text-text-muted">✗</td>
            <td class="py-3 px-4 text-center text-primary">⚡</td>
          </tr>
        </tbody>
      </table>
    </div>
    <div class="text-center mt-6">
      <a href="/pricing" class="inline-block px-6 py-3 bg-primary hover:bg-primary-dark text-white font-semibold rounded-xl transition-colors shadow-lg">
        Start 7-day Free Trial →
      </a>
      <p class="text-xs text-text-muted mt-2">7 days free · Cancel anytime</p>
    </div>
  </div>

  <!-- Pro Subscription -->
  <div class="mt-8 bg-bg-card border border-primary/30 rounded-xl p-8 text-center">
    <span class="inline-block text-xs font-semibold bg-primary/10 text-primary px-3 py-1 rounded-full mb-3">Early Bird — 50% off · First 100 members</span>
    <h2 class="text-2xl font-bold mb-2">DevPlaybook <span class="text-primary">Pro</span></h2>
    <p class="text-text-muted mb-2">AI-powered tools, exclusive templates, priority support, and member-only discounts.</p>
    <ul class="text-text-muted text-sm mb-6 space-y-1">
      <li>⚡ <a href="/tools/ai-code-review" class="hover:text-primary transition-colors">AI Code Review</a> — instant code feedback</li>
      <li>⚡ <a href="/tools/ai-doc-generator" class="hover:text-primary transition-colors">AI Doc Generator</a> — JSDoc, README, OpenAPI</li>
      <li>⚡ <a href="/tools/ai-sql-builder" class="hover:text-primary transition-colors">AI SQL Builder</a> — natural language to SQL</li>
      <li>✓ All premium templates &amp; future tools</li>
      <li>✓ Member-only discounts on products</li>
    </ul>
    <div class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" id="pro-checkout-container">
      <input
        type="email"
        id="pro-email"
        placeholder="you@example.com"
        class="flex-1 bg-bg-input border border-border rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-primary"
      />
      <button
        id="pro-checkout-btn"
        class="bg-primary hover:bg-primary-dark text-white font-semibold px-6 py-2.5 rounded-lg transition-colors text-sm shrink-0"
        data-track="pro_checkout_click"
      >
        Upgrade to Pro
      </button>
    </div>
    <div class="mt-4">
      <a href="/pro-waitlist" class="text-primary hover:text-primary-dark text-sm font-medium underline">
        🎯 Join early access waitlist — lock in 50% off forever →
      </a>
    </div>
    <p class="text-xs text-text-muted mt-2">Secure payment via Gumroad. Cancel anytime.</p>
    <p id="pro-checkout-error" class="text-xs text-red-400 mt-2 hidden"></p>
  </div>

  <script>
    const btn = document.getElementById('pro-checkout-btn');
    const emailInput = document.getElementById('pro-email');

    if (btn) {
      btn.addEventListener('click', () => {
        const email = emailInput?.value?.trim() || '';
        let url = 'https://vicnail.gumroad.com/l/yvbwzb?recurrence=monthly&utm_source=devplaybook&utm_medium=homepage&utm_campaign=monthly';
        if (email) url += '&email=' + encodeURIComponent(email);
        window.location.href = url;
      });
    }
  </script>
</BaseLayout>
