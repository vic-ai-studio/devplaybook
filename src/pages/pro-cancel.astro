---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Checkout Cancelled" description="Your DevPlaybook Pro checkout was cancelled. No charge was made.">
  <div class="max-w-2xl mx-auto text-center py-16">
    <div class="text-6xl mb-6">👋</div>
    <h1 class="text-3xl font-bold mb-4">No worries — checkout was cancelled</h1>
    <p class="text-text-muted text-lg mb-8">
      You have not been charged. Whenever you're ready to upgrade, come back anytime.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/"
        class="bg-primary hover:bg-primary-dark text-white font-semibold px-8 py-3 rounded-lg transition-colors"
      >
        Back to Home
      </a>
      <a
        href="/products"
        class="bg-bg-card border border-border hover:border-primary text-text font-semibold px-8 py-3 rounded-lg transition-colors"
      >
        Browse Free Products
      </a>
    </div>
  </div>
</BaseLayout>
