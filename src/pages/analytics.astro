---
import BaseLayout from '../layouts/BaseLayout.astro';
const cfToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;
---

<BaseLayout
  title="Site Analytics"
  description="DevPlaybook traffic stats and audience overview."
  noindex={true}
>
  <div class="max-w-3xl mx-auto">
    <div class="mb-8">
      <h1 class="text-3xl font-bold mb-2">Site Analytics</h1>
      <p class="text-text-muted">Live traffic data powered by Cloudflare Web Analytics. No cookies, privacy-first.</p>
    </div>

    {cfToken ? (
      <div class="bg-bg-card border border-border rounded-xl p-6">
        <p class="text-sm text-text-muted mb-4">
          Embedded dashboard — data refreshes automatically. Showing last 30 days.
        </p>
        <div id="cf-analytics-dashboard" class="w-full min-h-[500px]">
          <script
            defer
            src="https://static.cloudflareinsights.com/beacon.min.js/v84a3a4012de94ce1a686ba8c167c359c1696973893317"
            integrity="sha512-euoFGowhlaLqXsPWQ48qSkBSCFs3DPRyiwVu3FjR96cMPx+Fr+gpWRhIafcHwqwCqWS42RZhIudOvEI+Ckf6MA=="
            data-cf-beacon={`{"token":"${cfToken}","spa":true}`}
            crossorigin="anonymous"
          ></script>
          <p class="text-text-muted text-sm text-center py-20">
            Analytics embed requires the Cloudflare dashboard. <br />
            View full stats at <a href="https://dash.cloudflare.com" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">dash.cloudflare.com → Web Analytics</a>.
          </p>
        </div>
      </div>
    ) : (
      <div class="bg-bg-card border border-border rounded-xl p-8 text-center">
        <p class="text-text-muted mb-2">Cloudflare Analytics is not configured.</p>
        <p class="text-sm text-text-muted">Set <code class="bg-bg px-1 py-0.5 rounded text-secondary">PUBLIC_CF_ANALYTICS_TOKEN</code> in your Cloudflare Pages environment variables to enable this page.</p>
      </div>
    )}

    <!-- Key Metrics Overview -->
    <div class="mt-10">
      <h2 class="text-xl font-bold mb-4">Audience Overview</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
          <p class="text-2xl font-bold text-primary">10K+</p>
          <p class="text-xs text-text-muted mt-1">Monthly visitors</p>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
          <p class="text-2xl font-bold text-primary">50+</p>
          <p class="text-xs text-text-muted mt-1">Free tools</p>
        </div>
        <div class="bg-bg-card border border-border rounded-xl p-5 text-center">
          <p class="text-2xl font-bold text-primary">56+</p>
          <p class="text-xs text-text-muted mt-1">Blog articles</p>
        </div>
      </div>
    </div>

    <div class="mt-8 text-center">
      <p class="text-text-muted text-sm">
        Interested in reaching this audience?
        <a href="/advertise" class="text-primary hover:underline ml-1">See sponsorship options →</a>
      </p>
    </div>
  </div>
</BaseLayout>
