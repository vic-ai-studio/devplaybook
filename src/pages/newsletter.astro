---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="DevPlaybook Newsletter — Weekly Developer Tips"
  description="Get weekly developer tips, tool guides, productivity playbooks, and AI workflow tricks. Free. No spam. Unsubscribe anytime."
>
  <!-- Hero -->
  <div class="max-w-2xl mx-auto text-center mb-12">
    <div class="inline-block text-xs font-semibold uppercase tracking-widest bg-primary/10 text-primary px-3 py-1 rounded-full mb-4">Free Newsletter</div>
    <h1 class="text-4xl font-bold mb-4">
      Ship Faster.<br />
      <span class="text-primary">Stay Sharp Every Week.</span>
    </h1>
    <p class="text-text-muted text-lg mb-8">
      Join developers getting weekly deep-dives on tools, productivity playbooks, and AI workflow tips. One email. Pure signal.
    </p>

    <!-- Email capture form -->
    <div class="bg-bg-card border border-border rounded-2xl p-8 mb-4">
      <form id="newsletter-page-form" class="flex flex-col sm:flex-row gap-3 mb-3">
        <input
          type="email"
          id="newsletter-email"
          placeholder="you@example.com"
          required
          class="flex-1 bg-bg-input border border-border rounded-lg px-4 py-3 text-base focus:outline-none focus:border-primary"
        />
        <button
          type="submit"
          id="newsletter-btn"
          class="bg-primary hover:bg-primary-dark text-white font-semibold px-8 py-3 rounded-lg transition-colors text-base shrink-0"
        >
          Subscribe Free →
        </button>
      </form>
      <p id="newsletter-msg" class="text-sm mt-2 hidden"></p>
      <p class="text-text-muted text-xs">No spam. Unsubscribe anytime. ~500 readers.</p>
    </div>
  </div>

  <!-- What you get -->
  <div class="max-w-3xl mx-auto mb-16">
    <h2 class="text-2xl font-bold text-center mb-8">What's Inside Every Issue</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="bg-bg-card border border-border rounded-xl p-6">
        <div class="text-3xl mb-3">🛠️</div>
        <h3 class="font-semibold mb-1">Tool Deep Dives</h3>
        <p class="text-text-muted text-sm">Hands-on guides to the best developer tools — CLI tricks, API builders, regex tips, and more.</p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-6">
        <div class="text-3xl mb-3">⚡</div>
        <h3 class="font-semibold mb-1">Productivity Playbooks</h3>
        <p class="text-text-muted text-sm">Workflow patterns that actually save time. Git flows, CI/CD shortcuts, debugging checklists.</p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-6">
        <div class="text-3xl mb-3">🤖</div>
        <h3 class="font-semibold mb-1">AI Workflow Tips</h3>
        <p class="text-text-muted text-sm">Practical prompts, Cursor tips, and AI-assisted coding patterns that work in real projects.</p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-6">
        <div class="text-3xl mb-3">📦</div>
        <h3 class="font-semibold mb-1">Free Resources</h3>
        <p class="text-text-muted text-sm">Templates, boilerplates, and checklists. Subscribers get early access and member discounts.</p>
      </div>
    </div>
  </div>

  <!-- Free lead magnet -->
  <div class="max-w-2xl mx-auto mb-16 bg-gradient-to-br from-primary/10 to-bg-card border border-primary/30 rounded-2xl p-8 text-center">
    <div class="text-4xl mb-3">🎁</div>
    <h2 class="text-xl font-bold mb-2">Free on Subscribe</h2>
    <p class="text-text-muted mb-4">Get the <strong class="text-text">Developer Productivity Checklist</strong> — 50+ actionable items to level up your dev workflow.</p>
    <a href="/free-checklist" class="text-primary hover:text-primary-dark font-medium text-sm">Preview the checklist →</a>
  </div>

  <!-- Past issues / topics -->
  <div class="max-w-3xl mx-auto mb-16">
    <h2 class="text-2xl font-bold text-center mb-8">Topics We Cover</h2>
    <div class="flex flex-wrap gap-2 justify-center">
      {[
        'API Design', 'JSON Tools', 'Regex Mastery', 'Git Workflows',
        'Docker Tips', 'CI/CD Automation', 'TypeScript Patterns',
        'AI Coding Assistants', 'Debugging Strategies', 'Cron Jobs',
        'Security Basics', 'Performance Optimization', 'CLI Productivity',
        'Code Review', 'Developer Tooling'
      ].map(tag => (
        <span class="text-sm bg-bg-card border border-border rounded-full px-4 py-1.5 text-text-muted">{tag}</span>
      ))}
    </div>
  </div>

  <!-- MailerLite Embed (activate after Vic creates MailerLite account — see docs/MAILERLITE_SETUP.md) -->
  <!--
    STEP 1: Replace MAILERLITE_ACCOUNT_ID and MAILERLITE_FORM_ID below.
    STEP 2: Uncomment the script + div block.
    STEP 3: (Optional) Remove the custom forms above once MailerLite is active.

  <script>
    (function(w,d,e,u,f,l,n){w[f]=w[f]||function(){(w[f].q=w[f].q||[]).push(arguments);},l=d.createElement(e),l.async=1,l.src=u,n=d.getElementsByTagName(e)[0],n.parentNode.insertBefore(l,n);})(window,document,'script','https://assets.mailerlite.com/js/universal.js','ml');
    ml('account', 'MAILERLITE_ACCOUNT_ID');
  </script>
  <div class="ml-embedded max-w-2xl mx-auto mb-16" data-form="MAILERLITE_FORM_ID"></div>
  -->

  <!-- Bottom CTA -->
  <div class="max-w-xl mx-auto text-center mb-8">
    <h2 class="text-2xl font-bold mb-3">Ready to level up?</h2>
    <p class="text-text-muted mb-6">Join developers who read DevPlaybook to ship faster and build smarter.</p>
    <form id="newsletter-page-form-2" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
      <input
        type="email"
        id="newsletter-email-2"
        placeholder="you@example.com"
        required
        class="flex-1 bg-bg-input border border-border rounded-lg px-4 py-3 text-base focus:outline-none focus:border-primary"
      />
      <button
        type="submit"
        id="newsletter-btn-2"
        class="bg-primary hover:bg-primary-dark text-white font-semibold px-6 py-3 rounded-lg transition-colors shrink-0"
      >
        Subscribe Free
      </button>
    </form>
    <p id="newsletter-msg-2" class="text-sm mt-2 hidden"></p>
    <p class="text-text-muted text-xs mt-2">No spam. Unsubscribe anytime.</p>
  </div>
</BaseLayout>

<script>
  function setupForm(formId: string, emailId: string, btnId: string, msgId: string, source: string) {
    const form = document.getElementById(formId) as HTMLFormElement | null;
    const emailInput = document.getElementById(emailId) as HTMLInputElement | null;
    const btn = document.getElementById(btnId) as HTMLButtonElement | null;
    const msg = document.getElementById(msgId);
    if (!form || !emailInput || !btn || !msg) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = emailInput.value.trim();
      btn.disabled = true;
      btn.textContent = 'Subscribing...';

      try {
        const res = await fetch('/api/newsletter/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source }),
        });
        const data = await res.json();
        if (data.success) {
          form.innerHTML = '<p class="text-green-400 font-semibold text-center py-2">You\'re in! 🎉 Check your inbox soon.</p>';
          try { (window as any).dpTrack?.('newsletter_signup', { source }); } catch {}
        } else {
          btn.disabled = false;
          btn.textContent = 'Subscribe Free →';
          msg.textContent = data.error || 'Something went wrong.';
          msg.classList.remove('hidden');
          (msg as HTMLElement).style.color = '#f87171';
        }
      } catch {
        btn.disabled = false;
        btn.textContent = 'Subscribe Free →';
        msg.textContent = 'Network error. Please try again.';
        msg.classList.remove('hidden');
        (msg as HTMLElement).style.color = '#f87171';
      }
    });
  }

  setupForm('newsletter-page-form', 'newsletter-email', 'newsletter-btn', 'newsletter-msg', 'newsletter-page');
  setupForm('newsletter-page-form-2', 'newsletter-email-2', 'newsletter-btn-2', 'newsletter-msg-2', 'newsletter-page-bottom');
</script>
