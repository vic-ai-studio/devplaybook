---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="You're Subscribed! — DevPlaybook" description="Thank you for subscribing to the DevPlaybook newsletter.">
  <div class="max-w-2xl mx-auto text-center py-24">
    <div class="text-6xl mb-6">🎉</div>
    <h1 class="text-4xl font-bold mb-4">You're in!</h1>
    <p class="text-xl text-text-muted mb-8">
      Welcome to the DevPlaybook newsletter. Check your inbox for a welcome email with your free developer resources.
    </p>

    <div class="bg-bg-card border border-border rounded-2xl p-8 mb-10 text-left">
      <h2 class="text-lg font-semibold mb-4 text-center">What you'll get every week:</h2>
      <ul class="space-y-3 text-text-muted">
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">✓</span>
          <span>🛠️ <strong class="text-text">Developer tool guides</strong> — deep dives on the tools devs actually use</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">✓</span>
          <span>⚡ <strong class="text-text">Productivity playbooks</strong> — workflows and shortcuts that save hours</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">✓</span>
          <span>🤖 <strong class="text-text">AI workflow tips</strong> — prompts, agents, and automation for developers</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold mt-0.5">✓</span>
          <span>📦 <strong class="text-text">Free resources & templates</strong> — boilerplates, checklists, and more</span>
        </li>
      </ul>
    </div>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/tools" class="px-7 py-3 bg-primary hover:bg-primary-dark text-white font-semibold rounded-xl transition-colors">
        Access 15+ Free Dev Tools →
      </a>
      <a href="/free-checklist" class="px-7 py-3 bg-bg-card border border-border hover:border-primary text-text font-semibold rounded-xl transition-colors">
        Grab Free Dev Checklist →
      </a>
    </div>

    <p class="text-text-muted text-sm mt-10">
      <a href="/" class="text-primary hover:underline">← Back to DevPlaybook</a>
    </p>
  </div>
</BaseLayout>
