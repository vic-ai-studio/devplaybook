---
import BaseLayout from '../layouts/BaseLayout.astro';

// Prompt templates data
const promptCategories = [
  {
    id: 'blog',
    name: 'Blog Writing',
    icon: '✍️',
    platform: 'Any AI',
    description: 'Full-length articles, outlines, and hooks',
    templates: [
      {
        name: 'Blog Post Outline',
        desc: 'Generate a structured blog outline with introduction, 5 key points, and conclusion',
        prompt: 'Create a detailed blog post outline for [TOPIC]. Include: 1) Hook headline (under 60 chars), 2) 5 H2 sections with 3 bullet points each, 3) A compelling conclusion with CTA. Audience: [AUDIENCE]. Tone: [TONE].',
        variables: ['TOPIC', 'AUDIENCE', 'TONE'],
      },
      {
        name: 'SEO Article',
        desc: 'Write an SEO-optimized article with keyword integration',
        prompt: 'Write a 1500-word SEO article about [KEYWORD]. Include the keyword in the title, first 100 words, 3 subheadings, and conclusion. Add 2 external resource links and a FAQ section. Tone: informative and engaging.',
        variables: ['KEYWORD'],
      },
      {
        name: 'Listicle',
        desc: 'Create a numbered list article (e.g. "7 Ways to...")',
        prompt: 'Write a listicle article with [NUMBER] items about [TOPIC]. Each item should have a bold subheadline and 2-3 paragraphs of explanation. Include a hook introduction (100 words) and a conclusion summarizing the key takeaway.',
        variables: ['NUMBER', 'TOPIC'],
      },
      {
        name: 'How-To Guide',
        desc: 'Step-by-step tutorial format',
        prompt: 'Write a comprehensive how-to guide for [TASK]. Break it down into [NUMBER] clear steps. For each step include: what to do, why it matters, and a common mistake to avoid. End with a troubleshooting FAQ section.',
        variables: ['TASK', 'NUMBER'],
      },
    ],
  },
  {
    id: 'social',
    name: 'Social Media',
    icon: '📱',
    platform: 'ChatGPT / Claude',
    description: 'LinkedIn, Twitter/X, Instagram captions',
    templates: [
      {
        name: 'LinkedIn Post',
        desc: 'Professional post with hook, insight, and CTA',
        prompt: 'Write a LinkedIn post about [INSIGHT]. Structure: 1) Hook line (make people stop scrolling), 2) 3 short paragraphs sharing a key insight or lesson, 3) A question to drive comments, 4) 3 relevant hashtags. Tone: professional but approachable.',
        variables: ['INSIGHT'],
      },
      {
        name: 'Twitter Thread',
        desc: 'Engaging thread on a complex topic',
        prompt: 'Create a Twitter/X thread of [NUMBER] tweets about [TOPIC]. Tweet 1 is the hook (memorable statement). Tweets 2-[NUMBER-1] expand on the topic with one key point each. Tweet [NUMBER] is the CTA or key takeaway. Add relevant hashtags at the end.',
        variables: ['NUMBER', 'TOPIC'],
      },
      {
        name: 'Instagram Caption',
        desc: 'Scroll-stopping caption with story angle',
        prompt: 'Write an Instagram caption about [TOPIC]. Structure: 1) Hook in the first line (under 125 chars), 2) 2-3 short paragraphs telling a mini-story or sharing a lesson, 3) 3-5 relevant hashtags. Tone: conversational, relatable.',
        variables: ['TOPIC'],
      },
      {
        name: 'CTA Post',
        desc: 'Conversion-focused post with clear ask',
        prompt: 'Write a social media post about [TOPIC] that drives [DESIRED ACTION]. Include: 1) Emotional hook, 2) Problem-solution framing, 3) 2-3 social proof points, 4) Clear CTA with urgency. Keep under [CHAR LIMIT] characters.',
        variables: ['TOPIC', 'DESIRED ACTION', 'CHAR LIMIT'],
      },
    ],
  },
  {
    id: 'copy',
    name: 'Copywriting',
    icon: '🎯',
    platform: 'Any AI',
    description: 'Sales copy, landing pages, email sequences',
    templates: [
      {
        name: 'Landing Page Hero',
        desc: 'High-converting hero section headline + subheadline',
        prompt: 'Write 3 variations of a landing page hero section for [PRODUCT/SERVICE]. Each variation includes: 1) Main headline (under 10 words, benefit-focused), 2) Subheadline (1-2 sentences expanding on the benefit), 3) Primary CTA button text. Audience: [AUDIENCE]. Focus on [MAIN BENEFIT].',
        variables: ['PRODUCT/SERVICE', 'AUDIENCE', 'MAIN BENEFIT'],
      },
      {
        name: 'Email Subject Lines',
        desc: '10 high-open-rate subject lines',
        prompt: 'Generate 10 email subject lines for [EMAIL TOPIC]. Vary: urgency level (3 urgent, 4 curiosity, 3 personal), length (5 short under 40 chars, 5 longer 40-60 chars), and tone. Do not use emoji. Each should drive opens without being clickbait.',
        variables: ['EMAIL TOPIC'],
      },
      {
        name: 'Cold Email',
        desc: 'Personalized outreach that gets responses',
        prompt: 'Write a cold email to [PERSONA] about [OFFER]. Structure: 1) Personalized opening line referencing [PERSONALIZATION HOOK], 2) 2-sentence problem statement, 3) How you solve it (1 sentence), 4) Specific result/outcome (1 sentence), 5) Soft CTA. Keep total under 150 words.',
        variables: ['PERSONA', 'OFFER', 'PERSONALIZATION HOOK'],
      },
      {
        name: 'Product Description',
        desc: 'E-commerce or SaaS product copy that sells',
        prompt: 'Write a compelling product description for [PRODUCT]. Include: 1) Attention-grabbing first line, 2) 3 key features with benefits (not just specs), 3) Ideal customer persona fit, 4) Why this is better than alternatives. Tone: [TONE]. Target audience: [AUDIENCE].',
        variables: ['PRODUCT', 'TONE', 'AUDIENCE'],
      },
    ],
  },
  {
    id: 'video',
    name: 'Video Content',
    icon: '🎬',
    platform: 'ChatGPT / Claude',
    description: 'YouTube scripts, TikTok hooks, video outlines',
    templates: [
      {
        name: 'YouTube Script',
        desc: 'Full video script with hook, content, CTA',
        prompt: 'Write a YouTube video script about [TOPIC]. Duration: [LENGTH] minutes. Structure: 1) Hook (first 30 seconds to retain viewers), 2) Promise (what viewers will learn/feel), 3) 5 key points with timestamps, 4) Story or example for each point, 5) Summary, 6) End screen CTA. Tone: [TONE].',
        variables: ['TOPIC', 'LENGTH', 'TONE'],
      },
      {
        name: 'TikTok Script',
        desc: 'High-retention short-form video script',
        prompt: 'Write a TikTok/Reels script about [TOPIC] that drives [DESIRED ACTION]. Structure: 1) Hook (first 3 seconds — a bold statement or question), 2) Build-up (15 seconds building tension or curiosity), 3) Payoff (the insight or reveal), 4) CTA. Total: 30-60 seconds. Tone: [TONE].',
        variables: ['TOPIC', 'DESIRED ACTION', 'TONE'],
      },
      {
        name: 'Video Outline',
        desc: 'Talk-track outline for longer videos',
        prompt: 'Create a video outline for [TOPIC] targeting [AUDIENCE]. Include: 1) Pre-roll hook (1 sentence), 2) Opening problem statement (30 seconds), 3) 5 main points with talking notes (2-3 sentences each), 4) Objection handling section, 5) Final CTA. Total video length: [LENGTH] minutes.',
        variables: ['TOPIC', 'AUDIENCE', 'LENGTH'],
      },
    ],
  },
  {
    id: 'research',
    name: 'Research & Analysis',
    icon: '🔍',
    platform: 'Claude / ChatGPT',
    description: 'Market research, competitor analysis, summaries',
    templates: [
      {
        name: 'Competitor Analysis',
        desc: 'Structured competitive research report',
        prompt: 'Create a competitor analysis for [COMPETITOR] targeting [MARKET]. Cover: 1) Company overview (size, positioning, target customer), 2) Product strengths and weaknesses, 3) Pricing strategy, 4) Marketing approach, 5) Content strategy, 6) Potential gaps we can exploit. Format as a structured report.',
        variables: ['COMPETITOR', 'MARKET'],
      },
      {
        name: 'Article Summary',
        desc: 'Key takeaways from long-form content',
        prompt: 'Summarize [CONTENT LINK OR TEXT] in a structured format: 1) TL;DR (3 sentences), 2) Key Insight (1 paragraph), 3) 5 Main Takeaways (bullet points), 4) Actionable Next Step (1 specific thing to do), 5) Who should read this and why.',
        variables: ['CONTENT LINK OR TEXT'],
      },
      {
        name: 'Market Research Brief',
        desc: 'Comprehensive market analysis framework',
        prompt: 'Conduct a market research brief for [PRODUCT/SERVICE] in [MARKET]. Cover: 1) Market size and growth rate, 2) Target customer profile (demographics, psychographics, pain points), 3) Competitive landscape (top 5 players), 4) Pricing benchmarks, 5) Key trends, 6) Opportunities and threats. Be specific with data where possible.',
        variables: ['PRODUCT/SERVICE', 'MARKET'],
      },
    ],
  },
];

const gumroadProducts = [
  {
    name: 'AI 社群行銷助手',
    subtitle: '50 個實用提示詞',
    price: '$14.99',
    description: '50 個經實測的 AI 社群行銷提示詞，涵蓋 Instagram、LinkedIn、Threads 三大平台。含完整使用範例與情境說明。',
    badge: '熱銷中',
    badgeColor: 'green',
    href: 'https://devplaybook.cc/gumroad (auto-redirect via page link)',
    tags: ['社群行銷', 'IG', 'LinkedIn', '內容行銷'],
    features: ['IG 爆款文案 (10)', 'LinkedIn 專業建立 (8)', 'Threads 趨勢搭話 (7)', 'CTA 優化 (5)', 'Hashtag 策略 (5)'],
  },
  {
    name: 'AI Coding Prompts Mega Pack',
    subtitle: '200+ 開發者專用提示詞',
    price: '$19',
    description: '200+ 程式開發專用 AI 提示詞，含 Code Review、Debug、Branch Strategy、README 生成等分類。工程師必備。',
    badge: '最新',
    badgeColor: 'blue',
    href: 'https://devplaybook.cc/gumroad (auto-redirect via page link)',
    tags: ['開發者', '程式', 'Code Review', 'Git'],
    features: ['Code Review (30+)', 'Debug Assistant (25+)', 'Git Workflow (20+)', 'README 生成 (15+)', 'API Design (20+)'],
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "AI Writing Prompt Generator — DevPlaybook",
  "description": "Generate optimized AI writing prompts for blog, social media, copywriting, and video content. Free tool with links to premium prompt packs.",
  "url": "https://devplaybook.cc/ai-writing-prompt-generator",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "48",
  },
};
---

<BaseLayout
  title="AI Writing Prompt Generator — Free Tool + Premium Prompt Packs"
  description="Generate optimized AI writing prompts instantly for blog posts, social media, copywriting, and video content. Free browser tool + premium prompt packs on Gumroad."
  canonical="/ai-writing-prompt-generator"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  {/* Breadcrumb */}
  <nav class="text-sm text-text-muted mb-6" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2">
      <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
      <li>/</li>
      <li><a href="/ai-tools" class="hover:text-primary transition-colors">AI Tools</a></li>
      <li>/</li>
      <li class="text-text font-medium">Prompt Generator</li>
    </ol>
  </nav>

  {/* Hero */}
  <div class="mb-8">
    <div class="flex items-center gap-2 mb-3">
      <span class="text-xs font-semibold uppercase tracking-widest bg-primary/10 text-primary px-3 py-1 rounded-full">Free Tool</span>
      <span class="text-xs font-semibold uppercase tracking-widest bg-green-500/10 text-green-400 px-3 py-1 rounded-full">No Login Required</span>
    </div>
    <h1 class="text-3xl font-bold mb-3">
      AI Writing <span class="text-primary">Prompt Generator</span>
    </h1>
    <p class="text-text-muted text-lg max-w-2xl">
      Select a category, pick a template, fill in your variables. Get a production-ready AI prompt in seconds. No account needed — completely free.
    </p>
  </div>

  {/* Generator Interface */}
  <div class="grid lg:grid-cols-5 gap-6 mb-10">
    {/* Sidebar — Category selector */}
    <div class="lg:col-span-2">
      <div class="bg-bg-card border border-border rounded-xl p-4 sticky top-4">
        <h2 class="text-sm font-semibold uppercase tracking-widest text-text-muted mb-4">Choose Category</h2>
        <div class="space-y-2" id="category-list">
          {promptCategories.map((cat, i) => (
            <button
              data-category={cat.id}
              class={`category-btn w-full text-left px-4 py-3 rounded-lg border transition-all flex items-start gap-3 ${i === 0 ? 'bg-primary/10 border-primary text-primary' : 'bg-bg border-border text-text-muted hover:border-primary/50'}`}
            >
              <span class="text-xl shrink-0">{cat.icon}</span>
              <div>
                <p class="font-semibold text-sm">{cat.name}</p>
                <p class="text-xs opacity-70 mt-0.5">{cat.platform}</p>
              </div>
            </button>
          ))}
        </div>
      </div>
    </div>

    {/* Main — Template selector + output */}
    <div class="lg:col-span-3">
      {/* Template selector */}
      <div class="bg-bg-card border border-border rounded-xl p-5 mb-4">
        <h2 class="text-sm font-semibold uppercase tracking-widest text-text-muted mb-4">Choose Template</h2>
        <div class="space-y-2" id="template-list">
          {promptCategories[0].templates.map((t, i) => (
            <button
              data-template={i}
              class={`template-btn w-full text-left px-4 py-3 rounded-lg border transition-all ${i === 0 ? 'bg-primary/10 border-primary' : 'bg-bg border-border hover:border-primary/50'}`}
            >
              <p class="font-semibold text-sm">{t.name}</p>
              <p class="text-xs text-text-muted mt-0.5">{t.desc}</p>
            </button>
          ))}
        </div>
      </div>

      {/* Variable inputs */}
      <div class="bg-bg-card border border-border rounded-xl p-5 mb-4" id="variable-section" style="display:none">
        <h2 class="text-sm font-semibold uppercase tracking-widest text-text-muted mb-4">Fill Variables</h2>
        <div class="space-y-3" id="variable-inputs"></div>
        <button
          id="generate-btn"
          class="mt-4 w-full bg-primary text-white font-semibold py-3 rounded-lg hover:bg-primary/90 transition-colors"
        >
          Generate Prompt ✨
        </button>
      </div>

      {/* Output */}
      <div class="bg-bg-card border border-border rounded-xl p-5" id="output-section" style="display:none">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold uppercase tracking-widest text-text-muted">Your Prompt</h2>
          <button
            id="copy-btn"
            class="text-xs text-primary hover:text-primary/80 transition-colors font-medium"
          >
            📋 Copy to clipboard
          </button>
        </div>
        <div class="bg-[#1e293b] rounded-lg p-4 text-sm text-gray-200 font-mono leading-relaxed whitespace-pre-wrap" id="prompt-output"></div>
      </div>
    </div>
  </div>

  {/* Gumroad Product Section */}
  <div class="border-t border-border pt-10 mb-10">
    <div class="text-center mb-8">
      <h2 class="text-2xl font-bold mb-2">Ready-to-Use Prompt Packs</h2>
      <p class="text-text-muted max-w-xl mx-auto">
        50–200+ production-tested prompts. Buy once, use forever. Instant digital delivery.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
      {gumroadProducts.map(product => (
        <div class="bg-bg-card border border-border rounded-xl p-6 hover:border-primary/50 transition-colors">
          <div class="flex items-start justify-between mb-3">
            <div>
              <h3 class="font-bold text-lg">{product.name}</h3>
              <p class="text-sm text-text-muted">{product.subtitle}</p>
            </div>
            <span class={`text-xs font-semibold px-2 py-1 rounded-full ${
              product.badgeColor === 'green' ? 'bg-green-500/10 text-green-400' : 'bg-blue-500/10 text-blue-400'
            }`}>
              {product.badge}
            </span>
          </div>

          <p class="text-sm text-text-muted mb-4">{product.description}</p>

          <div class="flex flex-wrap gap-1.5 mb-4">
            {product.tags.map(tag => (
              <span class="text-xs bg-bg border border-border px-2 py-0.5 rounded text-text-muted">{tag}</span>
            ))}
          </div>

          <div class="text-xs text-text-muted space-y-1 mb-4">
            {product.features.map(f => (
              <p>• {f}</p>
            ))}
          </div>

          <div class="flex items-center justify-between pt-3 border-t border-border">
            <span class="text-xl font-bold">{product.price}</span>
            <a
              href={product.href}
              class="bg-primary text-white text-sm font-semibold px-5 py-2 rounded-lg hover:bg-primary/90 transition-colors"
            >
              View on Gumroad →
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>

  {/* How it works */}
  <div class="border-t border-border pt-10 mb-10">
    <h2 class="text-2xl font-bold mb-6 text-center">How the Generator Works</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="text-center">
        <div class="text-3xl mb-3">1️⃣</div>
        <h3 class="font-semibold mb-2">Pick a Category</h3>
        <p class="text-sm text-text-muted">Blog, Social Media, Copywriting, Video, or Research — each with purpose-built templates.</p>
      </div>
      <div class="text-center">
        <div class="text-3xl mb-3">2️⃣</div>
        <h3 class="font-semibold mb-2">Fill Variables</h3>
        <p class="text-sm text-text-muted">Replace [VARIABLES] like [TOPIC] or [AUDIENCE] with your specifics. No guesswork.</p>
      </div>
      <div class="text-center">
        <div class="text-3xl mb-3">3️⃣</div>
        <h3 class="font-semibold mb-2">Copy & Use Anywhere</h3>
        <p class="text-sm text-text-muted">Paste into ChatGPT, Claude, Gemini, or any AI assistant. Works with all models.</p>
      </div>
    </div>
  </div>

  {/* Internal links */}
  <div class="border-t border-border pt-8">
    <h2 class="text-lg font-semibold mb-4">Related Resources</h2>
    <div class="grid md:grid-cols-3 gap-4">
      <a href="/ai-writing-tools" class="group p-4 bg-bg-card border border-border rounded-xl hover:border-primary transition-colors">
        <p class="font-semibold text-sm group-hover:text-primary">AI Writing Tools Comparison</p>
        <p class="text-xs text-text-muted mt-1">Jasper, Copy.ai, Writesonic, Rytr compared</p>
      </a>
      <a href="/ai-coding-assistants" class="group p-4 bg-bg-card border border-border rounded-xl hover:border-primary transition-colors">
        <p class="font-semibold text-sm group-hover:text-primary">AI Coding Assistants</p>
        <p class="text-xs text-text-muted mt-1">Claude, Copilot, Cursor and more</p>
      </a>
      <a href="/blog" class="group p-4 bg-bg-card border border-border rounded-xl hover:border-primary transition-colors">
        <p class="font-semibold text-sm group-hover:text-primary">DevPlaybook Blog</p>
        <p class="text-xs text-text-muted mt-1">Developer tips, AI workflows, productivity</p>
      </a>
    </div>
  </div>

</BaseLayout>

<script id="prompt-categories-data" type="application/json" set:html={JSON.stringify(promptCategories)} />

<script>
  // ── Prompt Generator Logic ──────────────────────────────────────────
  const categories = JSON.parse(document.getElementById('prompt-categories-data')!.textContent!);

  let currentCat = 0;
  let currentTemplate = 0;

  const categoryBtns = document.querySelectorAll<HTMLButtonElement>('.category-btn');
  const templateBtns = document.querySelectorAll<HTMLButtonElement>('.template-btn');
  const variableSection = document.getElementById('variable-section')!;
  const variableInputs = document.getElementById('variable-inputs')!;
  const generateBtn = document.getElementById('generate-btn')!;
  const outputSection = document.getElementById('output-section')!;
  const promptOutput = document.getElementById('prompt-output')!;
  const copyBtn = document.getElementById('copy-btn')!;

  function getCat(idx: number) {
    return (categories as any)[idx];
  }

  function renderTemplates(catIdx: number) {
    const cat = getCat(catIdx);
    const list = document.getElementById('template-list')!;
    list.innerHTML = '';
    cat.templates.forEach((t: any, i: number) => {
      const btn = document.createElement('button');
      btn.className = `template-btn w-full text-left px-4 py-3 rounded-lg border transition-all ${i === 0 ? 'bg-primary/10 border-primary' : 'bg-bg border-border hover:border-primary/50'}`;
      btn.dataset.template = String(i);
      btn.innerHTML = `<p class="font-semibold text-sm">${t.name}</p><p class="text-xs text-text-muted mt-0.5">${t.desc}</p>`;
      btn.addEventListener('click', () => selectTemplate(catIdx, i));
      list.appendChild(btn);
    });
  }

  function selectCategory(catIdx: number) {
    currentCat = catIdx;
    currentTemplate = 0;
    categoryBtns.forEach((b, i) => {
      if (i === catIdx) {
        b.classList.add('bg-primary/10', 'border-primary', 'text-primary');
        b.classList.remove('bg-bg', 'border-border', 'text-text-muted');
      } else {
        b.classList.remove('bg-primary/10', 'border-primary', 'text-primary');
        b.classList.add('bg-bg', 'border-border', 'text-text-muted');
      }
    });
    renderTemplates(catIdx);
    renderVariables();
  }

  function selectTemplate(catIdx: number, tplIdx: number) {
    currentCat = catIdx;
    currentTemplate = tplIdx;
    templateBtns.forEach((b, i) => {
      if (i === tplIdx) {
        b.classList.add('bg-primary/10', 'border-primary');
        b.classList.remove('bg-bg', 'border-border');
      } else {
        b.classList.remove('bg-primary/10', 'border-primary');
        b.classList.add('bg-bg', 'border-border');
      }
    });
    renderVariables();
  }

  function renderVariables() {
    const cat = getCat(currentCat);
    const template = cat.templates[currentTemplate];
    variableInputs.innerHTML = '';
    if (!template.variables || template.variables.length === 0) {
      variableSection.style.display = 'none';
      return;
    }
    variableSection.style.display = 'block';
    template.variables.forEach((v: string) => {
      const label = document.createElement('label');
      label.className = 'block';
      label.innerHTML = `
        <span class="text-xs font-semibold text-text-muted uppercase tracking-wide mb-1 block">${v.replace(/_/g, ' ')}</span>
        <input
          type="text"
          data-var="${v}"
          placeholder="Enter ${v.replace(/_/g, ' ').toLowerCase()}..."
          class="w-full bg-bg border border-border rounded-lg px-3 py-2 text-sm text-text placeholder-text-muted/50 focus:outline-none focus:border-primary"
        />
      `;
      variableInputs.appendChild(label);
    });
  }

  categoryBtns.forEach((btn, i) => {
    btn.addEventListener('click', () => selectCategory(i));
  });

  generateBtn.addEventListener('click', () => {
    const cat = getCat(currentCat);
    const template = cat.templates[currentTemplate];
    let prompt = template.prompt;
    template.variables?.forEach((v: string) => {
      const input = document.querySelector<HTMLInputElement>(`[data-var="${v}"]`);
      const val = input?.value.trim() || `[${v}]`;
      prompt = prompt.replace(new RegExp(`\\[${v.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')}\\]`, 'g'), val);
    });
    promptOutput.textContent = prompt;
    outputSection.style.display = 'block';
    outputSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });

  copyBtn.addEventListener('click', () => {
    const text = promptOutput.textContent || '';
    navigator.clipboard.writeText(text).then(() => {
      copyBtn.textContent = '✅ Copied!';
      setTimeout(() => { copyBtn.textContent = '📋 Copy to clipboard'; }, 2000);
    });
  });

  // Init
  selectCategory(0);
</script>
