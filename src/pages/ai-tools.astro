---
import BaseLayout from '../layouts/BaseLayout.astro';

const tools = [
  {
    name: 'GitHub Copilot',
    logo: '🤖',
    price: 'Free (students) / $10/mo',
    freeTier: true,
    freeDetails: 'Free for students & OSS maintainers',
    languages: 'All major languages',
    ideSupport: 'VS Code, JetBrains, Neovim, CLI',
    bestFor: 'Teams on GitHub, enterprise orgs',
    rating: 4,
    href: 'https://github.com/features/copilot',
    tags: ['popular', 'enterprise'],
    inlineCompletion: true,
    chat: true,
    multiFile: true,
  },
  {
    name: 'Cursor',
    logo: '⚡',
    price: 'Free / $20/mo Pro',
    freeTier: true,
    freeDetails: '2000 completions/mo free',
    languages: 'All major languages',
    ideSupport: 'Cursor (VS Code fork)',
    bestFor: 'Whole-codebase AI edits, power users',
    rating: 5,
    href: 'https://cursor.sh',
    tags: ['popular', 'best-value'],
    inlineCompletion: true,
    chat: true,
    multiFile: true,
  },
  {
    name: 'Codeium',
    logo: '🟢',
    price: 'Free forever / $15/mo Teams',
    freeTier: true,
    freeDetails: 'Unlimited completions free',
    languages: '70+ languages',
    ideSupport: 'VS Code, JetBrains, Vim, Emacs, 40+ more',
    bestFor: 'Solo devs, wide IDE coverage, budget-conscious',
    rating: 4,
    href: 'https://codeium.com',
    tags: ['free', 'popular'],
    inlineCompletion: true,
    chat: true,
    multiFile: false,
  },
  {
    name: 'Tabnine',
    logo: '🔵',
    price: 'Free / $12/mo Pro',
    freeTier: true,
    freeDetails: 'Basic completions free',
    languages: '30+ languages',
    ideSupport: 'VS Code, JetBrains, Sublime, Vim',
    bestFor: 'Privacy-conscious teams, on-prem deployment',
    rating: 3,
    href: 'https://www.tabnine.com',
    tags: ['enterprise', 'privacy'],
    inlineCompletion: true,
    chat: true,
    multiFile: false,
  },
  {
    name: 'Amazon CodeWhisperer',
    logo: '☁️',
    price: 'Free (individual) / $19/mo Pro',
    freeTier: true,
    freeDetails: 'Free for individuals, unlimited',
    languages: '15+ languages',
    ideSupport: 'VS Code, JetBrains, AWS Cloud9',
    bestFor: 'AWS users, security scanning built-in',
    rating: 3,
    href: 'https://aws.amazon.com/codewhisperer',
    tags: ['free', 'aws'],
    inlineCompletion: true,
    chat: false,
    multiFile: false,
  },
  {
    name: 'Supermaven',
    logo: '🦸',
    price: 'Free / $10/mo Pro',
    freeTier: true,
    freeDetails: 'Free tier available',
    languages: 'All major languages',
    ideSupport: 'VS Code, JetBrains, Neovim',
    bestFor: 'Ultra-fast completions, large context window',
    rating: 4,
    href: 'https://supermaven.com',
    tags: ['fast'],
    inlineCompletion: true,
    chat: false,
    multiFile: false,
  },
  {
    name: 'Continue.dev',
    logo: '🔓',
    price: 'Free (open source)',
    freeTier: true,
    freeDetails: 'Fully open source, BYOM',
    languages: 'All languages (model-dependent)',
    ideSupport: 'VS Code, JetBrains',
    bestFor: 'Self-hosted LLMs, privacy-first, DIY setups',
    rating: 4,
    href: 'https://continue.dev',
    tags: ['open-source', 'privacy'],
    inlineCompletion: true,
    chat: true,
    multiFile: true,
  },
  {
    name: 'Aider',
    logo: '🖥️',
    price: 'Free (open source)',
    freeTier: true,
    freeDetails: 'Open source, bring your own API key',
    languages: 'All languages',
    ideSupport: 'Terminal / CLI',
    bestFor: 'CLI power users, git-aware AI edits',
    rating: 4,
    href: 'https://aider.chat',
    tags: ['open-source', 'cli'],
    inlineCompletion: false,
    chat: true,
    multiFile: true,
  },
];

const allTags = ['popular', 'free', 'enterprise', 'open-source', 'privacy', 'best-value', 'aws', 'fast', 'cli'];
---

<BaseLayout
  title="Best AI Coding Tools 2025 — GitHub Copilot Alternatives Compared"
  description="Side-by-side comparison of the best AI coding assistants in 2025: GitHub Copilot, Cursor, Codeium, Tabnine, Amazon CodeWhisperer, and more. Free tiers, pricing, IDE support."
>
  <div class="mb-8">
    <h1 class="text-3xl font-bold mb-3">
      Best AI Coding Tools in 2025
    </h1>
    <p class="text-text-muted text-lg">
      Side-by-side comparison of GitHub Copilot alternatives. Filter by free tier, IDE support, and best use case.
    </p>
  </div>

  {/* Filter bar */}
  <div id="filter-bar" class="flex flex-wrap gap-2 mb-8">
    <button
      data-filter="all"
      class="filter-btn px-3 py-1.5 rounded-full text-sm font-medium border bg-primary text-white border-primary transition-colors"
    >All tools</button>
    {allTags.map(tag => (
      <button
        data-filter={tag}
        class="filter-btn px-3 py-1.5 rounded-full text-sm font-medium border border-border text-text-muted hover:border-primary hover:text-primary transition-colors"
      >
        {tag.replace('-', ' ')}
      </button>
    ))}
    <label class="ml-auto flex items-center gap-2 text-sm text-text-muted cursor-pointer">
      <input id="free-only" type="checkbox" class="accent-primary" />
      Free tier only
    </label>
  </div>

  {/* Desktop table */}
  <div class="hidden md:block overflow-x-auto rounded-xl border border-border mb-10">
    <table class="w-full text-sm" id="tools-table">
      <thead>
        <tr class="bg-bg-card border-b border-border text-text-muted text-left">
          <th class="px-4 py-3 font-semibold">Tool</th>
          <th class="px-4 py-3 font-semibold cursor-pointer hover:text-primary" data-sort="price">Price ↕</th>
          <th class="px-4 py-3 font-semibold">Free Tier</th>
          <th class="px-4 py-3 font-semibold">Languages</th>
          <th class="px-4 py-3 font-semibold">IDE Support</th>
          <th class="px-4 py-3 font-semibold">Inline</th>
          <th class="px-4 py-3 font-semibold">Chat</th>
          <th class="px-4 py-3 font-semibold">Multi-file</th>
          <th class="px-4 py-3 font-semibold">Best For</th>
        </tr>
      </thead>
      <tbody id="table-body">
        {tools.map((tool, i) => (
          <tr
            class={`tool-row border-b border-border hover:bg-bg-card/60 transition-colors ${i % 2 === 0 ? '' : 'bg-bg-card/20'}`}
            data-tags={tool.tags.join(',')}
            data-free={tool.freeTier ? 'true' : 'false'}
            data-name={tool.name}
          >
            <td class="px-4 py-3">
              <a href={tool.href} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 font-semibold hover:text-primary">
                <span class="text-xl">{tool.logo}</span>
                {tool.name}
              </a>
            </td>
            <td class="px-4 py-3 text-text-muted">{tool.price}</td>
            <td class="px-4 py-3">
              {tool.freeTier
                ? <span class="text-green-400 font-medium" title={tool.freeDetails}>✓ Yes</span>
                : <span class="text-text-muted">✗ No</span>
              }
            </td>
            <td class="px-4 py-3 text-text-muted">{tool.languages}</td>
            <td class="px-4 py-3 text-text-muted">{tool.ideSupport}</td>
            <td class="px-4 py-3 text-center">{tool.inlineCompletion ? '✓' : '—'}</td>
            <td class="px-4 py-3 text-center">{tool.chat ? '✓' : '—'}</td>
            <td class="px-4 py-3 text-center">{tool.multiFile ? '✓' : '—'}</td>
            <td class="px-4 py-3 text-text-muted text-xs">{tool.bestFor}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  {/* Mobile cards */}
  <div class="md:hidden space-y-4 mb-10" id="mobile-cards">
    {tools.map(tool => (
      <div
        class="tool-row bg-bg-card border border-border rounded-xl p-5"
        data-tags={tool.tags.join(',')}
        data-free={tool.freeTier ? 'true' : 'false'}
        data-name={tool.name}
      >
        <div class="flex items-start justify-between mb-3">
          <a href={tool.href} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 font-semibold hover:text-primary text-lg">
            <span class="text-2xl">{tool.logo}</span>
            {tool.name}
          </a>
          {tool.freeTier && <span class="text-green-400 text-xs font-medium bg-green-400/10 px-2 py-0.5 rounded-full">Free tier</span>}
        </div>
        <dl class="grid grid-cols-2 gap-y-2 text-sm">
          <dt class="text-text-muted">Price</dt><dd>{tool.price}</dd>
          <dt class="text-text-muted">Languages</dt><dd>{tool.languages}</dd>
          <dt class="text-text-muted">IDE</dt><dd>{tool.ideSupport}</dd>
          <dt class="text-text-muted">Best for</dt><dd class="col-span-1 text-text-muted">{tool.bestFor}</dd>
        </dl>
        <div class="flex gap-3 mt-3 text-xs text-text-muted">
          {tool.inlineCompletion && <span class="bg-bg border border-border px-2 py-0.5 rounded">Inline ✓</span>}
          {tool.chat && <span class="bg-bg border border-border px-2 py-0.5 rounded">Chat ✓</span>}
          {tool.multiFile && <span class="bg-bg border border-border px-2 py-0.5 rounded">Multi-file ✓</span>}
        </div>
      </div>
    ))}
  </div>

  {/* SEO content */}
  <div class="prose prose-invert max-w-none">
    <h2 class="text-2xl font-bold mb-4">GitHub Copilot Alternatives in 2025</h2>
    <div class="grid md:grid-cols-2 gap-6 not-prose mb-8">
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h3 class="font-semibold mb-2">🏆 Best Overall: Cursor</h3>
        <p class="text-text-muted text-sm">
          Cursor leads the pack with whole-codebase context, multi-file edits, and a free tier that handles real workloads.
          If you do most of your coding in VS Code, Cursor's fork is the most seamless upgrade.
        </p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h3 class="font-semibold mb-2">💸 Best Free Option: Codeium</h3>
        <p class="text-text-muted text-sm">
          Codeium offers unlimited completions for free, supports 70+ languages, and works in 40+ IDEs. Hard to beat
          for solo developers or students.
        </p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h3 class="font-semibold mb-2">🔒 Best for Privacy: Continue.dev</h3>
        <p class="text-text-muted text-sm">
          Open source and self-hostable. Bring your own model (Ollama, OpenAI, Anthropic). Zero data leaves your
          machine if you run local models.
        </p>
      </div>
      <div class="bg-bg-card border border-border rounded-xl p-5">
        <h3 class="font-semibold mb-2">🏢 Best for Enterprise: GitHub Copilot</h3>
        <p class="text-text-muted text-sm">
          Deep GitHub integration, SOC2 compliance, org-level policy controls, and IP protection make Copilot the
          safe enterprise choice.
        </p>
      </div>
    </div>

    <h2 class="text-2xl font-bold mb-4">How to Choose the Right AI Coding Tool</h2>
    <ul class="space-y-2 text-text-muted mb-8">
      <li><strong class="text-text">You're on a team using GitHub</strong> → GitHub Copilot for seamless PR integration.</li>
      <li><strong class="text-text">You want the best AI power</strong> → Cursor with Claude Sonnet or GPT-4o backing.</li>
      <li><strong class="text-text">Budget is zero</strong> → Codeium or CodeWhisperer both offer real free tiers.</li>
      <li><strong class="text-text">You want to self-host</strong> → Continue.dev with Ollama for full privacy.</li>
      <li><strong class="text-text">You love the terminal</strong> → Aider for git-aware, CLI-based multi-file edits.</li>
    </ul>

    <p class="text-text-muted text-sm">
      Last updated: March 2025. Prices and features change — always verify on the vendor's official site.
    </p>
  </div>

  {/* Related tools CTA */}
  <div class="mt-10 bg-bg-card border border-border rounded-xl p-6 text-center">
    <p class="text-text-muted mb-4">More developer tools on DevPlaybook</p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a href="/tools" class="bg-primary hover:bg-primary-dark text-white font-semibold px-5 py-2.5 rounded-lg transition-colors">All Free Tools</a>
      <a href="/tools/git-command-builder" class="bg-bg border border-border hover:border-primary text-text px-5 py-2.5 rounded-lg transition-colors">Git Command Builder</a>
      <a href="/tools/pomodoro-timer" class="bg-bg border border-border hover:border-primary text-text px-5 py-2.5 rounded-lg transition-colors">Pomodoro Timer</a>
    </div>
  </div>

  <script>
    // Filter logic
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const freeOnly = document.getElementById('free-only') as HTMLInputElement;
    let activeFilter = 'all';

    function applyFilters() {
      const rows = document.querySelectorAll<HTMLElement>('.tool-row');
      rows.forEach(row => {
        const tags = row.dataset.tags ?? '';
        const isFree = row.dataset.free === 'true';
        const tagMatch = activeFilter === 'all' || tags.split(',').includes(activeFilter);
        const freeMatch = !freeOnly.checked || isFree;
        row.style.display = tagMatch && freeMatch ? '' : 'none';
      });
    }

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        activeFilter = btn.dataset.filter ?? 'all';
        filterBtns.forEach(b => {
          b.classList.toggle('bg-primary', b === btn);
          b.classList.toggle('text-white', b === btn);
          b.classList.toggle('border-primary', b === btn);
          b.classList.toggle('border-border', b !== btn);
          b.classList.toggle('text-text-muted', b !== btn);
        });
        applyFilters();
      });
    });

    freeOnly.addEventListener('change', applyFilters);
  </script>
</BaseLayout>
