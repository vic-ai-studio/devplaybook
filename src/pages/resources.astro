---
import BaseLayout from '../layouts/BaseLayout.astro';

const categories = [
  {
    id: 'hosting',
    icon: '☁️',
    title: 'Cloud & Hosting',
    description: 'Where to deploy your apps',
    items: [
      {
        name: 'DigitalOcean',
        tagline: '$200 free credit for new users',
        description: 'Simple, reliable cloud hosting. Great for VPS, managed databases, and Kubernetes. New users get $200 in credit over 60 days.',
        url: 'https://www.digitalocean.com/?refcode=devplaybook',
        badge: '$200 Credit',
        badgeColor: 'text-green-400 bg-green-400/10 border-green-400/30',
        tags: ['VPS', 'Managed DB', 'Kubernetes'],
      },
      {
        name: 'Vercel',
        tagline: 'Best frontend deployment platform',
        description: 'Deploy Next.js, Astro, and any frontend framework instantly. Free tier is generous. Scales automatically.',
        url: 'https://vercel.com/?utm_source=devplaybook',
        badge: 'Free Tier',
        badgeColor: 'text-blue-400 bg-blue-400/10 border-blue-400/30',
        tags: ['Next.js', 'Astro', 'Serverless'],
      },
      {
        name: 'Cloudflare Pages',
        tagline: 'Edge-first static hosting',
        description: 'Ultra-fast static and JAMstack hosting on Cloudflare\'s global network. Generous free tier with unlimited bandwidth.',
        url: 'https://pages.cloudflare.com/',
        badge: 'Free',
        badgeColor: 'text-orange-400 bg-orange-400/10 border-orange-400/30',
        tags: ['Edge', 'CDN', 'Workers'],
      },
    ],
  },
  {
    id: 'dev-tools',
    icon: '🛠️',
    title: 'Dev Tools & IDEs',
    description: 'Tools that make you faster',
    items: [
      {
        name: 'GitHub Copilot',
        tagline: 'AI pair programmer',
        description: 'AI code completion that actually works. Understands context, generates full functions, and explains code. Essential for modern development.',
        url: 'https://github.com/features/copilot',
        badge: 'AI',
        badgeColor: 'text-purple-400 bg-purple-400/10 border-purple-400/30',
        tags: ['AI', 'Autocomplete', 'All IDEs'],
      },
      {
        name: 'Warp Terminal',
        tagline: 'The modern terminal for developers',
        description: 'Fast, Rust-based terminal with AI command suggestions, block-based UI, and collaborative workflows. Free for individual use.',
        url: 'https://www.warp.dev/',
        badge: 'Free',
        badgeColor: 'text-blue-400 bg-blue-400/10 border-blue-400/30',
        tags: ['Terminal', 'AI', 'macOS'],
      },
      {
        name: 'TablePlus',
        tagline: 'Modern database GUI',
        description: 'Clean, fast database management for PostgreSQL, MySQL, SQLite, Redis, and more. Native app with a free tier.',
        url: 'https://tableplus.com/',
        badge: 'Native App',
        badgeColor: 'text-indigo-400 bg-indigo-400/10 border-indigo-400/30',
        tags: ['PostgreSQL', 'MySQL', 'Redis'],
      },
    ],
  },
  {
    id: 'ai-tools',
    icon: '🤖',
    title: 'AI Tools',
    description: 'Supercharge your workflow with AI',
    items: [
      {
        name: 'Claude (Anthropic)',
        tagline: 'Best AI for coding and writing',
        description: 'Claude excels at long-context tasks, code review, and nuanced reasoning. Claude Pro gives you priority access and larger context windows.',
        url: 'https://claude.ai/',
        badge: 'Recommended',
        badgeColor: 'text-primary bg-primary/10 border-primary/30',
        tags: ['LLM', 'Code', 'Writing'],
      },
      {
        name: 'Cursor',
        tagline: 'AI-powered code editor',
        description: 'VS Code fork with deep AI integration. Codebase-aware completions, multi-file edits, and chat with your entire project.',
        url: 'https://cursor.com/',
        badge: 'Popular',
        badgeColor: 'text-yellow-400 bg-yellow-400/10 border-yellow-400/30',
        tags: ['IDE', 'AI', 'VS Code'],
      },
      {
        name: 'v0 by Vercel',
        tagline: 'UI generation from prompts',
        description: 'Generate production-ready React + Tailwind components from text prompts. Great for rapid prototyping.',
        url: 'https://v0.dev/',
        badge: 'Free Tier',
        badgeColor: 'text-blue-400 bg-blue-400/10 border-blue-400/30',
        tags: ['UI', 'React', 'Tailwind'],
      },
    ],
  },
  {
    id: 'monitoring',
    icon: '📊',
    title: 'Monitoring & Analytics',
    description: 'Know what\'s happening in production',
    items: [
      {
        name: 'Sentry',
        tagline: 'Error tracking that developers love',
        description: 'Catch and fix production errors before users report them. Deep integration with every major language and framework. Generous free tier.',
        url: 'https://sentry.io/',
        badge: 'Free Tier',
        badgeColor: 'text-green-400 bg-green-400/10 border-green-400/30',
        tags: ['Error Tracking', 'APM', 'Logs'],
      },
      {
        name: 'Plausible Analytics',
        tagline: 'Privacy-first web analytics',
        description: 'Lightweight, open-source alternative to Google Analytics. No cookies, GDPR compliant, simple dashboard.',
        url: 'https://plausible.io/',
        badge: 'Privacy First',
        badgeColor: 'text-teal-400 bg-teal-400/10 border-teal-400/30',
        tags: ['Analytics', 'Privacy', 'GDPR'],
      },
    ],
  },
  {
    id: 'databases',
    icon: '🗄️',
    title: 'Databases & Storage',
    description: 'Where to store your data',
    items: [
      {
        name: 'Supabase',
        tagline: 'Open-source Firebase alternative',
        description: 'Postgres database with a full backend platform: auth, storage, realtime, and edge functions. Free tier is very generous.',
        url: 'https://supabase.com/',
        badge: 'Free Tier',
        badgeColor: 'text-green-400 bg-green-400/10 border-green-400/30',
        tags: ['PostgreSQL', 'Auth', 'Realtime'],
      },
      {
        name: 'PlanetScale',
        tagline: 'MySQL-compatible serverless DB',
        description: 'Serverless MySQL with branching workflows, horizontal sharding, and zero-downtime migrations.',
        url: 'https://planetscale.com/',
        badge: 'Serverless',
        badgeColor: 'text-purple-400 bg-purple-400/10 border-purple-400/30',
        tags: ['MySQL', 'Serverless', 'Branching'],
      },
    ],
  },
];
---

<BaseLayout
  title="Developer Resources & Recommended Tools"
  description="Curated affiliate links and recommended tools for developers. Cloud hosting, AI tools, databases, monitoring, and more — all tools DevPlaybook actually uses."
  noDefaultJsonLd
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Developer Resources & Recommended Tools | DevPlaybook",
    "description": "Curated tools and services for developers. Hosting, AI, databases, monitoring — with affiliate links.",
    "url": "https://devplaybook.cc/resources",
  })} />

  <!-- Hero -->
  <div class="text-center mb-12">
    <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-3">Curated Resources</p>
    <h1 class="text-4xl font-bold mb-3">Developer <span class="text-primary">Resources</span></h1>
    <p class="text-text-muted text-lg max-w-2xl mx-auto">
      Tools and services we use and trust. Some links are affiliate links — you pay nothing extra, and commissions help keep DevPlaybook free.
    </p>
    <div class="flex justify-center gap-6 mt-5 text-sm text-text-muted">
      <span>✦ Personally evaluated</span>
      <span>✦ No paid placements</span>
      <span>✦ Always honest</span>
    </div>
  </div>

  <!-- Affiliate disclaimer -->
  <div class="mb-10 flex items-start gap-3 bg-bg-card border border-border rounded-xl p-4 text-sm text-text-muted">
    <span class="text-lg shrink-0">ℹ️</span>
    <p>
      <strong class="text-text">Affiliate disclosure:</strong> Some links below are affiliate links.
      If you click and purchase, we earn a small commission at no extra cost to you.
      We only recommend tools we've personally used. <a href="/affiliate" class="text-primary hover:underline">Full disclosure →</a>
    </p>
  </div>

  <!-- Quick nav -->
  <div class="flex flex-wrap gap-2 mb-10">
    {categories.map(cat => (
      <a
        href={`#${cat.id}`}
        class="flex items-center gap-1.5 px-4 py-2 bg-bg-card border border-border rounded-full text-sm text-text-muted hover:border-primary hover:text-text transition-colors"
      >
        <span>{cat.icon}</span>
        <span>{cat.title}</span>
      </a>
    ))}
  </div>

  <!-- Categories -->
  {categories.map(cat => (
    <section id={cat.id} class="mb-14 scroll-mt-20">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-3xl">{cat.icon}</span>
        <div>
          <h2 class="text-2xl font-bold">{cat.title}</h2>
          <p class="text-text-muted text-sm">{cat.description}</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {cat.items.map(item => (
          <div class="bg-bg-card rounded-xl border border-border hover:border-primary transition-colors group flex flex-col overflow-hidden">
            <div class="p-5 flex-1">
              <div class="flex items-start justify-between mb-3">
                <h3 class="font-bold text-base group-hover:text-primary transition-colors">{item.name}</h3>
                <span class={`text-xs font-semibold px-2 py-0.5 rounded-full border ${item.badgeColor}`}>
                  {item.badge}
                </span>
              </div>
              <p class="text-primary text-xs font-medium mb-2">{item.tagline}</p>
              <p class="text-text-muted text-sm leading-relaxed mb-4">{item.description}</p>
              <div class="flex flex-wrap gap-1.5">
                {item.tags.map(tag => (
                  <span class="text-xs bg-bg border border-border text-text-muted px-2 py-0.5 rounded">{tag}</span>
                ))}
              </div>
            </div>
            <div class="px-5 pb-5">
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                data-track="affiliate_click"
                data-resource-name={item.name}
                data-resource-category={cat.id}
                class="block w-full bg-primary hover:bg-primary-dark text-white text-sm font-semibold px-4 py-2.5 rounded-lg transition-colors text-center"
              >
                Visit {item.name} →
              </a>
            </div>
          </div>
        ))}
      </div>
    </section>
  ))}

  <!-- Bottom CTA -->
  <div class="mt-4 rounded-2xl border border-primary/30 bg-gradient-to-r from-bg-card to-bg p-6 text-center">
    <h3 class="text-xl font-bold mb-2">Missing a tool you love?</h3>
    <p class="text-text-muted text-sm mb-4">We're always expanding this list. Got a recommendation? Let us know.</p>
    <a
      href="/newsletter"
      class="inline-block bg-primary hover:bg-primary-dark text-white font-semibold px-6 py-2.5 rounded-xl text-sm transition-colors"
    >
      Join the Newsletter →
    </a>
  </div>
</BaseLayout>
