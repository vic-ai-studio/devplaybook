const allItems = categories.flatMap(cat =>
  cat.items.map(item => ({ ...item, category: cat.title }))
);
---

<BaseLayout
  title="Developer Resources & Recommended Tools"
  description="Curated affiliate links and recommended tools for developers. Cloud hosting, AI tools, databases, email, monitoring, and learning — tools DevPlaybook actually uses and trusts."
  noDefaultJsonLd
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Developer Resources & Recommended Tools | DevPlaybook",
    "description": "Curated tools and services for developers. Hosting, AI, databases, email, monitoring — with affiliate links.",
    "url": "https://devplaybook.cc/resources",
    "numberOfItems": allItems.length,
    "itemListElement": allItems.map((item, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": item.name,
      "description": item.description,
      "url": item.url,
    })),
  })} />

  <!-- Hero -->
  <div class="text-center mb-12">
    <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-3">Curated Resources</p>
    <h1 class="text-4xl font-bold mb-3">Developer <span class="text-primary">Resources</span></h1>
    <p class="text-text-muted text-lg max-w-2xl mx-auto">
      Tools and services we use and trust. Some links are affiliate links — you pay nothing extra, and commissions help keep DevPlaybook free.
    </p>
    <div class="flex flex-wrap justify-center gap-4 mt-5 text-sm text-text-muted">
      <span>✦ Personally evaluated</span>
      <span>✦ No paid placements</span>
      <span>✦ Always honest</span>
      <span>✦ {allItems.length} tools listed</span>
    </div>
  </div>

  <!-- Affiliate disclaimer -->
  <div class="mb-10 flex items-start gap-3 bg-bg-card border border-border rounded-xl p-4 text-sm text-text-muted">
    <span class="text-lg shrink-0">ℹ️</span>
    <p>
      <strong class="text-text">Affiliate disclosure:</strong> Some links below are affiliate links.
      If you click and purchase, we earn a small commission at no extra cost to you.
      We only recommend tools we've personally used. <a href="/affiliate" class="text-primary hover:underline">Full disclosure →</a>
    </p>
  </div>

  <!-- Top Picks -->
  <div class="mb-14">
    <div class="flex items-center gap-2 mb-5">
      <span class="text-2xl">⭐</span>
      <div>
        <h2 class="text-xl font-bold">Top Picks</h2>
        <p class="text-text-muted text-sm">Highest-value tools for most developers</p>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {topPicks.map(item => (
        <a
          href={item.url}
          target="_blank"
          rel="noopener noreferrer"
          data-track="affiliate_click"
          data-resource-name={item.name}
          data-resource-category="top-picks"
          class="group flex items-start gap-4 bg-bg-card border border-primary/30 hover:border-primary rounded-xl p-5 transition-colors"
        >
          <span class="text-3xl shrink-0">{item.icon}</span>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <h3 class="font-bold group-hover:text-primary transition-colors">{item.name}</h3>
              <span class={`text-xs font-semibold px-2 py-0.5 rounded-full border ${item.badgeColor}`}>
                {item.badge}
              </span>
            </div>
            <p class="text-primary text-xs font-medium mb-1">{item.tagline}</p>
            <p class="text-text-muted text-sm leading-relaxed">{item.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- Quick nav -->
  <div class="flex flex-wrap gap-2 mb-10">
    {categories.map(cat => (
      <a
        href={`#${cat.id}`}
        class="flex items-center gap-1.5 px-4 py-2 bg-bg-card border border-border rounded-full text-sm text-text-muted hover:border-primary hover:text-text transition-colors"
      >
        <span>{cat.icon}</span>
        <span>{cat.title}</span>
      </a>
    ))}
  </div>

  <!-- Categories -->
  {categories.map(cat => (
    <section id={cat.id} class="mb-14 scroll-mt-20">
      <div class="flex items-center gap-3 mb-6">
        <span class="text-3xl">{cat.icon}</span>
        <div>
          <h2 class="text-2xl font-bold">{cat.title}</h2>
          <p class="text-text-muted text-sm">{cat.description}</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {cat.items.map(item => (
          <div class="bg-bg-card rounded-xl border border-border hover:border-primary transition-colors group flex flex-col overflow-hidden">
            <div class="p-5 flex-1">
              <div class="flex items-start justify-between mb-3">
                <h3 class="font-bold text-base group-hover:text-primary transition-colors">{item.name}</h3>
                <span class={`text-xs font-semibold px-2 py-0.5 rounded-full border ${item.badgeColor}`}>
                  {item.badge}
                </span>
              </div>
              <p class="text-primary text-xs font-medium mb-2">{item.tagline}</p>
              <p class="text-text-muted text-sm leading-relaxed mb-4">{item.description}</p>
              <div class="flex flex-wrap gap-1.5">
                {item.tags.map(tag => (
                  <span class="text-xs bg-bg border border-border text-text-muted px-2 py-0.5 rounded">{tag}</span>
                ))}
              </div>
            </div>
            <div class="px-5 pb-5">
              <a
                href={item.url}
                target="_blank"
                rel="noopener noreferrer"
                data-track="affiliate_click"
                data-resource-name={item.name}
                data-resource-category={cat.id}
                class="block w-full bg-primary hover:bg-primary-dark text-white text-sm font-semibold px-4 py-2.5 rounded-lg transition-colors text-center"
              >
                Visit {item.name} →
              </a>
            </div>
          </div>
        ))}
      </div>
    </section>
  ))}

  <!-- Bottom CTA -->
  <div class="mt-4 rounded-2xl border border-primary/30 bg-gradient-to-r from-bg-card to-bg p-6 text-center">
    <h3 class="text-xl font-bold mb-2">Missing a tool you love?</h3>
    <p class="text-text-muted text-sm mb-4">We're always expanding this list. Got a recommendation? Let us know.</p>
    <a
      href="/newsletter"
      class="inline-block bg-primary hover:bg-primary-dark text-white font-semibold px-6 py-2.5 rounded-xl text-sm transition-colors"
    >
      Join the Newsletter →
    </a>
  </div>
</BaseLayout>
