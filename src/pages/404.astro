---
import BaseLayout from '../layouts/BaseLayout.astro';

const tools = [
  { name: 'JSON Formatter', href: '/tools/json-formatter', icon: '📋' },
  { name: 'UUID Generator', href: '/tools/uuid-generator', icon: '🔑' },
  { name: 'Base64 Encode/Decode', href: '/tools/base64', icon: '🔒' },
  { name: 'Regex Tester', href: '/tools/regex-tester', icon: '🔍' },
  { name: 'Cron Generator', href: '/tools/cron-generator', icon: '⏰' },
  { name: 'JWT Decoder', href: '/tools/jwt-decoder', icon: '🛡️' },
];
---

<BaseLayout title="404 — Page Not Found" description="The page you're looking for doesn't exist. Explore free developer tools, boilerplates, and guides on DevPlaybook." noindex>
  <div class="max-w-2xl mx-auto text-center py-16">
    <p class="text-8xl font-bold text-primary/30 mb-4">404</p>
    <h1 class="text-3xl font-bold mb-3">Page Not Found</h1>
    <p class="text-text-muted mb-6">The page you're looking for doesn't exist or has been moved.</p>

    <form action="/tools" method="get" role="search" class="flex gap-2 max-w-md mx-auto mb-8">
      <input
        type="search"
        name="q"
        placeholder="Search 200+ free developer tools..."
        aria-label="Search developer tools"
        class="flex-1 px-4 py-3 rounded-xl border border-border bg-bg-card text-text placeholder-text-muted focus:outline-none focus:border-primary text-sm"
        autocomplete="off"
      />
      <button type="submit" class="px-5 py-3 bg-primary hover:bg-primary-dark text-white font-semibold rounded-xl transition-colors text-sm whitespace-nowrap">
        Search
      </button>
    </form>

    <div class="flex flex-col sm:flex-row gap-3 justify-center mb-12">
      <a href="/" class="px-6 py-3 bg-primary hover:bg-primary-dark text-white font-semibold rounded-xl transition-colors">
        ← Go Home
      </a>
      <a href="/tools" class="px-6 py-3 bg-bg-card border border-border hover:border-primary text-text font-semibold rounded-xl transition-colors">
        Browse All Tools
      </a>
    </div>

    <p class="text-sm text-text-muted mb-4 font-medium">Popular free tools:</p>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      {tools.map(tool => (
        <a href={tool.href} class="flex items-center gap-2 bg-bg-card border border-border rounded-lg px-4 py-3 hover:border-primary transition-colors text-sm">
          <span>{tool.icon}</span>
          <span>{tool.name}</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
