---
import BaseLayout from '../layouts/BaseLayout.astro';

const tools = [
  {
    name: 'Vercel',
    category: 'Hosting & Deployment',
    icon: '▲',
    tagline: 'The best way to deploy modern web apps',
    description: 'Vercel makes deploying Next.js, Astro, and any frontend framework trivially easy. Push to GitHub and you\'re live in seconds — zero config needed. The free tier handles most side projects, and the developer experience is unmatched.',
    url: 'https://vercel.com/?utm_source=devplaybook&utm_medium=uses',
    cta: 'Deploy Free →',
    badge: 'Free Tier',
    badgeColor: 'text-blue-400 bg-blue-400/10 border-blue-400/30',
    highlight: true,
  },
  {
    name: 'DigitalOcean',
    category: 'Cloud & Hosting',
    icon: '🌊',
    tagline: '$200 free credit for new users',
    description: 'When you need more control than serverless offers, DigitalOcean Droplets give you a clean VPS at a predictable price. Their managed databases (Postgres, Redis, MongoDB) save hours of setup time. New accounts get $200 in credit to start.',
    url: 'https://www.digitalocean.com/?refcode=devplaybook',
    cta: 'Get $200 Credit →',
    badge: '$200 Credit',
    badgeColor: 'text-green-400 bg-green-400/10 border-green-400/30',
    highlight: true,
  },
  {
    name: 'Cloudflare',
    category: 'CDN & Edge',
    icon: '🔶',
    tagline: 'DNS, CDN, edge workers — all free to start',
    description: 'Cloudflare handles our DNS, CDN, and DDoS protection. Cloudflare Pages hosts static sites with unlimited bandwidth on the free tier. If you\'re not running your DNS through Cloudflare yet, you\'re leaving performance and security on the table.',
    url: 'https://cloudflare.com/?utm_source=devplaybook&utm_medium=uses',
    cta: 'Start Free →',
    badge: 'Free',
    badgeColor: 'text-orange-400 bg-orange-400/10 border-orange-400/30',
    highlight: false,
  },
  {
    name: 'GitHub Copilot',
    category: 'AI Tools',
    icon: '🤖',
    tagline: 'The AI pair programmer that actually ships code',
    description: 'GitHub Copilot is still the most widely-used AI code assistant for good reason — it integrates into every editor, understands your codebase context, and generates surprisingly good completions. The chat mode handles code explanations, refactoring, and test generation.',
    url: 'https://github.com/features/copilot?utm_source=devplaybook&utm_medium=uses',
    cta: 'Try Copilot →',
    badge: '$10/mo',
    badgeColor: 'text-purple-400 bg-purple-400/10 border-purple-400/30',
    highlight: false,
  },
  {
    name: 'Cursor',
    category: 'AI Tools',
    icon: '✦',
    tagline: 'The AI-native code editor',
    description: 'Cursor is VS Code with AI baked into every layer. The composer feature lets you describe changes in plain English and apply them across multiple files at once. If you\'re building anything non-trivial, Cursor noticeably reduces the time from idea to working code.',
    url: 'https://cursor.com/?utm_source=devplaybook&utm_medium=uses',
    cta: 'Try Cursor →',
    badge: 'Free Tier',
    badgeColor: 'text-cyan-400 bg-cyan-400/10 border-cyan-400/30',
    highlight: false,
  },
  {
    name: 'Linear',
    category: 'Project Management',
    icon: '📐',
    tagline: 'Issue tracking that developers actually love',
    description: 'Linear is the first project management tool that feels fast. Keyboard-first, minimal UI, no ticket-hell. It syncs with GitHub branches, has smart priority views, and makes sprint planning feel lightweight instead of bureaucratic. The free plan handles small teams well.',
    url: 'https://linear.app/?utm_source=devplaybook&utm_medium=uses',
    cta: 'Try Linear →',
    badge: 'Free for small teams',
    badgeColor: 'text-violet-400 bg-violet-400/10 border-violet-400/30',
    highlight: false,
  },
  {
    name: 'Railway',
    category: 'Hosting & Deployment',
    icon: '🚂',
    tagline: 'Deploy backends and databases in one click',
    description: 'Railway is the simplest way to deploy a Node.js, Python, or Go backend with a real database. Connect a GitHub repo, add environment variables, and you\'re running. No Kubernetes, no Helm charts. The usage-based pricing keeps costs predictable for small apps.',
    url: 'https://railway.app/?utm_source=devplaybook&utm_medium=uses',
    cta: 'Deploy on Railway →',
    badge: 'Usage-based',
    badgeColor: 'text-pink-400 bg-pink-400/10 border-pink-400/30',
    highlight: false,
  },
];

const highlighted = tools.filter(t => t.highlight);
const rest = tools.filter(t => !t.highlight);
---

<BaseLayout
  title="Tools We Use — Developer Stack & Recommendations | DevPlaybook"
  description="The exact tools DevPlaybook uses for hosting, AI coding, project management, and deployment. Vercel, DigitalOcean, Cloudflare, GitHub Copilot, Cursor, Linear, Railway — with affiliate links."
  noDefaultJsonLd
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Tools DevPlaybook Uses — Developer Stack",
    "description": "The exact tools we use at DevPlaybook: hosting, AI, project management, and deployment.",
    "url": "https://devplaybook.cc/uses",
    "numberOfItems": tools.length,
    "itemListElement": tools.map((tool, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": tool.name,
      "description": tool.description,
      "url": tool.url,
    })),
  })} />

  <!-- Hero -->
  <div class="text-center mb-12">
    <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-3">Developer Stack</p>
    <h1 class="text-4xl font-bold mb-3">Tools We <span class="text-primary">Use</span></h1>
    <p class="text-text-muted text-lg max-w-2xl mx-auto">
      The exact stack we use to build and run DevPlaybook. No sponsored placements — only tools we've actually used and trust.
    </p>
    <div class="flex flex-wrap justify-center gap-4 mt-5 text-sm text-text-muted">
      <span>✦ {tools.length} tools</span>
      <span>✦ Personally vetted</span>
      <span>✦ Updated 2026</span>
    </div>
  </div>

  <!-- Affiliate disclaimer -->
  <div class="mb-10 flex items-start gap-3 bg-bg-card border border-border rounded-xl p-4 text-sm text-text-muted">
    <span class="text-lg shrink-0">ℹ️</span>
    <p>
      <strong class="text-text">Affiliate disclosure:</strong> Some links below are affiliate links.
      If you click and sign up, we may earn a small commission — at no extra cost to you.
      We only list tools we actually use. <a href="/affiliate" class="text-primary hover:underline">Full disclosure →</a>
    </p>
  </div>

  <!-- Top picks -->
  <div class="mb-12">
    <h2 class="text-xl font-bold mb-5">⭐ Top Picks</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {highlighted.map(tool => (
        <div class="bg-bg-card border border-primary/30 rounded-2xl p-6">
          <div class="flex items-start justify-between mb-3">
            <div>
              <div class="flex items-center gap-2 mb-1">
                <span class="text-2xl">{tool.icon}</span>
                <h3 class="text-xl font-bold">{tool.name}</h3>
                <span class={`text-xs font-semibold px-2 py-0.5 rounded-full border ${tool.badgeColor}`}>
                  {tool.badge}
                </span>
              </div>
              <p class="text-primary text-sm font-medium">{tool.tagline}</p>
            </div>
          </div>
          <p class="text-text-muted text-sm leading-relaxed mb-4">{tool.description}</p>
          <a
            href={tool.url}
            target="_blank"
            rel="noopener noreferrer"
            data-track="uses_click"
            data-tool={tool.name}
            class="inline-flex items-center gap-1.5 px-4 py-2 bg-primary hover:bg-primary-dark text-white text-sm font-semibold rounded-lg transition-colors"
          >
            {tool.cta}
          </a>
        </div>
      ))}
    </div>
  </div>

  <!-- All tools -->
  <div>
    <h2 class="text-xl font-bold mb-5">🛠️ Full Stack</h2>
    <div class="space-y-4">
      {rest.map(tool => (
        <div class="bg-bg-card border border-border hover:border-primary/50 rounded-2xl p-6 transition-colors">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xl">{tool.icon}</span>
                <h3 class="text-lg font-bold">{tool.name}</h3>
                <span class="text-xs text-text-muted border border-border rounded-full px-2 py-0.5">{tool.category}</span>
                <span class={`text-xs font-semibold px-2 py-0.5 rounded-full border ${tool.badgeColor}`}>
                  {tool.badge}
                </span>
              </div>
              <p class="text-primary text-sm font-medium mb-2">{tool.tagline}</p>
              <p class="text-text-muted text-sm leading-relaxed">{tool.description}</p>
            </div>
            <div class="shrink-0">
              <a
                href={tool.url}
                target="_blank"
                rel="noopener noreferrer"
                data-track="uses_click"
                data-tool={tool.name}
                class="inline-flex items-center gap-1.5 px-4 py-2 border border-primary text-primary hover:bg-primary hover:text-white text-sm font-semibold rounded-lg transition-colors whitespace-nowrap"
              >
                {tool.cta}
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Footer CTA -->
  <div class="mt-16 text-center bg-bg-card border border-border rounded-2xl p-8">
    <h2 class="text-2xl font-bold mb-3">More developer resources</h2>
    <p class="text-text-muted mb-6">See our full curated list of developer tools, cloud services, and learning resources.</p>
    <a href="/resources" class="inline-flex items-center gap-2 px-6 py-3 bg-primary hover:bg-primary-dark text-white font-semibold rounded-xl transition-colors">
      Browse All Resources →
    </a>
  </div>
</BaseLayout>
