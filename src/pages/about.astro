---
import BaseLayout from '../layouts/BaseLayout.astro';

const stats = [
  { label: 'Free Tools', value: '40+', icon: '🛠️' },
  { label: 'Monthly Visitors', value: '5K+', icon: '👥' },
  { label: 'Countries Reached', value: '50+', icon: '🌏' },
  { label: 'Tools Curated', value: '200+', icon: '🔍' },
];

const tools = [
  { name: 'JSON Formatter', url: '/tools/json-formatter', emoji: '📋' },
  { name: 'Base64 Encoder/Decoder', url: '/tools/base64', emoji: '🔐' },
  { name: 'Regex Tester', url: '/tools/regex-tester', emoji: '🔎' },
  { name: 'Timestamp Converter', url: '/tools/timestamp', emoji: '⏱️' },
  { name: 'Color Picker', url: '/tools/color-picker', emoji: '🎨' },
  { name: 'UUID Generator', url: '/tools/uuid', emoji: '🔑' },
  { name: 'Markdown Preview', url: '/tools/markdown-preview', emoji: '📝' },
  { name: 'Hash Generator', url: '/tools/hash', emoji: '🔒' },
];

const testimonials = [
  {
    quote: "DevPlaybook is my go-to for quick dev tools. JSON formatter alone saves me 10 minutes a day.",
    author: "Full-stack developer",
    context: "via direct feedback",
  },
  {
    quote: "Finally a site where I can format JSON, convert timestamps, and check regex — all without signing up or dealing with ads.",
    author: "Backend engineer",
    context: "via email",
  },
  {
    quote: "The curated tool list is genuinely useful. Not bloated with affiliate spam — just real tools developers actually use.",
    author: "Frontend developer",
    context: "via email",
  },
];
---

<BaseLayout
  title="About DevPlaybook — Developer Productivity Tools & Resources"
  description="DevPlaybook is a free hub of 40+ developer tools: JSON formatter, Base64, Regex tester, and more. No sign-up, no ads, built by developers for developers."
>
  <!-- Hero -->
  <div class="text-center mb-16">
    <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-3">About Us</p>
    <h1 class="text-4xl font-bold mb-4">Built by Developers,<br /><span class="text-primary">For Developers</span></h1>
    <p class="text-text-muted text-lg max-w-2xl mx-auto leading-relaxed">
      DevPlaybook is a free hub of 40+ essential developer tools — no login required, no ads, no friction.
      Just fast, reliable tools you can use right now.
    </p>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
    {stats.map(s => (
      <div class="bg-bg-card border border-border rounded-2xl p-5 text-center">
        <div class="text-3xl mb-2">{s.icon}</div>
        <div class="text-3xl font-bold text-primary mb-1">{s.value}</div>
        <div class="text-sm text-text-muted">{s.label}</div>
      </div>
    ))}
  </div>

  <!-- Mission -->
  <div class="bg-bg-card border border-border rounded-2xl p-8 mb-12">
    <h2 class="text-2xl font-bold mb-4">Our Mission</h2>
    <p class="text-text-muted leading-relaxed mb-4">
      Developer tools should be <strong class="text-text">fast, free, and frictionless</strong>.
      Too many useful tools are buried behind paywalls, cluttered with ads, or require creating an account
      just to convert a timestamp.
    </p>
    <p class="text-text-muted leading-relaxed mb-4">
      We built DevPlaybook to fix that. Every tool on this site runs entirely in your browser —
      no data sent to servers, no sign-up required, no waiting. Open the page, use the tool, done.
    </p>
    <p class="text-text-muted leading-relaxed">
      Beyond tools, we curate the best resources, workflows, and references to help developers
      ship faster and learn smarter.
    </p>
  </div>

  <!-- Tools Grid -->
  <div class="mb-12">
    <h2 class="text-2xl font-bold mb-2">Popular Tools</h2>
    <p class="text-text-muted mb-6">The most-used tools on DevPlaybook — all free, all instant.</p>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      {tools.map(t => (
        <a
          href={t.url}
          class="flex items-center gap-2 bg-bg-card border border-border hover:border-primary/50 rounded-xl px-4 py-3 text-sm font-medium transition-colors"
        >
          <span>{t.emoji}</span>
          <span class="text-text">{t.name}</span>
        </a>
      ))}
    </div>
    <div class="mt-4 text-center">
      <a href="/tools" class="text-primary hover:underline text-sm font-medium">View all 40+ tools →</a>
    </div>
  </div>

  <!-- Social Proof / Testimonials -->
  <div class="mb-12">
    <h2 class="text-2xl font-bold mb-6">What Developers Say</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {testimonials.map(t => (
        <div class="bg-bg-card border border-border rounded-2xl p-6">
          <div class="text-primary text-4xl font-serif leading-none mb-3">"</div>
          <p class="text-text-muted text-sm leading-relaxed mb-4">{t.quote}</p>
          <div class="border-t border-border pt-3">
            <div class="font-semibold text-sm text-text">{t.author}</div>
            <div class="text-xs text-text-muted">{t.context}</div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Open Source / GitHub -->
  <div class="bg-bg-card border border-primary/30 rounded-2xl p-8 mb-12">
    <div class="flex items-start gap-4">
      <div class="text-4xl">⭐</div>
      <div>
        <h2 class="text-xl font-bold mb-2">Open & Transparent</h2>
        <p class="text-text-muted text-sm leading-relaxed mb-4">
          DevPlaybook is built in public. We share our stack, our tools list, and our roadmap openly.
          No black boxes, no dark patterns.
        </p>
        <p class="text-text-muted text-sm leading-relaxed mb-4">
          If you find a bug, have a tool request, or want to contribute a resource — reach out.
          We read every message.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="https://github.com"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 bg-gray-800 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg transition-colors"
          >
            ⭐ Star on GitHub
          </a>
          <a
            href="/newsletter"
            class="inline-flex items-center gap-2 px-4 py-2 border border-primary text-primary hover:bg-primary hover:text-white text-sm font-semibold rounded-lg transition-colors"
          >
            📬 Join Newsletter
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="text-center bg-bg-card border border-border rounded-2xl p-8">
    <h2 class="text-2xl font-bold mb-3">Start Using DevPlaybook</h2>
    <p class="text-text-muted mb-6">40+ free tools, no sign-up required. Open a tool and get to work.</p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a href="/tools" class="inline-flex items-center gap-2 px-6 py-3 bg-primary hover:bg-primary-dark text-white font-semibold rounded-xl transition-colors">
        Browse All Tools →
      </a>
      <a href="/resources" class="inline-flex items-center gap-2 px-6 py-3 border border-border hover:border-primary text-text hover:text-primary font-semibold rounded-xl transition-colors">
        View Resources
      </a>
    </div>
  </div>
</BaseLayout>
