---
import BaseLayout from '../layouts/BaseLayout.astro';
import DevSetupShowcase from '../components/DevSetupShowcase.tsx';
---

<BaseLayout
  title="Dev Setup Showcase"
  description="Browse and share developer setups. Discover what IDE, OS, terminal, and tools real developers swear by. Share your own dev setup and get upvoted."
  noDefaultJsonLd
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Dev Setup Showcase | DevPlaybook",
    "description": "Community-driven developer setup gallery. Browse real dev setups and share yours.",
    "url": "https://devplaybook.cc/my-dev-setup",
  })} />

  <div class="mb-10 text-center">
    <div class="text-5xl mb-4">⚙️</div>
    <h1 class="text-4xl font-bold mb-3">Dev Setup Showcase</h1>
    <p class="text-text-muted text-lg max-w-2xl mx-auto">
      What IDE, OS, and tools are developers actually using? Browse community setups and share yours.
    </p>
    <div class="flex justify-center gap-6 mt-5 text-sm text-text-muted">
      <span>✦ Real developer setups</span>
      <span>✦ Upvote your favorites</span>
      <span>✦ Share on X</span>
    </div>
  </div>

  <DevSetupShowcase client:load />
</BaseLayout>
