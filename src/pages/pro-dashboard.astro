---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Pro Dashboard | DevPlaybook"
  description="Manage your DevPlaybook Pro subscription and access all member benefits."
  noindex
>
  <!-- Loading state -->
  <div id="loading-state" class="max-w-2xl mx-auto py-16 text-center">
    <div class="text-text-muted">Loading your account...</div>
  </div>

  <!-- Not logged in state -->
  <div id="not-logged-in" class="hidden max-w-md mx-auto py-16 text-center px-4">
    <div class="text-5xl mb-4">🔒</div>
    <h1 class="text-3xl font-bold mb-3">Sign in required</h1>
    <p class="text-text-muted mb-8">Please sign in to access your Pro dashboard.</p>
    <a href="/signin" class="inline-block bg-primary hover:bg-primary-dark text-white font-bold px-8 py-3 rounded-xl transition-colors">
      Sign In
    </a>
  </div>

  <!-- Free tier state -->
  <div id="free-state" class="hidden max-w-2xl mx-auto py-16 px-4">
    <div class="text-center mb-10">
      <div class="text-5xl mb-4">👋</div>
      <h1 class="text-3xl font-bold mb-2">Your Account</h1>
      <p id="free-email" class="text-text-muted"></p>
    </div>
    <div class="bg-bg-card border border-border rounded-2xl p-8 text-center">
      <h2 class="text-xl font-semibold mb-3">You're on the Free plan</h2>
      <p class="text-text-muted mb-6">Upgrade to Pro to unlock all premium tools, templates, and member benefits.</p>
      <a href="/pricing" class="inline-block bg-primary hover:bg-primary-dark text-white font-bold px-8 py-3 rounded-xl transition-colors mb-4">
        Upgrade to Pro — $9/mo
      </a>
      <div class="mt-6 pt-6 border-t border-border">
        <form method="POST" action="/api/auth/signout">
          <button type="submit" class="text-sm text-text-muted hover:text-text transition-colors">Sign out</button>
        </form>
      </div>
    </div>
  </div>

  <!-- Pro member state -->
  <div id="pro-state" class="hidden max-w-2xl mx-auto py-16 px-4">
    <div class="text-center mb-10">
      <div class="text-5xl mb-4">⚡</div>
      <h1 class="text-3xl font-bold mb-2">Pro Dashboard</h1>
      <p id="pro-email" class="text-text-muted"></p>
      <span class="inline-block mt-2 px-3 py-1 rounded-full bg-primary/20 text-primary text-sm font-medium">
        Pro Member
      </span>
    </div>

    <!-- Pro benefits -->
    <div class="bg-bg-card border border-border rounded-2xl p-8 mb-6">
      <h2 class="text-xl font-semibold mb-5">Your Pro Benefits</h2>
      <ul class="space-y-4">
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold shrink-0 mt-0.5">✓</span>
          <div>
            <p class="font-medium">All Premium Tools &amp; Templates</p>
            <p class="text-text-muted text-sm">Including all future releases at no extra cost</p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold shrink-0 mt-0.5">✓</span>
          <div>
            <p class="font-medium">Early Access Content</p>
            <p class="text-text-muted text-sm">New tools and guides before public release</p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold shrink-0 mt-0.5">✓</span>
          <div>
            <p class="font-medium">Member-Only Discounts</p>
            <p class="text-text-muted text-sm">Exclusive discounts on all Gumroad products</p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-primary font-bold shrink-0 mt-0.5">✓</span>
          <div>
            <p class="font-medium">Priority Support</p>
            <p class="text-text-muted text-sm">Your questions answered first</p>
          </div>
        </li>
      </ul>
    </div>

    <!-- Quick links -->
    <div class="grid grid-cols-2 gap-4 mb-6">
      <a href="/tools" class="bg-bg-card border border-border hover:border-primary rounded-xl p-5 transition-colors group">
        <div class="text-2xl mb-2">🛠️</div>
        <p class="font-medium group-hover:text-primary transition-colors">Dev Tools</p>
        <p class="text-text-muted text-sm">All 15+ tools</p>
      </a>
      <a href="/products" class="bg-bg-card border border-border hover:border-primary rounded-xl p-5 transition-colors group">
        <div class="text-2xl mb-2">📦</div>
        <p class="font-medium group-hover:text-primary transition-colors">Products</p>
        <p class="text-text-muted text-sm">Templates &amp; bundles</p>
      </a>
    </div>

    <!-- Subscription management -->
    <div class="bg-bg-card border border-border rounded-2xl p-6">
      <h3 class="font-semibold mb-3">Subscription</h3>
      <p class="text-text-muted text-sm mb-4">
        Manage your billing, update payment method, or cancel anytime from your Gumroad library.
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="https://app.gumroad.com/library" target="_blank" rel="noopener noreferrer"
           class="inline-block border border-border hover:border-primary text-text font-medium px-5 py-2.5 rounded-xl transition-colors text-sm text-center">
          Manage Billing →
        </a>
        <form method="POST" action="/api/auth/signout" class="inline">
          <button type="submit" class="text-sm text-text-muted hover:text-text transition-colors px-5 py-2.5">
            Sign out
          </button>
        </form>
      </div>
    </div>
  </div>

  <script is:inline>
    (async () => {
      try {
        const res = await fetch('/api/auth/session');
        const data = await res.json();

        document.getElementById('loading-state').classList.add('hidden');

        if (!data.loggedIn) {
          document.getElementById('not-logged-in').classList.remove('hidden');
          return;
        }

        if (data.isPro) {
          document.getElementById('pro-email').textContent = data.email;
          document.getElementById('pro-state').classList.remove('hidden');
        } else {
          document.getElementById('free-email').textContent = data.email;
          document.getElementById('free-state').classList.remove('hidden');
        }
      } catch {
        document.getElementById('loading-state').classList.add('hidden');
        document.getElementById('not-logged-in').classList.remove('hidden');
      }
    })();
  </script>
</BaseLayout>
