<script>
  // Client-side filter + sort logic
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const freeOnly = document.getElementById('free-only') as HTMLInputElement;
  const tableRows = document.querySelectorAll<HTMLElement>('.tool-row');

  function applyFilters() {
    const activeTag = (document.querySelector<HTMLButtonElement>('.filter-btn.bg-primary'))?.dataset.filter ?? 'all';
    const freeChecked = freeOnly?.checked ?? false;

    tableRows.forEach(row => {
      const tags = (row.dataset.tags ?? '').split(',');
      const isFree = row.dataset.free === 'true';
      const tagMatch = activeTag === 'all' || tags.includes(activeTag);
      const freeMatch = !freeChecked || isFree;
      row.style.display = tagMatch && freeMatch ? '' : 'none';
    });
  }

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => {
        b.classList.remove('bg-primary', 'text-white', 'border-primary');
        b.classList.add('border-border', 'text-text-muted');
      });
      btn.classList.add('bg-primary', 'text-white', 'border-primary');
      btn.classList.remove('border-border', 'text-text-muted');
      applyFilters();
    });
  });

  freeOnly?.addEventListener('change', applyFilters);
</script>
