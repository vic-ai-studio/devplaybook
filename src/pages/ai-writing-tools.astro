---
import BaseLayout from '../layouts/BaseLayout.astro';

const tools = [
  {
    name: 'Jasper AI',
    logo: '✨',
    price: '$49/mo',
    freeTier: false,
    freeDetails: '7-day free trial',
    brandVoice: true,
    workflowAutomation: false,
    seoBuiltIn: 'SurferSEO integration',
    templates: '50+',
    bestFor: 'Marketing teams, brand-consistent content',
    rating: 4.1,
    href: 'https://www.jasper.ai/?fpr=devplaybook',
    tags: ['enterprise', 'brand', 'seo'],
    longForm: true,
    webSearch: false,
    languages: '25+',
  },
  {
    name: 'Copy.ai',
    logo: '📋',
    price: 'Free / $36/mo',
    freeTier: true,
    freeDetails: '2,000 words/month permanently free',
    brandVoice: true,
    workflowAutomation: true,
    seoBuiltIn: false,
    templates: '90+',
    bestFor: 'B2B outbound, workflow automation',
    rating: 4.2,
    href: 'https://www.copy.ai/?via=devplaybook',
    tags: ['free', 'automation', 'b2b'],
    longForm: true,
    webSearch: false,
    languages: '25+',
  },
  {
    name: 'Writesonic',
    logo: '✍️',
    price: '$20/mo',
    freeTier: true,
    freeDetails: '10,000 words/month free',
    brandVoice: true,
    workflowAutomation: false,
    seoBuiltIn: 'Native SEO + Article Writer',
    templates: '80+',
    bestFor: 'SEO content, bloggers, solo creators',
    rating: 4.0,
    href: 'https://writesonic.com/?via=devplaybook',
    tags: ['seo', 'free', 'budget'],
    longForm: true,
    webSearch: true,
    languages: '25+',
  },
  {
    name: 'Rytr',
    logo: '⚡',
    price: '$9/mo',
    freeTier: true,
    freeDetails: '10,000 characters/month free',
    brandVoice: false,
    workflowAutomation: false,
    seoBuiltIn: 'Basic SEO suggestions',
    templates: '40+',
    bestFor: 'Budget writers, quick drafts',
    rating: 3.8,
    href: 'https://rytr.me/?via=devplaybook',
    tags: ['free', 'budget', 'quick'],
    longForm: true,
    webSearch: false,
    languages: '30+',
  },
  {
    name: 'ChatGPT',
    logo: '🤖',
    price: 'Free / $20/mo',
    freeTier: true,
    freeDetails: 'GPT-4o free with limits; Plus $20/mo',
    brandVoice: false,
    workflowAutomation: false,
    seoBuiltIn: false,
    templates: 'Unlimited (prompts)',
    bestFor: 'General writing, brainstorming, any format',
    rating: 4.3,
    href: 'https://chatgpt.com',
    tags: ['free', 'general', 'flexible'],
    longForm: true,
    webSearch: true,
    languages: '50+',
  },
  {
    name: 'Claude',
    logo: '🧠',
    price: 'Free / $20/mo',
    freeTier: true,
    freeDetails: 'Sonnet 4 free; Pro $20/mo',
    brandVoice: false,
    workflowAutomation: false,
    seoBuiltIn: false,
    templates: 'Unlimited (prompts)',
    bestFor: 'Long-form content, nuanced writing, analysis',
    rating: 4.4,
    href: 'https://claude.ai',
    tags: ['free', 'general', 'analysis'],
    longForm: true,
    webSearch: true,
    languages: '50+',
  },
];

const allTags = ['free', 'enterprise', 'seo', 'budget', 'automation', 'b2b', 'brand', 'general', 'analysis', 'quick'];

// JSON-LD structured data
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "AI Writing Tools Comparison",
  "description": "Compare the best AI writing tools of 2026: Jasper, Copy.ai, Writesonic, Rytr, ChatGPT, and Claude. Pricing, features, free tiers, and recommendations.",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "offers": tools.map(t => ({
    "@type": "Offer",
    "name": t.name,
    "price": t.price.replace('$', '').replace('/mo', ''),
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
  })),
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.1",
    "reviewCount": tools.length.toString(),
  },
};
---

<BaseLayout
  title="Best AI Writing Tools 2026 — Jasper vs Copy.ai vs Writesonic vs Rytr"
  description="Compare the top AI writing tools of 2026: Jasper, Copy.ai, Writesonic, Rytr, ChatGPT, and Claude. Free tiers, pricing, SEO features, and honest recommendations by use case."
  canonical="/ai-writing-tools"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  {/* Breadcrumb */}
  <nav class="text-sm text-text-muted mb-6" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2">
      <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
      <li>/</li>
      <li><a href="/ai-tools" class="hover:text-primary transition-colors">AI Tools</a></li>
      <li>/</li>
      <li class="text-text font-medium">AI Writing Tools</li>
    </ol>
  </nav>

  {/* Hero */}
  <div class="mb-10">
    <div class="flex items-center gap-2 mb-3">
      <span class="text-xs font-semibold uppercase tracking-widest bg-primary/10 text-primary px-3 py-1 rounded-full">AI Writing</span>
      <span class="text-xs font-semibold uppercase tracking-widest bg-green-500/10 text-green-400 px-3 py-1 rounded-full">2026 Updated</span>
    </div>
    <h1 class="text-3xl font-bold mb-3">
      Best AI Writing Tools <span class="text-primary">2026</span> — Compared
    </h1>
    <p class="text-text-muted text-lg max-w-2xl">
      Jasper vs Copy.ai vs Writesonic vs Rytr vs ChatGPT vs Claude. Free tiers, pricing, SEO features, and which tool is right for your use case.
    </p>

    {/* Quick TL;DR */}
    <div class="mt-5 p-4 bg-bg-card border border-border rounded-xl">
      <p class="text-sm font-semibold text-text mb-2">TL;DR — Which should you pick?</p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-2 text-xs">
        <a href="https://www.jasper.ai/?fpr=devplaybook" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 p-2 rounded-lg bg-bg hover:border-primary border border-border transition-colors">
          <span>✨</span><span><strong>Jasper</strong> — Brand voice teams</span>
        </a>
        <a href="https://www.copy.ai/?via=devplaybook" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 p-2 rounded-lg bg-bg hover:border-primary border border-border transition-colors">
          <span>📋</span><span><strong>Copy.ai</strong> — B2B workflows</span>
        </a>
        <a href="https://writesonic.com/?via=devplaybook" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 p-2 rounded-lg bg-bg hover:border-primary border border-border transition-colors">
          <span>✍️</span><span><strong>Writesonic</strong> — SEO + budget</span>
        </a>
        <a href="https://rytr.me/?via=devplaybook" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 p-2 rounded-lg bg-bg hover:border-primary border border-border transition-colors">
          <span>⚡</span><span><strong>Rytr</strong> — $9/mo pick</span>
        </a>
        <a href="https://chatgpt.com" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 p-2 rounded-lg bg-bg hover:border-primary border border-border transition-colors">
          <span>🤖</span><span><strong>ChatGPT</strong> — General purpose</span>
        </a>
        <a href="https://claude.ai" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 p-2 rounded-lg bg-bg hover:border-primary border border-border transition-colors">
          <span>🧠</span><span><strong>Claude</strong> — Long-form + analysis</span>
        </a>
      </div>
    </div>
  </div>

  {/* Filter bar */}
  <div id="filter-bar" class="flex flex-wrap gap-2 mb-8">
    <button
      data-filter="all"
      class="filter-btn px-3 py-1.5 rounded-full text-sm font-medium border bg-primary text-white border-primary transition-colors"
    >All tools</button>
    {allTags.map(tag => (
      <button
        data-filter={tag}
        class="filter-btn px-3 py-1.5 rounded-full text-sm font-medium border border-border text-text-muted hover:border-primary hover:text-primary transition-colors"
      >
        {tag.replace('-', ' ')}
      </button>
    ))}
    <label class="ml-auto flex items-center gap-2 text-sm text-text-muted cursor-pointer">
      <input id="free-only" type="checkbox" class="accent-primary" />
      Free tier only
    </label>
  </div>

  {/* Desktop table */}
  <div class="hidden md:block overflow-x-auto rounded-xl border border-border mb-10">
    <table class="w-full text-sm" id="tools-table">
      <thead>
        <tr class="bg-bg-card border-b border-border text-text-muted text-left">
          <th class="px-4 py-3 font-semibold">Tool</th>
          <th class="px-4 py-3 font-semibold cursor-pointer hover:text-primary" data-sort="price">Price ↕</th>
          <th class="px-4 py-3 font-semibold">Free Tier</th>
          <th class="px-4 py-3 font-semibold">Brand Voice</th>
          <th class="px-4 py-3 font-semibold">Workflow Auto</th>
          <th class="px-4 py-3 font-semibold">SEO Built-in</th>
          <th class="px-4 py-3 font-semibold">Web Search</th>
          <th class="px-4 py-3 font-semibold">Best For</th>
        </tr>
      </thead>
      <tbody id="table-body">
        {tools.map((tool, i) => (
          <tr
            class={`tool-row border-b border-border hover:bg-bg-card/60 transition-colors ${i % 2 === 0 ? '' : 'bg-bg-card/20'}`}
            data-tags={tool.tags.join(',')}
            data-free={tool.freeTier ? 'true' : 'false'}
            data-name={tool.name}
          >
            <td class="px-4 py-3">
              <a href={tool.href} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 font-semibold hover:text-primary">
                <span class="text-xl">{tool.logo}</span>
                {tool.name}
              </a>
            </td>
            <td class="px-4 py-3 text-text-muted">{tool.price}</td>
            <td class="px-4 py-3">
              {tool.freeTier
                ? <span class="text-green-400 font-medium text-xs" title={tool.freeDetails}>✓ {tool.freeDetails}</span>
                : <span class="text-text-muted text-xs">✗ No</span>
              }
            </td>
            <td class="px-4 py-3 text-center">{tool.brandVoice ? <span class="text-green-400">✓</span> : <span class="text-text-muted">—</span>}</td>
            <td class="px-4 py-3 text-center">{tool.workflowAutomation ? <span class="text-green-400">✓</span> : <span class="text-text-muted">—</span>}</td>
            <td class="px-4 py-3 text-text-muted text-xs">{tool.seoBuiltIn || '—'}</td>
            <td class="px-4 py-3 text-center">{tool.webSearch ? <span class="text-green-400">✓</span> : <span class="text-text-muted">—</span>}</td>
            <td class="px-4 py-3 text-text-muted text-xs">{tool.bestFor}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  {/* Mobile cards */}
  <div class="md:hidden space-y-4 mb-10" id="mobile-cards">
    {tools.map(tool => (
      <div
        class="tool-row bg-bg-card border border-border rounded-xl p-5"
        data-tags={tool.tags.join(',')}
        data-free={tool.freeTier ? 'true' : 'false'}
        data-name={tool.name}
      >
        <div class="flex items-start justify-between mb-3">
          <a href={tool.href} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 font-semibold hover:text-primary text-lg">
            <span class="text-2xl">{tool.logo}</span>
            {tool.name}
          </a>
          {tool.freeTier && <span class="text-green-400 text-xs font-medium bg-green-400/10 px-2 py-0.5 rounded-full">Free tier</span>}
        </div>
        <dl class="grid grid-cols-2 gap-y-2 text-sm">
          <dt class="text-text-muted">Price</dt><dd>{tool.price}</dd>
          <dt class="text-text-muted">Free Tier</dt><dd>{tool.freeTier ? tool.freeDetails : 'No'}</dd>
          <dt class="text-text-muted">Brand Voice</dt><dd>{tool.brandVoice ? '✓ Yes' : '—'}</dd>
          <dt class="text-text-muted">SEO</dt><dd class="col-span-1">{tool.seoBuiltIn || '—'}</dd>
          <dt class="text-text-muted">Best for</dt><dd class="col-span-1 text-text-muted text-xs">{tool.bestFor}</dd>
        </dl>
        <div class="flex gap-2 mt-3 text-xs text-text-muted flex-wrap">
          {tool.brandVoice && <span class="bg-bg border border-border px-2 py-0.5 rounded">Brand Voice ✓</span>}
          {tool.workflowAutomation && <span class="bg-bg border border-border px-2 py-0.5 rounded">Workflow Auto ✓</span>}
          {tool.seoBuiltIn && <span class="bg-bg border border-border px-2 py-0.5 rounded">SEO ✓</span>}
          {tool.webSearch && <span class="bg-bg border border-border px-2 py-0.5 rounded">Web Search ✓</span>}
          {tool.longForm && <span class="bg-bg border border-border px-2 py-0.5 rounded">Long-form ✓</span>}
        </div>
      </div>
    ))}
  </div>

  {/* Feature deep-dives */}
  <section class="mb-10">
    <h2 class="text-2xl font-bold mb-6">Feature Deep-Dives</h2>
    <div class="grid md:grid-cols-2 gap-6">

      {/* Jasper */}
      <div class="bg-bg-card border border-border rounded-xl p-6">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-2xl">✨</span>
          <h3 class="text-lg font-bold">Jasper AI</h3>
          <a href="https://www.jasper.ai/?fpr=devplaybook" target="_blank" rel="noopener noreferrer" class="ml-auto text-xs text-primary hover:underline">Visit →</a>
        </div>
        <p class="text-text-muted text-sm mb-3">
          The enterprise-grade choice. Jasper's brand voice training is the most sophisticated available — it learns your vocabulary, tone, and style from existing content and applies it consistently across all outputs, even across large teams.
        </p>
        <dl class="space-y-1 text-sm mb-4">
          <div class="flex justify-between border-b border-border pb-1">
            <dt class="text-text-muted">Price</dt><dd class="font-medium">$49–$69/mo</dd>
          </div>
          <div class="flex justify-between border-b border-border pb-1">
            <dt class="text-text-muted">Free trial</dt><dd class="font-medium">7 days</dd>
          </div>
          <div class="flex justify-between border-b border-border pb-1">
            <dt class="text-text-muted">Templates</dt><dd class="font-medium">50+</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-text-muted">Languages</dt><dd class="font-medium">25+</dd>
          </div>
        </dl>
        <div class="space-y-1.5 text-xs">
          <p class="font-semibold text-text">✅ Pros:</p>
          <p class="text-text-muted">• Best-in-class brand voice training</p>
          <p class="text-text-muted">• SurferSEO integration for SEO content</p>
          <p class="text-text-muted">• Team collaboration with permissions</p>
          <p class="text-text-muted">• 10,000+ word document support</p>
          <p class="font-semibold text-text mt-2">❌ Cons:</p>
          <p class="text-text-muted">• No web search capability</p>
          <p class="text-text-muted">• Most expensive option</p>
          <p class="text-text-muted">• No workflow automation</p>
        </div>
      </div>

      {/* Copy.ai */}
      <div class="bg-bg-card border border-border rounded-xl p-6">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-2xl">📋</span>
          <h3 class="text-lg font-bold">Copy.ai</h3>
          <a href="https://www.copy.ai/?via=devplaybook" target="_blank" rel="noopener noreferrer" class="ml-auto text-xs text-primary hover:underline">Visit →</a>
        </div>
        <p class="text-text-muted text-sm mb-3">
          The workflow automation champion. Copy.ai's "Workflows" feature lets you chain multiple AI steps together — ideal for B2B teams generating outreach sequences, product descriptions, or multi-step content pipelines without manual intervention.
        </p>
        <dl class="space-y-1 text-sm mb-4">
          <div class="flex justify-between border-b border-border pb-1">
            <dt class="text-text-muted">Price</dt><dd class="font-medium">Free / $36/mo</dd>
          </div>
          <div class="flex justify-between border-b border-border pb-1">
            <dt class="text-text-muted">Free tier</dt><dd class="font-medium">2,000 words/month (permanent)</dd>
          </div>
          <div class="flex justify-between border-b border-border pb-1">
            <dt class="text-text-muted">Templates</dt><dd class="font-medium">90+</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-text-muted">Languages</dt><dd class="font-medium">25+</dd>
          </div>
        </dl>
        <div class="space-y-1.5 text-xs">
          <p class="font-semibold text-text">✅ Pros:</p>
          <p class="text-text-muted">• Powerful workflow automation (no-code)</p>
          <p class="text-text-muted">• Permanent free tier (2k words/mo)</p>
          <p class="text-text-muted">• 90+ specialized templates</p>
          <p class="text-text-muted">• Infobase feature for knowledge grounding</p>
          <p class="font-semibold text-text mt-2">❌ Cons:</p>
          <p class="text-text-muted">• No native SEO tools</p>
          <p class="text-text-muted">• No web search in outputs</p>
          <p class="text-text-muted">• Brand voice less polished than Jasper</p>
        </div>
      </div>

      {/* Writesonic */}
      <div class="bg-bg-card border border-border rounded-xl p-6">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-2xl">✍️</span>
          <h3 class="text-lg font-bold">Writesonic</h3>
          <a href="https://writesonic.com/?via=devplaybook" target="_blank" rel="noopener noreferrer" class="ml-auto text-xs text-primary hover:underline">Visit →</a>
        </div>
        <p class="text-text-muted text-sm mb-3">
          The best value + SEO pick. Writesonic bundles native SEO analysis and an AI Article Writer directly into the workflow — paste a keyword, get an outline, generate a full blog post with on-page SEO recommendations. At $20/mo it's the strongest price-to-feature ratio.
        </p>
        <dl class="space-y-1 text-sm mb-4">
          <div class="flex justify-between border-b border-border pb-1">
            <dt class="text-text-muted">Price</dt><dd class="font-medium">$20/mo</dd>
          </div>
          <div class="flex justify-between border-b border-border pb-1">
            <dt class="text-text-muted">Free tier</dt><dd class="font-medium">10,000 words/month</dd>
          </div>
          <div class="flex justify-between border-b border-border pb-1">
            <dt class="text-text-muted">Templates</dt><dd class="font-medium">80+</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-text-muted">Languages</dt><dd class="font-medium">25+</dd>
          </div>
        </dl>
        <div class="space-y-1.5 text-xs">
          <p class="font-semibold text-text">✅ Pros:</p>
          <p class="text-text-muted">• Built-in SEO + Article Writer (no extra SaaS)</p>
          <p class="text-text-muted">• Chatsonic web search in outputs</p>
          <p class="text-text-muted">• Generous free tier (10k words)</p>
          <p class="text-text-muted">• $20/mo — best price-to-feature ratio</p>
          <p class="font-semibold text-text mt-2">❌ Cons:</p>
          <p class="text-text-muted">• Brand voice less sophisticated than Jasper</p>
          <p class="text-text-muted">• No workflow automation</p>
          <p class="text-text-muted">• Interface can feel busy</p>
        </div>
      </div>

      {/* Rytr */}
      <div class="bg-bg-card border border-border rounded-xl p-6">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-2xl">⚡</span>
          <h3 class="text-lg font-bold">Rytr</h3>
          <a href="https://rytr.me/?via=devplaybook" target="_blank" rel="noopener noreferrer" class="ml-auto text-xs text-primary hover:underline">Visit →</a>
        </div>
        <p class="text-text-muted text-sm mb-3">
          The budget workhorse. At $9/mo, Rytr delivers the essentials without the premium price tag. Best for individuals or small teams who need quick, reliable AI drafts — not advanced brand training or automation. The free tier (10k chars/mo) is genuinely useful, not a trial.
        </p>
        <dl class="space-y-1 text-sm mb-4">
          <div class="flex justify-between border-b border-border pb-1">
            <dt class="text-text-muted">Price</dt><dd class="font-medium">$9/mo</dd>
          </div>
          <div class="flex justify-between border-b border-border pb-1">
            <dt class="text-text-muted">Free tier</dt><dd class="font-medium">10,000 chars/month (permanent)</dd>
          </div>
          <div class="flex justify-between border-b border-border pb-1">
            <dt class="text-text-muted">Templates</dt><dd class="font-medium">40+</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-text-muted">Languages</dt><dd class="font-medium">30+</dd>
          </div>
        </dl>
        <div class="space-y-1.5 text-xs">
          <p class="font-semibold text-text">✅ Pros:</p>
          <p class="text-text-muted">• Cheapest paid plan ($9/mo)</p>
          <p class="text-text-muted">• Permanent free tier</p>
          <p class="text-text-muted">• 30+ supported languages</p>
          <p class="text-text-muted">• Chrome extension available</p>
          <p class="font-semibold text-text mt-2">❌ Cons:</p>
          <p class="text-text-muted">• No brand voice training</p>
          <p class="text-text-muted">• No workflow automation</p>
          <p class="text-text-muted">• Limited SEO capabilities</p>
        </div>
      </div>

    </div>
  </section>

  {/* ChatGPT + Claude */}
  <section class="mb-10">
    <h2 class="text-2xl font-bold mb-6">General-Purpose AI Assistants</h2>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-bg-card border border-border rounded-xl p-6">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-2xl">🤖</span>
          <h3 class="text-lg font-bold">ChatGPT</h3>
          <a href="https://chatgpt.com" target="_blank" rel="noopener noreferrer" class="ml-auto text-xs text-primary hover:underline">Visit →</a>
        </div>
        <p class="text-text-muted text-sm mb-3">
          Not a dedicated writing tool — but for many writers, it doesn't need to be. GPT-4o handles everything from blog post drafting to email sequences to code documentation. The advantage: unlimited format flexibility, web search, and $0 extra cost if you already have Plus.
        </p>
        <dl class="space-y-1 text-sm mb-4">
          <div class="flex justify-between border-b border-border pb-1">
            <dt class="text-text-muted">Price</dt><dd class="font-medium">Free / $20/mo Pro</dd>
          </div>
          <div class="flex justify-between border-b border-border pb-1">
            <dt class="text-text-muted">Free tier</dt><dd class="font-medium">GPT-4o (with limits)</dd>
