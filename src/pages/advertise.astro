---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Advertise on DevPlaybook"
  description="Reach 10,000+ developers monthly. Sponsor a tool page, blog post, or newsletter. No middleman — direct deals only."
>
  <!-- Hero -->
  <div class="max-w-3xl mx-auto text-center mb-16">
    <p class="text-xs font-semibold uppercase tracking-widest text-primary mb-3">Sponsor & Partner</p>
    <h1 class="text-4xl font-bold mb-4">Reach Developers<br class="hidden sm:block" /> Who Actually Build Things</h1>
    <p class="text-text-muted text-lg max-w-2xl mx-auto">
      DevPlaybook serves 10,000+ developers per month with free tools, guides, and productivity resources.
      Our audience is hands-on engineers, indie hackers, and startup builders.
    </p>
  </div>

  <!-- Audience Stats -->
  <div class="grid sm:grid-cols-3 gap-6 mb-16 max-w-3xl mx-auto">
    <div class="bg-bg-card border border-border rounded-xl p-6 text-center">
      <p class="text-3xl font-bold text-primary mb-1">10K+</p>
      <p class="text-text-muted text-sm">Monthly visitors</p>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-6 text-center">
      <p class="text-3xl font-bold text-primary mb-1">50+</p>
      <p class="text-text-muted text-sm">Free developer tools</p>
    </div>
    <div class="bg-bg-card border border-border rounded-xl p-6 text-center">
      <p class="text-3xl font-bold text-primary mb-1">56+</p>
      <p class="text-text-muted text-sm">Technical blog articles</p>
    </div>
  </div>

  <!-- Audience Profile -->
  <div class="max-w-3xl mx-auto mb-16">
    <h2 class="text-2xl font-bold mb-6 text-center">Who Reads DevPlaybook</h2>
    <div class="grid sm:grid-cols-2 gap-4">
      {[
        { icon: '👨‍💻', label: 'Full-stack developers', desc: 'Building web apps, APIs, and SaaS products' },
        { icon: '🚀', label: 'Indie hackers', desc: 'Shipping side projects and launching products' },
        { icon: '🤖', label: 'AI / LLM builders', desc: 'Integrating Claude, GPT-4, and MCP tools' },
        { icon: '⚙️', label: 'DevOps & infra engineers', desc: 'Docker, CI/CD, cloud deployment workflows' },
      ].map(({ icon, label, desc }) => (
        <div class="flex items-start gap-3 bg-bg-card border border-border rounded-xl p-4">
          <span class="text-2xl shrink-0">{icon}</span>
          <div>
            <p class="font-semibold text-sm text-text">{label}</p>
            <p class="text-xs text-text-muted mt-0.5">{desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Sponsorship Options -->
  <div class="max-w-3xl mx-auto mb-16">
    <h2 class="text-2xl font-bold mb-6 text-center">Sponsorship Options</h2>
    <div class="space-y-4">
      {[
        {
          name: 'Tool Page Sponsor',
          price: '$49 / month',
          desc: 'Your logo + link on a high-traffic tool page (e.g. JSON Formatter, JWT Decoder). Seen by developers actively using the tool.',
          highlight: false,
        },
        {
          name: 'Blog Post Sponsor',
          price: '$79 / post',
          desc: 'Sponsored callout in a published article. Permanent link — SEO value included. Matches to relevant content by your use case.',
          highlight: false,
        },
        {
          name: 'Newsletter Sponsor',
          price: '$99 / edition',
          desc: 'Dedicated sponsor section in our weekly developer newsletter. Delivered to subscribed developers who opted in.',
          highlight: true,
        },
        {
          name: 'Homepage Feature',
          price: '$149 / month',
          desc: 'Logo + short tagline in the homepage hero or "Used by developers" trust section. Maximum visibility.',
          highlight: false,
        },
      ].map(({ name, price, desc, highlight }) => (
        <div class={`rounded-xl p-6 border ${highlight ? 'border-primary/60 bg-primary/5' : 'border-border bg-bg-card'}`}>
          <div class="flex items-start justify-between gap-4 mb-2">
            <h3 class="font-semibold text-text">{name}</h3>
            <span class={`text-sm font-bold shrink-0 ${highlight ? 'text-primary' : 'text-text-muted'}`}>{price}</span>
          </div>
          <p class="text-sm text-text-muted">{desc}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- What We Won't Do -->
  <div class="max-w-3xl mx-auto mb-16 bg-bg-card border border-border rounded-xl p-6">
    <h2 class="text-lg font-bold mb-3">Editorial Standards</h2>
    <ul class="space-y-2 text-sm text-text-muted">
      <li class="flex items-start gap-2"><span class="text-green-400 shrink-0">✓</span> Sponsored content is clearly labeled</li>
      <li class="flex items-start gap-2"><span class="text-green-400 shrink-0">✓</span> We only feature products relevant to developers</li>
      <li class="flex items-start gap-2"><span class="text-red-400 shrink-0">✗</span> No crypto, gambling, or low-quality link farms</li>
      <li class="flex items-start gap-2"><span class="text-red-400 shrink-0">✗</span> No pop-ups or interstitial ads</li>
    </ul>
  </div>

  <!-- CTA -->
  <div class="max-w-xl mx-auto text-center bg-bg-card border border-primary/30 rounded-2xl p-8">
    <h2 class="text-2xl font-bold mb-2">Get in Touch</h2>
    <p class="text-text-muted mb-6 text-sm">
      Email us with your product, target page / audience, and budget. We'll respond within 2 business days.
    </p>
    <a
      href="mailto:ads@devplaybook.cc"
      class="inline-block bg-primary hover:bg-primary-dark text-white font-semibold px-8 py-3 rounded-xl transition-colors text-sm"
    >
      Contact: ads@devplaybook.cc
    </a>
    <p class="text-text-muted text-xs mt-4">No agencies. Direct deals only. Rates are negotiable for long-term sponsors.</p>
  </div>
</BaseLayout>
