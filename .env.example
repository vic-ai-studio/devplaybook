# devplaybook.cc — Cloudflare Pages 環境變數範例
# 複製為 .env.local 填入實際值；Cloudflare Pages 上用 wrangler secrets 或 Pages UI 設定
# 不要 commit .env.local

# ── Stripe 金流 ────────────────────────────────────────────────────────────────
# 取得：https://dashboard.stripe.com/apikeys
# 驗證：python tools/verify_stripe.py
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Google AdSense 廣告 ────────────────────────────────────────────────────────
# 取得：AdSense 帳號 → 設定 → 帳戶資訊 → 發布者 ID
# 格式：ca-pub-XXXXXXXXXXXXXXXXX
# 設為 PUBLIC_ 前綴讓前端讀取；3 個廣告位會自動啟用（head auto-ads + 文章中 + 首頁橫幅）
PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-...

# ── Buttondown 電子報 ──────────────────────────────────────────────────────────
# 取得：https://buttondown.com/settings/api  (免費，100 名訂閱者)
# 設定後：python tools/newsletter/setup_buttondown_sequences.py
BUTTONDOWN_API_KEY=

# ── Cloudflare Web Analytics ──────────────────────────────────────────────────
# 取得：Cloudflare Analytics → Web Analytics → your site → token
PUBLIC_CF_ANALYTICS_TOKEN=

# ── Resend 交易郵件 (magic link 登入) ────────────────────────────────────────
# 取得：https://resend.com/api-keys
RESEND_API_KEY=re_...

# ── KV Namespace（由 wrangler.toml 綁定，下列僅供參考）────────────────────────
# DEV_SETUPS        = e3a170ada7f24614aeda02f05d65321a
# SUBSCRIBERS       = 0526f357f31840868ddf9205e4a5c926
# ANALYTICS         = 30ee9f01d8eb4faf9120398ccb3dc70c
# NEWSLETTER_KV     = 1ca6a0dc6080480da7c8bc70298dd5f9
# AUTH_KV           = 63038dc567194c5d84cf66a0cf0ed918
# （KV 不需要 .env，wrangler.toml 已設定）

# ── Google Analytics 4 ───────────────────────────────────────────────────────
# 取得：GA4 → 管理 → 資料串流 → 評估 ID (格式 G-XXXXXXXXXX)
# 設為 PUBLIC_ 前綴讓前端讀取；設定後自動啟用 gtag.js + 轉換事件追蹤
PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Discord 通報（可選）──────────────────────────────────────────────────────
DISCORD_REPORTS_WEBHOOK=
