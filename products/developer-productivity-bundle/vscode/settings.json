{
  // ==========================================================================
  // DevPlaybook VS Code Settings — Optimized for Developer Productivity
  // Version: 1.0 | devplaybook.cc
  // INSTALL: Copy to: ~/Library/Application Support/Code/User/settings.json (macOS)
  //                   ~/.config/Code/User/settings.json (Linux)
  //                   %APPDATA%\Code\User\settings.json (Windows)
  // ==========================================================================

  // --- Editor Core ---
  "editor.fontSize": 14,
  "editor.fontFamily": "'JetBrains Mono', 'Fira Code', Consolas, monospace",
  "editor.fontLigatures": true,
  "editor.lineHeight": 1.6,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": true,
  "editor.wordWrap": "off",
  "editor.rulers": [80, 120],
  "editor.cursorBlinking": "phase",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "editor.mouseWheelZoom": true,

  // --- Productivity: IntelliSense & Completions ---
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "off",
    "strings": "on"
  },
  "editor.suggestOnTriggerCharacters": true,
  "editor.acceptSuggestionOnEnter": "on",
  "editor.tabCompletion": "on",
  "editor.snippetSuggestions": "top",
  "editor.parameterHints.enabled": true,

  // --- Code Quality ---
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true
  },
  "[go]": {
    "editor.defaultFormatter": "golang.go",
    "editor.formatOnSave": true
  },

  // --- Navigation & Multi-cursor ---
  "editor.multiCursorModifier": "alt",
  "editor.columnSelection": false,
  "editor.minimap.enabled": false,
  "editor.breadcrumbs.enabled": true,
  "editor.stickyScroll.enabled": true,
  "editor.folding": true,
  "editor.showFoldingControls": "mouseover",

  // --- Find & Replace ---
  "editor.find.addExtraSpaceOnTop": false,
  "editor.find.autoFindInSelection": "multiline",

  // --- Terminal ---
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.fontFamily": "'JetBrains Mono', monospace",
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.scrollback": 10000,

  // --- Files ---
  "files.autoSave": "onFocusChange",
  "files.trimTrailingWhitespace": true,
  "files.trimFinalNewlines": false,
  "files.insertFinalNewline": true,
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/dist": false,
    "**/build": false
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.git/objects/**": true,
    "**/dist/**": true
  },

  // --- Workbench & UI ---
  "workbench.colorTheme": "One Dark Pro",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.startupEditor": "none",
  "workbench.tree.indent": 16,
  "workbench.editor.enablePreview": false,
  "workbench.editor.showTabs": "multiple",
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 10,
  "workbench.statusBar.visible": true,
  "workbench.activityBar.location": "default",

  // --- Git ---
  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "git.autofetchPeriod": 180,
  "git.confirmSync": false,
  "git.pruneOnFetch": true,
  "git.openRepositoryInParentFolders": "always",
  "scm.defaultViewMode": "tree",

  // --- Explorer ---
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.sortOrder": "type",
  "explorer.compactFolders": false,

  // --- Search ---
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.git": true,
    "**/package-lock.json": true
  },
  "search.useIgnoreFiles": true,
  "search.smartCase": true,

  // --- Language Specific ---
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.preferences.importModuleSpecifier": "relative",
  "typescript.inlayHints.parameterNames.enabled": "literals",
  "typescript.inlayHints.variableTypes.enabled": false,

  // --- Extensions: Prettier ---
  "prettier.singleQuote": true,
  "prettier.semi": false,
  "prettier.trailingComma": "es5",
  "prettier.printWidth": 100,
  "prettier.arrowParens": "avoid",

  // --- Extensions: ESLint ---
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],
  "eslint.run": "onSave",

  // --- Zen Mode ---
  "zenMode.centerLayout": true,
  "zenMode.hideLineNumbers": false,
  "zenMode.hideStatusBar": false,
  "zenMode.silentNotifications": true,

  // ==========================================================================
  // TIP: Install these recommended extensions:
  // - esbenp.prettier-vscode (Prettier)
  // - dbaeumer.vscode-eslint (ESLint)
  // - eamodio.gitlens (GitLens)
  // - zhuangtongfa.material-theme (One Dark Pro)
  // - PKief.material-icon-theme (Material Icons)
  // - ms-python.python (Python)
  // - golang.go (Go)
  // ==========================================================================
}
